	},
	["0058_00236"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00101", file3="ikuko_01m_00309", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1202", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I got all the documents together in your place. Plus I got some dinner for you. You’d better be thankful!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我已经替你把资料给整理好了呢。连礼酱的晚餐都帮你留好了喔。可要好～好的谢谢我唷！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我已經替妳把資料給整理好了呢。連禮醬的晚餐都幫你留好了喔。可要好～好的謝謝我唷！」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00235",
		linknext = "0058_00237",
		line = 3247,
	},
	["0058_00237"] = {
		{"fg", file="rei_01f_00007", file1="rei_01f_00103", file2="rei_01f_00202", path=":fg/rei_01f/", id=30, ch="礼", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1089", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Oh, okay! Thank you! I’m sorry for inconveniencing you like that, Ikuko.”",
