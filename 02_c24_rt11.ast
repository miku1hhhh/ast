			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Ohhh? Hey, ’Bana, are you going for the direct approach? Finally facing up to your feelings? Adorable!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“喔？橘同学你莫非是那个啊！？所以我们最后还是要去突袭礼教官了嘛！？好猛！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「喔？橘同學你莫非是那個啊！？所以我們最後還是要去突襲禮教官了嘛！？好猛！？」",
					{"rt2"},
				},
			},
		},
