		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1201", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Rei! Where have you been? You were supposed to be meeting with Mizuhiki about the next event!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“啊，礼酱。真是的，都这个时间了，是去哪了呢？关于下一次的活动，不是预定好要和水引酱商量的嘛──？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「啊，禮醬。真是的，都這個時間了，是去哪了呢？關於下一次的活動，不是預定好要和水引醬商量的嘛──？」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00234",
		linknext = "0058_00236",
