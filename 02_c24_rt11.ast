	["0058_00160"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My reply catches in my throat.",
					{"rt2"},
				},
			},
			cn = {
				{
					"反驳的话语鲠在我的喉头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"反駁的話語鯁在我的喉頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00159",
		linknext = "0058_00161",
		line = 2280,
	},
	["0058_00161"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1062", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“If I had known you were part of the Anti-Copulation Front, I would’ve sent you straight to the guillotine, no mercy. I hated your kind so much...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“若知道你们是反交尾势力的话，我肯定会毫不留情的送你们上断头台的吧……我也只能憎恨着……那些摆脱强制性交的家伙了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「若知道你們是反交尾勢力的話，我肯定會毫不留情的送你們上斷頭台的吧……我也只能憎恨著……那些擺脫強制性交的傢伙了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00160",
		linknext = "0058_00162",
		line = 2292,
	},
	["0058_00162"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1063", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“And if that failed, I would’ve taken you to the SHO HQ basement. You would’ve been tortured until you submitted to the law, no matter how long it took.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“如果上了断头台还不悔改，应该会被带去SHO总部大楼的地下去。肯定会在那里接受无止尽的拷问，直到你们对服从条例吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「如果上了斷頭台還不悔改，應該會被帶去SHO總部大樓的地下去。肯定會在那裡接受無止盡的拷問，直到你們對服從條例吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00161",
		linknext = "0058_00163",
		line = 2304,
	},
	["0058_00163"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00209", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Stop!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……请你别再说了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……請你別再說了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00162",
		linknext = "0058_00164",
		line = 2316,
	},
	["0058_00164"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1064", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Your precious friends would be imprisoned, put in a living hell, constantly assaulted. I would’ve been responsible for—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“将你最珍贵的伙伴囚禁起来，让他们经历地狱般的苦难……让事情演变至此的罪魁祸首，你还──。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「將你最珍貴的夥伴囚禁起來，讓他們經歷地獄般的苦難……讓事情演變至此的罪魁禍首，你還──。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00163",
		linknext = "0058_00165",
		line = 2328,
	},
	["0058_00165"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00228", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I SAID STOP!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“请别再说这些话了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「請別再說這些話了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00164",
		linknext = "0058_00166",
		line = 2340,
	},
	["0058_00166"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00228", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="rcg01010102", x=0, y=0, path=":cg/rcg01/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What the hell is the point of all this theoretical stuff? ‘I would’ve’ this, ‘You would’ve’ that... My friends didn’t end up like that, remember?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你拿出这样的假设是要表示什么！？现实是我的伙伴并没有遭遇到这种事啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你拿出這樣的假設是要表示什麼！？現實是我的夥伴並沒有遭遇到這種事啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00165",
		linknext = "0058_00167",
		line = 2356,
	},
	["0058_00167"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="rcg01010107", x=0, y=0, path=":cg/rcg01/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1065", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Is that... what you really think?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……你真的是这么想的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……你真的是這麼想的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00166",
		linknext = "0058_00168",
		line = 2372,
	},
	["0058_00168"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What?",
					{"rt2"},
				},
			},
			cn = {
				{
					"我还在想是怎么一回事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我還在想是怎麼一回事。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00167",
		linknext = "0058_00169",
