	["0058_00221"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1084", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I really enjoyed the time we spent together. Of course, some of it was tough, but it really was fun.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“在那边度过的日子都太开心了。虽然糟糕的事情也是一大堆……现在想起，还是那么觉得。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「在那邊度過的日子都太開心了。雖然糟糕的事情也是一大堆……現在想起，還是那麼覺得。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00220",
		linknext = "0058_00222",
		line = 3015,
	},
	["0058_00222"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1085", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“But it was an aberration. It shouldn’t have happened. Let’s go back to where we were before... Tachibana.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不过，果然……那样的事……真的就不该发生的。所以啊。就让一切都回到原点吧……──橘。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不過，果然……那樣的事……真的就不該發生的。所以啊。就讓一切都回到原點吧……──橘。」",
					{"rt2"},
				},
			},
		},
