		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A certain someone summed it up like this: “Yoosa got isekai’d by a sex sleeve, and brought back by a butt warp drive!”",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不会说是谁说的，但总结成一句话“靠着超级飞机杯去到了异世界，再靠着扭曲菊花回来了美！”。",
					{"rt2"},
				},
			},
			tw = {
				{
