	["0058_00159"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="rcg01010104", x=0, y=0, path=":cg/rcg01/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1061", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“What if I had done something to your friends? What if it was your sister? Would you still be saying that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“就算我……将你的伙伴……或妹妹亲手了结了……你还会说出同样的话吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「就算我……將你的夥伴……或妹妹親手了結了……你還會說出同樣的話嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00158",
