	["0058_00181"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00226", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Meaningless speculation. You never took anything from me. Not even once.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“都是毫无意义的假设啊……现实是，礼前辈并没有从我身边夺走任何东西啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「都是毫無意義的假設啊……現實是，禮前輩並沒有從我身邊奪走任何東西啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00180",
		linknext = "0058_00182",
		line = 2540,
	},
	["0058_00182"] = {
