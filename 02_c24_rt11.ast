	},
	["0058_00169"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I really don’t like the sound of that. I can’t even ask her to continue.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过，因为她的回话太令我害怕──所以无法催促着她说下去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過，因爲她的回話太令我害怕──所以無法催促著她說下去。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00168",
		linknext = "0058_00170",
		line = 2392,
	},
	["0058_00170"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1066", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“The people I sentenced, they were just the same as you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“被我所制裁的是……跟你们没什么两样的人们啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「被我所制裁的是……跟你們沒什麼兩樣的人們啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00169",
		linknext = "0058_00171",
		line = 2404,
	},
	["0058_00171"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1067", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Some of them were clever. Some were strong and well-trained. Some sacrificed themselves to let their partner escape.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不只是有头脑聪明的人。或是运动神经好的人。又或是为了帮助恋人逃脱而选择自我牺牲的家伙。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不只是有頭腦聰明的人。或是運動神經好的人。又或是為了幫助戀人逃脫而選擇自我犧牲的傢伙。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00170",
		linknext = "0058_00172",
		line = 2416,
	},
	["0058_00172"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1068", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“They went to the basement. To the same fate that I suffered. And they gave up their partners every time. I crushed that love out of them, and I did it with ease.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我将他们带到了地下。让他们受了和我同样的苦。然后让他们说出恋人的身份。毫不在意地践踏了只想和相爱之人在一起的那份心意。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我將他們帶到了地下。讓他們受了和我同樣的苦。然後讓他們說出戀人的身份。毫不在意地踐踏了只想和相愛之人在一起的那份心意。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00171",
		linknext = "0058_00173",
		line = 2428,
	},
	["0058_00173"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file3="jun_01f_00305", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But it wasn’t easy... was it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……并不是毫不在意，不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……並不是毫不在意，不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00172",
		linknext = "0058_00174",
		line = 2440,
	},
	["0058_00174"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I force out a response, but Rei doesn’t seem to be listening.",
					{"rt2"},
				},
			},
			cn = {
				{
					"都已经说到这个份上了，礼前辈还是不领情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"都已經說到這個份上了，禮前輩還是不領情。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00173",
