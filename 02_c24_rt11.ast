				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Of course we didn’t get “too close.”",
					{"rt2"},
				},
			},
			cn = {
				{
					"太过亲近什么的，我可从没这么想过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"太過親近什麼的，我可從沒這麼想過。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00223",
		linknext = "0058_00225",
		line = 3049,
	},
	["0058_00225"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I want to be close. I want to be closer to Rei than anyone else in the world.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我想变得更亲近一些。比任何人都想要待在礼前辈身边。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我想變得更親近一些。比任何人都想要待在禮前輩身邊。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00224",
		linknext = "0058_00226",
		line = 3059,
	},
	["0058_00226"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I believe this from the bottom of my heart. And I confessed my feelings to her openly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是发自内心这么想的。这就是为什么我要赤裸裸的告诉她我的感受。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是發自內心這麼想的。這就是為什麼我要赤裸裸的告訴她我的感受。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00225",
		linknext = "0058_00227",
		line = 3069,
	},
	["0058_00227"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But why is her smile so sad?",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，为什么礼前辈却是看似如此悲伤地笑着呢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，為什麼禮前輩卻是看似如此悲傷地笑著呢。",
