	["0058_00192"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1077", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“If you go out with me... you’ll realize it too. When we come across a random man on the island, you’ll think ‘Has she been with him?’ I don’t want you to go through that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“如果和我交往的话……再怎么不愿意也肯定会在意这件事。即便是和岛上的男人擦肩而过……可能也会……让你想起那些不好的事情吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「如果和我交往的話……再怎麼不願意也肯定會在意這件事。即便是和島上的男人擦肩而過……可能也會……讓你想起那些不好的事情吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00191",
		linknext = "0058_00193",
		line = 2694,
	},
	["0058_00193"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1078", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You’ll end up hating this island all over again. And I don’t want that. More than anything in the world, I don’t want that to happen...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“也许你可能又会讨厌这座岛也说不定……我……并不想让你有那样子的感觉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「也許你可能又會討厭這座島也說不定……我……並不想讓你有那樣子的感覺……」",
					{"rt2"},
				},
			},
		},
