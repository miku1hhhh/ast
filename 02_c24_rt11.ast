			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I don’t even remember how many... I lost count so long ago. Can you believe that? I’m an awful woman...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“连我自己都记不得了……很久之前，我就放弃去计算了……你能相信吗？我……就是那样的女人啊……”",
					{"rt2"},
				},
			},
			tw = {
