	["0058_00089"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. I never expected to end up living with you and the others at the FS dorms, to be honest.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说的也是……倒是也没想到会和礼前辈们一起在FS宿舍里面生活呢。”",
					{"rt2"},
