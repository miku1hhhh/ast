		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That should be a relief... but if anything, my heart rate is even higher than it was a second ago.",
					{"rt2"},
				},
			},
			cn = {
				{
					"尽管最紧张的时刻过去了──心跳还是发了狂般的急速跳着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"儘管最緊張的時刻過去了──心跳還是發了狂般的急速跳著。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00113",
		linknext = "0058_00115",
		line = 1751,
	},
	["0058_00115"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Time seems to slow to a crawl.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仿佛有了时间停止一般的错觉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"彷彿有了時間停止一般的錯覺。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00114",
		linknext = "0058_00116",
		line = 1761,
	},
	["0058_00116"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A single second starts to feel like a minute, or even an hour.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在的1秒，感觉就像是过了1分钟甚至1小时的样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在的1秒，感覺就像是過了1分鐘甚至1小時的樣子。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00115",
		linknext = "0058_00117",
		line = 1771,
	},
	["0058_00117"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can feel my fingers twitching, and my knees feel like they’re about to give way, and my mouth is so dry it’s making my throat sore.",
					{"rt2"},
				},
			},
			cn = {
				{
					"指尖在颤抖着，双腿也像是发软一般，口干舌燥到嗓子发疼的地步。",
					{"rt2"},
				},
			},
			tw = {
				{
					"指尖在顫抖著，雙腿也像是發軟一般，口乾舌燥到嗓子發疼的地步。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00116",
		linknext = "0058_00118",
		line = 1781,
	},
