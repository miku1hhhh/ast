				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Haha, I’m honored that I was able to help out. Glorious Hero of the Lewd War sounds like a pretty impressive title.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……哈哈，要是能帮上忙的话，会是我的荣幸。变态战役英雄的伙伴啊……还真是了不起的称号呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……哈哈，要是能幫上忙的話，會是我的榮幸。變態戰役英雄的夥伴啊……還真是了不起的稱號呢？」",
					{"rt2"},
