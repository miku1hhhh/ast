	["0058_00086"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="rcg01010203", x=0, y=0, path=":cg/rcg01/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1046", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Heh. Well, going to another world was a pretty crazy experience. I can’t believe it’s only been a week since we got back.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“呵呵……不过，前往其他世界真的是一个奇妙的体验呢。在那之后过了还没一周……老实说，还是很难以置信呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「呵呵……不過，前往其他世界真的是一個奇妙的體驗呢。在那之後過了還沒一周……老實說，還是很難以置信呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00085",
		linknext = "0058_00087",
		line = 1424,
	},
	["0058_00087"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
