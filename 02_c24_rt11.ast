			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Watch out there, sonny, I might just grab that pretty little face of yours and twist it until no one will recognize you! Ah, but maybe you’re into that. Clever boy!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“哇呜你要是认真的欺负我的话，我就会把你变成我喜欢的那种脸，但如果是这样的话，我会很难做出反应……学聪明了呢，辈前……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「哇嗚你要是認真的欺負我的話，我就會把你變成我喜歡的那種臉，但如果是這樣的話，我會很難做出反應……學聰明了呢，輩前……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00041",
		linknext = "0058_00043",
		line = 753,
	},
	["0058_00043"] = {
