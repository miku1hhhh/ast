		{"evset", file="rcg01010202", set="rcg010102", path=":ev/rcg010102/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="rcg01010202", x=0, y=0, path=":cg/rcg01/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1045", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“How about ‘Hardened Hero of the Ins-erection?’ That’s another name I’ve heard. Pretty accurate, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是有听人家说过改变世界的勃起。还是说改成改世勃起英雄会比较好呢？要让你全身都能勃起。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是有聽人家說過改變世界的勃起。還是說改成改世勃起英雄會比較好呢？要讓你全身都能勃起。」",
					{"rt2"},
				},
			},
		},
