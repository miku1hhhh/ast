				},
			},
			cn = {
				{
					"我再也找不出能说的话了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我再也找不出能說的話了。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00200",
		linknext = "0058_00202",
		line = 2786,
	},
	["0058_00202"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1079", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You haven’t lost His Sexellency’s memories, have you? You must understand, surely?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“做为性帝的记忆并没有消失不见吧……？这样的话……呐，你能理解的吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「做為性帝的記憶並沒有消失不見吧……？這樣的話……吶，你能理解的吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00201",
		linknext = "0058_00203",
		line = 2798,
	},
	["0058_00203"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"His Sexellency. The Junnosuke Tachibana of World B.",
					{"rt2"},
				},
			},
			cn = {
				{
					"性帝。是B世界的橘淳之介。",
					{"rt2"},
				},
			},
			tw = {
				{
					"性帝。是B世界的橘淳之介。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00202",
		linknext = "0058_00204",
		line = 2808,
	},
	["0058_00204"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He was forced into sexual activity to save his sister, and punished people ruthlessly for breaking the law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了妹妹，被迫进行了非自愿的性行为，并毫不留情地逞罚那些违反条例之人的男人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"爲了妹妹，被迫進行了非自願的性行為，並毫不留情地逞罰那些違反條例之人的男人。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00203",
		linknext = "0058_00205",
		line = 2818,
	},
	["0058_00205"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I had experienced just a small fraction of his pain and suffering through his memories.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那份痛苦──尽管只是其中的一小部份──我也确时地重新体会过了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那份痛苦──儘管只是其中的一小部份──我也確時地重新體會過了。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00204",
		linknext = "0058_00206",
		line = 2828,
	},
	["0058_00206"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He always regretted what he did to Nanase. He kept it with him forever.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他──永远记得曾经对奈奈濑所犯下的过错。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他──永遠記得曾經對奈奈瀨所犯下的過錯。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00205",
		linknext = "0058_00207",
		line = 2838,
	},
	["0058_00207"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He kept the hatred toward the people who persecuted Fumika.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对迫害文歌小姐的家伙抱有强烈的恨意。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對迫害文歌小姐的傢伙抱有強烈的恨意。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00206",
		linknext = "0058_00208",
		line = 2848,
	},
	["0058_00208"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And yet, the other Junnosuke Tachibana had no option but to go along with the law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即便如此，为了妹妹──另一个橘淳之介，不得不迎合条例。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即便如此，為了妹妹──另一個橘淳之介，不得不迎合條例。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00207",
		linknext = "0058_00209",
		line = 2858,
	},
	["0058_00209"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He abandoned his own sister, who he loved more than anyone.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以他抛弃了比谁都还要重要的妹妹。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以他拋棄了比誰都還要重要的妹妹。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00208",
		linknext = "0058_00210",
		line = 2868,
	},
	["0058_00210"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But he did it for her. He did it to protect Asane. He did it with conviction...",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是为了保护麻沙音，也是为了表明自己的决心──",
					{"rt2"},
				},
			},
			tw = {
				{
					"那是為了保護麻沙音，也是為了表明自己的決心──",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00209",
		linknext = "0058_00211",
		line = 2878,
	},
	["0058_00211"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And he realized—I realized—that he could no longer stand by her side.",
					{"rt2"},
				},
			},
			cn = {
				{
					"──与此同时，我也察觉到自己不应该再待在麻沙音的身边了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"──與此同時，我也察覺到自己不應該再待在麻沙音的身邊了。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00210",
		linknext = "0058_00212",
		line = 2888,
	},
	["0058_00212"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He saw himself becoming corrupted by the island, and he felt like he had no right to even embrace his sister anymore... So he let her go.",
					{"rt2"},
				},
			},
			cn = {
				{
					"认为迎合了岛而变的肮脏的自己，已经没有资格再拥抱自己的妹妹了──他离开了自己最爱的妹妹。",
					{"rt2"},
				},
			},
			tw = {
				{
					"認為迎合了島而變的骯髒的自己，已經沒有資格再擁抱自己的妹妹了──他離開了自己最愛的妹妹。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00211",
		linknext = "0058_00213",
		line = 2898,
	},
	["0058_00213"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Now that I can feel what he was thinking... I really do understand what Rei is saying, much as it hurts to admit it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正因为能够理解那份心理──所以也能理解礼前辈所说话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正因為能夠理解那份心理──所以也能理解禮前輩所說話。",
					{"rt2"},
				},
			},
		},
