	},
	["0058_00175"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="rcg01010104", x=0, y=0, path=":cg/rcg01/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1069", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“If I hadn’t broken them, they could’ve joined the Anti-Copulation Front and become amazing assets for the NLNS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“要是我没下手的话……他们就能成为反交尾势力，NLNS强而有力的伙伴了吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「要是我沒下手的話……他們就能成為反交尾勢力，NLNS強而有力的夥伴了吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00174",
		linknext = "0058_00176",
		line = 2466,
	},
	["0058_00176"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1070", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Your allies didn’t escape without harm. I crushed them before they were even able to join you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你的伙伴也并不是没有遭遇毒手……只不过在成为你的伙伴之前……都被我击溃了而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你的夥伴也並不是沒有遭遇毒手……只不過在成為你的夥伴之前……都被我擊潰了而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00175",
		linknext = "0058_00177",
		line = 2478,
	},
	["0058_00177"] = {
