					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I can’t deal with the information overload. Every day brings more confusion...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“回来之后接收到的讯息量爆炸多……每天都过于密集了呢……”",
