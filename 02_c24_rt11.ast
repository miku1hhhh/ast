		linkback = "0058_00153",
		linknext = "0058_00155",
		line = 2210,
	},
	["0058_00155"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00212", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You’re a victim of the island just as much as I am! If you hadn’t done what you did, you’d never have survived!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“要真是这样，那礼前辈你不也是受害者嘛！要是不这么做的话，就无法在岛上存活下去啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「要真是這樣，那禮前輩你不也是受害者嘛！要是不這麼做的話，就無法在島上存活下去啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00154",
		linknext = "0058_00156",
		line = 2222,
	},
	["0058_00156"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00228", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No one can begrudge you that. I won’t let them!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“任何人都无法定你的罪！我绝对不会原谅说出这种话的家伙！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「任何人都無法定你的罪！我絕對不會原諒說出這種話的傢伙！」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00155",
		linknext = "0058_00157",
		line = 2234,
	},
	["0058_00157"] = {
