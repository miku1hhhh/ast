	},
	["0058_00141"] = {
		{"bgm", file="bgm27", vol=100},
		{"evset", file="rcg01", set="rcg01", path=":ev/rcg01/"},
		{"evset", file="rcg01010107", set="rcg010101", path=":ev/rcg010101/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="rcg01010107", x=0, y=0, path=":cg/rcg01/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1053", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You know what life has been like for me on this island, don’t you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我至今为止对这个岛都做了些什么……你不是都挺清楚的嘛？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我至今為止對這個島都做了些什麼……你不是都挺清楚的嘛？」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00140",
		linknext = "0058_00142",
		line = 2054,
	},
	["0058_00142"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei’s expression is tinged with sadness.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈的表情，因为悲伤而变了样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩的表情，因為悲傷而變了樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00141",
		linknext = "0058_00143",
		line = 2064,
	},
	["0058_00143"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s something I really hate seeing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我一点都不想看见她那样的表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我一點都不想看見她那樣的表情。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00142",
		linknext = "0058_00144",
		line = 2074,
	},
	["0058_00144"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1054", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You know how many people I sent to the guillotine against their will.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我将好几人……好几十个人推上了断头台。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我將好幾人……好幾十個人推上了斷頭台。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00143",
		linknext = "0058_00145",
		line = 2086,
	},
	["0058_00145"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1055", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“They were just people. They were just innocent people, going about their lives without having sex. And I took that from them. Over and over and over and over and over again.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“从像你一样，只是将不性交当成理所当然般的活着的人那里……我一次又一次、一次又一次、无数次地，夺走了那份理所当然。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「從像你一樣，只是將不性交當成理所當然般的活著的人那裡……我一次又一次、一次又一次、無數次地，奪走了那份理所當然。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00144",
		linknext = "0058_00146",
		line = 2098,
	},
	["0058_00146"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1056", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I know their pain more intimately than anyone. I was forced into the same thing. And I inflicted it on them, thinking it was for the best.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我明明比谁都清楚那种痛苦……却觉得让他们也尝尝和我同样的经历……强迫他们去做自己不想要的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我明明比誰都清楚那種痛苦……卻覺得讓他們也嘗嘗和我同樣的經歷……強迫他們去做自己不想要的事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00145",
		linknext = "0058_00147",
		line = 2110,
	},
	["0058_00147"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She’s imprisoned herself for her past crimes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她现在也还被囚禁在过去所犯下的罪孽之中。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她現在也還被囚禁在過去所犯下的罪孽之中。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00146",
		linknext = "0058_00148",
		line = 2120,
	},
	["0058_00148"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Totally unable to forgive herself for what happened.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对自己曾经做过的事，还没能够原谅自己。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對自己曾經做過的事，還沒能夠原諒自己。",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00147",
		linknext = "0058_00149",
		line = 2130,
	},
	["0058_00149"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00209", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But Rei, you always believed deep down that you wanted to change the law! You fought alongside us to achieve it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，礼前辈你……在内心深处一直在想着要改变条例……所以才会帮助我们的不是吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，禮前輩你……在內心深處一直在想著要改變條例……所以才會幫助我們的不是嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00148",
		linknext = "0058_00150",
		line = 2142,
	},
	["0058_00150"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="rcg01010104", x=0, y=0, path=":cg/rcg01/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1057", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Yeah... I suppose so. But...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是啊，也有可能是那样吧……但是啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是啊，也有可能是那樣吧……但是啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00149",
		linknext = "0058_00151",
		line = 2158,
	},
	["0058_00151"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1058", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“If a villain has a change of heart and ends up helping out the hero, does it erase all the sins they committed before? Of course not.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“即使……坏人回心转意成为了英雄的助力……所犯下的错也无法就此一笔勾消吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「即使……壞人回心轉意成為了英雄的助力……所犯下的錯也無法就此一筆勾消吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00150",
		linknext = "0058_00152",
		line = 2170,
	},
	["0058_00152"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="rcg01010107", x=0, y=0, path=":cg/rcg01/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1059", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Calling me a comrade of the hero responsible for changing the island? It’s like a bad joke. I’m a war criminal. I was the best at working to stop the revolution you spearheaded!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是改变这座岛的英雄的伙伴？别笑死人了……我可是战犯啊。我比谁都还要认真的阻止反判份子萌芽……不允许这座扭曲的岛屿进行改革啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是改變這座島的英雄的夥伴？別笑死人了……我可是戰犯啊。我比誰都還要認真的阻止反判份子萌芽……不允許這座扭曲的島嶼進行改革啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00151",
		linknext = "0058_00153",
		line = 2186,
	},
	["0058_00153"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1060", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“And that’s why I don’t have the right to call myself your friend. Let alone to love you as a partner.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“所以我……没资格称作是你的伙伴。更别说是恋人了……我根本就不可能做到。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「所以我……沒資格稱作是你的夥伴。更別說是戀人了……我根本就不可能做到。」",
					{"rt2"},
				},
			},
		},
		linkback = "0058_00152",
		linknext = "0058_00154",
		line = 2198,
	},
	["0058_00154"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00209", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
