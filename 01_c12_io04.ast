			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“What’s this? Don’t tell me you’re all playing hooky right before the big day? Come on now...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“唉呀呀……？大家聚在一起，明明已经是活动前一天了却还在玩？这可不行啊……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「唉呀呀……？大家聚在一起，明明已經是活動前一天了卻還在玩？這可不行啊……？」",
					{"rt2"},
