	["0003_00192"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The FS are unfortunately not the type to overlook run-of-the-mill deviancy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我知道──但是FS可不是那种会说“既然异常就没办法”然后放过的团体。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我知道──但是FS可不是那種會說「既然異常就沒辦法」然後放過的團體。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00191",
