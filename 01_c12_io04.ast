	["0003_00274"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00213", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0553", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“You mean, how would I feel if you and I were dating and you were running around with Tokie and Rei?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“也就是我跟亲爱的变成恋人，亲爱的跟桐香酱或礼酱也很热情往来──这种感觉吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「也就是我跟親愛的變成戀人，親愛的跟桐香醬或禮醬也很熱情往來──這種感覺嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00273",
		linknext = "0003_00275",
		line = 4101,
	},
	["0003_00275"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
