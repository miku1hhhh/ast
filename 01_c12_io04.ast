			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Darling, do you know how fast you start talking when you get on the subject of porno games?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“亲爱的只要聊到自慰或H Game，说话就会变得很快呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「親愛的只要聊到自慰或H Game，說話就會變得很快呢。」",
