	["0003_00252"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00208", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It’s actually pretty emotional if you go for another playthrough. The scene where she’s suddenly washing burdock root is just a gag the first time, but it’s super emotional the second time around!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“等全部玩完后再重来的话会非常感动……第一次玩时会觉得是突然开始洗牛蒡的搞笑场景，第二次玩时已经很感动……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「等全部玩完後再重來的話會非常感動……第一次玩時會覺得是突然開始洗牛蒡的搞笑場景，第二次玩時已經很感動……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00251",
