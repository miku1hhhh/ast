				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“My Darling! We’re finally done for the day!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“亲爱的～！我这边的微调结束啰ー”",
