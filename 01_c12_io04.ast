	},
	["0003_00254"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well it’s easy to get worked up talking about the stuff you like so it only makes sense. Anyone who doesn’t get excited is no hentai gamer in my book. Maybe not even human.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说到喜欢的东西时，会因为兴奋而心跳加速然后讲话变快，是为了爱而变快的。不如说，如果不会心跳变快应该是假的，那种家伙不是H Game玩家，应该说根本不是人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說到喜歡的東西時，會因為興奮而心跳加速然後講話變快，是為了愛而變快的。不如說，如果不會心跳變快應該是假的，那種傢伙不是H Game玩家，應該說根本不是人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00253",
		linknext = "0003_00255",
		line = 3838,
