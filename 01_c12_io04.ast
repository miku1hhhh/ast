	["0003_00309"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The Misaki of this world may not know me, but that doesn’t make her any less important in my eyes. She’s an irreplaceable friend.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“即使这里是其他世界，美岬也不知道我的事──但还是我不可取代的伙伴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
