	},
	["0003_00077"] = {
		{"fg", file="rin_01m_00001", file1="rin_01m_00101", file2="rin_01m_00203", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0107", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“I thought everyone knew? Didn’t it get a feature on TV at some point?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“哈？很有名吧，电视上有播过特集啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「哈？很有名吧，電視上有播過特集啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00076",
		linknext = "0003_00078",
		line = 1260,
	},
	["0003_00078"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Thinking back on it, there used to be a segment on SBS called Pussy of the Day. There must’ve been a penis edition too.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这么说来我看过SHK有“本日穴穴”这个节目──也就是那个节目的肉棒版吗。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這麼說來我看過SHK有「本日穴穴」這個節目──也就是那個節目的肉棒版嗎。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00077",
		linknext = "0003_00079",
		line = 1270,
	},
	["0003_00079"] = {
		{"fg", file="susuko_02m_00002", file1="susuko_02m_00101", file2="susuko_02m_00224", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0147", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“By the by, Berty, you got a name for the United States of Perversion anthem?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“对了伯仔。变态合众国国歌的名字是什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「對了伯仔。變態合眾國國歌的名字是什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00078",
		linknext = "0003_00080",
		line = 1285,
