		{"fg", file="schubert_01m_00002", file2="schubert_01m_00211", file4="schubert_01m_00402", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0121", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“So much that I’ve already thought one up, actually. Would you like to hear it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“所以我想了一下国歌，你们愿意听吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「所以我想了一下國歌，你們願意聽嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00066",
		linknext = "0003_00068",
		line = 1089,
	},
	["0003_00068"] = {
