				},
			},
			tw = {
				{
					name = {"凛"},
					"「唔啊啊ー！給我住手蠢鳥！明明是隻只會說啾嚕或啾啵的低能畜生，混帳！我要把你做成油淋雞！」",
					{"rt2"},
				},
			},
		},
