		text = {
			vo = {
				{"vo", file="rin0121", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Look, I’m both an FS inspector and a member of the FS. My mistake is the FS’s mistake. The more I mess up, the more faith in the FS drops, which I report, and then rake in the praise.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“我作为FS的副监察官，也是FS的一员。我的失误就是FS的失误。要是我失误越多FS的评价也会下降，而报告失误的话我的评价反而会上升。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「我作為FS的副監察官，也是FS的一員。我的失誤就是FS的失誤。要是我失誤越多FS的評價也會下降，而報告失誤的話我的評價反而會上升。」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00184",
		linknext = "0003_00186",
		line = 2806,
	},
	["0003_00186"] = {
