					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Well, if Itsuki hooks up with Miyu then Season doesn’t appear at all, right? Can you be her girlfriend after that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“你想想，三结酱跟一树君变成恋人后，四季酱就没再出来啰？所以之后四季酱也会变成恋人吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「妳想想，三結醬跟一樹君變成戀人後，四季醬就沒再出來囉？所以之後四季醬也會變成戀人嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00258",
