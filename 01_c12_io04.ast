			},
			[2999] = {
				{"transitiontime", time=300, timestamp=108, delay2=3000},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko0564", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Darling, you’re always giving Misaki shit for how she is, aren’t you? You were pretty worried about her today, though. Even though you told me the other day that you don’t care about her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“亲爱的对美岬酱其实很手下不留情呢？但今天意外地还挺担心她的……明明之前好像一副不把她当回事的样子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「親愛的對美岬醬其實很手下不留情呢？但今天意外地還挺擔心她的……明明之前好像一副不把她當回事的樣子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00297",
		linknext = "0003_00299",
		line = 4434,
	},
	["0003_00299"] = {
