				{"vo", file="schubert0122", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Perversion O’ Peeerversion♪ The United States of Perveeersion! A cuuuntry of peeerveeerts! Perversion weee looove yooouuu...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“变态～变态～♪United State of 变态～！！变态合众～～～～国！！变～态～”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「變態～變態～♪United State of 變態～！！變態合眾～～～～國！！變～態～」",
					{"rt2"},
				},
			},
		},
