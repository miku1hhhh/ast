		{"fgact", ch="凛14", id=14, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0106", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Ha! Does your mind lean right as much as your penis does?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“啊！要是鸡鸡往右弯的人，连思想也会倒向右派吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「啊！要是雞雞往右彎的人，連思想也會倒向右派嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00074",
		linknext = "0003_00076",
		line = 1233,
	},
	["0003_00076"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00213", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How do you know what way my cock leans?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为什么你会知道我的鸟弯向哪里啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為什麼你會知道我的鳥彎向哪裡啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00075",
