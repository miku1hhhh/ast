			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“It’s wild how well you conveyed what the country’s all about so concisely...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“国名和歌词想传达的资讯完全一致，这国歌还真不得了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「國名和歌詞想傳達的資訊完全一致，這國歌還真不得了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00069",
