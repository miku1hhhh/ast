	},
	["0003_00193"] = {
		{"fg", file="rin_01m_00001", file1="rin_01m_00101", file2="rin_01m_00204", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=395, y=-5},
