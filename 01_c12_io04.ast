	["0003_00300"] = {
		{"fgact", ch="郁子10", id=10, lv=10, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We were able to change the island for the better with everyone’s help. We wouldn’t have gotten anywhere without the support of each and every one of them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"要把岛变成最理想的样子，需要伙伴支持──无论是少了谁都不可能办到的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要把島變成最理想的樣子，需要夥伴支持──無論是少了誰都不可能辦到的。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00299",
		linknext = "0003_00301",
		line = 4459,
	},
	["0003_00301"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I regularly pushed Misaki to achieve the impossible, and she rose to the occasion every time, no matter how ridiculous.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我至今丢给了美岬无数难题，但她不管是有多困难都还是很有兴致地回答我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我至今丟給了美岬無數難題，但她不管是有多困難都還是很有興致地回答我。",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00300",
		linknext = "0003_00302",
		line = 4469,
	},
	["0003_00302"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’m sure it’s because she had faith in me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这一定是因为信赖我吧。",
