					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I might’ve said that, sure... But you’re the type that only likes one girl, right? So what other option do I have?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我是这么说过──因为淳之介君结果还是只能喜欢一个人不是嘛？所以只能独占了不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我是這麼說過──因為淳之介君結果還是只能喜歡一個人不是嘛？所以只能獨佔了不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00277",
		linknext = "0003_00279",
		line = 4161,
	},
	["0003_00279"] = {
