	["0003_00303"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The NLNS of World B—the Birds of a Feather—has been on the run way longer than in World A.",
					{"rt2"},
				},
			},
			cn = {
				{
					"B世界的NLNS──Tori公的逃亡期间比A世界的长很多。",
