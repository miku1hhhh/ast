					name = {"凛", "Rin"},
					"“Urrrkkk! Get this freaky bird away from me! Know your place, feather brain, before I cook you up and make crispy duck rolls outta you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“唔啊啊ー！给我住手蠢鸟！明明是只只会说啾噜或啾啵的低能畜生，混帐！我要把你做成油淋鸡！”",
