		text = {
			vo = {
				{"vo", file="ran0055", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Uh oh, I’ll need to take her to the doctors again... Yes, hello? Hi, is this the Seiran Island Happy Paws Veterinary Clinic? Great, it’s Rin again... Yes, please! You have time? Great, thank you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“啊哇哇……得带她去平常去的医院……！喂喂！是青蓝岛快乐动物医院吗！是的，凛她又……是、是的！可以吗！拜托你们了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「啊哇哇……得帶她去平常去的醫院……！喂喂！是青藍島快樂動物醫院嗎！是的，凛她又……是、是的！可以嗎！拜託你們了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00209",
		linknext = "0003_00211",
		line = 3194,
	},
