	["0003_00088"] = {
		{"bgm", file="bgm21", vol=100},
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00301", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I was duped by some asshole online into thinking it’d feel like the real deal...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我在网络上被吹牛骗子的话给骗到，不小心试了哈瓦那辣椒自慰──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我在網路上被吹牛騙子的話給騙到，不小心試了哈瓦那辣椒自慰──」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00087",
		linknext = "0003_00089",
		line = 1426,
	},
	["0003_00089"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00220", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Next thing you know, I’m freaking out and calling the fire department. I somehow made it out alive, but they told me I couldn’t jerk off for a while. That was a hellish few weeks.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然慌忙叫了消防车，所以奇迹似地捡回一命……但是被禁止自慰了一段时间，那真的是地狱啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然慌忙叫了消防車，所以奇蹟似地撿回一命……但是被禁止自慰了一段時間，那真的是地獄啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00088",
		linknext = "0003_00090",
		line = 1438,
	},
