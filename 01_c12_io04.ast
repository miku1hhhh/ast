		{"fg", file="schubert_01f_00002", file2="schubert_01f_00210", file4="schubert_01f_00402", path=":fg/schubert_01f/", id=30, ch="シューベルト", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0126", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“It seems plausible that even a professional count-downer could get wrapped up in the moment, forget to count to zero and just keep thinking ‘one, one, one’ over and over.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“就算是专业计数的人，有时明明下一个是0，却不断重覆‘1、1、1……’呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「就算是專業計數的人，有時明明下一個是0，卻不斷重覆『1、1、1……』呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00177",
		linknext = "0003_00179",
		line = 2692,
	},
