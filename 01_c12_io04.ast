		text = {
			vo = {
				{"vo", file="ikuko0516", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Of course! But Darling, I’ve missed you so! I’ve been working so hard, I deserve some titty pats, don’t you think?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嗯，但是亲爱的不在让我好寂寞喔～我很努力所以可以揉揉我的胸部吗ー？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嗯，但是親愛的不在讓我好寂寞喔～我很努力所以可以揉揉我的胸部嗎ー？」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00082",
