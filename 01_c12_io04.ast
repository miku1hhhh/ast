		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They say there have been way more events here, so Misaki and everyone of this world must’ve been in a bind on more than one occasion.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我在这边也办过很多活动，一定也让美岬她们遇上很多次困境吧。",
