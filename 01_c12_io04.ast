			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Listen here you cheeky bitch. I don’t care who you are, but you wanna make fun of my height then I’ll stretch you like Stretch Armstrong! Blowbo, come give us a hand!!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“你还真敢说啊这混帐，管你什么监察官，我要强制拉开你的关节让你也变成女巨人呜喔喔喔啾啪酱帮我！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「你還真敢說啊這混帳，管你什麼監察官，我要強制拉開你的關節讓妳也變成女巨人嗚喔喔喔啾啪醬幫我！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0003_00093",
