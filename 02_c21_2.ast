			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“That’s no good either. None of you are going to hit me, and I won’t let you hit Darling♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“这样也不行呢。不管是这个还是那个都没打中，也打不亲爱的啊♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「這樣也不行呢。不管是這個還是那個都沒打中，也打不親愛的啊♪」",
					{"rt2"},
				},
