	["0044_00146"] = {
		{"cgdel", id=4, lv=4, time=0, alphadel=1},
		{"fg", mode=-1, id=5, ch="麻沙音5", ch_origin="麻沙音", lv=5, time=0, sync=0},
		{"bg", id=1, file="bg03_3l_00000", x=-5, y=195, lv=1, path=":bg/", sync=0, style="blur", blurx=11, blury=11, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="asane_03m_00002", file2="asane_03m_00204", path=":fg/asane_03m/", id=3, lv=3, head="asane_03m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0091", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I thought there was a lot of noise coming from downstairs... So you came... Pretty big waste of time, if you ask me...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“还想说下面怎么吵吵闹闹的……原来是你来了……还真是白费力气呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「還想說下面怎麼吵吵鬧鬧的……原來是你來了……還真是白費力氣呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00145",
		linknext = "0044_00147",
		line = 3180,
	},
	["0044_00147"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00210", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I’m here to meet my little sister. How is that a waste of time?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“来见妹妹，怎么会是白费力气呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「來見妹妹，怎麼會是白費力氣呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00146",
		linknext = "0044_00148",
		line = 3192,
	},
	["0044_00148"] = {
		{"fg", file="asane_03m_00002", file2="asane_03m_00203", path=":fg/asane_03m/", id=3, lv=3, head="asane_03m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0092", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“What did you come here to do...? Didn’t everything between us end with the conversation we had earlier...? I don’t have anything to say to you now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“到底是来干嘛……？之前的谈话，不是全说完了吗……？已经没有什么话，要跟你说了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「到底是來幹嘛……？之前的談話，不是全說完了嗎……？已經沒有什麼話，要跟你說了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00147",
		linknext = "0044_00149",
		line = 3207,
	},
	["0044_00149"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But I have something to say to you. What, are you not able to listen to what your brother has to say?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我有啊。难道你不想听哥哥说话吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我有啊。難道你不想聽哥哥說話嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00148",
		linknext = "0044_00150",
		line = 3219,
	},
	["0044_00150"] = {
		{"fg", file="asane_03m_00002", file1="asane_03m_00105", file2="asane_03m_00204", path=":fg/asane_03m/", id=3, lv=3, head="asane_03m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0093", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“...Mgh! There’s nothing you can say worth listening to. Get out now or I kill you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……唔，没有什么可听的。你再不出去我就杀了你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……唔，沒有什麼可聽的。你再不出去我就殺了你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00149",
		linknext = "0044_00151",
		line = 3234,
	},
	["0044_00151"] = {
