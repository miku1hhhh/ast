		line = 7076,
	},
	["0044_00361"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even the incapacitated SHO members are audibly confused.",
					{"rt2"},
				},
			},
			cn = {
				{
					"处于无法战斗状态的SHO人也发出了困惑的声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"處於無法戰鬥狀態的SHO人也發出了困惑的聲音。",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00360",
