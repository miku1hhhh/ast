	["0044_00366"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg060101", x=0, y=0, path=":cg/kcg06/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0139", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“I will begin with the thorough destruction of Seiran Island, the practical symbol of the Lewd Code.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“那么首先，就要象征着变态法的青蓝岛给破坏殆尽。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「那麼首先，就要象徵著變態法的青藍島給破壞殆盡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00365",
		linknext = "0044_00367",
		line = 7152,
	},
	["0044_00367"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What does she want?",
					{"rt2"},
				},
			},
			cn = {
				{
					"你想怎么做呢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"妳想怎麼做呢。",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00366",
		linknext = "0044_00368",
		line = 7162,
	},
	["0044_00368"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg060102", x=0, y=0, path=":cg/kcg06/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0140", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“SHO headquarters, the lotion fountain, Baby Me Creche, the Grand Cock Shrine, Minotsuki Academy, Lewd Land, Cock-o-Bell—there will be no exceptions.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“〝SHO总部大楼〞〝润滑液〞〝奶嘴幼儿园〞〝肉棒大社〞〝水乃月学园〞〝变态游乐园〞〝野炮屋〞──无一例外。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「〝SHO總部大樓〞〝潤滑液〞〝奶嘴幼兒園〞〝肉棒大社〞〝水乃月學園〞〝變態遊樂園〞〝野砲屋〞──無一例外。」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00367",
		linknext = "0044_00369",
		line = 7178,
	},
	["0044_00369"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What is she trying to do?",
					{"rt2"},
				},
			},
			cn = {
				{
					"你想要做什么。",
					{"rt2"},
				},
			},
			tw = {
				{
					"妳想要做什麼。",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00368",
		linknext = "0044_00370",
		line = 7188,
	},
	["0044_00370"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0141", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“I then intend to conclude by razing every SHO building set for construction around the country, wiping the organization known as the SHO out from existence.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“最后，将摧毁计划在全国各地设置的所有SHO大楼,彻底消灭SHO这个组织。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「最後，將摧毀計劃在全國各地設置的所有SHO大樓,徹底消滅SHO這個組織。」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00369",
		linknext = "0044_00371",
		line = 7200,
	},
	["0044_00371"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just what...",
					{"rt2"},
				},
			},
			cn = {
				{
					"这家伙到底。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這傢伙到底。",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00370",
		linknext = "0044_00372",
		line = 7210,
	},
	["0044_00372"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg060102", x=0, y=0, path=":cg/kcg06/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0142", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“With lawless sex permitted and no SHO—I imagine nobody will ever discuss anything as ridiculous as the USP again.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“当没有了SHO且又允许了无秩序的性行为时──USD等等，就没有人会在开玩笑了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「當沒有了SHO且又允許了無秩序的性行為時──USD等等，就沒有人會在開玩笑了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00371",
		linknext = "0044_00373",
		line = 7226,
	},
