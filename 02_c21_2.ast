	["0044_00352"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sakimori made it sound like it wouldn’t be coming until later.",
					{"rt2"},
				},
			},
			cn = {
				{
					"根据驻防老人的说法，应该还早才是啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"根據駐防老人的說法，應該還早才是啊。",
