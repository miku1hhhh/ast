				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“But who exactly was it that made me crazy? What caused me to be this way? Who was it that kept persecuting a minority group within the minority?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"‘可是让我变得疯狂的到底是谁？我为什么会变成这样？不就是因为他们持续压迫身为少数中的少数的我吗？’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"『可是讓我變得瘋狂的到底是誰？我為什麼會變成這樣？不就是因為他們持續壓迫身為少數中的少數的我嗎？』",
					{"rt2"},
				},
			},
		},
