	["0044_00380"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg060101", x=0, y=0, path=":cg/kcg06/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0145", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Watch carefully, all of you who call yourselves ‘normal.’ Tremble in your sleep, all of you who spat abuse at me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“那些正常的人啊,给我瞧瞧吧。那些鄙夷的人啊,都颤抖着入睡吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「那些正常的人啊,給我瞧瞧吧。那些鄙夷的人啊,都顫抖著入睡吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00379",
		linknext = "0044_00381",
		line = 7336,
	},
	["0044_00381"] = {
