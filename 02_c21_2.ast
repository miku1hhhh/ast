			cn = {
				{
					name = {"麻沙音"},
					"“而且突然间就消失不见，还说出了什么不需要碍事的妹妹这样的话！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「而且突然間就消失不見，還說出了什麼不需要礙事的妹妹這樣的話！！」",
					{"rt2"},
