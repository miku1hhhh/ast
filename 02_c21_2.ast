	["0044_00263"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00216", path=":fg/jun_01f/", id=30, ch="淳之介", lv=2, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		delay = {
			[1000] = {
				{"cgact", file="cgact", id=2, act="浮遊", loop=1, size=12.5, time=150, ease="easeinout_sine", timestamp=359, delay2=1000, lv=2},
				{"se", id=0, loop=0, file="se_a185", timestamp=359, delay2=1000},
				{"se", id=1, loop=0, file="se_b087", timestamp=359, delay2=1000},
