		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0130", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Hello, everyone. This is Mizuhiki Akino, FS representative and SHO special auditor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“大家晚安。我是FS代表兼SHO特别监察官的秋野水引。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「大家晚安。我是FS代表兼SHO特別監察官的秋野水引。」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00348",
		linknext = "0044_00350",
		line = 6925,
	},
	["0044_00350"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0131", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“As I believe you already know, the Lewd Code was formally adopted just moments ago.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“我想大家都已经知道了──先前，〝变态法〞已经正式的通过了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「我想大家都已經知道了──先前，〝變態法〞已經正式的通過了。」",
					{"rt2"},
