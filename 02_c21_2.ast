				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Looks like we’ve ended up in a funny little tag-team. What do you think the two of us have in common?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“变成了奇怪的话题了呢，郁跟麻沙酱的共通点是什么呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「變成了奇怪的話題了呢，郁跟麻沙醬的共通點是什麼呢？」",
					{"rt2"},
				},
			},
		},
