	["0044_00376"] = {
		{"bgm", file="bgm22.5", vol=100},
		{"bg", id=18, file="kcg060102", x=0, y=0, path=":cg/kcg06/", lv=18, ev=1, bx=800, by=450},
		{"bg", id=1, file="bg22_3_00000", x=0, y=0, lv=1, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=18, file="kcg060102", x=0, y=0, path=":cg/kcg06/", lv=18, ev=1, bx=800, by=450},
		{"msgoff", time=1},
		{"extrans", sync=0, time=400, rule="eff_008_00000"},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0143", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“I have no lofty ambitions. My only goal is to plunge all of Japan into chaos and destroy its traditional values.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“我没有什么志向。目的只是让全日本陷入混乱,使传统的价值观崩坏。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「我沒有什麽志向。目的只是讓全日本陷入混亂,使傳統的價值觀崩壞。」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00375",
		linknext = "0044_00377",
		line = 7288,
	},
	["0044_00377"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Is she really trying to do this?",
					{"rt2"},
				},
			},
			cn = {
				{
					"你真的打算这样做吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"妳真的打算這樣做嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00376",
		linknext = "0044_00378",
		line = 7298,
	},
	["0044_00378"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0144", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“By that I do not mean anything as simple as upturning those values. My ultimate goal is to annihilate all ethics and morals.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“要改变价值观并不是一件容易的事情。我最终目标是摧毁道德和伦理观。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「要改變價值觀並不是一件容易的事情。我最終目標是摧毀道德和倫理觀。」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00377",
		linknext = "0044_00379",
		line = 7310,
	},
	["0044_00379"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Is she trying to destroy the fortunate for the sake of the immiserated?",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了不幸的人，所以要击溃幸福的人的意思吗。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了不幸的人，所以要擊潰幸福的人的意思嗎。",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00378",
