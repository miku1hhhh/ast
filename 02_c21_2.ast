		},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“My sex dolls must have thrown off their facial recognition systems... Or maybe because of the tablet... Seems like there’s still room for improvement... Ghhk!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“大概是因为充气娃娃的关系导致脸部认证系统错乱了吧……或是说平板也是原因……好像还有改良的余地呢……咕唔！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「大概是因為充氣娃娃的關係導致臉部認證系統錯亂了吧……或是說平板也是原因……好像還有改良的餘地呢……咕唔！」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00262",
		linknext = "0044_00264",
		line = 5714,
	},
	["0044_00264"] = {
		{"fg", file="asane_03m_00002", file1="asane_03m_00105", file3="asane_03m_00305", path=":fg/asane_03m/", id=3, lv=3, head="asane_03m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0117", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“That’s not what I mean! Why did you protect me?! If a Hamedori starts attacking me, all you’d have to do is get out of the way and you’d win! So why...?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“才不是那样，为什么要护着我啊！！要是Hamedori君对我进行攻击的话，你只要避开了不就赢了嘛！！但是为什么──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「才不是那樣，為什麼要護著我啊！！要是Hamedori君對我進行攻擊的話，你只要避開了不就贏了嘛！！但是為什麼──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00263",
		linknext = "0044_00265",
		line = 5729,
	},
	["0044_00265"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What a ridiculous thing to say.",
					{"rt2"},
				},
			},
			cn = {
				{
					"净做些愚蠢的事──",
					{"rt2"},
				},
			},
			tw = {
				{
					"淨做些愚蠢的事──",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00264",
