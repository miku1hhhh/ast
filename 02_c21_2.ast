	["0044_00353"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So this is why she never made an appearance?",
					{"rt2"},
				},
			},
			cn = {
				{
					"这难道就是他没有出线的原因吗。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這難道就是他沒有出線的原因嗎。",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00352",
