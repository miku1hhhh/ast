					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女F", "SHO Special Combat Division I"},
					"“She’s deflecting our bullets with a sword? Everything she does is absurd! But we have pinned her down! Team A, prepare for CQC! Engage!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女F", "SHO特殊战斗部I"},
					"“用刀子将子弹给弹飞，又做些乱七八糟的事──！不过行动也被锁住了！A小队，准备使用SQC──！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女F", "SHO特殊戰鬥部I"},
					"「用刀子將子彈給彈飛，又做些亂七八糟的事──！不過行動也被鎖住了！A小隊，準備使用SQC──！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00109",
		linknext = "0044_00111",
		line = 2490,
	},
