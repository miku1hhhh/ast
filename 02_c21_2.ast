					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "SHO Special Combat Division"},
					"“Wh... Huh...? What does she mean...? Did I mishear her...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "SHO特殊战斗部"},
					"“啥……咦……？这是什么意思……？搞什么，难道听错了……？”",
