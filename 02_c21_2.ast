	["0044_00375"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0042", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "Old Man"},
					"“I-Inconceivable...! Our dream, our plans for the USP...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "老人"},
					"“什，这是在说什么……！我梦想中的USD计划啊……！”",
