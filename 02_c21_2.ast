		text = {
			vo = {
				{"vo", file="ikuko1083", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I dunno about that one. Hey, Darling? If I take all of them out at once, will you do something naughty with me as a reward?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“那会是怎样呢？我说，亲爱的，如果郁能把这边的家伙全都打飞，你能给做色色的事给我当奖励吗──？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「那會是怎樣呢？我說，親愛的，如果郁能把這邊的傢伙全都打飛，你能給做色色的事給我當獎勵嗎──？」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00092",
		linknext = "0044_00094",
		line = 2090,
	},
