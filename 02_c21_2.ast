					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Those are homing missiles! It doesn’t matter how you manage to dodge them, they’ll catch you sooner or later! All it’ll take is one hit to render you immobile!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“是追击型导弹喔！！无论你多巧妙的避开，总有一天也绝对会被抓住！就算只挨了一击，绝对是无法动弹的！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「是追擊型導彈喔！！無論你多巧妙的避開，總有一天也絕對會被抓住！就算只挨了一擊，絕對是無法動彈的！！」",
					{"rt2"},
				},
			},
		},
