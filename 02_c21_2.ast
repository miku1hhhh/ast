			tw = {
				{
					name = {"モブ女A", "SHO特殊戰鬥部"},
					"「啥……咦……？這是什麼意思……？搞什麼，難道聽錯了……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00359",
