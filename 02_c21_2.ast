	["0044_00362"] = {
		{"bgm", file="bgm36", vol=100},
		{"bg", id=18, file="kcg060102", x=0, y=0, path=":cg/kcg06/", lv=18, ev=1, bx=800, by=450},
		{"bg", id=1, file="bg02_3_00000", x=0, y=0, lv=1, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=18, file="kcg060102", x=0, y=0, path=":cg/kcg06/", lv=18, ev=1, bx=800, by=450},
		{"msgoff", time=1},
		{"extrans", sync=0, time=400, rule="eff_008_00000"},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0137", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“To do this, I needed to enact the Lewd Code and make all of Japan a place where perversion is accepted.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“为此而制定了变态法，并让日本全国处于必须要接受变态法不可的状态。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「為此而制定了變態法，並讓日本全國處於必須要接受變態法不可的狀態。」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00361",
		linknext = "0044_00363",
		line = 7104,
	},
	["0044_00363"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don’t understand what she means.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我无法理解他的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我無法理解他的話。",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00362",
		linknext = "0044_00364",
		line = 7114,
	},
	["0044_00364"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0138", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“If the SHO is to collapse while the Lewd Code it’s meant to administer is in place, this nation will turn into a lawless land, sucked into a vortex of chaos and confusion.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“如果制定了变态法，但管理它的SHO崩坏的话，这个国家就会陷入无法无天的状况，因此陷入了混乱的漩涡。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「如果制定了變態法，但管理它的SHO崩壞的話，這個國家就會陷入無法無天的狀況，因此陷入了混亂的漩渦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00363",
		linknext = "0044_00365",
		line = 7126,
	},
	["0044_00365"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don’t get what she’s thinking.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她到底在想些什么，真的不明白。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她到底在想些什麼，真的不明白。",
					{"rt2"},
				},
			},
		},
