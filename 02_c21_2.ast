		text = {
			vo = {
				{"vo", file="rin0211", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Hyaaagh! Stop destroying that door at once, you peasants! Do you have any idea how much that door costs?! SHO! Suppress this riot at once! You may fire at will!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“嘎啊啊啊，你们这些贱民可别把门给撞坏了！！你们知道那是值多少钱嘛！？SHO的各位，为了镇压暴徒，准许你们开火！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「嘎啊啊啊，你們這些賤民可別把門給撞壞了！！你們知道那是值多少錢嘛！？SHO的各位，為了鎮壓暴徒，准許你們開火！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00029",
		linknext = "0044_00031",
		line = 499,
	},
