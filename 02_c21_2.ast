		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0125", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Finally, we got through! We’ve managed to handle things here with no issue and meet up with the others. What about you? How’d it go with Asa...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"‘终于联系上了──！终于联系上了-！这里已经安全地控制好了,我和大家已经会合了。你那如何了？和麻沙酱如何啦──？’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"『終於聯繫上了──！終於聯係上了-！這裡已經安全地控制好了,我和大家已經會合了。你那如何了？和麻沙醬如何啦──？』",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00323",
		linknext = "0044_00325",
		line = 6520,
	},
	["0044_00325"] = {
