	["0044_00133"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00307", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Misaki just brought her over! We thought she might want to meet you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“刚刚从美岬那边收到的！还真是没想过会遇见你呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「剛剛從美岬那邊收到的！還真是沒想過會遇見你呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00132",
		linknext = "0044_00134",
		line = 2959,
	},
	["0044_00134"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00302", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Who better to take on a father than his daughter, right?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“果然爸爸的对手还是要女儿来对吧──！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「果然爸爸的對手還是要女兒來對吧──！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00133",
		linknext = "0044_00135",
		line = 2971,
	},
	["0044_00135"] = {
