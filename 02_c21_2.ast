	["0044_00355"] = {
		{"bg", id=18, file="kcg060102", x=0, y=0, path=":cg/kcg06/", lv=18, ev=1, bx=800, by=450},
		{"bg", id=1, file="bg03_3_00000", x=0, y=0, lv=1, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=18, file="kcg060102", x=0, y=0, path=":cg/kcg06/", lv=18, ev=1, bx=800, by=450},
		{"msgoff", time=1},
		{"extrans", sync=0, time=400, rule="eff_008_00000"},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0132", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Now that your prayers have been answered, I intend to step down from my roles as FS representative and SHO special auditor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“那么，在大家的夙愿得以实现的情况下，我想辞去FS代表及SHO特别监察官的职务。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「那麽，在大家的夙願得以實現的情況下，我想辭去FS代表及SHO特別監察官的職務。」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00354",
		linknext = "0044_00356",
		line = 7002,
	},
	["0044_00356"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0133", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“But rather than a resignation speech, I would like to tell you now about my plans for the future.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“代替我的辞职问候，我想谈谈我对未来的计划。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「代替我的辭職問候，我想談談我對未來的計劃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00355",
		linknext = "0044_00357",
		line = 7014,
	},
	["0044_00357"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0134", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“From a young age, I was looked down upon for being homosexual. I was bullied, cursed, and treated as a non-person.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“我从小就因为同性恋而受到蔑视。被欺负，被辱骂，被当作不存在的人对待。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「我從小就因為同性戀而受到蔑視。被欺負，被辱罵，被當作不存在的人對待。」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00356",
		linknext = "0044_00358",
		line = 7026,
	},
	["0044_00358"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0135", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“None of that changed even when I came to Seiran Island in search of salvation. Minorities here were simply chased off into the darkness.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“即使在寻求救赎的青蓝岛,也没有改变。只是被当成少数族群而被驱赶到了阴暗的黑暗中。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「即使在尋求救贖的青藍島,也沒有改變。只是被當成少數族群而被驅趕到了陰暗的黑暗中。」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00357",
		linknext = "0044_00359",
		line = 7038,
	},
	["0044_00359"] = {
		{"bgm", stop=1},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg060101", x=0, y=0, path=":cg/kcg06/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0136", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Which is why I decided to crush this country and this island that disregarded me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“因此，我决定摧毁这个践踏自己的国家并且摧毁青蓝岛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「因此，我決定摧毀這個踐踏自己的國家並且摧毀青藍島。」",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00358",
