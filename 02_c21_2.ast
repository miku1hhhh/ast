	["0044_00344"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0128", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“That’s too bad, I got along with Asane... But it’s fine now. I’ve bought myself enough time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"‘那真是太遗憾了，我跟麻沙音酱很合得来的说⋯⋯不过也无所谓了。他也帮我争取了不少的时间──’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"『那真是太遺憾了，我跟麻沙音醬很合得來的說⋯⋯不過也無所謂了。他也幫我爭取了不少的時間──』",
					{"rt2"},
				},
			},
		},
		linkback = "0044_00343",
		linknext = "0044_00345",
		line = 6850,
	},
	["0044_00345"] = {
