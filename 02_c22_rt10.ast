		text = {
			vo = {
				{"vo", file="rei0998", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“If I hadn’t have met Hinami, I bet I would think the exact same way.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“要是没有遇到雏见的话⋯⋯我大概也会抱持着她那样的想法吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「要是沒有遇到雛見的話⋯⋯我大概也會抱持著她那樣的想法吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00023",
		linknext = "0051_00025",
		line = 317,
	},
	["0051_00025"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My thought spills from Rei’s mouth as if it were her own.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仿佛继承了我的想法似的，礼前辈脱口而出。",
					{"rt2"},
				},
			},
			tw = {
				{
					"彷彿繼承了我的想法似的，禮前輩脫口而出。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00024",
		linknext = "0051_00026",
		line = 327,
	},
	["0051_00026"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00210", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0999", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“There were certain parts of their argument that she didn’t have full conviction about. It was like looking in a mirror at my past self.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“她的主张⋯⋯也多少有触动我的地方喔。仿佛看见了过去的我自己一样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「她的主張⋯⋯也多少有觸動我的地方喔。彷彿看見了過去的我自己一樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00025",
		linknext = "0051_00027",
		line = 342,
	},
	["0051_00027"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1000", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I thought about destroying everything once. Condemning everyone to the same fate as me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“曾经有段时间⋯⋯我也希望把一切都破坏掉。我希望每个人遭遇我所遭遇到的事⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「曾經有段時間⋯⋯我也希望把一切都破壞掉。我希望每個人遭遇我所遭遇到的事⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00026",
		linknext = "0051_00028",
		line = 354,
	},
	["0051_00028"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei told me something like this before.",
					{"rt2"},
				},
			},
			cn = {
				{
					"之前，礼前辈也说过类似的事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"之前，禮前輩也說過類似的事。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00027",
		linknext = "0051_00029",
		line = 364,
	},
	["0051_00029"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She hated those people brave enough to refuse sex, which caused her to send all of them to the guillotine.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她憎恨着那些逃避性行为的人们──所以将无数的人逼上了断头台。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她憎恨著那些逃避性行為的人們──所以將無數的人逼上了斷頭台。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00028",
		linknext = "0051_00030",
		line = 374,
	},
	["0051_00030"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if what Akino is doing isn’t right, even if she’s lost her way in acting on her personal grudge... I can’t help but feel a degree of sympathy for her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即便秋野的做法只是在报复私仇，甚至没有一点道理──我在某种程度上也能共感她的心情，而理解她。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即便秋野的做法只是在報復私仇，甚至沒有一點道理──我在某種程度上也能共感她的心情，而理解她。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00029",
		linknext = "0051_00031",
		line = 384,
	},
	["0051_00031"] = {
