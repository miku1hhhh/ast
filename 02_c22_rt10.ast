	["0051_00020"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s how twisted Akino has come to be.",
					{"rt2"},
				},
			},
			cn = {
				{
					"秋野已经扭曲到这种地度了吗。",
					{"rt2"},
				},
			},
			tw = {
				{
					"秋野已經扭曲到這種地度了嗎。",
					{"rt2"},
				},
