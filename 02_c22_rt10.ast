	["0051_00021"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even though we walked a similar path, she came to a completely different conclusion.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她与我几乎是走在相同的道路上，却获得了简直是毁灭性的、截然不同的结果。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她與我幾乎是走在相同的道路上，卻獲得了簡直是毀滅性的、截然不同的結果。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00020",
		linknext = "0051_00022",
		line = 277,
	},
	["0051_00022"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"To destroy the status quo. To avenge her own grudge, with no regard for what’s right.",
					{"rt2"},
				},
			},
			cn = {
				{
					"摧毁掉一贯的价值观。并非为了大义，仅只是为了私仇的报复行为。",
					{"rt2"},
				},
			},
			tw = {
				{
					"摧毀掉一貫的價值觀。並非為了大義，僅只是為了私仇的報復行為。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00021",
		linknext = "0051_00023",
		line = 287,
	},
	["0051_00023"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I could have easily gone astray too...",
					{"rt2"},
				},
			},
			cn = {
				{
					"要是我行有偏差的话，大概也──",
					{"rt2"},
				},
			},
			tw = {
				{
					"要是我行有偏差的話，大概也──",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00022",
		linknext = "0051_00024",
		line = 297,
	},
	["0051_00024"] = {
