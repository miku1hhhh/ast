					{"rt2"},
				},
			},
			en = {
				{
					"Maybe she thought she had to resort to violence. And with no one to support her... maybe she thought she would never be accepted.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不大费周章地诏告天下、不让人知道自己的理念背景的话──自己的存在就不会获得包容──之类的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不大費周章地詔告天下、不讓人知道自己的理念背景的話──自己的存在就不會獲得包容──之類的。",
					{"rt2"},
				},
			},
		},
		linkback = "0051_00017",
		linknext = "0051_00019",
		line = 245,
	},
	["0051_00019"] = {
