			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I’m glad to hear it. Harem Girl #6 has been wailing about you in the dorms. She’s like, ‘Is Junnosuke okay?! He’s not going to die, right?! No, he can’t die, he just can’t!’, like that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“太好了。我们后宫6号在宿舍一直嚷嚷着‘淳之介没问题嘛⋯⋯！？不会死掉吧⋯⋯哇──我不要他死啊～～！’常常为此而哭呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「太好了。我們後宮6號在宿舍一直嚷嚷著『淳之介沒問題嘛⋯⋯！？不會死掉吧⋯⋯哇──我不要他死啊～～！』常常為此而哭呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00037",
		linknext = "0108_00039",
		line = 561,
	},
	["0108_00039"] = {
