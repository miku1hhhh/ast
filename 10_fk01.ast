	["0108_00016"] = {
		{"se", id=0, loop=0, file="se_a078"},
		{"fg", file="tohka_01m_00002", file1="tohka_01m_00101", file2="tohka_01m_00228", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", alpha=0, ch_origin="桐香", ch="桐香8", mw="mw", sync=1, a_chr151=1, mode=3, x=-205, y=-5},
