		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1270", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I figured you might be bored out of your mind laid up in bed, so I brought some anal toys for you! I’m sure in a week you’ll be able to fit a bulbous dildo up there!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我想说你一直睡的话一定会觉得很无聊，所以我带来一款菊穴专用的玩具来了！一周以后就连卖屌劳也有可能插得进去喔！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我想說妳一直睡的話一定會覺得很無聊，所以我帶來一款菊穴專用的玩具來了！一週以後就連賣屌勞也有可能插得進去喔！」",
					{"rt2"},
				},
			},
		},
