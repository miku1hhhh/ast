		{"fgact", ch="礼9", id=9, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2321", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Sorry to bother you, Hinami. We came by because he was discharged, but I heard he was still bedridden...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“打扰了，渡酱。我们听说他出院了，但还是一直处于卧病在床的状态，所以就来探病了⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
