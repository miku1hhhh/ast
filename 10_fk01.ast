				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Huh? H-Hinami, that’s um... By the way, what number am I? I can safely assume my position’s high too, right?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“欸⋯⋯渡酱⋯⋯顺便问一下那我是第几号啊⋯⋯我以为我应该还蛮前面的啊⋯⋯！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「欸⋯⋯渡醬⋯⋯順便問一下那我是第幾號啊⋯⋯我以為我應該還蠻前面的啊⋯⋯！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00030",
		linknext = "0108_00032",
