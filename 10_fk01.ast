			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“No need to deny it, Harem Girl #6. Well, from a #7 perspective, your libido must be through the roof after those injuries, so go ahead and pitch a tent right here...♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“后宫6号的部分倒是不否认嘛⋯⋯不过对后宫7号的我来说，我比较关系因为受伤而积累的性欲，要不要帮你弄出来呢～～♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「後宮6號的部分倒是不否認嘛⋯⋯不過對後宮7號的我來說，我比較關係因為受傷而積累的性慾，要不要幫你弄出來呢～～♪」",
