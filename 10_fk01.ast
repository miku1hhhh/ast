				},
			},
			en = {
				{
					"Because of my commitment to my goal, I was able to achieve this ending for myself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就因为如此⋯⋯结果才会变成这样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就因為如此⋯⋯結果才會變成這樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00075",
		linknext = "0108_00077",
		line = 1142,
	},
