		{"fgact", ch="桐香8", id=8, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1865", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Apologies for coming by uninvited. It is I, the one and only Touka Reizeiin, FS representative and the student council president of Minotsuki Academy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“是，不好意思上门打扰了，冷泉院桐香谨代表FS全体人员兼水乃月学员学生会长来也。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「是，不好意思上門打擾了，冷泉院桐香謹代表FS全體人員兼水乃月學員學生會長來也。」",
