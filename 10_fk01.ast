		{"fgact", ch="文乃4", id=4, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1015", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“His hallucinations are out of control lately. The doctor said that when the concentration of Fuminovsky love particles drop sharply, he starts to imagine every girl around him is her...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“最近很常出现幻觉，当周围的文乃分子浓度太低时，就会把周遭所有的女生都认作是文乃，医生是这么说的⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「最近很常出現幻覺，當周圍的文乃分子濃度太低時，就會把周遭所有的女生都認作是文乃，醫生是這麼說的⋯⋯」",
					{"rt2"},
				},
			},
		},
