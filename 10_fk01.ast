			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Junnosuke, are you okay?! What? D-Dipping noodles?! Yes, they’re so good, aren’t they?! I do wonder why do dipping noodles disappear so fast when you eat them!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“还好吗？淳之介君！？沾色，是在说沾面吗！？沾面很好吃对吧！不过沾面吃一吃就吃完了呢！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「還好嗎？淳之介君！？沾色，是在說沾麵嗎！？沾麵很好吃對吧！不過沾麵吃一吃就吃完了呢！？」",
					{"rt2"},
				},
			},
		},
