	["0108_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After finally getting discharged, I’ve come back to my beloved home.",
					{"rt2"},
