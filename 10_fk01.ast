			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Cut it out, Jun! There’s no medicine here! You need to get through this on your own!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“淳君！这里没有药，你看没有药啊！不能一直依赖药物！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「淳君！這裡沒有藥，你看沒有藥啊！不能一直依賴藥物！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00103",
		linknext = "0108_00105",
