	["0108_00106"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00101", file2="hinami_01m_00229", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0979", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I’m sure you’d rather go without meds if you could. You’re just whining from the pain, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我想你其实一点都不想要用药的，对吧？只是现在太辛苦了才会如此示弱⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我想你其實一點都不想要用藥的，對吧？只是現在太辛苦了才會如此示弱⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00105",
		linknext = "0108_00107",
		line = 1612,
	},
	["0108_00107"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00208", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“T-That’s right... I have to get better before Fumino gets back, no matter what...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对，没错ㄈ⋯⋯在文乃回来之前，我要振作起来──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對，沒錯ㄈ⋯⋯在文乃回來之前，我要振作起來──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00106",
		linknext = "0108_00108",
		line = 1624,
	},
	["0108_00108"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00101", file2="nanase_02m_00218", path=":fg/nanase_02m/", id=4, lv=4, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1014", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Right. You wouldn’t want Fumino to think you ended up overdosing on morphine because of that shot, so you have to recover.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“对．不要让文乃以为是自己射出的弹导致你吗啡中毒，在她回来之前要努力治好对吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「對．不要讓文乃以為是自己射出的彈導致你嗎啡中毒，在她回來之前要努力治好對吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00107",
		linknext = "0108_00109",
		line = 1639,
	},
	["0108_00109"] = {
