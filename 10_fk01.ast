				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“He did earn it, though. After all, he’s the great hero who claimed victory in the Lewd War.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“这是当然的好处啊，毕竟是在“色情狂战役”中引导大家取得胜利的大英雄嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「這是當然的好處啊，畢竟是在“色情狂戰役”中引導大家取得勝利的大英雄嘛。」",
					{"rt2"},
				},
