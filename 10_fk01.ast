	["0108_00005"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", file2="nanase_01m_00210", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1005", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Remember, a full week of complete bed rest was the condition for your release, so take it easy, all right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“说好绝对静养一周才让你回来的，你会老老实实的吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「說好絕對靜養一週才讓你回來的，你會老老實實的吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00004",
		linknext = "0108_00006",
		line = 68,
	},
	["0108_00006"] = {
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00101", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=495, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="ヒナミ5", id=5, act="振動下", loop=2, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0974", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“That’s right, don’t even move from your bed! You can count on Nanase and I to take perfect care of you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“是呀，不可以擅自下床！就由我和奈奈赖同学来完美的照顾你的生活起居！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「是呀，不可以擅自下床！就由我和奈奈賴同學來完美的照顧你的生活起居！」",
					{"rt2"},
				},
			},
		},
