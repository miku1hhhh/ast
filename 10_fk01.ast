	["0108_00072"] = {
		{"fg", file="ikuko_02m_00002", file1="ikuko_02m_00101", file2="ikuko_02m_00224", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2206", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“But Darling, even though you love fapping so much, you can’t do it right now. Poor thing...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“但是亲爱的⋯⋯你最爱的打手枪也做不到了⋯⋯太可怜了⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「但是親愛的⋯⋯你最愛的打手槍也做不到了⋯⋯太可憐了⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00071",
		linknext = "0108_00073",
		line = 1100,
	},
	["0108_00073"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I fought for the path I believe in. I don’t regret any of the choices I’ve made along the way.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为了自己的信念而战，为此我一点都不后悔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為了自己的信念而戰，為此我一點都不後悔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00072",
		linknext = "0108_00074",
		line = 1112,
	},
	["0108_00074"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"To get everything I’ve longed for, I chose to do battle.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我会为了想要的事物而勇于挑战。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我會為了想要的事物而勇於挑戰。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00073",
		linknext = "0108_00075",
		line = 1122,
	},
	["0108_00075"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even when people laughed and called me idealistic, saying it can’t be done, I never wavered.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算被笑称不切实际不被看好，我也不会因此改变自己的想法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算被笑稱不切實際不被看好，我也不會因此改變自己的想法。",
					{"rt2"},
				},
			},
		},
		linkback = "0108_00074",
		linknext = "0108_00076",
		line = 1132,
	},
	["0108_00076"] = {
		{"text"},
		text = {
