		linkback = "0013_00571",
		linknext = "0013_00573",
		line = 7621,
	},
	["0013_00573"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00210", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=13},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You can work out to calm your mind. If you do, you can always assume that if you don’t like your boss, you can punch them once, and they’re dead meat!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“──正因为如此，为了稳定自己的情绪，我想着‘如果真的发威的话一拳就可以揍扁讨人厌的上司’来锻炼身体⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「──正因為如此，為了穩定自己的情緒，我想著『如果真的發威的話一拳就可以揍扁討人厭的上司』來鍛鍊身體⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00572",
		linknext = "0013_00574",
		line = 7633,
	},
	["0013_00574"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“To work out is to put your heart at peace.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对我来说，安心就是锻炼身体的代名词──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對我來說，安心就是鍛煉身體的代名詞──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00573",
		linknext = "0013_00575",
		line = 7644,
	},
