	},
	["0013_00475"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00222", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Let go! That’s my omelet! Fumino and Nanase spent three months teaching me to how to make that!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“放开我！！！这家伙竟然敢对奈奈濑跟文乃花了三个月教才会学的绵滑蛋包饭──！！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「放開我！！！這傢伙竟然敢對奈奈瀨跟文乃花了三個月教才會學的綿滑蛋包飯──！！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00474",
		linknext = "0013_00476",
		line = 6238,
	},
	["0013_00476"] = {
