					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Brewing time may slightly differ depending on the tea, but in the case of this one, two minutes 52 seconds would be perfect since there are two of us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“冲泡时间会根据选择的茶叶略有不同，但这次是两个人，2分52秒是最理想的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「沖泡時間會根據選擇的茶葉略有不同，但這次是兩個人，2分52秒是最理想的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00282",
		linknext = "0013_00284",
		line = 3652,
