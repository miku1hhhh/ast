	["0013_00276"] = {
		{"se", id=0, stop=1, time=1000},
		{"se", id=0, loop=0, file="se_a176"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She takes an expensive looking pot, a burner, and a beaker from the shelf.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她从架子上拿出一个看起来很贵的茶壶，然后是一个炉子和一个烧杯。",
					{"rt2"},
				},
			},
			tw = {
				{
