		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’ve been fighting her for such a long time, this makes the blood rush in my veins.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我和这家伙斗了这么久，这让我突然间感受到热血沸腾。。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我和這傢伙鬥了這麼久，這讓我突然間感受到熱血沸騰。。",
					{"rt2"},
				},
			},
		},
