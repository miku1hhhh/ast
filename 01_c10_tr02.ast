		{"transitiontime", time=300},
		{"fgact", ch="礼9", id=9, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0351", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“What happened, Miss Touka? I don’t think you ever worried about your butt. You didn’t even know that something like scales existed up until recently.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“怎么了桐香大人⋯⋯？你之前从来没这么在意屁股的事情过啊。你不是直到最近都还连体重计的存在都不知道的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「怎麼了桐香大人⋯⋯？妳之前從來沒這麼在意屁股的事情過啊。妳不是直到最近都還連體重計的存在都不知道的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00547",
		linknext = "0013_00549",
		line = 7265,
	},
	["0013_00549"] = {
