					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If you do that, you’ll never make it until the lunch break is over! Eat, Touka! Chew it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你这样弄下去午休时间就结束了……！？就直接吃吧桐香，你好好地咬！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳這樣弄下去午休時間就結束了……！？就直接吃吧桐香，妳好好地咬！」",
					{"rt2"},
				},
			},
		},
