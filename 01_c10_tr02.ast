		{"text"},
		text = {
			vo = {
				{"vo", file="rei0346", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“W-Wait, Junnosuke! It was her expression of great joy...! Like, thank you for putting so much effort for me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“等等，纯之介，她那样刚刚是高兴的表现……！‘谢谢你为了她抽出时间来’这样的意思──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「等等，純之介，她那樣剛剛是高興的表現……！『謝謝你為了她抽出時間來』這樣的意思──！」",
					{"rt2"},
				},
			},
		},
