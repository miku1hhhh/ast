	["0013_00571"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00213", path=":fg/ikuko_02m/", id=10, lv=9, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0384", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Remember when you destroyed equipment around you with your thread when you were about to get a nutrition IV?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“上次要帮你打营养针的时候你也是这样用丝线把周围的器材都搞得乱七八糟的呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「上次要幫你打營養針的時候妳也是這樣用絲線把周圍的器材都搞得亂七八糟的呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00570",
		linknext = "0013_00572",
		line = 7605,
	},
	["0013_00572"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00103", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=8, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
