				{
					name = {"桐香", "Touka"},
					"“It’s because rice is Japanese cuisine, so it needs to be eaten with chopsticks. Whereas, a sausage is German, so not eating it with a knife and a fork would be a discourtesy to you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“因为米饭是日本的食物，所以要用筷子吃。但是香肠是德国的，不拿刀叉吃的话，对前辈会很失礼吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「因為米飯是日本的食物，所以要用筷子吃。但是香腸是德國的，不拿刀叉吃的話，對前輩會很失禮吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00316",
		linknext = "0013_00318",
		line = 4091,
	},
	["0013_00318"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Why are you making your life harder?!",
					{"rt2"},
				},
			},
			cn = {
				{
					"为什么要费心去做这么花时间的事……！？",
					{"rt2"},
				},
			},
			tw = {
				{
					"為什麼要費心去做這麼花時間的事……！？",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00317",
