		line = 3391,
	},
	["0013_00264"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She holds the receiver wedged between her ear and her shoulder as she browses through the documents on her desk, stamping them and arranging them into bundles.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她将听筒夹在两肩之间，侧头看了看桌上的文件，盖章、将文件整理成一叠。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她將聽筒夾在兩肩之間，側頭看了看桌上的文件，蓋章、將文件整理成一疊。",
					{"rt2"},
