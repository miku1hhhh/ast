		linkback = "0013_00284",
		linknext = "0013_00286",
		line = 3674,
	},
	["0013_00286"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="桐香8", id=8, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0279", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“But of course. The key to the perfect taste is the right amount. The tea will taste different if you mistake the amount by even so much as a milliliter or two.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“当然。这种东西的味道的秘诀是正确测量量份不是吗？因为如果用肉眼测量，会有1到2毫米的差异产生。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「當然。這種東西的味道的秘訣是正確測量量份不是嗎？因為如果用肉眼測量，會有1到2毫米的差異產生。」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00285",
		linknext = "0013_00287",
		line = 3690,
	},
	["0013_00287"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00214", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
