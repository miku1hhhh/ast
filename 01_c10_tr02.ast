		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She hums as she speaks. And how’s that a way to abbreviate her titles?",
					{"rt2"},
				},
			},
			cn = {
				{
					"她一边哼着曲子，一边用奇怪的缩写报自己的名字工作着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她一邊哼著曲子，一邊用奇怪的縮寫報自己的名字工作著。",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00262",
