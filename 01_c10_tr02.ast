			tw = {
				{
					name = {"桐香"},
					"「原來是這樣啊！那我就維持這樣就好了！哼哼～嗯♪」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00565",
		linknext = "0013_00567",
		line = 7530,
	},
	["0013_00567"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00220", path=":fg/ikuko_01m/", id=10, lv=9, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0383", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“But in terms of muscles, you’ll never beat me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“不过肌肉量的话肯定是郁比较高吧？桐香酱输了唷～”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「不過肌肉量的話肯定是郁比較高吧？桐香醬輸了唷～」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00566",
		linknext = "0013_00568",
		line = 7545,
	},
	["0013_00568"] = {
		{"fg", file="tohka_01l_00002", file1="tohka_01l_00101", file2="tohka_01l_00206", path=":fg/tohka_01l/", id=8, lv=10, head="tohka_01l", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0346", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Rei, starting tomorrow, I’ll only eat chicken breasts.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“⋯⋯礼、从明天开始饭都只帮我准备鸡胸肉就可以了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「⋯⋯禮、從明天開始飯都只幫我準備雞胸肉就可以了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00567",
		linknext = "0013_00569",
		line = 7560,
	},
	["0013_00569"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00213", path=":fg/rei_01m/", id=9, lv=8, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0354", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No, Miss Touka. You were told that if you pass out next time, you’re going to be sent to a hospital. Do you really want to?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不行桐香大人。我跟你说过你要是再昏倒的话我就要住院治疗吧？你想要去医院吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不行桐香大人。我跟你說過你要是再昏倒的話我就要住院治療吧？妳想要去醫院嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00568",
		linknext = "0013_00570",
		line = 7575,
	},
	["0013_00570"] = {
		{"fg", file="tohka_01l_00002", file1="tohka_01l_00101", file2="tohka_01l_00208", path=":fg/tohka_01l/", id=8, lv=10, head="tohka_01l", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
