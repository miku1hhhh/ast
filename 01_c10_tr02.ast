			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I can’t tell for sure... But was caring for Touka too much for you, after all?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我大概猜得到⋯⋯要亲爱的去照顾桐香，压力果然还是太大了对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我大概猜得到⋯⋯要親愛的去照顧桐香，壓力果然還是太大了對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00433",
