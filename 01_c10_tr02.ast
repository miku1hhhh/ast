				},
			},
			cn = {
				{
					name = {"桐香"},
					"“因为楼梯是人造的呀？自然界没有高低之分，每隔几公分就有台阶，这不是很不自然吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「因為樓梯是人造的呀？自然界沒有高低之分，每隔幾公分就有台階，這不是很不自然嗎？」",
					{"rt2"},
				},
			},
		},
