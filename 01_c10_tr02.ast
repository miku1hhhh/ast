		text = {
			vo = {
				{"vo", file="tohka0277", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Then, you prepare 154 ml of boiling water per person and put 2.45 g of tea leaves for each, then gently pour in the boiling water.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“再准备每人154c.c开水，把每冲2.45克茶叶放入烧热的茶壶里，快速倒入开水。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「再準備每人154c.c開水，把每沖2.45克茶葉放入燒熱的茶壺裡，快速倒入開水。」",
					{"rt2"},
				},
			},
		},
