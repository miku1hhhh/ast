					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I’m just enjoying the meal with you. It feels like a picnic, doesn’t it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“像这样和前辈一起吃饭，真的很开心呢。感觉有点像野餐呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「像這樣和前輩一起吃飯，真的很開心呢。感覺有點像野餐呢？」",
					{"rt2"},
				},
			},
		},
