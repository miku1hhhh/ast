	},
	["0013_00277"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00219", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“By the way, you said you’re interested in black tea. Do you like it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“话说回来，你有说过红茶是你的兴趣……你喜欢吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「話說回來，妳有說過紅茶是妳的興趣……妳喜歡嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00276",
		linknext = "0013_00278",
		line = 3564,
	},
	["0013_00278"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00202", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="桐香8", id=8, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0275", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes. I have an unsophisticated palate, so I’m a bad cook, but my sister once praised my taste in tea. Ever since, I’ve been trying to do at least this much myself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“没错，因为我是木舌头也不擅长做饭，但我姐姐曾夸过我能尝出红茶的味道。从那以后，我一直在尝试自己做这件事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「沒錯，因為我是木舌頭也不擅長做飯，但我姐姐曾誇過我能嘗出紅茶的味道。從那以後，我一直在嘗試自己做這件事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00277",
		linknext = "0013_00279",
		line = 3579,
	},
	["0013_00279"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00201", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don’t exactly have refined tastes either, so you don’t have to try too hard.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我对自己的味蕾也没有太大的信心，所以你随意就可以了喔？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我對自己的味蕾也沒有太大的信心，所以妳隨意就可以了喔？」",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00278",
		linknext = "0013_00280",
		line = 3591,
	},
	["0013_00280"] = {
		{"se", id=0, loop=0, file="se_a262"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But Touka proceeds to boil water on the burner, never minding the fact there’s an electric pot right beside her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然而，即使身边有电热水壶，桐香还是特意开始烧水。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然而，即使身邊有電熱水壺，桐香還是特意開始燒水。",
					{"rt2"},
				},
			},
		},
		linkback = "0013_00279",
		linknext = "0013_00281",
		line = 3602,
	},
	["0013_00281"] = {
		{"se", id=1, loop=0, file="se_a176"},
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00202", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"se", id=0, loop=0, file="se_a098"},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0276", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“First, you pour hot water into the pot and cup you’ll use to drink the tea in order to heat them beforehand.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“先将热水倒进要泡茶的茶壶里，提前温杯。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
