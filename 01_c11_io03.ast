				{"vo", file="ikuko0405", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Still, it was kind of a fresh experience. I guess they do make games where you don’t fight.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“不过，原来也有不是对战的游戏啊。有点新鲜。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「不過，原來也有不是對戰的遊戲啊。有點新鮮。」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00049",
		linknext = "0001_00051",
		line = 694,
	},
	["0001_00051"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00219", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Do you normally play nothing but fighting games?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你平常都玩对战游戏吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳平常都玩對戰遊戲嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00050",
		linknext = "0001_00052",
		line = 706,
	},
	["0001_00052"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00213", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0406", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I barely play games in general. Only when I go over to have fun at Rei’s, really. I don’t know the controls, though, so I always lose.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我很少玩，差不多只有去礼酱家里时会玩一下吧。不过我不知道怎么操作，每次都输。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我很少玩，差不多只有去禮醬家裡時會玩一下吧。不過我不知道怎麼操作，每次都輸。」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00051",
		linknext = "0001_00053",
		line = 721,
	},
	["0001_00053"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can just imagine it—Rei gaming hard, Ikuko getting annoyed and upset, and Touka saying something completely off the mark.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我眼前可以浮现那样的场景──礼前辈生龙活虎玩着游戏，郁子发出不满，然后桐香指出问题点的画面。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我眼前可以浮現那樣的場景──禮前輩生龍活虎玩著遊戲，郁子發出不滿，然後桐香指出問題點的畫面。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00052",
		linknext = "0001_00054",
		line = 731,
	},
	["0001_00054"] = {
