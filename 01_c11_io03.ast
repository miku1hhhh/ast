					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Stop pushing your values on me with those stupid lectures! I want you to tell me that the people obsessed with natural births are the real idiots! Poopyyy!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“我不喜欢强压给我的说教～！只有现在还坚持自然产的那些白痴跟我说我才愿意听──！！便便～！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「我不喜歡強壓給我的說教～！只有現在還堅持自然產的那些白痴跟我說我才願意聽──！！便便～！！」",
					{"rt2"},
				},
			},
		},
