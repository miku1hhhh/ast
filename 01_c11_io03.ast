	["0001_00059"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00211", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0409", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Well, Rei just won’t stop bragging when she wins. I thought she might get the wrong idea unless I taught her that no matter how much you win in a game, you’re not getting better in real fights.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“因为礼酱每次都会一直炫自己的胜利嘛。我如果不让她理解到，游戏中再怎么强，现实也不一定厉害，她搞不好会误解的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「因為禮醬每次都會一直炫自己的勝利嘛。我如果不讓她理解到，遊戲中再怎麼強，現實也不一定厲害，她搞不好會誤解的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00058",
		linknext = "0001_00060",
		line = 815,
	},
	["0001_00060"] = {
