			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“There was one time that Rei seemed to be having so much fun that I ended up snapping and giving her a real-life beatdown.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“因为礼酱看起来很开心，我总是忍不住气起来真的打起现实对战，直接开打呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「因為禮醬看起來很開心，我總是忍不住氣起來真的打起現實對戰，直接開打呢。」",
					{"rt2"},
				},
			},
		},
