				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But despite saying all of this, she apparently has much better grades than me. She’s just so obsessed with winning.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明成绩比我好得多才对，但对胜利的执着可真惊人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明成績比我好得多才對，但對勝利的執著可真驚人。",
