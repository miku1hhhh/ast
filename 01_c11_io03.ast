				},
			},
			tw = {
				{
					name = {"光姫"},
					"「來──媽咪要換尿布囉～♪要喝奶奶嗎～？」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00158",
		linknext = "0001_00160",
		line = 2153,
	},
	["0001_00160"] = {
		{"fg", file="rin_01m_00001", file1="rin_01m_00103", file3="rin_01m_00309", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-405, y=-5},
