	["0001_00061"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00204", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0410", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“And even if she’s really good at games, you can basically say that I got the win if I turn things into a real fight and beat her, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“不管游戏中再怎么强，要是现实都会马上输掉，那游戏应该也可以算是我赢了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「不管遊戲中再怎麼強，要是現實都會馬上輸掉，那遊戲應該也可以算是我贏了吧？」",
					{"rt2"},
				},
			},
		},
