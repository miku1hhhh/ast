	["0001_00161"] = {
		{"fg", file="kouki_01m_00002", file1="kouki_01m_00101", file2="kouki_01m_00210", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[9500] = {
				{"fg", file="kouki_01m_00002", file1="kouki_01m_00101", file2="kouki_01m_00214", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, timestamp=20, delay2=9500, mode=3, x=395, y=-5},
			},
			[9499] = {
				{"transitiontime", time=300, timestamp=20, delay2=9500},
			},
		},
		text = {
			vo = {
				{"vo", file="kouki0046", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“There, there. Focusing too much on breast milk only stresses mothers out, and that’s the worst thing of all for a baby. Using formula is a mommy’s way of showing her love, you know.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“好好，要是勉强挤母乳会造成妈妈的压力，对宝宝来说也是最不好的喔。用牛奶是妈妈的爱喔～”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「好好，要是勉強擠母乳會造成媽媽的壓力，對寶寶來說也是最不好的喔。用牛奶是媽媽的愛喔～」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00160",
		linknext = "0001_00162",
		line = 2187,
	},
	["0001_00162"] = {
		{"fgact", ch="凛14", id=14, act="浮遊横", loop=2, size=7.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0102", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“No, no, no! It’s bad enough that I was born a C-section loser!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“不要不要～！我明明就是剖腹产的人生失败组～！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「不要不要～！我明明就是剖腹產的人生失敗組～！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00161",
		linknext = "0001_00163",
		line = 2200,
	},
	["0001_00163"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00210", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0047", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Nothing about a C-section makes you a loser. It’s an act full of love from a mother who wants her precious child to have a safe birth.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“剖腹产不是失败组喔。是为了安全生下宝贵的孩子，所以妈妈才会这么做的喔～”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「剖腹產不是失敗組喔。是為了安全生下寶貴的孩子，所以媽媽才會這麼做的喔～」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00162",
		linknext = "0001_00164",
		line = 2215,
	},
	["0001_00164"] = {
