				{"fg", file="ikuko_02m_00002", file1="ikuko_02m_00101", file3="ikuko_02m_00315", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, timestamp=23, delay2=3700, mode=3, x=-5, y=-5},
			},
			[3699] = {
				{"transitiontime", time=300, timestamp=23, delay2=3700},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko0438", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Oh, yeah. Believe it or not, she’s pretty friendly with Rin. I’m pretty sure that she taught Rin all kinds of perverted techniques as soon as she was barely legal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“啊啊，因为她和凛酱关系很好的关系吧。确实凛酱当上性人后不久，就教了她很多变态技巧之类的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「啊啊，因為她和凜醬關係很好的關係吧。確實凜醬當上性人後不久，就教了她很多變態技巧之類的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00171",
		linknext = "0001_00173",
		line = 2353,
	},
	["0001_00173"] = {
		{"fg", file="ikuko_02m_00002", file1="ikuko_02m_00101", file2="ikuko_02m_00207", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0439", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“And you know. There’s a pretty big age gap between Kokie and her little sister Mizuki. It sounds like she helped take care of her as a baby.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“还有啊，珂琪酱、因为跟妹妹瑞希酱的年纪差很多，从妹妹还是婴儿的时候就在照顾她了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「還有啊，珂琪醬、因為跟妹妹瑞希醬的年紀差很多，從妹妹還是嬰兒的時候就在照顧她了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00172",
		linknext = "0001_00174",
		line = 2368,
	},
	["0001_00174"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh... So that’s what it is.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来如此……是这样啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來如此……是這樣啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00173",
		linknext = "0001_00175",
		line = 2380,
	},
	["0001_00175"] = {
		{"fg", file="ikuko_02m_00002", file1="ikuko_02m_00101", file3="ikuko_02m_00313", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0440", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Still, I get that it could be fun to regress in age and have people baby you, but I wonder what the people playing mommy get out of it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“但是啊～我能理解退化的乐趣，但是当妈妈有什么好玩的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「但是啊～我能理解退化的樂趣，但是當媽媽有什麼好玩的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00174",
		linknext = "0001_00176",
		line = 2395,
	},
	["0001_00176"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00219", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well... There are people who like taking care of others, right? Maybe they’re possessive, or they want to be mothers, or they want to be relied on.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这个……例如说想当支配欲很强的妈妈，或是想被人依赖──也有那种很喜欢照顾人的人吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這個……例如說想當支配慾很強的媽媽，或是想被人依賴──也有那種很喜歡照顧人的人吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00175",
		linknext = "0001_00177",
		line = 2407,
	},
	["0001_00177"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00201", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If anyone, I bet you’d love having people wrapped around your pinky like that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“郁子感觉会很喜欢吧？可以随意掌控对方这种的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「郁子感覺會很喜歡吧？可以隨意掌控對方這種的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00176",
		linknext = "0001_00178",
		line = 2419,
	},
	["0001_00178"] = {
		{"bgm", stop=1},
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00101", file3="ikuko_01m_00312", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
