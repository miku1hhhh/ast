		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0432", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“It’s a pain if I’m wearing my FS outfit. People keep propositioning me like earlier, so it’s easier this way. It’s not like we’re ordering anyone around today, either.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“因为穿着FS的制服就会像刚才那样有人来邀，很麻烦啊。穿这个会比较轻松。今天也没有要下指令的工作嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
