					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Rei was in tears and got so mad at me. I guess video games really do make people violent, huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
