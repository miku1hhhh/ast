	["0010_00007"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All we had to do to freely change the placement of SHO security was write a proposal, and we were able to get twice our estimated budget.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只要有企画书就能够自由变更SHO的警备配置，预算方面则是得到了预期的2被左右的金额。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只要有企畫書就能夠自由變更SHO的警備配置，預算方面則是得到了預期的2被左右的金額。",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00006",
		linknext = "0010_00008",
		line = 87,
	},
	["0010_00008"] = {
