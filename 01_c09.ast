			en = {
				{
					name = {"モブ男B", "Meemaw?-like Guy"},
					"“Is this the vagina that gobbled up my dick?! You naughty bird, you’d better get pregnant to apologize! Get pregnant! C’mon, chick-a-dee! Sing a song of sorrow! Get pregnant by my cock-a-doodle-doo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "奶奶？型男子"},
					"“吃掉了我的老二的就是这个小穴吗！？真是只坏麻雀，给我怀孕表达歉意吧！怀孕吧！喔拉、给我以孕谢罪！！怀孕吧！麻雀！高潮吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "奶奶？型男子"},
