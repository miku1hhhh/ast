	["0010_00009"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0180", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Attendance will be taken for Academy students, but it will be reflected on your record as volunteer work. I realize this will be taking place on a Saturday, but I hope to see you all there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘我们学园也会记录学生是否参加，虽然是在周末，但是因为会被视为义工活动、在学业成绩考核上也有影响，请大家踊跃参加喔。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『我們學園也會記錄學生是否參加，雖然是在週末，但是因為會被視為義工活動、在學業成績考核上也有影響，請大家踴躍參加喔。』",
					{"rt2"},
				},
			},
		},
		linkback = "0010_00008",
		linknext = "0010_00010",
		line = 109,
	},
