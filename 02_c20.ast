			},
			tw = {
				{
					name = {"礼", "禮"},
					"「而且，假屌幹穴這種事，要是沒有被插入的那一方接受這件事、建立幸賴關係的話，就無法成立了──這就是，淳之介想要傳達給雛見的意思⋯⋯！」",
					{"rt2"},
				},
			},
		},
