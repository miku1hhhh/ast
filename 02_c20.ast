	["0042_00152"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="chitsuno0015", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"茅津野アナ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"茅津野アナ", "Pussy Galore"},
					"“But now it will become a battlefield where the heroes will cross swords. This will be a hard fight, Kouki Senba—as our commentator today, what’s your read on it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"茅津野アナ", "茅津野播报员"},
					"‘不过从这边开始将会进入与英雄PK的淘汰赛。看来会是一番苦战的样子呢，解说员仙波光姬小姐？’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"茅津野アナ", "茅津野播報員"},
					"『不過從這邊開始將會進入與英雄PK的淘汰賽。看來會是一番苦戰的樣子呢，解說員仙波光姬小姐？』",
					{"rt2"},
				},
			},
		},
		linkback = "0042_00151",
		linknext = "0042_00153",
		line = 2722,
	},
	["0042_00153"] = {
		{"fg", file="kouki_01l_00001", file1="kouki_01l_00101", file2="kouki_01l_00203", path=":fg/kouki_01l/", id=17, lv=17, head="kouki_01l", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=-5, y=-5},
