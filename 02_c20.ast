	["0042_00206"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file3="jun_01f_00307", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You were taken to a hospital and couldn’t enter the olympiad! Don’t you remember?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你被送去医院，不得不退出体欲节不是吗！？难道你忘了吗──！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳被送去醫院，不得不退出體慾節不是嗎！？難道妳忘了嗎──！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0042_00205",
		linknext = "0042_00207",
		line = 3606,
	},
	["0042_00207"] = {
