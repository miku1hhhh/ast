			en = {
				{
					name = {"光姫", "Kouki"},
					"“Hell awaits you, hell is behind you... But they’re the ones who defeated us, and maybe they can pull off another miracle...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"‘没错，从这里开始，往前也是地狱、往后也是地狱⋯⋯不过他们刚刚才将我们打败、也许──’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"『沒錯，從這裡開始，往前也是地獄、往後也是地獄⋯⋯不過他們剛剛才將我們打敗、也許──』",
					{"rt2"},
				},
			},
		},
		linkback = "0042_00152",
		linknext = "0042_00154",
		line = 2736,
	},
