	["0042_00438"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", file2="nanase_01m_00203", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0092", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I-I... have to save you! From the FS you don’t wanna be a part of! I’ll lay your complexes bare and force you out of the FS!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我得⋯⋯！我、我得要帮你才行！我得帮你从那个、你根本就不想待的、那个不过你的自卑还强迫着你的FS里脱身才行！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我得⋯⋯！我、我得要幫你才行！我得幫你從那個、你根本就不想待的、那個不過你的自卑還強迫著你的FS裡脫身才行！」",
					{"rt2"},
				},
			},
		},
		linkback = "0042_00437",
		linknext = "0042_00439",
		line = 7484,
	},
	["0042_00439"] = {
