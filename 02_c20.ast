		{"fgact", ch="光姫21", id=21, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0079", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“This is the ejaculation-urging secret art, CQC Gangbang Special that passed in the Hanamaru family! They hold the opponent between them and whisper contradictive things in their both ears!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"‘这是，花丸家秘不外传、只传给继承人的‘双声道SQC杀法’！将对手夹在中间、从右边输入认输、左边输入加油的话语让对手的脑子陷入混乱，促使对手射精！是秘技中的秘技！’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"『這是，花丸家秘不外傳、只傳給繼承人的『雙聲道SQC殺法』！將對手夾在中間、從右邊輸入認輸、左邊輸入加油的話語讓對手的腦子陷入混亂，促使對手射精！是祕技中的秘技！』",
					{"rt2"},
				},
			},
		},
		linkback = "0042_00100",
		linknext = "0042_00102",
		line = 1681,
	},
	["0042_00102"] = {
