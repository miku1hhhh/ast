		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0086", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“A lot happened before you entered the team. You hoped to find help when you were doing your best to save men.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我觉得要是我能因为这样那样的原因加入这个团队，‘为了帮这个叫做橘君的男孩子而努力吧’这样，能帮得上大家的话就好了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我覺得要是我能因為這樣那樣的原因加入這個團隊，『為了幫這個叫做橘君的男孩子而努力吧』這樣，能幫得上大家的話就好了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0042_00392",
		linknext = "0042_00394",
		line = 6769,
	},
	["0042_00394"] = {
