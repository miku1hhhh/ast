				},
			},
			cn = {
				{
					name = {"茅津野アナ", "茅津野播报员"},
					"‘各位好，我是把你的一切都接受的、主播茅津野。终于我们的‘大逃啪’要开始了呢，是不是很令人血脉喷张呢？光姬解说员？’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"茅津野アナ", "茅津野播報員"},
