		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0780", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Certainly, the woman looked like a loser, but she turned out to be a savage queen. We would’ve never known what kind of a person she was if we didn’t try.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“确实如同这句话讲的，就算是这样一个必败无疑的不起眼女性，剥开外表却是个强势的女王类型。但要是不插入的话，谁都不会知道她是哪种类型的人──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「確實如同這句話講的，就算是這樣一個必敗無疑的不起眼女性，剝開外表卻是個強勢的女王類型。但要是不插入的話，誰都不會知道她是哪種類型的人──」",
					{"rt2"},
				},
			},
		},
		linkback = "0042_00376",
		linknext = "0042_00378",
		line = 6520,
	},
