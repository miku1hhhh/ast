	["0042_00393"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", file3="hinami_01m_00309", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=-5, y=-5},
