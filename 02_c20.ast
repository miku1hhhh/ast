					{"rt2"},
				},
			},
		},
		linkback = "0042_00050",
		linknext = "0042_00052",
		line = 790,
	},
	["0042_00052"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00204", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-205, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0764", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“The first rule of Battle Whore-for-all is to wager porn-star chips to join each match. The competition is decided by judges—members of the FS or the SHO who are present there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“得要用‘智慧晶片’作为大逃啪的赌注进行游戏，这是游戏的第一规则。比赛的内容则是由现场的裁判──FS或SHO来决定。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「得要用『智慧晶片』作為大逃啪的賭注進行遊戲，這是遊戲的第一規則。比賽的內容則是由現場的裁判──FS或SHO來決定。」",
					{"rt2"},
				},
			},
		},
		linkback = "0042_00051",
		linknext = "0042_00053",
		line = 805,
	},
	["0042_00053"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00214", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-205, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0765", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“The first to collect five porn-star chips will be able to fight in the SHO HQ—A.K.A. The Tower of the Lewd.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“集到五枚智慧晶片的人，可以向通称‘淫乱大地标塔’的SHO总部大楼挑战。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「集到五枚智慧晶片的人，可以向通稱『淫亂大地標塔』的SHO總部大樓挑戰。」",
					{"rt2"},
				},
			},
		},
		linkback = "0042_00052",
		linknext = "0042_00054",
		line = 820,
	},
	["0042_00054"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00203", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-205, y=-5},
