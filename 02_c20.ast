	["0042_00389"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file3="jun_01f_00301", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Um... I know you said it yourself, but do you believe me? It’s a bit of an absurd story though...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那个⋯⋯虽然我自己说有点那个、但是你愿意相信吗？像这种荒诞无稽的事⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那個⋯⋯雖然我自己說有點那個、但是妳願意相信嗎？像這種荒誕無稽的事⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0042_00388",
		linknext = "0042_00390",
		line = 6712,
	},
	["0042_00390"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", file2="hinami_01m_00220", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0084", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I do. My junior was so eager to tell me that. If I didn’t believe you, it would be the end of me as a woman!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我相信唷。因为后辈都拼命地解释了嘛、这样还不信的话就太不是个女人了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我相信唷。因為後輩都拼命地解釋了嘛、這樣還不信的話就太不是個女人了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0042_00389",
		linknext = "0042_00391",
		line = 6727,
	},
	["0042_00391"] = {
