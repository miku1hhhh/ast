			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“So, let’s review the rules of Battle Whore-for-all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“⋯⋯好了，我们来复习一下‘大逃啪’的规则吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
