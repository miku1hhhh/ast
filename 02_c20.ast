			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You face one opponent on each floor of the tower—the Birds of a Feather—whom you have to defeat and keep climbing to the top.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“在这个淫乱塔里每一层都有一个英雄──也就是‘Tori公’的成员──在等着，打倒他们登顶就是我们的目标。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「在這個淫亂塔裡每一層都有一個英雄──也就是『Tori公』的成員──在等著，打倒他們登頂就是我們的目標。」",
					{"rt2"},
				},
			},
		},
		linkback = "0042_00053",
		linknext = "0042_00055",
		line = 835,
	},
	["0042_00055"] = {
