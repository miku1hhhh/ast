					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"『一般來說，當絕頂自行車的速度上升越快、按摩棒的抽送速度也會跟著加快，所以會讓人無意識的加強腳踩踏的限制。』",
					{"rt2"},
