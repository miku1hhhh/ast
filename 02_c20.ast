	["0042_00508"] = {
		{"fgact", ch="奈々瀬4", id=4, lv=4, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="chitsuno0040", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"茅津野アナ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"茅津野アナ", "Pussy Galore"},
					"“What? What’s the meaning of this?! Right before the competition, the faplympics champion, Nanase Katagiri, withdraws! Commentator Kouki, what is this?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"茅津野アナ", "茅津野播报员"},
					"‘欸？这⋯⋯这到底、到底是怎么一回事⋯⋯！？比试开示之前，尻恁屄客霸主、片桐奈奈濑选手她，宣布弃权了──！？解说员光姬小姐，这究竟是⋯⋯？’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"茅津野アナ", "茅津野播報員"},
					"『欸？這⋯⋯這到底、到底是怎麼一回事⋯⋯！？比試開示之前，尻恁屄客霸主、片桐奈奈瀨選手她，宣佈棄權了──！？解說員光姬小姐，這究竟是⋯⋯？』",
					{"rt2"},
				},
			},
		},
		linkback = "0042_00507",
		linknext = "0042_00509",
		line = 8461,
	},
	["0042_00509"] = {
		{"bg", id=2, file="bg01_1l_00000", x=0, y=0, lv=2, path=":bg/", sync=0, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="kouki_01l_00001", file1="kouki_01l_00101", file2="kouki_01l_00203", path=":fg/kouki_01l/", id=17, lv=17, head="kouki_01l", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0090", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Hm. I see. It’s said that when two masters stand against each other, the winner is already decided before the first blow is even struck.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"‘唔姆，原来如此──据说高手之间的交锋，是在比试前就已经决定了雌雄的。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"『唔姆，原來如此──據說高手之間的交鋒，是在比試前就已經決定了雌雄的。』",
					{"rt2"},
				},
			},
		},
		linkback = "0042_00508",
		linknext = "0042_00510",
		line = 8476,
	},
	["0042_00510"] = {
		{"fg", file="kouki_01l_00001", file1="kouki_01l_00101", file2="kouki_01l_00202", path=":fg/kouki_01l/", id=17, lv=17, head="kouki_01l", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
