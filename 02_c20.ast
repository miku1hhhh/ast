					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Have you really... become like that because I was with you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“是因为、有我在⋯⋯你才会、变成这样、的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「是因為、有我在⋯⋯你才會、變成這樣、的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0042_00480",
		linknext = "0042_00482",
