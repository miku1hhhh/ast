			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“You don’t know it if you came from a place I don’t even know! But the Tachibana from this world has suffered so much!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“你、你不知道是从从哪里来的，所以你不懂！这个世界的橘君可是过得很痛苦啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「你、你不知道是從從哪裡來的，所以你不懂！這個世界的橘君可是過得很痛苦啊！」",
					{"rt2"},
				},
			},
		},
