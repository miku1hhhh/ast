			cn = {
				{
					name = {"茅津野アナ", "茅津野播报员"},
					"‘那么，从这边开始就是只有获胜者才能进入的特别房间。我想将实况转到岛上举行的活动去！’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"茅津野アナ", "茅津野播報員"},
					"『那麼，從這邊開始就是只有獲勝者才能進入的特別房間。我想將實況轉到島上舉行的活動去！』",
					{"rt2"},
				},
			},
		},
