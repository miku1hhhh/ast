			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“No, I believe you! If you knew so much about me even though I’m so dull, there’s no other explanation!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不，我相信你……！毕竟，不是这样的话，我也无法解释为什么你对我这种平庸到爆的人了解得如此之多……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不，我相信你……！畢竟，不是這樣的話，我也無法解釋為什麼你對我這種平庸到爆的人了解得如此之多……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0042_00255",
		linknext = "0042_00257",
		line = 4468,
	},
	["0042_00257"] = {
