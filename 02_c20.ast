		text = {
			vo = {
				{"vo", file="nanase0106", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Okay... I don’t know how to take you back to your world and how to get the previous Tachibana back, but I’ll try. We’re friends.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯、好喔⋯⋯我不知道你们要怎么样才能回到原来的世界，也不知道要怎没做才能让之前的橘君回来，但我会配合你们的。毕竟我们是‘伙伴’，对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯、好喔⋯⋯我不知道你們要怎麼樣才能回到原來的世界，也不知道要怎沒做才能讓之前的橘君回來，但我會配合你們的。畢竟我們是『夥伴』，對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0042_00519",
		linknext = "0042_00521",
		line = 8710,
	},
	["0042_00521"] = {
