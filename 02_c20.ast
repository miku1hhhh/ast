				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不过关卡还没全部清完喔！那个、叫做NLNS的组织？如果想跟里头全部的成员重归于好的话，不突破下一个关卡可不行──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不過關卡還沒全部清完喔！那個、叫做NLNS的組織？如果想跟裡頭全部的成員重歸於好的話，不突破下一個關卡可不行──！」",
					{"rt2"},
				},
			},
		},
