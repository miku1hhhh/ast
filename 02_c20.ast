			},
			en = {
				{
					name = {"茅津野アナ", "Pussy Galore"},
					"“Oh, due to the change of the subject, we are currently changing the settings for the Intravaginal Bucket Brigade. Please wait a while.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"茅津野アナ", "茅津野播报员"},
