					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“You came so far, weaklings. You defeated my brethren and arrived here. You are qualified to stand before me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“⋯⋯来了呢。你们这些弱鸡。不过既然你们蹂躏我的同胞、又通前面的关卡了，你们就有资格站在我的面前。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「⋯⋯來了呢。你們這些弱雞。不過既然你們蹂躪我的同胞、又通前面的關卡了，你們就有資格站在我的面前。」",
					{"rt2"},
				},
			},
		},
		linkback = "0042_00403",
		linknext = "0042_00405",
		line = 6957,
	},
