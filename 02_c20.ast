				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I accidentally arrived here from a similar world and changed places with my other self. I’m Junnosuke Tachibana from another world.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我只是偶然地从类似的世界穿过来、替代了这边的我的──不同世界里的、橘淳之介。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我只是偶然地從類似的世界穿過來、替代了這邊的我的──不同世界裡的、橘淳之介。」",
