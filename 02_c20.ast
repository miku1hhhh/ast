				},
			},
			en = {
				{
					name = {"茅津野アナ", "Pussy Galore"},
					"“Whoa! Misaki Hotori’s speed drops on the straight! Number 2, Fuck Slut passes the corner and takes the lead!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"茅津野アナ", "茅津野播报员"},
					"‘太吃惊了畔美岬的速度慢下来了，二号选手蝙蝠洨在进入直线的过道转弯上抢道骑进了内侧！’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"茅津野アナ", "茅津野播報員"},
					"『太吃驚了畔美岬的速度慢下來了，二號選手蝙蝠洨在進入直線的過道轉彎上搶道騎進了內側！』",
					{"rt2"},
				},
			},
		},
		linkback = "0042_00207",
		linknext = "0042_00209",
		line = 3638,
	},
	["0042_00209"] = {
