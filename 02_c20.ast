					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“That’s a secret! I only told that to Nanase and Wata! How do you know?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那、那是我连奈奈濑同学跟渡酱都没有讲过的秘密！你为什么──！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那、那是我連奈奈瀨同學跟渡醬都沒有講過的秘密！你為什麼──！？」",
					{"rt2"},
				},
			},
		},
