			en = {
				{
					name = {"茅津野アナ", "Pussy Galore"},
					"“Good afternoon. This is Pussy Galore, giving the people what they want. The Battle Whore-for-all has finally begun. I see y’all stirred up and turned on. What do you think, commentator Senba?”",
