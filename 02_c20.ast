			},
			[999] = {
				{"transitiontime", time=300, timestamp=230, delay2=1000},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0091", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“You’re lying! You aren’t Tachibana! He doesn’t laugh so impudently! He always had a pained expression, like he was enduring something...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“骗人──！你才不是橘君呢──！橘君、橘君他才不会这么轻松地笑⋯⋯！他总是一张很苦闷的表情、在苦苦忍着什么──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「騙人──！你才不是橘君呢──！橘君、橘君他才不會這麼輕鬆地笑⋯⋯！他總是一張很苦悶的表情、在苦苦忍著什麼──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0042_00435",
		linknext = "0042_00437",
		line = 7457,
	},
	["0042_00437"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I bet he did. If you cut out a part of Junnosuke Tachibana, I’d also be such a person.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“应该吧。如果把橘淳之介的某部分剪掉的话，我就是那样的人了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「應該吧。如果把橘淳之介的某部分剪掉的話，我就是那樣的人了。」",
					{"rt2"},
				},
			},
		},
