				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“But we have gotten a glimpse at the underlying cause. We’ll need to identify the individual who was inside the Hamedori suit at once.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“但是，我们终于看见事情发生的线索了。现在必须尽快弄清楚在Hamedori君里面的人物是谁。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「但是，我們終於看見事情發生的線索了。現在必須盡快弄清楚在Hamedori君裡面的人物是誰。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00413",
