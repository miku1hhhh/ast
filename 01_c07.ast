	["0008_00324"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I see... So that’s the kind of person she is...",
					{"rt2"},
				},
			},
			cn = {
				{
					"对喔……这个人，原本就是这样的人吗……。",
