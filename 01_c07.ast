					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“It seems that she suspects there’s a faction within the SHO who are diverting goods to the ‘Birds of a Feather.’”",
					{"rt2"},
				},
			},
