	["0008_00325"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Or rather, I guess she’s always been like this, even before she came to the island...",
					{"rt2"},
				},
			},
			cn = {
				{
					"应该说，在来这座岛前就已经是这样的人了吗……。",
					{"rt2"},
				},
			},
			tw = {
				{
					"應該說，在來這座島前就已經是這樣的人了嗎……。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00324",
		linknext = "0008_00326",
		line = 4660,
	},
	["0008_00326"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Now I can see what Ikuko means when she says she gets pissed off whenever she sees people living half-assed lives...",
					{"rt2"},
				},
			},
			cn = {
				{
					"郁子时常说“看到那种生活态度漫不经心的人真让人火大～”，就是指这样的事情吧……。",
					{"rt2"},
				},
			},
			tw = {
				{
					"郁子時常說「看到那種生活態度漫不經心的人真讓人火大～」，就是指這樣的事情吧……。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00325",
		linknext = "0008_00327",
		line = 4670,
	},
	["0008_00327"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I bet the feeling would be especially strong when you’ve led a life as grand as hers...",
					{"rt2"},
				},
			},
			cn = {
				{
					"要是经历过像她那样壮烈的人生，应该更有所感受吧……。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要是經歷過像她那樣壯烈的人生，應該更有所感受吧……。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00326",
		linknext = "0008_00328",
		line = 4680,
	},
	["0008_00328"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00210", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="光姫17", id=17, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0027", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“That’s why I’m grateful to this island... I was someone who always felt like an outsider and never had anywhere to go, but they took me in... I want to repay the favor someday.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“所以我很感谢这座岛……愿意接受无处可去，总是跟周围格格不入的我……总有一天我一定会好好报达恩情的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「所以我很感謝這座島……願意接受無處可去，總是跟周圍格格不入的我……總有一天我一定會好好報達恩情的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00327",
		linknext = "0008_00329",
		line = 4696,
	},
	["0008_00329"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I know this is supposed to be a heartwarming story on some level, but my brain refuses to recognize it as one.",
					{"rt2"},
				},
			},
			cn = {
				{
					"怎么回事，明明是一段好的故事，我却完全听不进去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"怎麼回事，明明是一段好的故事，我卻完全聽不進去。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00328",
		linknext = "0008_00330",
		line = 4706,
	},
	["0008_00330"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00205", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0028", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“I know that I’ve exposed myself all over the place and shot videos as the island’s head of publicity, but I just don’t know how much I’m actually helping...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“我负责宣传，也在各种地方露面或拍摄视频，但不知道帮上了多少忙……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「我負責宣傳，也在各種地方露面或拍攝影片，但不知道幫上了多少忙……」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00329",
		linknext = "0008_00331",
		line = 4721,
	},
	["0008_00331"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00211", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0029", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“I mean, it seems like Your Sexellency has been more popular than me lately. I’m on the downswing, apparently... I just wish I could contribute more...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“你看，像是最近‘性帝’比较有人气，我的人气好像就有下滑的趋势，……我想要再多贡献一点啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「你看，像是最近『性帝』比較有人氣，我的人氣好像就有下滑的趨勢，……我想要再多貢獻一點啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00330",
		linknext = "0008_00332",
		line = 4736,
	},
	["0008_00332"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her expression turns dejected as she glances at me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"光姬快速地瞥了我一眼，露出一副垂头丧气的表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"光姬快速地瞥了我一眼，露出一副垂頭喪氣的表情。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00331",
