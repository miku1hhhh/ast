	["0008_00370"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0167", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Right... Yeah, that’s right! How could we have not noticed something so simple until now?! Did we all go stupid or something?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“对啦……喂、没错！为什么这么简单的事情现在才发现！我们全都脑子坏了吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「對啦……喂、沒錯！為什麼這麼簡單的事情現在才發現！我們全都腦子壞了嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00369",
		linknext = "0008_00371",
		line = 5252,
	},
	["0008_00371"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0155", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“That’s right...! If Darling became the vice president, it wouldn’t make sense unless the vice president became Darling!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“说得没错耶……！如果是亲爱的成为副会长，那原本的副会长就一定得是亲爱的，不然事情就整合不起来了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「說得沒錯耶……！如果是親愛的成為副會長，那原本的副會長就一定得是親愛的，不然事情就整合不起來了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00370",
		linknext = "0008_00372",
		line = 5264,
	},
	["0008_00372"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Of course. That should have been clear from the start.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没错，这种事情就算不特别思考，也应该能明白。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒錯，這種事情就算不特別思考，也應該能明白。",
					{"rt2"},
				},
			},
