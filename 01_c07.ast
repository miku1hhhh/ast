					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Oh dear. He can’t go to school like this, and think of what it’ll do to his majesty as His Sexellency if other FS members see him... Oh, I know.”",
					{"rt2"},
				},
			},
			cn = {
