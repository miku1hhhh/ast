	["0008_00237"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00213", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="スス子11", id=11, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0075", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“The situation is being kept secret. Seems there was a slight difference in the number of riot bullets on the SHO report and the actual stock. Dunno how she saw that with a quick glance, though...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“是机密资讯。好像防暴弹的数量，乍看之下与SHO报告书上的数量有些微不同。虽然不知道为什么一看就发现了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「是機密資訊。好像防暴彈的數量，乍看之下與SHO報告書上的數量有些微不同。雖然不知道為什麼一看就發現了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00236",
		linknext = "0008_00238",
		line = 3455,
	},
	["0008_00238"] = {
		{"fg", file="schubert_01m_00002", file2="schubert_01m_00202", file4="schubert_01m_00402", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0076", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“That is why I’ve been entrusted with collecting data today, along with conducting an actual investigation. Data collection is my forte, after all...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“今天我被命令要去收集数据，所以也包含实际的调查。因为收集情报是我的擅长领域……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「今天我被命令要去收集數據，所以也包含實際的調查。因為收集情報是我的擅長領域……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00237",
		linknext = "0008_00239",
		line = 3470,
	},
	["0008_00239"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00214", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=8},
		{"text"},
