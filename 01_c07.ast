			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Let’s see... Maybe people would like you more if they were able to know you better through social media or something?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对呀……在SNS上变成亲近的人后，就无法提升好感度了吧？”",
