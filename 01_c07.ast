		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This stuns everyone for a moment. And then...",
					{"rt2"},
				},
			},
			cn = {
				{
					"大家目瞪口呆，",
					{"rt2"},
