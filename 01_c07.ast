					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「總之，詳細的情形之後再解釋……那我們在大浴場見，親愛的上課也別遲到了喔──！」",
					{"rt2"},
				},
			},
		},
