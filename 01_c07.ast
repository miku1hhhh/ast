			},
			[4500] = {
				{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00202", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, timestamp=32, delay2=4500, mode=3, x=-405, y=-5},
			},
			[4499] = {
				{"transitiontime", time=300, timestamp=32, delay2=4500},
			},
		},
		text = {
			vo = {
				{"vo", file="kouki0005", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Are you here to observe the SHO, Your Sexellency? Oh, are you interested in weapons?! Wonderful, then allow me, the SHO Public Order Division Special Combat Unit’s Kouki Senba, to explain!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“性帝在视察SHO吗？啊、难道是对武器有兴趣！？好的，那么就让SHO治安管理委员会特殊战斗部的仙波光姫为您说明吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「性帝在視察SHO嗎？啊、難道是對武器有興趣！？好的，那麼就讓SHO治安管理委員會特殊戰鬥部的仙波光姫為您説明吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00262",
		linknext = "0008_00264",
		line = 3834,
	},
	["0008_00264"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00203", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0006", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Let’s begin with this, the M4 Riot, standard issue to the SHO Special Combat Unit! Developed as the successor to the old M16 Riot A2, it has been miniaturized to reduce weight!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“首先是这台，SHO特殊战斗部的标准装备“M4防暴弹”！身为旧式的M16防暴弹A2的接班机，为了将它开发为轻量型，将机体小型化了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「首先是這台，SHO特殊戰鬥部的標準裝備「M4防暴彈」！身為舊式的M16防暴彈A2的接班機，為了將它開發為輕量型，將機體小型化了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00263",
		linknext = "0008_00265",
		line = 3849,
	},
	["0008_00265"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00214", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
