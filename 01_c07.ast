	["0008_00373"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I’ve become the student council vice president, the student council vice president should now be in my position.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果我现在是学生会副会长的身份，那么现在的学生会副会长就应该会是我的身份。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果我現在是學生會副會長的身分，那麼現在的學生會副會長就應該會是我的身分。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00372",
		linknext = "0008_00374",
		line = 5284,
	},
	["0008_00374"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"How did we not notice something so plainly obvious until now?",
					{"rt2"},
				},
			},
			cn = {
