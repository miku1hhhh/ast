		{"fgact", ch="光姫17", id=17, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0018", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Heh, once I put this barrel inside of me to relieve my burning passion only for it to go off after the safety got disabled. That one sent me to the emergency room... Oh, I was so young then...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“呵呵，之前为了平息这股潮热，我把枪身插入后，锁却不慎开启发生爆炸，结果陷入不得不紧急入园的窘境……那个时候真是年轻啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「呵呵，之前為了平息這股潮熱，我把槍身插入後，鎖卻不慎開啟發生爆炸，結果陷入不得不緊急入園的窘境……那個時候真是年輕啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00298",
		linknext = "0008_00300",
		line = 4331,
	},
	["0008_00300"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her eyes are closed, as though she’s talking about something from her distant past.",
					{"rt2"},
				},
			},
			cn = {
				{
					"光姬闭起双眼，仿佛回想起非常久远的过去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"光姬閉起雙眼，彷彿回想起非常久遠的過去。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00299",
		linknext = "0008_00301",
		line = 4341,
	},
	["0008_00301"] = {
