	["0008_00333"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I feel kind of bad for being the cause of all this, as indirect as it may be.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被她说间接是我造成的原因后，总觉得有股不好意思的心情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被她說間接是我造成的原因後，總覺得有股不好意思的心情。",
					{"rt2"},
				},
			},
