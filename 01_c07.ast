	["0008_00217"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s easy for me to imagine just how much I suffered in this world.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然说，不难想像在这个世界的我，经历过怎么样的痛苦。",
