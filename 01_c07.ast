				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Seiran Island isn’t that big on social media at all, really. We have a lot of followers, but our announcements never get many RHs... Maybe that’s to be expected, our posts are pretty safe.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“实际上青蓝岛的SNS不太活跃。虽然追踪人数很多，但告知的RH数都没有提升……不过因为都是些无关紧要的牢骚，这也是没有办法的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「實際上青藍島的SNS不太活躍。雖然追蹤人數很多，但告知的RH數都沒有提升……不過因為都是些無關緊要的牢騷，這也是沒有辦法的事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00338",
