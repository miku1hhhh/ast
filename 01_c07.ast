					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“...Ngh?! I-I’ve never seen the student council president have that expression before...! Stay calm, my data! There’s no need to fear...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“……嗯！？学、学生会长露出了没有见过的表情……！冷静点我的数据，别怕……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「……嗯！？學、學生會長露出了沒有見過的表情……！冷靜點我的數據，別怕……！」",
					{"rt2"},
				},
			},
		},
