	["0008_00305"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Both physically and mentally, I had her in her early 20s at best...",
					{"rt2"},
				},
			},
			cn = {
				{
					"不论是从外观还是智力看起来，都像是20出头左右……。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不論是從外觀還是智力看起來，都像是20出頭左右……。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00304",
		linknext = "0008_00306",
		line = 4404,
	},
	["0008_00306"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I thought you’d just started working after finishing school...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我还以为你可能是一从学校毕业就开始工作……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我還以為妳可能是一從學校畢業就開始工作……」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00305",
		linknext = "0008_00307",
		line = 4416,
	},
	["0008_00307"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00214", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="光姫17", id=17, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0020", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Oh, you! Do I really look that young? It’s been almost ten years since I finished my four-year university degree!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“讨厌啦我看起来有那么年轻吗！？我读了4年的大学，距离毕业出来工作，已经是将近10年前的事了唷～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「討厭啦我看起來有那麼年輕嗎！？我讀了4年的大學，距離畢業出來工作，已經是將近10年前的事了唷～！」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00306",
		linknext = "0008_00308",
		line = 4432,
	},
	["0008_00308"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00214", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What university, out of curiosity...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“顺便请教是哪所大学……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「順便請教是哪所大學……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00307",
		linknext = "0008_00309",
		line = 4444,
	},
	["0008_00309"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...She names a school that anyone in Japan would know.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……她说出了一间无人不知的学校名。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……她說出了一間無人不知的學校名。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00308",
		linknext = "0008_00310",
		line = 4454,
	},
	["0008_00310"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In fact, it’s where the best students in all of the country go.",
					{"rt2"},
				},
			},
			cn = {
				{
					"应该说，那里是日本最会读书的人才能进的学校。",
					{"rt2"},
				},
			},
			tw = {
				{
					"應該說，那裡是日本最會讀書的人才能進的學校。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00309",
		linknext = "0008_00311",
		line = 4464,
	},
	["0008_00311"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00209", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Why is someone who graduated from a school that good working as a stupid slut in a place like this?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为什么从那么厉害的地方毕业的人，会到这种地方来变成愚蠢的痴女──！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為什麼從那麼厲害的地方畢業的人，會到這種地方來變成愚蠢的痴女──！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00310",
		linknext = "0008_00312",
		line = 4476,
	},
	["0008_00312"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00218", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0021", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“It’s a long story. My parents got sick while I was in university, so I had to raise my little sister. She was still in kindergarten at the time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“这就说来话长了。我在就读大学时父母亲生病，我必须负责照顾当时还就读幼稚园的妹妹。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「這就說來話長了。我在就讀大學時父母親生病，我必須負責照顧當時還就讀幼稚園的妹妹。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00311",
		linknext = "0008_00313",
		line = 4491,
	},
	["0008_00313"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
