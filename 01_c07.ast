	["0008_00257"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00215", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="光姫17", id=17, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0003", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Even you, Susuko...? But I’m not allowed to touch any weapons at all even though I’m in the special combat division... I’ve got a high rank too... I’m vice chairperson, you know...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“连丝丝子酱也这样说……可是我明明身为特殊战斗部，却完全没有接触武器的权限……我明明也是上级……明明是副理事……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「連絲絲子醬也這樣說……可是我明明身為特殊戰鬥部，卻完全沒有接觸武器的權限……我明明也是上級……明明是副理事……」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00256",
		linknext = "0008_00258",
		line = 3749,
	},
	["0008_00258"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00213", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=395, y=-5},
