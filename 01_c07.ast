			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Just when I was vaguely wondering what I should do next, Seiran Island agreed to take me in. I agreed right away when they said I could handle guns too♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“在那之后，当我无所事事不知道该怎么办的时候，青蓝岛收留了我。而且因为还愿意让我碰枪，所以聊两句后我就回复OK了♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「在那之後，當我無所事事不知道該怎麼辦的時候，青藍島收留了我。而且因為還願意讓我碰槍，所以聊兩句後我就回覆OK了♪」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00316",
		linknext = "0008_00318",
