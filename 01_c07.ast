			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“You so said it. Can’t the Lewd Code get signed already so the whole world can join the USP...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“没错，不知道能不能赶快执行变态法，让全世界都加入USD呢～？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「沒錯，不知道能不能趕快執行變態法，讓全世界都加入USD呢～？」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00242",
