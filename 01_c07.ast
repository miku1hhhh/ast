				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“H... Hold up, that’s not funny! That means we’ll basically end up being the people we were here! And if that happens—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“喂……喂喂，别开玩笑了！那在这里的自己最后会变成几乎同一个身份了！如果是那样的话──。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「喂……喂喂，別開玩笑了！那在這裡的自己最後會變成幾乎同一個身分了！如果是那樣的話──。」",
					{"rt2"},
				},
			},
		},
