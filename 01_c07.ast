	["0008_00242"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00202", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0077", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Of course, my data also states these issues should vanish if the USP is founded. A more refined organization should improve the SHO’s nature as well.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“嗯，根据我的数据显示，这种事情只要USD一开始动身应该就会不见了。组织讲究的话，SHO的体质应该也会被改善吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「嗯，根據我的數據顯示，這種事情只要USD一開始動身應該就會不見了。組織講究的話，SHO的體質應該也會被改善吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00241",
		linknext = "0008_00243",
		line = 3517,
	},
	["0008_00243"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00207", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
