	},
	["0008_00266"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00213", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="スス子11", id=11, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0081", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“She might not seem it, but she’s such a military nerd. She wants to swing weapons around so bad that she refused a desk job to be here on the ground.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“这个人虽然外观看不出来，但可是个军事通唷。她是因为太想碰武器，所以拒绝了管理职留在现场。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「這個人雖然外觀看不出來，但可是個軍事通唷。她是因為太想碰武器，所以拒絕了管理職留在現場。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00265",
		linknext = "0008_00267",
		line = 3877,
	},
	["0008_00267"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That sounds like the last person you’d want to arm.",
					{"rt2"},
				},
			},
			cn = {
				{
					"要是让那个人拿到枪械不就会是最危险的人吗。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要是讓那個人拿到槍械不就會是最危險的人嗎。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00266",
		linknext = "0008_00268",
		line = 3887,
	},
	["0008_00268"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00201", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0007", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“This truck automatically recognizes the faces of pedophiles and fires tracking missiles at them. The Pedo-Riot (21)! Its abbreviation is PAD21, and it’s nicknamed the ‘Booby Missile.’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“这台卡车是Pedriot（２１），会发射导弹自动追击萝莉控的脸！由于简称为PAD21，所以又俗称为“木兰飞弹”。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「這台卡車是Pedriot（２１），會發射導彈自動追擊蘿莉控的臉！由於簡稱為PAD21，所以又俗稱為「木蘭飛彈」。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00267",
		linknext = "0008_00269",
		line = 3902,
	},
	["0008_00269"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00214", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What a cute name for such a deadly weapon...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“相对于它的杀伤力，名字也太可爱了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「相對於它的殺傷力，名字也太可愛了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00268",
		linknext = "0008_00270",
		line = 3914,
	},
	["0008_00270"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00203", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="光姫17", id=17, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0008", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Ah, and I’m seeing these for the first time myself! Experimental EMP bombs, used to destroy electrical circuits of all kinds! It’s said they’re able to cause the fall of enemy civilizations!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“哎呀，这台我也是第一次看到，是试作型的电磁脉冲波爆弹！由于借由EMP攻撃，可以破坏所有的电子回路，所以据说有葬送对方文明的效果！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「哎呀，這台我也是第一次看到，是試作型的電磁脈衝波爆彈！由於藉由EMP攻撃，可以破壞所有的電子迴路，所以據說有葬送對方文明的效果！」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00269",
		linknext = "0008_00271",
		line = 3930,
	},
	["0008_00271"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00213", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Are we really in Japan right now...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这里真的是日本吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這裡真的是日本嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00270",
		linknext = "0008_00272",
		line = 3942,
	},
	["0008_00272"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00202", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0009", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“And of course, this is the SHO’s latest weapon, origin unknown! The anti-radiation missile!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“还有无论如何都不能不提到的这台SHO最近采购的来路不明的武器！对辐射源飞弹！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「還有無論如何都不能不提到的這台SHO最近採購的來路不明的武器！對輻射源飛彈！」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00271",
		linknext = "0008_00273",
		line = 3957,
	},
	["0008_00273"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00203", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0010", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“These can pick up on communication waves used to launch enemy missiles and fire missiles back at the source of the signal, and they’ve been miniaturized to the greatest extent possible!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“这是能捕捉到敌方发射飞弹的通信电波，对其发信源发射反导弹的系统，将其尽可能最小化的成品！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「這是能捕捉到敵方發射飛彈的通信電波，對其發信源發射反導彈的系統，將其盡可能最小化的成品！」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00272",
		linknext = "0008_00274",
		line = 3972,
	},
	["0008_00274"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00202", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0011", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“The system, missiles and detectors included, fits in the palm of your hands. It’s a superb weapon able to take out any enemy who tries to go on the electronic offensive with suspect radio waves!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“不论是飞弹还是探测机，全部都缩小为手掌的大小，能把使用可疑电波设置电子攻击的对手一击毁灭，非常优秀！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「不論是飛彈還是探測機，全部都縮小為手掌的大小，能把使用可疑電波設置電子攻擊的對手一擊毀滅，非常優秀！」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00273",
		linknext = "0008_00275",
		line = 3987,
	},
	["0008_00275"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“This is getting so scary...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“太厉害了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「太厲害了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00274",
		linknext = "0008_00276",
		line = 3999,
	},
	["0008_00276"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00207", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="光姫17", id=17, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0012", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Oh, but these are all riot rounds, you know.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“啊、当然这些全部都是防暴弹唷。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「啊、當然這些全部都是防暴彈唷。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00275",
		linknext = "0008_00277",
		line = 4015,
	},
	["0008_00277"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00214", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Is it just me, or do you think any weapon is okay as long as you say that...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你不觉得这句话先讲在前头比较好吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳不覺得這句話先講在前頭比較好嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00276",
		linknext = "0008_00278",
		line = 4027,
	},
	["0008_00278"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Apparently these are all non-lethal, and just meant to neutralize enemies.",
					{"rt2"},
				},
			},
			cn = {
				{
					"场面话可能会说实际上不具任何杀伤力，全部都是无效化。",
					{"rt2"},
				},
			},
			tw = {
				{
					"場面話可能會說實際上不具任何殺傷力，全部都是無效化。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00277",
		linknext = "0008_00279",
		line = 4037,
	},
	["0008_00279"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00202", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0013", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Even this palm-sized missile is only meant to neutralize individuals sending out suspicious radio waves. It also has a short, ten-meter range to prevent accidental friendly fire.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“这个手掌大小的飞弹，也是为了能将发出可疑电波的个人无效化而研发的。为了避免误射，射程距离为10米左右，距离很短。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「這個手掌大小的飛彈，也是為了能將發出可疑電波的個人無效化而研發的。為了避免誤射，射程距離為10公尺左右，距離很短。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00278",
		linknext = "0008_00280",
		line = 4052,
	},
	["0008_00280"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Radio waves? That must mean it’s for electronic warfare.",
					{"rt2"},
				},
			},
			cn = {
				{
					"发射电波也就是打算做电子战斗吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"發射電波也就是打算做電子戰鬥吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00279",
		linknext = "0008_00281",
		line = 4062,
	},
	["0008_00281"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...It would’ve been pretty bad news if these existed in our world.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……这个如果在我的世界出现的话，相当危险啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……這個如果在我的世界出現的話，相當危險啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00280",
		linknext = "0008_00282",
		line = 4072,
	},
	["0008_00282"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My little sister was constantly jamming signals, after all...",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为我的妹妹时常会发射出妨碍电波……。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為我的妹妹時常會發射出妨礙電波……。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00281",
		linknext = "0008_00283",
		line = 4082,
	},
	["0008_00283"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...Right.",
					{"rt2"},
				},
			},
