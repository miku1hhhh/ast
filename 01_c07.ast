					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Ah... Your Sexellency! You caught me in such an unseemly moment... Thank you as always for all your hard work!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“啊……性帝大人！让您看到这丑陋的一面……您辛苦了！”",
