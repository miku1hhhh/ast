				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Cock-ie! You know the higher-ups are gonna get super sore about it if you’re slacking around here again!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
