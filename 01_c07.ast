			tw = {
				{
					name = {"郁子"},
					"「這麼一說……我今天在變態遊樂園H・ERO表演舞台做殺陣監督，那裡沒有Hamedori君的石像……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00351",
		linknext = "0008_00353",
		line = 5042,
	},
	["0008_00353"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He’s Seiran Island’s mascot in our world, and so he can be found all over the place.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在我们的世界，那是青蓝岛的吉祥物，岛上到处都有放置。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在我們的世界，那是青藍島的吉祥物，島上到處都有放置。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00352",
		linknext = "0008_00354",
		line = 5052,
	},
	["0008_00354"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They sell Hamedori merchandise at souvenir shops, and someone in a Hamedori suit goes around promoting the island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在伴手礼区有贩卖Hamedori君的周边商品，在促销活动时也会出现穿着Hamedori君的人偶。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在伴手禮區有販賣Hamedori君的周邊商品，在促銷活動時也會出現穿著Hamedori君的人偶。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00353",
		linknext = "0008_00355",
		line = 5062,
	},
	["0008_00355"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But there’s no Hamedori to be found here. Not in town, not at Lewd Land, not even in the promotional video that plays on the ship.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是在这里，不管是在城市中、变态游乐园里、在船上播放的视频里，不管哪里都没有Hamedori君。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是在這裡，不管是在城市中、變態遊樂園裡、在船上播放的影片裡，不管哪裡都沒有Hamedori君。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00354",
		linknext = "0008_00356",
		line = 5072,
	},
	["0008_00356"] = {
		{"evset", file="kcg03", set="kcg03", path=":ev/kcg03/"},
		{"evset", file="kcg030002040401", set="kcg030002", path=":ev/kcg030002/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg030002040401", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0156", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I just checked, and it appears as though Holeyrhythm was never released in this world either.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“刚才试着调查。看来这个世界中好像连“爱爱主义”都没有发行。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「剛才試著調查。看來這個世界中好像連「愛愛主義」都沒有發行。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00355",
		linknext = "0008_00357",
		line = 5091,
	},
	["0008_00357"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0157", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Well, it technically came out, but the music video featuring Hamedori suit actors was never filmed. The song itself was only a mild hit as well.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“正确上来说，有发行但是没有拍摄穿着Hamedori君人偶的MV。歌曲本身好像也是卖得不愠不火地就结束了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「正確上來說，有發行但是沒有拍攝穿著Hamedori君人偶的MV。歌曲本身好像也是賣得不慍不火地就結束了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00356",
		linknext = "0008_00358",
		line = 5103,
	},
	["0008_00358"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The Hamedori suit was never made as a result of that song, the catalyst for the Hamedori craze.",
					{"rt2"},
				},
			},
			cn = {
				{
					"原本是因Hamedori君热潮促成的那首歌，却没有制作Hamedori君的人偶。",
					{"rt2"},
				},
			},
			tw = {
				{
					"原本是因Hamedori君熱潮促成的那首歌，卻沒有製作Hamedori君的人偶。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00357",
		linknext = "0008_00359",
		line = 5113,
	},
	["0008_00359"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"While he did exist as a mascot, created during the SHO’s founding...",
					{"rt2"},
				},
			},
			cn = {
				{
					"原本是吉祥物的Hamedori君，应该在SHO开始活动时就被制作出来，所以才存在的……。",
					{"rt2"},
				},
			},
			tw = {
				{
					"原本是吉祥物的Hamedori君，應該在SHO開始活動時就被製作出來，所以才存在的……。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00358",
		linknext = "0008_00360",
		line = 5123,
	},
	["0008_00360"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We’re in a world where there was never a Hamedori craze. He only exists as a concept, one that everyone here would have forgotten by now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这里几乎大家都忘记，只空有形式，这个世界并没有发生Hamedori君热潮。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這裡幾乎大家都忘記，只空有形式，這個世界並沒有發生Hamedori君熱潮。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00359",
		linknext = "0008_00361",
		line = 5133,
	},
	["0008_00361"] = {
		{"evset", file="kcg03", set="kcg03", path=":ev/kcg03/"},
		{"evset", file="kcg030005040401", set="kcg030005", path=":ev/kcg030005/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg030005040401", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0158", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“His Sexellency’s presence is probably a major reason for that. While you may not be a symbol for the island on Hamedori’s level, there was still no reason to ever reuse him.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“原因大概是因为‘性帝’的存在感太大吧。就算Hamedori君没有出现，也已经有象征性人物，就不需要再次利用了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「原因大概是因為『性帝』的存在感太大吧。就算Hamedori君沒有出現，也已經有象徵性人物，就不需要再次利用了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00360",
		linknext = "0008_00362",
		line = 5152,
	},
	["0008_00362"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hamedori did appear in promotional videos before I transferred here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我在转校过来前，Hamedori君曾出现在视频中。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我在轉校過來前，Hamedori君曾出現在影片中。",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00361",
		linknext = "0008_00363",
		line = 5162,
	},
	["0008_00363"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Apparently it was an emergency measure, as Senba had trouble promoting it on her own.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那也听说是因为只靠仙波小姐的话宣传效果不够，所以才紧急决定使用的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那也聽說是因為只靠仙波小姐的話宣傳效果不夠，所以才緊急決定使用的。",
					{"rt2"},
				},
			},
		},
