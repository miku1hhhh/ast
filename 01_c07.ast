	["0008_00316"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00206", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0023", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“I was able to support my sister thanks to that and ended up getting a job offer too, but right after that I got into a bunch of Lonely Fans drama and they rescinded the offer...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“之后总算能负担扶养妹妹的费用，也取得了公司的内定，不过马上又在YoukakuTuber上引起极大的争议，内定也被取消了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「之後總算能負擔扶養妹妹的費用，也取得了公司的內定，不過馬上又在YoukakuTuber上引起極大的爭議，內定也被取消了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00315",
		linknext = "0008_00317",
		line = 4543,
	},
	["0008_00317"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00202", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=-5, y=-5},
