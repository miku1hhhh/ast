		{"fgact", ch="光姫17", id=17, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0026", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“I made sure to call the hit even when I came after someone shot my clitty and I wanted them to keep on firing, you know?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“但是当阴核被子弹射到高潮，想被多射一点的时候，我也有好好喊出被击中喔！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「但是當陰核被子彈射到高潮，想被多射一點的時候，我也有好好喊出被擊中喔！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00321",
		linknext = "0008_00323",
		line = 4628,
	},
	["0008_00323"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00214", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I get that you weren’t a zombie, but it sounds like you were still pretending to be in Night of the Giving Head.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这已经不是僵尸，而是淫湿了吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這已經不是殭屍，而是淫濕了吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0008_00322",
		linknext = "0008_00324",
