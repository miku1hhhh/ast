	["0008_00039"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I wanna meet my bratty shut-in of a little sister with a shitty personality who’s so uneducated she can’t do grade-school math and talks a big game when she’s actually useless!!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我好想那个明明自己的事情什么都不会只会出一张嘴，又没教养，连小学的算数都不会，还性格扭曲，有够嚣张狂妄的家里蹲妹妹～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
