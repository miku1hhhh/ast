					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“由一番队的孩子指挥二・三番队啊，要是放过一只老鼠就要让你们尝尝很舒服的惩罚了喔？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「由一番隊的孩子指揮二・三番隊啊，要是放過一隻老鼠就要讓你們嘗嘗很舒服的懲罰了喔？」",
					{"rt2"},
				},
			},
		},
