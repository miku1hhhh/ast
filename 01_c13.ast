			cn = {
				{
					name = {"郁子"},
					"“但是关到明天早上又会怎么样呢？NLNS的秘密基地不是有可以住一周左右的设备吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「但是關到明天早上又會怎麼樣呢？NLNS的秘密基地不是有可以住一週左右的設備嗎？」",
					{"rt2"},
				},
			},
		},
