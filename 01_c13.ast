		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00212", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0192", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Sorta seems like you got super psyched there... So what, is that what you’re into? Making your juniors slide up their skirts?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“怎么，你好像很兴奋嘛……怎么说，阿橘原来有这种兴趣吗。竟然会因为后辈掀裙子而兴奋吗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「怎麼，你好像很興奮嘛……怎麼說，阿橘原來有這種興趣嗎。竟然會因為後輩掀裙子而興奮嗎。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00320",
		linknext = "0021_00322",
		line = 5025,
	},
	["0021_00322"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If you’re just asking whether or not I found it arousing, of course I do... But there’s more to it than that, you realize.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“要是你问我兴不兴奋，那当然是兴奋……但可不只是那样喔？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「要是妳問我興不興奮，那當然是興奮……但可不只是那樣喔？」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00321",
		linknext = "0021_00323",
		line = 5037,
	},
	["0021_00323"] = {
