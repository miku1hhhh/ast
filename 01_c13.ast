			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“But you weren’t routed? Good job! FS second and third units, stand by! Work with the SHO to encircle them, and be careful for reinforcements! They may have supporting fire too!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“没有完全被击溃吗，太好了！FS二番队和三番队待命！SHO合作做出包围网，警戒援军来袭！也可以支援火器！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「沒有完全被擊潰嗎，太好了！FS二番隊和三番隊待命！SHO合作做出包圍網，警戒援軍來襲！也可以支援火器！」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00390",
		linknext = "0021_00392",
		line = 6054,
	},
