					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“而且只有爱爱是无法脱出的，要根据监视系统所监测的‘催产素’，确认幸福度够高才会开门。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「而且只有愛愛是無法脫出的，要根據監視系統所監測的『催產素』，確認幸福度夠高才會開門。」",
					{"rt2"},
				},
			},
		},
