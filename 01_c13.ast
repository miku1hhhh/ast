		text = {
			vo = {
				{"vo", file="misaki0068", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Allow me to act as your shield, my precious comrade! Oh, but having my anal virginity taken all of a sudden like this... No, I can’t, no, I can’t, it’s just so mortifying that I’m gonna coooooome❤”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“为了重要的伙伴，我就成为肉盾吧！但是要突然被夺走屁股的处女……光想像就很不甘心，不甘心，太不甘心了都要高潮了──",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「為了重要的夥伴，我就成為肉盾吧！但是要突然被奪走屁股的處女……光想像就很不甘心，不甘心，太不甘心了都要高潮了──",
					{"gaiji", text="①"},
					"」",
					{"rt2"},
				},
			},
		},
