		text = {
			vo = {
				{"vo", file="tohka0507", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“So, how do we handle a problem when one occurs? I’d like you to always keep in mind your chain of communication and who you should report to if there’s anything you don’t know.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“首先在发生问题时要如何应对，联络系统如何运作，不确定时该跟谁报告，要时常意识到这些事来行动。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「首先在發生問題時要如何應對，聯絡系統如何運作，不確定時該跟誰報告，要時常意識到這些事來行動。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00004",
		linknext = "0021_00006",
		line = 77,
	},
	["0021_00006"] = {
