			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Indeed. My idea was for a room you can’t escape unless you have perverted sex. Two teams are trapped inside and have to work together to break out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“没错，我想到的就是‘不做色色的事就不能出去的房间’，把两队关在一起，然后要互相帮助努力逃脱的游戏。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「沒錯，我想到的就是『不做色色的事就不能出去的房間』，把兩隊關在一起，然後要互相幫助努力逃脫的遊戲。」",
					{"rt2"},
				},
			},
		},
