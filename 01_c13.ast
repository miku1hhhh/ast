			en = {
				{
					name = {"茅津野アナ", "Pussy Galore"},
					"“Gooooooal! While there were some unexpected bumps in the road, everyone has made it to the top! In a record-breaking five minutes and twenty-one seconds too! What an extraordinary time, Miss Kouki!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"茅津野アナ", "茅津野播报员"},
					"‘达阵────！！虽然好像发生了一点事件，但全部成员都登顶成功了！而且记录是5分21秒！这真是令人惊讶的成绩啊，光姫同学！’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"茅津野アナ", "茅津野播報員"},
					"『達陣────！！雖然好像發生了一點事件，但全部成員都登頂成功了！而且記錄是5分21秒！這真是令人驚訝的成績啊，光姫同學！』",
					{"rt2"},
				},
			},
		},
