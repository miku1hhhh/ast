		line = 2741,
	},
	["0021_00170"] = {
		{"fg", file="tohka_02f_00001", file1="tohka_02f_00101", file2="tohka_02f_00201", path=":fg/tohka_02f/", id=30, ch="桐香", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0524", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
