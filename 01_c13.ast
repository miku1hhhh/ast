					name = {"桐香"},
					"“SHO的警备位置则是以例外的方式显示，在22点活动结束前，这个状态应该还会持续下去吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「SHO的警備位置則是以例外的方式顯示，在22點活動結束前，這個狀態應該還會持續下去吧。」",
					{"rt2"},
				},
			},
		},
