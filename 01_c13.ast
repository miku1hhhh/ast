					name = {"郁子"},
					"“好痛──！……唉呀呀，我还以为没被发现所以没防御，好像不是这样呢……那个椅子真的很乱来啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「好痛──！……唉呀呀，我還以為沒被發現所以沒防禦，好像不是這樣呢……那個椅子真的很亂來啊。」",
					{"rt2"},
				},
			},
		},
