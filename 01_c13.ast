	["0021_00328"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00210", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The important part is you looking disgusted. That’s what gets me hard.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“重要的是‘露出嫌恶的表情’。这样肉棒就会变硬──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「重要的是『露出嫌惡的表情』。這樣肉棒就會變硬──」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00327",
		linknext = "0021_00329",
		line = 5117,
	},
	["0021_00329"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00211", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If anything, the best masturbation fodder is of something you don’t normally like, or even something you loathe.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不如说要拿来当配菜的，就是平常不喜欢的人，或是有嫌恶感的人最好。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不如說要拿來當配菜的，就是平常不喜歡的人，或是有嫌惡感的人最好。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00328",
		linknext = "0021_00330",
		line = 5130,
	},
	["0021_00330"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Meanwhile, the greatest fap material of all is someone openly showing their contempt for you.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对手表现出嫌恶感反而是最棒的配菜。",
