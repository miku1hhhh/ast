		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0505", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“...And we’re ready to take on this day thanks to all of your hard work.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“……经过各位的努力，总算迎来这个日子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「……經過各位的努力，總算迎來這個日子。」",
					{"rt2"},
				},
			},
		},
		linknext = "0021_00002",
		line = 24,
	},
	["0021_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Regardless of it being the morning of our day off, every FS member is gathered in the disciplinary committee room, standbys and new recruits included.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然是假日早上，包含待命伙伴及新兵的全部FS都聚集在风纪委员室。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然是假日早上，包含待命夥伴及新兵的全部FS都聚集在風紀委員室。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00001",
		linknext = "0021_00003",
		line = 34,
	},
	["0021_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Touka stands before the throng of people, speaking to her comrades in her usual easygoing manner.",
					{"rt2"},
				},
			},
			cn = {
				{
					"站在大众面前的桐香，用平常那超脱于世俗的样子和伙伴说话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"站在大眾面前的桐香，用平常那超脫於世俗的樣子和夥伴說話。",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00002",
		linknext = "0021_00004",
		line = 44,
	},
	["0021_00004"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0506", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“This will be a large-scale event taking place across the entire island. Given that fact, we expect there to be many lost children and injured visitors.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“这次的活动规模很大，会使用到全岛，所以迷路的人跟受伤的人应该也很多。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「這次的活動規模很大，會使用到全島，所以迷路的人跟受傷的人應該也很多。」",
					{"rt2"},
				},
			},
		},
		linkback = "0021_00003",
		linknext = "0021_00005",
		line = 59,
	},
	["0021_00005"] = {
