	},
	["0018_00063"] = {
		{"fg", file="rei_02m_00008", file1="rei_02m_00101", file2="rei_02m_00220", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0442", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Oh, Junnosuke. What’re you doing here at this hour? Taking a break too?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“喔喔淳之介，怎么了这时间过来，你也要休息吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「喔喔淳之介，怎麼了這時間過來，你也要休息嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0018_00062",
		linknext = "0018_00064",
		line = 859,
	},
	["0018_00064"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, I was feeling a little thirsty... Were you working too, Rei?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，喉咙有点渴了……礼前辈也在工作中吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，喉嚨有點渴了……禮前輩也在工作中嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0018_00063",
		linknext = "0018_00065",
		line = 871,
	},
	["0018_00065"] = {
