					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I’ll pass on the milk, thanks. Both me and my sister have weak digestion. Just imagine how it’d look if I started shitting myself right in the middle of a battle.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“牛奶就先不了，我们兄妹的肠胃都有点弱，要是战斗中拉肚子可就难看了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「牛奶就先不了，我們兄妹的腸胃都有點弱，要是戰鬥中拉肚子可就難看了。」",
					{"rt2"},
				},
			},
		},
