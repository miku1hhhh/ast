		text = {
			vo = {
				{"vo", file="tohka0422", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“...We were able to complete all preparations for the Real Ultimate Pussy Breakout Game without incident today. Now we simply have to wait for it to begin tomorrow.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“……真实大蜜穴逃脱的准备，今天已经全部平安结束了。之后就等明天的正式展开了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「……真實大蜜穴逃脫的準備，今天已經全部平安結束了。之後就等明天的正式展開了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0018_00002",
		linknext = "0018_00004",
		line = 51,
	},
	["0018_00004"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00210", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So the day is finally here... Heh, never imagined the day would come when I’d be heading into an event on the side of the FS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“总算、吗……呵，没想到我竟然以FS的身份迎接活动到来──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「總算、嗎……呵，沒想到我竟然以FS的身份迎接活動到來──」",
					{"rt2"},
				},
			},
		},
		linkback = "0018_00003",
		linknext = "0018_00005",
		line = 63,
	},
	["0018_00005"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
