		},
		text = {
			vo = {
				{"vo", file="rei0443", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I’m not the only one, though I dunno about Ikuko. Miss Touka should still be doing paperwork, at the very least. She received reports from FS members who just returned.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“除了我大家都在工作啊。啊，郁子我就不知道了。但是至少桐香大人还在看文件，刚才回来的FS有提交一些报告。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「除了我大家都在工作啊。啊，郁子我就不知道了。但是至少桐香大人還在看文件，剛才回來的FS有提交一些報告。」",
					{"rt2"},
				},
			},
		},
		linkback = "0018_00064",
		linknext = "0018_00066",
		line = 892,
	},
	["0018_00066"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file3="jun_01f_00309", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You know, I can’t really blame her for having such a hard time waking up in the mornings.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那家伙就算早上起不来，也没办法骂她呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那傢伙就算早上起不來，也沒辦法罵她呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0018_00065",
		linknext = "0018_00067",
		line = 904,
	},
