				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I don’t mind you trying to act all cool about this, but what ever happened with what we were discussing the day before yesterday? You said you’d be getting someone’s help...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“虽然装帅是没关系啦淳之介，但前天的事怎样了？虽然你说会有人来帮──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「雖然裝帥是沒關係啦淳之介，但前天的事怎樣了？雖然你說會有人來幫──」",
					{"rt2"},
				},
			},
		},
		linkback = "0018_00004",
