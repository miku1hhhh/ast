				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I find Rei there, standing in front of the communal fridge.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就看见礼前辈站在有十几公升容积的冰箱前面。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就看見禮前輩站在有十幾公升容積的冰箱前面。",
