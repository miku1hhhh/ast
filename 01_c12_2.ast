	["0018_00062"] = {
		{"bgm", file="bgm38", vol=100},
		{"fg", file="rei_01m_00008", file1="rei_01m_00101", file2="rei_01m_00212", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
