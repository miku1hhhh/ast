				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You said it. She really does overwork herself... Glug, glug... Hooh! You really can’t beat milk at this hour!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“真的，她实在是太过劳……咕噜、咕噜……噗哈！这时间喝的牛奶真是太棒啦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「真的，她實在是太過勞……咕嚕、咕嚕……噗哈！這時間喝的牛奶真是太棒啦！」",
					{"rt2"},
				},
			},
		},
