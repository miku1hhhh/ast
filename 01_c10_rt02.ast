	["0002_00046"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ikuko may seem detached sometimes, but she clearly cares a lot about her comrades.",
					{"rt2"},
				},
			},
			cn = {
				{
					"郁子用一种无所谓、漫不经心的态度关心着伙伴们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"郁子用一種無所謂、漫不經心的態度關心著夥伴們。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00045",
		linknext = "0002_00047",
		line = 699,
	},
	["0002_00047"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Back when she was my enemy, she always seemed to be doing her own thing, but now it’s clear that Ikuko really pays attention to everything going on around her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"以前和她敌对时，我觉得她是刚愎自用、独断独行的人。但这么表现得郁子，可能比任何人都更关心身边人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"以前和她敵對時，我覺得她是剛愎自用、獨斷獨行的人。但這麼表現得郁子，可能比任何人都更關心身邊人。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00046",
		linknext = "0002_00048",
		line = 709,
	},
	["0002_00048"] = {
