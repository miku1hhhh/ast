					name = {"淳之介", "Junnosuke"},
					"“I would’ve thought that announcement would wake her up for sure.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过，她大概也被刚才的广播吵醒了吧。”",
