		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I want to do what I can to get this island moving in the right direction, even just a little bit, until I can return home.",
					{"rt2"},
				},
			},
			cn = {
				{
					"直到回到原来的世界之前，我都想踏踏实实的努力，让这个岛往更好的方向发展。",
