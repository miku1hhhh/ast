					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Oh dear, I hate to see FS troops given time off from their studies to help prepare for the event, only to waste it messing around with the Ass Wall! Very disappointing!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“这不是FS的大家吗，说为了准备活动而取消了上课，结果就只是弄出这个内轮承轴而已啊！还真是玩得很尽兴呢～！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「這不是FS的大家嗎，説為了準備活動而取消了上課，結果就只是弄出這個內輪承軸而已啊！還真是玩得很盡興呢～！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00170",
