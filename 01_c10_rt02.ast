					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「別的精子都已經用排卵節一樣的氣勢在操場集合了！你這連學校都還沒進的處男算什麼性帝啊！勃起之前先給我站起來吧！」",
					{"rt2"},
				},
			},
		},
