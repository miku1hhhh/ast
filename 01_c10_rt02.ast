				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Class president’s a tough job, but I have to admit I’m jealous of her right now...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“学生会长就是不一样呢……哈啊……真点羡慕呢。”",
