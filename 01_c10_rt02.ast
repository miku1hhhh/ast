					name = {"スス子", "絲絲子"},
					"「所以橘同學，你有什麼事嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00215",
		linknext = "0002_00217",
		line = 3274,
	},
	["0002_00217"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I hope one day everyone can just casually chat to me like Susuko.",
					{"rt2"},
				},
			},
			cn = {
				{
					"总有一天，大家应该都能像丝丝子这样友好地和我交谈。",
					{"rt2"},
				},
			},
			tw = {
				{
					"總有一天，大家應該都能像絲絲子這樣友好地和我交談。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00216",
		linknext = "0002_00218",
		line = 3284,
	},
	["0002_00218"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=14},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We’re short-handed on the crowd management side, can you lend us some of your team?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为要筹备活动，我们的引导人员人手不够。虽然你们很忙，但能不能在那边分配点人手？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為要籌備活動，我們的引導人員人手不夠。雖然你們很忙，但能不能在那邊分配點人手？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00217",
		linknext = "0002_00219",
		line = 3296,
	},
	["0002_00219"] = {
		{"fg", file="susuko_02m_00002", file1="susuko_02m_00101", file2="susuko_02m_00213", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-405, y=-5},
