	["0002_00230"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Another small step... But I’m closing the distance between His Sexellency and the people of the island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"依旧只是屈指可数，但‘性帝’正一点点地与身边人拉近距离。",
					{"rt2"},
				},
			},
			tw = {
				{
					"依舊只是屈指可數，但『性帝』正一點點地與身邊人拉近距離。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00229",
		linknext = "0002_00231",
		line = 3494,
	},
	["0002_00231"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If one person becomes a focus for everyone’s admiration and fear, their impression of that person is hardly gonna be normal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果所有人都崇拜一个人，那么思想就不可避免地会变得片面。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果所有人都崇拜一個人，那麼思想就不可避免地會變得片面。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00230",
		linknext = "0002_00232",
		line = 3504,
	},
	["0002_00232"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And that risks coloring every interaction, which will only make people more insular and restrictive.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果你的想法有偏见，将无法认同它以外的事物，产生排他性的想法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果你的想法有偏見，將無法認同它以外的事物，產生排他性的想法。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00231",
		linknext = "0002_00233",
		line = 3514,
	},
	["0002_00233"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This island glorifies perverted sex so much, they’ve become aggressive to anyone who’s not interested in it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"事实上，这个岛如此推崇淫荡，以致于对不这样做的人极度咄咄逼人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"事實上，這個島如此推崇淫蕩，以致於對不這樣做的人極度咄咄逼人。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00232",
		linknext = "0002_00234",
		line = 3524,
	},
	["0002_00234"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And the island in this world has even stronger feelings about perverted sex than my old one.",
					{"rt2"},
				},
			},
			cn = {
				{
					"最重要的是，这里比我们所在的世界更加赞扬着变态行为。",
					{"rt2"},
				},
			},
			tw = {
				{
					"最重要的是，這裡比我們所在的世界更加讚揚著變態行為。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00233",
		linknext = "0002_00235",
		line = 3534,
	},
	["0002_00235"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They’re trying to extend beyond the island, to conquer the world and enforce their perverted desires upon it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这导致他们不仅只想要在这个岛上推想，还想把它传遍全世界。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這導致他們不僅只想要在這個島上推想，還想把它傳遍全世界。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00234",
		linknext = "0002_00236",
		line = 3544,
	},
	["0002_00236"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The whole reason that the perverted sex law has been tolerated by the outside world, despite its extreme nature, is due to His Sexellency, a symbol that inspires people to fight for it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"之所以能在这个世界上肆无忌惮地推行着变态法之类的极端思想，或许是因为性帝这个绝对的象征正在让人热血沸腾。",
					{"rt2"},
				},
			},
			tw = {
				{
					"之所以能在這個世界上肆無忌憚地推行著變態法之類的極端思想，或許是因為性帝這個絕對的象徵正在讓人熱血沸騰。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00235",
		linknext = "0002_00237",
		line = 3554,
	},
	["0002_00237"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This may not be my world, but it still contains my friends.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这里当然不是我生活的那个世界，但我亲爱的朋友们还活在这里，所以没有什么区别。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這裡當然不是我生活的那個世界，但我親愛的朋友們還活在這裡，所以沒有什麼區別。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00236",
		linknext = "0002_00238",
		line = 3564,
	},
	["0002_00238"] = {
