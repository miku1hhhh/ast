		text = {
			vo = {
				{"vo", file="ikuko0366", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Touka’s not coming. She’s got a special mission to take care of, so she’s still asleep.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“桐香酱不会来唷。特别的工作项目都是她一个人在做嘛，所以现在还在睡呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「桐香醬不會來唷。特別的工作項目都是她一個人在做嘛，所以現在還在睡呢。」",
					{"rt2"},
				},
