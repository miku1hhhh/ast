					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Anyway, ’Bana, what’s up?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“所以橘同学，你有什么事吗？”",
					{"rt2"},
				},
			},
			tw = {
