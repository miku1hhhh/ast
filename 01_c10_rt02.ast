	["0002_00180"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The debate over the Ass Walls had raged for a long time, and the scars of the conflict remained...",
					{"rt2"},
				},
			},
			cn = {
				{
					"看来，壁尻派和尻壁派之间的宗教战争还是根深蒂固的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看來，壁尻派和尻壁派之間的宗教戰爭還是根深蒂固的。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00179",
		linknext = "0002_00181",
		line = 2729,
	},
	["0002_00181"] = {
		{"fg", file="rin_01m_00001", file1="rin_01m_00101", file2="rin_01m_00203", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=395, y=-5},
