	["0002_00267"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s nice to see her care for my friends, even though she’s acting as an FS officer.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她身为FS，同时也会关心我的同伴，真的让我很高兴。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她身為FS，同時也會關心我的同伴，真的讓我很高興。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00266",
		linknext = "0002_00268",
		line = 3961,
	},
	["0002_00268"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That said, the event itself was an indirect ploy to uncover Hinami and the others, so she was acting on behalf of the NLNS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"本来，会举办这个活动还有另一个目的就是为了对付NLNS、用于回的手段逼出雏见她们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"本來，會舉辦這個活動還有另一個目的就是為了對付NLNS、用於回的手段逼出雛見她們。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00267",
		linknext = "0002_00269",
		line = 3971,
	},
	["0002_00269"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Using the power of the FS, it would be easy to lure them out into the open.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只要使用FS的权力，要强制叫她们出来是轻而易举的事吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只要使用FS的權力，要強制叫她們出來是輕而易舉的事吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00268",
		linknext = "0002_00270",
		line = 3981,
	},
	["0002_00270"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But the FS was under the direct observation of the SHO.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然而，FS目前正受到SHO的监视。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然而，FS目前正受到SHO的監視。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00269",
		linknext = "0002_00271",
		line = 3991,
	},
	["0002_00271"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The SHO clearly considered the FS a thorn in its side, and would doubtless have multiple hidden observers in addition to Hanamaru and Akino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"既然SHO真的畏惧FS的话，或许还准备了花丸妹或秋野以外的秘密监视人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"既然SHO真的畏懼FS的話，或許還準備了花丸妹或秋野以外的秘密監視人。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00270",
		linknext = "0002_00272",
		line = 4001,
	},
	["0002_00272"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Which is why we held our meetings in the baths, where no prying eyes or ears could bother us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这就是为什么我们要在一个没有其他人能看到的大浴池里开战略会议。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這就是為什麼我們要在一個沒有其他人能看到的大浴池裡開戰略會議。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00271",
		linknext = "0002_00273",
		line = 4011,
	},
	["0002_00273"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If we were to get in direct contact with an NLNS member, that information would end up at the SHO’s doorstep.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在这种情况下，如果我们直接联系NLNS成员──SHO可能会知道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在這種情況下，如果我們直接聯繫NLNS成員──SHO可能會知道。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00272",
		linknext = "0002_00274",
		line = 4021,
	},
	["0002_00274"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And if they found anything fishy, the SHO’s suspicions could end up falling on the NLNS members...",
					{"rt2"},
				},
			},
			cn = {
				{
					"万一事情变得可疑，SHO也会怀疑起NLNS的成员们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"萬一事情變得可疑，SHO也會懷疑起NLNS的成員們。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00273",
		linknext = "0002_00275",
		line = 4031,
	},
	["0002_00275"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Which in turn is why for this event, when contacting the NLNS, we needed the pretense of it being on behalf of the FS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以我们才得利用这场活动，伪装成“FS”这样自然来接触NLNS。",
