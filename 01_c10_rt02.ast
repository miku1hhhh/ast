		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As I stand there, mouth agape, someone taps me on the back.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当我还沉浸在诧异的情绪时，就感受到有人戳了戳我的背。",
