	["0002_00035"] = {
		{"fg", file="ikuko_01l_00001", file1="ikuko_01l_00101", file3="ikuko_01l_00312", path=":fg/ikuko_01l/", id=10, lv=10, head="ikuko_01l", alpha=0, ch_origin="郁子", ch="郁子10", mw="mw", sync=1, a_chr151=1, mode=3, x=595, y=-5},
		{"fgact", ch="郁子10", id=10, lv=10, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="郁子10", id=10, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0364", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Rei isn’t really good at turning it on and off, so once she’s in drill-sergeant mode, you’ll really get chewed out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“虽然礼酱笨手笨脚到连开关机都不会，不过她只要进入教官模式时就会变成这样子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「雖然禮醬笨手笨腳到連開關機都不會，不過她只要進入教官模式時就會變成這樣子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00034",
		linknext = "0002_00036",
		line = 548,
	},
	["0002_00036"] = {
