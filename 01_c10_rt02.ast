				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Not a preachy bitch, but a teachy bitch! Minus 100 points. Perjury, further deductions! And the fact that His Sexellency did this merits exponential punishment! MINUS ONE THOUSAND POINTS!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“我可不是小人，我只是在指导你们！旷职-100分、做虚假的申告的话会扣更多分喔！身为楷模的性帝大人来做的话就更要翻倍了所以是-1000分！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「我可不是小人，我只是在指導你們！曠職-100分、做虛假的申告的話會扣更多分喔！身為楷模的性帝大人來做的話就更要翻倍了所以是-1000分！」",
					{"rt2"},
				},
			},
		},
