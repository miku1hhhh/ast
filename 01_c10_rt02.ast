					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Heh! What I hate most is people lying to me, so I shall be sure to include some exaggerations of my own in my report!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“哼！反正我最讨厌被人骗，所以我会既夸张又戏剧化地报告这件事的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「哼！反正我最討厭被人騙，所以我會既誇張又戲劇化地報告這件事的！」",
					{"rt2"},
