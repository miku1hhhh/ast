	["0059_00027"] = {
		{"se", id=0, stop=1, time=1000},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It looks like you’ve been really busy. Ikuko told me you haven’t been sleeping a wink.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好像真的很忙的样子啊。话说回来，听郁子说了你完全没睡？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好像真的很忙的樣子啊。話說回來，聽郁子說了你完全沒睡？」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00026",
		linknext = "0059_00028",
		line = 346,
	},
	["0059_00028"] = {
		{"fg", file="tohka_02m_00004", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=295, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0913", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes. I was pressed for time because of the modification of that permit. Before I noticed, a week had already passed since I started.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“是啊。一直忙着修改之前的许可证。等到回过神来都过了一周了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「是啊。一直忙著修改之前的許可證。等到回過神來都過了一週了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00027",
		linknext = "0059_00029",
		line = 360,
	},
