	},
	["0059_00049"] = {
		{"fg", file="tohka_01m_00004", file1="tohka_01m_00102", file2="tohka_01m_00214", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0925", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“And... as we were spending a lot of time together... I made some very important memories... I’ve grown to want you so much that I couldn’t give up... My feelings have only gotten stronger.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“然后……在一同相处的过程之中……那些成了重要的回忆……无法放弃般的，欲望越来越大……这份感情也越来越强烈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「然後……在一同相處的過程之中……那些成了重要的回憶……無法放棄般的，慾望越來越大……這份感情也越來越強烈……」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00048",
		linknext = "0059_00050",
		line = 666,
	},
	["0059_00050"] = {
