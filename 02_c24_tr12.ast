		{"fg", file="tohka_02m_00004", file1="tohka_02m_00101", file2="tohka_02m_00211", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=295, y=-5},
