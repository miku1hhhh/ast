	["0059_00047"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0924", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes... I truly like you, Tachibana. From the bottom of my heart. I have had feelings for you ever since I saw you for the first time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“没错我真的很喜欢前辈呢……发自内心的……肯定是从见到他的第一面开始……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「沒錯我真的很喜歡前輩呢……發自內心的……肯定是從見到他的第一面開始……」",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00046",
		linknext = "0059_00048",
		line = 641,
	},
	["0059_00048"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Not only other people’s. She doesn’t understand even her own heart.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这不仅仅是对待他人，对待自己的心也是如此。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這不僅僅是對待他人，對待自己的心也是如此。",
					{"rt2"},
				},
			},
		},
		linkback = "0059_00047",
