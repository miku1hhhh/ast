			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hamedori losing in an air battle affects the FS’s good name! Now the time is ripe for revenge! Avenge Hamedori!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“Hamedori君若一直输给荒鹫之类的，也关系到FS的尊严！所以，现在就是雪耻的时候！我们是Hamedori复仇者！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「Hamedori君若一直輸給荒鷲之類的，也關係到FS的尊嚴！所以，現在就是雪恥的時候！我們是Hamedori復仇者！！」",
					{"rt2"},
				},
			},
		},
