			},
			[3999] = {
				{"transitiontime", time=300, timestamp=44, delay2=4000},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko1269", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“You may be having fun now, but what about five or ten years from now? I hope you never tire of him, but there’s always a chance of murder-suicide from caregiver fatigue.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“当然现在可能还会觉得快乐没错。但5年、10年一直这样的话呢？只是厌烦了倒还好，看护太累决定一起去死的传闻你也听过吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「當然現在可能還會覺得快樂沒錯。但5年、10年一直這樣的話呢？只是厭煩了倒還好，看護太累決定一起去死的傳聞妳也聽過吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00108",
		linknext = "0064_00110",
