		text = {
			vo = {
				{"vo", file="ikuko1270", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Caretaking isn’t that easy! Are you okay with his home life losing all happiness? He will get worn out and not want to be home anymore!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“看护才没有那么轻松！！听好了，会让一个家失去笑容！时常会消磨精神！会变得不想待在家里！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「看護才沒有那麼輕鬆！！聽好了，會讓一個家失去笑容！時常會消磨精神！會變得不想待在家裡！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00110",
		linknext = "0064_00112",
		line = 1963,
	},
