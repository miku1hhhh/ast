		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0259", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Exactly. We’re always trailing behind the NLNS. Now’s our chance for revenge!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“没错，我们每次都慢了NLNS一步！现在终于轮到我们复仇了！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「沒錯，我們每次都慢了NLNS一步！現在終於輪到我們復仇了！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00150",
