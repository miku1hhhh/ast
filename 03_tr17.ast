	["0064_00105"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00203", path=":fg/ikuko_02m/", id=10, lv=11, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=345, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1267", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“She stole my Darling from me which I hate. I want him and Tokie to be happy together, but these conflicting feelings are too much! You’re so inconsiderate, Rei!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“郁是因为亲爱的被抢走的不甘心，加上真的希望桐香酱能获得幸福，两种感情交错所以心情复杂！礼酱明明也一样吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「郁是因為親愛的被搶走的不甘心，加上真的希望桐香醬能獲得幸福，兩種感情交錯所以心情複雜！禮醬明明也一樣吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00104",
		linknext = "0064_00106",
		line = 1834,
	},
	["0064_00106"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00102", file3="rei_02m_00305", path=":fg/rei_02m/", id=9, lv=10, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-355, y=-5},
