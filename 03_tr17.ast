		text = {
			vo = {
				{"vo", file="tohka1402", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Hehehe, cooking♪ Premonitions of death fill my head and I am cooookiiing♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“哼哼哼～哼，料理～♪死亡的预感，啊啦啦死亡预感的料理～♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「哼哼哼～哼，料理～♪死亡的預感，啊啦啦死亡預感的料理～♪」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00361",
		linknext = "0064_00363",
		line = 6103,
	},
	["0064_00363"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=12},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don’t sing about morbid things so cheerfully.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不要用那么甜美的声音唱那么不吉利的歌。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不要用那麼甜美的聲音唱那麼不吉利的歌。」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00362",
		linknext = "0064_00364",
		line = 6115,
	},
	["0064_00364"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She dances around the room in a hyperactive manner and flaps her hands around.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可能真的很高兴吧，比往常更过动似的在房间里跳着舞。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可能真的很高興吧，比往常更過動似的在房間裡跳著舞。",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00363",
		linknext = "0064_00365",
		line = 6125,
	},
	["0064_00365"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I still don’t know why Touka suddenly held a competition.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但，究竟为什么桐香会突然提出要一决胜负呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"但，究竟為什麼桐香會突然提出要一決勝負呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00364",
		linknext = "0064_00366",
		line = 6135,
	},
	["0064_00366"] = {
