	["0064_00367"] = {
		{"fg", file="tohka_01m_00002", file1="tohka_01m_00101", file2="tohka_01m_00212", path=":fg/tohka_01m/", id=8, lv=12, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1403", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“The FS said they wanted to crush the NLNS into defeat... Something about cuteness points... Revenge talk...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“FS的大家说要打倒NLNS……什么可爱之处之类的……雪耻之类的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「FS的大家說要打倒NLNS……什麼可愛之處之類的……雪恥之類的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00366",
		linknext = "0064_00368",
		line = 6161,
	},
	["0064_00368"] = {
