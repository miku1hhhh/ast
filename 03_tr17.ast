			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Y-yeah... Got it... I don’t want him to get rid of me, so I’ll hold my tongue while you work...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“嗯、嗯……我知道了……我不想要绝交，我会听话的……”",
