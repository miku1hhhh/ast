		line = 2651,
	},
	["0064_00152"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00203", path=":fg/rei_01m/", id=9, lv=10, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-355, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1183", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Revenge is a dish best served cold! I forgot about them and the True Perverted Sex Law because of all the parallel worlds and stuff, but they’ve given me a lot of grief.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“没错，复仇！什么真变态条例、平行世界之类的太多已经记不得了，但我们可是因为那些家伙而尝到不少辛酸！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「沒錯，復仇！什麼真變態條例、平行世界之類的太多已經記不得了，但我們可是因為那些傢伙而嚐到不少辛酸！」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00151",
		linknext = "0064_00153",
		line = 2666,
	},
	["0064_00153"] = {
