	["0064_00149"] = {
		{"bgm", file="bgm12", vol=100},
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00203", path=":fg/rei_02m/", id=9, lv=10, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-355, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="礼9", id=9, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1182", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“All right, everybody, Miss Touka gave us the green light! Let’s make an NLNS-defeating event. Everyone ready?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“好了，大伙儿，已经获得桐香大人的许可了！接下来就要举办为了打倒NLNS的活动！准备好了吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「好了，大夥兒，已經獲得桐香大人的許可了！接下來就要舉辦為了打倒NLNS的活動！準備好了嗎！？」",
					{"rt2"},
				},
			},
		},
