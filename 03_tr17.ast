				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Leave it to them, Miss Touka. I can’t stop feeling sick to my stomach! Ikuko and I keep losing, and now it’s time for revenge!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“先不管是否能将桐香大人交给那家伙，不觉得让人很不爽吗！我跟郁子都一直输！复仇吧！”",
					{"rt2"},
