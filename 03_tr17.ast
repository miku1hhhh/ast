			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“As long as everyone in the FS has a smile on their face, I’m happy. That hasn’t changed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“本来只要FS的大家露出笑容，我就觉得幸福了。这点现在也没有改变。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「本來只要FS的大家露出笑容，我就覺得幸福了。這點現在也沒有改變。」",
					{"rt2"},
				},
			},
		},
