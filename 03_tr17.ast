			},
			cn = {
				{
					name = {"麻沙音"},
					"‘啊，糟糕是我……我是为了让奈奈濑同学偶然发现之后，有些害羞地笑着说‘哎呀，原来麻沙酱已经对这种事感兴趣了啊’，而特别留下记录的却忘记了……’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"『啊，糟糕是我……我是為了讓奈奈瀨同學偶然發現之後，有些害羞地笑著說『哎呀，原來麻沙醬已經對這種事感興趣了啊』，而特別留下記錄的卻忘記了……』",
					{"rt2"},
				},
