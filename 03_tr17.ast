	["0064_00108"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00102", file2="tohka_02m_00223", path=":fg/tohka_02m/", id=8, lv=12, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
