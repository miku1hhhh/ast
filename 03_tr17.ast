					"“You’re not including me in the planning here... Hmmm, but... I have no idea about what type of event to hold...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“少了一个人的大家……唔嗯……但还完全不知道要举办什么样的活动啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「少了一個人的大家……唔嗯……但還完全不知道要舉辦什麼樣的活動啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00143",
