	["0064_00145"] = {
		{"fg", file="schubert_01m_00002", file2="schubert_01m_00202", file4="schubert_01m_00402", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=9, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=695, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="シューベルト12", id=12, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0258", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Leave all that stuff to us! I’ll compile all the data from planned events. As long as you grant us your seal of approval as our student council president, we’ll put the gears in motion!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“那就交给我吧会长！我会将预计举办的活动整理成资料！你只要盖个章，随时就能行动了──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「那就交給我吧會長！我會將預計舉辦的活動整理成資料！妳只要蓋個章，隨時就能行動了──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00144",
		linknext = "0064_00146",
		line = 2555,
	},
	["0064_00146"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00203", path=":fg/rei_01m/", id=9, lv=10, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-355, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1181", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You just need to sit and watch. You don’t even need to lift a finger, Miss Touka!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这次桐香大人只要坐着就好！什么都不用做！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這次桐香大人只要坐著就好！什麼都不用做！」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00145",
		linknext = "0064_00147",
		line = 2570,
	},
	["0064_00147"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00203", path=":fg/ikuko_01m/", id=10, lv=11, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=345, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="郁子10", id=10, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1280", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Please don’t trouble yourself with the planning, Tokie! We’re doing this for you! If you don’t do this, he’ll cut you out from his life, got it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“不，反而是要请你什么都不要做！这全部都是为了桐香酱，所以绝对不要动！动了的话就绝交喔，知道了吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「不，反而是要請妳什麼都不要做！這全部都是為了桐香醬，所以絕對不要動！動了的話就絕交喔，知道了嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00146",
		linknext = "0064_00148",
		line = 2586,
	},
	["0064_00148"] = {
		{"bgm", stop=1},
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00206", path=":fg/tohka_02m/", id=8, lv=12, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
