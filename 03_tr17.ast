	["0064_00377"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Touka lets it all out with nothing left between the lines, but it’s tricky to know the true meaning of her words.",
					{"rt2"},
				},
			},
			cn = {
				{
					"桐香说的话有些跳跃，有点没听懂她真正想表达的意思。",
