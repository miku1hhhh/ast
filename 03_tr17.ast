					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“T-That’s not true! I view Junnosuke as a cute little brother and nothing more. There’s nothing I wish for more than Miss Touka’s happiness.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我、我才不会做出那种事……！我只是将、淳之介当作可爱的弟弟而已，而且桐香大人的幸福才是最重要的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我、我才不會做出那種事……！我只是將、淳之介當作可愛的弟弟而已，而且桐香大人的幸福才是最重要的……！」",
					{"rt2"},
				},
			},
		},
