	["0064_00181"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="chitsuno0045", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"茅津野アナ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"茅津野アナ", "Pussy Galore"},
					"“The rules are simple. Three heroes of the Lewd War will go against Student Council President Touka Reizeiin. The heroes will assign themselves to a best of five battle of their choice.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"茅津野アナ", "茅津野播报员"},
					"‘规则非常简单。从现在开始作为‘变态战役’英雄的三个人，要跟FS学生会会长冷泉院桐香一决胜负。比赛项目由英雄方指定，全部共五局决胜负。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"茅津野アナ", "茅津野播報員"},
					"『規則非常簡單。從現在開始作為『變態戰役』英雄的三個人，要跟FS學生會會長冷泉院桐香一決勝負。比賽項目由英雄方指定，全部共五局決勝負。』",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00180",
		linknext = "0064_00182",
		line = 3169,
	},
	["0064_00182"] = {
