			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“M-me, inconsiderate?! Everything’s all about Miss Touka’s happiness first, and anything else isn’t given a second thought!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我、我……！对我来说桐香大人的幸福最重要，其他的都──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我、我……！對我來說桐香大人的幸福最重要，其他的都──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00105",
