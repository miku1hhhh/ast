				{"vo", file="tohka1364", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“B-but we’re still having fun, Ikuko...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“但、但是……前辈说，现在也很快乐……”",
