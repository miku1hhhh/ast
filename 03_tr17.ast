					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Hell yeah! They slapped me so viciously in the past, and now it’s time to settle scores!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“收到！！到目前为止一直被他们任意驱使，至少也要扳回一城吧──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「收到！！到目前為止一直被他們任意驅使，至少也要扳回一城吧──！」",
					{"rt2"},
