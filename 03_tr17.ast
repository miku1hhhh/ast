				{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00203", path=":fg/rei_02m/", id=9, lv=10, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=64, delay2=10000, mode=3, x=-355, y=-5},
			},
			[9999] = {
				{"transitiontime", time=300, timestamp=64, delay2=10000},
			},
		},
		text = {
			vo = {
				{"vo", file="rei1184", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“We couldn’t lead Miss Touka to victory in the battle of cuteness. Will we stand for our leader to remain defeated by a stuck-up, limp-dicked little scrote? Hell no!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我们在前几天的可爱之争中也无法引导桐香大人获得胜利……！我们这些队长难道就要这样输给那个自负的阳痿吗！？不，这怎么行！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我們在前幾天的可愛之爭中也無法引導桐香大人獲得勝利……！我們這些隊長難道就要這樣輸給那個自負的陽痿嗎！？不，這怎麼行！」",
					{"rt2"},
				},
			},
		},
		linkback = "0064_00152",
		linknext = "0064_00154",
		line = 2687,
	},
	["0064_00154"] = {
