			},
			[1999] = {
				{"transitiontime", time=300, timestamp=43, delay2=2000},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko1268", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“How would you feel if you were Tokie?! Darling might get tired of taking care of her and grow to dislike her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“与此相比，桐香酱又是如何呢！现在这样只会让亲爱的觉得一直在看护很累，到时候连被嫌弃了都不知道！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「與此相比，桐香醬又是如何呢！現在這樣只會讓親愛的覺得一直在看護很累，到時候連被嫌棄了都不知道！？」",
					{"rt2"},
				},
			},
		},
