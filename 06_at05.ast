		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase said it wouldn’t make her happy, even if the leader were to do something like that for her. That she didn’t understand why I wanted to do it. So I listened to her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"让队长做这种事情我可一点也不会觉得开心说到底我根本搞不清楚这有什么意义──形式上是因为接受了奈奈濑的这番说词。",
					{"rt2"},
				},
			},
			tw = {
				{
					"讓隊長做這種事情我可一點也不會覺得開心說到底我根本搞不清楚這有什麼意義──形式上是因為接受了奈奈瀨的這番說詞。",
					{"rt2"},
				},
			},
		},
