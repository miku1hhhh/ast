			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Welcome home, Junnosuke and Asane...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“欢迎回来，淳之介，麻沙音……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「歡迎回來，淳之介，麻沙音……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00016",
		linknext = "0087_00018",
		line = 264,
	},
	["0087_00018"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When we opened the door, Fumino came running toward us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一打开大门，文乃就啪哒啪哒地小跑了过来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一打開大門，文乃就啪噠啪噠地小跑了過來。",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00017",
		linknext = "0087_00019",
		line = 274,
	},
	["0087_00019"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her being this clingy towards us strangely reminded me of Asa when she was little.",
					{"rt2"},
				},
			},
			cn = {
				{
					"感觉这种黏人的模样，微妙地让人联想到以前的麻沙酱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"感覺這種黏人的模樣，微妙地讓人聯想到以前的麻沙醬。",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00018",
		linknext = "0087_00020",
		line = 284,
	},
