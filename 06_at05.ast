			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Okay, okay. So, that idea is... this! Operation: No Cock in Your Left Hand!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					[[“是是是，那么这次的主意是～这个！"右手抓鸡鸡！左手不用了！"作战～！”]],
