			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Asa, your brother is acting weird. Did something strange happen? Or is that normal...? Oh, forget that. I brought over that cute picture frame I mentioned yesterday.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“麻沙酱──，你哥感觉怪怪的耶是不是又做了什么莫名其妙的事情？啊，平时也都莫名其妙呢……比起这个，我找到昨天说的很可爱的相框了，所以就拿过来了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「麻沙醬──，妳哥感覺怪怪的耶是不是又做了什麼莫名其妙的事情？啊，平時也都莫名其妙呢……比起這個，我找到昨天說的很可愛的相框了，所以就拿過來了。」",
					{"rt2"},
				},
			},
		},
