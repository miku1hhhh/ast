		{"fg", file="asane_01m_00002", file1="asane_01m_00101", file2="asane_01m_00210", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0834", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“It’s self-warming, moves at the perfect pace and even automatically cleans itself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“对对，不但会自动保温、在刚好的时机动起来，而且还附带自动洗净机能。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「對對，不但會自動保溫、在剛好的時機動起來，而且還附帶自動洗淨機能。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00211",
		linknext = "0087_00213",
		line = 3080,
	},
	["0087_00213"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00208", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Damn, I’d have never been able to think of that...! That’s so frustrating I can’t even accept its existence yet! Let’s go with your plan that doesn’t use it to return my soul to inner peace!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“咕、怎么会，连我都做不出来那种东西……！太不甘心了，感觉还没办法接受！总之先让我听听看不用的那一边来取回内心的平静吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「咕、怎麼會，連我都做不出來那種東西……！太不甘心了，感覺還沒辦法接受！總之先讓我聽聽看不用的那一邊來取回內心的平靜吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00212",
		linknext = "0087_00214",
		line = 3092,
	},
	["0087_00214"] = {
