			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Well, when I put out applications on the net, bam!❤ Some anonymous person showed up willing to help because they loved getting naked. But I thought it was a guy in disguise, so I ignored them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我在网络上募集模特儿的时候有个网名叫做吹萧邦",
					{"gaiji", text="①"},
					"的人说自己很喜欢脱所以愿意帮忙，但是看起来就像个网络人妖所以我就无视掉了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我在網路上募集模特兒的時候有個網名叫做吹蕭邦",
					{"gaiji", text="①"},
					"的人說自己很喜歡脫所以願意幫忙，但是看起來就像個網路人妖所以我就無視掉了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00232",
		linknext = "0087_00234",
		line = 3401,
	},
	["0087_00234"] = {
