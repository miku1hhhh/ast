		text = {
			vo = {
				{"vo", file="fumino0296", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I’ve prepared a cloth to stop the bleeding. You’ve shown us your resolve, and we’ve witnessed it. It would be a shame if you lost that finger, so...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我帮您准备好止血用的布了……既然您都已经展现出觉悟了，那么我也共进退吧。因为让兄长失去手指也是我一生的耻辱──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我幫您準備好止血用的布了……既然您都已經展現出覺悟了，那麼我也共進退吧。因為讓兄長失去手指也是我一生的恥辱──」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00096",
		linknext = "0087_00098",
		line = 1413,
	},
	["0087_00098"] = {
