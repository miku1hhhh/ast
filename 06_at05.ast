		text = {
			vo = {
				{"vo", file="nanase0501", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Okay, suddenly I have way too many questions, so let’s stop for now. I mean, what is up with you lately?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“等一下想问的事情太多我已经乱掉了拜托你先暂停一下、不是慢着慢着慢着你到底在做什么啊！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「等一下想問的事情太多我已經亂掉了拜託你先暫停一下、不是慢著慢著慢著你到底在做什麼啊！？」",
					{"rt2"},
				},
			},
		},
