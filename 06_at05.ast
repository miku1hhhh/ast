	["0087_00025"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I told you yesterday. We’re a family. So it’s natural to call me that, don’t-cha think? Go on, give it a try.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“昨天不也说了吗，我们是一家人。这样才比较自然吧。对吧？喏，喊一声让我听听看吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「昨天不也說了嗎，我們是一家人。這樣才比較自然吧。對吧？喏，喊一聲讓我聽聽看吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00024",
		linknext = "0087_00026",
		line = 366,
	},
