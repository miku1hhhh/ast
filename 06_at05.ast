				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“喂笨蛋住口啊不要把事情变得更复杂了不要把短刀拿出来不要连你也跟着负起责任切断手指啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「喂笨蛋住口啊不要把事情變得更複雜了不要把短刀拿出來不要連妳也跟著負起責任切斷手指啊……！」",
					{"rt2"},
				},
			},
		},
