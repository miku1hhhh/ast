			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Oh, thank you so very much for the melon bread... Huh...? Is there something on my face...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“好的，谢谢……菠萝面包……怎么了吗，我的脸上有什么……？”",
