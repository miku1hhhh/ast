					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You called, Bro?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“在你叫我吗兄长大人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「在你叫我嗎兄長大人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00180",
		linknext = "0087_00182",
		line = 2641,
	},
	["0087_00182"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00102", file2="jun_01f_00209", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No way... It’s like the real thing... Could this be the power of recent memories...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					[[“真的假的……这品质简直就跟真的一样不是吗……这就是"最近的记忆"的力量吗──？”]],
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					[[「真的假的……這品質簡直就跟真的一樣不是嗎……這就是"最近的記憶"的力量嗎──？」]],
					{"rt2"},
				},
			},
		},
		linkback = "0087_00181",
		linknext = "0087_00183",
		line = 2653,
	},
	["0087_00183"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00101", file2="asane_02m_00214", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0825", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Why’re you staring off into space and talking to yourself, Bro?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“突然就凝视着虚空开始自言自语了耶老哥……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「突然就凝視著虛空開始自言自語了耶老哥……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00182",
		linknext = "0087_00184",
		line = 2668,
	},
	["0087_00184"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00102", file2="jun_01f_00208", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I can’t do this with my real sister... But desperate times call for desperate measures...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					[[“亲生妹妹什么的，那种事情我……不、可是俗话都说"舍大头保小头"……！”]],
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					[[「親生妹妹什麼的，那種事情我……不、可是俗話都說"捨大頭保小頭"……！」]],
					{"rt2"},
				},
			},
		},
		linkback = "0087_00183",
		linknext = "0087_00185",
		line = 2680,
	},
	["0087_00185"] = {
