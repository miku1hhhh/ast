			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Nanase had to go shopping, then said she’d head home. They were headed the same way, so Fumino went with her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“奈奈濑同学说她要去买东西。然后买完就要回去了。因为要去的店一样，所以文乃也跟去了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「奈奈瀨同學說她要去買東西。然後買完就要回去了。因為要去的店一樣，所以文乃也跟去了。」",
					{"rt2"},
				},
			},
		},
