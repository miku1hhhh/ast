			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Our Master did say that when someone wants to take clear responsibility for their mistakes... Fumino!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我的师父说过，人在必须要好好做出了断的时候要──文乃！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我的師父說過，人在必須要好好做出了斷的時候要──文乃！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00087",
