			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Lately people have been making custom 3D models and putting custom face-rigs in them, right? So you can have one auto-created to match your freaky fantasy for the day and put it in erotic poses.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“最近不是很流行把3D模拆件然后加上动作捕捉什么的吗？所以啦，就看当天的心情自动产生3D模然后请别人远隔摆出各种色色的姿势就可以了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「最近不是很流行把3D模拆件然後加上動作捕捉什麼的嗎？所以啦，就看當天的心情自動產生3D模然後請別人遠隔擺出各種色色的姿勢就可以了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00215",
		linknext = "0087_00217",
		line = 3140,
	},
	["0087_00217"] = {
