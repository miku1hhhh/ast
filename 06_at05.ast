			tw = {
				{
					name = {"淳之介"},
					"「才不是──！我、我……！我對自己氣量之狹窄感到丟臉！！請讓我道歉吧，對不起！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00083",
		linknext = "0087_00085",
		line = 1184,
	},
	["0087_00085"] = {
		{"fg", file="nanase_02m_00007", file1="nanase_02m_00102", file2="nanase_02m_00210", path=":fg/nanase_02m/", id=4, lv=4, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0498", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I don’t know what you’re going on about, but I’m not offended or anything. It’s okay...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“虽然不是很清楚你指的是什么事，但我不介意……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「雖然不是很清楚你指的是什麼事，但我不介意……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00084",
		linknext = "0087_00086",
		line = 1199,
	},
	["0087_00086"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00102", file2="jun_01f_00203", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I know! And I know this isn’t enough to get you to forgive me for what I did!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我懂的！！我也不认为这样就能求得你的原谅！！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我懂的！！我也不認為這樣就能求得妳的原諒！！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00085",
		linknext = "0087_00087",
		line = 1211,
	},
	["0087_00087"] = {
		{"fg", file="nanase_01m_00007", file1="nanase_01m_00101", file2="nanase_01m_00215", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0499", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“If you want forgiveness, please make sure to actually listen to people when they speak from now on...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“如果真的想要别人原谅你就好好听人说话好吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「如果真的想要別人原諒你就好好聽人說話好嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0087_00086",
		linknext = "0087_00088",
		line = 1226,
	},
	["0087_00088"] = {
