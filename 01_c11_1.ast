				{
					name = {"防人老人", "Sakimori"},
					"“What a funny thing to say. Why should I have to help the likes of you? Tell me, boy. What exactly is the reason for that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘你可说了真奇怪的话啊。为何我必须要帮助你呢？有什么理由帮你，嗯？小鬼。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『你可說了真奇怪的話啊。為何我必須要幫助你呢？有什麼理由幫你，嗯？小鬼。』",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00115",
		linknext = "0014_00117",
		line = 1742,
	},
	["0014_00117"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00302", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You sure you want me to tell the Yakuza about you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果我把你的存在告诉黑道们也没关系吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果我把你的存在告訴黑道們也沒關係嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00116",
		linknext = "0014_00118",
		line = 1754,
	},
	["0014_00118"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The SHO wiped out the Yakuza hiding on Seiran Island, but I’m sure that everyone here contributed to that behind the scenes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“潜藏在青蓝岛上的黑道们已经都被SHO消灭了，但背后想必是受到了这里的人协助才对。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「潛藏在青藍島上的黑道們已經都被SHO消滅了，但背後想必是受到了這裡的人協助才對。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00117",
		linknext = "0014_00119",
		line = 1766,
	},
	["0014_00119"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There’d be no other way for the SHO to find her that easily after all the time they spent investigating desperately.",
					{"rt2"},
				},
			},
			cn = {
				{
					"要不然，曾经花了那么长时间拼命调查的SHO，不会如此轻易发现。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要不然，曾經花了那麼長時間拚命調查的SHO，不會如此輕易發現。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00118",
		linknext = "0014_00120",
		line = 1776,
	},
	["0014_00120"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00302", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That too is all because you were pulling the strings behind the scenes—it was all to find Fumino and shelter her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而这也全都是你在背后牵线造成的结果──为了找出文乃，并且保护她。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而這也全都是你在背後牽線造成的結果──為了找出文乃，並且保護她。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00119",
		linknext = "0014_00121",
		line = 1788,
	},
	["0014_00121"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even the old man shrinks when I bring out Fumino’s name.",
					{"rt2"},
				},
			},
			cn = {
				{
					"扛出文乃这个名字后，即使是老人也动摇了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"扛出文乃這個名字後，即使是老人也動搖了。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00120",
		linknext = "0014_00122",
		line = 1798,
	},
	["0014_00122"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There should still be some Yakuza holdouts left on this island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这座岛上应该还有黑道的残党才对。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這座島上應該還有黑道的殘黨才對。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00121",
		linknext = "0014_00123",
		line = 1810,
	},
	["0014_00123"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You need to work with me unless you want them to find out about your plans and be forced to live a life on the run.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你如果不想要自己的计划被泄露出去，过着逃亡生活的话，就帮我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你如果不想要自己的計劃被洩露出去，過著逃亡生活的話，就幫我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00122",
		linknext = "0014_00124",
		line = 1822,
	},
	["0014_00124"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...I don’t want to have to rely on someone like him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"──其实我当然是不想拜托这种人的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"──其實我當然是不想拜託這種人的。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00123",
		linknext = "0014_00125",
		line = 1832,
	},
	["0014_00125"] = {
