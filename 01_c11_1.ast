					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘……………………’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『……………………』",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00136",
		linknext = "0014_00138",
		line = 2020,
	},
	["0014_00138"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sakimori stays silent after I finish speaking.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我说完后，驻防老人沉默了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我說完後，駐防老人沉默了。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00137",
		linknext = "0014_00139",
		line = 2030,
	},
	["0014_00139"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There’s no way he could begin to understand what I just told him, and I doubt he’d want to understand it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我所说的东西，他应该无法理解，也不想理解吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我所說的東西，他應該無法理解，也不想理解吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00138",
		linknext = "0014_00140",
		line = 2040,
	},
	["0014_00140"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, my words must have rung true.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但我的话应该带有真实感才对。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但我的話應該帶有真實感才對。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00139",
		linknext = "0014_00141",
		line = 2050,
	},
	["0014_00141"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"How could they not? Everything I said is a fact in my world.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是当然的，因为在我的世界中，这些都是事实。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那是當然的，因為在我的世界中，這些都是事實。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00140",
		linknext = "0014_00142",
		line = 2060,
	},
	["0014_00142"] = {
		{"bgm", file="bgm07", vol=100},
		{"fg", file="sakimori_01f_00001", file2="sakimori_01f_00201", path=":fg/sakimori_01f/", id=30, ch="防人老人", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0006", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“...You’re crazy. How could I possibly believe any of that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘……你是个强人啊。这种话，要人如何相信？’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『……你是個強人啊。這種話，要人如何相信？』",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00141",
		linknext = "0014_00143",
		line = 2074,
	},
	["0014_00143"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, crazy about getting this job done. It’s the only reason I’m dealing with you again. You’re even able to make deals with major politicians.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没错。我是很强韧的。所以才会和你再次对上，也能跟大人物的政治家交易。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒錯。我是很強韌的。所以才會和你再次對上，也能跟大人物的政治家交易。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00142",
		linknext = "0014_00144",
		line = 2086,
	},
	["0014_00144"] = {
		{"fg", file="sakimori_01f_00001", file2="sakimori_01f_00204", path=":fg/sakimori_01f/", id=30, ch="防人老人", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0007", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Wordplay at a time like this...? The most I can do for you is write a letter of introduction for a mental clinic.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘别玩文字游戏了……我能做的顶多是帮你写写医院的转诊信而已。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『別玩文字遊戲了……我能做的頂多是幫你寫寫醫院的轉診信而已。』",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00143",
		linknext = "0014_00145",
		line = 2099,
	},
	["0014_00145"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That’s not what I need. How about you give me something by tomorrow instead? It should be easy enough for you to get.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我才不需要那种东西。相对地，我有想要明天之前拿到的东西，如果是你应该可以轻易准备才对。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我才不需要那種東西。相對地，我有想要明天之前拿到的東西，如果是你應該可以輕易準備才對。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00144",
		linknext = "0014_00146",
		line = 2111,
	},
	["0014_00146"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sakimori’s eyes shine dully.",
					{"rt2"},
				},
			},
			cn = {
				{
					"驻防老人的眼睛闪出隐约的光芒。",
					{"rt2"},
				},
			},
			tw = {
				{
					"駐防老人的眼睛閃出隱約的光芒。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00145",
		linknext = "0014_00147",
		line = 2121,
	},
	["0014_00147"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He doesn’t trust what I say.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我的话无法信任。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我的話無法信任。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00146",
		linknext = "0014_00148",
		line = 2131,
	},
	["0014_00148"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But for whatever reason, it seems like he’s being swayed by this young man’s uncompromising attitude...",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，对少年强硬的态度，却似乎有些动摇ー",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，對少年強硬的態度，卻似乎有些動搖ー",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00147",
		linknext = "0014_00149",
		line = 2141,
	},
	["0014_00149"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...Like I’m finally getting a glimpse at this old man’s human side.",
					{"rt2"},
				},
			},
			cn = {
				{
					"──我感觉第一次稍微窥见了这老人带有人味的一面。",
					{"rt2"},
				},
			},
			tw = {
				{
					"──我感覺第一次稍微窺見了這老人帶有人味的一面。",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00148",
		linknext = "0014_00150",
		line = 2151,
	},
	["0014_00150"] = {
		{"fg", file="sakimori_01f_00001", file2="sakimori_01f_00201", path=":fg/sakimori_01f/", id=30, ch="防人老人", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0008", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“...My only wish is to stamp out the perverted sex law and destroy Seiran Island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘……我的希望只有破坏变态条例，以及青蓝岛而已。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『……我的希望只有破壞變態條例，以及青藍島而已。』",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00149",
		linknext = "0014_00151",
		line = 2164,
	},
	["0014_00151"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00305", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Not on my watch. I’m not letting you use Fumino to crush the perverted sex law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我可不会让你这么做。我不会原谅你想要利用文乃来破坏变态条例的想法。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我可不會讓你這麼做。我不會原諒你想要利用文乃來破壞變態條例的想法。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00150",
		linknext = "0014_00152",
		line = 2176,
	},
	["0014_00152"] = {
		{"fg", file="sakimori_01f_00001", file2="sakimori_01f_00213", path=":fg/sakimori_01f/", id=30, ch="防人老人", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0009", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“You immature little boy—you sound just like the other one. How infuriating.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘这黄口小儿──你也说了跟那个年轻人一样的话，真烦。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『這黃口小兒──你也說了跟那個年輕人一樣的話，真煩。』",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00151",
		linknext = "0014_00153",
		line = 2189,
	},
	["0014_00153"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The other one? Are you talking about the leader of the Birds of a Feather?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那个年轻人──是说‘Tori公’的领袖吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那個年輕人──是說『Tori公』的領袖嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00152",
		linknext = "0014_00154",
		line = 2201,
	},
	["0014_00154"] = {
		{"fg", file="sakimori_01f_00001", file2="sakimori_01f_00201", path=":fg/sakimori_01f/", id=30, ch="防人老人", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0010", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Indeed I am. Refusing to hand over Fumino after all the painstaking work it took to get her... We may have the same goals, but there’s no controlling a hot-blooded youth.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘没错。我可是费尽苦心才得到文乃的，他竟然拒绝把她交出来……我们明明目的一样，只能说血气方刚的年轻人就是难以驾驭。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『沒錯。我可是費盡苦心才得到文乃的，他竟然拒絕把她交出來……我們明明目的一樣，只能說血氣方剛的年輕人就是難以駕馭。』",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00153",
		linknext = "0014_00155",
		line = 2214,
	},
	["0014_00155"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You’re going to tell me where I can find this guy. Give me all the details you know.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“告诉我那个少年的事。在你知道的范围里，尽量详细点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「告訴我那個少年的事。在你知道的範圍裡，盡量詳細點。」",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00154",
		linknext = "0014_00156",
		line = 2226,
	},
	["0014_00156"] = {
		{"fg", file="sakimori_01f_00001", file2="sakimori_01f_00205", path=":fg/sakimori_01f/", id=30, ch="防人老人", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0011", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Details are not something I have.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘我不知道详情。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『我不知道詳情。』",
					{"rt2"},
				},
			},
		},
		linkback = "0014_00155",
		linknext = "0014_00157",
		line = 2239,
	},
	["0014_00157"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
