			},
		},
		text = {
			vo = {
				{"vo", file="hitoura0073", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Every man has times when he wants to be treated as a spoiled baby—you ought to keep that in mind if there’s a man in your heart too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“不管什么样的男人，都有想变成宝宝撒娇的时候──若是你有心仪的男性，最好记住这点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「不管什麼樣的男人，都有想變成寶寶撒嬌的時候──若是你有心儀的男性，最好記住這點。」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00068",
		linknext = "0053_00070",
		line = 1944,
	},
	["0053_00070"] = {
