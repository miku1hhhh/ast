			tw = {
				{
					name = {"郁子"},
					"「很高興見到你，Hamedori大人。我的名字是女部田郁。為正宗女部田家的嫡子，青柳修煉柔法女部田流劍術繼承者之一。」",
					{"rt2"},
				},
			},
		},
