				{
					name = {"仁浦"},
					"「呵，肯定會的……那麼，就算派不上什麼用場，也要拚盡全力。就只有這裡，絕不可以被它們給破壞了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00065",
		linknext = "0053_00067",
		line = 1899,
	},
	["0053_00067"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00209", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=495, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0863", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“My, I never knew you were so attached to Baby Me Creche.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“哎呀，对妈咪幼稚园有这么深的感情吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「哎呀，對媽咪幼稚園有這麼深的感情嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00066",
		linknext = "0053_00068",
		line = 1914,
	},
	["0053_00068"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00211", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-505, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0072", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“That’s right. This place reflects the memories I have of Fumika—of my wife.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“是啊，这里是和文歌的──是将我和妻子的记忆投射在那设施上了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「是啊，這裡是和文歌的──是將我和妻子的記憶投射在那設施上了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00067",
		linknext = "0053_00069",
		line = 1929,
	},
	["0053_00069"] = {
		{"text"},
		delay = {
			[6200] = {
				{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00212", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, timestamp=194, delay2=6200, mode=3, x=-505, y=-5},
