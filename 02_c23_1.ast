		{"bg", id=29, file="aci011201-1", x=0, y=0, path=":cg/aci/", lv=29, ev=1, time=300, sync=0, rule="eff_009_00000", a_chr60=1, bx=800, by=450},
		{"cgact", file="cgact", id=29, act="浮遊", loop=-1, size=2.5, time=50, ease="easeinout_sine", lv=29, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0182", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Plenty will come of it! You’re a fake! I’ve been watching you for all this time, so I could tell right away! Your words of an imitation mean nothing to me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“什么都有可能！你只是个假货！只要仔细观察就能知道了！不想听假货说话──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「什麼都有可能！你只是個假貨！只要仔細觀察就能知道了！不想聽假貨說話──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00356",
		linknext = "0053_00358",
		line = 7833,
	},
	["0053_00358"] = {
		{"fg", mode=-1, id=30},
		{"facehide"},
		{"cgact", file="cgact", id=29, act="stopact", lv=29, x=0, y=0},
