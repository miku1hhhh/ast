				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“There’s nothing I love more than delivering beatings to cocks and my first squad kids... But I can’t stand it when they’re bullied by someone else.”",
					{"rt2"},
				},
			},
			cn = {
