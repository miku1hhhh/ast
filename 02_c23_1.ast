	["0053_00153"] = {
		{"cgdel", id=2, time=0, alphadel=1, lv=2},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"These missiles use infrared cameras for image recognition to track their targets as they fly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这些导弹通过红外线录影机在空中进行图像认证和并展开追踪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這些導彈通過紅外線錄影機在空中進行圖像認證和並展開追蹤。",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00152",
		linknext = "0053_00154",
		line = 3798,
	},
	["0053_00154"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Therefore, this delicate image recognition system will be rendered unusable if some substance that generates powerful heat takes up a large amount of space.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因此，如果在大范围的区域出现发出强烈热能的物体，就无法使用精密的图像识别功能。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因此，如果在大範圍的區域出現發出強烈熱能的物體，就無法使用精密的圖像識別功能。",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00153",
		linknext = "0053_00155",
		line = 3808,
	},
	["0053_00155"] = {
