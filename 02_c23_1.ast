		{"se", id=5, loop=1, file="se_d037b"},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well I’m going to make them mean something one way or another! Because I’m someone who could have been you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就算是这样也能引起共鸣！因为我也可能跟你是同类人啊──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就算是這樣也能引起共鳴！因為我也可能跟你是同類人啊──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00357",
		linknext = "0053_00359",
		line = 7858,
	},
	["0053_00359"] = {
		{"se", id=5, loop=1, file="se_b123", vol=50},
		{"bg", id=29, file="aci011201-1", x=0, y=0, path=":cg/aci/", lv=29, ev=1, bx=800, by=450},
		{"bg", id=29, file="aci011201-1", x=0, y=0, path=":cg/aci/", lv=29, ev=1, time=300, sync=0, rule="eff_009_00000", a_chr60=1, bx=800, by=450},
		{"cgact", file="cgact", id=29, act="浮遊", loop=-1, size=2.5, time=50, ease="easeinout_sine", lv=29, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0183", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“What would you understand?! It’s not like you can deny the oppression and discrimination that comes from separating the sexes!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“你这家伙懂什么！？你并不能否定性别差异会导致迫害和歧视──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「你這傢伙懂什麼！？你並不能否定性別差異會導致迫害和歧視──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0053_00358",
		linknext = "0053_00360",
		line = 7874,
	},
	["0053_00360"] = {
