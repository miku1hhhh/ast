					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「知道了！數據已收集完畢──！敵人是以6架為1小隊的方式行動！即使數量再多，最多也就只能6架互相補充！直接將1個分隊擊落的話，就無法反抗了！」",
					{"rt2"},
				},
			},
		},
