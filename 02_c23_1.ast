			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“If you’re using image recognition, that just means I have to dazzle these and they won’t be able to track... Right?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“是我！如果是靠图片是别的话，只要让它们眼花撩乱就无法进行引导了吧──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「是我！如果是靠圖片是別的話，只要讓它們眼花撩亂就無法進行引導了吧──！」",
					{"rt2"},
				},
			},
		},
