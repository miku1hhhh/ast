			en = {
				{
					name = {"郁子", "Ikuko"},
					"“An honor to meet you, Sir Hamedori. My name is Iku Onabuta of the Onabuta style, master of Aoyagi-style technique, and the only heir of the Onabuta-style swordsmanship.”",
