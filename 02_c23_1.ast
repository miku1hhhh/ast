				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Medic! Take any casualties off the battlefield and provide treatment! ...Hey, that anti-air fire is looking thin!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“医疗班！！将伤者从战场中带出来进行治疗！……对空的炮火不够集中了！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「醫療班！！將傷者從戰場中帶出來進行治療！……對空的炮火不夠集中了！！」",
					{"rt2"},
				},
			},
		},
