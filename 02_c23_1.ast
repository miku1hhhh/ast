		text = {
			vo = {
				{"vo", file="ikuko1149", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Heh... It’s the number of my first squad kids you’ve taken out of commission.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“呵呵……是第一中队已经无法战斗的孩子们的数字呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「呵呵……是第一中隊已經無法戰鬥的孩子們的數字呢。」",
					{"rt2"},
				},
			},
		},
