			en = {
				{
					name = {"桐香", "Touka"},
					"“How very informative. In that case, let us launch a full, complete, and flawless defense.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“是啊，那还真是非常有参考价值呢。那么就让我们在没有任何差错下完成完全防御吧──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「是啊，那還真是非常有參考價值呢。那麼就讓我們在沒有任何差錯下完成完全防禦吧──」",
					{"rt2"},
				},
			},
		},
