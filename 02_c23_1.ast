			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Defend our town with everything you have as though the SHO’s authority depends on it! We can’t allow Seiran Island to be destroyed by some weird little birds!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“赌上SHO的名声，绝对要死守着我们的城市！绝对不能让来路不明的鸟之类的破坏青蓝岛！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「賭上SHO的名聲，絕對要死守著我們的城市！絕對不能讓來路不明的鳥之類的破壞青藍島！」",
					{"rt2"},
				},
			},
		},
