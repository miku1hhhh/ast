					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We just have to understand one another! Just talk it out! Isn’t that what coexistence means?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只要能互相理解就好！能彼此商量就好！共存不就是那么一回事嘛！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只要能互相理解就好！能彼此商量就好！共存不就是那麼一回事嘛！？」",
					{"rt2"},
				},
			},
		},
