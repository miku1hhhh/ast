					name = {"郁子"},
					"“我呢，虽然很喜欢欺负肉棒跟第一中队的孩子们可是……最讨厌他们被别人给欺负了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我呢，雖然很喜歡欺負肉棒跟第一中隊的孩子們可是……最討厭他們被別人給欺負了。」",
					{"rt2"},
