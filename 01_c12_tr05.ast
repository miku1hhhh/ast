			cn = {
				{
					"──桐香一名，蕴藏了已故双亲的爱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"──桐香一名，蘊藏了已故雙親的愛。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00088",
