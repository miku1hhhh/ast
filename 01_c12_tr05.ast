		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Slowly, but steadily... Why did you throw those documents around? Did you lose something? Can I help?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“慢慢进行中……怎么了，这么多文件散成一团？是有文件不见了吗？要帮忙吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「慢慢進行中……怎麼了，這麼多文件散成一團？是有文件不見了嗎？要幫忙嗎？」",
					{"rt2"},
				},
			},
		},
