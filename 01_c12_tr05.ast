	},
	["0020_00125"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What Hinami said back then was right on the mark.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当时雏见不经意的一句话──",
					{"rt2"},
				},
			},
			tw = {
				{
					"當時雛見不經意的一句話──",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00124",
		linknext = "0020_00126",
