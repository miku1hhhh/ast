				},
			},
		},
		linkback = "0020_00023",
		linknext = "0020_00025",
		line = 296,
	},
	["0020_00025"] = {
		{"fg", file="tohka_02m_00004", file1="tohka_02m_00101", file2="tohka_02m_00212", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0474", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yeah... That’s not incorrect. To a certain degree, I was following the way of thinking of myself from this world. That’s why it wouldn’t be a faulty statement to say that it was my opinion.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“是啊……某种程度上是抄这世界的我自己的想法，所以说那是我的意见，也不算太有语病吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「是啊……某種程度上是抄這世界的我自己的想法，所以說那是我的意見，也不算太有語病吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00024",
		linknext = "0020_00026",
		line = 311,
	},
	["0020_00026"] = {
