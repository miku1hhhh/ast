	["0020_00131"] = {
		{"fg", file="tohka_02m_00004", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0498", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“There was a meaning to all those days we spent fighting you. There was a meaning to the days when we couldn’t understand each other.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“和你们战争的日子，是有意义的。互相无法理解的日子也有意义──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「和你們戰爭的日子，是有意義的。互相無法理解的日子也有意義──」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00130",
		linknext = "0020_00132",
