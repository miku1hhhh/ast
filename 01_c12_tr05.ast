	["0020_00124"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It happened on the boat that was taking the FS members back.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这是在FS的成员们被强制遣返回国时，发生在那艘遣返船上的事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這是在FS的成員們被強制遣返回國時，發生在那艘遣返船上的事。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00123",
