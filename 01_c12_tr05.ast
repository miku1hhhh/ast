		},
		linkback = "0020_00099",
		linknext = "0020_00101",
		line = 1194,
	},
	["0020_00101"] = {
		{"fg", file="tohka_02m_00004", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0492", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“That’s why I thought this. If my sister understands me when she kisses me on the cheek, then maybe the failure that I am will also understand her when I kiss her on the lips.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“所以我能透过姐姐亲脸颊来了解自我……可能就算是我这么笨拙的人，亲嘴的话就能理解了也说不定，我是这样想的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「所以我能透過姐姐親臉頰來了解自我……可能就算是我這麼笨拙的人，親嘴的話就能理解了也說不定，我是這樣想的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00100",
		linknext = "0020_00102",
		line = 1209,
	},
	["0020_00102"] = {
