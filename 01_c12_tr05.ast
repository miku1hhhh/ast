	["0020_00079"] = {
		{"fg", file="tohka_02m_00004", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As I look at her, she stops working and smiles slightly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我用视线催促，桐香停下手边工作小小微笑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我用視線催促，桐香停下手邊工作小小微笑。",
					{"rt2"},
