					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I’m not... Ah, but if I said that I am, would you join the FS in our world? If so, I’m pushing myself very much.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我没在勉强……啊，要是说勉强，学长在原本世界是加入FS的吧？如果是这样的话，在这边应该很勉强吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我沒在勉強……啊，要是說勉強，學長在原本世界是加入FS的吧？如果是這樣的話，在這邊應該很勉強吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00046",
		linknext = "0020_00048",
		line = 575,
	},
	["0020_00048"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00207", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
