		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei and Ikuko also told me that her sympathy for me may be a bit twisted.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也从另外两人那里知道，她对于我的事有些不一样的关心。",
