			},
		},
		linkback = "0020_00078",
		linknext = "0020_00080",
		line = 947,
	},
	["0020_00080"] = {
		{"bgm", file="bgm21", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0486", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I never had anyone who would look after me, so I was passed around from place to place. And so, I ended up in the Sakimori family.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我从小时开始就没有人要领养，一直被各个地方踢来踢去的，最后一个待的地方就是那个驻防家。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我從小時開始就沒有人要領養，一直被各個地方踢來踢去的，最後一個待的地方就是那個駐防家。」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00079",
		linknext = "0020_00081",
		line = 960,
	},
	["0020_00081"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00218", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=8},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“At old Sakimori’s base, right? The place that’s supposed to be Sparta for servants.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就是驻防长老──培育仆人的大本营吗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就是駐防長老──培育僕人的大本營嗎。」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00080",
		linknext = "0020_00082",
		line = 972,
	},
	["0020_00082"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The little Touka Reizeiin was treated like a slave there.",
					{"rt2"},
				},
			},
			cn = {
				{
					"小时候冷泉院桐香确实在那里被当成“驻防家的仆人”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"小時候冷泉院桐香確實在那裡被當成「駐防家的僕人」。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00081",
		linknext = "0020_00083",
		line = 982,
	},
	["0020_00083"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And slaves don’t need something like their own “self.” They’re only required to loyally serve their duty.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那里需要没有自我，只会忠实完成任务的“驻防家的仆人”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那裡需要沒有自我，只會忠實完成任務的「駐防家的僕人」。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00082",
		linknext = "0020_00084",
		line = 992,
	},
	["0020_00084"] = {
		{"fg", file="tohka_02m_00004", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0487", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“However, they branded me as incapable, so I wasn’t able to live even as a servant.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“但我在那边被烙上无能的烙印，连“驻防家的仆人”都当不了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「但我在那邊被烙上無能的烙印，連「駐防家的僕人」都當不了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00083",
		linknext = "0020_00085",
		line = 1007,
	},
