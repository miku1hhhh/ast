	["0020_00034"] = {
		{"fg", file="tohka_02m_00004", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0477", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“It’s obvious that when you hold so many events and try to reinforce the FS, there will be opposition. Even in our old world, I always had to be conscious of the balance of power.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“举办这么多的活动，加强FS的力量的话，引起反弹也是自然的。事实上我在原本世界也相当重视权力制衡。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「舉辦這麼多的活動，加強FS的力量的話，引起反彈也是自然的。事實上我在原本世界也相當重視權力制衡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00033",
		linknext = "0020_00035",
		line = 418,
	},
	["0020_00035"] = {
		{"fg", file="tohka_02m_00004", file1="tohka_02m_00101", file3="tohka_02m_00303", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
