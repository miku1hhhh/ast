				},
			},
			cn = {
				{
					name = {"桐香"},
					"“虽说如此，但竟想掌权到做出那种文件……我还是很不了解这边的自己啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「雖說如此，但竟想掌權到做出那種文件……我還是很不了解這邊的自己啊。」",
					{"rt2"},
				},
			},
		},
