	["0020_00100"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She couldn’t comprehend whether her sister pities her, sympathizes with her, or simply loves her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是觉得可怜呢，还是悲伤呢，还是只是爱着她呢，都没有办法理解。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是覺得可憐呢，還是悲傷呢，還是只是愛著她呢，都沒有辦法理解。",
