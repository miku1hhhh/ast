	},
	["0020_00143"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’m certain that only people close to her know the truth.",
					{"rt2"},
				},
			},
			cn = {
				{
					"应该只有亲近的人才知道这些事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"應該只有親近的人才知道這些事。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00142",
		linknext = "0020_00144",
		line = 1671,
	},
	["0020_00144"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In that sense, there are very few individuals who can understand her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在这个层面上，果然",
					{"ruby", text="・・・・・"},
					"理解她的人",
					{"/ruby"},
					"相当少。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在這個層面上，果然",
					{"ruby", text="・・・・・"},
					"理解她的人",
					{"/ruby"},
					"相當少。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00143",
		linknext = "0020_00145",
		line = 1681,
	},
	["0020_00145"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There’s a side to her that has incredible charisma, exceptional fighting skills, and an ability to attract everyone around her...",
					{"rt2"},
				},
			},
			cn = {
				{
					"发挥领袖魅力并拥有一骑当千的战斗能力，吸引周遭的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"發揮領袖魅力並擁有一騎當千的戰鬥能力，吸引周遭的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00144",
		linknext = "0020_00146",
		line = 1691,
	},
	["0020_00146"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And the completely opposite side that is unable to perform daily activities, is sloppy in everything she does, and unintentionally irritates people.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没有办法好好过日常生活，做什么都麻烦，无意识会惹怒人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒有辦法好好過日常生活，做什麼都麻煩，無意識會惹怒人。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00145",
		linknext = "0020_00147",
		line = 1701,
	},
	["0020_00147"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No one would believe it if I told them that. Just like the FS members didn’t earlier today.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算说出口也不会有人信的吧，就像刚才的FS们那样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算說出口也不會有人信的吧，就像剛才的FS們那樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00146",
		linknext = "0020_00148",
		line = 1711,
	},
	["0020_00148"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even I wouldn’t have known her, had I not become her babysitter.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我要是没有照顾桐香，也不会这么了解她。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我要是沒有照顧桐香，也不會這麼了解她。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00147",
		linknext = "0020_00149",
		line = 1721,
	},
	["0020_00149"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, both sides of Touka belong to the same person after all.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使如此，果然哪一边的桐香都是她自己。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使如此，果然哪一邊的桐香都是她自己。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00148",
		linknext = "0020_00150",
		line = 1731,
	},
	["0020_00150"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This crooked balance is what makes her imperfect and puts her at risk.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这种不平衡造成她的不安定感，也带有一些扭曲──",
					{"rt2"},
				},
			},
			tw = {
				{
					"這種不平衡造成她的不安定感，也帶有一些扭曲──",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00149",
		linknext = "0020_00151",
		line = 1741,
	},
	["0020_00151"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s exactly why she’s so lonely.",
					{"rt2"},
				},
			},
			cn = {
				{
					"──所以她非常地孤独。",
					{"rt2"},
				},
			},
			tw = {
				{
					"──所以她非常地孤獨。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00150",
