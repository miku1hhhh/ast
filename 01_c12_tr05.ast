	["0020_00088"] = {
		{"fg", file="tohka_02m_00004", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0488", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“The only thing I had was my name. It means ‘paulownia tree flower.’ My parents wanted me to make people smile at its wonderful smell.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“如桐花般芬芳，笑如花般美丽──只有加入父母这样愿望的名字而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「如桐花般芬芳，笑如花般美麗──只有加入父母這樣願望的名字而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00087",
		linknext = "0020_00089",
		line = 1052,
	},
	["0020_00089"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This is the story behind her name “Touka” that she received from her late parents.",
					{"rt2"},
