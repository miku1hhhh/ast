	},
	["0020_00152"] = {
		{"fg", file="tohka_01m_00004", file1="tohka_01m_00101", file2="tohka_01m_00208", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="桐香8", id=8, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0500", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Phew... I feel so tired. I probably talked too much.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呼啊ー总觉得有点疲倦，因为说太多话了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「呼啊ー總覺得有點疲倦，因為說太多話了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00151",
		linknext = "0020_00153",
		line = 1767,
	},
	["0020_00153"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Of course there was meaning to those fighting days.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那些战斗的日子当然有意义。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那些戰鬥的日子當然有意義。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00152",
		linknext = "0020_00154",
		line = 1777,
	},
	["0020_00154"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I earned various things. I can’t say that it ended badly for me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我也赢得很多东西，不认为那样有错。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我也贏得很多東西，不認為那樣有錯。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00153",
		linknext = "0020_00155",
		line = 1787,
	},
	["0020_00155"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I wonder if it really had a point for her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但那对她来说真的有意义吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"但那對她來說真的有意義嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00154",
		linknext = "0020_00156",
		line = 1797,
	},
	["0020_00156"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What meaning did it have for me, her caretaker, and for our relationship?",
					{"rt2"},
				},
			},
			cn = {
				{
					{"ruby", text="・・・・・・・・"},
					"对于跟她相处的我",
					{"/ruby"},
					"，还有我们的关系来说，究竟有什么意义呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					{"ruby", text="・・・・・・・・"},
					"對於跟她相處的我",
					{"/ruby"},
					"，還有我們的關係來說，究竟有什麼意義呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00155",
		linknext = "0020_00157",
		line = 1807,
	},
	["0020_00157"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Honestly, I don’t know at the moment.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在的我，老实说并不清楚。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在的我，老實說並不清楚。",
					{"rt2"},
				},
			},
		},
