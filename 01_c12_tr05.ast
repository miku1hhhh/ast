				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Actually... Why do you want me to join the FS, Touka?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“相反地……桐香为什么这么想让我加入FS啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「相反地……桐香為什麼這麼想讓我加入FS啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00068",
		linknext = "0020_00070",
		line = 832,
	},
	["0020_00070"] = {
