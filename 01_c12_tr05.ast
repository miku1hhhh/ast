	["0020_00067"] = {
		{"fg", file="tohka_01m_00004", file1="tohka_01m_00101", file2="tohka_01m_00202", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="桐香8", id=8, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0483", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I see. If you’re putting it that way, then I won’t push you anymore. It’s a shame, but I’ll give up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“这样啊。……这样的话我也不能再继续拜托你了，真可惜，我会放弃的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「這樣啊。……這樣的話我也不能再繼續拜託你了，真可惜，我會放棄的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00066",
		linknext = "0020_00068",
		line = 810,
	},
	["0020_00068"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She shrugs her shoulders and gives me a smile. She looks sorry from the bottom of her heart, but also not THAT sorry at the same time.",
					{"rt2"},
				},
			},
			cn = {
				{
					"桐香像是真心可惜般，用着也没那么严重的笑容耸肩。",
					{"rt2"},
				},
			},
			tw = {
				{
					"桐香像是真心可惜般，用著也沒那麼嚴重的笑容聳肩。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00067",
		linknext = "0020_00069",
		line = 820,
	},
	["0020_00069"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00219", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=8},
		{"text"},
		text = {
