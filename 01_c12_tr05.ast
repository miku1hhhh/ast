					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“When you spoke your opinion to shut them up earlier... Were those your real thoughts?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那时让他们闭嘴的意见……是你的真心话吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那時讓他們閉嘴的意見……是妳的真心話吧？」",
