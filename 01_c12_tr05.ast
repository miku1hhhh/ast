			},
			tw = {
				{
					"即使被賣到這座島上，被當成超人或天才，也沒有改變。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00107",
		linknext = "0020_00109",
		line = 1281,
	},
	["0020_00109"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, there’s no such person on Seiran Island who would understand her as her sister did.",
					{"rt2"},
				},
			},
			cn = {
				{
					"青蓝岛上没有像姐姐那样理解自己的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"青藍島上沒有像姐姐那樣理解自己的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00108",
		linknext = "0020_00110",
		line = 1291,
	},
	["0020_00110"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She found comrades who are eager to support her, but everyone approaches her with awe, respect, or fear.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然有支持自己的伙伴，但她们对自己抱持敬畏，甚至是畏惧，来跟她相处。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然有支持自己的夥伴，但她們對自己抱持敬畏，甚至是畏懼，來跟她相處。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00109",
		linknext = "0020_00111",
		line = 1301,
	},
	["0020_00111"] = {
		{"fg", file="tohka_02m_00004", file1="tohka_02m_00101", file3="tohka_02m_00313", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0493", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Rei and Ikuko are well aware that they’re my subordinates. This is necessary to maintain balance in an organization.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“礼或郁子，为了保持组织平衡，所以才当我的部下。当然我也知道。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「禮或郁子，為了保持組織平衡，所以才當我的部下。當然我也知道。」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00110",
		linknext = "0020_00112",
		line = 1316,
	},
	["0020_00112"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, there was no one but her sister who could try to know the real Touka Reizeiin.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是没有人想理解真正的冷泉院桐香。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是沒有人想理解真正的冷泉院桐香。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00111",
		linknext = "0020_00113",
		line = 1326,
	},
	["0020_00113"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No... probably even her sister couldn’t understand her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不……或许连那个姐姐也不是真的理解她也说不定。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不……或許連那個姐姐也不是真的理解她也說不定。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00112",
		linknext = "0020_00114",
		line = 1336,
	},
	["0020_00114"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She’s always been alone.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她──总是一个人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她──總是一個人。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00113",
		linknext = "0020_00115",
		line = 1346,
	},
	["0020_00115"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The only one on the top.",
					{"rt2"},
				},
			},
			cn = {
				{
					"顶点，只会有一个人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"頂點，只會有一個人。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00114",
		linknext = "0020_00116",
		line = 1356,
	},
	["0020_00116"] = {
		{"fg", file="tohka_02m_00004", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0494", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“That’s why I didn’t want to find such a person... I didn’t want anyone to become like me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“所以我不希望打造出这样的人……不想要做出跟我一样的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「所以我不希望打造出這樣的人……不想要做出跟我一樣的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00115",
		linknext = "0020_00117",
		line = 1371,
	},
	["0020_00117"] = {
		{"fg", file="tohka_02m_00004", file1="tohka_02m_00101", file2="tohka_02m_00213", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0495", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I didn’t want that for you either.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“也不希望你变得像我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「也不希望你變得像我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00116",
		linknext = "0020_00118",
		line = 1386,
	},
	["0020_00118"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But she couldn’t realize it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是该说是她没有自觉吗。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是該說是她沒有自覺嗎。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00117",
		linknext = "0020_00119",
		line = 1396,
	},
	["0020_00119"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She was just blindly acting based on her obsession that some things have to be done a particular way.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只是根据着“应该这样做”的强迫观念在含糊地行动。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只是根據著「應該這樣做」的強迫觀念在含糊地行動。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00118",
		linknext = "0020_00120",
		line = 1406,
	},
	["0020_00120"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This behavioral pattern may be called both genius and one of habit.",
					{"rt2"},
				},
			},
			cn = {
				{
					"该说是天才还是习性般的行动模式。",
					{"rt2"},
				},
			},
			tw = {
				{
					"該說是天才還是習性般的行動模式。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00119",
		linknext = "0020_00121",
		line = 1416,
	},
	["0020_00121"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The cause of an “initial impulse” is said to be the most fierce.",
					{"rt2"},
				},
			},
			cn = {
				{
					"最激烈而被称为“原始冲动”的理由。",
					{"rt2"},
				},
			},
			tw = {
				{
					"最激烈而被稱為「原始衝動」的理由。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00120",
		linknext = "0020_00122",
		line = 1426,
	},
	["0020_00122"] = {
		{"fg", file="tohka_01m_00004", file1="tohka_01m_00101", file2="tohka_01m_00202", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0496", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You were the ones who made me notice it, Tachibana.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“注意到这点的只有你们喔，学长？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「注意到這點的只有你們喔，學長？」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00121",
		linknext = "0020_00123",
		line = 1441,
	},
	["0020_00123"] = {
