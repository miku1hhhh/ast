	["0020_00126"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She described Touka’s heart perfectly, in a way even Touka herself could never do.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说中了连自己都不清楚的少女的心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說中了連自己都不清楚的少女的心。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00125",
		linknext = "0020_00127",
		line = 1483,
	},
	["0020_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Touka, who sees the world with pure eyes, would never be able to put it into words.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那不带一丝阴霾的眼睛看着世界，看着少女。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那不帶一絲陰霾的眼睛看著世界，看著少女。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00126",
		linknext = "0020_00128",
		line = 1493,
	},
	["0020_00128"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But Hinami saw right through her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"完全看透了她的心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"完全看透了她的心。",
					{"rt2"},
				},
