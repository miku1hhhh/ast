	},
	["0020_00132"] = {
		{"fg", file="tohka_02m_00004", file1="tohka_02m_00101", file2="tohka_02m_00228", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="桐香8", id=8, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0499", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“And I’m really happy about that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“……这对我来说是非常高兴的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「……這對我來說是非常高興的事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00131",
		linknext = "0020_00133",
		line = 1559,
	},
	["0020_00133"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Understanding another person by connecting with their mucous membranes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"──透过黏膜接触来理解对手。",
					{"rt2"},
				},
			},
			tw = {
				{
					"──透過黏膜接觸來理解對手。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00132",
		linknext = "0020_00134",
		line = 1569,
	},
	["0020_00134"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Normally, that’s not possible.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这可不是普通能办到的事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這可不是普通能辦到的事。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00133",
		linknext = "0020_00135",
		line = 1579,
	},
	["0020_00135"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But if it was, she would have figured it out with her brilliant deduction.",
					{"rt2"},
				},
			},
			cn = {
				{
					"要是能办到，大概也是因为她天生的洞察力导出的结论吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要是能辦到，大概也是因為她天生的洞察力導出的結論吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00134",
		linknext = "0020_00136",
		line = 1589,
	},
	["0020_00136"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, I felt like saying that aloud would be awful.",
					{"rt2"},
				},
			},
			cn = {
				{
					"把这些想法说出口，感觉实在太过残酷。",
					{"rt2"},
				},
			},
			tw = {
				{
					"把這些想法說出口，感覺實在太過殘酷。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00135",
		linknext = "0020_00137",
		line = 1599,
	},
	["0020_00137"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s not something I should say when she wants to understand another person from the bottom of her heart.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为过去的孤独，少女打从心底想要理解其他人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為過去的孤獨，少女打從心底想要理解其他人。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00136",
		linknext = "0020_00138",
		line = 1609,
	},
	["0020_00138"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ironically, because of her brilliance, she absolutely lacks the ability to sympathize with other people.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但讽刺的是她却因为天才性，完全缺乏这样的能力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但諷刺的是她卻因為天才性，完全缺乏這樣的能力。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00137",
		linknext = "0020_00139",
		line = 1619,
	},
	["0020_00139"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This is how the student council president, Touka Reizeiin, is.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不了解人心的学生会长，冷泉院桐香。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不了解人心的學生會長，冷泉院桐香。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00138",
		linknext = "0020_00140",
		line = 1629,
	},
	["0020_00140"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In spite of the fact that what she wants the most is mutual understanding, she can’t possibly be further from achieving it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"过去生存的地方，是最不寻求相互理解的场所。",
					{"rt2"},
				},
			},
			tw = {
				{
					"過去生存的地方，是最不尋求相互理解的場所。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00139",
		linknext = "0020_00141",
		line = 1639,
	},
	["0020_00141"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"At the end of the day, she keeps living not being able to gain understanding, and always remains alone.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算终于能好好面对无法相互理解的日子，也还是很孤独。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算終於能好好面對無法相互理解的日子，也還是很孤獨。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00140",
		linknext = "0020_00142",
		line = 1649,
	},
	["0020_00142"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file3="jun_01f_00301", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=8},
		{"text"},
		text = {
