		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0503", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Hehe! I could get addicted to this... Mmm...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呵呵……这个，真让人沉迷啊……嗯呜ー”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「呵呵……這個，真讓人沉迷啊……嗯嗚ー」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00161",
