		line = 1913,
	},
	["0020_00163"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00210", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=8},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You finally understood, huh? Idiot.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你终于明白了吗，这个小笨蛋……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳終於明白了嗎，這個小笨蛋……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00162",
		linknext = "0020_00164",
		line = 1925,
	},
	["0020_00164"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe this is because she unconsciously wants to make her parents’ wish hidden in her name come true.",
					{"rt2"},
				},
			},
			cn = {
				{
					"或许是她无意识地觉得──想要实现父母的愿望，那个加诸于名字的愿望也说不定。",
					{"rt2"},
				},
			},
			tw = {
				{
					"或許是她無意識地覺得──想要實現父母的願望，那個加諸於名字的願望也說不定。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00163",
		linknext = "0020_00165",
		line = 1935,
	},
	["0020_00165"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s why she wants everyone to smile as well.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以她才会希望一直对大家笑着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以她才會希望一直對大家笑著。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00164",
		linknext = "0020_00166",
		line = 1945,
	},
	["0020_00166"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But... people’s hearts can’t always be smiling.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是──在心里不可能一直笑着才对。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是──在心裡不可能一直笑著才對。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00165",
		linknext = "0020_00167",
		line = 1955,
	},
	["0020_00167"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Environmental changes affect her genius nature and her abnormalities, even if she’s the object of everyone’s awe and respect caused by her genius.",
					{"rt2"},
				},
			},
			cn = {
				{
					"环境跟当时不同了，拥有天才性跟超常特质，成为所有人都感到畏惧的对象。",
					{"rt2"},
				},
			},
			tw = {
				{
					"環境跟當時不同了，擁有天才性跟超常特質，成為所有人都感到畏懼的對象。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00166",
		linknext = "0020_00168",
		line = 1965,
	},
	["0020_00168"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No one could truly understand her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没有人能成为理解她的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒有人能成為理解她的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00167",
		linknext = "0020_00169",
		line = 1975,
	},
	["0020_00169"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even Rei and Ikuko. They are aware that they can’t understand Touka.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使是礼前辈或郁子，也都像她们自觉的那样，没有打算理解真正的桐香。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使是禮前輩或郁子，也都像她們自覺的那樣，沒有打算理解真正的桐香。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00168",
		linknext = "0020_00170",
		line = 1985,
	},
	["0020_00170"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"From their point of view, they’re her subordinates, so they aren’t actually her equals.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为是部下，不是真正意义上的对等存在，那两人是这样想的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為是部下，不是真正意義上的對等存在，那兩人是這樣想的。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00169",
		linknext = "0020_00171",
		line = 1995,
	},
