	["0020_00071"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I know that she has a kind of her own philosophy when it comes to mutual understanding.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为相互理解，我知道她拥有某种程度的个人哲学。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為相互理解，我知道她擁有某種程度的個人哲學。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00070",
