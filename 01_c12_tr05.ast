					{"rt2"},
				},
			},
			en = {
				{
					"Plus, I saw her as an enemy I needed to defeat, so, of course, my opinion was biased.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为当时的我认为他们是必须打倒的敌人，当然也有所偏见……。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為當時的我認為他們是必須打倒的敵人，當然也有所偏見……。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00062",
		linknext = "0020_00064",
		line = 764,
	},
	["0020_00064"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe I didn’t actually hate that place called the FS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……但我或许意外地不讨厌FS这个地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……但我或許意外地不討厭FS這個地方。",
					{"rt2"},
				},
			},
		},
		linkback = "0020_00063",
		linknext = "0020_00065",
		line = 774,
	},
	["0020_00065"] = {
