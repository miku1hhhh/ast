	["0048_00030"] = {
		{"fg", file="asane_04m_00001", file1="asane_04m_00101", file2="asane_04m_00222", path=":fg/asane_04m/", id=3, lv=3, head="asane_04m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0133", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“No, you should stay in bed...! Onabuta said you shattered a ton of bones when you got sandwiched by those riot bullets...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊啊啊！还是躺着比较好啦……！女部田说你被防暴弹夹杀的时候，骨头全都碎得乱七八糟了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊啊啊！還是躺著比較好啦……！女部田說你被防暴彈夾殺的時候，骨頭全都碎得亂七八糟了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0048_00029",
		linknext = "0048_00031",
		line = 436,
	},
	["0048_00031"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00210", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
