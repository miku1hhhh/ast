	["0048_00057"] = {
		{"fg", file="asane_03m_00001", file1="asane_03m_00101", file2="asane_03m_00204", path=":fg/asane_03m/", id=3, lv=3, head="asane_03m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0144", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“It’s in the heart of the island, and it’s the focal point for the perverted sex law. All you have to do is destroy it and you’d make perverted sex essentially impossible.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那是这座岛的心脏，变态条例的重镇。要是连这儿都被摧毁的话，变态做爱也不可能实行了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那是這座島的心臟，變態條例的重鎮。要是連這兒都被摧毀的話，變態做愛也不可能實行了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0048_00056",
		linknext = "0048_00058",
		line = 792,
	},
	["0048_00058"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The SHO realizes that themselves, and so their response must be to further increase their security.",
					{"rt2"},
				},
			},
			cn = {
				{
					"SHO成员们也很清楚这点，所以应该会再次加强警备来应对。",
					{"rt2"},
				},
			},
			tw = {
				{
					"SHO成員們也很清楚這點，所以應該會再次加強警備來應對。",
					{"rt2"},
				},
			},
		},
		linkback = "0048_00057",
		linknext = "0048_00059",
		line = 802,
	},
	["0048_00059"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That said, Akino vanished after everything that happened.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但那之后，秋野不知所踪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但那之後，秋野不知所蹤。",
					{"rt2"},
				},
			},
		},
		linkback = "0048_00058",
		linknext = "0048_00060",
		line = 812,
	},
	["0048_00060"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I doubt the men and women of the SHO can hold out defending their headquarters. Not only are they exhausted, a sense of despair now hangs over them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那些人精疲力尽又受尽绝望折磨，我并不认为他们能守得住大楼。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那些人精疲力盡又受盡絕望折磨，我並不認為他們能守得住大樓。",
					{"rt2"},
				},
			},
		},
		linkback = "0048_00059",
		linknext = "0048_00061",
		line = 822,
	},
	["0048_00061"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Did she decide to hang us out to dry knowing all this...?",
					{"rt2"},
				},
			},
			cn = {
				{
					"她连这个都算到了，所以才放任我们行动吗──",
					{"rt2"},
				},
			},
			tw = {
				{
					"她連這個都算到了，所以才放任我們行動嗎──",
					{"rt2"},
				},
			},
		},
		linkback = "0048_00060",
		linknext = "0048_00062",
		line = 832,
	},
