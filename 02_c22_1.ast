			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I don’t know where the Hamedoris are being housed, but I have locked them down with a security code. I’m generating random numbers to change the password every thirty seconds, but...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“虽然我不知道存放Hamedori君的仓库在哪，不过安全码是我设定的。我现在设置了每30秒就会透过乱数更改一次的路径，不过──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「雖然我不知道存放Hamedori君的倉庫在哪，不過安全碼是我設定的。我現在設置了每30秒就會透過亂數更改一次的路徑，不過──」",
					{"rt2"},
				},
			},
		},
		linkback = "0048_00061",
		linknext = "0048_00063",
		line = 850,
	},
	["0048_00063"] = {
