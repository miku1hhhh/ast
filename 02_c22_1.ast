	["0048_00071"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00210", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It’s a big brother’s job to clean up after his little sister’s messes. Who do you think changed your diapers for all those years?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“帮妹妹擦屁股本来就是哥哥的责任。你也不想想你的尿布都是谁帮你换的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「幫妹妹擦屁股本來就是哥哥的責任。妳也不想想妳的尿布都是誰幫妳換的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0048_00070",
