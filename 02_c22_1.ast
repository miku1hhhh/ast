					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It’s fine, Asa... I’m your big brother, remember?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没事的啦麻沙酱⋯⋯因为我是哥哥嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒事的啦麻沙醬⋯⋯因為我是哥哥嘛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0048_00030",
		linknext = "0048_00032",
		line = 448,
	},
	["0048_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Older brothers aren’t so weak that they’d let something like this stop them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我这个当哥哥的，还没有弱到这种程度就动弹不得的地步。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我這個當哥哥的，還沒有弱到這種程度就動彈不得的地步。",
					{"rt2"},
				},
			},
		},
		linkback = "0048_00031",
		linknext = "0048_00033",
		line = 458,
	},
	["0048_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Physically speaking, I should be able to move without any issues if I just get Fumino to hit me with some morphine later.",
					{"rt2"},
				},
			},
			cn = {
				{
					"物理上来说，只要待会让文乃给我注射完吗啡，活动什么就完全没问题了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"物理上來說，只要待會讓文乃給我注射完嗎啡，活動什麼就完全沒問題了。",
					{"rt2"},
				},
			},
		},
		linkback = "0048_00032",
		linknext = "0048_00034",
		line = 468,
	},
	["0048_00034"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What we should really be doing is going over Akino’s plan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“比起这个，我们还是来整理回顾一下秋野的计划吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「比起這個，我們還是來整理回顧一下秋野的計畫吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0048_00033",
		linknext = "0048_00035",
		line = 480,
	},
	["0048_00035"] = {
		{"fg", file="asane_03m_00001", file1="asane_03m_00101", file2="asane_03m_00206", path=":fg/asane_03m/", id=3, lv=3, head="asane_03m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0134", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yeah... Right now, there are a few hundred Armored Hamedoris being serviced at the SHO—though I guess the organization has been taken over now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯⋯⋯现在的SHO──虽然已经被那个人掌控了但还是先这样称呼──里头配备了数百架的武装Hamedori君。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯⋯⋯現在的SHO──雖然已經被那個人掌控了但還是先這樣稱呼──裡頭配備了數百架的武裝Hamedori君。」",
					{"rt2"},
				},
			},
		},
		linkback = "0048_00034",
		linknext = "0048_00036",
		line = 495,
	},
	["0048_00036"] = {
		{"fg", file="asane_03m_00001", file1="asane_03m_00101", file2="asane_03m_00206", path=":fg/asane_03m/", id=3, lv=3, head="asane_03m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0135", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“They were originally hidden all over the island so that Akino could always be ready to fight, but...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“岛上各处也藏了装甲，原本是方便让秋野同学能随时战斗用的──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「島上各處也藏了裝甲，原本是方便讓秋野同學能隨時戰鬥用的──」",
					{"rt2"},
				},
			},
		},
		linkback = "0048_00035",
		linknext = "0048_00037",
		line = 510,
	},
	["0048_00037"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Of course. That’s why they were able to appear anywhere...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来如此，所她才能无时无刻出现在各种地方──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來如此，所她才能無時無刻出現在各種地方──」",
					{"rt2"},
				},
			},
		},
		linkback = "0048_00036",
		linknext = "0048_00038",
		line = 522,
	},
	["0048_00038"] = {
		{"fg", file="asane_03m_00001", file1="asane_03m_00101", file2="asane_03m_00204", path=":fg/asane_03m/", id=3, lv=3, head="asane_03m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0136", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“But now they can basically fight on their own thanks to the automatic control I made. They’re all equipped with neural networks that allow them to teach themselves combat.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“因为有我做的自动控制程式，每一架Hamedori君都搭载了类神经网络，所以可以自己学习战斗技术，现在它们几乎可以完全自动执行战斗了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「因為有我做的自動控制程式，每一架Hamedori君都搭載了類神經網路，所以可以自己學習戰鬥技術，現在它們幾乎可以完全自動執行戰鬥了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0048_00037",
		linknext = "0048_00039",
		line = 537,
	},
	["0048_00039"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00305", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So you’re saying they’ve already learned from our earlier fight?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说，上一次跟我们对战的一切，它都已经吸收学习了吗──？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說，上一次跟我們對戰的一切，它都已經吸收學習了嗎──？」",
					{"rt2"},
				},
			},
		},
		linkback = "0048_00038",
		linknext = "0048_00040",
		line = 549,
	},
	["0048_00040"] = {
		{"fg", file="asane_03m_00001", file1="asane_03m_00101", file2="asane_03m_00217", path=":fg/asane_03m/", id=3, lv=3, head="asane_03m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0137", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yeah, so they won’t malfunction like before. I doubt you’ll be able to sic any Hamedoris on Akino or confuse them into fighting each other this time...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯，所以不会再发生像上次那样的故障情况，所以想要透过让秋野同学触发Hamedori的攻击机制，让它混淆攻击对象是不可能的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯，所以不會再發生像上次那樣的故障情況，所以想要透過讓秋野同學觸發Hamedori的攻擊機制，讓它混淆攻擊對象是不可能的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0048_00039",
		linknext = "0048_00041",
		line = 564,
	},
	["0048_00041"] = {
		{"fg", file="asane_03m_00001", file1="asane_03m_00101", file2="asane_03m_00203", path=":fg/asane_03m/", id=3, lv=3, head="asane_03m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0138", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“All of these Hamedoris are capable of self-sustained flight. One order and they’ll keep going until their mission is complete. They can even share information with each other using radio waves.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“这些Hamedori君都能自己飞。只要下令的话，没有完成之前它们绝对不会停止。而且它们还能透过电波传输来共享情报。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「這些Hamedori君都能自己飛。只要下令的話，沒有完成之前它們絕對不會停止。而且它們還能透過電波傳輸來共享情報。」",
					{"rt2"},
				},
			},
		},
		linkback = "0048_00040",
		linknext = "0048_00042",
		line = 579,
	},
	["0048_00042"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00218", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So I won’t be able to use anti-radiation missiles like last time because there’s no single source of orders...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以说没有了像上次一样的单一命令讯号源，那导弹就不能用了──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以說沒有了像上次一樣的單一命令訊號源，那導彈就不能用了──」",
					{"rt2"},
				},
			},
		},
		linkback = "0048_00041",
		linknext = "0048_00043",
		line = 591,
	},
	["0048_00043"] = {
