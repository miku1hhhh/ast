			en = {
				{
					name = {"礼", "Rei"},
					"“Sorry about all this. It was Hinami who said she wanted to play ghost-hunting. I had no idea we’d end up involving so many people...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“总觉得很对不起……明明是雏见想要试胆才叫上大家……没想到变成这么大一群人啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「總覺得很對不起……明明是雛見想要試膽才叫上大家……沒想到變成這麼大一群人啊……」",
					{"rt2"},
				},
			},
		},
