					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「什什什什剛剛那是甚麼！臉！臉臉！沒有了！沒，沒有臉……！！」",
					{"rt2"},
				},
			},
		},
