		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The night’s hot, moist air wraps around my skin, giving me discomfort that words can’t describe.",
					{"rt2"},
				},
			},
			cn = {
				{
					"热带夜晚潮湿的空气渐渐地附着在身上，给人一种说不出的不适感。",
