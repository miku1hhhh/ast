		text = {
			vo = {
				{"vo", file="rei2265", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“That said, I know a show that incorporated the Y2K problem quite well into its lore! It’s shorter compared to other series in its franchise, but the story gets really intense midway and...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“哦，我只知道在设定中巧妙地加入了2000年问题的作品！本篇在相关作品中时间较短,从中途开始就不断有激烈的剧情展开,我也非常推荐。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「哦，我只知道在設定中巧妙地加入了2000年問題的作品！本篇在相關作品中時間較短,從中途開始就不斷有激烈的劇情展開,我也非常推薦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00490",
		linknext = "0098_00492",
		line = 7577,
	},
	["0098_00492"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Somehow, I pushed her Tokusatsu weeb button. Rei likes to compare every worldly event to a Tokusatsu show, like a true weeb.",
					{"rt2"},
				},
			},
			cn = {
				{
					"唔哇，总觉得踩到了特摄宅特有的将全世界都与特摄连接上而开始兴奋得地雷。",
					{"rt2"},
				},
			},
			tw = {
				{
					"唔哇，總覺得踩到了特攝宅特有的將全世界都與特攝連接上而開始興奮得地雷。",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00491",
		linknext = "0098_00493",
		line = 7587,
	},
	["0098_00493"] = {
