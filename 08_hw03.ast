			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Oh, Hinami has her chair with her. Oh my... she might kill us if we pull the wrong punches.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“哎呀……雏见同学，还带着那把椅子呢……真可怕……一弄不好会不会被杀了啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「哎呀……雛見同學，還帶著那把椅子呢……真可怕……一弄不好會不會被殺了啊？」",
					{"rt2"},
				},
			},
		},
