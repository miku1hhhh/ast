		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0643", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“W-w-w-w-what was that?! Face?! No face?! Why no face?! Holy buttocks, face...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
