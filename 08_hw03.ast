					name = {"礼", "Rei"},
					"“Be cautious. Legends say that if you do not free the spirits of 15 lewd ghosts within 99 minutes, you will become lewd yourself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“要好好保重喔。听说要是在99分钟之内无法将15只变态幽灵驱除干净的话，就会变成变态喔⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「要好好保重喔。聽說要是在99分鐘之內無法將15隻變態幽靈驅除乾淨的話，就會變成變態喔⋯⋯」",
					{"rt2"},
				},
			},
		},
