				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“FS所拥有的数据也被用于Orgast的开发。这次为了狩猎幽灵，麻沙酱进行许多测试的样子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「FS所擁有的數據也被用於Orgast的開發。這次為了狩獵幽靈，麻沙醬進行許多測試的樣子。」",
					{"rt2"},
				},
			},
		},
