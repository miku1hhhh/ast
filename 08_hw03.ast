		{"fgact", ch="麻沙音3", id=3, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1318", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Oh no, no, no, absolutely no problem at all, I’ll gladly sacrifice every bone in my body any day if you’re willing to break a bone for my pathetic kiddie-diddling sorry excuse for a brother.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不会不会不会，要是奈奈濑同学为了那种萝莉控而折断我的骨头的话，本人也已经做好全身粉碎性骨折的准备了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不會不會不會，要是奈奈瀨同學為了那種蘿莉控而折斷我的骨頭的話，本人也已經做好全身粉碎性骨折的準備了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00071",
		linknext = "0098_00073",
		line = 1149,
	},
	["0098_00073"] = {
		{"fg", mode=-1, id=3, ch="麻沙音3", ch_origin="麻沙音", lv=3, time=0, sync=0},
