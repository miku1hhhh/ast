	["0098_00082"] = {
		{"fg", file="hinami_04l_00001", file1="hinami_04l_00102", file2="hinami_04l_00211", path=":fg/hinami_04l/", id=5, lv=5, head="hinami_04l", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", mwframe="mwframe", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0633", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“But in TV, people who say things like that are the first ones to die...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“可，可是……在看电视剧的时候，说这种话的人，基本上都会死翘翘啊……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「可，可是……在看電視劇的時候，說這種話的人，基本上都會死翹翹啊……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00081",
		linknext = "0098_00083",
		line = 1389,
	},
	["0098_00083"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00218", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You’re talking about TV. We’re living in reality here—and in reality, there are no ghosts.”",
					{"rt2"},
				},
			},
			cn = {
