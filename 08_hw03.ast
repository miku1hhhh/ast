		{"text"},
		text = {
			vo = {
				{"vo", file="august0028", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"オーガスト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"オーガスト", "August"},
					"“Fox Face. Binomial name Solanum mammosum. Also known as nipplefruit, fox head, etc. Native to South America.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"オーガスト", "August"},
					"‘可可树。梧桐科常绿树木。原产于热带美洲’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"オーガスト", "August"},
					"『可可樹。梧桐科常綠樹木。原產於熱帶美洲』",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00120",
		linknext = "0098_00122",
		line = 1970,
	},
	["0098_00122"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00212", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We didn’t ask for that! We want to know what the hell we just saw! Can this be real?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“才没问你啊！刚刚看见的是什么啊！？真的是真实的嘛！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「才沒問你啊！剛剛看見的是什麼啊！？真的是真實的嘛！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0098_00121",
		linknext = "0098_00123",
		line = 1982,
	},
