			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Oh no, the chair struck a randomly passing woodpecker and changed course! It’s heading right back at us... GAH!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不妙！被弹飞的钢管椅被不知从哪飞来的啄木鸟猛烈地撞击了！椅子改变了路线朝这边来了──唔！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不妙！被彈飛的鋼管椅被不知從哪飛來的啄木鳥猛烈地撞擊了！椅子改變了路線朝這邊來了──唔！？」",
					{"rt2"},
				},
			},
		},
