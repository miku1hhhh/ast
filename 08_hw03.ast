				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Hehehe... From here on, it’s us ghosts’ turn. Can’t wait to see ’Bana’s neat little face get twisted in fear.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“嘿嘿嘿……从现在开始，我们终于要当鬼了。我开始期待橘同学因为恐惧而下歪了的嘴脸了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「嘿嘿嘿……從現在開始，我們終於要當鬼了。我開始期待橘同學因為恐懼而下歪了的嘴臉了。」",
					{"rt2"},
				},
			},
		},
