		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I see. To summarize, you’d like for Hinami and I to go check out the mountains and look into reported ghost sightings since the FS members are occupied and you don’t have the manpower.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来如此⋯⋯有传言说山上有幽灵出没，不过FS的大家都忙得不可开交，因为资源不足才要请我跟雏见做调查、是吗──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來如此⋯⋯有傳言說山上有幽靈出沒，不過FS的大家都忙得不可開交，因為資源不足才要請我跟雛見做調查、是嗎──」",
					{"rt2"},
				},
			},
		},
		linknext = "0098_00002",
		line = 22,
	},
	["0098_00002"] = {
