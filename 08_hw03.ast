					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Yes, evil spirits that possess humans to perform perverse acts using their bodies.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“没错⋯⋯是会附身在活人身上，透过他们的肉体来进行变态行为的恶灵。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「沒錯⋯⋯是會附身在活人身上，透過他們的肉體來進行變態行為的惡靈。」",
					{"rt2"},
				},
			},
		},
