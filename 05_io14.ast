			en = {
				{
					name = {"スス子", "Susuko"},
					"“It said ‘SUCKKKKK! SLURRRRRP!’ and like that it left my home...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“啾噜噜噜噜！啾啵啵啵啵啵啵！？啾啵啾啰啰！！它斩钉截铁地这么说完，就离开我身边了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「啾嚕嚕嚕嚕！啾啵啵啵啵啵啵！？啾啵啾囉囉！！牠斬釘截鐵地這麼說完，就離開我身邊了……」",
					{"rt2"},
				},
			},
		},
