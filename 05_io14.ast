					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“...Huh? Whoa whoa whoa, I swear I told you! The final battle of the Lewd War! I said I love you as you left for the battlefield! Remember?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“……哈？不不不！我说过了吧！？在色情狂战役最终决战的时候，我对即将前往决战的战场的淳之介君说了‘最喜欢你了’不是吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「……哈？不不不！我說過了吧！？在色情狂戰役最終決戰的時候，我對即將前往決戰的戰場的淳之介君說了『最喜歡你了』不是嗎！？」",
					{"rt2"},
				},
			},
		},
