				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I’m sorry, Misaki. I guess you’re still mad that I took Darling from you...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“对不起喔美岬酱……你果然很气我把亲爱的抢走了吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「對不起喔美岬醬……妳果然很氣我把親愛的搶走了吧……」",
