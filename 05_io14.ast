	["0078_00595"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuki0004", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"水姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水姫", "Mizuki"},
					"“The decision was made due to your discriminatory comments made in social networks in the past. That will be all. Now, if you’ll excuse me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水姫"},
					"“据说问题出在过去在SNS等上的歧视言论上面。事情就是这些了。那么容我告辞。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水姫"},
					"「據說問題出在過去在SNS等上的歧視言論上面。事情就是這些了。那麼容我告辭。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00594",
		linknext = "0078_00596",
		line = 8606,
	},
	["0078_00596"] = {
		{"bgm", file="bgm12", vol=100},
		{"bg", id=2, file="bg03_3l_00000", x=0, y=0, lv=2, path=":bg/", sync=0, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="rin_01l_00002", file1="rin_01l_00102", file3="rin_01l_00305", path=":fg/rin_01l/", id=14, lv=14, head="rin_01l", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
