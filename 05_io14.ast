					name = {"郁子", "Ikuko"},
					"“We’re enjoying the party just fine. Just not as much as you. Are you drunk?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“干劲和精神是都有，但恐怕没有美岬吧。你喝醉了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「幹勁和精神是都有，但恐怕沒有美岬吧。妳喝醉了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00192",
		linknext = "0078_00194",
