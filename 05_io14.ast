	["0078_00291"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The island may be in a perpetual summer, but the season on the mainland is late fall. The clear night sky filled with glimmering stars is so captivating.",
					{"rt2"},
				},
			},
			cn = {
				{
					"青蓝岛四季如夏，不过如果用本岛的基准来说，现在的季节是晚秋──空气清澈，星光闪烁的夜空几乎可以说是光彩夺目。",
					{"rt2"},
				},
			},
			tw = {
				{
					"青藍島四季如夏，不過如果用本島的基準來說，現在的季節是晚秋──空氣清澈，星光閃爍的夜空幾乎可以說是光彩奪目。",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00290",
		linknext = "0078_00292",
		line = 4694,
	},
	["0078_00292"] = {
