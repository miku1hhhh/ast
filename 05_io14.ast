		{"bg", id=1, file="bg03_3_00000", x=0, y=0, lv=1, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_009_00000"},
		{"fg", file="rin_01m_00002", file1="rin_01m_00101", file3="rin_01m_00302", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", alpha=0, ch_origin="凛", ch="凛14", mw="mw", sync=1, a_chr151=1, mode=3, x=195, y=-5},
		{"fgact", ch="凛14", id=14, lv=14, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="凛14", id=14, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0260", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Yes yes, Rin Hanamaru coming in! Thank you for taking such a long journey for this visit!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“是是我失礼了花丸凛前来花丸！今天远道而来真是太谢谢您了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「是是我失禮了花丸凜前來花丸！今天遠道而來真是太謝謝您了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00586",
		linknext = "0078_00588",
		line = 8485,
	},
	["0078_00588"] = {
		{"fg", file="rin_01m_00002", file1="rin_01m_00101", file2="rin_01m_00213", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[7000] = {
				{"fg", file="rin_01m_00002", file1="rin_01m_00101", file2="rin_01m_00201", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, timestamp=80, delay2=7000, mode=3, x=-5, y=-5},
			},
			[6999] = {
				{"transitiontime", time=300, timestamp=80, delay2=7000},
			},
		},
		text = {
			vo = {
				{"vo", file="rin0261", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“So, what is the topic for this meeting? Am I going to sing on TV? Get stranded on a deserted island? I wouldn’t mind being a counselor for midnight programs.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“然后呢，大人？您找我有什么贵干？在红白出场？还是要开拓无人岛？要在深夜节目里担任评论人员我也完全可以喔！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「然後呢，大人？您找我有什麼貴幹？在紅白出場？還是要開拓無人島？要在深夜節目裡擔任評論人員我也完全可以喔！」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00587",
		linknext = "0078_00589",
		line = 8503,
	},
	["0078_00589"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuki0001", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"水姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水姫", "Mizuki"},
					"“Sorry to disappoint you, but the gentleman you’re looking for is not here. I am here to convey a message from him.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水姫"},
					"“在您心情正好的时候打真不好意思，但是大人不在场喔。事情大人已经嘱托给在下水姬了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水姫"},
					"「在您心情正好的時候打真不好意思，但是大人不在場喔。事情大人已經囑託給在下水姬了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00588",
		linknext = "0078_00590",
		line = 8516,
	},
	["0078_00590"] = {
		{"fg", file="rin_01m_00002", file1="rin_01m_00101", file3="rin_01m_00319", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[4600] = {
				{"fg", file="rin_01m_00002", file1="rin_01m_00101", file2="rin_01m_00216", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, timestamp=81, delay2=4600, mode=3, x=-5, y=-5},
			},
			[4599] = {
				{"transitiontime", time=300, timestamp=81, delay2=4600},
			},
		},
		text = {
			vo = {
				{"vo", file="rin0262", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Huh? Oh, you’re Senba’s little sister. Hey, I know how tough it is to have a fool for a sister, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“啊？……啊啊，仙波家的妹妹啊。你好。同样有个傻姐姐，你肯定也很辛苦吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「啊？……啊啊，仙波家的妹妹啊。妳好。同樣有個傻姊姊，妳肯定也很辛苦吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00589",
		linknext = "0078_00591",
		line = 8534,
	},
	["0078_00591"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuki0002", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"水姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水姫", "Mizuki"},
					"“There are good fools and bad fools, and my sister falls in the former. I believe she’s done a lot for you too, Rin Hanamaru.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水姫"},
					"“傻瓜也分为好的傻瓜和坏的傻瓜，而家姐算是好的傻瓜。记得花丸凛小姐也关照了她不少吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水姫"},
					"「傻瓜也分為好的傻瓜和壞的傻瓜，而家姊算是好的傻瓜。記得花丸凜小姐也關照了她不少吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00590",
		linknext = "0078_00592",
		line = 8546,
	},
	["0078_00592"] = {
		{"fg", file="rin_01m_00002", file1="rin_01m_00101", file3="rin_01m_00301", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
