				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“You’re satisfied by swinging your power around in the name of justice and delivering brutish punishments to unknowing individuals?! Is that the so-called understanding they want?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					[[“以正义之名高举强权对缺乏同理心的人施加制裁就满足了吗！？那就是各位所期望的"同理心"嘛！？”]],
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					[[「以正義之名高舉強權對缺乏同理心的人施加制裁就滿足了嗎！？那就是各位所期望的"同理心"嘛！？」]],
