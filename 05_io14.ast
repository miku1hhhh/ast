					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「今天是為了一道慶祝歸還到A世界、許可證地更新、還有一隊隊長交到了男朋友──等等諸多事物的派對。」",
					{"rt2"},
				},
			},
		},
