			},
			[8999] = {
				{"transitiontime", time=300, timestamp=83, delay2=9000},
			},
		},
		text = {
			vo = {
				{"vo", file="rin0263", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Sure. But I’m not so sure about being told to show up just to get a message. But, oh well. What do they want?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“算是吧──。可是把本小姐叫过来却叫人传话啊……感觉好像被看轻了让人有点不满，不过也好吧。所以找我有什么事？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「算是吧──。可是把本小姐叫過來卻叫人傳話啊……感覺好像被看輕了讓人有點不滿，不過也好吧。所以找我有什麼事？」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00591",
		linknext = "0078_00593",
		line = 8567,
	},
	["0078_00593"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuki0003", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"水姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水姫", "Mizuki"},
					"“The talk about scouting you has been cancelled.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水姫"},
					"“想要招募花丸凛小姐一事取消了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水姫"},
					"「想要招募花丸凜小姐一事取消了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00592",
