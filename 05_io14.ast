	["0078_00585"] = {
		{"fg", file="rin_01m_00002", file1="rin_01m_00101", file3="rin_01m_00314", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0259", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“My cum-stained struggles are finally about to be Rin-dicated! Goodbye to this god-forsaken island! Believe and you shall be saved!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“也就是说至今为止那些鱿鱼臭的步步积累终于花丸了！可以跟这乡下的小岛说再见啦！信者得救啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「也就是說至今為止那些魷魚臭的步步積累終於花丸了！可以跟這鄉下的小島說再見啦！信者得救啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00584",
		linknext = "0078_00586",
		line = 8450,
	},
	["0078_00586"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuki0000", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"水姫", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水姫", "???"},
					"“Thank you for waiting, Rin Hanamaru. Please come in.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水姫", "？？？"},
					"“久等了，花丸凛小姐。请进。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水姫", "？？？"},
					"「久等了，花丸凜小姐。請進。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00585",
		linknext = "0078_00587",
		line = 8462,
	},
	["0078_00587"] = {
		{"se", id=0, loop=0, file="se_a261"},
