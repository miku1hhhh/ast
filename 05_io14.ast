		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Everyone stopped for a second to see what the ruckus was about, but when they saw that it involved Misaki they lost interest.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为突如其来的骚动，一时之间会场里群情哗然，都在问发生了什么事，但是一发现美岬处在事件的中心，大家就都失去兴趣了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為突如其來的騷動，一時之間會場裡群情嘩然，都在問發生了什麼事，但是一發現美岬處在事件的中心，大家就都失去興趣了。",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00229",
