		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1437", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Oh, then why don’t you join FS? We’d welcome you. You’re so strong. Not as strong as me though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“啊，那要加入FS吗？奈奈濑酱的话我们很欢迎喔。虽然比不上我，但是奈奈濑酱也很强嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「啊，那要加入FS嗎？奈奈瀨醬的話我們很歡迎喔。雖然比不上我，但是奈奈瀨醬也很強嘛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00041",
		linknext = "0078_00043",
		line = 742,
	},
	["0078_00043"] = {
