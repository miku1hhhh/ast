					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yo yo! You two are the star of the show tonight! Why the long face? Let me see your party face! Your Misaki face!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“嘿嘿──，两位可以说是今天的主角，情绪会不会太低落了一点啊！？你们有干劲吗──！有精神吗──！？有美岬吗──！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嘿嘿──，兩位可以說是今天的主角，情緒會不會太低落了一點啊！？你們有幹勁嗎──！有精神嗎──！？有美岬嗎──！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00191",
		linknext = "0078_00193",
		line = 3159,
	},
	["0078_00193"] = {
