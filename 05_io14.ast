	["0078_00280"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1476", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“If it was the other way around, like if you were going out with another girl, I wouldn’t be able to congratulate you like that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“如果立场相反……如果亲爱的，跟其他人交往了的话。我肯定没办法像那样老实地祝福你们吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「如果立場相反……如果親愛的，跟其他人交往了的話。我肯定沒辦法像那樣老實地祝福你們吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00279",
		linknext = "0078_00281",
		line = 4548,
	},
	["0078_00281"] = {
