		{"fgact", ch="凛14", id=14, act="浮遊", loop=2, size=5, time=75, ease="easeinout_sine"},
		{"se", id=0, loop=0, file="se_a098"},
		{"text"},
		delay = {
			[600] = {
				{"fg", file="rin_01l_00002", file1="rin_01l_00102", file2="rin_01l_00222", path=":fg/rin_01l/", id=14, lv=14, head="rin_01l", ch_origin="凛", ch="凛14", mw="mw", sync=0, timestamp=84, delay2=600, mode=3, x=-5, y=-5},
			},
			[599] = {
				{"transitiontime", time=300, timestamp=84, delay2=600},
			},
		},
		text = {
			vo = {
				{"vo", file="rin0265", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Wait a second! What the hell?! I’m an intelligent, beautiful woman from an elite family, and I’ve been chosen by God! Why would I make some discriminatory comments like some uneducated delinquents?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“等一下啦！这是怎么回事！？出生在菁英的家系、才貌双全、堪称被神明选中的本小姐怎么可能会像那些毫无学养的弱智一样说出歧视言论！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「等一下啦！這是怎麼回事！？出生在菁英的家系、才貌雙全、堪稱被神明選中的本小姐怎麼可能會像那些毫無學養的弱智一樣說出歧視言論！」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00595",
		linknext = "0078_00597",
		line = 8629,
	},
	["0078_00597"] = {
		{"fg", file="rin_01l_00002", file1="rin_01l_00101", file3="rin_01l_00318", path=":fg/rin_01l/", id=14, lv=14, head="rin_01l", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="凛14", id=14, act="振動下", loop=2, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[2700] = {
				{"fg", file="rin_01l_00002", file1="rin_01l_00101", file2="rin_01l_00222", path=":fg/rin_01l/", id=14, lv=14, head="rin_01l", ch_origin="凛", ch="凛14", mw="mw", sync=0, timestamp=85, delay2=2700, mode=3, x=-5, y=-5},
			},
			[2699] = {
				{"transitiontime", time=300, timestamp=85, delay2=2700},
			},
		},
		text = {
			vo = {
				{"vo", file="rin0266", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Hey, don’t ignore me! What’s the big idea?! So, assuming that I did make those comments, you’re saying it’s okay to treat me however you want?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“啊、不准无视我！不然假设我真的有歧视言论好了！你们是想说对这种人想怎么样都可以吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「啊、不準無視我！不然假設我真的有歧視言論好了！你們是想說對這種人想怎麼樣都可以嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00596",
		linknext = "0078_00598",
		line = 8648,
