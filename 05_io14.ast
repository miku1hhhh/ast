	["0078_00276"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00101", file3="ikuko_01m_00313", path=":fg/ikuko_01m/", id=10, lv=9, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1475", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I might sound sarcastic saying it, but... Being able to congratulate your friend that you liked but ended up hooking up with another girl is just like... wow.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“这听起来或许有点像风凉话……可是喜欢的人有了恋人，却还能祝福人家……我觉得真的很厉害。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「這聽起來或許有點像風涼話……可是喜歡的人有了戀人，卻還能祝福人家……我覺得真的很厲害。」",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00275",
		linknext = "0078_00277",
		line = 4506,
	},
	["0078_00277"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I recall the events at World B.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我回想在B世界发生的种种。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我回想在B世界發生的種種。",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00276",
		linknext = "0078_00278",
		line = 4516,
	},
	["0078_00278"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In her very first eroge she played, Ikuko supported the female character who was not chosen in the end.",
					{"rt2"},
				},
			},
			cn = {
				{
					"第一次玩色情游戏的郁子，微妙地更支持那些没有被选上的女角。",
					{"rt2"},
				},
			},
			tw = {
				{
					"第一次玩色情遊戲的郁子，微妙地更支持那些沒有被選上的女角。",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00277",
		linknext = "0078_00279",
		line = 4526,
	},
	["0078_00279"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe she’s putting herself in that character’s place over what happened.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说不定──她是把游戏里的情境，跟现在的状况重合了吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說不定──她是把遊戲裡的情境，跟現在的狀況重合了吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0078_00278",
