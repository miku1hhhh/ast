		text = {
			vo = {
				{"vo", file="ikuko1469", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“No you didn’t. You go back doing magic tricks. Misaki, you all right? You ran towards me all of a sudden.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“没人叫你喔──。你可以回去继续变魔术了──。美岬酱不要紧吗？谁叫你突然扑上来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「沒人叫妳喔──。妳可以回去繼續變魔術了──。美岬醬不要緊嗎？誰叫妳突然撲上來。」",
					{"rt2"},
				},
			},
		},
