		{"text"},
		text = {
			vo = {
				{"vo", file="rei1198", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼", "ハメドレイくん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Hamedo-Rei"},
					"“Hame! What a miserable bunch of bird-brains we have here! Listen up! I bet you maggots think you’re real Hamedoris.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼", "Hame奴隶君"},
					"“Hame！还真是每一个都一脸呆相啊啪啪！听好了hame！你们似乎误以为自己是Hamedori君啪啪──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "Hame奴隸君"},
					"「Hame！還真是每一個都一臉呆相啊啪啪！聽好了hame！你們似乎誤以為自己是Hamedori君啪啪──」",
					{"rt2"},
				},
			},
		},
