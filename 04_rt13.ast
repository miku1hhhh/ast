		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Who would’ve thought being a spoiled brat would give you that kind of talent...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“撒娇鬼到了这种地步已经算是一种才能了呢……”",
