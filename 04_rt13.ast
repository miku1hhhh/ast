			ja = {
				{
					name = {"礼", "ハメドレイくん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Hamedo-Rei"},
					"“Well you’re not! You’re imitations! Fakes! Sham-edoris! Your Latin name is Birdus Incorrectus!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼", "Hame奴隶君"},
					"“但是要我来说的话，你们只是虚假的Hamedori君──冒牌dori君hame！用学名来说的话就是Ashinagashikopako Hametariandorymodoki（长足干不停属拟相干鸟）啪啪！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "Hame奴隸君"},
					"「但是要我來說的話，你們只是虛假的Hamedori君──冒牌dori君hame！用學名來說的話就是Ashinagashikopako Hametariandorymodoki（長足幹不停屬擬相幹鳥）啪啪！！」",
					{"rt2"},
				},
			},
		},
