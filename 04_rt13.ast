				},
			},
			tw = {
				{
					name = {"水引", "原創Hamedori君"},
					"「對我而言，說到飛機杯就是橘君的作品了嘛。橘君的飛機杯──不論是我的前面和後面都包裹住了喔？」",
					{"rt2"},
				},
			},
		},
