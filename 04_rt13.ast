			ja = {
				{
					name = {"礼", "ハメドレイくん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Hamedo-Rei"},
					"“You haven’t done anything worth crowing about just yet! You’re just standing in line like birds on a wire! When I’m done with you, you’ll be moaning and panting like pros!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼", "Hame奴隶君"},
					"“现在的你们只不过是一群臭鸟刚好凑到一起，也就是乌合之众啪啪！等到这场训练结束之后，才能真正成为娇喘声够吓人的呜齁之众hame！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "Hame奴隸君"},
					"「現在的你們只不過是一群臭鳥剛好湊到一起，也就是烏合之眾啪啪！等到這場訓練結束之後，才能真正成為嬌喘聲夠嚇人的嗚齁之眾hame！」",
					{"rt2"},
				},
			},
		},
