			ja = {
				{
					name = {"麻沙音", "アサドリくん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asadori"},
					"“I thought Nanase was asking me to supervise some kind of mass orgy and I thought damn that sounds cool so I obviously accepted...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音", "麻沙dori君"},
					"“不，只是因为奈奈濑姐跟我说了大量的Hamedori如何如何的，问我要不要参加活动，我想说‘那是啥也太棒了吧’就迫不及待地答应了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音", "麻沙dori君"},
					"「不，只是因為奈奈瀨姊跟我說了大量的Hamedori如何如何的，問我要不要參加活動，我想說『那是啥也太棒了吧』就迫不及待地答應了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00020",
		linknext = "0069_00022",
		line = 282,
	},
	["0069_00022"] = {
