					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It’s rare to see you getting involved with an event.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是……还真是难得啊。麻沙酱居然会参加这种活动。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是……還真是難得啊。麻沙醬居然會參加這種活動。」",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00019",
		linknext = "0069_00021",
		line = 269,
	},
	["0069_00021"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", file2="asane_01f_00209", path=":fg/asane_01f/", id=30, ch="麻沙音", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
