				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「撒嬌鬼到了這種地步已經算是一種才能了呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00017",
		linknext = "0069_00019",
		line = 247,
	},
	["0069_00019"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The Asane in World B knew that I had been switched, so I’m not being entirely flippant here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"实际上B世界的麻沙音也马上就注意到我交换了，所以搞不好还真不是胡诌的呢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"實際上B世界的麻沙音也馬上就注意到我交換了，所以搞不好還真不是胡謅的呢。",
					{"rt2"},
				},
			},
		},
		linkback = "0069_00018",
		linknext = "0069_00020",
		line = 257,
	},
	["0069_00020"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
