			en = {
				{
					name = {"水引", "Origin Hamedori"},
					"“Your sex sleeves are on another level to anyone else’s! They’ve got me fully covered—literally! Party in the front, business in the back!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引", "原创Hamedori君"},
					"“对我而言，说到飞机杯就是橘君的作品了嘛。橘君的飞机杯──不论是我的前面和后面都包裹住了喔？”",
