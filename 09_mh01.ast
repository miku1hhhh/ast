			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I can’t stand it when they think a good story lets them off the hook for the erotic part. It’s like #2 on my unforgivable list, after you, chubbers!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“有剧情然后色情要素少一点也没关系吧？遇上那种色情游戏的话，除了畔大不原谅外，我也是不会原谅的⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「有劇情然後色情要素少一點也沒關係吧？遇上那種色情遊戲的話，除了畔大不原諒外，我也是不會原諒的⋯⋯！」",
					{"rt2"},
				},
			},
		},
