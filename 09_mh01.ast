	["0101_00143"] = {
		{"bgm", file="bgm21", vol=100},
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=6},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The eroge she bought with our parents inheritance money based on the cover art ended up not being a nukige. She still hasn’t gotten over that trauma.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙酱呢，是因为有拿父母留下的遗产买那种只看标题的色情游戏，结果发现不是拔作，所以很受伤的过去⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙醬呢，是因為有拿父母留下的遺產買那種只看標題的色情遊戲，結果發現不是拔作，所以很受傷的過去⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0101_00142",
		linknext = "0101_00144",
		line = 2009,
	},
	["0101_00144"] = {
		{"fg", file="misaki_02l_00001", file1="misaki_02l_00102", file2="misaki_02l_00215", path=":fg/misaki_02l/", id=6, lv=6, head="misaki_02l", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
