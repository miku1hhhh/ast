			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You’re kidding... My parents died when I was young, I got kidnapped by yakuza, and now Misaki’s gonna be my sister? What the hell sort of crap life is this?”",
					{"rt2"},
				},
			},
			cn = {
				{
