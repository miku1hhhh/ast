	["0101_00056"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I thought I’d be ready to emancipate my load any moment, but Lady Liberty doesn’t smile on me this day.",
					{"rt2"},
				},
			},
			cn = {
				{
					"以为快要射了，结果还是没办法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"以為快要射了，結果還是沒辦法。",
					{"rt2"},
				},
			},
		},
		linkback = "0101_00055",
		linknext = "0101_00057",
		line = 703,
	},
	["0101_00057"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The island has continued to go through big changes with the perverted law done for. But as always, I’m unable to get off without Misaki.",
					{"rt2"},
				},
			},
			cn = {
				{
					"变态条例没了以后，岛有了很大的改变──但不变的是，只有美岬能让我射出来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"變態條例沒了以後，島有了很大的改變──但不變的是，只有美岬能讓我射出來。",
					{"rt2"},
				},
			},
		},
		linkback = "0101_00056",
		linknext = "0101_00058",
		line = 713,
	},
	["0101_00058"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There’s no mistaking it. I’m in love with her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不用说那是因为我爱着美岬。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不用說那是因為我愛著美岬。",
					{"rt2"},
				},
			},
		},
		linkback = "0101_00057",
		linknext = "0101_00059",
