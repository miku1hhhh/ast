			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Although, I do actually enjoy it when the erotic part comes out of nowhere right after a slice-of-life scene and blows past the whole getting-there part like there’s some sex scene quota to meet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊，不过那种不走这过程，就像是交功课一样，日常画面下展开色情的那种的话，我是还蛮喜欢的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊，不過那種不走這過程，就像是交功課一樣，日常畫面下展開色情的那種的話，我是還蠻喜歡的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0101_00139",
		linknext = "0101_00141",
		line = 1971,
	},
	["0101_00141"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My lil’ sis always gets grouchy over romance games for general audiences getting converted into eroge.",
					{"rt2"},
				},
			},
			cn = {
				{
					"抱怨这么多，我妹说到底只要一般类型的纯爱游戏，稍稍添加色情因素的话，就会瞬间喜欢上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"抱怨這麼多，我妹說到底只要一般類型的純愛遊戲，稍稍添加色情因素的話，就會瞬間喜歡上。",
					{"rt2"},
				},
			},
		},
