	["0101_00145"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00224", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=6},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She got so pissed, she flooded the message boards with rage-posts about how crap the sex was and how the fans were creepy. Then the hivemind turned her scathing reviews into a copypasta.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而且更惨的是‘色情是屁，粉丝毛没长齐，官方很恶烂。恶屁孩的烂3K’有志一同都是一样内容到处挪用，内容只是复制贴上再修改一下而已⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而且更慘的是『色情是屁，粉絲毛沒長齊，官方很噁爛。噁屁孩的爛3K』有志一同都是一樣內容到處挪用，內容只是複製貼上再修改一下而已⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0101_00144",
		linknext = "0101_00146",
		line = 2036,
	},
	["0101_00146"] = {
