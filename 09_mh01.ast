					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Despite its eroge status, it starts out looking safe for all ages, but then BAM—ero scene. Are you kidding me?! Do you even know what an eroge is, Bro?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“明明就是色情游戏，一开始设定什么所有年龄层皆适用，带入那些随便的色情场景，未免也太搞笑！干脆别说自己是色情游戏！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「明明就是色情遊戲，一開始設定什麼所有年齡層皆適用，帶入那些隨便的色情場景，未免也太搞笑！乾脆別說自己是色情遊戲！」",
					{"rt2"},
				},
			},
		},
