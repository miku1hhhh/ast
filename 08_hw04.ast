		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It looks a bit off from the sample picture, but nothing to make a fuss about.",
					{"rt2"},
				},
			},
			cn = {
				{
					"的确是长跟样品图上有点不太一样，不过我也不是特别在意这种事。",
