	["0099_00674"] = {
		{"fg", file="hinami_01l_00003", file1="hinami_01l_00104", file2="hinami_01l_00206", path=":fg/hinami_01l/", id=5, lv=5, head="hinami_01l", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0896", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I’m sorry, Jun. This was supposed to be a fun date, and I put you through all this trouble...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯⋯⋯对不起啊淳君⋯⋯明明是难得开心的约会⋯⋯结果给你添麻烦了⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯⋯⋯對不起啊淳君⋯⋯明明是難得開心的約會⋯⋯結果給你添麻煩了⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00673",
		linknext = "0099_00675",
		line = 9368,
	},
	["0099_00675"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file3="jun_01f_00309", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Are you crazy? If that’s all it takes for you to apologize to me, then God knows how many times I need to apologize to you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你在说什么啊。要是你为了这种事道歉，那我不知道都要跟雏见你道歉多少次了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳在說什麼啊。要是妳為了這種事道歉，那我不知道都要跟雛見妳道歉多少次了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00674",
		linknext = "0099_00676",
		line = 9380,
	},
	["0099_00676"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We’re looking up how to treat you, so get some rest for now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我现在去看看有什么应急措施，你别急。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我現在去看看有什麼應急措施，妳別急。」",
					{"rt2"},
				},
			},
		},
