	["0099_00758"] = {
		{"fg", file="hinami_01l_00003", file1="hinami_01l_00103", file2="hinami_01l_00206", path=":fg/hinami_01l/", id=5, lv=5, head="hinami_01l", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0914", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Your mind becomes unstable. Every little thing will bother you, you’ll get mad over little things, you begin hating things you used to like...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“像是心情变得不稳定之类的。会在意琐碎的小事情、容易就生气了，或是一直都喜欢的东西突然就讨厌了起来……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「像是心情變得不穩定之類的。會在意瑣碎的小事情、容易就生氣了，或是一直都喜歡的東西突然就討厭了起來……」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00757",
		linknext = "0099_00759",
		line = 10593,
	},
	["0099_00759"] = {
		{"fg", file="hinami_01l_00003", file1="hinami_01l_00103", file2="hinami_01l_00210", path=":fg/hinami_01l/", id=5, lv=5, head="hinami_01l", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0915", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“And it can lead to getting into fights with your partner. So... it’s kinda weird to say it now, but... I was worried.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“所以夫妻吵架的事情会经常发生……虽然现在就说这些话是挺奇怪的……但我很担心。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「所以夫妻吵架的事情會經常發生……雖然現在就說這些話是挺奇怪的……但我很擔心。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00758",
		linknext = "0099_00760",
		line = 10608,
	},
	["0099_00760"] = {
