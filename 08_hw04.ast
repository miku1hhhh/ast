				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah... I’m fine now. Thanks.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯⋯⋯已经不要紧了，谢谢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯⋯⋯已經不要緊了，謝謝。」",
