	["0099_00608"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hinami’s gotten really into it, having always been wanting to be a mother and all. She’s always enthusiastic in the role, even outside of sex.",
					{"rt2"},
				},
			},
			cn = {
				{
					"渴望成为人母的雏见好像完全陷入其中，每天都积极的在玩着无情色的扮演游戏。",
					{"rt2"},
				},
			},
			tw = {
				{
					"渴望成為人母的雛見好像完全陷入其中，每天都積極的在玩著無情色的扮演遊戲。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00607",
		linknext = "0099_00609",
		line = 8342,
	},
	["0099_00609"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I personally don’t mind being Hinami’s baby either. In fact, I love it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不认为成为雏见的小宝宝是件坏事──倒不如说棒透了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不認為成為雛見的小寶寶是件壞事──倒不如說棒透了。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00608",
