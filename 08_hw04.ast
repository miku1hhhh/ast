	["0099_00061"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But the book I read said that although the man has to take the lead on a date, he also has to let the girl do what she wants to do.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过──书上写着，在约会的时候，即使男生主导，也要以女朋友想做的事为最优先。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過──書上寫著，在約會的時候，即使男生主導，也要以女朋友想做的事為最優先。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00060",
		linknext = "0099_00062",
		line = 790,
	},
	["0099_00062"] = {
