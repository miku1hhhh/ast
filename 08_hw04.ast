			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Listen to yourself man... Look who’s ridiculous here. Besides, if you tell me to enter into a threesome while role-playing as a baby, how the hell am I supposed to determine my position?”",
					{"rt2"},
				},
			},
			cn = {
