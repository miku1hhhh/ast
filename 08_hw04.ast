			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I... I guess that wasn’t good advice after all. I mean, I’d like to walk beside you, eat a hearty meal, and more... hehe...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“总觉得，效果不太好啊⋯⋯毕竟我还是想要走在淳君的旁边、吃很多东西的说⋯⋯啊哈哈⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「總覺得，效果不太好啊⋯⋯畢竟我還是想要走在淳君的旁邊、吃很多東西的說⋯⋯啊哈哈⋯⋯」",
					{"rt2"},
				},
			},
		},
