	},
	["0099_00113"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She really is running around all over helping out her people.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没想到她会连这种地步都想到还特地关照──真是个为后辈着想的好人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒想到她會連這種地步都想到還特地關照──真是個為後輩著想的好人。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00112",
		linknext = "0099_00114",
		line = 1526,
	},
	["0099_00114"] = {
