					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Yes, immediately after the perverted sex law was abandoned. It seems that there was some outside influence that wanted to see it gone.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“是的，就在变态条例瓦解前不久⋯⋯似乎之前被施加了不明的压力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「是的，就在變態條例瓦解前不久⋯⋯似乎之前被施加了不明的壓力。」",
					{"rt2"},
				},
			},
		},
