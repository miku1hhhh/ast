	["0099_00168"] = {
		{"fg", file="hinami_02l_00002", file1="hinami_02l_00104", file2="hinami_02l_00222", path=":fg/hinami_02l/", id=5, lv=5, head="hinami_02l", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=95, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0764", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“U-um... I’ve also been asking the internet about... how to be a good girlfriend, and... it said things like walk behind your man, order only tofu, and...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我、我也一样⋯⋯想要当一个好女友，所以在网络上查很了多资料⋯⋯所以才做了像是跟在你后面、还有只点了豆腐的事⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我、我也一樣⋯⋯想要當一個好女友，所以在網路上查很了多資料⋯⋯所以才做了像是跟在你後面、還有只點了豆腐的事⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00167",
		linknext = "0099_00169",
		line = 2301,
	},
	["0099_00169"] = {
		{"fg", file="hinami_02l_00002", file1="hinami_02l_00104", file3="hinami_02l_00309", path=":fg/hinami_02l/", id=5, lv=5, head="hinami_02l", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=95, y=-5},
		{"transitiontime", time=300},
		{"text"},
