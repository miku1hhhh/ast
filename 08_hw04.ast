	["0099_00754"] = {
		{"fg", file="hinami_02l_00003", file1="hinami_02l_00105", file2="hinami_02l_00229", path=":fg/hinami_02l/", id=5, lv=5, head="hinami_02l", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=-5, y=-5},
