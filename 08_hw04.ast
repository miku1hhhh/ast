	["0099_00738"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0908", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I thought I’d be fine since I took my usual pill, but I started to feel a little sick when I got home.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我吃的是平时的药，所以还以为没问题的说⋯⋯不过回来的时候，我就有点不太舒服了⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我吃的是平時的藥，所以還以為沒問題的說⋯⋯不過回來的時候，我就有點不太舒服了⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00737",
		linknext = "0099_00739",
		line = 10349,
	},
	["0099_00739"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00206", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这、这样啊⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這、這樣啊⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00738",
		linknext = "0099_00740",
		line = 10361,
	},
	["0099_00740"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I had no idea... and during that time all I did was call her mommy...",
					{"rt2"},
				},
			},
			cn = {
				{
					"没有注意到这一点，我还要雏见扮演妈妈的角色。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒有注意到這一點，我還要雛見扮演媽媽的角色。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00739",
		linknext = "0099_00741",
		line = 10371,
	},
	["0099_00741"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0909", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I never had this happened to me before. Maybe it’s because I stopped taking the Seiran Island pill.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“但是我之前从来没有这样子过⋯⋯搞不好是因为我没有吃青蓝岛给的避孕药才这样的⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「但是我之前從來沒有這樣子過⋯⋯搞不好是因為我沒有吃青藍島給的避孕藥才這樣的⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00740",
		linknext = "0099_00742",
		line = 10383,
	},
	["0099_00742"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ever since the sex law was crushed, the pill that all the women on the island were taking is no longer distributed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"变态条例瓦解之后，岛上的女性们一直在吃的避孕药就没有给付了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"變態條例瓦解之後，島上的女性們一直在吃的避孕藥就沒有給付了。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00741",
		linknext = "0099_00743",
		line = 10393,
	},
	["0099_00743"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The whole point of the pill was of course to prevent unwanted pregnancies, but it also had the effect of controlling your hormones.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当初给予给付的原因当然是为了防止意外怀孕──不过避孕药也有调整荷尔蒙的作用在。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當初給予給付的原因當然是為了防止意外懷孕──不過避孕藥也有調整荷爾蒙的作用在。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00742",
		linknext = "0099_00744",
		line = 10403,
	},
	["0099_00744"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asa once got sick from having a bad period, but maybe it was partly because the island’s pill was having bad effects on her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"之前麻沙酱也有过生理期来就身体不舒服的情况──现在回想起来，那大概也有一部份原因是因为她跟岛上给的避孕药不合吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"之前麻沙醬也有過生理期來就身體不舒服的情況──現在回想起來，那大概也有一部份原因是因為她跟島上給的避孕藥不合吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00743",
		linknext = "0099_00745",
		line = 10413,
	},
	["0099_00745"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And for some people, stopping taking the pill can also have adverse effects on their health.",
					{"rt2"},
				},
			},
			cn = {
				{
					"反过来说，一直在吃那款药的人突然不吃了，身体会有大大小小的毛病出现也是很正常的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"反過來說，一直在吃那款藥的人突然不吃了，身體會有大大小小的毛病出現也是很正常的。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00744",
		linknext = "0099_00746",
		line = 10423,
	},
	["0099_00746"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hinami happened to be one of those cases.",
					{"rt2"},
				},
			},
			cn = {
				{
					"雏见大概就是这么一回事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雛見大概就是這麼一回事。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00745",
		linknext = "0099_00747",
		line = 10433,
	},
	["0099_00747"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00220", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I’m sorry, Hinami. I should’ve known.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对不起，雏见⋯⋯我都没注意到。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對不起，雛見⋯⋯我都沒注意到。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00746",
		linknext = "0099_00748",
		line = 10445,
	},
	["0099_00748"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Many things are changing on this island with the sex law being gone.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从条例解除开始，这座岛上的许多事都发生了变化。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從條例解除開始，這座島上的許多事都發生了變化。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00747",
		linknext = "0099_00749",
		line = 10455,
	},
	["0099_00749"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As the man who started the process of the abolishing of the sex law, I should be the one changing more than anyone else, but...",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算是我这个制造契机来改变岛屿得当事人，也必须做出改变，但在这种情况下────",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算是我這個製造契機來改變島嶼得當事人，也必須做出改變，但在這種情況下────",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00748",
		linknext = "0099_00750",
		line = 10465,
	},
	["0099_00750"] = {
