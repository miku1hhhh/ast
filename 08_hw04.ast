	["0099_00010"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Why all this hassle? Because today I’m out on a date with Hinami.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我想要隐藏什么──因为今天是我和雏见的约会。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我想要隱藏什麼──因為今天是我和雛見的約會。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00009",
