	["0099_00288"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I was worried what would happen with the sex law completely abolished, but it’s nice to see that everyone seems to be doing just fine.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我很常担心条例被废除之后会怎样──看到同学们过得不错，我终于松了口气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我很常擔心條例被廢除之後會怎樣──看到同學們過得不錯，我終於鬆了口氣。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00287",
		linknext = "0099_00289",
		line = 4105,
	},
	["0099_00289"] = {
