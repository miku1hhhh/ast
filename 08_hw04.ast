	["0099_00164"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00206", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You see, I’ve been doing some research about how to be a cool boyfriend...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“其实⋯⋯我为了表现得像个帅气的男朋友，做了很多研究⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「其實⋯⋯我為了表現得像個帥氣的男朋友，做了很多研究⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00163",
		linknext = "0099_00165",
		line = 2249,
	},
	["0099_00165"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00220", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And one tip said that I should be eating at the same pace as my partner, so I tried, and...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“里面就有一条是要配合女朋友吃饭的节奏，所以我就照做了⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「裡面就有一條是要配合女朋友吃飯的節奏，所以我就照做了⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00164",
		linknext = "0099_00166",
		line = 2261,
	},
	["0099_00166"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=5},
