		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’ve never had a friend say something like that to me. Kinda embarrassing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被同性友人问这样的问题还是第一次──总觉得有点怪尴尬的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被同性友人問這樣的問題還是第一次──總覺得有點怪尷尬的。",
					{"rt2"},
				},
			},
		},
