			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Don’t worry about it. I didn’t tell you, so there was no way for you to know.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“没事的……因为我没说，没有注意到也是理所当然啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「沒事的……因為我沒說，沒有注意到也是理所當然啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00749",
		linknext = "0099_00751",
