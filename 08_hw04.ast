		line = 132,
	},
	["0099_00011"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We’ve never been on a real outing since we began dating.",
					{"rt2"},
				},
			},
			cn = {
				{
					"回想起来，从交往到现在，我们都没有在外面约会过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"回想起來，從交往到現在，我們都沒有在外面約會過。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00010",
		linknext = "0099_00012",
		line = 142,
	},
	["0099_00012"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Most of the time we just hang out around the house, and when we do go somewhere, it’s usually with friends like the NLNS or Rei.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大多时间里，我们都是在家里耍废，出去外面玩多半都是跟NLNS或礼前辈一起。",
