			[4999] = {
				{"transitiontime", time=300, timestamp=29, delay2=5000},
			},
		},
		text = {
			vo = {
				{"vo", file="susuko0572", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Hehe, it’s my gesture of gratitude to Tachi for all that he’s done for me. I’m a considerate junior, you see.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“嘻嘻嘻。之前受了橘同学的照顾，所以这个是我请你们的。不才在下可是个有心的后辈喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「嘻嘻嘻。之前受了橘同學的照顧，所以這個是我請你們的。不才在下可是個有心的後輩喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00176",
		linknext = "0099_00178",
		line = 2433,
	},
	["0099_00178"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Do you have to come up with weird names to call me every time?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你的自称跟称别人的方式也固定一点行吗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳的自稱跟稱別人的方式也固定一點行嗎。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00177",
		linknext = "0099_00179",
		line = 2445,
	},
	["0099_00179"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00217", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0573", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“What do you mean, Tach? I’ve always called you Tachibana. Get your head on straight, Mr. T.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“讨厌啦辈前。人家的自称是‘我’啊，丝丝子我不是一直都这么说的吗──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「討厭啦輩前。人家的自稱是『我』啊，絲絲子我不是一直都這麼說的嗎──」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00178",
		linknext = "0099_00180",
		line = 2460,
	},
	["0099_00180"] = {
