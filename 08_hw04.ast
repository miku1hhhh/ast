				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“To be specific, your cuteness is so off the charts it is literally a work of God that no artist in the whole wide world could recreate.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“要打比方的话，大概就是把东西两方由古至今的艺术家都聚集起来也没办法具体描绘出的那种神之造物，这么说再适合不过了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「要打比方的話，大概就是把東西兩方由古至今的藝術家都聚集起來也沒辦法具體描繪出的那種神之造物，這麼說再適合不過了。」",
					{"rt2"},
				},
			},
		},
