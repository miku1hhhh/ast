	["0099_00160"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The whole point of eating fast was so she doesn’t have to worry about me, but instead I’ve gotten her all worried.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我因为不想让她担心所以拼命地大口疾吃，反而让她为我担心了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我因為不想讓她擔心所以拚命地大口疾吃，反而讓她為我擔心了。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00159",
		linknext = "0099_00161",
		line = 2200,
	},
	["0099_00161"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What was I thinking?",
					{"rt2"},
				},
			},
			cn = {
				{
					"啊，对。我──",
					{"rt2"},
				},
			},
			tw = {
				{
					"啊，對。我──",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00160",
		linknext = "0099_00162",
		line = 2210,
	},
	["0099_00162"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00208", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I’m such a fool! I was so caught up in trying to act like a gentleman, I lost my original and my most important mission: to have fun with Hinami like always.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我是⋯⋯笨蛋⋯⋯！我都忘了，比起表现得像个好男人，像平常那样更能让雏见开心啊⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我是⋯⋯笨蛋⋯⋯！我都忘了，比起表現得像個好男人，像平常那樣更能讓雛見開心啊⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00161",
		linknext = "0099_00163",
		line = 2222,
	},
	["0099_00163"] = {
		{"fg", file="hinami_02l_00002", file1="hinami_02l_00101", file2="hinami_02l_00212", path=":fg/hinami_02l/", id=5, lv=5, head="hinami_02l", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=95, y=-5},
		{"transitiontime", time=300},
		{"text"},
