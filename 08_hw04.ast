		{"fg", file="hinami_01l_00003", file1="hinami_01l_00103", file3="hinami_01l_00309", path=":fg/hinami_01l/", id=5, lv=5, head="hinami_01l", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"extrans", sync=0, time=1500},
		{"ex", time=500, func="wait"},
		{"text"},
		text = {
