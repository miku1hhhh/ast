	["0099_00679"] = {
		{"fg", file="asane_02m_00003", file1="asane_02m_00102", file2="asane_02m_00221", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1333", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I found something! If you place cabbage over her head the alkaline substance goes into her body and absorbs the toxins and blood that turned acidic from the fever!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“有个不错的喔哥哥……！如果把卷心菜放在头上那卷心菜的碱性会渗透到体内并吸收血液中因发热而变成酸性的毒素！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「有個不錯的喔哥哥……！如果把高麗菜放在頭上那高麗菜的鹼性會滲透到體內並吸收血液中因發熱而變成酸性的毒素！」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00678",
		linknext = "0099_00680",
		line = 9480,
	},
	["0099_00680"] = {
