		text = {
			vo = {
				{"vo", file="schubert0392", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Certainly suits me right now. Hehehe... I made it exactly according to the manual, yet it resembles nothing in my data. Crepe making is so fascinating!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“是很适合现在的我的名字呢。呵呵呵⋯⋯不过，这个可丽饼可不是按照SOP做的喔，是我的资料库上没有的东西。这也是做可丽饼的乐趣所在之处！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「是很適合現在的我的名字呢。呵呵呵⋯⋯不過，這個可麗餅可不是按照SOP做的喔，是我的資料庫上沒有的東西。這也是做可麗餅的樂趣所在之處！」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00284",
		linknext = "0099_00286",
		line = 4073,
	},
	["0099_00286"] = {
