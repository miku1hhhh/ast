		},
		text = {
			vo = {
				{"vo", file="schubert0385", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Precisely. Many people come here, and that means lots of data that I can collect. Are you on a date with your girlfriend, Pussybana?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“您真是观察仔细。这里来往的人形形色色，能收集到很多的数据所以也很有趣喔。橘猫同学今天是跟可爱的女朋友来约会的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「您真是觀察仔細。這裡來往的人形形色色，能收集到很多的數據所以也很有趣喔。橘貓同學今天是跟可愛的女朋友來約會的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00261",
		linknext = "0099_00263",
		line = 3672,
	},
	["0099_00263"] = {
