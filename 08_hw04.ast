				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸嘿嘿。雖然常常路過遊樂園，不過我都沒來玩過呢。接下來要玩什麼好呢？」",
					{"rt2"},
				},
