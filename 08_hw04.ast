				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yeah... I didn’t want bad things to happen to you, nor did I want you to hate me, but...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯……我不想让淳君感到厌烦，更不想要被讨厌，所以是这么想的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯……我不想讓淳君感到厭煩，更不想要被討厭，所以是這麼想的……」",
					{"rt2"},
				},
			},
		},
