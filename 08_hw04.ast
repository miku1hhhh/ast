					"“Mmhmm! This is great! The sweet cream with the salty-sweet strawberry is making me melt away.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯嗯！好好吃喔，甜甜的奶油跟草莓的酸甜感，感觉像是恋爱了一样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯嗯！好好吃喔，甜甜的奶油跟草莓的酸甜感，感覺像是戀愛了一樣。」",
					{"rt2"},
				},
			},
		},
