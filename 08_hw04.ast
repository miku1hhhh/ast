		{"transitiontime", time=300},
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00212", path=":fg/jun_01f/", id=30, ch="淳之介", lv=3, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asa! Did you find out anything yet?!”",
