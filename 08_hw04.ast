		text = {
			vo = {
				{"vo", file="susuko0563", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Wassup! Let me take your order... wait, what’s ’Bana and the chair girl doing here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“你好！要点餐了吗──这不是橘同学跟椅子酱吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「你好！要點餐了嗎──這不是橘同學跟椅子醬嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00108",
		linknext = "0099_00110",
		line = 1473,
	},
	["0099_00110"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00219", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Susuko, you work here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“丝丝子。你在这里上班吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「絲絲子。妳在這裡上班嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00109",
		linknext = "0099_00111",
		line = 1485,
	},
	["0099_00111"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00202", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="スス子11", id=11, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[6800] = {
				{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00207", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, timestamp=18, delay2=6800, mode=3, x=-5, y=-5},
			},
			[6799] = {
				{"transitiontime", time=300, timestamp=18, delay2=6800},
			},
		},
		text = {
			vo = {
				{"vo", file="susuko0564", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Yup, that’s me, Susuko, working at a bunch of places with the sex law gone and my scholarship apparently being reconsidered. Don’t worry, I got all the permissions, thanks to our instructor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“没错。因为变态条例被瓦解了所以特别奖学金也飞了得要另寻出路，所以丝丝子现在正在打工喔。啊、这是有获得许可的喔。是教官安排的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「沒錯。因為變態條例被瓦解了所以特別獎學金也飛了得要另尋出路，所以絲絲子現在正在打工喔。啊、這是有獲得許可的喔。是教官安排的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00110",
		linknext = "0099_00112",
		line = 1504,
	},
	["0099_00112"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Rei did that for you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“礼前辈啊⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「禮前輩啊⋯⋯」",
