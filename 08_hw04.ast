	["0099_00734"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0906", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Having you jump around and trying to do something for me made me feel so happy. It made my heart feel so warm... and it made me feel a bit better.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“因为淳君啊……为了我慌慌张张的，说要为我做点什么而努力，真的让我很开心。开心到心都揪紧了呢……就稍微好了一点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「因為淳君啊……為了我慌慌張張的，說要為我做點什麼而努力，真的讓我很開心。開心到心都揪緊了呢……就稍微好了一點。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00733",
