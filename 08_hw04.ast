	["0099_00106"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I read that a real man only needs three cards up his sleeve to respond to whatever his partner says.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一个好男人，对恋人讲的话只要有三个反应就行了──书上是这么写的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一個好男人，對戀人講的話只要有三個反應就行了──書上是這麼寫的。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00105",
