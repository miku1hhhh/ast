					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“But when I looked it up, it said that you turn weird when you become pregnant.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不过啊⋯⋯我研究了很多资料，好像人怀孕了之后会变得很奇怪⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不過啊⋯⋯我研究了很多資料，好像人懷孕了之後會變得很奇怪⋯⋯」",
					{"rt2"},
				},
			},
		},
