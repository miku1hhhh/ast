					{"rt2"},
				},
			},
			en = {
				{
					"1: Yes, 2: Okay, and 3: Nice. That’s the only deck you’ll ever need in romance.",
					{"rt2"},
				},
			},
			cn = {
				{
					"“好”、“没错”跟“不错耶”──除了这三句之外，在谈恋爱的时候都不需要。",
					{"rt2"},
				},
			},
			tw = {
				{
					"「好」、「沒錯」跟「不錯耶」──除了這三句之外，在談戀愛的時候都不需要。",
					{"rt2"},
				},
			},
		},
