					{"rt2"},
				},
			},
			cn = {
				{
					"正因如此，几天前我才跟礼前辈商量要买什么礼物给雏见，然后拜托了奈奈濑跟女部甜中队长的──",
					{"rt2"},
				},
			},
			tw = {
				{
					"正因如此，幾天前我才跟禮前輩商量要買什麼禮物給雛見，然後拜託了奈奈瀨跟女部甜中隊長的──",
					{"rt2"},
				},
			},
		},
