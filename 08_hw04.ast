			},
		},
		text = {
			vo = {
				{"vo", file="hinami0929", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Today, I felt that I can be with you for the rest of my life, and then you gave me such a wonderful present. So let’s make this our special day.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“今天啊⋯⋯是我跟淳君一直在一起的一天⋯⋯而且淳君还送我了这么棒的礼物⋯⋯所以我们就把今天当作特别的日子怎么样？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「今天啊⋯⋯是我跟淳君一直在一起的一天⋯⋯而且淳君還送我了這麼棒的禮物⋯⋯所以我們就把今天當作特別的日子怎麼樣？」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00813",
		linknext = "0099_00815",
		line = 11294,
	},
	["0099_00815"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Making today a special day for the two of us... I would’ve never thought of such a thing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"今天对我们俩来说都是特别的一天──我从来没有想过这样的事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"今天對我們倆來說都是特別的一天──我從來沒有想過這樣的事。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00814",
		linknext = "0099_00816",
		line = 11304,
	},
	["0099_00816"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This ordinary day is going to be a special day for just the two of us every year, starting now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"丝毫没有特意之处的平凡日子，从现在开始的每一年都会成为我们的──独属于我们的，特别的日子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"絲毫沒有特意之處的平凡日子，從現在開始的每一年都會成為我們的──獨屬於我們的，特別的日子。",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00815",
		linknext = "0099_00817",
		line = 11314,
	},
	["0099_00817"] = {
