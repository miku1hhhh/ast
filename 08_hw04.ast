			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Anyhoo, have fun you two. Oh, by the way, no sex is allowed here, so if you feel like banging you’ll have to find somewhere else. Just sayin’ ’cause some people still haven’t gotten the message.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“那么，你们就好好享受吧，啊、不过本店禁止变态做爱喔，要做的话就要去能做的地方喔。现在偶尔还是有这种人喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「那麼，你們就好好享受吧，啊、不過本店禁止變態做愛喔，要做的話就要去能做的地方喔。現在偶爾還是有這種人喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0099_00180",
		linknext = "0099_00182",
		line = 2490,
	},
	["0099_00182"] = {
