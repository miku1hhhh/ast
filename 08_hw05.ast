	["0100_00048"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2276", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“What the hell was that, a tornado?! Tachibana, Hinami, you two get out of here now! I’ll handle this!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“怎么会突然有龙卷风！？橘、雏见你们快逃跑啊！让我来阻止它吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「怎麼會突然有龍捲風！？橘、雛見你們快逃跑啊！讓我來阻止它吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00047",
		linknext = "0100_00049",
		line = 632,
	},
	["0100_00049"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Who else would react like this after getting her ear blown on?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“还有戴上耳罩就会变成这样的人吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「還有戴上耳罩就會變成這樣的人嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00048",
		linknext = "0100_00050",
		line = 643,
	},
	["0100_00050"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
