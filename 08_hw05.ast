	["0100_00053"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg0201-103", x=-5, y=-2.5, path=":cg/hcg02/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=400},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0942", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“You’ve been looking tense all day. Today’s supposed to be a happy day.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“因为礼酱的脸色一直都很难看嘛⋯⋯这是个难得的大好日子耶。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「因為禮醬的臉色一直都很難看嘛⋯⋯這是個難得的大好日子耶。」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00052",
		linknext = "0100_00054",
		line = 698,
	},
	["0100_00054"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2278", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Uh... s-sorry... But you have to understand the immense pressure of having to do the opening speech!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“呃⋯⋯抱、抱歉⋯⋯不过我今天啊！因为要当致词代表所以真的压力山大⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「呃⋯⋯抱、抱歉⋯⋯不過我今天啊！因為要當致詞代表所以真的壓力山大⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00053",
		linknext = "0100_00055",
		line = 710,
	},
	["0100_00055"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg0201-101", x=-5, y=-2.5, path=":cg/hcg02/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=400},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0943", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“You’ll be fine. You had no problem talking to all those people when you were the disciplinary committee president.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“礼酱你不用担心啦！你以前当风纪委员长的时候，不是也时常在大家面前说话吗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「禮醬妳不用擔心啦！妳以前當風紀委員長的時候，不是也時常在大家面前說話嗎。」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00054",
		linknext = "0100_00056",
		line = 726,
	},
	["0100_00056"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, just let loose like you used to during our FS training.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对啊。你在训练FS的时候可是正当光明的讲了一连串淫语不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對啊。妳在訓練FS的時候可是正當光明的講了一連串淫語不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00055",
		linknext = "0100_00057",
		line = 737,
	},
	["0100_00057"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2279", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“The hell I will! You want me to ruin your wedding?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“怎么可能这样啦白痴喔！这样会把婚礼给毁了吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「怎麼可能這樣啦白癡喔！這樣會把婚禮給毀了吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00056",
		linknext = "0100_00058",
		line = 749,
	},
	["0100_00058"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, we might never be able to have a social life if something like that went viral.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“要是真的传出去的话大概就无法做人了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「要是真的傳出去的話大概就無法做人了呢。」",
					{"rt2"},
				},
