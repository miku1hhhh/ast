					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don’t worry. Just cry like a river on stage like you did during graduation. Everyone’ll get sentimental and the whole thing’ll work out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不用担心啦，礼前辈。要是你像毕业典礼那样哭起来的话，大家也会被气氛感染跟着一起哭出来的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不用擔心啦，禮前輩。要是妳像畢業典禮那樣哭起來的話，大家也會被氣氛感染跟著一起哭出來的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00061",
		linknext = "0100_00063",
		line = 810,
	},
	["0100_00063"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2281", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Don’t remind me about that! You have no idea how much it traumatized me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“喂，白痴喔现在不要跟我提这个啦！那个对我造成不小的创伤了好吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「喂，白癡喔現在不要跟我提這個啦！那個對我造成不小的創傷了好嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00062",
		linknext = "0100_00064",
		line = 822,
	},
	["0100_00064"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg0201-101", x=-5, y=-2.5, path=":cg/hcg02/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=400},
		{"text"},
		delay = {
			[9000] = {
				{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1, timestamp=2, delay2=9000},
				{"bg", id=18, file="hcg0201-104", x=-5, y=-2.5, path=":cg/hcg02/", lv=18, ev=1, timestamp=2, delay2=9000, bx=800, by=450},
			},
			[8999] = {
				{"transitiontime", time=400, timestamp=2, delay2=9000},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0945", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“It was amazing, though. I still like to rewatch it sometimes. Everyone from the FS was crying too. They were so amazed to see the drill sergeant from hell in tears like that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那真的很棒耶。我到现在偶尔都还会用电视重播来看喔。FS的大家、每个都在哭呢⋯⋯呵呵⋯⋯‘就算是鳄鱼也会流眼泪’，常常会被人这样讲呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那真的很棒耶。我到現在偶爾都還會用電視重播來看喔。FS的大家、每個都在哭呢⋯⋯呵呵⋯⋯『就算是鱷魚也會流眼淚』，常常會被人這樣講呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00063",
		linknext = "0100_00065",
		line = 842,
	},
	["0100_00065"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She gets into tears a lot when she’s with us, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过她很常在我们面前哭就是了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過她很常在我們面前哭就是了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00064",
		linknext = "0100_00066",
		line = 853,
	},
	["0100_00066"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2282", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Grr... Am I doomed to be teased like this by you two for the rest of my life?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“啧⋯⋯怎样啦，我就要一辈子被你们揶揄吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嘖⋯⋯怎樣啦，我就要一輩子被你們揶揄嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00065",
		linknext = "0100_00067",
		line = 865,
	},
	["0100_00067"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對。」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00066",
		linknext = "0100_00068",
		line = 876,
	},
	["0100_00068"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2283", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Don’t yes me! Show some respect for your superior! Don’t make me have to punish you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“对个头啦！你对上司也放尊重点！小心我更用力职场霸凌你喔！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「對個頭啦！你對上司也放尊重點！小心我更用力職場霸凌你喔！」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00067",
		linknext = "0100_00069",
		line = 888,
	},
	["0100_00069"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Superior? We’re just both in the SHO. It’s not like I’m directly working under you or anything.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就算你说你是我上司⋯⋯但我们只是同在SHO里面而已，你又不是我的直属⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就算妳說妳是我上司⋯⋯但我們只是同在SHO裡面而已，妳又不是我的直屬⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00068",
		linknext = "0100_00070",
		line = 899,
	},
	["0100_00070"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2284", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Humph, I can always have you repositioned to general affairs if I want to.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“哼，要是我想的话，我也可以把你调到总务课去喔！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「哼，要是我想的話，我也可以把你調到總務課去喔！」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00069",
		linknext = "0100_00071",
		line = 911,
	},
	["0100_00071"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Try it. If you get me out of PR then all the problems caused by Senba are gonna have to be mopped up by Ran.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你可以试看看啊⋯⋯要是我不在公关部的话，收拾仙波小姐乱来的烂摊子的责任就会全部落在兰身上喔⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳可以試看看啊⋯⋯要是我不在公關部的話，收拾仙波小姐亂來的爛攤子的責任就會全部落在蘭身上喔⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00070",
		linknext = "0100_00072",
		line = 922,
	},
	["0100_00072"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2285", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ugh... I can’t let Ran bear all that burden. Damn it, you and your dirty tricks again...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“啧⋯⋯把那个全都交给兰一个人处理的话责任太重了⋯⋯可恶，你还是一样手段很卑鄙⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嘖⋯⋯把那個全都交給蘭一個人處理的話責任太重了⋯⋯可惡，你還是一樣手段很卑鄙⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00071",
		linknext = "0100_00073",
		line = 934,
	},
	["0100_00073"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
