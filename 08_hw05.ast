				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呵呵⋯⋯真的很有禮醬的風格呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00049",
		linknext = "0100_00051",
