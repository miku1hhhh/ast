			},
			cn = {
				{
					"似乎是因为她PO了一个无限循环的网址，所以被警察来家里搜查，不过她还挺乐在其中的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"似乎是因為她PO了一個無限循環的網址，所以被警察來家裡搜查，不過她還挺樂在其中的。",
					{"rt2"},
