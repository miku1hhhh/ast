	["0100_00103"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The income from the sex technology developed with her raw skills is much more than what I make.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过，以她用天赋写出的的色情科技的收入其实比我高得多。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過，以她用天賦寫出的的色情科技的收入其實比我高得多。",
					{"rt2"},
