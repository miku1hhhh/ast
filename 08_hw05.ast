			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It’s amazing that I can’t imagine it being anything but a disaster.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真可怕，我已经有不祥的预感了。”",
