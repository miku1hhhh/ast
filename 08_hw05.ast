		line = 1314,
	},
	["0100_00105"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="hcg0201-101", x=-5, y=-2.5, path=":cg/hcg02/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=400},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0953", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Asane’s coming, and Nanase and Misaki and Fumino too, so... Wow, the whole NLNS gang is gathering again!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“有麻沙音酱⋯⋯今天奈奈濑酱跟美岬酱还有文乃酱也会来，是久违的NLNS全员集合呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「有麻沙音醬⋯⋯今天奈奈瀨醬跟美岬醬還有文乃醬也會來，是久違的NLNS全員集合呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00104",
		linknext = "0100_00106",
		line = 1330,
	},
	["0100_00106"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah... it’s been a while since I heard that name.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊⋯⋯这个名子也让人好怀念啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊⋯⋯這個名子也讓人好懷念啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00105",
		linknext = "0100_00107",
		line = 1341,
	},
	["0100_00107"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"May days have passed since I left the academy, but hearing the name NLNS makes me remember those days as clear as yesterday.",
					{"rt2"},
				},
			},
			cn = {
				{
					"尽管已经离开学校相当长的时间了，一直到如今，听到NLNS5这个名字，那时的画面都还历历在目。",
					{"rt2"},
				},
			},
			tw = {
				{
					"儘管已經離開學校相當長的時間了，一直到如今，聽到NLNS5這個名字，那時的畫面都還歷歷在目。",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00106",
		linknext = "0100_00108",
		line = 1351,
	},
	["0100_00108"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We struggled so hard to achieve our one goal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那些不顾一切，只为了一个目的持续抗战的日子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那些不顧一切，只為了一個目的持續抗戰的日子。",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00107",
		linknext = "0100_00109",
		line = 1361,
	},
	["0100_00109"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There were times we suffered so badly I wanted to just run away, but the happiness I’m experiencing now tells me that we made the right choice.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然当时也有艰难到想要逃跑的时候──不过现在回想起来，那也是另一种幸福⋯⋯我果然还是觉得，当时的选择并没有错。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然當時也有艱難到想要逃跑的時候──不過現在回想起來，那也是另一種幸福⋯⋯我果然還是覺得，當時的選擇並沒有錯。",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00108",
		linknext = "0100_00110",
		line = 1371,
	},
	["0100_00110"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2291", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Oh yes, Hotori said she’s going to put on a special performance. She said it’s gonna be hilarious so you better not miss it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“啊对了。我听说畔想要搞个余兴节目。她说会超有趣所以要我们好好期待。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「啊對了。我聽說畔想要搞個餘興節目。她說會超有趣所以要我們好好期待。」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00109",
		linknext = "0100_00111",
		line = 1383,
	},
	["0100_00111"] = {
