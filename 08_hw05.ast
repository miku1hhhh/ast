	["0100_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hinami eventually graduated and went to college on the mainland. I graduated Minotsuki Academy the following year and enrolled in a school nearby.",
					{"rt2"},
				},
			},
			cn = {
				{
					"雏见毕业后去本岛读书，隔年我也从水乃月学园毕业，到她附近的学校念书。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雛見畢業後去本島讀書，隔年我也從水乃月學園畢業，到她附近的學校唸書。",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00003",
