					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Come on, today’s the day to celebrate, not the day to look mad. Come this way.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“是是是。但今天是大喜之日，礼酱你就别再顶着那张恐怖的脸了，好了，来这边吧──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「是是是。但今天是大喜之日，禮醬妳就別再頂著那張恐怖的臉了，好了，來這邊吧──」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00072",
		linknext = "0100_00074",
		line = 950,
	},
	["0100_00074"] = {
