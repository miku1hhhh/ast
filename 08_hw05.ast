	},
	["0100_00104"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Our home was raided by police once because she posted a URL of a website that generated an infinite loop or something, but all in all things are going just fine.",
					{"rt2"},
