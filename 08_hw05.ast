				},
			},
			en = {
				{
					"Well, “wedded” might be the wrong word to describe it. We filled out our paperwork this morning, so legally we’re already married.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不──说是要成为夫妇，这样不太准确。早上我们已经登记结婚了，所以现在我们早就不是恋人、而是夫妇了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不──説是要成為夫婦，這樣不太準確。早上我們已經登記結婚了，所以現在我們早就不是戀人、而是夫婦了。",
					{"rt2"},
				},
			},
		},
