			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Hehe, Rei never changes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呵呵⋯⋯真的很有礼酱的风格呢。”",
