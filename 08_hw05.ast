	},
	["0100_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Little by little the island has been changing, and so have we. How we are, where we stand...",
					{"rt2"},
