	["0100_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s an ordinary day for everyone else, but that makes it even more special for both of us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然对这世界来说，这真的是普通的一天，但正是因为这样，对我们来说才特别有感觉。",
