	["0100_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Every year, we commemorate and celebrate our special day that Hinami made.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们都一直记得雏见设下的“特别的日子”，然后每年都会庆祝这天。",
