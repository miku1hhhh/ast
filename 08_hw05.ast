		line = 760,
	},
	["0100_00059"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2280", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Not just that, but... it’s your one and only ceremony. I want to make sure it’s the best it can be.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那也是考量的一点⋯⋯不过这可是雏见跟橘、你们一生只有一次的高光时刻⋯⋯我想要它成为一场最棒的婚礼。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那也是考量的一點⋯⋯不過這可是雛見跟橘、你們一生只有一次的高光時刻⋯⋯我想要它成為一場最棒的婚禮。」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00058",
