	},
	["0100_00051"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2277", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Blow on my ear? What, are you teasing me or something?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“耳罩⋯⋯？什、什么东西？我是被揶揄了吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「耳罩⋯⋯？什、什麼東西？我是被揶揄了嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0100_00050",
		linknext = "0100_00052",
		line = 671,
	},
	["0100_00052"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I would’ve never thought you’d confuse it with a tornado.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我不会被龙卷风误导的喔。”",
