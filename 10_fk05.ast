					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Let’s see. If it’s something I’ve saved up for, I’d want something that lasts rather than anything consumable.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嗯，为了纪念存了一笔钱的话，就不要买会消失不见而是买可以持久的东西好像不错喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嗯，為了紀念存了一筆錢的話，就不要買會消失不見而是買可以持久的東西好像不錯喔。」",
					{"rt2"},
				},
			},
		},
