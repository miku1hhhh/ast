			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I’d love some new anal beads. But handmade would be fine too. Then it’d be a double gesture of love!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我应该会拿来做卖屌劳吧。手工的也不错呢⋯⋯！双重意义，可以感受到爱呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我應該會拿來做賣屌勞吧。手工的也不錯呢⋯⋯！雙重意義，可以感受到愛呢。」",
					{"rt2"},
				},
			},
		},
