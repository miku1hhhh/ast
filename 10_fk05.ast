			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Really now, Tachibana? You know that you and I want the same thing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“真是蠢问题啊，橘君。我们想要的东西当然是一样的啊⋯⋯”",
