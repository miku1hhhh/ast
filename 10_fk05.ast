					name = {"麻沙音", "Asane"},
					"“Hey, Fumino. I bought a laptop the other day but I don’t want it. I put it your room. I’ll swing by and take care of the wires later!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“喂，文乃！之前买的桌上型电脑太碍事了，搬回去你自己的房间吧⋯⋯！拉线还有充电的部分我晚点再帮你弄⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「喂，文乃！之前買的桌上型電腦太礙事了，搬回去妳自己的房間吧⋯⋯！拉線還有充電的部分我晚點再幫妳弄⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00156",
		linknext = "0112_00158",
		line = 2412,
	},
