			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“But really Darling, don’t you think you should ask her, herself? I think that would be best.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“亲爱的，是说这种还是问本人最好吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「親愛的，是說這種還是問本人最好吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00097",
		linknext = "0112_00099",
		line = 1461,
	},
	["0112_00099"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
