					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I would want to spend it on a getaway. We could book a hotel room for a week and make out the entire time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我觉得拿来当约会资金不错。饭店房间住一个礼拜，两人在里面尽情的调情，这样如何？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我覺得拿來當約會資金不錯。飯店房間住一個禮拜，兩人在裡面盡情的調情，這樣如何？」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00069",
