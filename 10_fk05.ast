	["0112_00107"] = {
		{"fg", file="asane_02m_00003", file1="asane_02m_00102", file2="asane_02m_00203", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1574", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“What are you going to do then, Bro? She’s a light sleeper so you can’t even sneak in while she’s snoozing. What about getting her wasted?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那哥你要怎么办呀⋯⋯？趁她睡得时候偷溜进去吗，但是她睡眠很浅一碰到就会被发现了吧⋯⋯还是让她喝酒⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那哥你要怎麼辦呀⋯⋯？趁她睡得時候偷溜進去嗎，但是她睡眠很淺一碰到就會被發現了吧⋯⋯還是讓她喝酒⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00106",
		linknext = "0112_00108",
		line = 1618,
	},
	["0112_00108"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00211", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
