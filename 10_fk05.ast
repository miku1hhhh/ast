	["0112_00186"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file2="fumino_01m_00208", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="文乃7", id=7, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0743", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I have cost your family 300,000 yen all because I was a salacious and debauched woman who wanted to watch sexy videos.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“文乃是想看色情视频的淫乱女子⋯⋯呜呜⋯⋯橘家将为此支付30万元⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「文乃是想看色情影片的淫亂女子⋯⋯嗚嗚⋯⋯橘家將為此支付30萬元⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00185",
		linknext = "0112_00187",
		line = 2919,
	},
	["0112_00187"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00101", file2="asane_02m_00203", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", alpha=0, ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=1, a_chr151=1, mode=3, x=595, y=-5},
		{"fgact", ch="麻沙音3", id=3, lv=3, act="表示アクション", a1=0, a2=255, time=400, a_chr=151, alpha=255},
		{"fgact", ch="麻沙音3", id=3, act="移動", x=-200, y=0, time=400},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1583", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ah. You clicked on spam and got scammed didn’t you? There, there. I’ll just clear the cache and it’ll disappear.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊⋯⋯是广告诈欺吧⋯⋯没问题的，只要清除缓存就没事了⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊⋯⋯是廣告詐欺吧⋯⋯沒問題的，只要清除緩存就沒事了⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00186",
		linknext = "0112_00188",
		line = 2934,
	},
	["0112_00188"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00102", file3="fumino_01m_00301", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="文乃7", id=7, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0744", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“But the computer lady knew where I was. And threatened me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“但是他们威胁说已经知道我们住在哪里了⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「但是他們威脅說已經知道我們住在哪裡了⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00187",
		linknext = "0112_00189",
		line = 2950,
	},
	["0112_00189"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00101", file2="asane_01m_00220", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1584", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“She probably just found the IP address and gave a general location, right? If she’d actually knew, this place would already be toast. Just a dumb troll.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“只是靠IP位址抓到大概位置而已啦，如果那样就能得知我们住在哪里的话，我们家早就会因为我的荒诞行径而被放一把火烧了吧⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「只是靠IP位址抓到大概位置而已啦，如果那樣就能得知我們住在哪裡的話，我們家早就會因為我的荒誕行徑而被放一把火燒了吧⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00188",
		linknext = "0112_00190",
		line = 2965,
	},
	["0112_00190"] = {
