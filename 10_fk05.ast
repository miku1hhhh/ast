			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Forgive me. I’ve gone and lost my head. I’m sorry you have to see me like this.”",
