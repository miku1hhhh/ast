					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You may be right... but I wanted to try and surprise her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“话是这么说没错⋯⋯但是机会难得，我想给她惊喜呀⋯⋯！”",
