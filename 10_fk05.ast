		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1573", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Oh, really? Aren’t they like smartwatches where you just click a button and adjust the size?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“原来是这样啊⋯⋯我还以为是像智慧手表一样有扣子，所以可以扣得刚刚好呢⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「原來是這樣啊⋯⋯我還以為是像智慧手錶一樣有釦子，所以可以釦得剛剛好呢⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00104",
		linknext = "0112_00106",
		line = 1593,
	},
	["0112_00106"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Both of us were deeply unfamiliar with the inventions of old.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们俩兄妹对于旧时代的硬体完全不懂啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們倆兄妹對於舊時代的硬體完全不懂啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00105",
