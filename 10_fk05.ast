	["0112_00096"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00204", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But what kind of ring would be good? What can I even get with only 100,000 yen?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过戒指要什么样子的比较好呢⋯⋯会有10万元能买的吗⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過戒指要什麼樣子的比較好呢⋯⋯會有10萬元能買的嗎⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00095",
		linknext = "0112_00097",
		line = 1431,
	},
	["0112_00097"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00223", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2249", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“You could get a promise ring with that much. I’ve seen some in the department store called Tiffany & Cum.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“对戒的话这价钱就买得了喔。我在岛上的百货公司‘[|伊句安’有看到过]。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「對戒的話這價錢就買得了喔。我在島上的百貨公司“[|伊句安”有看到過]。」",
					{"rt2"},
				},
			},
		},
		linkback = "0112_00096",
		linknext = "0112_00098",
		line = 1446,
	},
	["0112_00098"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00216", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
