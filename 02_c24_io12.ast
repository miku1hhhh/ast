		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Do you remember the first time we met?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“还记得吗？第一次见面时的事──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「還記得嗎？第一次見面時的事──」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00055",
		linknext = "0056_00057",
		line = 759,
	},
	["0056_00057"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I’d just transferred here and you said something like ‘I call dibs’ and I thought to myself, there’s no way we’re gonna get along.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对着才刚转学过来的我说‘把你的第一次给我’之类的……还觉得我绝对跟这家伙处不来的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對著才剛轉學過來的我說『把你的第一次給我』之類的……還覺得我絕對跟這傢伙處不來的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00056",
		linknext = "0056_00058",
		line = 771,
	},
	["0056_00058"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Even after we became enemies, you were so freaking strong and you were always targeting me. You drove me nuts, seriously.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“即使变成了像敌对关系，也是强得吓人，又只攻击我一个──你真的是个狠难缠的对手呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「即使變成了像敵對關係，也是強得嚇人，又只攻擊我一個──你真的是個狠難纏的對手呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00057",
		linknext = "0056_00059",
		line = 782,
	},
	["0056_00059"] = {
		{"evset", file="icg04", set="icg04", path=":ev/icg04/"},
