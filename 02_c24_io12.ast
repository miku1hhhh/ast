	},
	["0056_00029"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00103", file2="ikuko_01m_00202", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1176", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Ooh, look over there! It’s a giant Hamedori! I used to love coming to Hamedori Land.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“啊……你看你看。巨大Hamedori君！好怀念啊，有Hamedori君在的游乐园。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「啊……你看你看。巨大Hamedori君！好懷念啊，有Hamedori君在的遊樂園。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00028",
		linknext = "0056_00030",
		line = 386,
	},
	["0056_00030"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I bet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真的呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真的呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00029",
		linknext = "0056_00031",
		line = 398,
	},
	["0056_00031"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I never thought I’d see the day when looking up at this hideously weird looking bird would fill me with a sense of ease, but here I am.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我没想过有一天，当看到这只设计的恶心的鸟时，会放下心来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我沒想過有一天，當看到這隻設計的噁心的鳥時，會放下心來。",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00030",
		linknext = "0056_00032",
		line = 408,
	},
	["0056_00032"] = {
		{"fg", file="ikuko_02m_00007", file1="ikuko_02m_00103", file3="ikuko_02m_00310", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1177", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“It’s like it was all a dream—cumming my way into a parallel dimension where there’s no Hamedori and everyone’s calling you His Sexellency.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“就算是……在做梦一样。因为自慰而跨越平行世界，然后淳之介居然被称为性帝，而且Hamedori君不见了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「就算是……在做夢一樣。因為自慰而跨越平行世界，然後淳之介居然被稱為性帝，而且Hamedori君不見了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00031",
		linknext = "0056_00033",
		line = 423,
	},
	["0056_00033"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asane and the others were my enemy too. Then just when you thought you’d smoked out the leader, Hamedori showed up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“麻沙音跟大家都与我为敌──当我以为能将首脑揪出来时，Hanedori君就出现了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「麻沙音跟大家都與我為敵──當我以爲能將首腦揪出來時，Hanedori君就出現了呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00032",
		linknext = "0056_00034",
		line = 435,
	},
	["0056_00034"] = {
		{"fg", file="ikuko_02m_00007", file1="ikuko_02m_00103", file2="ikuko_02m_00229", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1178", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Being beaten to bits by him was pretty disheartening.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“真是受不了，结果被Hamedori君狠狠的修理了一顿。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「真是受不了，結果被Hamedori君狠狠的修理了一頓。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00033",
		linknext = "0056_00035",
		line = 450,
	},
	["0056_00035"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00220", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“More than that, being duped and labeled a traitor by the FS was pretty unbearable.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不仅如此，还被巧妙地利用，甚至被FS视为叛徒……真是吃不消啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不僅如此，還被巧妙地利用，甚至被FS視為叛徒……真是吃不消啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00034",
		linknext = "0056_00036",
		line = 462,
	},
	["0056_00036"] = {
		{"fg", file="ikuko_02m_00007", file1="ikuko_02m_00103", file2="ikuko_02m_00222", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1179", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“But you never once gave up. You picked us up and recruited the NLNS to our cause, one by one.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“即便如此，淳之介君也没放弃呢。不仅激励了我们，更把NLNS的人一个个的拉回来……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「即便如此，淳之介君也沒放棄呢。不僅激勵了我們，更把NLNS的人一個個的拉回來……」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00035",
		linknext = "0056_00037",
		line = 477,
	},
	["0056_00037"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00211", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fumino, Misaki, Hinami, Nanase... They became our friends all over again. We got the FS back on our side.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不管是文乃、美岬、雏见或是奈奈濑……都再一次的成为了我们的伙伴。FS的伙伴也都回来了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不管是文乃、美岬、雛見或是奈奈瀨……都再一次的成爲了我們的夥伴。FS的夥伴也都回來了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00036",
		linknext = "0056_00038",
		line = 489,
	},
	["0056_00038"] = {
		{"fg", file="ikuko_02m_00007", file1="ikuko_02m_00103", file3="ikuko_02m_00311", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1180", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“And you never gave up on Asane when she was the only one left. You clung to her desperately all that time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“最后只剩下麻沙音，也是绝对不会放弃她……淳之介君发了疯似地拥抱她呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「最後只剩下麻沙音，也是絕對不會放棄她……淳之介君發了瘋似地擁抱她呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00037",
		linknext = "0056_00039",
		line = 504,
	},
	["0056_00039"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Then with everyone together, we won the final battle and made it back to our own world.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊──然后，终于将大家聚集起来……赢得了最后的战役，回到了原来的世界了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊──然後，終於將大家聚集起來……贏得了最後的戰役，回到了原來的世界了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00038",
		linknext = "0056_00040",
		line = 516,
	},
	["0056_00040"] = {
