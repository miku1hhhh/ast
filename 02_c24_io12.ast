				},
			},
		},
		linkback = "0056_00058",
		linknext = "0056_00060",
		line = 799,
	},
	["0056_00060"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00211", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And that’s what led to you almost being chased off the island. Because of me...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“然后……因为我的关系，被驱逐出了岛──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「然後……因為我的關係，被驅逐出了島──」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00059",
		linknext = "0056_00061",
		line = 811,
	},
	["0056_00061"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And in spite of that, you came running to save me when I was in a pinch.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“即使如此……在最危急之时，还是赶来帮助了我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「即使如此……在最危急之時，還是趕來幫助了我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00060",
		linknext = "0056_00062",
		line = 823,
	},
	["0056_00062"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
