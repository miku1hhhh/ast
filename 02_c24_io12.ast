					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You were there to pick me up in my darkest moments. You helped make me stronger when I was feeling weak and stupid.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……在我沮丧的时，是你扶持了我。在我又笨又弱时，即使这样你依旧锻炼着我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……在我沮喪的時，是你扶持了我。在我又笨又弱時，即使這樣你依舊鍛鍊著我。」",
					{"rt2"},
				},
			},
		},
