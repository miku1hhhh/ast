	["0056_00026"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s always summer on the island, but the days are growing cooler, making it much more comfortable to pass time outside once the sun goes down.",
					{"rt2"},
				},
			},
			cn = {
				{
					"岛上万年不变的夏天最近变得有些凉爽，太阳下山后的天气也很宜人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"島上萬年不變的夏天最近變得有些涼爽，太陽下山後的天氣也很宜人。",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00025",
		linknext = "0056_00027",
		line = 342,
	},
	["0056_00027"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Walking with Ikuko and having idle conversations like this is nice. And yet my heart is still racing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"像这样和郁子边走边聊些不着边际的话，光是这样就让我很安心──然而，我的心跳得更快了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"像這樣和郁子邊走邊聊些不著邊際的話，光是這樣就讓我很安心──然而，我的心跳得更快了。",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00026",
		linknext = "0056_00028",
		line = 352,
	},
	["0056_00028"] = {
		{"fg", mode=-1, id=30},
		{"facehide"},
		{"fg", mode=-1, id=10, ch="郁子10", ch_origin="郁子", lv=10, time=0, sync=0},
