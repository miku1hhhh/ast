				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ikuko closes her eyes, recalling the moments I’m talking about.",
					{"rt2"},
				},
			},
			cn = {
				{
					"郁子闭上双眼──像是回想一般的听着我说话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"郁子閉上雙眼──像是回想一般的聽著我說話。",
