			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“You’ve said a whole lot of words, but I don’t want fancy proclamations about ‘now and forever.’ I just want you to tell me how you feel.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“说了这么多，还是想和你在一起……淳之介还是一如往常般地帅气呢。希望你能告诉我更直接地感受？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「說了這麼多，還是想和你在一起……淳之介還是一如往常般地帥氣呢。希望你能告訴我更直接地感受？」",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00086",
