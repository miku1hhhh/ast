	["0056_00017"] = {
		{"fg", file="ikuko_01f_00002", file1="ikuko_01f_00103", file2="ikuko_01f_00229", path=":fg/ikuko_01f/", id=30, ch="郁子", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1171", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Mhm. I knew about coffee milk before I knew what coffee was, so I believed there was a cow that squirted coffee milk.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嗯。我比起咖啡最先知道咖啡牛奶。深信着只要挤咖啡牛的奶就会出现咖啡牛奶。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嗯。我比起咖啡最先知道咖啡牛奶。深信著只要擠咖啡牛的奶就會出現咖啡牛奶。」",
					{"rt2"},
				},
			},
		},
