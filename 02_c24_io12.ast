	["0056_00064"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The days Ikuko and I spent together, the way her voice sounds, the expressions she makes—they run around in my mind like a carousel.",
					{"rt2"},
				},
			},
			cn = {
				{
					"和郁子一起度过的那些日子，她的声音、她的表情──像走马灯一样在脑海中闪过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"和郁子一起度過的那些日子，她的聲音、她的表情──像走馬燈一樣在腦海中閃過。",
					{"rt2"},
				},
			},
		},
		linkback = "0056_00063",
		linknext = "0056_00065",
		line = 855,
	},
	["0056_00065"] = {
