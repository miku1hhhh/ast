	["0052_00039"] = {
		{"bgm", file="bgm26", vol=100},
		{"bg", id=10, file="bg29_2l_00000", x=-450, y=0, lv=10, path=":bg/", sync=0, style="blur", blurx=11, blury=11, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00203", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0316", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“That’s not true, President! You didn’t want to expand the FS’s power just for yourself!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“不是的会长！会长并不是因为任性妄为才扩张了FS的权利。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「不是的會長！會長並不是因為任性妄為才擴張了FS的權利。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00038",
		linknext = "0052_00040",
		line = 592,
	},
	["0052_00040"] = {
		{"fg", file="schubert_01m_00002", file2="schubert_01m_00203", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0204", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“That’s right! You were trying to increase the FS’s independence in order to protect our rights!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“是啊会长！会长你这么做，是为了提高FS的自主性、维护我们的权利不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「是啊會長！會長你這麼做，是為了提高FS的自主性、維護我們的權利不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00039",
		linknext = "0052_00041",
		line = 606,
	},
	["0052_00041"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00101", file2="ran_01m_00203", file4="ran_01m_00401", path=":fg/ran_01m/", id=13, lv=13, head="ran_01m", ch_origin="蘭", ch="蘭13", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0090", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“In reality, we wouldn’t have been able to do anything if we were under orders of the SHO! We wouldn’t be able to reject entertaining the customers, just like Bootlicker and Mizuki!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“现在这种状，只要SHO一下令，我们就只能无条件服从。像马屁精同学跟水机同那样，连陪酒这种事都没办法拒绝！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「現在這種狀，只要SHO一下令，我們就只能無條件服從。像馬屁精同學跟水機同那樣，連陪酒這種事都沒辦法拒絕！」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00040",
		linknext = "0052_00042",
		line = 620,
	},
	["0052_00042"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00206", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
