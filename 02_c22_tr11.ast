	["0052_00052"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You grasped the connection between the Birds of a Feather and the SHO. You were only performing diversionary actions.”",
					{"rt2"},
				},
			},
