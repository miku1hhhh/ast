			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“No FS member wants to do such things! That’s why you were doing your best not to put us in such a situation!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“没有一个FS想做这样的事！所以，会长才会这么努力，想要针对现状做点什么不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「沒有一個FS想做這樣的事！所以，會長才會這麼努力，想要針對現狀做點什麼不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00041",
		linknext = "0052_00043",
		line = 638,
	},
	["0052_00043"] = {
