	["0052_00079"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00102", file2="tohka_01m_00223", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0849", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Y-Yes... Now... my memories finally match...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“想起来了⋯⋯现在⋯⋯记忆、总算⋯⋯是⋯⋯变得一致了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「想起來了⋯⋯現在⋯⋯記憶、總算⋯⋯是⋯⋯變得一致了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00078",
		linknext = "0052_00080",
		line = 1123,
	},
	["0052_00080"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file3="tohka_02m_00312", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0850", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“As of now, freedom of everyone at school is restricted... Even though they’re happy, only... he ...can’t be. That’s why I was trying to get a hold of personal affairs and a right to make decisions.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“按照现在的状况，学校内部的自由会受到束缚⋯⋯虽然大家都很快乐，却只有‘他’一个人依旧很不幸⋯⋯所以他才想要把人事权跟决定权握在手里⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「按照現在的狀況，學校內部的自由會受到束縛⋯⋯雖然大家都很快樂，卻只有『他』一個人依舊很不幸⋯⋯所以他才想要把人事權跟決定權握在手裡⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00079",
		linknext = "0052_00081",
		line = 1138,
	},
	["0052_00081"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00102", file2="tohka_02m_00223", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0851", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I... understand that... It’s because...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我懂他⋯⋯我懂、我真的懂⋯⋯因为──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我懂他⋯⋯我懂、我真的懂⋯⋯因為──」",
					{"rt2"},
				},
			},
		},
		linkback = "0052_00080",
		linknext = "0052_00082",
		line = 1153,
	},
	["0052_00082"] = {
