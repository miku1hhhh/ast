				{
					name = {"淳之介", "Junnosuke"},
					"“Good thing no one was watching. Be careful next time, all right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“幸好没被任何人看见，可是还是要小心点才行喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「幸好沒被任何人看見，可是還是要小心點才行喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00181",
		linknext = "0096_00183",
		line = 2782,
	},
	["0096_00183"] = {
		{"fg", file="hinami_02m_00004", file1="hinami_02m_00102", file2="hinami_02m_00204", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=1},
		{"fgact", ch="ヒナミ5", id=5, act="振動下", loop=1, size=10, time=175, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0418", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yeah, I guess. The sea is full of danger, like sharks and stuff.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯⋯⋯我会好好注意的。海里有很多危险嘛，搞不好还有鲨鱼呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯⋯⋯我會好好注意的。海裡有很多危險嘛，搞不好還有鯊魚呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00182",
		linknext = "0096_00184",
		line = 2798,
	},
	["0096_00184"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00101", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Haha, I doubt there’ll be any sharks around this shallow...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哈哈，这么浅的水域不用担心会有鲨鱼啦──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哈哈，這麼淺的水域不用擔心會有鯊魚啦──」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00183",
		linknext = "0096_00185",
		line = 2810,
	},
	["0096_00185"] = {
		{"fg", file="rei_01m_00004", file1="rei_01m_00102", file2="rei_01m_00209", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
