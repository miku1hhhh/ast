	["0096_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s currently the peak of summer vacation, and that means beach time for us here on Seiran Island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在也正值暑假期间──我们来到了青蓝岛的海边。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在也正值暑假期間──我們來到了青藍島的海邊。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00004",
		linknext = "0096_00006",
		line = 74,
	},
	["0096_00006"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei, often busy with her work of maintaining the FS, is on vacation with us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"平时总是为了FS的续存而忙前忙后的礼前辈今天也休息。",
					{"rt2"},
				},
			},
			tw = {
				{
					"平時總是為了FS的續存而忙前忙後的禮前輩今天也休息。",
					{"rt2"},
				},
			},
		},
