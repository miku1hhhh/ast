	["0096_00053"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00218", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hinami wanted to hear about my time in the FS. I mean, she’s my girlfriend, so I don’t want to keep secrets...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“雏见说他想听我在FS时的事⋯⋯我们是情侣，我不想有所隐瞒⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雛見說他想聽我在FS時的事⋯⋯我們是情侶，我不想有所隱瞞⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00052",
