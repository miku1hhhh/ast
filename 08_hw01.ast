			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You say your well-endowed sister is cute? But I thought you loved lolis! Damn you and your half-baked fetishes! Damn it, I love you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“吵死了啦，明明就是个萝莉控还会说自己的巨乳妹妹很可爱。性癖歪斜的哥哥！爱你喔！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「吵死了啦，明明就是個蘿莉控還會說自己的巨乳妹妹很可愛。性癖歪斜的哥哥！愛你喔！」",
