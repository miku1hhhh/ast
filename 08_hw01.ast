	["0096_00281"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00101", file2="jun_01f_00226", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There you go again, accusing your big brother of being a pedo, you cheeky cutie little sister, you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你怎么可以说自己的哥哥是萝莉控呢，真是嚣张啊我可爱的妹妹！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳怎麼可以說自己的哥哥是蘿莉控呢，真是囂張啊我可愛的妹妹！」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00280",
		linknext = "0096_00282",
		line = 4529,
	},
	["0096_00282"] = {
