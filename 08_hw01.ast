				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Uh no, that’s one of the FS’s training regimen... Tachibana, have you been telling her weird stories?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“欸？不不那是FS的训练⋯⋯喂橘，你到底都跟雏见说了什么奇怪的事⋯⋯！”",
					{"rt2"},
