			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“是、是晒痕啊⋯⋯吓死我了。原来穿着泳衣在外面玩，会变成这样啊⋯⋯哇⋯⋯嗯⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
