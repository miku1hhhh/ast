				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This island, once ridiculed with names like Pussyville, has been dismantled along with its sex law. With all the bangers gone, we can now enjoy bathing in the shallows.",
					{"rt2"},
				},
			},
			cn = {
				{
					"曾经被人嘲笑为小穴村的岛上，如今已经没了变态条例与变态们──以往在浅滩上啪啪做爱的人们也消失了，才能让人们在浅滩啪啪地戏水玩闹。",
					{"rt2"},
				},
			},
			tw = {
				{
					"曾經被人嘲笑為小穴村的島上，如今已經沒了變態條例與變態們──以往在淺灘上啪啪做愛的人們也消失了，才能讓人們在淺灘啪啪地戲水玩鬧。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00287",
		linknext = "0096_00289",
		line = 4630,
	},
	["0096_00289"] = {
