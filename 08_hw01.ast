					name = {"蘭", "Ran"},
					"“Aaaahhhhh! There’s a shark!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“噫噫是鲨鱼！有鲨鱼！”",
