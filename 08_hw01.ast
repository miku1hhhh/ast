			},
		},
		text = {
			vo = {
				{"vo", file="asane1311", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“What the hell, Bro, you got this most awesome bad-ass waifu in human history Nanase standing next to you and all you care about is some flat-chested chick? You goddamn kiddie-fiddler, you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“有可以说是有史以来最强的命运之人、像是奈奈濑同学这样的女孩子在身边，居然还可以说贫乳贫乳可爱得不得了，是萝莉控吧这男人⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「有可以說是有史以來最強的命運之人、像是奈奈瀨同學這樣的女孩子在身邊，居然還可以說貧乳貧乳可愛得不得了，是蘿莉控吧這男人⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00278",
		linknext = "0096_00280",
		line = 4502,
	},
