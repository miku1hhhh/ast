	},
	["0096_00189"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I turn towards Rei’s voice, and see a large fin—it does scream “shark”, I suppose—heading right this way.",
					{"rt2"},
				},
			},
			cn = {
				{
					"听到礼前辈的声音，我回头一看，一条鲨鱼的背鳍正朝着这边过来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"聽到禮前輩的聲音，我回頭一看，一條鯊魚的背鰭正朝著這邊過來。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00188",
		linknext = "0096_00190",
		line = 2883,
	},
	["0096_00190"] = {
