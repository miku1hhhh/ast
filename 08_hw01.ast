					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hang on, Hinami. We need to warm ourselves up first, or our legs might cramp up while swimming.”",
					{"rt2"},
				},
			},
			cn = {
