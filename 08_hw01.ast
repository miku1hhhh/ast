		{"fgact", ch="ヒナミ5", id=5, act="振動下", loop=1, size=12.5, time=750, ease="easeinout_sine"},
		{"text"},
		delay = {
			[3500] = {
				{"fgact", ch="ヒナミ5", id=5, act="振動下", loop=1, size=12.5, time=750, ease="easeinout_sine", timestamp=118, delay2=3500},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0437", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“...Zzz... zzz...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呼⋯⋯鼾⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呼⋯⋯鼾⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00324",
		linknext = "0096_00326",
		line = 5140,
	},
	["0096_00326"] = {
		{"fg", file="jun_01f_00004", file3="jun_01f_00309", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh... you’re asleep.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯睡着了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯睡著了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00325",
		linknext = "0096_00327",
		line = 5152,
	},
	["0096_00327"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She must’ve been really wiped out from all the fun. She’s conked out, like her batteries ran out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"估计是第一次出海太兴奋而累了──她就像没电一样地睡着了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"估計是第一次出海太興奮而累了──她就像沒電一樣地睡著了。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00326",
		linknext = "0096_00328",
		line = 5162,
	},
	["0096_00328"] = {
		{"fg", file="hinami_03ll_00004", file1="hinami_03ll_00101", file3="hinami_03ll_00307", path=":fg/hinami_03ll/", id=5, lv=5, head="hinami_03ll", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0438", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Mmm... Phew...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“呼⋯⋯⋯⋯哈⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「呼⋯⋯⋯⋯哈⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00327",
		linknext = "0096_00329",
		line = 5177,
	},
	["0096_00329"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Look at her, breathing so gently in her sleep. It’s the outdoors and yet, she’s so unguarded.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她睡得很安稳，即时在外面也完全没有防备。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她睡得很安穩，即時在外面也完全沒有防備。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00328",
		linknext = "0096_00330",
		line = 5187,
	},
	["0096_00330"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"At times, she can be so grown up, but the next thing you know, she’s no more than a child.",
					{"rt2"},
				},
			},
			cn = {
				{
					"偶尔，当我以为她表现出大人的一面时，突然又会像这样子出现孩子气的状况。",
					{"rt2"},
				},
			},
			tw = {
				{
					"偶爾，當我以為她表現出大人的一面時，突然又會像這樣子出現孩子氣的狀況。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00329",
		linknext = "0096_00331",
		line = 5197,
	},
	["0096_00331"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And that makes me so happy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对此──我感到很开心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對此──我感到很開心。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00330",
		linknext = "0096_00332",
		line = 5207,
	},
	["0096_00332"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She feels safe enough in my arms to be able to fall asleep like this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对雏见来说，我的怀抱是她可以心安的地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對雛見來說，我的懷抱是她可以心安的地方。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00331",
		linknext = "0096_00333",
		line = 5217,
	},
	["0096_00333"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In the past, I tried to take on everything by myself. It was Hinami who cared for me with her warm embrace.",
					{"rt2"},
				},
			},
			cn = {
				{
					"曾经，当我想一个人撑起一切时──是雏见给了我一个温暖的拥抱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"曾經，當我想一個人撐起一切時──是雛見給了我一個溫暖的擁抱。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00332",
		linknext = "0096_00334",
		line = 5227,
	},
	["0096_00334"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My heart was a mess and on the verge of breaking down. Hinami helped me let go of that weight.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这解放了我荒芜而破碎的内心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這解放了我荒蕪而破碎的內心。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00333",
		linknext = "0096_00335",
		line = 5237,
	},
	["0096_00335"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s why I’m so genuinely happy that I can become for her what she was for me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以，如果现在的我对雏见来说能成为那样的地方就好了──我是认真这么想的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以，如果現在的我對雛見來說能成為那樣的地方就好了──我是認真這麼想的。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00334",
		linknext = "0096_00336",
		line = 5247,
	},
	["0096_00336"] = {
		{"cgdel", id=1, lv=1, time=0, alphadel=1},
		{"fg", mode=-1, id=5, ch="ヒナミ5", ch_origin="ヒナミ", lv=5, time=0, sync=0},
		{"bg", id=1, file="bg05_2_00000", x=0, y=0, lv=1, path=":bg/", sync=0, style="blur", blurx=11, blury=11, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="hinami_03ll_00004", file1="hinami_03ll_00101", file3="hinami_03ll_00307", path=":fg/hinami_03ll/", id=5, lv=6, head="hinami_03ll", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=0, y=0},
		{"bgm", stop=1},
		{"fgact", ch="ヒナミ5", id=5, act="移動", x=395, y=-5, time=800},
		{"bg", id=1, file="bg05_2_00000", x=0, y=0, lv=1, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="rei_01m_00004", file1="rei_01m_00101", file2="rei_01m_00201", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", alpha=0, ch_origin="礼", ch="礼9", mw="mw", sync=1, a_chr151=1, mode=3, x=-605, y=-5},
		{"fgact", ch="礼9", id=9, lv=5, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="礼9", id=9, act="移動", x=200, y=0, time=700},
		{"text"},
		delay = {
			[2000] = {
				{"fg", file="rei_01m_00004", file1="rei_01m_00102", file2="rei_01m_00209", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=119, delay2=2000, mode=3, x=-405, y=-5},
			},
			[1999] = {
				{"transitiontime", time=300, timestamp=119, delay2=2000},
			},
		},
		text = {
			vo = {
				{"vo", file="rei2127", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hey, Hinami, Tachibana, we should be going... oh, is Hinami asleep?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“喂。雏见、橘，时间差不多了──欸，什么嘛。雏见睡着了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「喂。雛見、橘，時間差不多了──欸，什麼嘛。雛見睡著了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00335",
		linknext = "0096_00337",
		line = 5273,
	},
	["0096_00337"] = {
		{"fg", file="jun_01f_00004", file3="jun_01f_00309", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Looks like she really had fun out there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊。在海边玩得太开心了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊。在海邊玩得太開心了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00336",
		linknext = "0096_00338",
		line = 5285,
	},
	["0096_00338"] = {
		{"fg", file="rei_01m_00004", file1="rei_01m_00101", file2="rei_01m_00207", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2128", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Well... I’m certainly glad for her, then.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这样啊⋯⋯真是太好了呢，雏见。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這樣啊⋯⋯真是太好了呢，雛見。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00337",
		linknext = "0096_00339",
		line = 5300,
	},
	["0096_00339"] = {
		{"fg", file="rei_01m_00004", file1="rei_01m_00101", file2="rei_01m_00201", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2129", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“But what should we do? Should I carry her home?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不过要怎么办？要我把她背回家吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不過要怎麼辦？要我把她揹回家嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00338",
		linknext = "0096_00340",
		line = 5315,
	},
	["0096_00340"] = {
		{"fg", file="jun_01f_00004", file2="jun_01f_00207", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She was gonna stay at my place tonight, so I’ll take her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她今天打算去我们家住，我把她带回家就好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「她今天打算去我們家住，我把她帶回家就好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00339",
		linknext = "0096_00341",
		line = 5327,
	},
	["0096_00341"] = {
		{"fg", file="jun_01f_00004", file2="jun_01f_00201", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh yeah, Hinami has always wanted to have a sleepover with you. You could come with us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊对。雏见也说了想跟礼前辈一起过夜的──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊對。雛見也說了想跟禮前輩一起過夜的──」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00340",
		linknext = "0096_00342",
		line = 5339,
	},
	["0096_00342"] = {
		{"fg", file="rei_01m_00004", file1="rei_01m_00101", file2="rei_01m_00227", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2130", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I’ll pass. Don’t want to get between you two.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“⋯⋯不用了。我可不想要当电灯泡。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「⋯⋯不用了。我可不想要當電燈泡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00341",
		linknext = "0096_00343",
		line = 5354,
	},
	["0096_00343"] = {
		{"fg", file="rei_01m_00004", file1="rei_01m_00101", file2="rei_01m_00207", path=":fg/rei_01m/", id=9, lv=5, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2131", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“It was great today. Thank you for inviting me, Tachibana. Tell Hinami the same when she wakes up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
