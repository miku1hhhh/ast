	},
	["0096_00325"] = {
		{"fg", file="hinami_04ll_00004", file1="hinami_04ll_00101", file3="hinami_04ll_00307", path=":fg/hinami_04ll/", id=5, lv=5, head="hinami_04ll", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=0, y=0},
