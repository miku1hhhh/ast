		{"transitiontime", time=100},
		{"text"},
		delay = {
			[2800] = {
				{"fgact", ch="美岬6", id=6, act="振動下", loop=3, size=10, time=75, ease="easeinout_sine", timestamp=110, delay2=2800},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0461", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“No, I can’t see anything. But hehe, calories live and breathe. I can sense the calories that lie ahead of me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“看不见喔。不过呢⋯⋯呵呵、因为是有卡路里的活物嘛。我可以感觉到那里确实有着卡路里的气息飘来喔！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「看不見喔。不過呢⋯⋯呵呵、因為是有卡路里的活物嘛。我可以感覺到那裡確實有著卡路里的氣息飄來喔！」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00264",
		linknext = "0096_00266",
		line = 4257,
	},
	["0096_00266"] = {
