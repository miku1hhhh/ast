	["0096_00284"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We may complain about each other at times, but in the end, we’re siblings bonded by deep love.",
					{"rt2"},
				},
			},
			cn = {
				{
					"尽管会互相抱怨，但我们依旧是用深深的爱来联系彼此的兄妹。",
					{"rt2"},
				},
			},
			tw = {
				{
					"儘管會互相抱怨，但我們依舊是用深深的愛來聯繫彼此的兄妹。",
					{"rt2"},
				},
			},
		},
