	["0096_00063"] = {
		{"fgact", ch="ヒナミ5", id=5, lv=5, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The exercise may be simple, but it’s clear that she’s putting all of her effort into it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然只是热身，不过她用上可以说是“拼老命”的力气认真做着热身。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然只是熱身，不過她用上可以說是「拚老命」的力氣認真做著熱身。",
					{"rt2"},
				},
			},
