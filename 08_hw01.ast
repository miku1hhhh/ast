	["0096_00076"] = {
		{"fg", file="hinami_01m_00004", file1="hinami_01m_00101", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0402", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Hehe♪ The sea’s so fun!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“欸嘿嘿♪海水好好玩呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「欸嘿嘿♪海水好好玩呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00075",
		linknext = "0096_00077",
		line = 1166,
	},
	["0096_00077"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It only took ten seconds for Hinami to split into a massive smile like she’s experienced every joy the sea has to offer.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过跳进水里10秒左右，雏见就露出了充分享受了大海的乐趣般的笑容。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過跳進水裡10秒左右，雛見就露出了充分享受了大海的樂趣般的笑容。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00076",
		linknext = "0096_00078",
		line = 1176,
	},
	["0096_00078"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00004", file1="jun_01f_00101", file3="jun_01f_00302", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hehehe... Hinami, you haven’t seen anything yet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哼哼哼⋯⋯雏见，大海的乐趣还多着呢⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哼哼哼⋯⋯雛見，大海的樂趣還多著呢⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00077",
		linknext = "0096_00079",
		line = 1189,
	},
	["0096_00079"] = {
		{"se", id=0, loop=0, file="se_a185"},
		{"fg", file="rei_01m_00004", file1="rei_01m_00101", file2="rei_01m_00209", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"fg", file="hinami_01m_00004", file1="hinami_01m_00101", file2="hinami_01m_00212", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"fg", file="jun_01f_00004", file1="jun_01f_00101", file3="jun_01f_00303", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There’s still so much more fun to be had at the beach!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你可要⋯⋯好好玩个开心才行喔⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳可要⋯⋯好好玩個開心才行喔⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00078",
		linknext = "0096_00080",
		line = 1207,
	},
	["0096_00080"] = {
		{"fg", file="rei_02m_00004", file1="rei_02m_00101", file2="rei_02m_00204", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2093", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hold up, Tachibana. You don’t mean...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“什么⋯⋯？橘，这该不会是⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「什麼⋯⋯？橘，這該不會是⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00079",
		linknext = "0096_00081",
		line = 1222,
	},
	["0096_00081"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00101", file3="jun_01f_00302", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You guessed it: beach volleyball!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哼哼哼⋯⋯是沙滩排球喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哼哼哼⋯⋯是沙灘排球喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00080",
		linknext = "0096_00082",
		line = 1234,
	},
	["0096_00082"] = {
		{"bgm", file="bgm05", vol=100},
		{"fg", file="hinami_01m_00004", file1="hinami_01m_00101", file2="hinami_01m_00201", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[3500] = {
				{"fg", file="hinami_01m_00004", file1="hinami_01m_00101", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, timestamp=27, delay2=3500, mode=3, x=395, y=-5},
			},
			[3499] = {
				{"transitiontime", time=300, timestamp=27, delay2=3500},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0403", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Oh, that big ball you toss around with everyone? I wanna try!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哦哦！就是大家都会拍来拍去的东西吗。好啊，来玩玩看。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哦哦！就是大家都會拍來拍去的東西嗎。好啊，來玩玩看。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00081",
		linknext = "0096_00083",
		line = 1253,
	},
	["0096_00083"] = {
		{"fg", file="rei_02m_00004", file1="rei_02m_00101", file2="rei_02m_00209", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2094", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Well, that’s a surprise. I never thought beach volleyball was your thing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“欸⋯⋯真是意外呢，橘。你喜欢沙滩排球啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「欸⋯⋯真是意外呢，橘。你喜歡沙灘排球啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00082",
		linknext = "0096_00084",
		line = 1268,
	},
	["0096_00084"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00101", file3="jun_01f_00302", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hehe... If only. I’ve never even tried it before.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呵呵⋯⋯怎么可能。不管我是喜欢还是讨厌──我都没有玩过。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呵呵⋯⋯怎麼可能。不管我是喜歡還是討厭──我都沒有玩過。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00083",
		linknext = "0096_00085",
		line = 1280,
	},
	["0096_00085"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00101", file3="jun_01f_00303", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Because I had nobody to play it with, of course!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就算想玩，也没有人陪啊⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就算想玩，也沒有人陪啊⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00084",
		linknext = "0096_00086",
		line = 1292,
	},
	["0096_00086"] = {
		{"fg", file="rei_02m_00004", file1="rei_02m_00104", file2="rei_02m_00224", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[2500] = {
				{"fg", file="rei_02m_00004", file1="rei_02m_00104", file3="rei_02m_00306", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=28, delay2=2500, mode=3, x=-405, y=-5},
			},
			[2499] = {
				{"transitiontime", time=300, timestamp=28, delay2=2500},
			},
		},
		text = {
			vo = {
				{"vo", file="rei2095", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Um... sorry for bringing it up, I guess. Also, why the evil grin?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“啊、这样啊⋯⋯真是抱歉喔⋯⋯？那你提这个时还笑得那么自信满满⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「啊、這樣啊⋯⋯真是抱歉喔⋯⋯？那你提這個時還笑得那麼自信滿滿⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00085",
		linknext = "0096_00087",
		line = 1310,
	},
	["0096_00087"] = {
		{"fg", file="hinami_02m_00004", file1="hinami_02m_00101", file2="hinami_02m_00202", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0404", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“In other words, Jun is happy that he can play beach ball with us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我来说，因为淳君觉得能跟我们一起打沙滩排球很高兴嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我來說，因為淳君覺得能跟我們一起打沙灘排球很高興嘛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00086",
		linknext = "0096_00088",
		line = 1325,
	},
	["0096_00088"] = {
		{"fg", file="rei_02m_00004", file1="rei_02m_00101", file2="rei_02m_00220", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[2000] = {
				{"fg", file="rei_02m_00004", file1="rei_02m_00101", file2="rei_02m_00214", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=29, delay2=2000, mode=3, x=-405, y=-5},
			},
			[1999] = {
				{"transitiontime", time=300, timestamp=29, delay2=2000},
			},
		},
		text = {
			vo = {
				{"vo", file="rei2096", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Oh, that’s it. Why didn’t you just say that out loud?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“喔，是喔⋯⋯算了，你这么说我就当成是这样吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「喔，是喔⋯⋯算了，妳這麼說我就當成是這樣吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00087",
		linknext = "0096_00089",
		line = 1343,
	},
	["0096_00089"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00101", file2="jun_01f_00212", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Because ‘Yay! I’ve always wanted to play beach volleyball!’ isn’t exactly a masculine thing to say! Duh!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为这很丢脸嘛！这么大的男人还一直想打沙滩排球什么的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為這很丟臉嘛！這麼大的男人還一直想打沙灘排球什麼的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00088",
		linknext = "0096_00090",
		line = 1355,
	},
	["0096_00090"] = {
		{"fg", file="rei_02m_00004", file1="rei_02m_00102", file2="rei_02m_00224", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
