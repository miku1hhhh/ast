			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“一起想那个台词很有趣的说。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「一起想那個台詞很有趣的說。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00103",
		linknext = "0096_00105",
		line = 1596,
	},
	["0096_00105"] = {
		{"fg", file="rei_02m_00004", file1="rei_02m_00101", file2="rei_02m_00209", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"fg", file="jun_01f_00004", file1="jun_01f_00101", file2="jun_01f_00219", path=":fg/jun_01f/", id=30, ch="淳之介", lv=9, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You helped her out with it, Hinami?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“雏见你也有参一脚吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雛見妳也有參一腳嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00104",
		linknext = "0096_00106",
		line = 1611,
	},
	["0096_00106"] = {
		{"fg", file="hinami_01m_00004", file1="hinami_01m_00101", file2="hinami_01m_00201", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="ヒナミ5", id=5, act="振動下", loop=1, size=10, time=200, ease="easeinout_sine"},
		{"text"},
		delay = {
			[2000] = {
				{"fg", file="hinami_01m_00004", file1="hinami_01m_00101", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, timestamp=32, delay2=2000, mode=3, x=395, y=-5},
			},
			[1999] = {
				{"transitiontime", time=300, timestamp=32, delay2=2000},
			},
			[7200] = {
				{"fg", file="hinami_01m_00004", file1="hinami_01m_00101", file2="hinami_01m_00203", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, timestamp=33, delay2=7200, mode=3, x=395, y=-5},
			},
			[7199] = {
				{"transitiontime", time=300, timestamp=33, delay2=7200},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0407", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yup! We were working on it during lunch, but then Rei fell asleep in the middle of it and just wouldn’t wake up... and then a teacher came by.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯！我们在午休的时候一起想的呦，不过礼酱想到一半就睡着了，所以没有起来⋯⋯然后老师就来了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯！我們在午休的時候一起想的呦，不過禮醬想到一半就睡著了，所以沒有起來⋯⋯然後老師就來了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00105",
		linknext = "0096_00107",
		line = 1633,
	},
	["0096_00107"] = {
		{"fg", file="rei_02m_00004", file1="rei_02m_00101", file3="rei_02m_00305", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"fg", file="hinami_01m_00004", file1="hinami_01m_00101", file2="hinami_01m_00206", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[6300] = {
				{"fg", file="hinami_01m_00004", file1="hinami_01m_00101", file2="hinami_01m_00201", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, timestamp=34, delay2=6300, mode=3, x=395, y=-5},
			},
			[6299] = {
				{"transitiontime", time=300, timestamp=34, delay2=6300},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0408", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I passed her a note that said ‘no naps’, ‘wake up!’ and ‘the teacher’s coming’, and Rei turned all that into that cool-sounding chant.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“所以我偷偷她‘不能睡着’、‘快起来’、‘老师来了’的纸条，然后看见那些纸条的礼酱就想出了这个很炫的台词喔！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「所以我偷偷她『不能睡著』、『快起來』、『老師來了』的紙條，然後看見那些紙條的禮醬就想出了這個很炫的台詞喔！」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00106",
		linknext = "0096_00108",
		line = 1653,
	},
	["0096_00108"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00101", file2="jun_01f_00206", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hold on, Rei. That makes you the ‘lazy sloth’. Are you sure you want to be making that your catchphrase?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以那个‘放肆午睡的懒惰之人’说的不就是礼前辈吗⋯⋯这个真的没问题吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以那個『放肆午睡的懶惰之人』說的不就是禮前輩嗎⋯⋯這個真的沒問題嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00107",
		linknext = "0096_00109",
		line = 1665,
	},
	["0096_00109"] = {
		{"fg", file="rei_02m_00004", file1="rei_02m_00104", file2="rei_02m_00206", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2103", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I... was never aware of that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我、我不知道这个啊⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我、我不知道這個啊⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00108",
		linknext = "0096_00110",
		line = 1680,
	},
	["0096_00110"] = {
		{"fg", file="hinami_01m_00004", file1="hinami_01m_00101", file2="hinami_01m_00212", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"fg", file="jun_01f_00004", file1="jun_01f_00102", file2="jun_01f_00205", path=":fg/jun_01f/", id=30, ch="淳之介", lv=5, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“欸⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「欸⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00109",
		linknext = "0096_00111",
		line = 1695,
	},
	["0096_00111"] = {
		{"fg", file="rei_01m_00004", file1="rei_01m_00102", file2="rei_01m_00224", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[7000] = {
				{"fg", file="rei_01m_00004", file1="rei_01m_00102", file3="rei_01m_00320", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=35, delay2=7000, mode=3, x=-405, y=-5},
			},
			[6999] = {
				{"transitiontime", time=300, timestamp=35, delay2=7000},
			},
		},
		text = {
			vo = {
				{"vo", file="rei2104", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“When I woke up, I found a note Hinami left with some catchy words written on it, and it helped me come up with the rest of the line. I never thought there was such a story behind it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“讨厌，我起来的时候就看到雏见放了很不错的纸条在旁边⋯⋯想说感觉很不错就用来当台词了⋯⋯我没想过背后是这样的⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「討厭，我起來的時候就看到雛見放了很不錯的紙條在旁邊⋯⋯想說感覺很不錯就用來當台詞了⋯⋯我沒想過背後是這樣的⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00110",
		linknext = "0096_00112",
		line = 1713,
	},
	["0096_00112"] = {
		{"fg", file="jun_01f_00004", file2="jun_01f_00214", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00111",
		linknext = "0096_00113",
		line = 1725,
	},
	["0096_00113"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I have to say, there are times that make me think Rei might actually be quite dumb.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈说是相当的迟钝──不如说是呆吧⋯⋯",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩說是相當的遲鈍──不如說是呆吧⋯⋯",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00112",
		linknext = "0096_00114",
		line = 1735,
	},
	["0096_00114"] = {
		{"fg", file="rei_02m_00004", file1="rei_02m_00101", file3="rei_02m_00306", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2105", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You just thought to yourself ‘Rei might actually be quite dumb’, didn’t you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“喂橘⋯⋯你现在在想我是呆子对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「喂橘⋯⋯你現在在想我是呆子對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00113",
		linknext = "0096_00115",
		line = 1750,
	},
	["0096_00115"] = {
		{"fg", file="jun_01f_00004", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes, I did.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没错。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒錯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00114",
		linknext = "0096_00116",
		line = 1762,
	},
	["0096_00116"] = {
		{"fg", file="rei_02m_00004", file1="rei_02m_00104", file2="rei_02m_00223", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=200},
		{"fgact", ch="礼9", id=9, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[2300] = {
				{"fg", file="rei_02m_00004", file1="rei_02m_00101", file2="rei_02m_00222", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=36, delay2=2300, mode=3, x=-405, y=-5},
			},
			[2299] = {
				{"transitiontime", time=200, timestamp=36, delay2=2300},
			},
		},
		text = {
			vo = {
				{"vo", file="rei2106", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Can’t you at least be courteous and deny it?! Damn it, now I’m pissed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“就算是做做样子你也应该要否认才对吧！？可恶，我要生气了⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「就算是做做樣子你也應該要否認才對吧！？可惡，我要生氣了⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00115",
		linknext = "0096_00117",
		line = 1781,
	},
	["0096_00117"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"You were gonna be pissed even if I denied it, so I figured I’d save the effort and be honest.",
					{"rt2"},
				},
			},
			cn = {
				{
					"反正我就算是否认你也会生气，那还不如直接肯定呢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"反正我就算是否認妳也會生氣，那還不如直接肯定呢。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00116",
		linknext = "0096_00118",
		line = 1791,
	},
	["0096_00118"] = {
		{"fg", mode=-1, id=5, ch="ヒナミ5", ch_origin="ヒナミ", lv=5, time=0, sync=0},
		{"fg", file="rei_02l_00004", file1="rei_02l_00101", file2="rei_02l_00215", path=":fg/rei_02l/", id=9, lv=9, head="rei_02l", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2107", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You traitors who dare sully our territory. In the name of our lord, scatter like petals in the wind!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“在我们领土上的逆贼们。我已主君之名，将打得你们落花流水──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「在我們領土上的逆賊們。我已主君之名，將打得你們落花流水──」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00117",
		linknext = "0096_00119",
		line = 1808,
	},
	["0096_00119"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Oh yeah, this phrase about the petals or whatever too. I wonder if this also has a dumb origin story.",
					{"rt2"},
				},
			},
			cn = {
				{
