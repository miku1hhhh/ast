					name = {"ヒナミ", "雏见"},
					"“礼酱礼酱！海水咸咸的！好咸好咸！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「禮醬禮醬！海水鹹鹹的！好鹹好鹹！」",
