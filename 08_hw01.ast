			},
			[4499] = {
				{"transitiontime", time=300, timestamp=1, delay2=4500},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0384", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Wow, everyone’s wearing swimsuits and yet, nobody’s having sex. It’s like we’re in a comic book or something.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“哇喔⋯⋯大家都穿着泳衣却没有人在做爱呢，好棒啊，简直像漫画一样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「哇喔⋯⋯大家都穿著泳衣卻沒有人在做愛呢，好棒啊，簡直像漫畫一樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00006",
		linknext = "0096_00008",
		line = 102,
	},
	["0096_00008"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yup, this place isn’t a nudist beach anymore. Just another good old beach.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为这里已经不是裸体海滩了嘛。只是普通的海滩而已喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為這裡已經不是裸體海灘了嘛。只是普通的海灘而已喔。」",
					{"rt2"},
				},
			},
		},
