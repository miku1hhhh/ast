	["0096_00122"] = {
		{"se", id=0, loop=0, file="se_b066", vol=60},
		{"cgact", file="cgact", id=2, act="浮遊", loop=2, size=10, time=75, ease="easeinout_sine", lv=2, x=195, y=-205},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The intensity of her spike catches me off guard and my body braces reflexively, sending the ball soaring high up into the air.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是出乎意料的猛烈扣球──我的身体条件反射地动了起来，接住了发射而来的沙滩球。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是出乎意料的猛烈扣球──我的身體條件反射地動了起來，接住了發射而來的沙灘球。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00121",
		linknext = "0096_00123",
		line = 1879,
	},
	["0096_00123"] = {
