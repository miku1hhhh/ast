					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“太强了⋯⋯她真的看不见吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「太強了⋯⋯她真的看不見嗎？」",
