	["0096_00227"] = {
		{"fg", file="jun_01f_00004", file2="jun_01f_00206", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Uh, Fumino... I really hate to say this, but shouldn’t you be choosing your friends a little more wisely?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“文乃⋯⋯虽然我不想说太多，不过你真的该好好挑一下朋友喔⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「文乃⋯⋯雖然我不想說太多，不過妳真的該好好挑一下朋友喔⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00226",
		linknext = "0096_00228",
		line = 3547,
	},
	["0096_00228"] = {
		{"bgm", file="bgm02", vol=100},
