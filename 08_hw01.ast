		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I’ve told her all about you losing to that aphrodisiac, and also about that time you got so drunk you were sobbing like crazy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我把礼前辈轻易就输给春药跟喝醉了之后大哭的事情全都说了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我把禮前輩輕易就輸給春藥跟喝醉了之後大哭的事情全都說了。」",
					{"rt2"},
				},
			},
		},
