	["0096_00296"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hotori goes berserk and Asa snaps at her; Nanase and Rei try to calm them down, while Hotori sobs all over Fumino for comfort...",
					{"rt2"},
				},
			},
			cn = {
				{
					"畔大暴走、麻沙酱被惹到抓狂，奈奈濑跟礼前辈出面协调，畔又对着文乃哭闹──",
					{"rt2"},
				},
			},
			tw = {
				{
					"畔大暴走、麻沙醬被惹到抓狂，奈奈瀨跟禮前輩出面協調，畔又對著文乃哭鬧──",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00295",
		linknext = "0096_00297",
		line = 4765,
	},
	["0096_00297"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase casually gives Asa a nosebleed without noticing, and as Rei and Fumino go to treat her, Hotori goes berserk again, and Asa snaps back again...",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑发挥了她的迟钝BUFF、麻沙酱喷出了鼻血、礼前辈跟文乃忙着照顾她，然后畔又开始暴走、麻沙酱又被惹怒──",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨發揮了她的遲鈍BUFF、麻沙醬噴出了鼻血、禮前輩跟文乃忙著照顧她，然後畔又開始暴走、麻沙醬又被惹怒──",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00296",
		linknext = "0096_00298",
		line = 4775,
	},
