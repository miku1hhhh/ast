		linkback = "0096_00218",
		linknext = "0096_00220",
		line = 3423,
	},
	["0096_00220"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I guess this could be fun in its own way, for some...",
					{"rt2"},
				},
			},
			cn = {
				{
					"这搞不好还真的挺有趣的──",
					{"rt2"},
				},
			},
			tw = {
				{
					"這搞不好還真的挺有趣的──",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00219",
		linknext = "0096_00221",
		line = 3433,
	},
