				{"fgact", ch="美岬6", id=6, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine", timestamp=85, delay2=10000},
			},
			[9999] = {
				{"transitiontime", time=200, timestamp=85, delay2=10000},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0458", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Mwisasasasa! Nothing you say will sway her! Fumino and I have bonded through our indubitable friendship! Right, Fumino? Indubi☆”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“美岬岬岬！不管橘同学你怎么说都没用的！我跟文乃可是有着原来原来般的友情喔！对吧、文乃酱！原来☆”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「美岬岬岬！不管橘同學你怎麼說都沒用的！我跟文乃可是有著原來原來般的友情喔！對吧、文乃醬！原來☆」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00227",
		linknext = "0096_00229",
		line = 3575,
	},
	["0096_00229"] = {
