	},
	["0096_00010"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Here on Seiran Island, beaches have traditionally been a place to have sex. Not a bathing beach, but a “banging beach”, so to speak.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对青蓝岛来说，海滩是一个做爱的地点──这并不是海水浴场，而是一个享受性爱快活的地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對青藍島來說，海灘是一個做愛的地點──這並不是海水浴場，而是一個享受性愛快活的地方。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00009",
		linknext = "0096_00011",
		line = 139,
	},
	["0096_00011"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Although swimming wasn’t banned per se, Hinami, bless her kind heart, didn’t want to be a bother to the beachgoers-slash-sex-havers and kept herself away until now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然这并不代表游泳被禁止了，不过对于体贴的雏见来说，为了不打扰那些享受性爱的人们，她选择了回避在这里游泳的举动。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然這並不代表游泳被禁止了，不過對於體貼的雛見來說，為了不打擾那些享受性愛的人們，她選擇了迴避在這裡游泳的舉動。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00010",
		linknext = "0096_00012",
		line = 149,
	},
	["0096_00012"] = {
