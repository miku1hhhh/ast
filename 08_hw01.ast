	["0096_00223"] = {
		{"cgact", file="cgact", id=17, act="stopact", lv=17, x=0, y=0},
		{"cgdel", id=17, time=0, alphadel=1, lv=17},
		{"cgact", file="cgact", id=18, act="stopact", lv=18, x=0, y=0},
		{"cgdel", id=18, time=0, alphadel=1, lv=18},
		{"fg", file="misaki_01m_00004", file1="misaki_01m_00101", file3="misaki_01m_00303", path=":fg/misaki_01m/", id=6, lv=6, head="misaki_01m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"fg", file="fumino_01m_00004", file1="fumino_01m_00101", file2="fumino_01m_00219", file4="fumino_01m_00403", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=500},
		{"fgact", ch="文乃7", id=7, act="移動", x=-200, y=0, time=800},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0456", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Crabs and hot pot, they can’t be beat, but where would Fumino like to eat crab?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“说到螃蟹，文乃酱最喜欢的螃蟹是什么呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
