	["0096_00263"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The crowd gives her conflicting directions, but Hotori ignores them all and heads straight towards the watermelon.",
					{"rt2"},
				},
			},
			cn = {
				{
					"每个人都在叫喊着，不过畔没有听任何人的指示，直直朝着西瓜的方向前进。",
					{"rt2"},
				},
			},
			tw = {
				{
					"每個人都在叫喊著，不過畔沒有聽任何人的指示，直直朝著西瓜的方向前進。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00262",
