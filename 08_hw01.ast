			},
			cn = {
				{
					name = {"礼"},
					"“用击铁之声敲开那些放肆午睡的懒惰之人的眼吧！让他们瞧瞧主人归来的时刻！全队扫射！上啊──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「用擊鐵之聲敲開那些放肆午睡的懶惰之人的眼吧！讓他們瞧瞧主人歸來的時刻！全隊掃射！上啊──」",
					{"rt2"},
				},
			},
		},
