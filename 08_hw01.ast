			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“美岬酱你没事吧！？哇啊、她像鸵鸟一样从嘴巴里喷出水来了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「美岬醬妳沒事吧！？哇啊、她像鴕鳥一樣從嘴巴裡噴出水來了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00206",
		linknext = "0096_00208",
		line = 3261,
	},
	["0096_00208"] = {
		{"fg", file="jun_01f_00004", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Let me see... Yup, she’s fine. She’s Hotori.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我看看⋯⋯嗯，因为她是畔，所以没事的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我看看⋯⋯嗯，因為她是畔，所以沒事的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00207",
		linknext = "0096_00209",
		line = 3273,
	},
	["0096_00209"] = {
		{"fg", file="rei_01m_00004", file1="rei_01m_00101", file2="rei_01m_00201", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[2700] = {
				{"fg", file="rei_01m_00004", file1="rei_01m_00101", file2="rei_01m_00207", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=76, delay2=2700, mode=3, x=-405, y=-5},
			},
			[2699] = {
				{"transitiontime", time=300, timestamp=76, delay2=2700},
			},
		},
		text = {
			vo = {
				{"vo", file="rei2121", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I agree. No need to worry about her, Hinami. If anything, studies show that your chances of survival increase when you fall into water.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“也是的⋯⋯看样子是没问题了。雏见你不用担心，有统计说要是有什么紧急时刻，掉进水里面的生存机率会比较高喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「也是的⋯⋯看樣子是沒問題了。雛見妳不用擔心，有統計說要是有什麼緊急時刻，掉進水裡面的生存機率會比較高喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00208",
		linknext = "0096_00210",
		line = 3290,
	},
	["0096_00210"] = {
		{"fg", file="jun_01f_00004", file2="jun_01f_00214", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That’s only in tokusatsu dramas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“根本没有人在讲特摄的事啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「根本沒有人在講特攝的事啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00209",
		linknext = "0096_00211",
		line = 3302,
	},
	["0096_00211"] = {
		{"fgact", ch="礼9", id=9, lv=9, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"fgact", ch="ヒナミ5", id=5, lv=5, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"fg", file="jun_01f_00004", file2="jun_01f_00219", path=":fg/jun_01f/", id=30, ch="淳之介", lv=7, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		delay = {
			[300] = {
				{"fg", file="fumino_01m_00004", file1="fumino_01m_00101", file2="fumino_01m_00201", file4="fumino_01m_00403", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", alpha=0, ch_origin="文乃", ch="文乃7", mw="mw", sync=1, timestamp=77, delay2=300, a_chr151=1, mode=3, x=-5, y=-5},
				{"fgact", ch="文乃7", id=7, lv=7, act="表示アクション", a1=0, a2=255, time=300, a_chr=151, timestamp=77, delay2=300, alpha=255},
			},
		},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“By the way, Fumino, are you fine swimming with that eyepatch on?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过⋯⋯文乃带着那个眼罩能游泳吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過⋯⋯文乃帶著那個眼罩能游泳嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00210",
		linknext = "0096_00212",
		line = 3320,
	},
	["0096_00212"] = {
		{"fg", file="fumino_01m_00004", file1="fumino_01m_00101", file2="fumino_01m_00207", file4="fumino_01m_00403", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0309", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I’m fine with just watching everyone else having fun.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我⋯⋯只要看到大家开心就很满足了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我⋯⋯只要看到大家開心就很滿足了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00211",
		linknext = "0096_00213",
		line = 3335,
	},
	["0096_00213"] = {
		{"fg", file="fumino_01m_00004", file1="fumino_01m_00101", file2="fumino_01m_00201", file4="fumino_01m_00403", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0310", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Besides, there are other ways to enjoy yourself at the beach without getting in the water.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“而且，就算不下水⋯⋯在沙滩上也有很多有趣的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「而且，就算不下水⋯⋯在沙灘上也有很多有趣的事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00212",
		linknext = "0096_00214",
		line = 3350,
	},
	["0096_00214"] = {
		{"fg", file="jun_01f_00004", file2="jun_01f_00219", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Like what?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“举个例子？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「舉個例子？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00213",
		linknext = "0096_00215",
		line = 3362,
	},
	["0096_00215"] = {
		{"fg", file="fumino_01m_00004", file1="fumino_01m_00101", file2="fumino_01m_00219", file4="fumino_01m_00403", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0311", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Staring at crabs.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“看螃蟹⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「看螃蟹⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00214",
		linknext = "0096_00216",
		line = 3377,
	},
	["0096_00216"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Crabs?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“螃蟹⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「螃蟹⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00215",
		linknext = "0096_00217",
		line = 3388,
	},
	["0096_00217"] = {
		{"bgm", stop=1},
		{"fgact", ch="文乃7", id=7, lv=7, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I turn towards where Fumino’s looking, and find a small crab making its way.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我顺着文乃的视线看去，一只小螃蟹正在跨着步横行着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我順著文乃的視線看去，一隻小螃蟹正在跨著步橫行著。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00216",
		linknext = "0096_00218",
		line = 3401,
	},
	["0096_00218"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And then it stops and starts foaming at the mouth.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我正想着它会继续走下去时，螃蟹却停了下来，噗噜噜地吐着泡泡。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我正想著它會繼續走下去時，螃蟹卻停了下來，噗嚕嚕地吐著泡泡。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00217",
		linknext = "0096_00219",
		line = 3411,
	},
	["0096_00219"] = {
		{"fg", file="jun_01f_00004", file2="jun_01f_00214", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
		{"text"},
		text = {
