	["0096_00230"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00102", file2="jun_01f_00206", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You’re indubitably annoying.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这根本就是‘原来霸凌’吧⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這根本就是『原來霸凌』吧⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00229",
		linknext = "0096_00231",
		line = 3603,
	},
	["0096_00231"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s become quite a headache, but at least Fumino now has a friend after being alone for so long.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我很吃惊，不过至今一直孤零零的文乃交到了朋友，那一定也好是一件吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我很吃驚，不過至今一直孤零零的文乃交到了朋友，那一定也好是一件吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00230",
		linknext = "0096_00232",
		line = 3613,
	},
	["0096_00232"] = {
		{"fg", file="misaki_01m_00004", file1="misaki_01m_00101", file2="misaki_01m_00214", path=":fg/misaki_01m/", id=6, lv=6, head="misaki_01m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hotori has always been a borderline lunatic, if not a total airhead, but I’ve known her long enough to know that she’s a good person at heart.",
					{"rt2"},
				},
			},
			cn = {
				{
					"畔虽然是个多少有点不太正常的傻妞，不过相处一段时间就会知道她其实对朋友很照顾。",
					{"rt2"},
				},
			},
			tw = {
				{
					"畔雖然是個多少有點不太正常的傻妞，不過相處一段時間就會知道她其實對朋友很照顧。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00231",
		linknext = "0096_00233",
		line = 3626,
	},
	["0096_00233"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mild-mannered Fumino and Hotori the charming lunatic; they may seem an odd couple, but they just might make a pretty good team.",
					{"rt2"},
				},
			},
			cn = {
				{
					"深藏不漏的文乃跟怪胎工具人的畔──就如同字面上的是对不搭嘎的朋友，不过搞不好她们意外得合得来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"深藏不漏的文乃跟怪胎工具人的畔──就如同字面上的是對不搭嘎的朋友，不過搞不好她們意外得合得來。",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00232",
		linknext = "0096_00234",
		line = 3636,
	},
	["0096_00234"] = {
		{"fg", mode=-1, id=6, ch="美岬6", ch_origin="美岬", lv=6, time=0, sync=0},
		{"fg", mode=-1, id=7, ch="文乃7", ch_origin="文乃", lv=7, time=0, sync=0},
		{"fg", file="nanase_01m_00009", file1="nanase_01m_00101", file2="nanase_01m_00219", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0962", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“By the way, where’s Asa? Home?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“话说回来，麻沙酱呢？在家吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「話說回來，麻沙醬呢？在家嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00233",
		linknext = "0096_00235",
		line = 3654,
	},
	["0096_00235"] = {
		{"fg", file="jun_01f_00004", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I did invite her, but she said she’s too sleepy and didn’t want to go outside.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我有叫她一起来，不过她说她困了不想要出门。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我有叫她一起來，不過她說她睏了不想要出門。」",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00234",
		linknext = "0096_00236",
		line = 3666,
	},
	["0096_00236"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But maybe she’ll change her mind if she finds out that Nanase is here in her swimsuit. I’ll give her a call.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过要是跟她说这里有穿着泳装的奈奈濑在，她搞不好会以光速飞奔而来──我要不要打个电话试试？",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過要是跟她說這裡有穿著泳裝的奈奈瀨在，她搞不好會以光速飛奔而來──我要不要打個電話試試？",
					{"rt2"},
				},
			},
		},
		linkback = "0096_00235",
		linknext = "0096_00237",
		line = 3676,
	},
