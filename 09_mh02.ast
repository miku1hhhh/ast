	["0102_00040"] = {
		{"bgm", file="bgm21", vol=100},
		{"bg", id=7, file="bg19_1l_00000", x=-470, y=0, lv=7, path=":bg/", sync=0, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="asane_02l_00008", file1="asane_02l_00101", file2="asane_02l_00229", path=":fg/asane_02l/", id=8, lv=8, head="asane_02l", ch_origin="麻沙音", ch="麻沙音8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1396", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Our story starts with poor Misaki Hotori, Seiran Island nympho. Misaki leaves the island, gets into trouble with some mainland dudes, and then finds herself sentenced to death.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“楚楚可怜的畔美岬。剧情大纲⋯⋯住在本岛的公务员们将住在青蓝岛上的狂人畔美岬带离了岛，但想到事情会变得一发不可收拾，于是决定杀了她。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「楚楚可憐的畔美岬。劇情大綱⋯⋯住在本島的公務員們將住在青藍島上的狂人畔美岬帶離了島，但想到事情會變得一發不可收拾，於是決定殺了她。」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00039",
		linknext = "0102_00041",
		line = 686,
	},
	["0102_00041"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", file2="misaki_01m_00214", path=":fg/misaki_01m/", id=6, lv=6, head="misaki_01m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"fg", file="asane_02l_00008", file1="asane_02l_00101", file2="asane_02l_00203", path=":fg/asane_02l/", id=8, lv=8, head="asane_02l", ch_origin="麻沙音", ch="麻沙音8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1397", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“A guard forces Misaki Hotori to eat poisoned food. However, she is not destined for death this day. They try mixing poisons from all over the world, but she only grows fatter and fatter...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“负责喂食畔美岬的人将毒掺入食物中后喂她吃⋯⋯结果她却没死成。之后尝试喂食她来自世界各地的剧毒，没想到畔美岬就只是越变越胖而已⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「負責餵食畔美岬的人將毒摻入食物中後餵她吃⋯⋯結果她卻沒死成。之後嘗試餵食她來自世界各地的劇毒，沒想到畔美岬就只是越變越胖而已⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00040",
		linknext = "0102_00042",
