	["0102_00158"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00211", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don’t try to copy her. She’s her, and you’re you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就算你装得很像也是没用的。美岬就是美岬，郁子就是郁子啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就算妳裝得很像也是沒用的。美岬就是美岬，郁子就是郁子啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00157",
		linknext = "0102_00159",
		line = 2533,
	},
	["0102_00159"] = {
