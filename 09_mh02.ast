		text = {
			vo = {
				{"vo", file="asane1398", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Crying, she then faces a firing squad, but her thick subcutaneous fat renders the bullets useless. They then try administrating deadly poison anally, but she remains a vibrant beacon of health.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不甘愿地打算用枪射杀她，结果因为皮下脂肪太厚子弹无法穿透⋯⋯后来试着将剧毒从穴穴中塞入体内⋯⋯结果她还是活绷乱跳⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不甘願地打算用槍射殺她，結果因為皮下脂肪太厚子彈無法穿透⋯⋯後來試著將劇毒從穴穴中塞入體內⋯⋯結果她還是活繃亂跳⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00041",
		linknext = "0102_00043",
		line = 721,
	},
	["0102_00043"] = {
		{"fg", file="asane_02l_00008", file1="asane_02l_00101", file2="asane_02l_00221", path=":fg/asane_02l/", id=8, lv=8, head="asane_02l", ch_origin="麻沙音", ch="麻沙音8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1399", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“That’s right, listeners, she consumed so much poison it gave her immunity. Misaki Hotori’s flesh, fat, and blood became immortal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“后来，那些试过的毒药让她的身体产生了抗毒性，最后畔美岬变成了不死之身⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「後來，那些試過的毒藥讓她的身體產生了抗毒性，最後畔美岬變成了不死之身⋯⋯」",
					{"rt2"},
				},
			},
		},
