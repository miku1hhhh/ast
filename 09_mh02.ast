			cn = {
				{
					name = {"麻沙音"},
					"“喔～～怎么到了要反驳的时候，脑筋倒是转得很快嘛。你动脑的方式一定有问题！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「喔～～怎麼到了要反駁的時候，腦筋倒是轉得很快嘛。妳動腦的方式一定有問題！」",
					{"rt2"},
				},
			},
		},
