			en = {
				{
					name = {"美岬", "Misaki"},
					"“But ‘Fatty Angel’ is too short for a title and lacks impact.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“但是，标题只用‘-[|天使（肥仔]）’的话太短了，不太有冲击力耶。”",
