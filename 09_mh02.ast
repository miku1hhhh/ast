					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If I were to choose a word to describe you, I’d call you an angel.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过对我来说，美岬就是‘天使’般的存在啊──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過對我來說，美岬就是『天使』般的存在啊──」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00083",
		linknext = "0102_00085",
		line = 1386,
	},
	["0102_00085"] = {
