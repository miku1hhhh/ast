		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Following the sexual mayhem, new FS members filled the ranks. They all look familiar to me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"FS成员中似乎也有做爱骚动后，新加入的人在。我对她们还有点印象。",
					{"rt2"},
				},
			},
			tw = {
				{
					"FS成員中似乎也有做愛騷動後，新加入的人在。我對她們還有點印象。",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00171",
		linknext = "0102_00173",
