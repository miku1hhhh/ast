		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Since the location is Seiran Island... How does, ‘An Island like a Nukige’ sound?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就设定是在青蓝岛发生的事⋯⋯‘下体升级岛’这个如何？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就設定是在青藍島發生的事⋯⋯『下體升級島』這個如何？」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00090",
