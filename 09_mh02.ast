					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「今天的主角是各位前來的觀眾們，我們飾演壞蛋⋯⋯為了讓各位更入戲，我們會壞得很徹底的！」",
					{"rt2"},
				},
			},
		},
