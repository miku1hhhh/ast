	},
	["0102_00173"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I remember that tall, cheerful girl failing to cure my brainwashing when I became severely impotent from loving Misaki so much.",
					{"rt2"},
				},
			},
			cn = {
				{
					"像那个子高高活泼开朗的女生，我还记得她因为太爱美岬变成重度阳痿时，结果要解除洗脑状态时还失败过一次呢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"像那個子高高活潑開朗的女生，我還記得她因為太愛美岬變成重度陽痿時，結果要解除洗腦狀態時還失敗過一次呢。",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00172",
		linknext = "0102_00174",
		line = 2764,
	},
	["0102_00174"] = {
		{"text"},
		text = {
