			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Yeah. Hmm... I think I can match your voice and body type, but that hair...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“是呀。嗯⋯⋯要我认真的话，不管是声音还是体型我都有办法装，但是发型的部分⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「是呀。嗯⋯⋯要我認真的話，不管是聲音還是體型我都有辦法裝，但是髮型的部分⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00156",
		linknext = "0102_00158",
