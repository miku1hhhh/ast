			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Even if humanity and all other life forms were to go extinct, Misaki Hotori would live on as the sole living being in the universe.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
