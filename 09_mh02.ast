	["0102_00148"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ikuko Onabuta... Out of all my friends, the perverted law has affected her the most.",
					{"rt2"},
				},
			},
			cn = {
				{
					"女部田郁子──在我所有的朋友之中，最受变态条例影响的少女。",
					{"rt2"},
				},
			},
			tw = {
				{
					"女部田郁子──在我所有的朋友之中，最受變態條例影響的少女。",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00147",
		linknext = "0102_00149",
		line = 2400,
	},
	["0102_00149"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She still complains about it how the Yakuza were crushed and the perverted law abolished.",
					{"rt2"},
				},
			},
			cn = {
				{
					"打倒了黑道联盟，抹消了变态条例──直到现在，对此不满的声音依旧时有耳闻。",
					{"rt2"},
				},
			},
			tw = {
				{
					"打倒了黑道聯盟，抹消了變態條例──直到現在，對此不滿的聲音依舊時有耳聞。",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00148",
		linknext = "0102_00150",
		line = 2410,
	},
	["0102_00150"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Despite her dissatisfaction, Ikuko still finds Seiran Island comforting.",
					{"rt2"},
				},
			},
			cn = {
				{
					"尽管如此，感谢郁子说出现在的青蓝岛很适合待着这样的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"儘管如此，感謝郁子說出現在的青藍島很適合待著這樣的話。",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00149",
		linknext = "0102_00151",
		line = 2420,
	},
	["0102_00151"] = {
