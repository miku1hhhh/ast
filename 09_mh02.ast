	["0102_00096"] = {
		{"fg", file="asane_02m_00008", file1="asane_02m_00101", file2="asane_02m_00203", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1407", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You’re getting way ahead of yourself here. You’re like a naive wannabe fantasizing about being interviewed for the anime version before you’ve even written the book yet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“都还没开始弄，就说看到完成的样子，真是太天真了。你是连小说都还没开始写，就已经妄想着可以动漫化，甚至在准备受访内容的做梦仔吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「都還沒開始弄，就說看到完成的樣子，真是太天真了。你是連小說都還沒開始寫，就已經妄想著可以動漫化，甚至在準備受訪內容的做夢仔嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00095",
		linknext = "0102_00097",
		line = 1561,
	},
	["0102_00097"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00203", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
