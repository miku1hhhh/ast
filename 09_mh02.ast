				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You’re right... We still don’t have anyone in charge of the crucial system programming or the script.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这倒是真的⋯⋯被你这么一说才想到，游戏程式部分和台词还没人负责呢⋯⋯”",
