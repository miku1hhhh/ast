				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I also recall the geeky guy in the glasses squirting semen while spouting stats for the events during the Olympiad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后戴着眼镜看起来很知性的那个男生，在体欲祭上比赛的时候，一边讲什么数据啊什么的一边射精的样子，我还有印象呢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後戴著眼鏡看起來很知性的那個男生，在體慾祭上比賽的時候，一邊講什麼數據啊什麼的一邊射精的樣子，我還有印象呢。",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00173",
		linknext = "0102_00175",
		line = 2774,
