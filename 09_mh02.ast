			},
			en = {
				{
					"And if that’s because of me, I’m all the happier.",
					{"rt2"},
				},
			},
			cn = {
				{
					"还说那都多亏有我──没有比这个更令人开心的事了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"還說那都多虧有我──沒有比這個更令人開心的事了。",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00082",
		linknext = "0102_00084",
		line = 1374,
	},
	["0102_00084"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00211", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
