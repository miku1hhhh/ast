					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Yup. I didn’t even ask, but she kept going on and on about the nuances of different ways to shout out ‘Transform!’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“没错。也没问她，她就自顾自地讲起了‘变身’的不同说法，相当投入呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「沒錯。也沒問她，她就自顧自地講起了『變身』的不同說法，相當投入呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00141",
		linknext = "0102_00143",
		line = 2314,
	},
