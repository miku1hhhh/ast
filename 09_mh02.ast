		{"fg", file="misaki_02m_00001", file1="misaki_02m_00103", file2="misaki_02m_00209", path=":fg/misaki_02m/", id=6, lv=7, head="misaki_02m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0669", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Wh-what is it? Do I have fat on my face or something?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“怎、怎么了吗？我哪里长肉了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「怎、怎麼了嗎？我哪裡長肉了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00155",
		linknext = "0102_00157",
		line = 2503,
	},
	["0102_00157"] = {
