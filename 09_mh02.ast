			},
		},
		text = {
			vo = {
				{"vo", file="ikuko2130", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Even Rei got weirdly excited, saying ‘So we’re performing a hero show?!’ Her constantly yelling ‘Transform! Transform!’ every day has been so aggravating.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“礼酱还直呼‘这就是要我们办英雄秀吧！？’每天很嗨的在那边变身来变身去的喊，有点聒噪呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「禮醬還直呼『這就是要我們辦英雄秀吧！？』每天很嗨的在那邊變身來變身去的喊，有點聒噪呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00139",
		linknext = "0102_00141",
		line = 2287,
	},
	["0102_00141"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00219", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh? Didn’t know she liked that kind of thing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哇⋯⋯风纪委员长原来喜欢这种啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哇⋯⋯風紀委員長原來喜歡這種啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0102_00140",
		linknext = "0102_00142",
		line = 2299,
	},
	["0102_00142"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file3="ikuko_02m_00306", path=":fg/ikuko_02m/", id=10, lv=6, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=395, y=-5},
