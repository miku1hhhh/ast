				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That I can hear her say that makes me deeply happy that we joined hands and cooperated with the islanders.",
					{"rt2"},
				},
			},
			cn = {
				{
					"听到这番话，让我打心底觉得能够和郁子，以及其他岛民合作真是太好了──",
					{"rt2"},
				},
			},
			tw = {
				{
					"聽到這番話，讓我打心底覺得能夠和郁子，以及其他島民合作真是太好了──",
					{"rt2"},
				},
			},
		},
