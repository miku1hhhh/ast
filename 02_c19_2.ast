	["0038_00113"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I only shake my head and close my eyes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但我摇了摇头，闭上了眼睛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但我搖了搖頭，閉上了眼睛。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00112",
		linknext = "0038_00114",
		line = 1396,
	},
	["0038_00114"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I already told Fumino I’d let her handle the rest.",
					{"rt2"},
				},
			},
			cn = {
				{
					"后续的事，我说了我会把一切都交给文乃的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"後續的事，我說了我會把一切都交給文乃的。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00113",
		linknext = "0038_00115",
		line = 1406,
	},
	["0038_00115"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00102", file2="fumino_01m_00211", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0087", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“It has been some time... Has it been years since we last properly spoke...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“好久不见、您了⋯⋯像这样、与您好好对话⋯⋯也已经好几年不曾有了吧⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「好久不見、您了⋯⋯像這樣、與您好好對話⋯⋯也已經好幾年不曾有了吧⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00114",
		linknext = "0038_00116",
		line = 1421,
	},
	["0038_00116"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00102", file2="sakimori_01f_00209", path=":fg/sakimori_01f/", id=30, ch="防人老人", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
