		{"fg", file="fumino_01l_00001", file1="fumino_01l_00101", file2="fumino_01l_00209", path=":fg/fumino_01l/", id=7, lv=7, head="fumino_01l", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0096", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“What...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“欸⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「欸⋯⋯？」",
					{"rt2"},
