	["0038_00161"] = {
		{"cgdel", id=19, lv=19, time=0, alphadel=1},
		{"fg", mode=-1, id=20, ch="文乃20", ch_origin="文乃", lv=20, time=0, sync=0},
		{"bg", id=18, file="pm3_00001", x=0, y=0, lv=18, path=":cg/pm3/", ev=1},
		{"bg", id=10, file="blackback_00000", x=0, y=0, lv=10, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="sakimori_01m_00001", file1="sakimori_01m_00102", file2="sakimori_01m_00213", path=":fg/sakimori_01m/", id=16, lv=16, head="sakimori_01m", ch_origin="防人老人", ch="防人老人16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=1000},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0051", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“But...! No amount of reconciliation will bring back my daughter! So then, what choice do I have but to seek revenge?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘但是⋯⋯！不管你怎么修整，我女儿都回不来了！既然如此，那除了报仇我还能做什么──！？’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『但是⋯⋯！不管你怎麼修整，我女兒都回不來了！既然如此，那除了報仇我還能做什麼──！？』",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00160",
		linknext = "0038_00162",
		line = 2003,
	},
	["0038_00162"] = {
		{"cgdel", id=10, lv=10, time=0, alphadel=1},
		{"fg", mode=-1, id=16, ch="防人老人16", ch_origin="防人老人", lv=16, time=0, sync=0},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"fg", file="jun_01m_00006", file1="jun_01m_00101", file2="jun_01m_00211", path=":fg/jun_01m/", id=2, lv=2, head="jun_01m", ch_origin="淳之介", ch="淳之介2", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I understand, I really do—I know just how much of an empty platitude it sounds like when someone says that revenge is a fruitless thing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这我也知道──说复仇不会产任何结果，这种谎言太巧妙了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這我也知道──說復仇不會產任何結果，這種謊言太巧妙了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00161",
		linknext = "0038_00163",
		line = 2023,
	},
	["0038_00163"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Revenge leads to all kinds of creation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"复仇，会产生各式各样的后果。",
					{"rt2"},
				},
			},
			tw = {
				{
					"復仇，會產生各式各樣的後果。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00162",
		linknext = "0038_00164",
		line = 2033,
	},
	["0038_00164"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In fact... I’d say it ends up creating too much.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不如说，它创造了太多东西。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不如說，它創造了太多東西。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00163",
		linknext = "0038_00165",
		line = 2043,
	},
	["0038_00165"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Resentment, hatred, spite...",
					{"rt2"},
				},
			},
			cn = {
				{
					"恨、憎、怨⋯⋯",
					{"rt2"},
				},
			},
			tw = {
				{
					"恨、憎、怨⋯⋯",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00164",
		linknext = "0038_00166",
		line = 2053,
	},
	["0038_00166"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And those in turn gave birth... to Junnosuke Tachibana, to Sakimori.",
					{"rt2"},
				},
			},
			cn = {
				{
					"借此而催生出的⋯⋯是像橘淳之介、又或者驻防老人之流。",
					{"rt2"},
				},
			},
			tw = {
				{
					"藉此而催生出的⋯⋯是像橘淳之介、又或者駐防老人之流。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00165",
		linknext = "0038_00167",
		line = 2063,
	},
	["0038_00167"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Those are what gave us life.",
					{"rt2"},
				},
			},
			cn = {
				{
					"依附着它们，我们才得以生存。",
					{"rt2"},
				},
			},
			tw = {
				{
					"依附著它們，我們才得以生存。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00166",
		linknext = "0038_00168",
		line = 2073,
	},
	["0038_00168"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No... They’re what kept us alive.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不，是它们吸食着我们而生。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不，是它們吸食著我們而生。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00167",
		linknext = "0038_00169",
		line = 2083,
	},
	["0038_00169"] = {
		{"fg", file="jun_01m_00006", file1="jun_01m_00101", file2="jun_01m_00203", path=":fg/jun_01m/", id=2, lv=2, head="jun_01m", ch_origin="淳之介", ch="淳之介2", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But that’s exactly why we need to think about the weight of what we could end up creating.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这就是为什么，我们处于必须谨慎考虑创造物重量的位置。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這就是為什麼，我們處於必須謹慎考慮創造物重量的位置。」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00168",
		linknext = "0038_00170",
		line = 2097,
	},
	["0038_00170"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The pros and cons of revenge.",
					{"rt2"},
				},
			},
			cn = {
				{
					"复仇的是与非。",
					{"rt2"},
				},
			},
			tw = {
				{
					"復仇的是與非。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00169",
		linknext = "0038_00171",
		line = 2107,
	},
	["0038_00171"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Something decided by the feelings of those left behind.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这取决于被留下来的人的感受。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這取決於被留下來的人的感受。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00170",
		linknext = "0038_00172",
		line = 2117,
	},
	["0038_00172"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Revenge on its own isn’t a bad thing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因此复仇本身，并非是坏事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因此復仇本身，並非是壞事。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00171",
		linknext = "0038_00173",
		line = 2127,
	},
	["0038_00173"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We have no right to criticize the very concept of it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为复仇本身，并没不具这种批判的权利。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為復仇本身，並沒不具這種批判的權利。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00172",
		linknext = "0038_00174",
		line = 2137,
	},
	["0038_00174"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No living person does. I’m sure of that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这对于所有活着的人来说，无庸置疑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這對於所有活著的人來說，無庸置疑。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00173",
		linknext = "0038_00175",
		line = 2147,
	},
	["0038_00175"] = {
		{"fg", file="jun_01m_00006", file1="jun_01m_00101", file2="jun_01m_00203", path=":fg/jun_01m/", id=2, lv=2, head="jun_01m", ch_origin="淳之介", ch="淳之介2", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But so many people will lose their livelihood if we get our revenge. So many minorities who’ve always felt alone will lose a place where they can go.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但如果我们报复，很多人将失去工作。继续感到孤独的少数群体将无处可去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但如果我們報復，很多人將失去工作。繼續感到孤獨的少數群體將無處可去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00174",
		linknext = "0038_00176",
		line = 2161,
	},
	["0038_00176"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00102", file2="sakimori_01f_00203", path=":fg/sakimori_01f/", id=30, ch="防人老人", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0052", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Good, then! Of course they will! Do I not have the right to do that?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘那样最好──！那样不是当然的吗！我有这个报仇的权利！’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『那樣最好──！那樣不是當然的嗎！我有這個報仇的權利！』",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00175",
		linknext = "0038_00177",
		line = 2174,
	},
	["0038_00177"] = {
		{"fg", file="jun_01m_00006", file1="jun_01m_00101", file3="jun_01m_00307", path=":fg/jun_01m/", id=2, lv=2, head="jun_01m", ch_origin="淳之介", ch="淳之介2", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There is no such thing in this world as justified revenge!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这世界上并不存在着正当的复仇──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這世界上並不存在著正當的復仇──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00176",
		linknext = "0038_00178",
		line = 2188,
	},
	["0038_00178"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Revenge isn’t an evil thing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"复仇并非恶事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"復仇並非惡事。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00177",
		linknext = "0038_00179",
		line = 2198,
	},
	["0038_00179"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But there’s nothing justifiable about it either.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，它也没有所谓的正当性。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，它也沒有所謂的正當性。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00178",
		linknext = "0038_00180",
		line = 2208,
	},
	["0038_00180"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The idea of justified revenge that Touka once approached me with...",
					{"rt2"},
				},
			},
			cn = {
				{
					"像过去桐香所说的那样正当的报复──",
					{"rt2"},
				},
			},
			tw = {
				{
					"像過去桐香所說的那樣正當的報復──",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00179",
		linknext = "0038_00181",
		line = 2218,
	},
	["0038_00181"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It doesn’t exist. Anywhere.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那种东西，根本就不存在。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那種東西，根本就不存在。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00180",
		linknext = "0038_00182",
		line = 2228,
	},
	["0038_00182"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No matter how well you might frame it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无论我多么努力地修复它，最终还是如此。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無論我多麼努力地修復它，最終還是如此。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00181",
		linknext = "0038_00183",
		line = 2238,
	},
	["0038_00183"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s going to be nothing more than selfish, unexamined hatred.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没有什么可反省的，因为那仅只是一种利己主义的恩怨。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒有什麼可反省的，因為那僅只是一種利己主義的恩怨。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00182",
		linknext = "0038_00184",
		line = 2248,
	},
	["0038_00184"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We don’t have the right to carry out any kind of justified revenge! But there’s no such thing as the right to not take revenge either!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们没有报复的权利！但也没有不报复的权利！权利这种东西根本不存在──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們沒有報復的權利！但也沒有不報復的權利！權利這種東西根本不存在──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00183",
		linknext = "0038_00185",
		line = 2259,
	},
	["0038_00185"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"You can’t justify revenge with something like that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不能借着它，来正当化复仇行为。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不能借著它，來正當化復仇行為。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00184",
		linknext = "0038_00186",
		line = 2269,
	},
	["0038_00186"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even so, you can’t stop someone else from taking it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以也不能以它，来阻止任何复仇行为。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以也不能以它，來阻止任何復仇行為。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00185",
		linknext = "0038_00187",
		line = 2279,
	},
	["0038_00187"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Only you can stop yourself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"复仇这种事──除了自己以外，谁也不能阻止。",
					{"rt2"},
				},
			},
			tw = {
				{
					"復仇這種事──除了自己以外，誰也不能阻止。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00186",
		linknext = "0038_00188",
		line = 2289,
	},
	["0038_00188"] = {
		{"fg", file="jun_01m_00006", file1="jun_01m_00101", file3="jun_01m_00304", path=":fg/jun_01m/", id=2, lv=2, head="jun_01m", ch_origin="淳之介", ch="淳之介2", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We need to take our own self-respect and evaluate it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以我们才得要好好权衡一下自己的尊严！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以我們才得要好好權衡一下自己的尊嚴！」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00187",
		linknext = "0038_00189",
		line = 2303,
	},
	["0038_00189"] = {
		{"fg", file="jun_01m_00006", file1="jun_01m_00101", file3="jun_01m_00306", path=":fg/jun_01m/", id=2, lv=2, head="jun_01m", ch_origin="淳之介", ch="淳之介2", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Do we carry out our revenge and settle the score at last?! Or...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是先去报仇，还是先洗清自己的遗憾！又或者──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是先去報仇，還是先洗清自己的遺憾！又或者──」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00188",
		linknext = "0038_00190",
		line = 2317,
	},
	["0038_00190"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", file="jun_01m_00006", file1="jun_01m_00101", file3="jun_01m_00307", path=":fg/jun_01m/", id=2, lv=2, head="jun_01m", ch_origin="淳之介", ch="淳之介2", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="淳之介2", id=2, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...Or do we turn our ear to the wishes of those left behind and make them a reality?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“──又或者，去实现剩下的愿望。！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「──又或者，去實現剩下的願望。！」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00189",
		linknext = "0038_00191",
		line = 2333,
	},
	["0038_00191"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"You have to first weigh those against one another...",
					{"rt2"},
				},
			},
			cn = {
				{
					"当所有事物都被放上天秤时──",
					{"rt2"},
				},
			},
			tw = {
				{
					"當所有事物都被放上天秤時──",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00190",
		linknext = "0038_00192",
		line = 2343,
	},
	["0038_00192"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...And that’s when those left behind can decide on the wrongs and rights of revenge.",
					{"rt2"},
				},
			},
			cn = {
				{
					"──复仇的对错，就必须由留下的人来决定。",
					{"rt2"},
				},
			},
			tw = {
				{
					"──復仇的對錯，就必須由留下的人來決定。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00191",
		linknext = "0038_00193",
		line = 2353,
	},
	["0038_00193"] = {
		{"fg", file="jun_01m_00006", file1="jun_01m_00101", file2="jun_01m_00203", path=":fg/jun_01m/", id=2, lv=2, head="jun_01m", ch_origin="淳之介", ch="淳之介2", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“My decision... is that I want to see the world this girl wishes for.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我啊──决定要看看这她想要的世界。”",
					{"rt2"},
				},
			},
			tw = {
