	["0038_00112"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino looks at me with a little distress.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃用略带不安的表情看着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃用略帶不安的表情看著我。",
					{"rt2"},
				},
