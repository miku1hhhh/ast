	["0038_00149"] = {
		{"cgdel", id=2, lv=2, time=0, alphadel=1},
		{"fg", mode=-1, id=7, ch="文乃7", ch_origin="文乃", lv=7, time=0, sync=0},
		{"fg", file="jun_01m_00006", file1="jun_01m_00101", file2="jun_01m_00203", path=":fg/jun_01m/", id=2, lv=2, head="jun_01m", ch_origin="淳之介", ch="淳之介2", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I just can’t bring myself to forgive the people who took someone so special to me away—the people who took Fumino’s mother.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我不能原谅那些，从我最珍惜的人──文乃你的母亲给夺走的岛民们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我不能原諒那些，從我最珍惜的人──文乃妳的母親給奪走的島民們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00148",
		linknext = "0038_00150",
		line = 1860,
	},
	["0038_00150"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just thinking about it still makes my blood boil.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即便是现在，光是想起来我的胃都会翻腾。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即便是現在，光是想起來我的胃都會翻騰。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00149",
		linknext = "0038_00151",
		line = 1870,
	},
	["0038_00151"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’m overcome with the impulse to beat down every last one of them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"每个人都都被想要揍人的冲动给驱使。",
					{"rt2"},
				},
			},
			tw = {
				{
					"每個人都都被想要揍人的衝動給驅使。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00150",
		linknext = "0038_00152",
		line = 1880,
	},
	["0038_00152"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Those dim flames continue to smolder within me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那股晦暗的火焰仍在我体内闷烧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那股晦暗的火焰仍在我體內悶燒。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00151",
		linknext = "0038_00153",
		line = 1890,
	},
	["0038_00153"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even in World A, a place that we should have made peaceful again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算是在身在恢复和平的A世界里也一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算是在身在恢復和平的A世界裡也一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00152",
		linknext = "0038_00154",
		line = 1900,
	},
	["0038_00154"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But... But still.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过──可是、然而。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過──可是、然而。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00153",
		linknext = "0038_00155",
		line = 1910,
	},
	["0038_00155"] = {
		{"fg", file="jun_01m_00006", file1="jun_01m_00101", file2="jun_01m_00211", path=":fg/jun_01m/", id=2, lv=2, head="jun_01m", ch_origin="淳之介", ch="淳之介2", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But if the one and only child she left behind—if Fumino says she wishes for coexistence.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但如果那个人的唯一的孩子──文乃你想要共存的话。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但如果那個人的唯一的孩子──文乃妳想要共存的話。」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00154",
		linknext = "0038_00156",
		line = 1924,
	},
	["0038_00156"] = {
		{"fg", file="jun_01m_00006", file1="jun_01m_00101", file2="jun_01m_00204", path=":fg/jun_01m/", id=2, lv=2, head="jun_01m", ch_origin="淳之介", ch="淳之介2", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Then I will fight anyone and everyone who threatens that. Including you, Sakimori.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我试着去威胁、与他们为敌。驻防老先生，你也一样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我試著去威脅、與他們為敵。駐防老先生，你也一樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00155",
		linknext = "0038_00157",
		line = 1938,
	},
	["0038_00157"] = {
		{"bg", id=19, file="bg29_2l_00000", x=-400, y=0, lv=19, path=":bg/", sync=0, style="blur", blurx=11, blury=11, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00101", file2="fumino_01l_00209", path=":fg/fumino_01l/", id=20, lv=20, head="fumino_01l", ch_origin="文乃", ch="文乃20", mw="mw", sync=0, mode=3, x=-5, y=-5},
