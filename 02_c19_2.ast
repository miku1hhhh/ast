	["0038_00143"] = {
		{"fg", file="sakimori_01m_00001", file1="sakimori_01m_00102", file2="sakimori_01m_00213", path=":fg/sakimori_01m/", id=16, lv=16, head="sakimori_01m", ch_origin="防人老人", ch="防人老人16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0050", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“I refuse to accept this! I don’t care what happens, I will never let those who killed my daughter get away with what they’ve done!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘我不能接受！无论发生什么，我都不能原谅害死我女儿的人──！’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『我不能接受！無論發生什麼，我都不能原諒害死我女兒的人──！』",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00142",
