	["0038_00159"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Yes, I guess you wouldn’t know in this world.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是啊，这个世界的你并不知道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是啊，這個世界的妳並不知道。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00158",
		linknext = "0038_00160",
		line = 1973,
	},
	["0038_00160"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But this is the truth. It’s how I really feel.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这也是来自于我本心的，一个事实。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這也是來自於我本心的，一個事實。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00159",
