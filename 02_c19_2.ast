	["0038_00137"] = {
		{"bgm", file="bgm22.5", vol=100},
		{"bg", id=18, file="pm3_00001", x=0, y=0, lv=18, path=":cg/pm3/", ev=1},
		{"bg", id=10, file="blackback_00000", x=0, y=0, lv=10, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="sakimori_01m_00001", file1="sakimori_01m_00102", file2="sakimori_01m_00203", path=":fg/sakimori_01m/", id=16, lv=16, head="sakimori_01m", ch_origin="防人老人", ch="防人老人16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=1000},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0047", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“What’s the meaning of this, boy...?! Did you think you could get me to change my mind with that girl’s sob story?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘小子⋯⋯你这是什么意思！？你以为听了小姑娘的哭诉、我就会改变主意吗──！？’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『小子⋯⋯你這是什麼意思！？你以為聽了小姑娘的哭訴、我就會改變主意嗎──！？』",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00136",
		linknext = "0038_00138",
		line = 1695,
	},
	["0038_00138"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That’s not what this is.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不是的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不是的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00137",
		linknext = "0038_00139",
		line = 1707,
	},
	["0038_00139"] = {
		{"fg", file="sakimori_01m_00001", file1="sakimori_01m_00102", file2="sakimori_01m_00213", path=":fg/sakimori_01m/", id=16, lv=16, head="sakimori_01m", ch_origin="防人老人", ch="防人老人16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0048", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“It will take more than this to dispel my anger...! I will never forgive those bastards who took away my precious family, my daughter, the happiness I’d finally found!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘这种程度才无法消除我的愤怒⋯⋯！我永远不会原谅那些偷走我宝贵的家人、我的女儿，以及我好不容易得到的幸福的人──！’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『這種程度才無法消除我的憤怒⋯⋯！我永遠不會原諒那些偷走我寶貴的家人、我的女兒，以及我好不容易得到的幸福的人──！』",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00138",
		linknext = "0038_00140",
		line = 1722,
	},
	["0038_00140"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I know.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我知道。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我知道。」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00139",
		linknext = "0038_00141",
		line = 1734,
	},
	["0038_00141"] = {
		{"fg", file="sakimori_01m_00001", file1="sakimori_01m_00102", file2="sakimori_01m_00215", path=":fg/sakimori_01m/", id=16, lv=16, head="sakimori_01m", ch_origin="防人老人", ch="防人老人16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0049", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“I will get my revenge no matter what! How could I ever forgive somebody who trampled over my daughter and used her as the bedrock of a false stronghold!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘我一定会报仇──！我绝对不能原谅一个践踏我女儿、并以此为基础建造虚构的城池的人！’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『我一定會報仇──！我絕對不能原諒一個踐踏我女兒、並以此為基礎建造虛構的城池的人！』",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00140",
		linknext = "0038_00142",
		line = 1749,
	},
	["0038_00142"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
