	["0038_00117"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The old man stays quiet.",
					{"rt2"},
				},
			},
			cn = {
				{
					"驻防老人默不做声。",
					{"rt2"},
				},
			},
			tw = {
				{
					"駐防老人默不做聲。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00116",
		linknext = "0038_00118",
		line = 1444,
	},
	["0038_00118"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"To him, Fumino is nothing more than the child of the man who stole away his beloved daughter.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对他来说，文乃只不过是夺走了他心爱女儿的男人的孩子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對他來說，文乃只不過是奪走了他心愛女兒的男人的孩子。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00117",
		linknext = "0038_00119",
		line = 1454,
	},
	["0038_00119"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file2="fumino_01m_00210", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0088", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Today... I would like to speak about my mother.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“今天……我想和您谈谈我妈妈的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「今天……我想和您談談我媽媽的事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00118",
		linknext = "0038_00120",
		line = 1469,
	},
	["0038_00120"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...I just can’t bring myself to trust Sakimori, given what he did.",
					{"rt2"},
				},
			},
			cn = {
				{
					"──我果然，还是无法信任，会做出那样子的事来的驻防老人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"──我果然，還是無法信任，會做出那樣子的事來的駐防老人。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00119",
		linknext = "0038_00121",
		line = 1479,
	},
	["0038_00121"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file2="fumino_01m_00203", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0089", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“My mother... My mother’s life on Seiran Island was not what you could call a tranquil one.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我的母亲……她在青蓝岛的生活，并不像我所说的那么平静。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我的母親……她在青藍島的生活，並不像我所說的那麼平靜。」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00120",
		linknext = "0038_00122",
		line = 1494,
	},
	["0038_00122"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But... I did want to give it a try at least once.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是⋯⋯我还是想试一次看看。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是⋯⋯我還是想試一次看看。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00121",
		linknext = "0038_00123",
		line = 1504,
	},
	["0038_00123"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file2="fumino_01m_00215", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0090", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“She lived deep in the mountains to avoid being discovered by my father, and she was despised by the residents as somebody who stood counter to the perverted sex law by selling her body.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“为了让父亲找不到所以在深山里，因为卖身所以被村民鄙视为仇视变态条例的存在。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「為了讓父親找不到所以在深山里，因為賣身所以被村民鄙視為仇視變態條例的存在。」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00122",
		linknext = "0038_00124",
		line = 1519,
	},
	["0038_00124"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I wanted him to try really talking to Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我想让他和文乃好好地谈谈。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我想讓他和文乃好好地談談。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00123",
		linknext = "0038_00125",
		line = 1529,
	},
	["0038_00125"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file3="fumino_01m_00301", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0091", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“But... she was not bothered by any of that. She merely accepted the spectacle before her for what it was with a smile...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“可是妈妈她⋯⋯她根本不在乎这些。她只是挂着笑脸、理所当然地接受了眼前的景象⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「可是媽媽她⋯⋯她根本不在乎這些。她只是掛著笑臉、理所當然地接受了眼前的景象⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00124",
		linknext = "0038_00126",
		line = 1544,
	},
	["0038_00126"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It didn’t have to be right away.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不用马上也没关系。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不用馬上也沒關係。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00125",
		linknext = "0038_00127",
		line = 1554,
	},
	["0038_00127"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file2="fumino_01m_00222", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0092", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“She raised me alone, despite any slander or derision... As though being on the island was enough to bring her joy. As though seeing my distant father was enough to bring her joy...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“即使是一个人抚养我长大、被虐待、被鄙视⋯⋯好像只要在岛上她就很幸福，好像只要她能远远地看着父亲就很幸福那样⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「即使是一個人撫養我長大、被虐待、被鄙視⋯⋯好像只要在島上她就很幸福，好像只要她能遠遠地看著父親就很幸福那樣⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00126",
		linknext = "0038_00128",
		line = 1569,
	},
	["0038_00128"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They didn’t even need to understand one another in the end.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即便结果是互相不理解也没关系。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即便結果是互相不理解也沒關係。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00127",
		linknext = "0038_00129",
		line = 1579,
	},
	["0038_00129"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file2="fumino_01m_00217", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0093", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“My mother resented nobody... Not those who rebuked her, not those who spoke ill of her in secret, not even my father.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“母亲没有对任何人怀恨在心⋯⋯对那些狠狠地打她的人、在背后诽谤和扔石头的人，甚至是父亲──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「母親沒有對任何人懷恨在心⋯⋯對那些狠狠地打她的人、在背後誹謗和扔石頭的人，甚至是父親──」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00128",
		linknext = "0038_00130",
		line = 1594,
	},
	["0038_00130"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I just wanted them to talk.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只是，想好好地谈谈。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只是，想好好地談談。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00129",
		linknext = "0038_00131",
		line = 1604,
	},
	["0038_00131"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file2="fumino_01m_00210", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0094", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“She loved all, just as she loved me... She loved the island my father built with all her heart and showed her affection for it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“她和我一样热爱一切⋯⋯她打从心底热爱并珍惜⋯⋯父亲创造的岛屿。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「她和我一樣熱愛一切⋯⋯她打從心底熱愛並珍惜⋯⋯父親創造的島嶼。」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00130",
		linknext = "0038_00132",
		line = 1619,
	},
	["0038_00132"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Because maybe... just maybe.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也许，也许我们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也許，也許我們。",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00131",
		linknext = "0038_00133",
		line = 1629,
	},
	["0038_00133"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file3="fumino_01m_00304", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0095", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Which is why I—I hope that all on this island can coexist.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“这就是为什么我──我希望所有的一切都能在这个岛上共存。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「這就是為什麼我──我希望所有的一切都能在這個島上共存。」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00132",
		linknext = "0038_00134",
		line = 1644,
	},
	["0038_00134"] = {
