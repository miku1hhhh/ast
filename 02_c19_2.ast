		{"bgm", file="bgm09", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0096", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“...Hello. This is Mizuhiki Akino, FS representative and SHO special auditor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“──大家好，我是代表FS的SHO特别监察官秋野水引。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「──大家好，我是代表FS的SHO特別監察官秋野水引。」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00260",
		linknext = "0038_00262",
		line = 3321,
	},
	["0038_00262"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0097", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“I apologize for taking your valuable time today. However, I have an announcement that I believe you will all be happy to hear.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“很抱歉本次占用了各位宝贵的时间。不过我深信这次的报告内容一定能让各位都感到开心的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「很抱歉本次佔用了各位寶貴的時間。不過我深信這次的報告內容一定能讓各位都感到開心的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00261",
		linknext = "0038_00263",
		line = 3333,
	},
	["0038_00263"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0098", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Recent days have seen one somber news story after the next regarding the traitorous acts carried out by the former FS Big Three and more.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“近来青蓝岛上，不断有如原FS三巨头引发叛乱等负面新闻。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「近來青藍島上，不斷有如原FS三巨頭引發叛亂等負面新聞。」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00262",
		linknext = "0038_00264",
		line = 3345,
	},
	["0038_00264"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0099", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“As such, both the SHO and the FS have decided to carry out a certain project.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“为此，SHO以及FS决定举行某个企划活动。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「為此，SHO以及FS決定舉行某個企劃活動。」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00263",
		linknext = "0038_00265",
		line = 3357,
	},
	["0038_00265"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0100", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Its name is the Battle Whore-for-all—a giant event that takes place across the entire island!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“这个将扩及全岛的大型活动──叫做‘大逃啪’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「這個將擴及全島的大型活動──叫做『大逃啪』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00264",
		linknext = "0038_00266",
		line = 3369,
	},
	["0038_00266"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0101", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“The rules are simple. Participants will bet porn-star chips that will be distributed and commence a fucking bout. The loser will forfeit his or her chips to the winner.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“规则很简单。以分发到的这个‘智慧晶片’作为赌注进行啪啪啪比赛，输的一方交出晶片、赢的一方则可以获得晶片。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「規則很簡單。以分發到的這個『智慧晶片』作為賭注進行啪啪啪比賽，輸的一方交出晶片、贏的一方則可以獲得晶片。」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00265",
		linknext = "0038_00267",
		line = 3381,
	},
	["0038_00267"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0102", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Only those who have collected five of these porn-star chips will earn the right to take part in the challenge at SHO headquarters.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“只要集满5枚智慧晶片，就能获得挑战SHO总部大楼的权利。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「只要集滿5枚智慧晶片，就能獲得挑戰SHO總部大樓的權利。」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00266",
		linknext = "0038_00268",
		line = 3393,
	},
	["0038_00268"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0103", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Waiting there in each floor will be three bosses, heroes from the earlier battle.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“这里共3层、每一层都有一位在上一场战斗中发挥积极作用名英雄作为BOSS应战。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「這裡共3層、每一層都有一位在上一場戰鬥中發揮積極作用名英雄作為BOSS應戰。」",
					{"rt2"},
				},
			},
		},
		linkback = "0038_00267",
		linknext = "0038_00269",
		line = 3405,
	},
	["0038_00269"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0104", path=":vo/", ch="mizuhiki"},
			},
			ja = {
