			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“From this day forth, I ask that you give me whatever instructions you may have... I am your servant and your attendant—I will carry out your orders.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“从今往后，若有什么问题请都跟我说⋯⋯我是服从、是下属──只要大人你的命令，我使命必达。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「從今往後，若有什麼問題請都跟我說⋯⋯我是服從、是下屬──只要大人你的命令，我使命必達。」",
					{"rt2"},
				},
			},
		},
