	},
	["0075_00089"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just like Nanase and Fumika saved me. I wouldn’t trade my friends for the world.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对我来说就是奈奈濑和文歌小姐──还有我无可取代的伙伴们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對我來說就是奈奈瀨和文歌小姐──還有我無可取代的夥伴們。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00088",
