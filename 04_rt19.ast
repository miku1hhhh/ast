					{"rt2"},
				},
			},
			en = {
				{
					"Even if a leader is lacking in certain respects, as long as they work hard, people tend to follow. Like a special brand of charisma.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算少了几根筋，只要那种一心一意的精神──可以说是可爱之处吧，人们就会愿意追随她。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算少了幾根筋，只要那種一心一意的精神──可以說是可愛之處吧，人們就會願意追隨她。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00069",
