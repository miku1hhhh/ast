	["0075_00095"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00224", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1769", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“It’s just a shame that we won’t be able to spend your birthday together. Won’t you be celebrating the holidays with your family?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我想说这样一来，就不能一起过生日了……除夕就是要跟各自的家人过的不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我想說這樣一來，就不能一起過生日了……除夕就是要跟各自的家人過的不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00094",
		linknext = "0075_00096",
		line = 1406,
	},
	["0075_00096"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00219", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Actually, no, I don’t have any plans with family. But even if I did, you’re basically part of the family now, Rei.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
