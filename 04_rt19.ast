	["0075_00064"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00214", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[2000] = {
				{"fg", file="rei_02m_00001", file1="rei_02m_00101", file3="rei_02m_00321", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=17, delay2=2000, mode=3, x=-5, y=-5},
			},
			[1999] = {
				{"transitiontime", time=300, timestamp=17, delay2=2000},
			},
		},
		text = {
			vo = {
				{"vo", file="rei1757", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“C’mon, it’s not that surprising! Sure, Ran may not be the strongest or most charismatic. And when she first joined, she took about six steps before tripping and spraining both of her ankles...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“没那么值得惊讶吧？确实兰的战斗力不高，也不是特别有领袖魅力。刚进FS的时候只不过是走了六步就把两脚都扭伤了”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「沒那麼值得驚訝吧？確實蘭的戰鬥力不高，也不是特別有領袖魅力。剛進FS的時候只不過是走了六步就把兩腳都扭傷了」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00063",
		linknext = "0075_00065",
		line = 979,
	},
	["0075_00065"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00214", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1758", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“She has her faults, and she makes a LOT of mistakes. The other day, she mistook the shredder for the copy machine and obliterated a bunch of important files. She never remembers trash day, either...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“少了几根筋，也常常犯错。之前还把影印机和碎纸机搞混了，然后把重要文件碎成了纸片，也会在丢可燃垃圾的日子拿塑胶垃圾出去”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「少了幾根筋，也常常犯錯。之前還把影印機和碎紙機搞混了，然後把重要文件碎成了紙片，也會在丟可燃垃圾的日子拿塑膠垃圾出去」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00064",
		linknext = "0075_00066",
		line = 994,
	},
	["0075_00066"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So why the hell is she getting a promotion?!",
					{"rt2"},
				},
			},
			cn = {
				{
					"要到什么时候才会开始夸她啊……？",
					{"rt2"},
				},
			},
			tw = {
				{
					"要到什麼時候才會開始誇她啊……？",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00065",
		linknext = "0075_00067",
		line = 1004,
	},
	["0075_00067"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00202", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1759", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“But her work ethic is unparalleled. When it comes right down to it, hard workers are the best match for the job.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“可是，是个一心一意的努力家。那种类型意外地比较适合这个位置喔”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「可是，是個一心一意的努力家。那種類型意外地比較適合這個位置喔」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00066",
		linknext = "0075_00068",
		line = 1019,
	},
	["0075_00068"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It still seems like the cons far outweigh the pros here!",
					{"rt2"},
				},
			},
			cn = {
				{
					"扣分项这么多合计起来好像还是负分耶……？",
					{"rt2"},
				},
			},
			tw = {
				{
					"扣分項這麼多合計起來好像還是負分耶……？",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00067",
		linknext = "0075_00069",
		line = 1029,
	},
	["0075_00069"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, it’s not my place to butt in on FS matters.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可是，她想说什么我能够理解。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可是，她想說什麼我能夠理解。",
					{"rt2"},
				},
