	["0075_00138"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00101", file2="asane_02m_00213", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
