	["0075_00227"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00228", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There should be a limit, right?! On how cute a person can get, I mean! Is she even human?! Was she hired to assassinate me with her adorable antics?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“从头到尾都可爱过头也要有个限度吧！那个女人是怎么回事！是为了萌杀我而被派来的暗杀者吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「從頭到尾都可愛過頭也要有個限度吧！那個女人是怎麼回事！是為了萌殺我而被派來的暗殺者嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00226",
		linknext = "0075_00228",
		line = 3409,
	},
	["0075_00228"] = {
