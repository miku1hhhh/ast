		text = {
			vo = {
				{"vo", file="rei1765", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“This time around, I want to be the one to help them. Even if some people call me a hypocrite...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“所以我想，这一次我一定要帮上他们的忙……虽然可能会有人觉得我没有那个资格就是了”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「所以我想，這一次我一定要幫上他們的忙……雖然可能會有人覺得我沒有那個資格就是了」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00083",
		linknext = "0075_00085",
		line = 1259,
	},
	["0075_00085"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00206", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
