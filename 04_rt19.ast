	["0075_00083"] = {
		{"bgm", file="bgm21", vol=100},
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file3="rei_01m_00320", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1764", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“The laws on the island have changed, but our society is undergoing a period of growth and instability. There are still a lot of people who are suffering the after-effects of the Perverted Sex Law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“虽然岛上的条例改变了，可是现在还处在发展途中的不安定状态。因为变态条例心灵受创的人也还有很多……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「雖然島上的條例改變了，可是現在還處在發展途中的不安定狀態。因為變態條例心靈受創的人也還有很多……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00082",
		linknext = "0075_00084",
		line = 1241,
	},
	["0075_00084"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00201", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
