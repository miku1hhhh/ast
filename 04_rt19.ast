	["0075_00145"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino has been complaining about Touka’s tendencies for as long as I can remember. She finally couldn’t stand it any more, so she’s been tutoring her privately these days.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从以前就一直看着桐香的言行原来原来念个不停的文乃，似乎总算是看不下去了，最近开始干起了像是个人指导一样的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從以前就一直看著桐香的言行原來原來念個不停的文乃，似乎總算是看不下去了，最近開始幹起了像是個人指導一樣的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00144",
		linknext = "0075_00146",
		line = 2077,
	},
	["0075_00146"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Touka has always been pretty hopeless, but maybe with Fumino’s guidance, she’ll be able to—",
					{"rt2"},
				},
			},
			cn = {
				{
					"据说桐香是落第的特化型，如果有文乃的指导或许────",
					{"rt2"},
				},
			},
			tw = {
				{
					"據說桐香是落第的特化型，如果有文乃的指導或許────",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00145",
