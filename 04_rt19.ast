				},
			},
			tw = {
				{
					"……不，果然還是有難度吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00146",
		linknext = "0075_00148",
		line = 2098,
	},
	["0075_00148"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Regardless of the outcome, the two are on speaking terms now. That’s a win in my book.",
					{"rt2"},
				},
			},
			cn = {
				{
					"总而言之，不论是以哪种形式，桐香和文乃变成了常常交谈的关系是件好事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"總而言之，不論是以哪種形式，桐香和文乃變成了常常交談的關係是件好事。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00147",
		linknext = "0075_00149",
		line = 2108,
	},
	["0075_00149"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And while I’ve been busy with Rei, Asa and Susuko have also gotten close. I’m glad that Asa is finally making friends her own age.",
					{"rt2"},
				},
			},
			cn = {
				{
					"另一方面麻沙酱也被丝丝子喜欢上了──在我和礼卿卿我我的时候，年少组似乎也建立起了她们自己的人际关系了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"另一方面麻沙醬也被絲絲子喜歡上了──在我和禮卿卿我我的時候，年少組似乎也建立起了她們自己的人際關係了。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00148",
		linknext = "0075_00150",
		line = 2118,
	},
	["0075_00150"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00101", file2="asane_02m_00201", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0322", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“So! What were you and Rei talking about, Bro?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“然后呢……哥哥你们在聊什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「然後呢……哥哥你們在聊什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00149",
		linknext = "0075_00151",
		line = 2133,
	},
	["0075_00151"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00207", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1782", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Oh, I was just asking Junnosuke what he wants to do after he graduates.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“啊啊，我刚好在问淳之介毕业以后打算怎么办”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「啊啊，我剛好在問淳之介畢業以後打算怎麼辦」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00150",
		linknext = "0075_00152",
		line = 2148,
	},
	["0075_00152"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00219", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=0},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hmm... I guess I want to study at a university on the mainland.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“唔—嗯……果然是到本岛升学吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「唔—嗯……果然是到本島升學吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00151",
		linknext = "0075_00153",
		line = 2160,
	},
	["0075_00153"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00102", file2="asane_02m_00212", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0323", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Really? No way, Bro! If you leave us, then Fumino and I will be all alone in the house... I won’t have anything to do except pick on her all day...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“咦……不要不要如果哥哥去升学了那这个家不就只剩下我和文乃两个人了吗……这样我除了欺负文乃以外就找不到其他乐趣了啦……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「咦……不要不要如果哥哥去升學了那這個家不就只剩下我和文乃兩個人了嗎……這樣我除了欺負文乃以外就找不到其他樂趣了啦……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00152",
		linknext = "0075_00154",
		line = 2176,
	},
	["0075_00154"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00215", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=0},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fumino takes good care of you. You should be more grateful to her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你可是受文乃诸多照顾的，要好好慰劳人家啊”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳可是受文乃諸多照顧的，要好好慰勞人家啊」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00153",
		linknext = "0075_00155",
		line = 2188,
	},
	["0075_00155"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00102", file2="asane_02m_00221", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=100},
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=1, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0324", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Gasp! Is that the reason why Fumino has been buddying up with Reizeiin?! Once Reizeiin is under her control, she’s going to use her to get rid of me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哈……难道说最近文乃之所以会和冷泉院同学那么好是想要使用被她纳入支配之下的冷泉院同学让我消失吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哈……難道說最近文乃之所以會和冷泉院同學那麼好是想要使用被她納入支配之下的冷泉院同學讓我消失嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00154",
		linknext = "0075_00156",
		line = 2204,
	},
	["0075_00156"] = {
		{"fg", file="asane_02l_00001", file1="asane_02l_00102", file2="asane_02l_00211", path=":fg/asane_02l/", id=3, lv=3, head="asane_02l", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="浮遊横", loop=15, size=5, time=75, ease="easeinout_sine"},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0325", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Oh noooo! I don’t wanna die! Bro, let’s hide out here together! My life is on the line! You have Tadasugawa, so why don’t you let her support you? You can be her little lapdog.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不要—我不想死—！哥哥，陪我一起家里蹲吧？这可是关乎妹妹的生命喔？毕竟还有糺川前辈在，就成为传说中的尼特游手好闲地活下去吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不要—我不想死—！哥哥，陪我一起家裡蹲吧？這可是關乎妹妹的生命喔？畢竟還有糺川前輩在，就成為傳說中的尼特遊手好閒地活下去吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00155",
		linknext = "0075_00157",
		line = 2221,
	},
	["0075_00157"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00203", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=0},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Of course I can’t do that! I may not look it, but at least I have that much self-respect. I can’t just live off of Rei forever...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那可不行──我也是有所谓矜持的。怎么能堕落成小白脸……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那可不行──我也是有所謂矜持的。怎麼能墮落成小白臉……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00156",
		linknext = "0075_00158",
		line = 2233,
	},
	["0075_00158"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00214", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1783", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Well... Even if you don’t decide to become my little pet, there are still ways to make money without even leaving the house.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“唉……小白脸之类的先不说，现在姑且已经是躲在家里也能工作的时代了嘛”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「唉……小白臉之類的先不說，現在姑且已經是躲在家裡也能工作的時代了嘛」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00157",
		linknext = "0075_00159",
		line = 2248,
	},
	["0075_00159"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00101", file2="asane_02m_00213", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
