				{
					name = {"ヒナミ", "雛見"},
					"『嗯。剛才禮醬也打電話過來了。說著我太喜歡淳之介了！然後述說了好久的愛意呢』",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00234",
		linknext = "0075_00236",
		line = 3511,
	},
	["0075_00236"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00209", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Seriously?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你说什么……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳說什麼……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00235",
		linknext = "0075_00237",
		line = 3523,
	},
	["0075_00237"] = {
		{"fg", file="hinami_02f_00001", file1="hinami_02f_00103", file2="hinami_02f_00218", path=":fg/hinami_02f/", id=30, ch="ヒナミ", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0301", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Ahh, I’m so happy I could die! Growing old with Junnosuke, being with him for the rest of my life... Oh, I’m drowning in happiness! Help me, Hinamiii!!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"‘感觉太幸福了好像快死了啦这样下去直到变成老太婆为止都会跟淳之介一直一直在一起然后在幸福的包裹之下死去啊救救我啊雏见～’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"『感覺太幸福了好像快死了啦這樣下去直到變成老太婆為止都會跟淳之介一直一直在一起然後在幸福的包裹之下死去啊救救我啊雛見～』",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00236",
		linknext = "0075_00238",
		line = 3536,
	},
	["0075_00238"] = {
		{"fg", file="hinami_02f_00001", file1="hinami_02f_00101", file2="hinami_02f_00202", path=":fg/hinami_02f/", id=30, ch="ヒナミ", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0302", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“That’s exactly what she said. It’s shocking how similar you are. You two are a such perfect couple, it’s even making me smile!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"‘这样。呵呵，相同到吓人一跳对吧？你们感情这么好，连我都觉得高兴起来了呢’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"『這樣。呵呵，相同到嚇人一跳對吧？你們感情這麼好，連我都覺得高興起來了呢』",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00237",
		linknext = "0075_00239",
		line = 3549,
	},
	["0075_00239"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00209", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
