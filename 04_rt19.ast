	["0075_00080"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00205", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Rei, what do you want to do after you graduate? College?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“礼毕业以后打算怎么办？果然是要升学吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「禮畢業以後打算怎麼辦？果然是要升學嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00079",
		linknext = "0075_00081",
		line = 1198,
	},
	["0075_00081"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00201", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1763", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Well... I was considering college for a while. But I’ve been thinking about just joining the SHO right after graduation.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“啊啊……虽然我姑且是这么考虑的……可是我在想，就这样进去SHO或许也是个选择”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「啊啊……雖然我姑且是這麼考慮的……可是我在想，就這樣進去SHO或許也是個選擇」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00080",
		linknext = "0075_00082",
		line = 1213,
	},
	["0075_00082"] = {
