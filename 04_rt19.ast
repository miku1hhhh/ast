			},
			[3999] = {
				{"transitiontime", time=300, timestamp=35, delay2=4000},
			},
		},
		text = {
			vo = {
				{"vo", file="asane0326", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Imagine it, Bro! You’ll become a fantasy author and get so popular that they’ll make your books into anime! You can spend your days living off the royalties and getting roasted by internet trolls!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“就是嘛……！你看哥哥糺川前辈也这么说了喔就以拿肉作家为目标嘛大受欢迎以后就是书籍化动画化在网络上被大骂特骂然后就可以过上梦一般的版睡生活了呀嗬……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「就是嘛……！你看哥哥糺川前輩也這麼說了喔就以拿肉作家為目標嘛大受歡迎以後就是書籍化動畫化在網路上被大罵特罵然後就可以過上夢一般的版睡生活了呀嗬……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00158",
		linknext = "0075_00160",
		line = 2269,
	},
	["0075_00160"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00218", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=0},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But I don’t know the first thing about fantasy. Alternate dimension stories just aren’t my thing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是异世界什么的我又不懂”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是異世界什麼的我又不懂」",
					{"rt2"},
