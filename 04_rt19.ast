	["0075_00269"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s just the two of us, and Rei has her guard down completely. Her entire ass is on display for me—and though she’s acting tough, she seems deliciously embarrassed about it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为跟我两人独处所以完全放松了心情，于是毫无防备地露出了内裤──这个事实似乎让她觉得非常丢脸的样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為跟我兩人獨處所以完全放鬆了心情，於是毫無防備地露出了內褲──這個事實似乎讓她覺得非常丟臉的樣子。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00268",
		linknext = "0075_00270",
		line = 3983,
	},
	["0075_00270"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe she wasn’t really showing her panties on purpose, but she’s too embarrassed to admit it. She’s clinging to her stubborn pride—probably because of her status at school and because she’s a senior.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可是“故意给你看的”这个说法怎么想都只是耻上加耻──这恐怕是因为姑且比我年长、而且过去还是我的教官导致的倔强吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可是「故意給你看的」這個說法怎麼想都只是恥上加恥──這恐怕是因為姑且比我年長、而且過去還是我的教官導致的倔強吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00269",
		linknext = "0075_00271",
		line = 3993,
	},
	["0075_00271"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If that’s the case, I want to utterly destroy that prideful facade and expose her shame. Who wouldn’t? This kind of urge is just part of human nature.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这样一来就想要打破那份倔强，这也是人之常情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這樣一來就想要打破那份倔強，這也是人之常情。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00270",
		linknext = "0075_00272",
		line = 4003,
	},
