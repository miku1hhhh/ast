			},
			[6099] = {
				{"transitiontime", time=300, timestamp=21, delay2=6100},
			},
		},
		text = {
			vo = {
				{"vo", file="rei1767", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“But I still have so much to do before graduation. There’s also Christmas, New Year’s, and—come to think of it, your birthday is on New Year’s Eve, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“可是，在毕业之前还有很多事情要办。圣诞节啊过年啊……啊啊……这么说起来，淳之介的生日是除夕对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「可是，在畢業之前還有很多事情要辦。聖誕節啊過年啊……啊啊……這麼說起來，淳之介的生日是除夕對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00090",
		linknext = "0075_00092",
		line = 1349,
	},
	["0075_00092"] = {
