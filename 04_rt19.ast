	["0075_00115"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don’t forget! We always eat soba to welcome the New Year, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“跨年的时候得吃发光的荞麦面才行呢”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「跨年的時候得吃發光的蕎麥麵才行呢」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00114",
		linknext = "0075_00116",
		line = 1663,
	},
	["0075_00116"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00103", file3="rei_02m_00309", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1776", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Haha, we’re going to be busy. And stuffed! Ah... I’m so happy I could die.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“哈哈，一个接着一个呢……太幸福了，感觉都快死了”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「哈哈，一個接著一個呢……太幸福了，感覺都快死了」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00115",
		linknext = "0075_00117",
		line = 1678,
	},
	["0075_00117"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That’s a good thing, isn’t it? If I don’t make you that happy, then I’m not doing my job.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不是挺好的吗？我至少也得让礼这么幸福吧”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不是挺好的嗎？我至少也得讓禮這麼幸福吧」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00116",
		linknext = "0075_00118",
		line = 1690,
	},
	["0075_00118"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Whenever I express my true feelings to Rei, she always shows a mixture of happiness and embarrassment. I catch a glimpse of her shy smile.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我直白地说出了真心话，而礼有点害羞地笑了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我直白地說出了真心話，而禮有點害羞地笑了。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00117",
		linknext = "0075_00119",
		line = 1700,
	},
	["0075_00119"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00219", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I’ve been meaning to ask. When is your birthday, exactly? It’s in February, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对了。礼的生日是什么时候？我记得是在2月──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對了。禮的生日是甚麼時候？我記得是在2月──」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00118",
		linknext = "0075_00120",
		line = 1712,
	},
