	["0075_00086"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00211", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[2500] = {
				{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00214", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=20, delay2=2500, mode=3, x=-5, y=-5},
			},
			[2499] = {
				{"transitiontime", time=300, timestamp=20, delay2=2500},
			},
		},
		text = {
			vo = {
				{"vo", file="rei1766", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I’m not trying to atone for my sins. I just want to save people in the same way that I was saved. Become the light in the darkness for them. Like the one who helped me find my way... That’s all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我并不是想要功过相抵或是补偿他们。我只是想说如果能给别人我受过的帮助……如果某处有昔日的我，我想对他们伸出手……就只是这样而已”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我並不是想要功過相抵或是補償他們。我只是想說如果能給別人我受過的幫助……如果某處有昔日的我，我想對他們伸出手……就只是這樣而已」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00085",
		linknext = "0075_00087",
		line = 1289,
	},
	["0075_00087"] = {
