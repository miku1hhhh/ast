	["0075_00240"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This phone call was supposed to calm me down. But it only fueled my passion for Rei even more.",
					{"rt2"},
				},
			},
			cn = {
				{
					"原本打算释放对礼的好感来冷静下来的，结果反而吃了一记反击。",
					{"rt2"},
				},
			},
			tw = {
