					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I agree about the parrot part, at least.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“关于最后一点我是完全同意啦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「關於最後一點我是完全同意啦？」",
