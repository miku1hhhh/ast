	["0075_00088"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei wants to be someone’s savior. Just like Hinami was for her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对礼来说就是雏见。",
					{"rt2"},
				},
