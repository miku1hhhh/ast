	["0075_00133"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00102", file2="asane_02m_00205", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[2000] = {
				{"fg", file="asane_02m_00001", file1="asane_02m_00102", file2="asane_02m_00216", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, timestamp=29, delay2=2000, mode=3, x=-405, y=-5},
			},
			[1999] = {
				{"transitiontime", time=300, timestamp=29, delay2=2000},
			},
		},
		text = {
			vo = {
				{"vo", file="asane0317", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ah, Tadasugawa! Heyo! I’m fine, it’s just that there’s this big-ass girl in my class who’s been hanging around me lately. She’s always bugging me like, ‘AAAASA, AAAASA!’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊，糺川前辈……你好—。不是啦，有个丝—丝—念个不停的大只女自从上次的庆功宴以后就一直麻—沙—酱—麻—沙—酱—地缠着我……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊，糺川前輩……妳好—。不是啦，有個絲—絲—念個不停的大隻女自從上次的慶功宴以後就一直麻—沙—醬—麻—沙—醬—地纏著我……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00132",
		linknext = "0075_00134",
		line = 1915,
	},
	["0075_00134"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Oh, she must be talking about Susuko. They’re both first-year students.",
					{"rt2"},
				},
			},
			cn = {
				{
					"丝丝子啊──这么说起来她们都是1年级呢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"絲絲子啊──這麼說起來她們都是1年級呢。",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00133",
		linknext = "0075_00135",
		line = 1925,
	},
	["0075_00135"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So you made a friend in your grade? Good for you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“难道说你交到同年纪的朋友了吗？太好了呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「難道說妳交到同年紀的朋友了嗎？太好了呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00134",
		linknext = "0075_00136",
		line = 1937,
	},
	["0075_00136"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00101", file2="asane_02m_00203", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0318", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Who said she’s my friend? For one, I don’t like hanging out with people my age, and besides she’s WAY too touchy-feely and she breathes all over me and her creepy-ass parrot freaks me out!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不，也不是朋友……我基本上同年龄的都不当作对象、她又很喜欢一直黏上来跟人家肌肤接触吓死人了、加上那身高压力十足、而且养的鹦鹉简直吓死人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不，也不是朋友……我基本上同年齡的都不當作對象、她又很喜歡一直黏上來跟人家肌膚接觸嚇死人了、加上那身高壓力十足、而且養的鸚鵡簡直嚇死人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0075_00135",
		linknext = "0075_00137",
		line = 1952,
	},
	["0075_00137"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
