			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Oh, but she seems like she’d be SUPER into cosplay sex! So if she’s down for that, that means we could totally be friends...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊，只不过感觉Cosplay做爱之类的感觉会很配合，这点非常可以……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊，只不過感覺Cosplay做愛之類的感覺會很配合，這點非常可以……！」",
					{"rt2"},
				},
			},
		},
