			en = {
				{
					name = {"桐香", "Touka"},
					"“What’s that? Oh... There must be some unfamiliar material in there. In that case, skim through your textbook first. Then we’ll start answering the questions.”",
					{"rt2"},
				},
			},
			cn = {
