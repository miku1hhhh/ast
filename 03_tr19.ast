		{"text"},
		text = {
			vo = {
				{"vo", file="ran0101", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“It has always been my dream to get into the Secret Shagniques Course! So I’ve been studying at the Cock-Cramming University Matriculation Program. You know! The CUM Program!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“我从以前的梦想就是进入‘性事秘技课程’就读……！所以我还一直在针对小孩的通信课程后背座位鸡鸡研究会，简称‘鸡研会’一直努力学习呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「我從以前的夢想就是進入『性事祕技課程』就讀……！所以我還一直在針對小孩的通信課程後背座位雞雞研究會，簡稱『雞研會』一直努力學習呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00061",
		linknext = "0066_00063",
		line = 1021,
	},
	["0066_00063"] = {
