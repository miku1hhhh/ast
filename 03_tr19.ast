	["0066_00076"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I had no idea. When did she make up her mind?",
					{"rt2"},
				},
			},
			cn = {
				{
					"原来是这样啊，但是是什么时候……",
					{"rt2"},
				},
			},
			tw = {
				{
					"原來是這樣啊，但是是什麼時候……",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00075",
		linknext = "0066_00077",
		line = 1221,
	},
	["0066_00077"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The Touka I knew, who didn’t want a thing in the world, had finally found a dream to chase.",
					{"rt2"},
				},
			},
			cn = {
				{
					"完全没有愿望的桐香，终于有自己的梦想了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"完全沒有願望的桐香，終於有自己的夢想了。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00076",
		linknext = "0066_00078",
		line = 1231,
	},
	["0066_00078"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=21},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What is it? Tell me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是什么呢？告诉我吧，我很感兴趣。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是什麼呢？告訴我吧，我很感興趣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00077",
		linknext = "0066_00079",
		line = 1243,
	},
	["0066_00079"] = {
		{"fg", file="tohka_01ll_00001", file1="tohka_01ll_00101", file2="tohka_01ll_00212", path=":fg/tohka_01ll/", id=21, lv=21, head="tohka_01ll", ch_origin="桐香", ch="桐香21", mw="mw", sync=0, mode=3, x=200, y=0},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[6000] = {
				{"fg", file="tohka_02ll_00001", file1="tohka_02ll_00101", file2="tohka_02ll_00228", path=":fg/tohka_02ll/", id=21, lv=21, head="tohka_02ll", ch_origin="桐香", ch="桐香21", mw="mw", sync=0, timestamp=20, delay2=6000, mode=3, x=200, y=0},
			},
			[5999] = {
				{"transitiontime", time=300, timestamp=20, delay2=6000},
			},
		},
		text = {
			vo = {
				{"vo", file="tohka1552", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Well... up until now, I didn’t want much of anything. But it turns out that once I find something that I want, nothing can stop me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“嗯……因为我一直没有什么特别想要的东西，所以不太清楚。不过看起来，我好像是如果有想要的东西的话，那我会为了得到他什么都愿意做。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「嗯……因為我一直沒有什麼特別想要的東西，所以不太清楚。不過看起來，我好像是如果有想要的東西的話，那我會為了得到他什麼都願意做。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00078",
		linknext = "0066_00080",
		line = 1261,
	},
	["0066_00080"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=21},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, I know how you can get. I’ve experienced it firsthand.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这我可以理解，毕竟我也亲身体验过不少。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這我可以理解，畢竟我也親身體驗過不少。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00079",
		linknext = "0066_00081",
		line = 1273,
	},
	["0066_00081"] = {
