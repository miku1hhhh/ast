			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I took Nanase’s advice when I made all of this. I followed the recipes exactly, and I didn’t add any extra seasoning.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“在奈奈濑的建议下，完全按照食谱上来，而且我自己没有试味道的状态下终于成功了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「在奈奈瀨的建議下，完全按照食譜上來，而且我自己沒有試味道的狀態下終於成功了。」",
					{"rt2"},
				},
			},
		},
