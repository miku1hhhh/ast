	["0066_00124"] = {
		{"fg", file="schubert_01m_00001", file1="schubert_01m_00102", file2="schubert_01m_00216", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=11, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=695, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0265", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“To think that I’d find this kind of data about your daily lives...! Hang in there, Junnosuke!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“如果这是日常生活的一块……那还真是辛苦啊，淳之介……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「如果這是日常生活的一塊……那還真是辛苦啊，淳之介……」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00123",
		linknext = "0066_00125",
		line = 1980,
	},
	["0066_00125"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Heh. It’s all right, Touka. I’ll admit, there are still times when I don’t know what you’re thinking. But there’s one thing that I always know for sure.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呵，没问题的……虽然老实说，有时候还是会不知道她在想什么，但我明白了一件事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呵，沒問題的……雖然老實說，有時候還是會不知道她在想什麼，但我明白了一件事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00124",
		linknext = "0066_00126",
		line = 1992,
	},
	["0066_00126"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Everything you do, you do for love. Isn’t that right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这家伙的行动，全部都是基于庞大的‘爱’而来──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這傢伙的行動，全部都是基於龐大的『愛』而來──」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00125",
		linknext = "0066_00127",
		line = 2004,
	},
	["0066_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’ve come to understand that all of Touka’s actions are an expression of her love.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没错，全部都是她的爱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒錯，全部都是她的愛。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00126",
