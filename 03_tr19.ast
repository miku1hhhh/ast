				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, I’ve heard of it! They advertised in the porno manga I used to read. Do you remember Creampie Cutie? She was my favorite character!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是萝莉挑战一年级生吧！？真怀念，我也超常读寄来的色情漫画呢～！吉祥物的‘怀孕欧拉修’超可爱的！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是蘿莉挑戰一年級生吧！？真懷念，我也超常讀寄來的色情漫畫呢～！吉祥物的『懷孕歐拉修』超可愛的！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00062",
		linknext = "0066_00064",
		line = 1037,
	},
	["0066_00064"] = {
