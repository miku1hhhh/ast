	["0066_00086"] = {
		{"fg", file="misaki_02ll_00001", file1="misaki_02ll_00104", file2="misaki_02ll_00222", path=":fg/misaki_02ll/", id=6, lv=15, head="misaki_02ll", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-5, y=295},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0240", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Why aren’t you?! Junnosuke used to be our friend, you know? Now he’s just... ugh! Nanase, help me out here!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“这是当然的啊……！？明明淳之介君就是我们的伙伴，却，那个、对吧，奈奈濑同学！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「這是當然的啊……！？明明淳之介君就是我們的夥伴，卻，那個、對吧，奈奈瀨同學！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00085",
		linknext = "0066_00087",
		line = 1369,
	},
	["0066_00087"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", file2="nanase_01m_00210", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=345, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0271", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I respect Jun’s decision. Let’s cheer for the happy couple from a distance so that we don’t get cavities from all of their sweet talk.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“毕竟是淳选择的，那就没办法了啊！就祝福他们吧，至于那糖分摄取，就尽量隔段距离吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「畢竟是淳選擇的，那就沒辦法了啊！就祝福他們吧，至於那糖分攝取，就盡量隔段距離吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00086",
		linknext = "0066_00088",
		line = 1384,
	},
	["0066_00088"] = {
		{"fg", file="misaki_01ll_00001", file1="misaki_01ll_00104", file2="misaki_01ll_00222", path=":fg/misaki_01ll/", id=6, lv=15, head="misaki_01ll", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=0, y=300},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0241", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Are you just gonna let him go like this? Once Junnosuke is gone, there’s no turning back! We’re all gonna end up losers—like the jilted ‘childhood friend’ characters in a dating sim!!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“一副从容的样子，说不定这次淳之介君真的就不会回来了？这样也没关系吗？你这失败属性的青梅竹马就要跟一般常说的一样输了耶，也不后悔吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「一副從容的樣子，說不定這次淳之介君真的就不會回來了？這樣也沒關係嗎？妳這失敗屬性的青梅竹馬就要跟一般常說的一樣輸了耶，也不後悔嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00087",
		linknext = "0066_00089",
		line = 1399,
	},
	["0066_00089"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00205", path=":fg/ikuko_02m/", id=10, lv=9, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=695, y=-5},
		{"transitiontime", time=300},
