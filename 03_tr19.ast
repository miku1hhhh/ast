	},
	["0066_00176"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even though we’re dating, she still calls me by my last name. She says it with respect, but it’s a little too stiff for my liking.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然是恋人了，但她说话还是非常有礼貌。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然是戀人了，但她說話還是非常有禮貌。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00175",
		linknext = "0066_00177",
		line = 2691,
	},
