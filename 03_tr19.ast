			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Just like you told me. You said that you love my smile. But I love yours, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“就像你跟我说的，我也最喜欢你的笑容了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「就像你跟我說的，我也最喜歡你的笑容了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00321",
		linknext = "0066_00323",
		line = 4793,
	},
	["0066_00323"] = {
		{"fgact", ch="桐香8", id=8, lv=7, act="表示アクション", alpha=0, alphadel=1, style="reset", time=500},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I now understood why she was even willing to let me be the first one to put it in her ass. Because she thought that was what I wanted.",
					{"rt2"},
				},
			},
			cn = {
				{
					"后穴性交，也是因为觉得我喜欢处女。",
					{"rt2"},
				},
			},
			tw = {
				{
					"後穴性交，也是因為覺得我喜歡處女。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00322",
		linknext = "0066_00324",
		line = 4805,
	},
	["0066_00324"] = {
