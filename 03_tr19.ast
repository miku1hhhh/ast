			cn = {
				{
					name = {"郁子"},
					"“但是亲爱的，如果连考虑未来的时候都必须考虑到桐香酱的话不会太辛苦了吗？不会不高兴吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
