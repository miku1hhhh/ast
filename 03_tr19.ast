	["0066_00083"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=21},
