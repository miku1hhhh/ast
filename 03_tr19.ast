			},
		},
		text = {
			vo = {
				{"vo", file="misaki0239", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Seriously?! If I have to take any more of your lovey-dovey shit, I’m gonna hurl! Get a room already!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“真的别在这里搞这套，连我都有点吃不下的甜腻戏码，请到别的地方再上演，别的地方拜托……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「真的別在這裡搞這套，連我都有點吃不下的甜膩戲碼，請到別的地方再上演，別的地方拜託……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00083",
		linknext = "0066_00085",
