	["0066_00149"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’m not gonna lie, I get hard just thinking about the “study date” scenes. I can’t wait.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对于读书约会这种老套内容特别没辄的我。",
