				},
			},
			cn = {
				{
					name = {"桐香"},
					"“哪里！具体是哪边！？什么时间点，我明明想用一般的说法却说了方言！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「哪裡！具體是哪邊！？什麼時間點，我明明想用一般的說法卻說了方言！？」",
					{"rt2"},
				},
			},
		},
