		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00205", path=":fg/tohka_02m/", id=8, lv=7, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"bg", id=1, file="bg33_2_00000", x=0, y=0, lv=1, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00205", path=":fg/tohka_02m/", id=8, lv=7, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_024_00000"},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1587", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“And as long as I can make you happy, I’ll do whatever it takes. Just give me the chance.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“然后为了让你可以一直幸福下去，我会一直一直努力的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「然後為了讓你可以一直幸福下去，我會一直一直努力的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00301",
		linknext = "0066_00303",
