		{"se", id=1, loop=0, file="se_b087"},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1559", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Leave it to me, Tachibana! Just a hop, skip and a jump up these stairs and I’ll fly right into your arms and—B-B-BLEAHHHHHHGHHH!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“好的，我知道了，包在我身上，我马上会爬上这样的阶梯，奔向前辈的胸膛，恶恶恶恶恶恶！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「好的，我知道了，包在我身上，我馬上會爬上這樣的階梯，奔向前輩的胸膛，噁噁噁噁噁噁！」",
					{"rt2"},
				},
			},
		},
