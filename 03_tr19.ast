			},
			[7399] = {
				{"transitiontime", time=300, timestamp=43, delay2=7400},
			},
		},
		text = {
			vo = {
				{"vo", file="tohka2023", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Ahhhh! Rei, please forgive me! I haven’t lived in Kyoto since I was five! I don’t know the first thing about temples! So please don’t ask me for a tour on the next FS business trip!!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“啊啊抱歉礼！我只有到5岁为止住在那边所以不清楚那边的寺庙！所以不要用那么天真的脸说‘下次的慰劳旅行，请带我们去京都玩吧’！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「啊啊抱歉禮！我只有到5歲為止住在那邊所以不清楚那邊的寺廟！所以不要用那麼天真的臉說『下次的慰勞旅行，請帶我們去京都玩吧』！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00223",
		linknext = "0066_00225",
		line = 3417,
	},
	["0066_00225"] = {
