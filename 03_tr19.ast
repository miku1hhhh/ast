	},
	["0066_00306"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00202", path=":fg/tohka_01m/", id=8, lv=7, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1588", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Compared to everyone else, I can’t do much of anything. But I will put in the most effort to make you smile.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“跟其他人比起来我可能什么都做不到，但如果你愿意对我笑，要我怎么努力都可以。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「跟其他人比起來我可能什麼都做不到，但如果你願意對我笑，要我怎麼努力都可以。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00305",
		linknext = "0066_00307",
		line = 4537,
	},
	["0066_00307"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Not being able to empathize with others’ feelings is just part of her nature.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为桐香无法察觉进而体谅对方的心情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為桐香無法察覺進而體諒對方的心情。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00306",
		linknext = "0066_00308",
		line = 4547,
	},
	["0066_00308"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But Touka knows that. She definitely does.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而她自己也充分明白这一点。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而她自己也充分明白這一點。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00307",
		linknext = "0066_00309",
		line = 4557,
	},
	["0066_00309"] = {
