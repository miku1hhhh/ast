	["0066_00188"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Apparently, Touka is just very particular when it comes to addressing other people.",
					{"rt2"},
				},
			},
			cn = {
				{
					"桐香似乎对于称呼、说话方式有很深的坚持。",
					{"rt2"},
				},
			},
			tw = {
				{
					"桐香似乎對於稱呼、說話方式有很深的堅持。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00187",
		linknext = "0066_00189",
		line = 2908,
	},
	["0066_00189"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00218", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Come to think of it, Ikuko said before that you would rather die than let someone hear your accent.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……是说郁子之前也说过，‘跟桐香酱是到死也不会说方言的同盟’之类的呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……是說郁子之前也說過，『跟桐香醬是到死也不會說方言的同盟』之類的呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00188",
		linknext = "0066_00190",
		line = 2920,
	},
	["0066_00190"] = {
