				{"vo", file="tohka1551", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Actually, I’ve already decided. There’s a certain dream I want to realize no matter what.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不，我有个无论如何都想实现的梦想。所以目前正在准备中。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不，我有個無論如何都想實現的夢想。所以目前正在準備中。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00073",
		linknext = "0066_00075",
		line = 1199,
	},
	["0066_00075"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00219", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=21},
		{"text"},
