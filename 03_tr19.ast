					"Now I have no idea what’s gotten into her. What in the world is she thinking?",
					{"rt2"},
				},
			},
			cn = {
				{
					"当时的我……究竟在想什么呢……",
					{"rt2"},
				},
			},
			tw = {
				{
					"當時的我……究竟在想什麼呢……",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00217",
		linknext = "0066_00219",
		line = 3323,
	},
	["0066_00219"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00203", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Why are you so scared of your accent? It sounds refined and pretty to me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是说，为什么那么不想说方言呢……？京都腔不是很好吗？感觉很有气质。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是說，為什麼那麼不想說方言呢……？京都腔不是很好嗎？感覺很有氣質。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00218",
		linknext = "0066_00220",
		line = 3335,
	},
	["0066_00220"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00102", file3="tohka_02m_00316", path=":fg/tohka_02m/", id=8, lv=7, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[7000] = {
				{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file3="tohka_02m_00307", path=":fg/tohka_02m/", id=8, lv=7, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, timestamp=41, delay2=7000, mode=3, x=-5, y=-5},
				{"fgact", ch="桐香8", id=8, act="浮遊", loop=10, size=5, time=50, ease="easeinout_sine", timestamp=41, delay2=7000},
			},
			[6999] = {
				{"transitiontime", time=300, timestamp=41, delay2=7000},
			},
		},
		text = {
			vo = {
				{"vo", file="tohka2021", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“When I was taken into a new home, they told me, ‘Servants should speak in the standard dialect!’ They said my accent sounded like I was putting on airs. If it slipped out, I was scolded and spanked!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“被收养之后第一个被矫正的就是方言，‘佣人就是要用标准语’或是‘感觉装模作样’之类的，只要稍微说了方言就马上会被骂……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「被收養之後第一個被矯正的就是方言，『傭人就是要用標準語』或是『感覺裝模作樣』之類的，只要稍微說了方言就馬上會被罵……」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00219",
		linknext = "0066_00221",
		line = 3354,
	},
	["0066_00221"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00205", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sounds like you’re holding on to a lot of Sakimori family trauma.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“驻防家造成的心理阴影真深……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「駐防家造成的心理陰影真深……」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00220",
		linknext = "0066_00222",
		line = 3366,
	},
	["0066_00222"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00102", file3="tohka_02m_00305", path=":fg/tohka_02m/", id=8, lv=7, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="桐香8", id=8, act="振動下", loop=1, size=17.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka2022", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“No one understood me. I didn’t think I was better than anyone else just because I was born in Kyoto! In fact, it was the exact opposite! I had no money—nothing!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“才不是呢，只是在上京区出生而已，才不会因此就藐视其他地区的人觉得他们是乡下人！更何况我家还因为没有钱而没落了啊！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「才不是呢，只是在上京區出生而已，才不會因此就藐視其他地區的人覺得他們是鄉下人！更何況我家還因為沒有錢而沒落了啊！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00221",
		linknext = "0066_00223",
		line = 3383,
	},
	["0066_00223"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00203", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
