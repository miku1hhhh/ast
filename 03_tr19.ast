	["0066_00144"] = {
		{"bgm", file="bgm02", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Touka promised to help me study today after school.",
					{"rt2"},
				},
			},
			cn = {
				{
					"今天放学后，要让桐香教我读书。",
					{"rt2"},
				},
			},
			tw = {
				{
					"今天放學後，要讓桐香教我讀書。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00143",
		linknext = "0066_00145",
		line = 2287,
	},
	["0066_00145"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"From what I’ve heard, Touka spends her free time reading through old textbooks. She’s practically an expert when it comes to the material I need to cover.",
					{"rt2"},
				},
			},
			cn = {
				{
					"听她说，似乎闲暇的时间就会看看课本，所以A等部的内容她大概都知道了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"聽她說，似乎閒暇的時間就會看看課本，所以A等部的內容她大概都知道了。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00144",
		linknext = "0066_00146",
		line = 2297,
	},
	["0066_00146"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Although a part of me finds Touka’s jealous tendencies to be endearing, I decided that it would be best to ask her for help studying instead of one of the others.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了不让她吃可爱的醋，所以选择让桐香教我，应该是最正确的选择。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了不讓她吃可愛的醋，所以選擇讓桐香教我，應該是最正確的選擇。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00145",
		linknext = "0066_00147",
		line = 2307,
	},
	["0066_00147"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Besides, once we get tired of studying, there are plenty of other things to do afterward. Two birds one stone.",
					{"rt2"},
				},
			},
			cn = {
				{
					"累了的话还可以你侬我侬，真是一石二鸟。",
					{"rt2"},
				},
			},
			tw = {
				{
					"累了的話還可以你儂我儂，真是一石二鳥。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00146",
		linknext = "0066_00148",
		line = 2317,
	},
