		{"cgact", file="cgact", id=18, act="浮遊横", loop=4, size=5, time=50, ease="easeinout_sine", lv=18, x=-15, y=-125},
		{"transitiontime", time=100, draw2=1},
		{"ex", time=1000, func="wait"},
		{"fg", file="ikuko_01f_00001", file1="ikuko_01f_00102", file3="ikuko_01f_00308", path=":fg/ikuko_01f/", id=30, ch="郁子", lv=18, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1289", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Hey, Rei... Considering the NLNS rebels, I thought that we might have to do something about the relationship between my Darling and Tokie, but... it’s too late now, isn’t it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“欸，礼酱……本来想要给NLNS好看，顺便处理一下亲爱的跟桐香酱……这下不可能了对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「欸，禮醬……本來想要給NLNS好看，順便處理一下親愛的跟桐香醬……這下不可能了對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00050",
		linknext = "0066_00052",
		line = 833,
	},
	["0066_00052"] = {
		{"fg", file="rei_02f_00001", file1="rei_02f_00101", file3="rei_02f_00303", path=":fg/rei_02f/", id=30, ch="礼", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1191", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Indeed. But all of our plans have already been foiled. Things between them seem to be going well. So it seems that the FS no longer has a role to play here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“唔嗯……不过至少他们处得不错，而我们报复的小动作也都失败了……看来已经没有FS出场的机会了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「唔嗯……不過至少他們處得不錯，而我們報復的小動作也都失敗了……看來已經沒有FS出場的機會了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00051",
		linknext = "0066_00053",
		line = 846,
	},
	["0066_00053"] = {
		{"fg", file="rei_01f_00001", file1="rei_01f_00101", file2="rei_01f_00203", path=":fg/rei_01f/", id=30, ch="礼", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1192", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“All that’s left to do now is watch over the two of them and pray—both for our leader’s happiness, and that Junnosuke’s love for her never runs out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“接下来就守护着他们……并祈祷吧。我们队长的幸福，以及他对桐香大人的爱不会变淡……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「接下來就守護著他們……並祈禱吧。我們隊長的幸福，以及他對桐香大人的愛不會變淡……」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00052",
		linknext = "0066_00054",
		line = 859,
	},
	["0066_00054"] = {
