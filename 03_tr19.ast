	["0066_00175"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Come to think of it, isn’t it about time to quit all of the formalities? You don’t have to call me ‘Tachibana’ anymore.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是说……差不多可以了吧，还有‘前辈’也是。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是說……差不多可以了吧，還有『前輩』也是。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00174",
		linknext = "0066_00176",
