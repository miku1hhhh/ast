					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Being by your side for all eternity... Ah! I’m so happy that I could melt just imagining it!❤”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“到死为止都能待在你身边，是多么幸福的人生啊～",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「到死為止都能待在你身邊，是多麼幸福的人生啊～",
