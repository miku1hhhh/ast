	["0066_00185"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I try to chip away at her here and there, maybe she’ll be ready to change her mind soon.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以就会像现在这样，偶尔问问是不是可以了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以就會像現在這樣，偶爾問問是不是可以了。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00184",
		linknext = "0066_00186",
		line = 2869,
	},
	["0066_00186"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00202", path=":fg/tohka_01m/", id=8, lv=7, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka2009b", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“It’s just that it has become a bit of a habit.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我说话的方式已经是一种习惯了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我說話的方式已經是一種習慣了。」",
