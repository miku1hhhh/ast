		text = {
			vo = {
				{"vo", file="mizuhiki0514", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“You want to know my class rank, huh? I’ll give you a hint. It’s the same as the number of dicks you have. That’s right! ONE! I was first from the bottom of the list!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“擅长吗……？橘君，你肉棒有几根呢？没错，只有一根。也就是说我除了‘一’以外是不可能的。就算是从后面数来也一样──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「擅長嗎……？橘君，你肉棒有幾根呢？沒錯，只有一根。也就是說我除了『一』以外是不可能的。就算是從後面數來也一樣──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00024",
		linknext = "0066_00026",
		line = 405,
	},
	["0066_00026"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=15},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Mizuhiki... ‘first from the bottom’ actually means ‘last in the class.’ But the way you said it sounded cool, so whatever!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真不愧是我们的水引酱！连说是全年级最后一名的说法都这么冷酷──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真不愧是我們的水引醬！連說是全年級最後一名的說法都這麼冷酷──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00025",
		linknext = "0066_00027",
		line = 417,
	},
