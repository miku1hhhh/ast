					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh! I have just the thing. Asane gave me her extra Tanoogle Translate machine! According to Tanoogle, what she really means is, ‘Mastering the basics is super important! I’m proud of you!❤’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是说麻沙音酱给了预备用的‘狸狸加尔’──呃，该不会这个意思是‘从基础开始复习真令人佩服",
