	["0066_00303"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s why she’s telling me all of this now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为什么故意要说出这样的话呢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為什麼故意要說出這樣的話呢。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00302",
		linknext = "0066_00304",
		line = 4502,
	},
	["0066_00304"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"From the bottom of her heart, Touka wants to understand my every desire.",
					{"rt2"},
				},
			},
			cn = {
				{
					"其实就只是无论如何都想要理解我想要的东西。",
					{"rt2"},
				},
			},
			tw = {
				{
					"其實就只是無論如何都想要理解我想要的東西。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00303",
		linknext = "0066_00305",
		line = 4512,
	},
	["0066_00305"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I don’t tell her what I want, of course she won’t know.",
					{"rt2"},
				},
			},
			cn = {
				{
