					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So people misunderstood you because of your accent...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“还被那么说过啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「還被那麼說過啊……」",
