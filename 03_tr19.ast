	["0066_00138"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", file2="misaki_01m_00206", path=":fg/misaki_01m/", id=6, lv=15, head="misaki_01m", alpha=0, ch_origin="美岬", ch="美岬6", mw="mw", sync=1, a_chr151=1, mode=3, x=-405, y=-5},
		{"fgact", ch="美岬6", id=6, lv=15, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="美岬6", id=6, act="移動", x=-300, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0245", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Even though she’s this much of a handful, why the hell does their relationship just keep getting better...? It makes no sense. It doesn’t make dollars, either.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“哎唷，真的是不知道为什么这么麻烦却还感情这么好……我真的是无法明白……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「哎唷，真的是不知道為什麼這麼麻煩卻還感情這麼好……我真的是無法明白……」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00137",
		linknext = "0066_00139",
		line = 2177,
	},
	["0066_00139"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That’s just what ‘love’ is, Misaki. It doesn’t have to make sense. And you can stop it with the weird puns already.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这就是‘爱’呀，美岬……还有，不要学奇怪的东西……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這就是『愛』呀，美岬……還有，不要學奇怪的東西……」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00138",
		linknext = "0066_00140",
		line = 2189,
	},
	["0066_00140"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s right. Love. I don’t know much, but I at least know that.",
					{"rt2"},
