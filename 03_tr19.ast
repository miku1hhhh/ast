			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But you haven’t ‘taught’ me anything yet! You just told me to read the damn book!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
