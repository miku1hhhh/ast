		line = 2014,
	},
	["0066_00128"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if I don’t know the reason why she does something, it’s all right. Because whatever the reason, love is at the source. Thinking about it this way, a little vomit is no big deal at all!",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算不知道理由，只要知道这是因爱而来的，那就算要处理呕吐物也不算什么。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算不知道理由，只要知道這是因愛而來的，那就算要處理嘔吐物也不算什麼。",
					{"rt2"},
				},
			},
		},
