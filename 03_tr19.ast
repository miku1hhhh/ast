					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是說麻沙音醬給了預備用的『狸狸加爾』──呃，該不會這個意思是『從基礎開始複習真令人佩服",
					{"gaiji", text="①"},
					"』吧……！？」",
					{"rt2"},
				},
			},
		},
