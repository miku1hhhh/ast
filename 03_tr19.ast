				{
					name = {"淳之介"},
					"「就算是這樣，那也不表示可以對現在正要開始努力的人說這種話啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00286",
		linknext = "0066_00288",
		line = 4250,
	},
	["0066_00288"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For Touka, studying really is just as straightforward as reading a book. As soon as she reads it, she can do it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对她而言，可能读书真的就是把书读过了就会了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對她而言，可能讀書真的就是把書讀過了就會了。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00287",
		linknext = "0066_00289",
		line = 4260,
	},
	["0066_00289"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Clearly, we are not the same. But I have to remember that I’m doing all of this for her sake.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，我做这些也都是为了桐香。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，我做這些也都是為了桐香。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00288",
		linknext = "0066_00290",
		line = 4270,
	},
	["0066_00290"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I don’t want to push her or become a burden to her in the process, either.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我也不想硬逼她接受，或是不希望她因此逞强。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我也不想硬逼她接受，或是不希望她因此逞強。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00289",
		linknext = "0066_00291",
		line = 4280,
	},
	["0066_00291"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Unfortunately, simply loving each other doesn’t give us the power to read each other’s minds.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算知道彼此互相喜欢，但不表示我们能够心电感应。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算知道彼此互相喜歡，但不表示我們能夠心電感應。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00290",
		linknext = "0066_00292",
		line = 4290,
	},
	["0066_00292"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It turns out that accurately expressing my feelings is a lot harder than I thought.",
					{"rt2"},
				},
			},
			cn = {
				{
					"要把想法正确的传达给对方，也不是那么简单──",
					{"rt2"},
				},
			},
			tw = {
				{
					"要把想法正確的傳達給對方，也不是那麼簡單──",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00291",
		linknext = "0066_00293",
		line = 4300,
	},
	["0066_00293"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00201", path=":fg/tohka_01m/", id=8, lv=7, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1582", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I understand. That’s why I want you to tell me when I’ve done something wrong, Tachibana. I promise I’ll fix it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“所以，请告诉我吧，前辈。我会改的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「所以，請告訴我吧，前輩。我會改的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00292",
		linknext = "0066_00294",
		line = 4315,
	},
	["0066_00294"] = {
		{"bgm", file="bgm27", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00219", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...Huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“…………咦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「…………咦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00293",
		linknext = "0066_00295",
		line = 4328,
	},
	["0066_00295"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00202", path=":fg/tohka_01m/", id=8, lv=7, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1583", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“A lot of people have told me the same thing, so it must be true. I’m not very good at understanding what other people are feeling.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“很多人都这么说过我，所以我可能真的不是很能理解其他人的心。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「很多人都這麼說過我，所以我可能真的不是很能理解其他人的心。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00294",
		linknext = "0066_00296",
		line = 4343,
	},
	["0066_00296"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00222", path=":fg/tohka_02m/", id=8, lv=7, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1584", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I may not be perfect, but I’ll always be by your side.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“但，就算是这样的我，你也愿意一直跟我在一起。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「但，就算是這樣的我，你也願意一直跟我在一起。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00295",
		linknext = "0066_00297",
		line = 4358,
	},
	["0066_00297"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file3="tohka_01m_00309", path=":fg/tohka_01m/", id=8, lv=7, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1585", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“So from now on, if I do something wrong, I want you to tell me. Tell me as many times as you need to. Discipline me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“所以未来希望你继续提醒我。向我抱怨，或骂我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「所以未來希望你繼續提醒我。向我抱怨，或罵我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00296",
		linknext = "0066_00298",
		line = 4373,
	},
	["0066_00298"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00228", path=":fg/tohka_02m/", id=8, lv=7, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1586", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You may get angry with me, but just know that I’m always trying my best to understand you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“虽然你可能会生气，但我真的很想理解你说的所有的话。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「雖然你可能會生氣，但我真的很想理解你說的所有的話。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00297",
		linknext = "0066_00299",
		line = 4388,
	},
	["0066_00299"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just then, I remembered that Touka said that she actually enjoyed it when I got mad at her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她曾经说过喜欢惹我生气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她曾經說過喜歡惹我生氣。",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00298",
		linknext = "0066_00300",
		line = 4398,
	},
