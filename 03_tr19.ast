			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I know that I can do anything for you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我，应该什么都很快就学会了。”",
