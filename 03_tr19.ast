		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1554", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I’m all yours. Every single part of me. Isn’t that right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“因为现在的我，已经是真真正正只属于你的人了……对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「因為現在的我，已經是真真正正只屬於你的人了……對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00081",
