					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yeah, this is pretty much how their lovers spats sound at home, too. I can’t understand a thing. But if they’re fighting, that means they have a close relationship, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“虽然很常在家里发生那样的争执，但我们是不太能理解对话的内容……虽然感情还不错。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「雖然很常在家裡發生那樣的爭執，但我們是不太能理解對話的內容……雖然感情還不錯。」",
					{"rt2"},
				},
			},
		},
