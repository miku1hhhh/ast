		{"text"},
		text = {
			vo = {
				{"vo", file="minase0010", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Ms. Minase"},
					"“Consider this poem. ‘As I am stroking, eyes rolled back and mouth agape, they watch me erupt, while pondering my member, filled with great concern.’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“……就是这样，‘摩擦阴茎 直到",
					{"gaiji", text="①"},
					"に想射精 我的自慰 直到被问了 才明白己心’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「……就是這樣，『摩擦陰莖 直到",
					{"gaiji", text="①"},
					"に想射精 我的自慰 直到被問了 才明白己心』。」",
					{"rt2"},
				},
			},
		},
		linknext = "0066_00002",
		line = 21,
	},
	["0066_00002"] = {
		{"text"},
		delay = {
			[4000] = {
