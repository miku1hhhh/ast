				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“All right! Let’s warm up. Go ahead and solve all of the entrance exam questions in this workbook.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“那么一开始，就先从你的志愿，红色本开始解题吧。”",
