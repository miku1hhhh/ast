				},
			},
			tw = {
				{
					name = {"桐香"},
					"「那麼一開始，就先從你的志願，紅色本開始解題吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00264",
		linknext = "0066_00266",
		line = 3912,
	},
	["0066_00266"] = {
