	["0066_00150"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But for some reason, Touka had asked me to wait for a little while after school. She said that she had “some things to prepare” before our meeting.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但，不知道为什么，桐香说要准备，请我稍等一下。",
