					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I would never abandon you, Touka... It’s my duty to protect you from now on!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“绝对不能放这样的人独自一人……所以就由我来照顾你吧……！！”",
