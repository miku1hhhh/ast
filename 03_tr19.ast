					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Hehe, that’s because I just had to have you all to myself. Now I don’t have to worry about that...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呵呵，毕竟那时候，非常想要得到你呀。不过现在我已经不担心了。”",
