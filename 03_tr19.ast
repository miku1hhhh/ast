					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You mean the once-in-a-lifetime moment I confessed my true feelings to you—was sullied by my accent?! As student council president, I should have the composure to speak without embarrassing myself!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“在那种一生一次的告白时吗！？我居然会犯下这样的错误！我本来想要像个学生会长，很酷的告白的啊！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「在那種一生一次的告白時嗎！？我居然會犯下這樣的錯誤！我本來想要像個學生會長，很酷的告白的啊！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0066_00203",
		linknext = "0066_00205",
		line = 3142,
	},
	["0066_00205"] = {
