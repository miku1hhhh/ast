	["0095_00016"] = {
		{"fg", file="tohka_01l_00001", file1="tohka_01l_00101", file2="tohka_01l_00202", path=":fg/tohka_01l/", id=8, lv=8, head="tohka_01l", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1847", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“So, shall we teach them? About your power. About your ability. About what you really are. Shall we clear up the people’s grave misunderstanding?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“来吧，让大家看看。你的能力、你的才能，你的真面目。让所有人都好好明白吧。”",
