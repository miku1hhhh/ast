					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Isn’t it obvious? Don’t ask such stupid questions, Ikuko.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这不是很明显吗。别问这种废话，郁子──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這不是很明顯嗎。別問這種廢話，郁子──」",
					{"rt2"},
				},
			},
		},
