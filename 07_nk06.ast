					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“真不愧是郁亲爱的大人⋯⋯",
					{"gaiji", text="①"},
					"可以做到这样的事的人，就只有您呦⋯⋯",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「真不愧是郁親愛的大人⋯⋯",
					{"gaiji", text="①"},
					"可以做到這樣的事的人，就只有您呦⋯⋯",
					{"gaiji", text="①"},
					"」",
					{"rt2"},
				},
			},
		},
		linkback = "0095_00003",
		linknext = "0095_00005",
		line = 64,
	},
	["0095_00005"] = {
