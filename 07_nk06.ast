		{"fg", file="rei_01f_00000", file1="rei_01f_00102", file2="rei_01f_00203", path=":fg/rei_01f/", id=30, ch="礼", lv=2, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2076", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“All facilities on the island are under your control. With Hitoura now resigned, the upper echelons of the SHO are puppets of the FS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“⋯⋯已经完成了对岛上所有设施的掌控。现在仁浦已经辞职了，SHO的高层已经全都是我们FS的魁儡了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「⋯⋯已經完成了對島上所有設施的掌控。現在仁浦已經辭職了，SHO的高層已經全都是我們FS的魁儡了。」",
					{"rt2"},
				},
			},
		},
		linknext = "0095_00002",
		line = 28,
	},
	["0095_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A naked Rei Tadasugawa reports with a slight look of dread on her face.",
					{"rt2"},
				},
			},
			cn = {
				{
					"全裸的糺川礼用带着几分恐惧的神情报告着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"全裸的糺川禮用帶著幾分恐懼的神情報告著。",
					{"rt2"},
				},
			},
		},
		linkback = "0095_00001",
		linknext = "0095_00003",
		line = 38,
	},
	["0095_00003"] = {
		{"fg", file="rei_02f_00000", file1="rei_02f_00101", file2="rei_02f_00204", path=":fg/rei_02f/", id=30, ch="礼", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2077", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“It’s no exaggeration to say that this island—the entirety of Seiran Island—is yours, Lord Junnosuke.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“如此一来这座岛──青蓝岛可以说是完全在您的掌握之中了。淳之介大人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「如此一來這座島──青藍島可以說是完全在您的掌握之中了。淳之介大人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0095_00002",
		linknext = "0095_00004",
		line = 51,
	},
	["0095_00004"] = {
		{"fg", file="ikuko_02f_00000", file1="ikuko_02f_00101", file2="ikuko_02f_00202", path=":fg/ikuko_02f/", id=30, ch="郁子", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
