		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1848", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You will continue to use me as your possession... now and forever, won’t you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“然后从现在开始，请永远永远⋯⋯让我作为你的所有物喔⋯⋯前辈？”",
					{"rt2"},
				},
			},
			tw = {
