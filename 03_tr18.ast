					name = {"麻沙音"},
					"“那哥哥可以吗？这个好吃吗……！？如果要每天吃这样的料理你满足吗？你被奈奈濑同学跟文乃的料理养刁了的胃口可以忍耐吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那哥哥可以嗎？這個好吃嗎……！？如果要每天吃這樣的料理你滿足嗎？你被奈奈瀨同學跟文乃的料理養刁了的胃口可以忍耐嗎……！？」",
					{"rt2"},
				},
			},
		},
