			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Are you okay with this shit, Bro? Can you really say it tastes good with a straight face?! I don’t know if my tastebuds, spoiled by Nanase and Fumino’s cooking, could stand this every day!”",
					{"rt2"},
				},
