	},
	["0065_00130"] = {
		{"fg", file="tohka_02m_00014", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1479", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“So many amazing, wonderful people surround him. You, Hinami, Misaki, Fumino... Even Rei and Ikuko...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“他的周围真的有很多很棒的人在。有奈奈濑同学、雏见同学、美岬同学跟文乃同学，还有礼跟郁子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「他的周圍真的有很多很棒的人在。有奈奈瀨同學、雛見同學、美岬同學跟文乃同學，還有禮跟郁子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00129",
		linknext = "0065_00131",
		line = 2041,
	},
	["0065_00131"] = {
		{"fg", file="tohka_02m_00014", file1="tohka_02m_00101", file3="tohka_02m_00313", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1480", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“There are so many people... So surely he doesn’t have to settle for me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“真的，有很多人……所以可能，其实不是我也没关系。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「真的，有很多人……所以可能，其實不是我也沒關係。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00130",
		linknext = "0065_00132",
		line = 2056,
	},
	["0065_00132"] = {
		{"fg", file="nanase_01m_00007", file1="nanase_01m_00101", file2="nanase_01m_00219", file4="nanase_01m_00401", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"fg", file="tohka_02m_00014", file1="tohka_02m_00101", file3="tohka_02m_00308", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1481", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Hehe... That’s all I think about before I fall asleep. I get so anxious, I can’t sleep and sometimes I break out in acne.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呵呵……最近睡觉前总是忍不住想着这些，然后莫名其妙的不安了起来。睡不着，甚至还长出痘痘了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「呵呵……最近睡覺前總是忍不住想著這些，然後莫名其妙的不安了起來。睡不著，甚至還長出痘痘了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00131",
		linknext = "0065_00133",
		line = 2074,
	},
	["0065_00133"] = {
		{"fg", file="tohka_02m_00014", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1482", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“But he is the only one for me. So I need to keep working hard...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“但是，我除了他无法喜欢别人──所以不努力不行。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「但是，我除了他無法喜歡別人──所以不努力不行。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00132",
		linknext = "0065_00134",
		line = 2089,
	},
	["0065_00134"] = {
		{"fg", file="tohka_02m_00014", file1="tohka_02m_00101", file2="tohka_02m_00228", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
