			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Miss Reizeiin, I have something difficult to tell you... This food is not at a level suitable for human consumption.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
