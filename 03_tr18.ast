				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Is that so? Umm, if you don’t mind me asking... Why did you suddenly want to learn how to cook?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“是吗……那个，可以告诉我吗？……为什么突然会想要学做料理呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「是嗎……那個，可以告訴我嗎？……為什麼突然會想要學做料理呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00113",
		linknext = "0065_00115",
		line = 1791,
	},
	["0065_00115"] = {
		{"fg", file="tohka_02m_00014", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
