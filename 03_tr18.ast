		{"se", id=0, loop=0, file="se_a176"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00206", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=4, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hmm... It’s neither sweet nor spicy... A very complex flavor...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“该怎么说……不能说甜、也不能辣……复杂的味道……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「該怎麼說……不能說甜、也不能辣……複雜的味道……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00076",
		linknext = "0065_00078",
		line = 1212,
	},
	["0065_00078"] = {
		{"fg", file="asane_01l_00002", file1="asane_01l_00102", file2="asane_01l_00206", path=":fg/asane_01l/", id=3, lv=3, head="asane_01l", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0261", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yeah, the taro stew over here is neither sweet nor spicy, it’s more of an inexplicable dining experience that I’ve never tasted before...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯，这边的煮芋头也是……不是甜也不是辣，只能说是体验到不知道是什么口味、没有尝到过的经验……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯，這邊的煮芋頭也是……不是甜也不是辣，只能說是體驗到不知道是什麼口味、沒有嚐到過的經驗……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00077",
		linknext = "0065_00079",
		line = 1227,
	},
