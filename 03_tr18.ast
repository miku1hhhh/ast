	["0065_00071"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But because there’s no school today, she can start her cooking lessons from the afternoon.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但因为今天是假日，所以从中午便可以有充足的时间进行。",
