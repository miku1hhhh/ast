				{"vo", file="tohka1471", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“He really understands me as a person.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“他真的理解我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「他真的理解我。」",
					{"rt2"},
