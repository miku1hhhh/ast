			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, since I’ve known him for so long, I’ll take the risk here. I’ll keep you company until your cooking is perfect.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯，毕竟也相处这么久了，那就让我好好帮忙吧。在你的料理达到完美境界为止，我都会帮你的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯，畢竟也相處這麼久了，那就讓我好好幫忙吧。在妳的料理達到完美境界為止，我都會幫妳的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00144",
		linknext = "0065_00146",
		line = 2271,
	},
