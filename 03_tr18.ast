			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I find challenging yourself to something you find difficult is in itself a grand achievement... However, to attempt the same thing over and over to the same result is indubitable.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“虽然挑战不擅长的事是非常好的……但是每次都重复露出同样的失态可是非常不应该的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「雖然挑戰不擅長的事是非常好的……但是每次都重複露出同樣的失態可是非常不應該的……」",
					{"rt2"},
				},
			},
		},
