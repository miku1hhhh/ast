		{"fg", file="asane_01l_00002", file1="asane_01l_00102", file2="asane_01l_00216", path=":fg/asane_01l/", id=3, lv=3, head="asane_01l", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=495, y=-5},
