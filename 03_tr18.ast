	["0065_00028"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"cgact", file="cgact", id=1, act="浮遊", loop=3, size=5, time=50, ease="easeinout_sine", lv=1},
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00209", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=1, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Are you listening, Touka?! Asa, the anti-social homebody who’s only hobby is trolling foreigners online, wants to leave the house! Let’s take a picture to celebrate this pivotal moment for her!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“喂，听到了吗桐香！？那个超级家里蹲，兴趣只有从房间挑衅外人的麻沙酱居然说要离开家了！纪念，来拍照记念！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「喂，聽到了嗎桐香！？那個超級家裡蹲，興趣只有從房間挑釁外人的麻沙醬居然說要離開家了！紀念，來拍照記念！」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00027",
		linknext = "0065_00029",
		line = 463,
	},
	["0065_00029"] = {
		{"fg", file="tohka_02m_00002", file1="tohka_02m_00101", file3="tohka_02m_00308", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
