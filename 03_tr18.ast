				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I’m back! Sorry to keep you girls waiting. All right, let’s get back to the cooking training!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们回来了，久等了！好了，那就继续料理特训吧──！”",
