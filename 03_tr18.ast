	},
	["0065_00072"] = {
		{"se", id=0, loop=0, file="se_a174", vol=50},
		{"fg", file="nanase_01m_00007", file1="nanase_01m_00101", file2="nanase_01m_00201", file4="nanase_01m_00401", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", alpha=0, ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=1, a_chr151=1, mode=3, x=-205, y=-5},
		{"fgact", ch="奈々瀬4", id=4, lv=4, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="奈々瀬4", id=4, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0255", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Good job. When it’s boiled, throw out the extra water, cut everything into big bite-sized pieces and put it in this pot...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“没错没错，然后，好好去除水分之后就将煮出来的汤倒掉，切成一口的大小后放到这边的锅子──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「沒錯沒錯，然後，好好去除水分之後就將煮出來的湯倒掉，切成一口的大小後放到這邊的鍋子──」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00071",
		linknext = "0065_00073",
		line = 1156,
	},
	["0065_00073"] = {
