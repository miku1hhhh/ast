			},
		},
		linkback = "0065_00115",
		linknext = "0065_00117",
		line = 1821,
	},
	["0065_00117"] = {
		{"fg", file="tohka_02m_00014", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1471b", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“He accepts me both for what I am able to do and what I am unable to do. He stands by my side through thick and thin.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我可以做的，不能做的，他都全盘接受，还愿意待在我身边。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我可以做的，不能做的，他都全盤接受，還願意待在我身邊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00116",
		linknext = "0065_00118",
		line = 1836,
	},
	["0065_00118"] = {
		{"fg", file="nanase_02m_00007", file1="nanase_02m_00101", file2="nanase_02m_00220", file4="nanase_02m_00401", path=":fg/nanase_02m/", id=4, lv=4, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[1000] = {
				{"fg", file="nanase_01m_00007", file1="nanase_01m_00101", file2="nanase_01m_00210", file4="nanase_01m_00401", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, timestamp=49, delay2=1000, mode=3, x=395, y=-5},
			},
			[999] = {
				{"transitiontime", time=300, timestamp=49, delay2=1000},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0259", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well... Yeah, he’s a sweet guy in a weird way. He may have a filthy mouth sometimes, but he really cares deeply about you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯……没错，他的确是个在奇怪的地方很温柔的男子呢……虽然嘴巴有点坏，但我觉得他是真的很为你着想。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯……沒錯，他的確是個在奇怪的地方很溫柔的男子呢……雖然嘴巴有點壞，但我覺得他是真的很為妳著想。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00117",
		linknext = "0065_00119",
		line = 1854,
	},
	["0065_00119"] = {
		{"fg", file="tohka_02m_00014", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"fgact", ch="桐香8", id=8, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"transitiontime", time=0},
		{"ex", time=1000, func="wait"},
		{"fg", file="tohka_02m_00014", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[3000] = {
				{"fg", file="tohka_02m_00014", file1="tohka_02m_00101", file2="tohka_02m_00227", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, timestamp=50, delay2=3000, mode=3, x=-405, y=-5},
			},
			[2999] = {
				{"transitiontime", time=300, timestamp=50, delay2=3000},
			},
		},
		text = {
			vo = {
				{"vo", file="tohka1472", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“He understands me, and that makes me so happy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我能获得他的理解，是一件非常幸福的事──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我能獲得他的理解，是一件非常幸福的事──」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00118",
		linknext = "0065_00120",
		line = 1877,
	},
	["0065_00120"] = {
		{"fg", file="tohka_02m_00014", file1="tohka_02m_00101", file3="tohka_02m_00302", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1472b", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“He also taught me that not everyone can be such a kind person.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“──但并不是所有的人都能遇到这么温柔的人。这也是他教会我的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「──但並不是所有的人都能遇到這麼溫柔的人。這也是他教會我的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00119",
		linknext = "0065_00121",
		line = 1892,
	},
	["0065_00121"] = {
		{"fg", file="nanase_01m_00007", file1="nanase_01m_00101", file2="nanase_01m_00219", file4="nanase_01m_00401", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0260", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00120",
		linknext = "0065_00122",
		line = 1907,
	},
	["0065_00122"] = {
		{"fg", file="tohka_02m_00014", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1473", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Human beings require effort to understand others, and he has taken the effort to understand me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“一个人要能被其他人理解，是需要努力的──而我获得了他的理解。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「一個人要能被其他人理解，是需要努力的──而我獲得了他的理解。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00121",
		linknext = "0065_00123",
		line = 1922,
	},
	["0065_00123"] = {
		{"fg", file="tohka_02m_00014", file1="tohka_02m_00101", file2="tohka_02m_00228", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1473b", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“So now I need to put in my effort.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“所以接下来，接下来还是需要努力的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「所以接下來，接下來還是需要努力的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00122",
		linknext = "0065_00124",
		line = 1937,
	},
	["0065_00124"] = {
		{"fg", file="tohka_02m_00014", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1474", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“He says he’s happy with the way I am now, but I want to change myself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“虽然他一定会说，我维持现在这样就好了，但我还是想要努力改变自己。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「雖然他一定會說，我維持現在這樣就好了，但我還是想要努力改變自己。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00123",
		linknext = "0065_00125",
		line = 1952,
	},
	["0065_00125"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1475", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I want him to continue accepting me. I want him to love me forever.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“希望他未来还能继续理解我。一直一直，继续喜欢我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「希望他未來還能繼續理解我。一直一直，繼續喜歡我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00124",
		linknext = "0065_00126",
		line = 1964,
	},
	["0065_00126"] = {
		{"bgm", stop=1},
		{"fg", file="nanase_01m_00007", file1="nanase_01m_00101", file2="nanase_01m_00219", file4="nanase_01m_00401", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0261", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“In that case... What if you talked to Jun first before trying to fix your weak points?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“所以，你想要……改善缺点就是为了……以后，一直和淳──？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「所以，妳想要……改善缺點就是為了……以後，一直和淳──？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00125",
		linknext = "0065_00127",
		line = 1980,
	},
	["0065_00127"] = {
		{"fg", file="tohka_02m_00014", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1477", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yeah. I don’t want to see all the smiles fade in this house from caregiver fatigue.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“是的。我绝对不想要让他因为看护我太累，而使这个家失去笑容。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「是的。我絕對不想要讓他因為看護我太累，而使這個家失去笑容。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00126",
		linknext = "0065_00128",
		line = 1995,
	},
	["0065_00128"] = {
		{"bgm", file="bgm23", vol=100},
		{"fg", file="tohka_02m_00014", file1="tohka_02m_00101", file2="tohka_02m_00205", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1478", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Hey, Nanase... I’m not actually free from jealousy, you know.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“……那个，奈奈濑同学。其实我，并不是真的不嫉妒的喔？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「……那個，奈奈瀨同學。其實我，並不是真的不嫉妒的喔？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00127",
		linknext = "0065_00129",
		line = 2011,
	},
	["0065_00129"] = {
