					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yeah, I completely agree. But what is the joy of love without floundering through some difficulties?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“嗯，我也这么觉得。但是自寻烦恼也是恋爱有趣的地方。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「嗯，我也這麼覺得。但是自尋煩惱也是戀愛有趣的地方。」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00142",
		linknext = "0065_00144",
		line = 2244,
	},
	["0065_00144"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00201", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Flounder? What a great idea! We can practice sharpening knives to fillet one too. Should I make another grocery run to buy one?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“鲤鱼？鲤鱼酱汤吗！不错啊也可以顺便练习刀功，那我再去采购一趟吧！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「鯉魚？鯉魚醬湯嗎！不錯啊也可以順便練習刀功，那我再去採購一趟吧！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0065_00143",
		linknext = "0065_00145",
		line = 2256,
	},
	["0065_00145"] = {
		{"fg", file="nanase_01m_00007", file1="nanase_01m_00101", file2="nanase_01m_00211", file4="nanase_01m_00401", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
