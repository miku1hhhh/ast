		{"cgact", file="cgact", id=2, act="移動", x=595, y=-5, time=10000, lv=2},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I face SHO headquarters, where we’ve been summoned. There are easily over a hundred people here already.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我一前往收到连络的SHO总部大楼时，那里已经聚集了超过100人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我一前往收到連絡的SHO總部大樓時，那裡已經聚集了超過100人。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00263",
		linknext = "0007_00265",
		line = 3520,
	},
	["0007_00265"] = {
		{"cgdel", id=2, lv=2, time=0, alphadel=1},
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00102", file2="susuko_02m_00213", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=400},
		{"fgact", ch="スス子11", id=11, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0034", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Shoot... Those are some serious numbers... This is one of those serious assemblies, one they didn’t clear with the SHO first.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“唔哇……好多人啊……他们聚集过来都没有向SHO提出申请，真的假的啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「唔哇……好多人啊……他們聚集過來都沒有向SHO提出申請，真的假的啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00264",
		linknext = "0007_00266",
		line = 3537,
	},
	["0007_00266"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0031", path=":vo/", ch="gmob"},
			},
			ja = {
				{
					name = {"モブ女A", "反ドスケベデモ女性A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Anti-Pervert Protest Girl"},
					"“Say no to the Lewd Code! Stop encouraging sexual exploitation!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "反超变态示威女性A"},
					"“反对变态法！！不要助长性榨取！！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "反超變態示威女性A"},
					"「反對變態法！！不要助長性搾取！！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00265",
		linknext = "0007_00267",
		line = 3549,
	},
	["0007_00267"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s hard to hear all the voices speaking over each other, but I get the gist.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有很多声音在喊，虽然听不清楚，但能理解他们的理念。",
					{"rt2"},
				},
			},
			tw = {
				{
					"有很多聲音在喊，雖然聽不清楚，但能理解他們的理念。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00266",
		linknext = "0007_00268",
		line = 3559,
	},
	["0007_00268"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"These people seem to be protesting the Lewd Code and standing for women’s rights.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说这些人好像是要抗议“变态法”，以及主张女性的权利。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說這些人好像是要抗議「變態法」，以及主張女性的權利。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00267",
		linknext = "0007_00269",
		line = 3569,
	},
	["0007_00269"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00215", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0035", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“This set too... We’re dealing with some real troublemakers...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“而且那些人里……也出现了棘手的家伙……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「而且那些人裡……也出現了棘手的傢伙……」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00268",
		linknext = "0007_00270",
		line = 3584,
	},
	["0007_00270"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00218", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=12},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...So something like this has happened before?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……这种事情过去也发生过吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……這種事情過去也發生過嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00269",
		linknext = "0007_00271",
		line = 3596,
	},
	["0007_00271"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00205", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="スス子11", id=11, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0036", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Susu’s seen this for herself about five times already! Sure, we’ve got land and so we stand out, which is why it’s easy for them to make a fuss like this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“就丝丝知道的，这已经是第五次了！我们这里有土地又很显眼，很适合办那类活动吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「就絲絲知道的，這已經是第五次了！我們這裡有土地又很顯眼，很適合辦那類活動吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00270",
		linknext = "0007_00272",
		line = 3612,
	},
	["0007_00272"] = {
		{"fgact", ch="スス子11", id=11, act="移動", x=-400, y=0, time=800},
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00201", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", alpha=0, ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=1, a_chr151=1, mode=3, x=595, y=-5},
		{"fgact", ch="シューベルト12", id=12, lv=12, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="シューベルト12", id=12, act="移動", x=-200, y=0, time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0057", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“I’ve seen them quite often online as well... You must remember, Susuko. The time that one famous account criticized Seiran Island from an LGBT perspective.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“除此之外，在网络上也很常见呢……就是有个出名的昵称会从LGBT的观点来批判青蓝岛啊，丝丝子君。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「除此之外，在網路上也很常見呢……就是有個出名的暱稱會從LGBT的觀點來批判青藍島啊，絲絲子君。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00271",
		linknext = "0007_00273",
		line = 3628,
	},
	["0007_00273"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00201", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="スス子11", id=11, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0037", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Oh, s’right. A sorta young someone? Saying ‘Seiran Island must conduct discussions on agender issues’ or something? The e-warfare fifth squad had to go and squash the drama.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“啊，对对，好像是个年轻人呢。说什么‘青蓝岛应该要讨论无性别问题’什么的，把事情闹得很大，还被电子战的五队找了出来哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「啊，對對，好像是個年輕人呢。說什麼『青藍島應該要討論無性別問題』什麼的，把事情鬧得很大，還被電子戰的五隊找了出來哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00272",
		linknext = "0007_00274",
		line = 3644,
	},
	["0007_00274"] = {
		{"fg", file="schubert_01m_00002", file2="schubert_01m_00214", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0058", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Though I merely collected data as my main job is an administrative one... It seems most of the discussion was quickly crowded out by feminists.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“我主要注重实务，所以只是在收集数据……看来是不知不觉间被女性主义者给吞没淘汰了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「我主要注重實務，所以只是在收集數據……看來是不知不覺間被女性主義者給吞沒淘汰了呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00273",
		linknext = "0007_00275",
		line = 3659,
	},
	["0007_00275"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00213", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0038", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“And now so-called extremists shoot to spread their stature by arguing both. That huge group ended up getting absorbed and the situation was settled. Weird sitch.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“现在由于过激派的同伴增加，所以双方都有所主张，能够吸收掉那样大的势力，算是了结了一件事呢，真怪。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「現在由於過激派的同伴增加，所以雙方都有所主張，能夠吸收掉那樣大的勢力，算是了結了一件事呢，真怪。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00274",
		linknext = "0007_00276",
		line = 3674,
	},
	["0007_00276"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That... is something that never happened in my world.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是在──我的世界里没发生的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那是在──我的世界裡沒發生的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00275",
		linknext = "0007_00277",
		line = 3684,
	},
	["0007_00277"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...At least I don’t think it did.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……我是这样想的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……我是這樣想的。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00276",
		linknext = "0007_00278",
		line = 3694,
	},
	["0007_00278"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I guess Seiran Island has become the center of those kinds of social movements in World B.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在B世界，青蓝岛成了那种运动的中心地带吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"在B世界，青藍島成了那種運動的中心地帶嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00277",
		linknext = "0007_00279",
		line = 3704,
	},
	["0007_00279"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In World A, Governor Hitoura seems to have staved them off through donations and pork-barrel politicking.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在A世界的话，这部分应该已经靠着仁浦氏撒钱控制下来了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在A世界的話，這部分應該已經靠著仁浦氏撒錢控制下來了。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00278",
		linknext = "0007_00280",
		line = 3714,
	},
	["0007_00280"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But even that isn’t enough to keep them down here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然而尽管如此还是压制不住的原因。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然而儘管如此還是壓制不住的原因。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00279",
		linknext = "0007_00281",
		line = 3724,
	},
	["0007_00281"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There can only be one reason. The influence of the Lewd Code and the USP.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无疑就是‘变态法’和‘USD’的影响吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無疑就是『變態法』和『USD』的影響吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00280",
