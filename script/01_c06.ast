		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, well... That was nothing, really.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊啊，没什么……我没做什么大事啦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊啊，沒什麼……我沒做什麼大事啦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00380",
		linknext = "0007_00382",
		line = 5170,
	},
	["0007_00382"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“All that really went through my mind was that if they were repulsed by sex... then maybe they’d run off in fear if I showed them my junk.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我只是想说对方厌恶性行为的话，那她看到我的男根应该会吓得逃跑……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我只是想說對方厭惡性行為的話，那她看到我的男根應該會嚇得逃跑……」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00381",
		linknext = "0007_00383",
		line = 5181,
	},
	["0007_00383"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00309", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...Either way, I’m just glad it worked.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……总之，幸好这招的结果顺利。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……總之，幸好這招的結果順利。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00382",
		linknext = "0007_00384",
		line = 5193,
	},
	["0007_00384"] = {
		{"fg", file="mizuhiki_01m_00001", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00225", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0015", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“...You look pretty glum for someone who feels that way. Is something the matter...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“……不过，你的表情好阴沉啊？怎么了吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「……不過，你的表情好陰沉啊？怎麼了嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00383",
		linknext = "0007_00385",
		line = 5208,
	},
	["0007_00385"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00218", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
