		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What was that...?! Is there some kind of code encrypted in that line just now?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么回事……！？她刚才那句话，里面有暗号吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼回事……！？她剛才那句話，裡面有暗號嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00641",
		linknext = "0007_00643",
		line = 8750,
	},
	["0007_00643"] = {
