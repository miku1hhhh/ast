			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Hold on, you two! Two anal analysts must never rear up and butt heads with their butts in an ass duel! It’s absolutely ver-butt-en!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“慢着，你们两个！你们都是肛门的分析家，但不准你们用肛门来进行肛斗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「慢著，妳們兩個！妳們都是肛門的分析家，但不准妳們用肛門來進行肛鬥！」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00207",
