			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Here, I’ll pat it for you instead.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我代替她摸摸你的头，来吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我代替她摸摸妳的頭，來吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00624",
		linknext = "0007_00626",
		line = 8515,
