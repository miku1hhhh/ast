	["0007_00368"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’m sure I would have passed out had this been the old me, before I overcame my past.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是在穿越过去之前的我，想必会昏倒吧。",
