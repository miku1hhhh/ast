		linkback = "0007_00384",
		linknext = "0007_00386",
		line = 5220,
	},
	["0007_00386"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00301", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...I just thought that maybe they had a point with what they were saying.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……我在想他们说的话，也算是有道理。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……我在想他們說的話，也算是有道理。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00385",
		linknext = "0007_00387",
		line = 5232,
	},
	["0007_00387"] = {
		{"fg", file="mizuhiki_01m_00001", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00223", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In a way, my position is close to what those women protestors were saying.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个示威集团的女性所主张的内容，在某种程度上和我很相像。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那個示威集團的女性所主張的內容，在某種程度上和我很相像。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00386",
		linknext = "0007_00388",
		line = 5245,
	},
	["0007_00388"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We hate perverted sex, and forcing it on people is wrong.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她讨厌变态，认为强制是种恶行。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她討厭變態，認為強制是種惡行。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00387",
		linknext = "0007_00389",
		line = 5255,
	},
	["0007_00389"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Our convictions are firm to the point that we believe others should feel the same way.",
					{"rt2"},
				},
			},
			cn = {
				{
					"并觉得别人也应该这么做，贯彻自己的信念。",
					{"rt2"},
				},
			},
			tw = {
				{
					"並覺得別人也應該這麼做，貫徹自己的信念。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00388",
		linknext = "0007_00390",
		line = 5265,
	},
	["0007_00390"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Where I used force, those women used words.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我使用武力，她们则是靠言语。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我使用武力，她們則是靠言語。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00389",
		linknext = "0007_00391",
		line = 5275,
	},
	["0007_00391"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don’t see much of a difference between us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不觉得这样有多大的差别。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不覺得這樣有多大的差別。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00390",
		linknext = "0007_00392",
		line = 5285,
	},
	["0007_00392"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If anything, they’re the ones acting in a more civilized, constructive way.",
					{"rt2"},
				},
			},
			cn = {
				{
					"反倒觉得她们的做法更加有文化涵养，更有建设性。",
					{"rt2"},
				},
			},
			tw = {
				{
					"反倒覺得她們的做法更加有文化涵養，更有建設性。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00391",
		linknext = "0007_00393",
		line = 5295,
	},
	["0007_00393"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而且……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而且……」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00392",
		linknext = "0007_00394",
		line = 5306,
	},
	["0007_00394"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"People who fall in love with others of the same sex do exist in this world.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个世界上真的有喜欢同性的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個世界上真的有喜歡同性的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00393",
		linknext = "0007_00395",
		line = 5316,
	},
	["0007_00395"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My little sister is one of them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就像我的妹妹一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就像我的妹妹一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00394",
		linknext = "0007_00396",
		line = 5326,
	},
	["0007_00396"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They’re not wrong to say that these people are being unconsciously persecuted here on this island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他或她们在这座岛上于无意识间受到迫害，是确有其事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他或她們在這座島上於無意識間受到迫害，是確有其事。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00395",
		linknext = "0007_00397",
		line = 5336,
	},
	["0007_00397"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There’s what Susuko said, too. “We’re just having fun.”",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且丝丝子说的“我就是喜欢才做爱的啊”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且絲絲子說的「我就是喜歡才做愛的啊」。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00396",
		linknext = "0007_00398",
		line = 5346,
	},
	["0007_00398"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s really just an excuse used by those on the side of the establishment.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这是制定体制方的理由。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這是制定體制方的理由。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00397",
		linknext = "0007_00399",
		line = 5356,
	},
	["0007_00399"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A form of violence wielded by the overwhelming majority that they just call “common sense.”",
					{"rt2"},
				},
			},
			cn = {
				{
					"是以压倒性多数人的认知视为常识的一种暴力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是以壓倒性多數人的認知視為常識的一種暴力。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00398",
		linknext = "0007_00400",
		line = 5366,
	},
	["0007_00400"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We were made to suffer under them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们一直为其所苦。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們一直為其所苦。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00399",
		linknext = "0007_00401",
		line = 5376,
	},
	["0007_00401"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s why I feel conflicted.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正因如此，我的心情感到很复杂。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正因如此，我的心情感到很複雜。",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00400",
		linknext = "0007_00402",
		line = 5386,
	},
	["0007_00402"] = {
		{"fg", file="mizuhiki_01m_00001", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00214", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0016", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“But you know, that could just be a stance she’s taking to pay her bills... Especially if she’s a professor, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“可是像她那样子，可能是要维持家计……如果是大学教授的话，就更是如此了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「可是像她那樣子，可能是要維持家計……如果是大學教授的話，就更是如此了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00401",
		linknext = "0007_00403",
		line = 5401,
	},
	["0007_00403"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00218", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I mean, probably, yeah...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，是这样没错……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，是這樣沒錯……」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00402",
		linknext = "0007_00404",
		line = 5413,
	},
	["0007_00404"] = {
		{"fg", file="mizuhiki_01m_00001", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00215", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0017", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“In fact, it sounds like she once released a book about how homosexuality goes against the laws of nature... And that she only changed her position to ride the recent LGBT wave.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“其实那名大学教授以前好像写过一本书，说同性恋者违反自然伦理之类的……是搭上最近的LGBT热潮而改变主张了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「其實那名大學教授以前好像寫過一本書，說同性戀者違反自然倫理之類的……是搭上最近的LGBT熱潮而改變主張了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00403",
		linknext = "0007_00405",
		line = 5428,
	},
	["0007_00405"] = {
