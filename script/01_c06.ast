	["0007_00193"] = {
		{"fg", file="ran_01f_00001", file1="ran_01f_00101", file2="ran_01f_00202", file4="ran_01f_00401", path=":fg/ran_01f/", id=30, ch="蘭", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0018", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“It happens often to people who’ve just come to the island, but their cliteracy is quickly fostered. It’s a major factor distinguishing residents from tourists.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“刚来岛上的人很容易这样，不过很快就能培养出龟头的素养。这也是区分居民和旅客的重大要素。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「剛來島上的人很容易這樣，不過很快就能培養出龜頭的素養。這也是區分居民和旅客的重大要素。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00192",
		linknext = "0007_00194",
		line = 2558,
	},
	["0007_00194"] = {
