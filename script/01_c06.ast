	["0007_00662"] = {
		{"fg", file="rei_02m_00006", file1="rei_02m_00105", file2="rei_02m_00202", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", alpha=0, ch_origin="礼", ch="礼9", mw="mw", sync=1, a_chr151=1, mode=3, x=-805, y=-5},
		{"fgact", ch="礼9", id=9, lv=9, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="礼9", id=9, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0138", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Okay, then! Time to put on a little show to cheer Junnosuke up! All of you, start getting ready for the number we did for the last end-of-year FS party!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“好，为了让淳之介打起精神，我来表演个才艺！你们！准备一下去年的FS尾牙的节目～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「好，為了讓淳之介打起精神，我來表演個才藝！你們！準備一下去年的FS尾牙的節目～！」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00661",
		linknext = "0007_00663",
		line = 9048,
	},
	["0007_00663"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00103", file2="ikuko_01m_00202", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
