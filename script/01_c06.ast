			},
			[1499] = {
				{"transitiontime", time=300, timestamp=8, delay2=1500},
			},
		},
		text = {
			vo = {
				{"vo", file="tohka0112", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Huh? Oh... Yes, I was born in Kyoto. I didn’t pick up much of the accent as I was sent to serve right away.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“咦？啊……对，我是京都出生的。很早就离家工作，不太记得方言了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「咦？啊……對，我是京都出生的。很早就離家工作，不太記得方言了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00081",
		linknext = "0007_00083",
		line = 1067,
	},
	["0007_00083"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00104", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=11},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I-I see... Oh, what’s your birthday?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这、这样啊……啊，那你的生日是？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這、這樣啊……啊，那妳的生日是？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00082",
		linknext = "0007_00084",
		line = 1079,
	},
	["0007_00084"] = {
		{"fg", file="tohka_02l_00003", file1="tohka_02l_00101", file2="tohka_02l_00207", path=":fg/tohka_02l/", id=12, lv=12, head="tohka_02l", ch_origin="桐香", ch="桐香12", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0113", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“October 17. I don’t know if it really is, but my older sister said it was, so I think it should be the truth.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“10月17日。虽然不晓得是不是真的，但这是姐姐告诉我的，我想应该是真的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「10月17日。雖然不曉得是不是真的，但這是姐姐告訴我的，我想應該是真的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00083",
		linknext = "0007_00085",
		line = 1094,
	},
	["0007_00085"] = {
