				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Yeah, t-that’s hate speech...! See that, ’Bana? I can be a full-time protestor too! Shit, I’m starting to get excited! Take a shot, take a shot!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“仇、仇恨言论……！看到了吗？阿橘，那是真的专业市民哦！糟糕，我好兴奋啊，快拍照快怕照！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「仇、仇恨言論……！看到了嗎？阿橘，那是真的專業市民哦！糟糕，我好興奮啊，快拍照快怕照！」",
					{"rt2"},
				},
			},
		},
