	},
	["0007_00288"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0012", path=":vo/", ch="gmob"},
			},
			ja = {
				{
					name = {"モブ女C", "デモの中心人物"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Protesting Ringleader"},
					"“Hitoura, you sexual exploiter and pervert! Resign as prefectural governor! Don’t treat women like porn stars! Make Japan a zero-perversion nation!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "示威的核心人物"},
					"“让压榨性行为的变态仁浦县知事下台！！别把女性当成AV女优一样！！让日本变成零变态的国家！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "示威的核心人物"},
					"「讓壓搾性行為的變態仁浦縣知事下台！！別把女性當成AV女優一樣！！讓日本變成零變態的國家！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00287",
		linknext = "0007_00289",
		line = 3848,
	},
	["0007_00289"] = {
