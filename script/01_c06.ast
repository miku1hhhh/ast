				{"vo", file="rei0135", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Right, Junnosuke?! Aren’t you feeling lonely ’cause you can’t see Hinami?! It just doesn’t feel right unless she pats your head once a day, right?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“欸！淳之介！不能见雏见很寂寞吧！？要是不能一天给她摸摸头一次，心情就静不下来啊！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「欸！淳之介！不能見雛見很寂寞吧！？要是不能一天給她摸摸頭一次，心情就靜不下來啊！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00623",
		linknext = "0007_00625",
		line = 8503,
	},
	["0007_00625"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00225", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=13},
		{"text"},
		text = {
