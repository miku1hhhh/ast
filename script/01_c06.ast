	["0007_00666"] = {
		{"fg", file="rei_02m_00006", file1="rei_02m_00105", file2="rei_02m_00227", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="礼9", id=9, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0140", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You don’t know it, Junnosuke?! Holeyrhythm was ridiculously popular! That was the same time Hamedori suits came out, and everyone was into it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你不知道吗，淳之介！？爱爱主义，超级流行的耶！当时Hamedori君做了玩偶装，造成很大的热潮！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你不知道嗎，淳之介！？愛愛主義，超級流行的耶！當時Hamedori君做了玩偶裝，造成很大的熱潮！」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00665",
		linknext = "0007_00667",
		line = 9106,
	},
	["0007_00667"] = {
