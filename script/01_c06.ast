			cn = {
				{
					name = {"凛"},
					"“……哦，这集会还真大型啊，像大蚊子一样在一起嗡嗡叫，蠢不蠢啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「……哦，這集會還真大型啊，像大蚊子一樣在一起嗡嗡叫，蠢不蠢啊。」",
					{"rt2"},
				},
			},
