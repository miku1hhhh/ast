		line = 2752,
	},
	["0007_00208"] = {
		{"fg", file="schubert_01m_00001", file1="schubert_01m_00102", file2="schubert_01m_00203", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=395, y=-5},
