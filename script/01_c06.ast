				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Oh, Holeyrhythm! That takes me back, it used to be so popular!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“啊，好怀念啊～！爱爱主义，以前很流行呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「啊，好懷念啊～！愛愛主義，以前很流行呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00662",
