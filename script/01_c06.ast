	["0007_00207"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0009", path=":vo/", ch="gmob"},
			},
			ja = {
				{
					name = {"モブ女C", "アナル保守派女子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Anally Conservative Girl"},
					"“Butt of course. We both preside over asses—as such, asses should be all we need here. No need to make this a hole affair.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "肛门保守派女子"},
					"“如你所说，我们都是敬畏肛门者──既然如此需要好好谈谈的，就是肛门了，不需要其他决定。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "肛門保守派女子"},
					"「如妳所說，我們都是敬畏肛門者──既然如此需要好好談談的，就是肛門了，不需要其他決定。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00206",
