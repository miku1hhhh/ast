			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“She really did mean well, from the bottom of her heart. It sounds like she wanted you to join us because she thought it’d be best for you...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“可是她是真心怀着善意，觉得这样对亲爱的好，才说希望我跟着你的哦……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「可是她是真心懷著善意，覺得這樣對親愛的好，才說希望我跟著你的哦……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00709",
		linknext = "0007_00711",
		line = 9711,
	},
