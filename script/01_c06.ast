		{"fg", file="rin_01m_00001", file1="rin_01m_00101", file2="rin_01m_00216", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0043", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“These women who always go on about their rights must have massive egos despite their awful educations. They assume everyone ought to go along with their no-name junior college graduate selves.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“老爱主张权利的女人，明明学历没多高，就只会放大自我意识，让旁人来配合自己，还当成理所当然，那些短大毕业的底层人类。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「老愛主張權利的女人，明明學歷沒多高，就只會放大自我意識，讓旁人來配合自己，還當成理所當然，那些短大畢業的底層人類。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00294",
		linknext = "0007_00296",
		line = 3966,
	},
	["0007_00296"] = {
