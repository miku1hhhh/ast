	["0007_00369"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Well, okay. Exposing your junk to a group of protestors would be enough to make anyone normal feel like passing out.",
					{"rt2"},
				},
