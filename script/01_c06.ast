			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She seems pretty pissed off... We’ll need to behave ourselves here, don’t want to upset them further.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对方似乎很生气……小心不要刺激她，尽量不要采取不恰当的行动。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對方似乎很生氣……小心不要刺激她，儘量不要採取不恰當的行動。」",
