			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“We are technically overseers as well. Part of our job is keeping watch over these kinds of things... Sorry, we’ll stay out of your way.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“我们姑且是要监视你的，也得来看看你这种时候工作做得怎么样……抱歉啊，我们尽量不会打扰你的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「我們姑且是要監視你的，也得來看看你這種時候工作做得怎麼樣……抱歉啊，我們儘量不會打擾你的。」",
					{"rt2"},
				},
			},
		},
