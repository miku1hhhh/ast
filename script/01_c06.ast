			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Come on, Darling. I can’t clean your wounds if you’re moving around. Don’t blame me if you get germs in your leg and it rots so we have to amputate it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“好了，亲爱的，要是乱动的话，伤口会很难看喔？要是细菌跑进去，脚烂掉要切断的话，我可不管哦～”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「好了，親愛的，要是亂動的話，傷口會很難看喔？要是細菌跑進去，腳爛掉要切斷的話，我可不管哦～」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00548",
		linknext = "0007_00550",
		line = 7527,
	},
