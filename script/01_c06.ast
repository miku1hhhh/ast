		text = {
			vo = {
				{"vo", file="ikuko0124", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Well, I’ve trained to be combat-ready even when I’m drunk since I was seven! Glug, glug... Mmh, I guess this is enough to make me feel a little excited?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“郁从七岁开始就算喝醉也会做战斗训练～咕噜咕噜……噗哈，喝到这个程度，其实是会有点兴奋呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「郁從七歲開始就算喝醉也會做戰鬥訓練～咕嚕咕嚕……噗哈，喝到這個程度，其實是會有點興奮呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00659",
		linknext = "0007_00661",
		line = 9023,
	},
