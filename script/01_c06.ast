		{"transitiontime", time=300},
		{"cgact", file="cgact", id=11, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine", lv=11},
		{"fg", file="jun_01f_00003", file1="jun_01f_00104", file2="jun_01f_00228", path=":fg/jun_01f/", id=30, ch="淳之介", lv=11, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...Mh! Right, Touka! Where are you from, Touka? You haven’t always lived here, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……唔，对了桐香！桐香是哪里出身的？你不是一直住这里吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……唔，對了桐香！桐香是哪裡出身的？妳不是一直住這裡吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00080",
		linknext = "0007_00082",
		line = 1049,
	},
	["0007_00082"] = {
		{"fg", file="tohka_02l_00003", file1="tohka_02l_00101", file2="tohka_02l_00209", path=":fg/tohka_02l/", id=12, lv=12, head="tohka_02l", alpha=0, ch_origin="桐香", ch="桐香12", mw="mw", sync=1, a_chr151=1, mode=3, x=195, y=-5},
