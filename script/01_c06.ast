	["0007_00573"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Call them what they are, TAEs... But yes, I made those in World A. Yet Nanase had Eggs and a nipple rotor-shaped taser.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“叫T-A-E的……对了，那是我在A世界制作的。可是奈奈濑拿着的是‘Egg’和‘乳头跳蛋型电击枪’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「叫T-A-E的……對了，那是我在A世界製作的。可是奈奈瀨拿著的是『Egg』和『乳頭跳蛋型電擊槍』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00572",
		linknext = "0007_00574",
		line = 7818,
	},
	["0007_00574"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00209", path=":fg/rei_02m/", id=9, lv=8, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
