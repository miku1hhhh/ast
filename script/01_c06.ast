	["0007_00406"] = {
		{"fg", file="mizuhiki_01m_00001", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00201", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0018", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Plus—you never know, there might be people out there who want to spice up their boring lives by coming up with imaginary enemies, don’t you think?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“而且──也有人会在无聊的人生里制造假想敌，去与对方竞争吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「而且──也有人會在無聊的人生裡製造假想敵，去與對方競爭吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00405",
		linknext = "0007_00407",
		line = 5453,
	},
	["0007_00407"] = {
