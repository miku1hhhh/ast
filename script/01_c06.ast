	["0007_00728"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00103", file2="ikuko_01m_00214", path=":fg/ikuko_01m/", id=10, lv=9, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
