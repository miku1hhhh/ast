			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“There were three of them in different colors and they danced in perfect rhythm. It went, ‘Fuck me once again, in my hole-yrhythm, all this lust I feel, fucked like an animal.’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“有三只不同颜色的玩偶，会出来跳舞。唱‘进进出出，我的爱爱主义，这种情欲就要大干特干’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「有三隻不同顏色的玩偶，會出來跳舞。唱『進進出出，我的愛愛主義，這種情慾就要大幹特幹』。」",
					{"rt2"},
				},
			},
		},
