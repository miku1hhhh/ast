			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Why?! I honestly couldn’t stand it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为什么！？她不是真心讨厌我吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為什麼！？她不是真心討厭我嗎！？」",
					{"rt2"},
