					name = {"郁子", "Ikuko"},
					"“What about the one other girl? It was Nanase, Hinami, Fumino, and Misaki there, right? Just the four of them?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“还有一件事，出现在那里的是奈奈濑酱、雏见酱，文乃酱，还有美岬酱，只有她们四个吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「還有一件事，出現在那裡的是奈奈瀨醬、雛見醬，文乃醬，還有美岬醬，只有她們四個吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00566",
		linknext = "0007_00568",
		line = 7746,
	},
	["0007_00568"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00102", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=8, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0128", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You’re right... Junnosuke’s little sister wasn’t there. Not that it’d be unusual for an operator to be away from the battlefront...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是啊……没看到淳之介的妹妹。引导员不在战场上是理所当然的事情──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是啊……沒看到淳之介的妹妹。引導員不在戰場上是理所當然的事情──」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00567",
		linknext = "0007_00569",
		line = 7761,
	},
	["0007_00569"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s right. Asa was always there alongside us too.",
					{"rt2"},
