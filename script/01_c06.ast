				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Hmph. It would’ve been kind of fun if it’d turned into a brawl... But I was able to get a video of those fools retreating pathetically. I can chalk this up as a Rin.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“哼，要是互殴的话还有趣一点……不过，我也拍到了那些凄惨逃走的笨蛋的视频，今天就先用花丸告一段落吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「哼，要是互毆的話還有趣一點……不過，我也拍到了那些淒慘逃走的笨蛋的影片，今天就先用花丸告一段落吧。」",
					{"rt2"},
				},
			},
		},
