	},
	["0007_00708"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0130", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“You know how Tokie doesn’t understand the way other people feel... She couldn’t even see why you hated it so much...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“你看嘛，桐香酱完全不懂别人的心情……我是不懂你怎么会觉得她在找碴啦，不过……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「你看嘛，桐香醬完全不懂別人的心情……我是不懂你怎麼會覺得她在找碴啦，不過……」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00707",
		linknext = "0007_00709",
		line = 9684,
	},
	["0007_00709"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00217", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=11},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I really suffered because of her! Well okay, I’ve put it behind me! Because we’re comrades now!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我因为那样觉得很痛苦耶！！！不是，我是已经忘记了啦！！！因为我们现在是同伴啊！！！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我因為那樣覺得很痛苦耶！！！不是，我是已經忘記了啦！！！因為我們現在是同伴啊！！！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0007_00708",
		linknext = "0007_00710",
		line = 9696,
	},
	["0007_00710"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00104", file2="ikuko_01m_00229", path=":fg/ikuko_01m/", id=10, lv=9, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
