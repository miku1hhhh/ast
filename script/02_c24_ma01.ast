		{"fgact", ch="麻沙音3", id=3, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0187", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You’re... going to lend each other sex sleeves like some kind of game?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那东西能像游戏一样借来借去的吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那東西能像遊戲一樣借來借去的嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00178",
		linknext = "0057_00180",
		line = 3687,
	},
	["0057_00180"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=29},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, since platonic love connects us, it’s only logical to connect with our sex sleeves too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“当然，我们是通过友情联系在一起──所以也需要连飞机杯都系在一起吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「當然，我們是通過友情聯繫在一起──所以也需要連飛機杯都繫在一起吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00179",
		linknext = "0057_00181",
		line = 3699,
	},
	["0057_00181"] = {
