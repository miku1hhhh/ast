	},
	["0057_00265"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=20},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You’re surprised? To think you were my strongest follower and promising new star, @MIZUHIKI_A.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我才是吓一跳呢？没想到水引酱居然是我的忠实粉丝，被寄予厚望的新星“＠MIZUHIKI＿A”先生呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我才是嚇一跳呢？沒想到水引醬居然是我的忠實粉絲，被寄予厚望的新星“＠MIZUHIKI＿A”先生呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00264",
		linknext = "0057_00266",
		line = 5009,
	},
	["0057_00266"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She’s supported me as my number one fan since the day I started creating sex sleeves.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是从我开始做飞机杯的时候，就一直支持我的粉丝第一号。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是從我開始做飛機杯的時候，就一直支持我的粉絲第一號。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00265",
		linknext = "0057_00267",
