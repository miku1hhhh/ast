		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“When’s Shu getting here? I should message him first.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“舒君有说他什么时候会来吗？总之先联系他吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
