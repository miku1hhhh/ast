		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00214", path=":fg/ikuko_01m/", id=23, lv=23, head="ikuko_01m", ch_origin="郁子", ch="郁子23", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=300, rule="eff_008_00000"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1192", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I see. As the leader of the NLNS, Darling has to be on his toes all the time to look out for us like a big brother.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“这样啊。NLNS的大家对亲爱的而言都像是一定要守护的部下，作为队长若是不时时刻刻提高警觉是不行的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「這樣啊。NLNS的大家對親愛的而言都像是一定要守護的部下，作為隊長若是不時時刻刻提高警覺是不行的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00051",
		linknext = "0057_00053",
		line = 900,
	},
	["0057_00053"] = {
