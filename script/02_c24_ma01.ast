			},
		},
		text = {
			vo = {
				{"vo", file="nanase0158", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Oh, woe is me, I’m so—Huh? Is nobody watching Jun and them? That one over there is...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“虽然我的个性很忧郁，但我不……哎呀？对面也有孩子在看着淳他们呢。那孩子应该是──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「雖然我的個性很憂鬱，但我不……哎呀？對面也有孩子在看著淳他們呢。那孩子應該是──」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00114",
		linknext = "0057_00116",
		line = 2268,
	},
	["0057_00116"] = {
		{"bgm", file="bgm08", vol=100},
