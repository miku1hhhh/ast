			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Spoken like a true gentleman with common interests.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呵，真不亏是跟我臭气相投的男人──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呵，真不虧是跟我臭氣相投的男人──！」",
					{"rt2"},
				},
