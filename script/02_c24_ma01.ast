			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“But everyone’s getting along surprisingly well... What should we do? Should we take our leader back?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不过每个人好像都吓了一跳的样子……想怎么做呢，我们的队长可要被抢走了喔……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不過每個人好像都嚇了一跳的樣子……想怎麼做呢，我們的隊長可要被搶走了喔……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00094",
		linknext = "0057_00096",
		line = 1756,
	},
	["0057_00096"] = {
