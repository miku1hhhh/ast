	["0057_00183"] = {
		{"se", id=0, loop=0, file="se_a138"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=0, mw="mw", mode=1, sync=0, x=-5, y=-5},
