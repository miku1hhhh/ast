			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Even if we pamper him, it is not as his equal. It may be okay from your point of view, but this is mild cuckoldry!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“就算是能像他撒娇，但关系也不是对等的呢……但是对大家来说没关系吗，很轻易地就会被戴绿帽了呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「就算是能像他撒嬌，但關係也不是對等的呢……但是對大家來說沒關係嗎，很輕易地就會被戴綠帽了呢？」",
					{"rt2"},
				},
			},
		},
