	["0057_00062"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00208", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0222", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Trust me, if I won the lottery, I’d buy so much audio porn. It would swell my database to the brim.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“我说啊。如果中乐透的话，就可以大量购买音声作品还可以让我的资料库更充实一点──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「我說啊。如果中樂透的話，就可以大量購買音聲作品還可以讓我的資料庫更充實一點──」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00061",
		linknext = "0057_00063",
		line = 1140,
	},
	["0057_00063"] = {
