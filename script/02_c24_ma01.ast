			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“It’s like a scene from the Power Grangers! They’re hot, they’re cool, but don’t you think it’s terrible, Hinami?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这家伙只会用不纯洁的眼光在看战队跟骑士啦……！明明这么热血跟帅气地说……！你不觉得很过分吗，雏见……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這傢伙只會用不純潔的眼光在看戰隊跟騎士啦……！明明這麼熱血跟帥氣地說……！你不覺得很過分嗎，雛見……！？」",
					{"rt2"},
				},
			},
		},
