					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Stop it! There’s nothing in my data about you giving noogies!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“喂喂别这样──！在我的数据库里，可没有攻击太阳穴这个动作啊──！”",
					{"rt2"},
				},
			},
