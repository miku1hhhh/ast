			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I’ve never seen childhood friends live happily ever after in any manga either.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我看过的漫画也是从没见过青梅竹马走向幸福终点的……？”",
