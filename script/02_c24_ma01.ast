					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Sounds great! I can bring a high-end PC so we can perform with instruments.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“挺不错的啊！也可以准备一台高阶电脑，要是有乐器之类的也能进行演奏，挺开心的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「挺不錯的啊！也可以準備一台高階電腦，要是有樂器之類的也能進行演奏，挺開心的。」",
					{"rt2"},
				},
			},
		},
