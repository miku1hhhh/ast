	["0057_00055"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", file2="misaki_01m_00210", path=":fg/misaki_01m/", id=6, lv=6, head="misaki_01m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-705, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0163", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I think it’s good for Junnosuke, and as his first friend, I can honestly say I’m happy for him.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我觉得这对淳之介君来说是好事……但作为最开始的伙伴，是没法坦率的为他开心……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我覺得這對淳之介君來說是好事……但作為最開始的夥伴，是沒法坦率的為他開心……」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00054",
