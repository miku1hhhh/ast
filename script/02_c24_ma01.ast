		text = {
			vo = {
				{"vo", file="nanase0156", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Huh? H-he’s just my childhood friend and first crush. To call me his wife is a bit much, don’t you think?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“咦？……再，再怎么说我也是青梅竹马啊？是初恋的对象啊？有这些要素的话，应该……还蛮强的吧……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「咦？……再，再怎麼說我也是青梅竹馬啊？是初戀的對象啊？有這些要素的話，應該……還蠻強的吧……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00104",
		linknext = "0057_00106",
		line = 2017,
	},
	["0057_00106"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", file2="misaki_01m_00222", path=":fg/misaki_01m/", id=6, lv=6, head="misaki_01m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-705, y=-5},
