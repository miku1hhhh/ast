	["0057_00243"] = {
		{"se", id=0, loop=0, file="se_a078"},
		{"se", id=1, loop=0, file="se_a098"},
		{"fg", file="nanase_01m_00007", file1="nanase_01m_00102", file2="nanase_01m_00209", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", alpha=0, ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=1, a_chr151=1, mode=3, x=-805, y=-5},
