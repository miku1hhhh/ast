		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0227", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“It would be the ultimate form of masturbation! I’d love to collect data on the phenomenon, especially as no one’s done it before!”",
