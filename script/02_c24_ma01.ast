					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“They sound like a bunch of middle school guys...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“真的就跟一般男国中生一样的谈话内容呢。那些人们……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「真的就跟一般男國中生一樣的談話內容呢。那些人們……」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00062",
		linknext = "0057_00064",
		line = 1153,
	},
	["0057_00064"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What would you buy if you had 1,000,000 yen, Mizuhiki?”",
					{"rt2"},
				},
			},
			cn = {
