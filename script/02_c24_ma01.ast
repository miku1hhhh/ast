		text = {
			vo = {
				{"vo", file="misaki0174", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“You’re staring over there too, Ikuko?! Leave it to me. Literature is filled with ‘I told ya so!’ stories. Feel free to create a new addition for the library!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“郁子酱也终于觉醒了〝那个〞吗……！？包在我身上，文学中有很多〝这样的〞作品！这样的话，也可以搞同人志──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「郁子醬也終於覺醒了〝那個〞嗎……！？包在我身上，文學中有很多〝這樣的〞作品！這樣的話，也可以搞同人誌──！」",
					{"rt2"},
				},
			},
		},
