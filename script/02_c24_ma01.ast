	["0057_00205"] = {
		{"fg", file="mizuhiki_01m_00002", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00212", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", alpha=0, ch_origin="水引", ch="水引15", mw="mw", sync=1, a_chr151=1, mode=3, x=195, y=-5},
		{"fgact", ch="水引15", id=15, lv=15, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="水引15", id=15, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0316", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Oh, I called him earlier, and he’s had sudden plans and can’t come anymore. You know him, he has to collect data no matter what.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“啊，刚刚跟他通电话了，说今天有急事来不了了。说是有个数据非得去收集不可。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「啊，剛剛跟他通電話了，說今天有急事來不了了。說是有個數據非得去收集不可。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00204",
		linknext = "0057_00206",
		line = 4172,
	},
	["0057_00206"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00219", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What the hell? We were supposed to take our dick measurements for our custom-fit sex sleeve.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么啊，好不容易才茎体测量了，想说两个人一起弄一个他专属的飞机杯的说。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼啊，好不容易才莖體測量了，想說兩個人一起弄一個他專屬的飛機杯的說。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00205",
		linknext = "0057_00207",
		line = 4184,
	},
	["0057_00207"] = {
		{"fg", file="mizuhiki_01m_00002", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00202", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
