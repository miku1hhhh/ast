		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0212", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Well if it isn’t Junnosuke? What’s eating at you to rush over?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“哎呀，这不是淳之介嘛。怎么啦？这么着急？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「哎呀，這不是淳之介嘛。怎麼啦？這麼著急？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00004",
		linknext = "0057_00006",
		line = 84,
	},
	["0057_00006"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You missing data again? We decided to eat lunch together Mondays and Thursdays!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么啊，你的数据又漏了吗？不是约好了周一跟周四一起吃便当嘛！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼啊，你的數據又漏了嗎？不是約好了周一跟周四一起吃便當嘛！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00005",
		linknext = "0057_00007",
		line = 96,
	},
	["0057_00007"] = {
