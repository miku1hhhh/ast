	},
	["0057_00278"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=20},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But no matter how good we insist it feels, there come times where you want to quit or punch the wall.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，不管在怎么感觉良好……也有受不了，想要停下的时候。也有想放弃的时候。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，不管在怎麼感覺良好……也有受不了，想要停下的時候。也有想放棄的時候。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00277",
		linknext = "0057_00279",
		line = 5177,
	},
	["0057_00279"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=20},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“When I fall in those ruts, I look to your glowing reviews and support and am able to propel myself out of them with your positivity.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在那种时候──水引酱热情的评论跟支持，即使就只有一点点数据，也绝对会反馈，所以我才能走到这一步。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在那種時候──水引醬熱情的評論跟支持，即使就只有一點點數據，也絕對會反饋，所以我才能走到這一步。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00278",
		linknext = "0057_00280",
		line = 5189,
	},
