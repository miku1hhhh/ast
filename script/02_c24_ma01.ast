		line = 2159,
	},
	["0057_00111"] = {
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00104", file2="fumino_01m_00203", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-355, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0143", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“U-um... Anyway, so if that’s the case, who would be the servant?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“那，那个……附带一提，从那个观点来看……应该就类似仆人……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「那，那個……附帶一提，從那個觀點來看……應該就類似僕人……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00110",
		linknext = "0057_00112",
		line = 2174,
	},
	["0057_00112"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", file2="misaki_01m_00210", path=":fg/misaki_01m/", id=6, lv=6, head="misaki_01m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-705, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0169", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Most of them fall in love with their young masters, but are treated like sex toys, and the master marries another lady for them to be thrown away!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“多半是，虽然爱上了少爷，却被当成性发泄的道具，最后少爷娶了别的千金然后被抛弃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「多半是，雖然愛上了少爺，卻被當成性發洩的道具，最後少爺娶了別的千金然後被拋棄。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00111",
		linknext = "0057_00113",
		line = 2189,
	},
