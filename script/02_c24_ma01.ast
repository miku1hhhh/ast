		},
		text = {
			vo = {
				{"vo", file="rin0223", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Aren’t we playing now? Aren’t you having fun, little birdie?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“所以这不就是在玩了嘛。对于狩猎方来说，这就是最棒的〝游戏〞了，不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「所以這不就是在玩了嘛。對於狩獵方來說，這就是最棒的〝遊戲〞了，不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00139",
