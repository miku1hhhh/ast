	["0057_00048"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", file2="asane_01m_00216", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0180", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Normal people would shut down. It’s wrong to get turned on by your own parents doing the nasty. It’s like one sumo merging with another sumo into a giant sumo!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“一般都会萎了吧，看到父母做爱还会兴奋的，在生物学上都是不同物种了。相扑选手加相扑选手配合而成的王者相扑。被淘汰的相扑选手……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「一般都會萎了吧，看到父母做愛還會興奮的，在生物學上都是不同物種了。相撲選手加相撲選手配合而成的王者相撲。被淘汰的相撲選手……」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00047",
		linknext = "0057_00049",
		line = 829,
	},
	["0057_00049"] = {
		{"fg", file="tohka_02f_00001", file1="tohka_02f_00101", file2="tohka_02f_00212", path=":fg/tohka_02f/", id=30, ch="桐香", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
