				{
					name = {"美岬", "Misaki"},
					"“More characters have entered the scene... Rivals are increasing, but we haven’t done anything!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“怎么登场的人物增加了……我们的对手这不就增加了嘛──！？”",
