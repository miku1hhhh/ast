			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“That’s not it. Reizeiin, Tadasugawa is depressed... I’ve told you before to be considerate of others and listen to what they have to say.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“并不是这样子的，冷泉院同学……糺川同学请冷静一下……应该之前就有说过，要好好考虑他人跟听人说话的吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「並不是這樣子的，冷泉院同學……糺川同學請冷靜一下……應該之前就有說過，要好好考慮他人跟聽人說話的吧……」",
					{"rt2"},
				},
			},
		},
