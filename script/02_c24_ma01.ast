					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Dreams... You mean aspirations for the future... it’s just an idea but...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“梦想，是的呢……与其说将来的梦想，倒不如说是我的理想……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「夢想，是的呢……與其說將來的夢想，倒不如說是我的理想……」",
					{"rt2"},
				},
			},
		},
