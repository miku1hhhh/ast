			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“As childhood friends, you must chase after him harder! You hold back too much. How can you be plainer than some chubby girl like me?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“青梅竹马的话，就要更加把劲啊！奈奈濑同学太低调了，要是比身为胖子的我还不起眼，该怎么办呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「青梅竹馬的話，就要更加把勁啊！奈奈瀨同學太低調了，要是比身為胖子的我還不起眼，該怎麼辦呢？」",
					{"rt2"},
				},
			},
		},
