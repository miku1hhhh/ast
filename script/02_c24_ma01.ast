			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“It has great ratings online. I believe all the folds are made in the golden ratio for an infinite spiral sensation!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“在网上很受欢迎。我记得所有的皱褶都是由黄金比例制成的，所以我可以享受无限的螺旋式爱抚──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「在網上很受歡迎。我記得所有的皺褶都是由黃金比例制成的，所以我可以享受無限的螺旋式愛撫──」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00221",
		linknext = "0057_00223",
		line = 4408,
	},
