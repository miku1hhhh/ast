	},
	["0057_00222"] = {
		{"fg", file="mizuhiki_01m_00002", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00217", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
