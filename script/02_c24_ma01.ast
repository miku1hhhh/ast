		{"fgact", ch="スス子21", id=21, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0326", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Why’s he so into that... person? Could it be... some kind of... some impossible... love?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“为什么会这么在意那个备钱啊……！为何……为什么……难道说……这就是爱……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「為什麼會這麼在意那個備錢啊……！為何……為什麼……難道說……這就是愛……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00115",
		linknext = "0057_00117",
		line = 2285,
	},
