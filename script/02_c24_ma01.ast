				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Can’t do anything about the importance of data collection. Now about the two of us using that cocksleeve...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“如果是收集数据的话就没辙了。今天就我们俩来讨论关于飞机杯──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
