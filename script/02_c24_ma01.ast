				{
					"For some reason, Asa’s changed out of her nightgown and into her going-out clothes, and her hair is done up.",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙酱也不知为什么，从睡衣换成了外出服，还绑了头发。",
					{"rt2"},
				},
			},
			tw = {
				{
					"麻沙醬也不知為什麼，從睡衣換成了外出服，還綁了頭髮。",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00231",
		linknext = "0057_00233",
		line = 4546,
	},
	["0057_00233"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=21},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Speaking of looks, since when did you start dressing up, Mizuhiki? Do you have a model or something?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说道打扮……水引你是从什么时候开始打扮的？有参考的对象吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說道打扮……水引妳是從什麼時候開始打扮的？有參考的對象嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00232",
		linknext = "0057_00234",
		line = 4558,
	},
	["0057_00234"] = {
		{"fg", file="mizuhiki_01m_00002", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00214", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0319", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“I guess... Some kid of a distant relative maybe...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“是这样的……应该是我远房亲戚的孩子吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「是這樣的……應該是我遠房親戚的孩子吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00233",
		linknext = "0057_00235",
		line = 4573,
	},
	["0057_00235"] = {
		{"fg", file="mizuhiki_01m_00002", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00211", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0319b", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“So instead of liking her, you strive to become her? Is that what started this?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“与其说喜欢那个孩子，不如说是想成为那个孩子，或许这就是契机吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「與其說喜歡那個孩子，不如說是想成為那個孩子，或許這就是契機吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00234",
		linknext = "0057_00236",
		line = 4588,
	},
	["0057_00236"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=21},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, so a role model.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嘿，那么应该是榜样吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嘿，那麼應該是榜樣吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00235",
		linknext = "0057_00237",
