	["0057_00146"] = {
		{"fg", file="rin_01m_00002", file1="rin_01m_00101", file2="rin_01m_00218", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0226", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Lately, when I look at your face, I feel like my life plan has been destroyed. It pisses me off. Please tell me it’s all in my head...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“话说回来，最近只要看到你的脸，就觉得我的前途已经完蛋了，不知为何让人特别不爽。是我多心了吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「話說回來，最近只要看到你的臉，就覺得我的前途已經完蛋了，不知為何讓人特別不爽。是我多心了嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00145",
		linknext = "0057_00147",
		line = 2940,
	},
	["0057_00147"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
