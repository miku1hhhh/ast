			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“If I’m so lucky to be treated poorly, sandwiched between my mistress and wife, I’d say I’m in the right place!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我做为第2受宠跟小三之间也相处融洽的大老婆，却还要受到粗暴的对待，那就是〝这样〞的设定……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我做為第2受寵跟小三之間也相處融洽的大老婆，卻還要受到粗暴的對待，那就是〝這樣〞的設定……！」",
					{"rt2"},
				},
			},
		},
