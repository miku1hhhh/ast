			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“It’s Misaki! I can’t stay quiet when my anal detectors go off! Won’t you let me in on your fun games too?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“──美岬登场！当我听到菊花时就无法保持沉默了！！那个胜负，也可以让这个畔美岬加入嘛！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「──美岬登場！當我聽到菊花時就無法保持沉默了！！那個勝負，也可以讓這個畔美岬加入嘛！？」",
					{"rt2"},
				},
			},
		},
