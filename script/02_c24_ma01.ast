			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Oh, if it isn’t Nakamura and Mizuhiki. Since when did those two get along in this world?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“那个是中村君跟水引酱喔。什么时候连在这边的世界都这么好了？”",
