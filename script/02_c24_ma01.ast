		{"fgact", ch="奈々瀬4", id=4, act="移動", x=200, y=0, time=300},
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=4, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...Nanase, what are you doing?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你在干嘛啊，奈奈濑？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……你在幹嘛啊，奈奈瀨？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00242",
		linknext = "0057_00244",
		line = 4697,
	},
	["0057_00244"] = {
		{"fg", file="nanase_01m_00007", file1="nanase_01m_00102", file3="nanase_01m_00306", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0165", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“What... I was just curious about what sort of friends Jun has...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“咦……就是想知道淳的朋友，是怎么样的人之类……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「咦……就是想知道淳的朋友，是怎麼樣的人之類……」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00243",
		linknext = "0057_00245",
		line = 4712,
	},
	["0057_00245"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00203", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You’re really turning into my mom, aren’t you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就为了这样，才进化成妈妈模式吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就為了這樣，才進化成媽媽模式嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00244",
		linknext = "0057_00246",
		line = 4724,
	},
	["0057_00246"] = {
		{"fg", file="nanase_01m_00007", file1="nanase_01m_00102", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0166", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Um, Mizuhiki... was it? What are your plans for this evening. Will you stay for dinner?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那个，秋野君……水引同学？今晚想怎么样呢？要吃饭吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那個，秋野君……水引同學？今晚想怎麼樣呢？要吃飯嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00245",
		linknext = "0057_00247",
		line = 4739,
	},
	["0057_00247"] = {
		{"fg", file="mizuhiki_01m_00002", file1="mizuhiki_01m_00102", file2="mizuhiki_01m_00229", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0322", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“I’m fine. Don’t worry about me, Katagiri. Really.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“不用了，不劳烦片桐同学了……没事的，真的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「不用了，不勞煩片桐同學了……沒事的，真的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00246",
