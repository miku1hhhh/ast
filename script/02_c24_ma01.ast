		{"text"},
		text = {
			vo = {
				{"vo", file="asane0191", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I-it’s harder than it looks, okay?! She’s so demure and elegant like a woman, but she’s not a girl, but she’s so my type and is fucking with my sexual identity! Argh...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“总觉得有点难应付那个人……！虽然不起眼又很成熟，但她是男的，虽然不是女孩子但是性取向和我很接近所以对我来说很难受……呜呼呼……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「總覺得有點難應付那個人……！雖然不起眼又很成熟，但她是男的，雖然不是女孩子但是性取向和我很接近所以對我來說很難受……嗚呼呼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00199",
		linknext = "0057_00201",
		line = 4071,
	},
	["0057_00201"] = {
