	["0057_00357"] = {
		{"fg", file="mizuhiki_01ll_00002", file1="mizuhiki_01ll_00103", file2="mizuhiki_01ll_00210", file4="mizuhiki_01ll_00401", path=":fg/mizuhiki_01ll/", id=15, lv=15, head="mizuhiki_01ll", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=0, y=0},
