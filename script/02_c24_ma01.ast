	["0057_00009"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00205", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0214", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Sorry, I just get jealous of the other comrades... To be honest, I want to eat with you every day.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“对不起，就只是有点嫉妒其他同伴……我也想要每天跟你一起吃午餐啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「對不起，就只是有點嫉妒其他同伴……我也想要每天跟你一起吃午餐啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00008",
