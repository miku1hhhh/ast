	["0057_00027"] = {
		{"fg", file="mizuhiki_01m_00002", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00214", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0300", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“I let it go by. It’s hard to come up with 1,000 yen on the fly.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“嗯──我暂时还没买。金额超过1000的话就无法马上出手了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「嗯──我暫時還沒買。金額超過1000的話就無法馬上出手了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00026",
		linknext = "0057_00028",
		line = 452,
	},
	["0057_00028"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There’s value to what they’re selling. It’s hi-res audio, catchy, and all the sounds are homemade, so you don’t hear the same stock sounds all the time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“很值得买。因为是高解析度的,且这里是黑耳,掏耳朵的声音也是自制的,所以没有熟悉的声音也没关系。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「很值得買。因為是高解析度的,且這裡是黑耳,掏耳朵的聲音也是自制的,所以沒有熟悉的聲音也沒關係。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00027",
		linknext = "0057_00029",
		line = 464,
	},
	["0057_00029"] = {
		{"fg", file="mizuhiki_01m_00002", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00210", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"fg", file="mizuhiki_01m_00002", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00211", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"text"},
		delay = {
			[2999] = {
				{"transitiontime", time=300, timestamp=1, delay2=3000},
			},
		},
		text = {
			vo = {
				{"vo", file="mizuhiki0301", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“But I don’t have equipment to play hi-res audio. It’s just a fancy word for a fancy marketing phrase.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“但是没有播放高解析度音源的机器啊……这样不就是以文字的感觉为卖点吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「但是沒有播放高解析度音源的機器啊……這樣不就是以文字的感覺為賣點嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00028",
		linknext = "0057_00030",
		line = 482,
	},
	["0057_00030"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“True, but they know that when they write it out like that, the buyers will cum.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然是这样，不过看到写着就不自觉地买了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然是這樣，不過看到寫著就不自覺地買了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00029",
		linknext = "0057_00031",
		line = 494,
	},
	["0057_00031"] = {
		{"fg", file="schubert_01m_00002", file2="schubert_01m_00220", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="シューベルト12", id=12, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0218", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“I know just what you mean, Junnosuke. I always end up buying content with words like ‘succubus’, ‘housewife’, and ‘bossy coworker’ in the titles!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“淳之介我懂你，我也是看到〝淫魔〞、〝人妻〞和〝命令后辈，就会毫不犹豫地买了──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「淳之介我懂你，我也是看到〝淫魔〞、〝人妻〞和〝命令後輩，就會毫不猶豫地買了──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00030",
		linknext = "0057_00032",
		line = 510,
	},
	["0057_00032"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
