		text = {
			vo = {
				{"vo", file="nanase0157", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ugh! At the end of the day, no matter where I go, it’s just me and my lack of confidence!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“呃……！老实说，我有不管他去了哪里，最终都会回到我的身边，这样毫无根据的自信心……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「呃……！老實說，我有不管他去了哪裡，最終都會回到我的身邊，這樣毫無根據的自信心……！」",
					{"rt2"},
				},
			},
		},
