		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0303", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“It was freakin’ fantastic... You return from the hypnotic spell and feel a bit despondent for when you had a cock.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“非常的〝好〞啊……从催眠状态回来后，发现在己有小鸡鸡时，还感觉到轻微的绝望呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「非常的〝好〞啊……從催眠狀態回來後，發現在己有小雞雞時，還感覺到輕微的絕望呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00036",
		linknext = "0057_00038",
		line = 606,
	},
	["0057_00038"] = {
