			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“They seemed to hit it off fast when we got back. I believe they share some common interests...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“回来之后，很快地就融洽了起来。的确也是有共同的兴趣──”",
