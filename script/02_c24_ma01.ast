			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asa! Nanase! Fumino! I’ve got company coming over today. That cool?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
