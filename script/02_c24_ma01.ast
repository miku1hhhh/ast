				{"vo", file="fumino0141", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“If we are going to lose as people, we will win through food. They will only eat our food... Only ours...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“如果输给别人的话就用料理决一胜负……肯定会让他说出〝除了文乃她们以外所做的料理都难以下咽〞……肯定会……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「如果輸給別人的話就用料理決一勝負……肯定會讓他說出〝除了文乃她們以外所做的料理都難以下嚥〞……肯定會……」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00055",
		linknext = "0057_00057",
