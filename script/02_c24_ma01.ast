	["0057_00142"] = {
		{"fg", file="rin_01m_00002", file1="rin_01m_00101", file2="rin_01m_00226", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[3000] = {
				{"fg", file="rin_01m_00002", file1="rin_01m_00101", file2="rin_01m_00220", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, timestamp=56, delay2=3000, mode=3, x=-5, y=-5},
			},
			[2999] = {
				{"transitiontime", time=300, timestamp=56, delay2=3000},
			},
		},
		text = {
			vo = {
				{"vo", file="rin0224", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“You’re so serious, you make me sick. You may be a hero, the so-called island protector, but I won’t forgive you getting on my damn nerves.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“从刚刚开始就认真地吐槽着，真烦人呢，橘同学，在怎么被说是岛的守护英雄，我也不会原谅你对我的不敬行为的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「從剛剛開始就認真地吐槽著，真煩人呢，橘同學，在怎麼被說是島的守護英雄，我也不會原諒你對我的不敬行為的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00141",
		linknext = "0057_00143",
		line = 2874,
	},
	["0057_00143"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00218", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Phew... By the way, do you believe in religion?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哈啊……稍微问一下，你对宗教有何看法？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哈啊……稍微問一下，你對宗教有何看法？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00142",
		linknext = "0057_00144",
