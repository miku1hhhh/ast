				{"vo", file="tohka0901", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Did you just say your parents are sumo wrestlers?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“至少也要加入相扑联盟吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「至少也要加入相撲聯盟吧？」",
