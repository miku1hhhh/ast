	},
	["0057_00050"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", file2="hinami_02m_00206", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=695, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0138", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“But this is so out of character for Jun. I’ve never seen him have so much fun before...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不过淳君是这样的人设吗……？像那么开心的样子，我还是第一次见呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不過淳君是這樣的人設嗎……？像那麼開心的樣子，我還是第一次見呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00049",
		linknext = "0057_00051",
		line = 857,
	},
	["0057_00051"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", file2="nanase_01m_00210", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=345, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0151", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Jun’s never had many friends before. He’s never had someone to get excited with where he didn’t have to worry about rules.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“淳他啊……几乎没什么朋友，所以我还是第一次见到那种不把自己的处境当回事还嘻嘻哈哈的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「淳他啊……幾乎沒甚麼朋友，所以我還是第一次見到那種不把自己的處境當回事還嘻嘻哈哈的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00050",
		linknext = "0057_00052",
		line = 872,
	},
