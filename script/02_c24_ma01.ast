		text = {
			vo = {
				{"vo", file="rin0225", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“The fuck are you saying? Does it look like I’m religious? Anyone who takes refuge in that hogwash is full of shit! Jesus fuckin’ Christ!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“啥？你到底是在说什么，是觉得我会相信那类的东西吗？那么皈依的家伙就是垃圾啦，垃圾！咳～呸！！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「啥？你到底是在說什麼，是覺得我會相信那類的東西嗎？那麼皈依的傢伙就是垃圾啦，垃圾！咳～呸！！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00143",
		linknext = "0057_00145",
		line = 2913,
	},
	["0057_00145"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
