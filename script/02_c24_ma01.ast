		text = {
			vo = {
				{"vo", file="ikuko1199", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“You like manga, right Misaki? I tried it out, but I can’t get turned on unless it’s real people. Sorry.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“美岬说的是漫画之类的吧？我已经试过了，我对于不是真人就没感觉的样子。真抱歉？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「美岬說的是漫畫之類的吧？我已經試過了，我對於不是真人就沒感覺的樣子。真抱歉？」",
					{"rt2"},
				},
			},
		},
