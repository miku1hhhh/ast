		{"fgact", ch="郁子23", id=23, act="振動下", loop=1, size=22.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1196", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Hey, Nanase! You were always the calm and collected one. You need to imagine yourself as the only one on top!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“啊──！因为奈奈濑同学总是从容不迫的样子！就是高人一等的样子！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「啊──！因為奈奈瀨同學總是從容不迫的樣子！就是高人一等的樣子！」",
					{"rt2"},
				},
			},
		},
