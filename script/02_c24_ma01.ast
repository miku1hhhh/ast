		{"fg", file="rin_01m_00002", file1="rin_01m_00101", file2="rin_01m_00227", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", alpha=0, ch_origin="凛", ch="凛14", mw="mw", sync=1, a_chr151=1, mode=3, x=295, y=-5},
		{"fgact", ch="凛14", id=14, lv=14, act="表示アクション", a1=0, a2=255, time=300, a_chr=151, alpha=255},
		{"fgact", ch="凛14", id=14, act="移動", x=-300, y=0, time=300},
		{"se", id=1, loop=0, file="se_a002"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0221", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Hmph, I missed. What a stubborn vermin, so agile despite your stupid face!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“啧，能放开吗。这种灵敏不适合令人厌恶的脸,这是多么顽强的害虫──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「嘖，能放開嗎。這種靈敏不適合令人厭惡的臉,這是多麽頑強的害蟲──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00134",
		linknext = "0057_00136",
		line = 2759,
	},
	["0057_00136"] = {
		{"se", id=1, stop=1, time=1000},
		{"se", id=0, loop=0, file="se_a098"},
		{"fgact", ch="凛14", id=14, act="移動", x=-400, y=0, time=500},
		{"fg", file="ran_01m_00001", file1="ran_01m_00102", file2="ran_01m_00209", file4="ran_01m_00401", path=":fg/ran_01m/", id=13, lv=13, head="ran_01m", alpha=0, ch_origin="蘭", ch="蘭13", mw="mw", sync=1, a_chr151=1, mode=3, x=195, y=-5},
		{"fgact", ch="蘭13", id=13, lv=13, act="表示アクション", a1=0, a2=255, time=400, a_chr=151, alpha=255},
		{"fgact", ch="蘭13", id=13, act="移動", x=200, y=0, time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0093", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Now Rin, how many times must I remind you that us FS can’t carry weapons anymore?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“喂，凛，已经跟你说过多少次了，我们FS已经不允许配戴武器了……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「喂，凜，已經跟你說過多少次了，我們FS已經不允許配戴武器了……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00135",
		linknext = "0057_00137",
		line = 2777,
	},
	["0057_00137"] = {
