	["0057_00024"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00228", path=":fg/tohka_02m/", id=21, lv=21, head="tohka_02m", ch_origin="桐香", ch="桐香21", mw="mw", sync=0, mode=3, x=-5, y=-5},
