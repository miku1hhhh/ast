					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Aw, you’re adorable. I wish the script writers gave me a cute catchphrase or something.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊~那个‘嘶’的孩子吗？那孩子很可爱呢。我也来模仿一下她的人设吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊~那個『嘶』的孩子嗎？那孩子很可愛呢。我也來模仿一下她的人設吧？」",
					{"rt2"},
				},
			},
		},
