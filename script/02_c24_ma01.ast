				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“We have to be doing it at the same time in the other world for that to happen, right? Probably a rare occurrence...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“那也要那边的世界也在进行才会吧？这种事应该不太会发生。而且──”",
