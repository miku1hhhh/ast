	["0057_00268"] = {
		{"fg", file="mizuhiki_01m_00002", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00211", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0326", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“You wrote your age in your profile and deleted it as soon as it became a problem.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“因为橘君你，在最一开始的介绍里就写了年纪了吗？虽然马上就发生问题删掉了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「因為橘君你，在最一開始的介紹裡就寫了年紀了嗎？雖然馬上就發生問題刪掉了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00267",
		linknext = "0057_00269",
		line = 5044,
	},
	["0057_00269"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=20},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh yeah, that was a big mistake. It would’ve gone viral if I did the same thing now. It was the early days of Fapista, so I got off unscathed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊，那真的是倒楣……要是现在的话，肯定会大炎上的吧。因为是Onetter初期所以被原谅了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊，那真的是倒楣……要是現在的話，肯定會大炎上的吧。因為是Onetter初期所以被原諒了呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00268",
		linknext = "0057_00270",
		line = 5056,
	},
	["0057_00270"] = {
		{"fg", file="mizuhiki_01m_00002", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00210", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0327", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“I was impressed someone the same age as me bought a 3D printer and put all their fiery passion into such deep enthusiasm for masturbation...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“自己购买3D列印机和制作的热情，以及对自慰的浓厚热意……明明跟我同年，真的很厉害啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「自己購買3D列印機和製作的熱情，以及對自慰的濃厚熱意……明明跟我同年，真的很厲害啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00269",
		linknext = "0057_00271",
		line = 5071,
	},
	["0057_00271"] = {
		{"fg", file="mizuhiki_01m_00002", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00211", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0328", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“I longed to get closer, even if by a little. This all feels so overdo.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“所以我也想慢慢的接近一下，开始了活动……但是，也已经晚了许多了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「所以我也想慢慢的接近一下，開始了活動……但是，也已經晚了許多了呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00270",
		linknext = "0057_00272",
		line = 5086,
	},
	["0057_00272"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=20},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don’t be harsh on yourself. Thanks to you, I’ve come so far.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不要自卑……多亏有了你，我才能走到这一步。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不要自卑……多虧有了妳，我才能走到這一步。」",
					{"rt2"},
				},
			},
		},
