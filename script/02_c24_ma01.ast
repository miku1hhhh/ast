				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Thanks. Fumino makes the best tea. Drink up. You won’t be able to go back to normal tea again.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊啊，谢谢啦。文乃泡的茶是最棒的，喝喝看吧。会变得不想喝一般的茶喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊啊，謝謝啦。文乃泡的茶是最棒的，喝喝看吧。會變得不想喝一般的茶喔。」",
					{"rt2"},
