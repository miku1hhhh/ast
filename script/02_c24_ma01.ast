			[4999] = {
				{"transitiontime", time=300, timestamp=54, delay2=5000},
			},
		},
		text = {
			vo = {
				{"vo", file="rin0222", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“It’s just for hunting, so leave me alone. I’ve got a hunting license too, geez.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“这是猎枪所以没问题的。我可是有猎枪执照的，你看。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「這是獵槍所以沒問題的。我可是有獵槍執照的，你看。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00136",
		linknext = "0057_00138",
		line = 2797,
	},
	["0057_00138"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It’s crazies like you that make people look down on hunters.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就是因为有这种家伙，才会让猎人蒙羞的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就是因為有這種傢伙，才會讓獵人蒙羞的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00137",
		linknext = "0057_00139",
		line = 2809,
	},
	["0057_00139"] = {
