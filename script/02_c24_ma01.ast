				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Morning, Jun. Sorry I’m early. My errands ended sooner than expected.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“早安，橘君。真抱歉，来早了。因为要办的事情比想像中的还早结束。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「早安，橘君。真抱歉，來早了。因為要辦的事情比想像中的還早結束。」",
					{"rt2"},
				},
			},
		},
