		},
		text = {
			vo = {
				{"vo", file="schubert0221", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Of course, I also bought it. I focused more on Nipple Shack yesterday, so haven’t listened yet. How did you like it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“当然我也已经买玩了，但是昨天太专心于乳头开发，所以还没有听……所以如何？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「當然我也已經買玩了，但是昨天太專心於乳頭開發，所以還沒有聽……所以如何？」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00035",
