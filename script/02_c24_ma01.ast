	["0057_00012"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00203", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Listen to this, Mizuhiki! Shu forgot our promise to eat lunch together.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你听我说啊，水引酱！舒君这家伙，居然忘了我们之间的约定啦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你聽我說啊，水引醬！舒君這傢伙，居然忘了我們之間的約定啦！」",
					{"rt2"},
				},
			},
		},
