	},
	["0057_00013"] = {
		{"fg", file="schubert_01m_00002", file2="schubert_01m_00205", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="シューベルト12", id=12, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0215", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Well, Junnosuke leapt into the classroom to inform me he misses me soooo much. I remembered the promise soon enough.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“不是，淳之介他啊，因为爱我爱得受不了了，所以才从教室飞奔过来。我终于想起来了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「不是，淳之介他啊，因為愛我愛得受不了了，所以才從教室飛奔過來。我終於想起來了呢。」",
					{"rt2"},
				},
			},
		},
