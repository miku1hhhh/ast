			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“You compliment me too much, Tachibana.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“怎么会……说得太过头了喔，橘君你啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「怎麼會……說得太過頭了喔，橘君你啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00272",
		linknext = "0057_00274",
		line = 5113,
	},
	["0057_00274"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00211", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=20},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You’re wrong. Sex sleeve creation is an art, and art isn’t all fun and games. I’d go so far to say that 80% of it is pain and suffering.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哪会──制作飞机杯可是艺术呢。艺术也不仅仅只有开心的事情。相反地，还不如说有8成都是痛苦的呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哪會──製作飛機杯可是藝術呢。藝術也不僅僅只有開心的事情。相反地，還不如說有8成都是痛苦的呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0057_00273",
		linknext = "0057_00275",
		line = 5125,
	},
	["0057_00275"] = {
