	["0105_00120"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00101", file2="asane_02m_00203", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1454", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“It looks legit though. There’re multiple accounts of the FS and SHO advocating for the Pervy Restoration. Hamedori even Queefed about it on the SHO’s official account.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不过这些⋯⋯看起来是真的耶。很多人目击到FS和SHO在提倡复活变态条例，SHO的官方帐号上的Hamedori君也在说条例复活的事⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不過這些⋯⋯看起來是真的耶。很多人目擊到FS和SHO在提倡復活變態條例，SHO的官方帳號上的Hamedori君也在說條例復活的事⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00119",
		linknext = "0105_00121",
		line = 1862,
	},
	["0105_00121"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00209", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=6},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You’re kidding, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是骗人的吧⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是騙人的吧⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00120",
		linknext = "0105_00122",
		line = 1874,
	},
	["0105_00122"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"On the day of the sexual mayhem, didn’t we understand each other?",
					{"rt2"},
				},
			},
			cn = {
				{
					"那天──因为做爱骚动，我们大家终于彼此理解了不是吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"那天──因為做愛騷動，我們大家終於彼此理解了不是嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00121",
		linknext = "0105_00123",
		line = 1884,
	},
	["0105_00123"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Isn’t this what everyone—the FS, the SHO, the islanders—what we all wanted?",
					{"rt2"},
				},
			},
			cn = {
				{
					"这不是FS、SHO和岛上的人们──大家携手迎接的结局吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"這不是FS、SHO和島上的人們──大家攜手迎接的結局嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00122",
		linknext = "0105_00124",
		line = 1894,
	},
	["0105_00124"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Didn’t Ikuko say she has plenty of fun even without the perverted sex law?",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算没了变态条例也能过得很开心，郁子不是也这么说了吗。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算沒了變態條例也能過得很開心，郁子不是也這麼說了嗎。",
					{"rt2"},
				},
			},
		},
