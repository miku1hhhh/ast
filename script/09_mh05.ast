				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“To confirm, Darling, did you tell Hitoura something along the lines of, ‘We need perversion’ or not?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我确认一下喔，亲爱的，你们和仁浦大叔说了类似‘变态是必要的。’的话吗？还是没说呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我確認一下喔，親愛的，你們和仁浦大叔說了類似『變態是必要的。』的話嗎？還是沒說呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00445",
		linknext = "0105_00447",
		line = 7775,
	},
	["0105_00447"] = {
