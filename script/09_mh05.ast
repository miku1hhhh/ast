			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Wasn’t this whole mess because of your misunderstanding, Kokie? How do you plan on making it right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“说起来结论就是光姬酱自己误解了嘛。你打算怎么弥补这一切？”",
