				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“In that case, let’s throw the event as planned. If they’re really planning what you say, they’ll most likely try something.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“这么一来⋯⋯还是如期举行吧。如果前辈们真的在筹划复活的事的话，那一定会在活动举办的时候表示什么的吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「這麼一來⋯⋯還是如期舉行吧。如果前輩們真的在籌劃復活的事的話，那一定會在活動舉辦的時候表示什麼的吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00012",
		linknext = "0105_00014",
		line = 225,
	},
	["0105_00014"] = {
