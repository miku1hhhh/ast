				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Even so, before we all dote on Kokie, we better check the facts first just in case.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“不过，在疼爱光姬酱之前，我想先确认一下事实关系。”",
