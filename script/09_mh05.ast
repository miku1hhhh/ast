		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, not just her. You and I are one and the same. I think of others first! And I think of you too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“──当然不是只有这样。和你一样！我也有为大家着想啊！当然连郁子的事也是！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「──當然不是只有這樣。和妳一樣！我也有為大家著想啊！當然連郁子的事也是！」",
					{"rt2"},
				},
			},
		},
