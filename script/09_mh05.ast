			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“A true friend will tell someone when they mess up and correct them. THAT’S what a friend does!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“同伴做错了事就要出声指正──这才是真正的同伴啊！？”",
