	},
	["0105_00384"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I joined hands with former foes. In the end, we brought the whole island together. And the fruit of that labor is the time we’re living in now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就连原本是敌人的郁子也和我联手，最后全岛同心协力──终于得胜，也才有今日的啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就連原本是敵人的郁子也和我聯手，最後全島同心協力──終於得勝，也才有今日的啊。",
					{"rt2"},
				},
			},
		},
