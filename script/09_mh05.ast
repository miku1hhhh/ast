				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We stop them, of course! We cannot allow that law to be reinstated! Let’s go!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就这么办！我绝对不允许条例的复活！我们要赶快去阻止！”",
