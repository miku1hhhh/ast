	["0105_00390"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if her FS friends are important to her—even if they’re like family—Ikuko should be able to do that much.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算再怎么重视FS的同伴们──就算把她们当家人看待，我想郁子也应该要能做到我说的那样才对。",
					{"rt2"},
				},
			},
			tw = {
				{
