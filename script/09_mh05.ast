			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“It’s like if you made ‘Lord of the Cockrings’ but you didn’t even have dwarf-on-elf-on-wizard action or a climactic orgy in the fires of Mt. Poon! It would be a total flop!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“在[|淫笼中变身，被]变态和干干先生硬上这种安排就好，要是突然多余安排攻守转换的话，会爆死喔⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「在[|淫籠中變身，被]變態和幹幹先生硬上這種安排就好，要是突然多餘安排攻守轉換的話，會爆死喔⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00082",
		linknext = "0105_00084",
