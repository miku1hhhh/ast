		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2183", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“There are so many things I could go on about like dangerous driving, attempted murder, obstruction of business, etc., but for now, you two need to reflect on what transpired.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“危险驾驶和杀人未遂还有妨碍业务执行等，数都数不完，总之你们就先在这好好反省一下吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「危險駕駛和殺人未遂還有妨礙業務執行等，數都數不完，總之你們就先在這好好反省一下吧。」",
					{"rt2"},
				},
			},
		},
