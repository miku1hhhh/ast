		text = {
			vo = {
				{"vo", file="asane1450", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Calm down. Eroge players, fantasy geeks, and anime freaks alike will love it, even if it’s the same story. They’re actually more likely to get triggered if you change it up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“色情游戏玩家和时代剧宅还有特摄狂粉，也都是不管类似的剧情来几次照样开心啊⋯⋯反而突然不是这样的时候才会遭他们骂呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「色情遊戲玩家和時代劇宅還有特攝狂粉，也都是不管類似的劇情來幾次照樣開心啊⋯⋯反而突然不是這樣的時候才會遭他們罵呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00081",
		linknext = "0105_00083",
		line = 1358,
	},
	["0105_00083"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", file2="asane_01m_00205", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
