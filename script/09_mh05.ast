			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I thought we might find ourselves in this kind of situation, so I got my license between scenes. Now we can commit traffic crimes with reckless abandon!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我就想到会这样，所以就在空档时间考取驾照了！接下来随便我们违规了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我就想到會這樣，所以就在空檔時間考取駕照了！接下來隨便我們違規了！」",
					{"rt2"},
				},
			},
		},
