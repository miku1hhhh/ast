				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You’re right! The FS of today consists of the cream of the crop. We’ll have no trouble dealing with whatever they try to pull! Way to go, Miss Touka, using the event to our advantage!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“的确⋯⋯！当天FS的菁英都聚集在一起了⋯⋯很容易有对策！在活动上反将他们一军，真不愧是桐香大小姐啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「的確⋯⋯！當天FS的菁英都聚集在一起了⋯⋯很容易有對策！在活動上反將他們一軍，真不愧是桐香大小姐啊！」",
					{"rt2"},
				},
			},
		},
