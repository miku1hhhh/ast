					name = {"美岬", "Misaki"},
					"“Huh?! So this whole Pervy Restoration and everything was just a performance?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“什么！？那么变态条例复活啊什么的，都只是在作秀吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「什麼！？那麼變態條例復活啊什麼的，都只是在作秀嗎！？」",
					{"rt2"},
				},
