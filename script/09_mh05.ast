		text = {
			vo = {
				{"vo", file="kouki0194", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Huh? The audience loved the show, so I don’t see anything I need to fix.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“什么？但是观众们都以为是活动的节目，也很投入其中啊，就算了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「什麼？但是觀眾們都以為是活動的節目，也很投入其中啊，就算了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00434",
		linknext = "0105_00436",
		line = 7591,
	},
	["0105_00436"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00216", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2178", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Nothing to fix? I can’t even remember how many major fires your lack of awareness caused.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“什么算了！你这样随便的态度，好几次让事情炎上，你不记得了嘛？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「什麼算了！妳這樣隨便的態度，好幾次讓事情炎上，妳不記得了嘛？」",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00435",
		linknext = "0105_00437",
		line = 7606,
	},
	["0105_00437"] = {
