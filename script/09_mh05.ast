		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When I returned to the island and fought the lewd law, I gathered allies one by one.",
					{"rt2"},
				},
			},
			cn = {
				{
					"回到岛上，因为条例而战时，是我一个一个将同伴聚集起来的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"回到島上，因為條例而戰時，是我一個一個將同伴聚集起來的。",
