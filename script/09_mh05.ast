	["0105_00217"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In the post-sexual mayhem era, public perception of the perverted sex law is bad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"做爱骚动后的现在，大家普遍都认为变态条例是很有问题的条例了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"做愛騷動後的現在，大家普遍都認為變態條例是很有問題的條例了。",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00216",
		linknext = "0105_00218",
		line = 3514,
	},
	["0105_00218"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If the SHO resurrects the law, they’ll inevitably face harsh criticism. After that, it will be difficult for them to continue their operations on the island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算是SHO想让条例复活，也一定会引起世人反感──接下来关于岛的运营就会遭遇困难吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算是SHO想讓條例復活，也一定會引起世人反感──接下來關於島的運營就會遭遇困難吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00217",
		linknext = "0105_00219",
		line = 3524,
	},
	["0105_00219"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But if WE’RE the ones pushing to get the lewd law back...",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过，要是把条例复活说成是我们的打算的话──",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過，要是把條例復活說成是我們的打算的話──",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00218",
		linknext = "0105_00220",
		line = 3534,
	},
	["0105_00220"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"WE’LL be the ones who take the fall while they get to play the good guys and take back control in the name of the lewd law. That’s what this smells like!",
					{"rt2"},
				},
			},
			cn = {
				{
					"责任就变到我们头上了，之后她们再以收拾善后的名义，就能运营再次受到变态条例管理的岛了──是这打算。",
					{"rt2"},
				},
			},
			tw = {
				{
					"責任就變到我們頭上了，之後她們再以收拾善後的名義，就能運營再次受到變態條例管理的島了──是這打算。",
					{"rt2"},
				},
			},
		},
		linkback = "0105_00219",
