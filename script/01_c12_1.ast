			vo = {
				{"vo", file="tohka0395", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“It seems you sweat quite a lot. Did you dream of doing exercise? Oh, or maybe it was a naughty dream? I’d be so happy if I was your partner in it...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“你好像流了很多汗，是梦见在运动吗？啊，该不会是色色的梦？要是对象是我的话会很开心就是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「你好像流了很多汗，是夢見在運動嗎？啊，該不會是色色的夢？要是對象是我的話會很開心就是……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00019",
		linknext = "0017_00021",
		line = 286,
	},
	["0017_00021"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00209", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
