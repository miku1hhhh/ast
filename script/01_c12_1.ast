	["0017_00077"] = {
		{"fg", file="ikuko_02m_00003", file1="ikuko_02m_00101", file2="ikuko_02m_00211", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0490", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Which means that back in World A, today is the day when Darling gets shot up at the test for the Unbelievable Humans promotional video that you came up with?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“也就是说A世界的亲爱的，因为礼酱所想出的惊异人类秀PV的测试，被不断殴打的日子？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「也就是說A世界的親愛的，因為禮醬所想出的驚異人類秀PV的測試，被不斷毆打的日子？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00076",
		linknext = "0017_00078",
		line = 1397,
	},
	["0017_00078"] = {
