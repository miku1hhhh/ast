	["0017_00115"] = {
		{"fg", file="ikuko_02l_00003", file1="ikuko_02l_00101", file2="ikuko_02l_00207", path=":fg/ikuko_02l/", id=10, lv=10, head="ikuko_02l", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[4000] = {
				{"fg", file="ikuko_02l_00003", file1="ikuko_02l_00101", file2="ikuko_02l_00229", path=":fg/ikuko_02l/", id=10, lv=10, head="ikuko_02l", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, timestamp=69, delay2=4000, mode=3, x=-5, y=-5},
			},
			[3999] = {
				{"transitiontime", time=300, timestamp=69, delay2=4000},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko0500", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“But right now you need to fight it and cheer up! None of us will be able to go to our original world without you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“但是，这时候要忍耐打起精神喔？因为亲爱的不在的话，我们就没办法回到原本的世界了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「但是，這時候要忍耐打起精神喔？因為親愛的不在的話，我們就沒辦法回到原本的世界了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00114",
		linknext = "0017_00116",
		line = 2017,
	},
	["0017_00116"] = {
