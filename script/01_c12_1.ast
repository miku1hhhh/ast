	["0017_00111"] = {
		{"fg", file="rei_01m_00008", file1="rei_01m_00102", file2="rei_01m_00219", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0435", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Please, Miss Touka! Don’t force yourself...! Just getting close to children—especially babies—will generally cause them to cry from your charisma...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“桐香大人请不要勉强……！基本上你的领袖威严，只要接近小孩或婴儿就会让他们哭出来的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「桐香大人請不要勉強……！基本上妳的領袖威嚴，只要接近小孩或嬰兒就會讓他們哭出來的……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00110",
		linknext = "0017_00112",
		line = 1945,
	},
	["0017_00112"] = {
