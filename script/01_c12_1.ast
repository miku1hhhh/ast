		{"fg", file="ikuko_02m_00008", file1="ikuko_02m_00102", file2="ikuko_02m_00203", path=":fg/ikuko_02m/", id=10, lv=8, head="ikuko_02m", alpha=0, ch_origin="郁子", ch="郁子10", mw="mw", sync=1, a_chr151=1, mode=3, x=-805, y=-5},
