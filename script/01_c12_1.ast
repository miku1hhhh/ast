				},
			},
			cn = {
				{
					"FS的宿舍里有着齐全的医疗用品，绷带等必需品在我眼前一字排开。",
					{"rt2"},
				},
			},
			tw = {
				{
					"FS的宿舍裡有著齊全的醫療用品，繃帶等必需品在我眼前一字排開。",
