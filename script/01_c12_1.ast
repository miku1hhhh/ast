			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Doesn’t it kind of remind you of when he’s laughing when you see his face in pain, though?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“但是他痛的表情跟笑的表情有点像吧？”",
