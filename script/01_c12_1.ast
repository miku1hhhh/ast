		{"text"},
		text = {
			vo = {
				{"vo", file="rei0422", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hm... I don’t notice any external wounds, though... No signs of internal bleeding, either...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯……但是没有什么外伤……也没看到内出血的痕迹……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯……但是沒有什麼外傷……也沒看到內出血的痕跡……」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00070",
		linknext = "0017_00072",
		line = 1288,
	},
	["0017_00072"] = {
