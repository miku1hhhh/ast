			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes, so if what happens in the other world feeds back into this one—or rather, if our worlds affect one another...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“啊啊，所以如果受到了那个世界的影响──应该说，要是可以互相干涉的话，就有可能。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「啊啊，所以如果受到了那個世界的影響──應該說，要是可以互相干涉的話，就有可能。」",
					{"rt2"},
				},
			},
