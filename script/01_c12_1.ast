				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Now that I think about it, we’re all awful at praising others, aren’t we?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“这样仔细一想，我们都是些不擅长安慰的人耶？”",
