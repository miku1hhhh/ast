				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Though it does seem possible just for Junnosuke, since his existence is so different between worlds A and B because he’s been swapped out with the Birds of a Feather...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“只有和‘Tori公’交换的淳之介，有在A世界跟B世界重叠了的可能性，这样的盖然性很高──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「只有和『Tori公』交換的淳之介，有在A世界跟B世界重疊了的可能性，這樣的蓋然性很高──」",
					{"rt2"},
				},
			},
		},
