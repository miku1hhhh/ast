		text = {
			vo = {
				{"vo", file="ikuko0501", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“That’s right! We would’ve been just so depressed without you around, but we’re able to feel motivated thanks to you. So cheer up, okay?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“没错ー要是没有亲爱的的话，我们就会非常沮丧，我们是托淳之介君的福才能努力下去的。所以，打起精神来吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「沒錯ー要是沒有親愛的的話，我們就會非常沮喪，我們是託淳之介君的福才能努力下去的。所以，打起精神來吧？」",
					{"rt2"},
				},
			},
		},
