		{"cgact", file="cgact", id=1, act="浮遊", loop=8, size=5, time=35, ease="easeinout_sine", lv=1},
		{"fgact", ch="桐香8", id=8, act="浮遊", loop=8, size=10, time=35, ease="easeinout_sine"},
		{"fgact", ch="郁子10", id=10, act="浮遊", loop=8, size=10, time=35, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0481", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“What was that just now?! Did someone attack you?! An enemy raid? Who’s my prey here?! Don’t worry, you two! I’m stronger than anyone...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“等等刚才是什么声音──！？有人被袭击了吗！？敌袭、猎物呢！？没问题的两位，人家是最强的──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「等等剛才是什麼聲音──！？有人被襲擊了嗎！？敵襲、獵物呢！？沒問題的兩位，人家是最強的──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00043",
		linknext = "0017_00045",
		line = 748,
	},
	["0017_00045"] = {
		{"fg", file="ikuko_02m_00008", file1="ikuko_02m_00101", file2="ikuko_02m_00205", path=":fg/ikuko_02m/", id=10, lv=8, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-405, y=-5},
