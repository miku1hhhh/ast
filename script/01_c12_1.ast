	["0017_00022"] = {
		{"fg", file="tohka_02l_00003", file1="tohka_02l_00101", file2="tohka_02l_00202", path=":fg/tohka_02l/", id=8, lv=8, head="tohka_02l", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
