		text = {
			vo = {
				{"vo", file="ikuko0499", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Ugh, fine... Hey, Darling? Your body hurts, right? That must be awful. Don’t worry, I understand. I know that you’re trying so hard, Darling.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“真是的，没办法……欸亲爱的，身体很痛吗？很辛苦吧，这样啊，郁很了解喔。亲爱的很努力嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「真是的，沒辦法……欸親愛的，身體很痛嗎？很辛苦吧，這樣啊，郁很了解喔。親愛的很努力嘛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00112",
		linknext = "0017_00114",
		line = 1986,
	},
	["0017_00114"] = {
