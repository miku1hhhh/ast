				{"fg", file="ikuko_02m_00008", file1="ikuko_02m_00101", file2="ikuko_02m_00216", path=":fg/ikuko_02m/", id=10, lv=8, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, timestamp=28, delay2=4700, mode=3, x=-405, y=-5},
			},
			[4699] = {
