	["0017_00102"] = {
		{"fg", file="tohka_02m_00003", file1="tohka_02m_00101", file2="tohka_02m_00212", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0417", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“The NLNS is great at coddling people. They have Nanase at the lead, then Hinami, Fumino, and even Asane.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“NLNS那边以奈奈濑同学为首，雏见同学、文乃同学、还有麻沙音同学都很擅长宠人嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「NLNS那邊以奈奈瀨同學為首，雛見同學、文乃同學、還有麻沙音同學都很擅長寵人嘛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00101",
		linknext = "0017_00103",
		line = 1798,
	},
