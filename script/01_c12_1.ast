		text = {
			vo = {
				{"vo", file="tohka0396", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Of course even if I wasn’t your partner, if you were to tell me about what you dreamed about in detail, I do have enough training that I’d be able to feel like I was actually being cucked...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“当然就算不是跟我，要是能和我仔细说明梦的内容，也算一种训练，还能在现实中感觉到NTR的感受──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「當然就算不是跟我，要是能和我仔細說明夢的內容，也算一種訓練，還能在現實中感覺到NTR的感受──」",
					{"rt2"},
				},
			},
		},
