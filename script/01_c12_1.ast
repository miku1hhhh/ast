					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I can’t say for sure, but maybe it’s because we’re still in the exact same positions as before.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“也不能笃定没有。或是因为我们完全取代了本尊也说不定。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「也不能篤定沒有。或是因為我們完全取代了本尊也說不定。」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00079",
		linknext = "0017_00081",
		line = 1448,
	},
	["0017_00081"] = {
		{"fg", file="rei_01m_00008", file1="rei_01m_00101", file2="rei_01m_00211", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
