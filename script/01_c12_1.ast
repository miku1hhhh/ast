				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I didn’t do a thing to him, but he broke...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我什么都没做他就坏掉了……”",
