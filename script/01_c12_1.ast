					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I guess that would explain this... But why just Darling? That’s not happening to us, is it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“虽然好像说得通了……但为什么只有亲爱的？我们身上没有同样现象呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「雖然好像說得通了……但為什麼只有親愛的？我們身上沒有同樣現象呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00078",
		linknext = "0017_00080",
		line = 1433,
	},
	["0017_00080"] = {
		{"fg", file="tohka_02m_00003", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0414", path=":vo/", ch="touka"},
