	},
	["0017_00071"] = {
		{"fg", file="rei_02l_00008", file1="rei_02l_00101", file2="rei_02l_00201", path=":fg/rei_02l/", id=9, lv=9, head="rei_02l", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
