					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Okay, Tachibana! I’m neeext♪ Here, little baby, it’s your junior’s boobies...! Aww, does it hurt? Thewe thewe, that’sh a good boy...♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“好了学长，接下来换我～♪用后辈的胸部来叭噗叭噗吧～♪你觉得痛痛吗，好乖好～乖。乖孩子乖孩子～♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「好了學長，接下來換我～♪用後輩的胸部來叭噗叭噗吧～♪你覺得痛痛嗎，好乖好～乖。乖孩子乖孩子～♪」",
					{"rt2"},
				},
			},
		},
