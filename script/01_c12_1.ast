		},
		text = {
			vo = {
				{"vo", file="ikuko0482", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“...Wait, what’s wrong, Darling? Why are you flopping around on your sheets like a salmon out of water, what’d you do to him Tokie?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“……所以，为什么亲爱的在被子上，像是上了岸的鲑鱼一样不停翻滚，桐香酱你做了什么！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「……所以，為什麼親愛的在被子上，像是上了岸的鮭魚一樣不停翻滾，桐香醬妳做了什麼！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0017_00044",
		linknext = "0017_00046",
		line = 766,
	},
	["0017_00046"] = {
		{"fg", file="tohka_02m_00003", file1="tohka_02m_00101", file2="tohka_02m_00206", path=":fg/tohka_02m/", id=8, lv=9, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=395, y=-5},
