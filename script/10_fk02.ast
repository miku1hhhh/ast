		text = {
			vo = {
				{"vo", file="ikuko2213", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Something about those eyes just isn’t normal... I don’t think you can acquire them through training. I guess it’s more like Hinami’s chair...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“果然那对眼睛不太普通呢⋯⋯也不像是训练出来的，比较像是渡酱的椅子一样⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「果然那對眼睛不太普通呢⋯⋯也不像是訓練出來的，比較像是渡醬的椅子一樣⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00118",
		linknext = "0109_00120",
		line = 1671,
	},
	["0109_00120"] = {
		{"fg", file="ikuko_02l_00002", file1="ikuko_02l_00101", file2="ikuko_02l_00201", path=":fg/ikuko_02l/", id=10, lv=10, head="ikuko_02l", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
