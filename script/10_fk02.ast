			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Reizeiin... I’ve been wanting to say something about this, but I can’t say I’m pleased about you sneaking in unannounced. You could interrupt my cooking, and then there’s Asane... indubitably.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“冷泉院同学⋯⋯我一直很想说⋯⋯我一点都不感谢你这样擅自过来的行为喔⋯⋯这些料理是要给麻沙音酱的⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「冷泉院同學⋯⋯我一直很想說⋯⋯我一點都不感謝妳這樣擅自過來的行為喔⋯⋯這些料理是要給麻沙音醬的⋯⋯」",
					{"rt2"},
				},
			},
		},
