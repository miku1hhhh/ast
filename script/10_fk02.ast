		{"fg", file="fumino_02l_00001", file1="fumino_02l_00103", file2="fumino_02l_00226", path=":fg/fumino_02l/", id=21, lv=21, head="fumino_02l", ch_origin="文乃", ch="文乃21", mw="mw", sync=0, mode=3, x=-5, y=-5},
