			en = {
				{
					name = {"郁子", "Ikuko"},
					"“If we fought, maybe I could win...? Well, I think I would at least do some damage anyway...♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“打起来的话会赢吧⋯⋯？呵呵，郁郁可不会白白就输的喔⋯⋯♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「打起來的話會贏吧⋯⋯？呵呵，郁郁可不會白白就輸的喔⋯⋯♪」",
					{"rt2"},
				},
			},
		},
