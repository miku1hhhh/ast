			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Really though, that’s the reason you ended up flying to a parallel world, so cut it out already, Tokie. What if you interrupted him in the middle of getting down and dirty with Fumino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“你就是这样才会被放飞到平行世界去的，适可而止吧，桐香酱。要是一个不小心撞见正在和文乃做的话，你要怎么办啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「妳就是這樣才會被放飛到平行世界去的，適可而止吧，桐香醬。要是一個不小心撞見正在和文乃做的話，妳要怎麼辦啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00060",
		linknext = "0109_00062",
		line = 818,
	},
	["0109_00062"] = {
