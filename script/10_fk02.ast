	["0109_00486"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In that case, no matter how grateful and eager to repay me she is, there’s no issue with making fun of me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如此假设的话，什么“忠心仆仆”的心都不需要了，讪笑的行为也就不会有什么不对劲。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如此假設的話，什麼“忠心僕僕”的心都不需要了，訕笑的行為也就不會有什麼不對勁。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00485",
		linknext = "0109_00487",
		line = 7138,
	},
	["0109_00487"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There are times when men have to give in to defeat. Times when we have to yield.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“男人总有要认输的时候，总有要屈服的时候。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「男人總有要認輸的時候，總有要屈服的時候。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00486",
