		text = {
			vo = {
				{"vo", file="asane1504", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“A conversation straight out of a porn game... I guess people who are so blessed just pray... I’m sure those boobs will sag over time though. All worldly things are impermanent, as Buddhism teaches.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“就像色情游戏内的对话⋯⋯人类要是幸福的能量超过一定的量时，就只会膜拜了吧⋯⋯胸部总有一天会往下垂⋯⋯所谓诸行无常就是指这样呢，哥⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「就像色情遊戲內的對話⋯⋯人類要是幸福的能量超過一定的量時，就只會膜拜了吧⋯⋯胸部總有一天會往下垂⋯⋯所謂諸行無常就是指這樣呢，哥⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00329",
		linknext = "0109_00331",
		line = 4972,
	},
	["0109_00331"] = {
