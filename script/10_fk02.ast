			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Woohoo! I played with some little kids and we took a bath together... If only Hinami were here too it would’ve been a perfect day!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“呼～～！今天和小小孩有玩到，又一起洗了澡，要是还有雏见也在的话，真的就太满足了⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「呼～～！今天和小小孩有玩到，又一起洗了澡，要是還有雛見也在的話，真的就太滿足了⋯⋯！」",
					{"rt2"},
				},
			},
		},
