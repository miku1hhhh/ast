	["0109_00233"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just the other day Fumino and I were looking up at this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"和文乃一起看到看板是在几天前。",
					{"rt2"},
				},
			},
			tw = {
				{
					"和文乃一起看到看板是在幾天前。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00232",
		linknext = "0109_00234",
		line = 3587,
	},
	["0109_00234"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ever since then, Fumino hides in my shadow whenever we get close to this area, hiding her face and blushing furiously.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在那之后，文乃只要来到这附近就会躲在我的影子处，满脸通红的低着头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在那之後，文乃只要來到這附近就會躲在我的影子處，滿臉通紅的低著頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00233",
		linknext = "0109_00235",
		line = 3597,
