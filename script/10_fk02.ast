	},
	["0109_00164"] = {
		{"fg", file="ikuko_02m_00002", file1="ikuko_02m_00101", file2="ikuko_02m_00224", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2217", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“And over there... is that charcoal? Are you going to use it to grill fish?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“然后⋯⋯那边那个是炭吗？该不会是为了烤鱼而有的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「然後⋯⋯那邊那個是炭嗎？該不會是為了烤魚而有的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00163",
		linknext = "0109_00165",
		line = 2374,
	},
	["0109_00165"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file3="fumino_01m_00302", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="文乃7", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0374", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“The gentle cooking from the far-infrared heat makes fish come out extra delicious!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“活用远红外线的话，就能将鱼烤的更美味喔⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「活用遠紅外線的話，就能將魚烤的更美味喔⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00164",
		linknext = "0109_00166",
		line = 2390,
	},
	["0109_00166"] = {
		{"fg", file="ikuko_02m_00002", file1="ikuko_02m_00101", file2="ikuko_02m_00209", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2218", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“But it must take a while first thing in the morning. Fish grills are convenient and so easy anyone but Tokie can use one.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“但是一早就要弄的话，很花时间吧。用烤鱼箱的话会很方便喔，除了桐香以外谁都很容易用的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「但是一早就要弄的話，很花時間吧。用烤魚箱的話會很方便喔，除了桐香以外誰都很容易用的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00165",
		linknext = "0109_00167",
		line = 2405,
	},
	["0109_00167"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00101", file2="fumino_02m_00226", path=":fg/fumino_02m/", id=7, lv=7, head="fumino_02m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0375", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I’ve always been an early riser, so it’s no problem for me... It’s also convenient for searing...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我本来就早起，这不算什么⋯⋯而且要做半生不熟的时候也很方便⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我本來就早起，這不算什麼⋯⋯而且要做半生不熟的時候也很方便⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00166",
		linknext = "0109_00168",
		line = 2420,
	},
	["0109_00168"] = {
		{"fg", file="rei_02m_00002", file1="rei_02m_00102", file2="rei_02m_00224", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2345", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“But lack of sleep can cause breakouts and dry skin, plus it’s bad for your health, you know...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“要是睡眠时间因此变短，影响皮肤变糟排便不顺的话，对身体不好吧⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「要是睡眠時間因此變短，影響皮膚變糟排便不順的話，對身體不好吧⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00167",
		linknext = "0109_00169",
		line = 2435,
	},
	["0109_00169"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file2="fumino_01m_00207", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
