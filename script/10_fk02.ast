	},
	["0109_00194"] = {
		{"cgact", file="cgact", act="表示アクション", alpha=0, id=2, lv=2, time=500, alphadel=1, style="reset"},
		{"text"},
		text = {
			vo = {
				{"vo", file="chitsuno0069", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"茅津野アナ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"茅津野アナ", "Pussy Galore"},
					"“Anyway, I’m counting on your support for giving close coverage of your activities over the next month, Governor Hitoura... Oh, terribly sorry.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"茅津野アナ", "茅津野播报员"},
					"“从今天开始为期一个月，我们将进行贴身取材，请多多指教了，仁浦县知事⋯⋯啊，抱歉。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"茅津野アナ", "茅津野播報員"},
					"「從今天開始為期一個月，我們將進行貼身取材，請多多指教了，仁浦縣知事⋯⋯啊，抱歉。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00193",
		linknext = "0109_00195",
		line = 2872,
	},
	["0109_00195"] = {
		{"bgm", file="bgm09", vol=100},
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00207", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", alpha=0, ch_origin="仁浦", ch="仁浦16", mw="mw", sync=1, a_chr151=1, mode=3, x=-205, y=-5},
		{"fgact", ch="仁浦16", id=16, lv=16, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="仁浦16", id=16, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0140", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I don’t mind. However, I’m no longer the governor. Just an insignificant entrepreneur.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“没关系。我现在已经不是知事，只是个不足为道的创业家。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「沒關係。我現在已經不是知事，只是個不足為道的創業家。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00194",
		linknext = "0109_00196",
		line = 2888,
	},
	["0109_00196"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="chitsuno0070", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"茅津野アナ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"茅津野アナ", "Pussy Galore"},
					"“Not insignificant at all! After stepping down, you launched ‘Red Nethers’ virility drinks, a brand that’s shaken up the industry and been named one of the 19 most influential companies!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"茅津野アナ", "茅津野播报员"},
					"“不足为道，才不是这样呢⋯⋯！急流勇退后将全神精力灌注在增强精力的能量饮料公司‘红色耻部’，目前席卷整个业界，还入选19家广受注目的企业名单！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"茅津野アナ", "茅津野播報員"},
					"「不足為道，才不是這樣呢⋯⋯！急流勇退後將全神精力灌注在增強精力的能量飲料公司『紅色恥部』，目前席捲整個業界，還入選19家廣受注目的企業名單！」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00195",
		linknext = "0109_00197",
		line = 2900,
	},
	["0109_00197"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00211", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[1000] = {
				{"fgact", ch="仁浦16", id=16, act="振動下", loop=1, size=5, time=150, ease="easeinout_sine", timestamp=26, delay2=1000},
				{"se", id=0, loop=0, file="se_a093", timestamp=26, delay2=1000},
				{"se", id=1, loop=0, file="se_a174", timestamp=26, delay2=1000},
			},
		},
		text = {
			vo = {
				{"vo", file="hitoura0141", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“In this industry... Well, not just this one, but I’m still basically a greenhorn, so I’m not sure I deserve to be featured on TV like this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“在这个业界⋯⋯我在这业界还是经验尚浅的新生代。不认为自己有资格上节目接受访谈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「在這個業界⋯⋯我在這業界還是經驗尚淺的新生代。不認為自己有資格上節目接受訪談。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00196",
		linknext = "0109_00198",
		line = 2918,
	},
	["0109_00198"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="chitsuno0071", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"茅津野アナ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"茅津野アナ", "Pussy Galore"},
					"“Governor Hitoura... what are you doing there?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"茅津野アナ", "茅津野播报员"},
					"“哎呀，仁浦县知事⋯⋯您现在在做什么呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"茅津野アナ", "茅津野播報員"},
					"「哎呀，仁浦縣知事⋯⋯您現在在做什麼呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00197",
		linknext = "0109_00199",
		line = 2930,
	},
	["0109_00199"] = {
		{"se", id=0, loop=0, file="se_a175"},
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00212", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="仁浦16", id=16, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0142", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Well... I guess it’s a habit of mine. Being the governor, part of the job is being seen by people, so you have to keep yourself groomed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“唔⋯⋯这是我的个人习惯。毕竟知事是公众人物，所以我会像这样注意自己的外观。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「唔⋯⋯這是我的個人習慣。畢竟知事是公眾人物，所以我會像這樣注意自己的外觀。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00198",
		linknext = "0109_00200",
		line = 2947,
	},
	["0109_00200"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00201", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0143", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Although it’s not terribly important right now, I guess I’ve just gotten used to taking care of my skin like this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“也不是什么特别的大事⋯⋯像这样保养肌肤已经变成了习惯了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「也不是什麼特別的大事⋯⋯像這樣保養肌膚已經變成了習慣了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00199",
		linknext = "0109_00201",
		line = 2962,
	},
	["0109_00201"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="chitsuno0072", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"茅津野アナ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"茅津野アナ", "Pussy Galore"},
					"“I see. So this is the secret of your success!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"茅津野アナ", "茅津野播报员"},
					"“原来如此，这就是仁浦氏您成功的秘诀是吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"茅津野アナ", "茅津野播報員"},
					"「原來如此，這就是仁浦氏您成功的秘訣是吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00200",
		linknext = "0109_00202",
		line = 2974,
	},
	["0109_00202"] = {
