	["0109_00265"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Since I’m worried about leaving her alone while I’m out (although Asa is here), I had the FS Big Three come over today.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可是放她一个人在家我也是很担心（虽然说麻沙酱是在啦），所以今天请来了FS三巨头到家里一趟。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可是放她一個人在家我也是很擔心（雖然說麻沙醬是在啦），所以今天請來了FS三巨頭到家裡一趟。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00264",
		linknext = "0109_00266",
		line = 4012,
	},
	["0109_00266"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, I was never expecting them to have so much fun playing the “Super Smash Sisters Gangbang” game Rei brought over.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过礼前辈拿来的‘女角大乱交’会让大家这么兴致高昂，我倒是有点意外。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過禮前輩拿來的『女角大亂交』會讓大家這麼興致高昂，我倒是有點意外。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00265",
		linknext = "0109_00267",
		line = 4022,
	},
	["0109_00267"] = {
