					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“That certainly was a quick turnaround.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“态度变得可真快。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「態度變得可真快。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00180",
		linknext = "0109_00182",
		line = 2626,
	},
	["0109_00182"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=20},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I want things to be easier for you, Fumino. Plus, I can help out this way. We can cook together.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我想要文乃更加轻松，而且我就能帮忙了，可以一起做饭。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我想要文乃更加輕鬆，而且我就能幫忙了，可以一起做飯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00181",
		linknext = "0109_00183",
		line = 2638,
	},
	["0109_00183"] = {
