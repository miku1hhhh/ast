				},
			},
			tw = {
				{
					name = {"水姫"},
					"「是，這邊是紅色恥部公司社長的辦公室⋯⋯是，要和仁浦社長？聯名產品？希望馬上就能展開？」",
					{"rt2"},
				},
			},
		},
