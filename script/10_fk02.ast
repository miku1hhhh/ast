	["0109_00472"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Things like, ‘Why are you hard just from getting stepped on? They say stepping on wheat makes it grow bigger, but this much gets it bent over backwards, touching the ground so it’s unharvestable’!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“骂我‘为什么只是踩下去就勃起来了呢？有一说小麦经过踩踏就会长大，但是像这样贴着地面的话，要怎么采收麦谷呢’！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「罵我『為什麼只是踩下去就勃起來了呢？有一說小麥經過踩踏就會長大，但是像這樣貼著地面的話，要怎麼採收麥穀呢』！」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00471",
		linknext = "0109_00473",
		line = 6981,
	},
