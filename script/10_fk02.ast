		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fumino, of course I know that you’re particular about the way you do things because you want us to enjoy your food. Thanks for that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“文乃，我懂你对料理这么讲究是想让我们吃下所有的美味，谢谢你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「文乃，我懂妳對料理這麼講究是想讓我們吃下所有的美味，謝謝妳。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00177",
		linknext = "0109_00179",
		line = 2585,
	},
	["0109_00179"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=20},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But if you sacrifice your own health for that, it makes me sad too. If you can sleep a bit longer, it’s better to use a rice cooker.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，要是因为这样影响你的健康的话，我会很伤心的。为了你的睡眠时间，用煮饭锅比较好吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，要是因為這樣影響妳的健康的話，我會很傷心的。為了妳的睡眠時間，用煮飯鍋比較好吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00178",
		linknext = "0109_00180",
		line = 2597,
	},
	["0109_00180"] = {
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00103", file2="fumino_01l_00229", path=":fg/fumino_01l/", id=21, lv=21, head="fumino_01l", ch_origin="文乃", ch="文乃21", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="文乃21", id=21, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0378", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Understood. In that case, I’ll start using it tonight.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我明白了，今晚开始我会用煮饭锅的⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我明白了，今晚開始我會用煮飯鍋的⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00179",
		linknext = "0109_00181",
		line = 2612,
	},
	["0109_00181"] = {
		{"fg", file="tohka_02m_00002", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1889", path=":vo/", ch="touka"},
			},
			ja = {
