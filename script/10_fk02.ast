	["0109_00093"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“This is a piggy bank for whenever Fumino takes care of housework or I’m moved by her sacred presence, I put in 500 yen as an offering to the gods.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这是文乃好尊专用存钱筒⋯⋯当觉得文乃好尊的时候，我就会存入500元，感谢神明⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這是文乃好尊專用存錢筒⋯⋯當覺得文乃好尊的時候，我就會存入500元，感謝神明⋯⋯」",
					{"rt2"},
				},
			},
		},
