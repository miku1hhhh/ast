				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Oh, thank you... I don’t like bitter flavors. Mnh, this tea is delicious! Could it be as good as what Miss Touka makes...?!”",
					{"rt2"},
				},
			},
			cn = {
