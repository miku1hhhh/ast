				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino chose me to be her husband, so now I have to make sure that choice wasn’t a mistake.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃视我为丈夫，我要证明她的选择没有错。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃視我為丈夫，我要證明她的選擇沒有錯。",
