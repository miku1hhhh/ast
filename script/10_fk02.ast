	["0109_00208"] = {
		{"se", id=0, loop=0, file="se_a217", vol=50},
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00201", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0147", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“It’s important to get a good lather. When it sticks to your hand upside down, the foam absorbs dirt well. It’s also important to be gentle. Too much friction causes skin—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"‘最重要的是搓泡泡。就算手反着泡泡也不会掉下来的程度，才能成功将肌肤中的脏污给带出来。另外，力道也很重要，太过大力摩擦的话，皮肤会──’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"『最重要的是搓泡泡。就算手反著泡泡也不會掉下來的程度，才能成功將肌膚中的髒污給帶出來。另外，力道也很重要，太過大力摩擦的話，皮膚會──』",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00207",
		linknext = "0109_00209",
		line = 3127,
	},
	["0109_00209"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="chitsuno0074", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"茅津野アナ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"茅津野アナ", "Pussy Galore"},
					"“Maintaining a consistent and thorough skincare routine is Hitoura’s way. Before bed, he applies a mask with 5 different extracts.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"茅津野アナ", "茅津野播报员"},
					"‘任何时刻都要小心翼翼的呵护肌肤，这就是仁浦氏作风。睡前使用5种萃取液制成的面膜缓缓睡去。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"茅津野アナ", "茅津野播報員"},
					"『任何時刻都要小心翼翼的呵護肌膚，這就是仁浦氏作風。睡前使用5種萃取液製成的面膜緩緩睡去。』",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00208",
		linknext = "0109_00210",
		line = 3139,
	},
