			[4499] = {
				{"transitiontime", time=300, timestamp=7, delay2=4500},
			},
		},
		text = {
			vo = {
				{"vo", file="tohka1874", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I mean, it’s just so lonely for me in the dorm now that you’re gone. Could you at least help me change clothes, Tachibana?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“因为你不在宿舍，我很寂寞嘛。至少帮我换个衣服如何，前辈？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「因為你不在宿舍，我很寂寞嘛。至少幫我換個衣服如何，前輩？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00058",
		linknext = "0109_00060",
		line = 787,
	},
	["0109_00060"] = {
		{"fg", file="rei_01m_00002", file1="rei_01m_00102", file2="rei_01m_00223", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="礼9", id=9, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2332", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“But I’m still there in the dorms... Isn’t that enough for you?! And changing your clothes is my job, Miss Touka! Am I being fired already?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“有我在不是吗⋯⋯您对我有什么不满意的吗⋯⋯！？为桐香大小姐换衣服是我的工作，还是您不要我了⋯⋯！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「有我在不是嗎⋯⋯您對我有什麼不滿意的嗎⋯⋯！？為桐香大小姐換衣服是我的工作，還是您不要我了⋯⋯！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00059",
		linknext = "0109_00061",
		line = 803,
	},
	["0109_00061"] = {
		{"fg", file="ikuko_02m_00002", file1="ikuko_02m_00101", file2="ikuko_02m_00214", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
