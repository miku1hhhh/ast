			cn = {
				{
					name = {"礼"},
					"“你游戏玩得也不怎么样，和我都是倒数的啊⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「妳遊戲玩得也不怎麼樣，和我都是倒數的啊⋯⋯」",
