				},
			},
			cn = {
				{
					name = {"桐香"},
					"“冷静点啊，前辈，你们要是就把我这样放着不管的话，可是会影响到晚餐的准备的喔⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「冷靜點啊，前輩，你們要是就把我這樣放著不管的話，可是會影響到晚餐的準備的喔⋯⋯」",
