			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“And you made my dream come true even in another world... I’m so happy about that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“你在别的世界也是努力实现我的梦啊⋯⋯我很高兴呢⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「你在別的世界也是努力實現我的夢啊⋯⋯我很高興呢⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00087",
		linknext = "0109_00089",
