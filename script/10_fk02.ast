					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“This rice cooker is falling apart, so let’s go buy a new one right away!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“煮饭锅也很旧了，马上去买个新的吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「煮飯鍋也很舊了，馬上去買個新的吧！」",
					{"rt2"},
				},
			},
		},
