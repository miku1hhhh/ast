		{"transitiontime", time=300},
		{"fgact", ch="桐香8", id=8, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1893", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Listen, Tachibana. By finding out what kind of body the woman who stole my love has, I can picture more realistic NTR scenarios!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“没关系呀，前辈。我也想知道我爱的人爱的人到底有怎样的一副身材，这样我就能做更真实的NTR妄想了⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「沒關係呀，前輩。我也想知道我愛的人愛的人到底有怎樣的一副身材，這樣我就能做更真實的NTR妄想了⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00285",
		linknext = "0109_00287",
		line = 4308,
	},
	["0109_00287"] = {
