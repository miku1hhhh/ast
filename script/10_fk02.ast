				{
					name = {"水姫", "Mizuki"},
					"“It seems impossible to me... hehe. I must admit, I love those kinds of hidden faults of yours though...❤”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水姫"},
					"“总感觉这辈子都不可能了⋯⋯喔呵呵，你这些不为人知没用的地方，我好喜欢哪⋯⋯",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水姫"},
					"「總感覺這輩子都不可能了⋯⋯喔呵呵，你這些不為人知沒用的地方，我好喜歡哪⋯⋯",
					{"gaiji", text="①"},
					"」",
					{"rt2"},
				},
			},
		},
