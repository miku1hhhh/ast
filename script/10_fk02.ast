	["0109_00070"] = {
		{"fg", file="ikuko_02m_00002", file1="ikuko_02m_00101", file3="ikuko_02m_00306", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2209", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Darling, you were always a weirdo, but even more so around Fumino. Back in the other world too, you were always saying her name.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“虽然亲爱的平常就很怪了，但是扯到文乃的事就会变得更奇怪呢。在另外一个世界也是这样文乃文乃的吗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「雖然親愛的平常就很怪了，但是扯到文乃的事就會變得更奇怪呢。在另外一個世界也是這樣文乃文乃的嗎。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00069",
		linknext = "0109_00071",
		line = 952,
	},
	["0109_00071"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file3="jun_01f_00307", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=22},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fumino, look this way! At a downward angle from slightly above!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“文乃，看向我这边！！视线有点从上往下看的感觉！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「文乃，看向我這邊！！視線有點從上往下看的感覺！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00070",
