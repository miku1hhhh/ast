			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Heh, well we are comrades who fought our way out of certain death together after all. Come hang out anytime.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你们是一起出生共死的伙伴──随时都欢迎你们来玩。”",
