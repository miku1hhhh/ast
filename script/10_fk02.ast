				{"vo", file="chitsuno0068", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"茅津野アナ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"茅津野アナ", "Pussy Galore"},
					"“Good afternoon. This is Pussy Galore, giving the people what they want.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"茅津野アナ", "茅津野播报员"},
					"“大家好⋯⋯我是接受你的全部的主播茅津野。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"茅津野アナ", "茅津野播報員"},
					"「大家好⋯⋯我是接受你的全部的主播茅津野。」",
