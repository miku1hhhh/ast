			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Well, I should get started on dinner soon... Since there are so many guests here, today’s menu will be—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“差不多要准备晚饭了⋯⋯今天这么多客人来访，那今天就做──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「差不多要準備晚飯了⋯⋯今天這麼多客人來訪，那今天就做──」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00266",
		linknext = "0109_00268",
