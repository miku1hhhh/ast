		{"fgact", ch="郁子10", id=10, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2220", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Rei, you’re in last place again so you’re out. Should we start our final battle?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“喂，礼酱，你又是最后一名了，让出来吧──差不多要来场顶上决战了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「喂，禮醬，妳又是最後一名了，讓出來吧──差不多要來場頂上決戰了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00253",
		linknext = "0109_00255",
		line = 3859,
	},
	["0109_00255"] = {
