				},
			},
			cn = {
				{
					name = {"礼"},
					"“为什么要在这个时机点把钱投入长得像香油钱箱的存钱筒中呢⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
