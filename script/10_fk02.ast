		{"text"},
		text = {
			vo = {
				{"vo", file="chitsuno0073", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"茅津野アナ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"茅津野アナ", "Pussy Galore"},
					"“Hitoura starts every morning by washing his face.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"茅津野アナ", "茅津野播报员"},
					"‘──仁浦的早晨就从洗脸开始。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"茅津野アナ", "茅津野播報員"},
					"『──仁浦的早晨就從洗臉開始。』",
