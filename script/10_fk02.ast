					name = {"桐香"},
					"“纺纱织线成就终点的牢，横扫乱斗对上完美防御⋯⋯来吧，就算毁灭坠落你还能回来吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「紡紗織線成就終點的牢，橫掃亂鬥對上完美防禦⋯⋯來吧，就算毀滅墜落你還能回來嗎？」",
					{"rt2"},
				},
			},
		},
