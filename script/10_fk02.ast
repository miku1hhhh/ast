				{"vo", file="tohka1898", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Fumino really seems like a good match for you. You suit each other well, and unfortunately it seems like there’s no place for me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“⋯⋯文乃同学很适合你。你们两个看起来很合，似乎没有我插入的余地。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「⋯⋯文乃同學很適合你。你們兩個看起來很合，似乎沒有我插入的餘地。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00343",
		linknext = "0109_00345",
		line = 5205,
	},
	["0109_00345"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Of course. Fumino’s my partner for life, you know?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“当然的呀，文乃可是我的人生伴侣。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「當然的呀，文乃可是我的人生伴侶。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00344",
		linknext = "0109_00346",
		line = 5217,
	},
	["0109_00346"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She always trusts me completely.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她总是信任我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她總是信任我。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00345",
		linknext = "0109_00347",
		line = 5227,
	},
	["0109_00347"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So I have to be the kind of person who deserves that trust.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以我要成为她值得信赖的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以我要成為她值得信賴的人。",
					{"rt2"},
				},
			},
		},
