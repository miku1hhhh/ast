			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Guests, please have a seat over here. I’ve prepared some tea for you... but would coffee be better?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“请往这边做。我准备好茶了⋯⋯还是说咖啡比较好呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「請往這邊做。我準備好茶了⋯⋯還是說咖啡比較好呢？」",
					{"rt2"},
				},
			},
		},
