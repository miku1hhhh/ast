	["0109_00361"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino follows my lead, and I always try my best to make her see me as a cool guy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃凡事几乎顺从我，而我希望在她面前表现帅气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃凡事幾乎順從我，而我希望在她面前表現帥氣。",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00360",
		linknext = "0109_00362",
