			en = {
				{
					name = {"水姫", "Mizuki"},
					"“This is the Red Nethers President’s Office. Oh, you’d like to collaborate on a project with President Hitoura? Starting right away?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水姫"},
					"“是，这边是红色耻部公司社长的办公室⋯⋯是，要和仁浦社长？联名产品？希望马上就能展开？”",
