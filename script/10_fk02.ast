		{"se", id=0, loop=0, file="se_a140"},
		{"se", id=1, loop=0, file="se_a080"},
		{"bgm", file="bgm09.5", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuki0014", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"水姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水姫", "Mizuki"},
					"“Excuse me. President Hitoura, I’m Mizuki Senba, a company secretary. The broadcast of the previously recorded ‘45-Hour Genitalia Deep Dive’ starts soon.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水姫"},
					"“打扰了⋯⋯仁浦社长，我是秘书仙波水姬。之前录制的节目‘性器贴身45小时’要开始播放了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水姫"},
					"「打擾了⋯⋯仁浦社長，我是秘書仙波水姬。之前錄製的節目『性器貼身45小時』要開始播放了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00202",
		linknext = "0109_00204",
		line = 3040,
	},
	["0109_00204"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00207", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", alpha=0, ch_origin="仁浦", ch="仁浦16", mw="mw", sync=1, a_chr151=1, mode=3, x=-5, y=-5},
		{"fgact", ch="仁浦16", id=16, lv=16, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="仁浦16", id=16, act="移動", x=0, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0145", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Oh, it’s already time for that? Let’s see how the editing turned out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“哎呀，已经要播了吗，让我来看看他们怎么剪辑的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「哎呀，已經要播了嗎，讓我來看看他們怎麼剪輯的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00203",
		linknext = "0109_00205",
		line = 3055,
	},
	["0109_00205"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuki0015", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"水姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水姫", "Mizuki"},
					"“As I mentioned, mass-media video editing can sometimes be used to intentionally distort the statements and character of subjects...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水姫"},
					"“媒体进行视频剪辑时，总是有所意图地将受访者的内容或者人物像捏造成想要的样子，之前有特别告诉过您⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水姫"},
					"「媒體進行影片剪輯時，總是有所意圖地將受訪者的內容或者人物像捏造成想要的樣子，之前有特別告訴過您⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0109_00204",
		linknext = "0109_00206",
		line = 3067,
	},
	["0109_00206"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00211", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0146", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Naturally, I tried to avoid statements that could be abused. Plenty of people who would like to crush an up-and-comer like me. Let’s see how it turned out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我说的话都是再三思量后才说的，多少人想要击败我这新起之辈，就让我来看看他们会怎么做吧──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
