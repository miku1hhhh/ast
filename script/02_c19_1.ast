		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s easy to understand how this situation is set up.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对方的意图就十分明白了。",
					{"rt2"},
				},
