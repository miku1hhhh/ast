			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“See, Rei? We weren’t able to get back before Darling woke up because you were taking forever! Just when we wanted to surprise him with a meal, too.”",
					{"rt2"},
				},
			},
			cn = {
