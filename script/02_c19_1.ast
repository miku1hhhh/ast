		},
		linkback = "0037_00054",
		linknext = "0037_00056",
		line = 729,
	},
	["0037_00056"] = {
		{"fg", file="rei_02m_00006", file1="rei_02m_00101", file2="rei_02m_00206", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0910", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“A man’s appearance, I believe. I recall Akino’s hair being long, but not that long.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是男性的姿态。我印象中他有留长发、不过没有像现在这么长。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是男性的姿態。我印象中他有留長髮、不過沒有像現在這麼長。」",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00055",
		linknext = "0037_00057",
		line = 744,
	},
	["0037_00057"] = {
		{"fg", file="tohka_02m_00006", file1="tohka_02m_00101", file2="tohka_02m_00214", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0724", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Though our academy allows its students to customize their outfits, they are not allowed to wear clothes of the opposite sex due to the effects that would have on perversion.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“虽然说我们学校是可以穿便服的私校，但因为变态法的关系，学生不能穿着跟性别不同的服装。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「雖然說我們學校是可以穿便服的私校，但因為變態法的關係，學生不能穿著跟性別不同的服裝。」",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00056",
		linknext = "0037_00058",
		line = 759,
	},
	["0037_00058"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s why Fumino kept dressing like a boy as she went to the Academy in World A.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这就是为什么A世界的文乃会穿着男装上学的原因。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這就是為什麼A世界的文乃會穿著男裝上學的原因。",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00057",
		linknext = "0037_00059",
		line = 769,
	},
	["0037_00059"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If your information is registered in Minotsuki Academy’s records, men are not allowed to wear women’s clothing, and vice versa.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一旦在水乃月月学园登记了个人资料，就无法做出男生穿女装、女生穿男装的行为。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一旦在水乃月月學園登記了個人資料，就無法做出男生穿女裝、女生穿男裝的行為。",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00058",
		linknext = "0037_00060",
		line = 779,
	},
	["0037_00060"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That was the rule. It was set in place to ensure perversion occurs in the smoothest possible manner.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这是为了让变态行为能更顺利执行而制定的规定。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這是為了讓變態行為能更順利執行而制定的規定。",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00059",
		linknext = "0037_00061",
		line = 789,
	},
	["0037_00061"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Which is why she went to the SHO and asked Hitoura to change the information our school has on file?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以她才会透过SHO──透过仁浦来修改她登基在学校的资料。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以她才會透過SHO──透過仁浦來修改她登基在學校的資料。」",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00060",
		linknext = "0037_00062",
		line = 801,
	},
	["0037_00062"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s why the gender ratio was off compared to our world.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这就是原本的世界里，男女比差距很大的原因。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這就是原本的世界裡，男女比差距很大的原因。",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00061",
		linknext = "0037_00063",
		line = 811,
	},
	["0037_00063"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So this was the reason why Touka felt like something was off. We were so close this whole time.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而桐香在刚刚感受到的违和感，背后的真实原因，就是这个──",
					{"rt2"},
				},
			},
			tw = {
				{
					"而桐香在剛剛感受到的違和感，背後的真實原因，就是這個──",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00062",
		linknext = "0037_00064",
		line = 821,
	},
	["0037_00064"] = {
		{"fg", file="tohka_02m_00006", file1="tohka_02m_00101", file2="tohka_02m_00204", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0725", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I apologize. I’d figured so much out... but I was unable to connect all the dots.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“非常抱歉。虽然我有想过这件事⋯⋯但没有想到这个层面上。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「非常抱歉。雖然我有想過這件事⋯⋯但沒有想到這個層面上。」",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00063",
		linknext = "0037_00065",
		line = 836,
	},
	["0037_00065"] = {
		{"fg", file="rei_01m_00006", file1="rei_01m_00102", file2="rei_01m_00206", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0911", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No, Miss Touka...! No average person would’ve been able to make it as far as you...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你在胡说什么呢，桐香大人⋯⋯！一般人的人谁都不会想到那里去的⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你在胡說什麼呢，桐香大人⋯⋯！一般人的人誰都不會想到那裡去的⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00064",
		linknext = "0037_00066",
		line = 851,
	},
	["0037_00066"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’d be practically impossible for us to notice something about Akino now that our memories are being overwritten.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在。因为记忆开始被覆盖，我们察觉到那是秋野的可能性几乎同等于零。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在。因為記憶開始被覆蓋，我們察覺到那是秋野的可能性幾乎同等於零。",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00065",
		linknext = "0037_00067",
		line = 861,
	},
	["0037_00067"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s why they’ve been able to fool us for this long.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那就是为什么，状况会是这样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那就是為什麼，狀況會是這樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00066",
