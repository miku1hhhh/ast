	["0037_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But she was just so much like me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她，跟我自己非常的像。",
					{"rt2"},
				},
