	["0037_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s not as though I had any concrete reason to think that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我并没有一个非常明确的理由来佐证。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我並沒有一個非常明確的理由來佐證。",
