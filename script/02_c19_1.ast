	["0037_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I felt bad for her, and I sympathized with her as well.",
					{"rt2"},
				},
			},
			cn = {
				{
					"觉得她很可怜之余，其实也在对方身上投射了对自己的同情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"覺得她很可憐之餘，其實也在對方身上投射了對自己的同情。",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00004",
