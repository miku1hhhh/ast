	["0037_00055"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The Akino who took my place looked like a woman... What about in World A?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在这边，取代了我的位置的秋野是女性的姿态⋯⋯A世界那边也是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在這邊，取代了我的位置的秋野是女性的姿態⋯⋯A世界那邊也是嗎？」",
