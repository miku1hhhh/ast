	["0037_00053"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So easy that we never even considered it, you might say.",
					{"rt2"},
				},
			},
			cn = {
				{
					"甚至太过明了到完全没有其他的可能性。",
					{"rt2"},
				},
			},
			tw = {
				{
					"甚至太過明瞭到完全沒有其他的可能性。",
