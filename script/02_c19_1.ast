		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A girl who leads her life while dressing differently and lying about her sex.",
					{"rt2"},
				},
			},
			cn = {
				{
					"改变穿着、掩饰性别生存下去的少女。",
					{"rt2"},
