		{"fg", file="ikuko_02l_00001", file1="ikuko_02l_00101", file3="ikuko_02l_00301", path=":fg/ikuko_02l/", id=10, lv=10, head="ikuko_02l", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="郁子10", id=10, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0976", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“And I foraged some edible plants. Have I made you fall back in love with me yet, Darling?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“能吃的野草也是郁找到的喔？是不是又爱上我了啊，亲爱的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「能吃的野草也是郁找到的喔？是不是又愛上我了啊，親愛的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00037",
		linknext = "0037_00039",
		line = 523,
	},
	["0037_00039"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Whoa, all these...?! Wow, I guess first squad must have undergone survival training or something?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“唔哇啊这么多⋯⋯！真是厉害，果然一队有做过生存训练的吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「唔哇啊這麼多⋯⋯！真是厲害，果然一隊有做過生存訓練的吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00038",
		linknext = "0037_00040",
		line = 535,
	},
	["0037_00040"] = {
		{"fg", file="ikuko_02l_00001", file1="ikuko_02l_00101", file2="ikuko_02l_00207", path=":fg/ikuko_02l/", id=10, lv=10, head="ikuko_02l", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0977", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“We did do some of that, but I learned it from my family. There was all kinds of training, like being abandoned in the woods and having to survive for two weeks when I was five.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“虽然说队上的训练也有没错，不过郁的话还是因为在老家的经验呢。我从5岁开始就被丢在树林自生自灭了大概两周，这样子的训练喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「雖然說隊上的訓練也有沒錯，不過郁的話還是因為在老家的經驗呢。我從5歲開始就被丟在樹林自生自滅了大概兩週，這樣子的訓練喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00039",
		linknext = "0037_00041",
		line = 550,
	},
	["0037_00041"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00218", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, okay... I see...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊、噢⋯⋯这样啊⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊、噢⋯⋯這樣啊⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00040",
		linknext = "0037_00042",
		line = 562,
	},
	["0037_00042"] = {
		{"fg", file="ikuko_02l_00001", file1="ikuko_02l_00101", file2="ikuko_02l_00202", path=":fg/ikuko_02l/", id=10, lv=10, head="ikuko_02l", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0978", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I made this based on my memories from back then, but with plenty of love! So, Darling? How is it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“所以我运用那时候的记忆，做出了这个加了很多爱的食物喔。亲爱的觉得怎么样，好吃吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「所以我運用那時候的記憶，做出了這個加了很多愛的食物喔。親愛的覺得怎麼樣，好吃嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00041",
		linknext = "0037_00043",
		line = 577,
	},
	["0037_00043"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00214", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It lost most of its flavor just a second ago...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“突然没胃口了呢⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「突然沒胃口了呢⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00042",
		linknext = "0037_00044",
		line = 589,
	},
	["0037_00044"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Food isn’t an issue, at least, thanks to the FS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"总之多亏了有FS，吃食才不需要烦恼。",
					{"rt2"},
				},
			},
			tw = {
				{
					"總之多虧了有FS，吃食才不需要煩惱。",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00043",
		linknext = "0037_00045",
		line = 599,
	},
	["0037_00045"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We’ve figured out our drinking water situation too, fetching it in secret.",
					{"rt2"},
				},
			},
			cn = {
				{
					"饮用水也是，偷偷地打来的话，也总是能弄到手的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"飲用水也是，偷偷地打來的話，也總是能弄到手的。",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00044",
		linknext = "0037_00046",
		line = 609,
	},
	["0037_00046"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As far as the time we’ve needed to heal our wounds—we’ve managed to buy enough, but just barely.",
					{"rt2"},
				},
			},
			cn = {
				{
					"──总算是勉强争取到让伤口复原的时间。",
					{"rt2"},
				},
			},
			tw = {
				{
					"──總算是勉強爭取到讓傷口復原的時間。",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00045",
		linknext = "0037_00047",
		line = 619,
	},
	["0037_00047"] = {
		{"cgdel", id=2, lv=2, time=0, alphadel=1},
		{"fg", mode=-1, id=10, ch="郁子10", ch_origin="郁子", lv=10, time=0, sync=0},
		{"fg", file="rei_01m_00006", file1="rei_01m_00102", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0909", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I still can’t believe it, though. Akino was the one leading the Birds of a Feather...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“可是，难不成──‘Tori公’的背后推手，是秋野吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「可是，難不成──『Tori公』的背後推手，是秋野嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00046",
		linknext = "0037_00048",
		line = 637,
	},
	["0037_00048"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah... So, do you remember what happened in our world now?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊啊⋯⋯你想起了我们的世界的情况了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊啊⋯⋯妳想起了我們的世界的情況了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00047",
		linknext = "0037_00049",
		line = 649,
	},
	["0037_00049"] = {
		{"fg", file="tohka_02m_00006", file1="tohka_02m_00101", file2="tohka_02m_00204", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0723", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes. While the details aren’t clear... the FS student council vice president was none other than Mizuhiki Akino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“没错，虽然记忆并不是很清晰⋯⋯不过那边的FS学生副会长，是那个人、秋野水引。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「沒錯，雖然記憶並不是很清晰⋯⋯不過那邊的FS學生副會長，是那個人、秋野水引。」",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00048",
		linknext = "0037_00050",
		line = 663,
	},
	["0037_00050"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00211", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0979", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“She was also the one inside Hamedori. I doubt you had any chances to meet her since she was always out doing PR, though...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“在Hamedori君面的人也是他喔。因为一直在外面当公关宣传，所以亲爱的你才会没有见过他⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「在Hamedori君面的人也是他喔。因為一直在外面當公關宣傳，所以親愛的你才會沒有見過他⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00049",
		linknext = "0037_00051",
		line = 677,
	},
	["0037_00051"] = {
		{"text"},
		text = {
