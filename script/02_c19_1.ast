	},
	["0037_00068"] = {
		{"fg", file="tohka_02m_00006", file1="tohka_02m_00102", file3="tohka_02m_00313", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0726", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“There’s that... but there’s also our plan to infiltrate the SHO.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“话是这么说没错⋯⋯不过SHO的潜入计划，恐怕也是如此。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「話是這麼說沒錯⋯⋯不過SHO的潛入計畫，恐怕也是如此。」",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00067",
		linknext = "0037_00069",
		line = 886,
	},
	["0037_00069"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00219", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I guess you weren’t all that enthusiastic about it, were you...? Was this why?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“话说回来，桐香你一直都不怎么积极的原因⋯⋯难不成是因为这样吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「話說回來，桐香妳一直都不怎麼積極的原因⋯⋯難不成是因為這樣嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00068",
		linknext = "0037_00070",
		line = 898,
	},
	["0037_00070"] = {
		{"fg", file="tohka_02m_00006", file1="tohka_02m_00101", file3="tohka_02m_00312", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[3000] = {
				{"fg", file="tohka_02m_00006", file1="tohka_02m_00101", file2="tohka_02m_00206", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, timestamp=3, delay2=3000, mode=3, x=-5, y=-5},
			},
			[2999] = {
				{"transitiontime", time=300, timestamp=3, delay2=3000},
			},
		},
		text = {
			vo = {
				{"vo", file="tohka0727", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“It’s not as though I had a clear reason, but I felt concerned about leaving the area around Minotsuki shorthanded... I’m sorry, I should have stated my thoughts out loud.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“实际上我并没有明确的理由。我只不过是有点担心这会让水乃月周边环境变得有些薄弱⋯⋯抱歉，我应该要好好表达自己的意见的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「實際上我並沒有明確的理由。我只不過是有點擔心這會讓水乃月周邊環境變得有些薄弱⋯⋯抱歉，我應該要好好表達自己的意見的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00069",
		linknext = "0037_00071",
		line = 916,
	},
	["0037_00071"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00229", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0980", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“It’s fine, Tokie... We were all for it, and it’s not like you could’ve predicted any of this happening.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“没关系啦桐香酱⋯⋯实话说我们也没办法想像你积极起来会是什么样子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「沒關係啦桐香醬⋯⋯實話說我們也沒辦法想像妳積極起來會是什麼樣子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00070",
		linknext = "0037_00072",
		line = 931,
	},
	["0037_00072"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ikuko’s right. Why don’t we just focus on finding a way to beat them for now?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“郁子说得没错⋯⋯而且现在更重要的，是摸索出赢过那家伙的办法。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「郁子說得沒錯⋯⋯而且現在更重要的，是摸索出贏過那傢伙的辦法。」",
					{"rt2"},
				},
			},
		},
		linkback = "0037_00071",
