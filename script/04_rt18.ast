			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Fourth! I didn’t realize you watched that season, Touka! You know that’s so relevant to the character of the fourth rider! If you’re talking about the 80s ones, sorry, I haven’t watched them yet!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					[[“喔喔四号！？桐香大小姐也看了那个了吗？说那个"可以"，大小姐也还真懂呢！啊，如果是昭和的那就对不起了，我只稍微看了一些”]],
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					[[「喔喔四號！？桐香大小姐也看了那個了嗎？說那個"可以"，大小姐也還真懂呢！啊，如果是昭和的那就對不起了，我只稍微看了一些」]],
					{"rt2"},
				},
			},
		},
		linkback = "0074_00198",
		linknext = "0074_00200",
		line = 3159,
	},
