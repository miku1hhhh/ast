	["0074_00119"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asa’s good at making things weird, but she did hit on Rei’s core qualities pretty well.",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙酱也是，该说是在奇怪的方面感觉很敏锐吗──她或许是用野性的本能嗅出了礼的本质吧？",
					{"rt2"},
				},
			},
			tw = {
				{
					"麻沙醬也是，該說是在奇怪的方面感覺很敏銳嗎──她或許是用野性的本能嗅出了禮的本質吧？",
					{"rt2"},
				},
			},
		},
