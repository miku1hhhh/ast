	["0074_00128"] = {
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=2, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Unfortunately, Asa’s off on one of her tirades.",
					{"rt2"},
				},
			},
			cn = {
				{
					"像是想说光是这样还说不够似地，麻沙酱不停地抱怨。",
					{"rt2"},
				},
			},
			tw = {
				{
					"像是想說光是這樣還說不夠似地，麻沙醬不停地抱怨。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00127",
		linknext = "0074_00129",
		line = 2125,
	},
	["0074_00129"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She doesn’t mind people calling the character by name instead of the actor playing them, but it’s weird when they still use the tokusatsu name when the actor is on other shows, etc., etc.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不是用演员而是用角色的名字来称呼登场人物姑且不论，当同样的演员在其他的戏剧或节目礼登场的时候还是用角色的名字来叫实在是很恶心之类的──",
					{"rt2"},
				},
			},
			tw = {
				{
					"不是用演員而是用角色的名字來稱呼登場人物姑且不論，當同樣的演員在其他的戲劇或節目禮登場的時候還是用角色的名字來叫實在是很噁心之類的──",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00128",
		linknext = "0074_00130",
		line = 2135,
	},
	["0074_00130"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I’m gonna stay with Rei, Asa’s gonna come into contact with her at some point.",
					{"rt2"},
				},
			},
			cn = {
				{
					"既然今后我要和礼继续交往，礼和麻沙酱接触的机会应该也会增加吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"既然今後我要和禮繼續交往，禮和麻沙醬接觸的機會應該也會增加吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00129",
		linknext = "0074_00131",
		line = 2145,
	},
	["0074_00131"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When I visited Rei’s room before I saw that she was playing some of the same games as Asa, so maybe they share other interests?",
					{"rt2"},
				},
			},
			cn = {
				{
					"先前拜访礼的房间的时候也有看到跟麻沙酱在玩的一样的游戏，不只是特摄，我感觉她们的兴趣本身应该是满合的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"先前拜訪禮的房間的時候也有看到跟麻沙醬在玩的一樣的遊戲，不只是特攝，我感覺她們的興趣本身應該是滿合的。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00130",
		linknext = "0074_00132",
		line = 2155,
	},
	["0074_00132"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Huh, they actually have a lot in common now that I think about it. They both have trouble getting up in the mornings and are sloppy when they’re not working.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不如说──早上起不来啊、私生活很邋遢之类的，颇有相似之处。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不如說──早上起不來啊、私生活很邋遢之類的，頗有相似之處。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00131",
		linknext = "0074_00133",
		line = 2165,
	},
	["0074_00133"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And Asa likes girls older than her, while Rei prefers younger. They seem like they’d definitely get along!",
					{"rt2"},
				},
			},
			cn = {
				{
					"在此之上，麻沙酱还喜欢年纪大的、而礼也喜欢年纪小的。如果只抽出这些要素，感觉她们的相性应该挺好的才对──",
					{"rt2"},
				},
			},
			tw = {
				{
					"在此之上，麻沙醬還喜歡年紀大的、而禮也喜歡年紀小的。如果只抽出這些要素，感覺她們的相性應該挺好的才對──",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00132",
