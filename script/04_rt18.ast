				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I’m not sure about the whole data thing, but you really killed it with this. I kind of want to give it a try... What’s your secret? Do you have any data?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“资料搜集先不说，这还真厉害啊……让人想要学学看呢……有什么要诀吗？有相关的资料之类的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「資料蒐集先不說，這還真厲害啊……讓人想要學學看呢……有什麼要訣嗎？有相關的資料之類的……」",
					{"rt2"},
				},
			},
		},
