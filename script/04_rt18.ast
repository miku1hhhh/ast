				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“If I could, I’d do it in a heartbeat! Do you even understand the despair I feel that I keep getting taller?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“能分给你的话我也想啊就连现在这个瞬间都还在继续长高的这种绝望你哪会懂啊！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「能分給妳的話我也想啊就連現在這個瞬間都還在繼續長高的這種絕望妳哪會懂啊！！」",
					{"rt2"},
				},
			},
		},
