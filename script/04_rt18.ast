			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“I’m so happy for you, Rei... When I first started here, I was always causing trouble for you with my incompetence, and now... Oh, I’m gonna cry!”",
					{"rt2"},
				},
			},
			cn = {
