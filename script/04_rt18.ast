				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那些家伙总会在聊完全无关的作品的时候也会马上搬出特摄的话题、而且老是认定世界上所有的存在都是从特摄作品之中诞生的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那些傢伙總會在聊完全無關的作品的時候也會馬上搬出特攝的話題、而且老是認定世界上所有的存在都是從特攝作品之中誕生的……」",
					{"rt2"},
				},
			},
		},
