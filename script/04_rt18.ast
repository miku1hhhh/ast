		{"text"},
		text = {
			vo = {
				{"vo", file="ran0119", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“It’s time for a party to close out the event and celebrate the newly formed couple of our disciplinary committee president Rei Tadasugawa, and the hero of the Lewd War, Junnosuke Tachibana!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“今天是为了举办该活动的庆功宴以及……祝贺吾等的风纪委员长、糺川礼与色情狂战役的英雄橘淳之介君开始交往，包下整间店举办的派对！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「今天是為了舉辦該活動的慶功宴以及……祝賀吾等的風紀委員長、糺川禮與色情狂戰役的英雄橘淳之介君開始交往，包下整間店舉辦的派對！」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00002",
		linknext = "0074_00004",
		line = 49,
	},
	["0074_00004"] = {
