			en = {
				{
					name = {"礼", "Rei"},
					"“Or maybe you’re talking about the mystery fourth member? Classic Touka, you even know all the insider terms! Hahahaha! Heck yeah! Hahahaha!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“还是说是那边吗、是未确认的那个四号吗？特地把那个给说成是四号桐香大小姐还真是内行啊哈哈哈哈哈！──咕！！呜哇哈哈哈哈！！”",
