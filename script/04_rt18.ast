			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“A serious nerdy slut who’s older than me... Never say never, but I don’t see the appeal. Tadasugawa just doesn’t do it for me. Absolutely no threesome potential there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不……年长死认真型的顽固婊子……以麻沙酱的角度来看明明应该是完全可以的……可是麻沙酱对糺川前辈，不知为何一点感觉都没有呢……一点3P的欲望都没有……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不……年長死認真型的頑固婊子……以麻沙醬的角度來看明明應該是完全可以的……可是麻沙醬對糺川前輩，不知為何一點感覺都沒有呢……一點3P的慾望都沒有……」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00116",
		linknext = "0074_00118",
		line = 1985,
	},
	["0074_00118"] = {
