		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She likes tokusatsu, you two would probably get along well. You watch it occasionally, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“礼似乎很喜欢特摄，跟麻沙酱应该挺有话题的吧？麻沙酱偶尔也会看不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「禮似乎很喜歡特攝，跟麻沙醬應該挺有話題的吧？麻沙醬偶爾也會看不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00120",
		linknext = "0074_00122",
		line = 2029,
	},
