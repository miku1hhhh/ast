					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Huh? It was just on my mind! Did the man who famously said he was never gonna sususu, finally do the sususu? Well? Well?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“咦—？毕竟这很令人在意不是吗？那位说着“我绝对不会s丝x的！”的仁兄到底s丝x了没？欸欸，怎么样啊？怎么样啊～？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「咦—？畢竟這很令人在意不是嗎？那位說著「我絕對不會s絲x的！」的仁兄到底s絲x了沒？欸欸，怎麼樣啊？怎麼樣啊～？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00028",
