					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Wait, is this even a buffet plate? It looks like a chef plated it...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这个……真的是自助餐吗？不是原本就摆成这样的料理之类的……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這個……真的是自助餐嗎？不是原本就擺成這樣的料理之類的……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00013",
		linknext = "0074_00015",
		line = 237,
	},
	["0074_00015"] = {
		{"fg", file="schubert_01m_00002", file2="schubert_01m_00211", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=11, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0291", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Of course! Well, I always say buffet plating is similar to data collection. And no one’s better at that than myself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“嗯，当然是自助餐了。呼……虽然有点老王卖瓜，但是说到搜集资料和自助餐的摆盘，我自负无人能与我比肩”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「嗯，當然是自助餐了。呼……雖然有點老王賣瓜，但是說到蒐集資料和自助餐的擺盤，我自負無人能與我比肩」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00014",
		linknext = "0074_00016",
		line = 252,
	},
	["0074_00016"] = {
