		linknext = "0074_00120",
		line = 2007,
	},
	["0074_00120"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I mean, she’s still into Nanase, who’s more of a would-be slut... But her vibe is more about past conquests.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽说如此，可是她似乎还是一如既往地对假婊子奈奈濑一往情深──比起是不是婊子云云，或许跟过去发生的事情更有关系吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖說如此，可是她似乎還是一如既往地對假婊子奈奈瀨一往情深──比起是不是婊子云云，或許跟過去發生的事情更有關係吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00119",
		linknext = "0074_00121",
		line = 2017,
	},
	["0074_00121"] = {
