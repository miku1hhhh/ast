	["0074_00024"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He tailored it to my personal tastes, but he knew that too much meat would make it look like a pile of brown, so he combined it skillfully with the other colors.",
