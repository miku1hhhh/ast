	["0074_00196"] = {
		{"fg", file="tohka_01f_00001", file1="tohka_01f_00101", file2="tohka_01f_00212", path=":fg/tohka_01f/", id=30, ch="桐香", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1700", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“It’s like Rei is his official wife, but you were his first wife, and Fumino, who lives with them, is their mistress... Wait, that puts me fourth in the ranking!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“礼是本妻、奈奈濑是正宫、同居的文乃实质上就是情妇……这么一来我就是排在第四个了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「禮是本妻、奈奈瀨是正宮、同居的文乃實質上就是情婦……這麼一來我就是排在第四個了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00195",
		linknext = "0074_00197",
		line = 3117,
	},
	["0074_00197"] = {
		{"fg", file="ikuko_01f_00001", file1="ikuko_01f_00101", file2="ikuko_01f_00213", path=":fg/ikuko_01f/", id=30, ch="郁子", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1317", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“And how does being fourth make you feel, Tokie?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“桐香酱看来如何，四号这个位置？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「桐香醬看來如何，四號這個位置？」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00196",
		linknext = "0074_00198",
		line = 3130,
	},
	["0074_00198"] = {
		{"fg", file="tohka_02f_00001", file1="tohka_02f_00103", file2="tohka_02f_00219", path=":fg/tohka_02f/", id=30, ch="桐香", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1701", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I’m the one who he sighs and settles for when the other three aren’t available... I couldn’t hope for better!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					[[“在前三个人都不在的时候，负责被叹着气充当妥协的对象的四号……完全"可以"呢”]],
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					[[「在前三個人都不在的時候，負責被嘆著氣充當妥協的對象的四號……完全"可以"呢」]],
					{"rt2"},
				},
			},
		},
		linkback = "0074_00197",
		linknext = "0074_00199",
		line = 3143,
	},
	["0074_00199"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="rcg0401010401", x=0, y=0, path=":cg/rcg04/", lv=18, ev=1, bx=800, by=450},
