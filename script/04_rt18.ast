		{"fgact", ch="スス子11", id=11, act="振動下", loop=1, size=-25, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0431", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Why I oughta... You’re gonna spoil the party by talkin’ about my height, ya damned loli! I didn’t choose to be this tall!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“呶喔喔居然在这可喜可贺的场合谈论起了身高啊这个死萝莉丝丝子也不是自愿长得这么大只的好吗！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「呶喔喔居然在這可喜可賀的場合談論起了身高啊這個死蘿莉絲絲子也不是自願長得這麼大隻的好嗎！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00045",
		linknext = "0074_00047",
		line = 717,
	},
	["0074_00047"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00103", file2="hinami_02m_00218", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=100},
		{"fgact", ch="ヒナミ5", id=5, act="振動下", loop=2, size=-25, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0280", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I’m not a loli! I didn’t choose to be this small either! Share some of that height with me! Gimme some of those tiddies!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“才不是萝莉呢，而且椅子子也不是自愿长得这么小只的啊！！把那身高和胸部分我一点啦！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「才不是蘿莉呢，而且椅子子也不是自願長得這麼小隻的啊！！把那身高和胸部分我一點啦！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0074_00046",
		linknext = "0074_00048",
		line = 733,
	},
	["0074_00048"] = {
