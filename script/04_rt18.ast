				},
			},
			cn = {
				{
					name = {"凛"},
					"“呕恶……快吐了……呜呜……总是说一些居高临下的话真是对不起……原谅我吧只属于富裕阶级的神明……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「嘔噁……快吐了……嗚嗚……總是說一些居高臨下的話真是對不起……原諒我吧只屬於富裕階級的神明……」",
					{"rt2"},
				},
			},
		},
