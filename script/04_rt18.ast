				},
			},
			tw = {
				{
					name = {"蘭"},
					[[「如此這般，"Hamedori君大量射精無套做愛滋滋啪啪狂歡節"性況空前地閉幕，撤展與整理也平安結束了！」]],
					{"rt2"},
				},
			},
		},
