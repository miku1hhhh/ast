				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「雖然播放『為了努力工作的你而溫柔鼓勵的大姐姐.wav』來解決，但是……在H部分要是被迫高潮了，反而會很累啊。」",
					{"rt2"},
				},
			},
