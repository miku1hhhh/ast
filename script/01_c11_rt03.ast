		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Not all that long ago, I once retreated from reality due to the stress I was under. I must be wary of making the same mistake.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不久前才因为压力过大而退化成婴儿，所以不得不承认。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不久前才因為壓力過大而退化成嬰兒，所以不得不承認。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00171",
