			tw = {
				{
					"剛來青藍島的時候嗎──確實，禮前輩原本是出生在本島的。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00214",
		linknext = "0002_00216",
		line = 2901,
	},
	["0002_00216"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The reason she hates sex... She must have been unable to get used to the way of life here, no matter how many partners she has slept with.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这么长时间都嫌恶性行为──无论敞开多少次身体却都没有习惯岛上的价值观，或许也是因为那样吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這麼長時間都嫌惡性行為──無論敞開多少次身體卻都沒有習慣島上的價值觀，或許也是因為那樣吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00215",
		linknext = "0002_00217",
		line = 2911,
	},
	["0002_00217"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This isn’t something you broach out of nowhere...",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且──这不是可以随意追问的事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且──這不是可以隨意追問的事。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00216",
		linknext = "0002_00218",
		line = 2921,
	},
	["0002_00218"] = {
