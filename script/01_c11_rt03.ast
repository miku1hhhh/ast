	["0002_00036"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hmm, the non-FS students around the school were helping out a little, weren’t they?",
					{"rt2"},
				},
			},
			cn = {
				{
					"我记得报告确实提过学园周遭有不是FS的学生在努力协助工作。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我記得報告確實提過學園周遭有不是FS的學生在努力協助工作。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00035",
