	["0002_00154"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Please, don’t try and shoulder every burden on your own.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不要像这样──什么都一个人承受。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不要像這樣──什麼都一個人承受。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00153",
		linknext = "0002_00155",
		line = 2067,
	},
	["0002_00155"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sometimes, taking the extra burden only ends up hurting those closest to you more.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了不伤害任何人──所以一个人背负起所有事情，比什么都更让重要的人伤心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了不傷害任何人──所以一個人背負起所有事情，比什麼都更讓重要的人傷心。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00154",
		linknext = "0002_00156",
		line = 2077,
	},
	["0002_00156"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I felt this most of all when fighting alongside my comrades in the NLNS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是──我和NLNS的伙伴们一同战斗中所痛感到的结论。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那是──我和NLNS的夥伴們一同戰鬥中所痛感到的結論。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00155",
		linknext = "0002_00157",
		line = 2087,
	},
	["0002_00157"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There was a girl who fought alone—who believed that all the wrongs on the island were her responsibility, and resolved to give everything she had to change things.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为过去曾有觉得岛上所有的事都是自己责任，一个人不断战斗并奉献自己，来改变岛屿的少女。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為過去曾有覺得島上所有的事都是自己責任，一個人不斷戰鬥並奉獻自己，來改變島嶼的少女。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00156",
		linknext = "0002_00158",
		line = 2097,
	},
	["0002_00158"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"—And a boy who thought he was responsible for her actions, and tried to save her all by himself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"还有因为觉得是自己害她承受了这些，而只身帮助她的少年。",
					{"rt2"},
				},
			},
			tw = {
				{
					"還有因為覺得是自己害她承受了這些，而隻身幫助她的少年。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00157",
		linknext = "0002_00159",
		line = 2107,
	},
	["0002_00159"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’ll never forget how that made my friends feel, how my actions affected them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"结果究竟让伙伴们有多痛苦──我已经亲身经历了。",
