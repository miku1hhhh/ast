				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“We’d eat cup noodles in her room even though we’d already eaten the dinner her mom cooked.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“明明吃过晚饭了，还是瞒着妈妈在房间里一起吃泡面。”",
