	["0002_00166"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I really appreciate my comrades, I should rely on them. That’s my new philosophy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"要是真的珍惜伙伴，就要依赖伙伴──我现在是这么想的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要是真的珍惜夥伴，就要依賴夥伴──我現在是這麼想的。",
