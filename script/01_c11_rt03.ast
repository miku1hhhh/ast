		text = {
			vo = {
				{"vo", file="rei0389", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“...And thanks for telling me not to take everything on by myself. It feels like a lot of pressure has been lifted off my back.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……我是说全部都自己一个人烦恼的事啦。虽然不完全是那样……但总觉得好像卸下了肩头的重担。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……我是說全部都自己一個人煩惱的事啦。雖然不完全是那樣……但總覺得好像卸下了肩頭的重擔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00198",
		linknext = "0002_00200",
		line = 2682,
	},
	["0002_00200"] = {
