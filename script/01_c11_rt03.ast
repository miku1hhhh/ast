		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00210", path=":fg/jun_01f/", id=30, ch="淳之介", lv=9, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She was so happy when Fumino showed up, going all ‘yay, flatty friends!’ She ended up explaining everything about the base to her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“文乃来的时候，她还很嗨地说什么‘是贫乳伙伴呢～’，很仔细地一一对她介绍基地呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「文乃來的時候，她還很嗨地說什麼『是貧乳夥伴呢～』，很仔細地一一對她介紹基地呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00227",
		linknext = "0002_00229",
		line = 3078,
	},
	["0002_00229"] = {
