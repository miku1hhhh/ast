		text = {
			vo = {
				{"vo", file="rei0395", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Yeah. She was even smaller when we first met. But personality-wise, no changes. She’s always been a lovely girl.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是啊，我遇到她时，她大概比现在还小两圈吧……嗯，但跟现在没有差很多。从以前就是很好的孩子……真的很好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是啊，我遇到她時，她大概比現在還小兩圈吧……嗯，但跟現在沒有差很多。從以前就是很好的孩子……真的很好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00219",
		linknext = "0002_00221",
		line = 2961,
	},
	["0002_00221"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00207", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I see... I can’t imagine an evil version of her, even in a mirror universe.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样啊……不过确实是难以想像雏见坏的样子呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣啊……不過確實是難以想像雛見壞的樣子呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00220",
		linknext = "0002_00222",
		line = 2973,
	},
	["0002_00222"] = {
