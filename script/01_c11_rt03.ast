				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ahaha, what an adorable scene that must’ve been! Hinami and Fumino! Oh, if only I could be a fly on the wall of the NLNS base!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“啊啊啊啊可以想像！光是这个故事就能吃下三碗饭了！雏见和文乃吗！？咦，太棒了吧……真想当NLNS基地的观赏植物……”",
