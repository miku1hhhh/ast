			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You know how there’s a rumor that His Sexellency needs at least one of the Big Three with him at all times to stay satisfied?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“如果不是身体万全状态的三巨头，是没办法满足性帝的──岛上有这样的传闻。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「如果不是身體萬全狀態的三巨頭，是沒辦法滿足性帝的──島上有這樣的傳聞。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00134",
