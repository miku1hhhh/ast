	["0002_00137"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00219", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0370", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“They also say that if one of us were to have sex with someone else and tire ourselves out, it might result in His Sexellency not being satisfied, and his furious anger will ravage the island...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“然后……如果我们跟其他人进行性行为而导致疲劳，没有办法让性帝满足，招来怒火的话……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「然後……如果我們跟其他人進行性行為而導致疲勞，沒有辦法讓性帝滿足，招來怒火的話……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00136",
		linknext = "0002_00138",
		line = 1828,
	},
	["0002_00138"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00206", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
