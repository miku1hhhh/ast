		{"cgact", file="cgact", id=2, act="移動", x=195, y=-5, time=20000, lv=2},
		{"fg", file="rei_02f_00001", file1="rei_02f_00101", file2="rei_02f_00214", path=":fg/rei_02f/", id=30, ch="礼", lv=2, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0376", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Before, I would never have resisted a man’s advance, no matter how crude. I guess I just got used to the world that you changed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“以前……明明心里完全没有抵抗的。可能因为我太习惯你们改变后的世界了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「以前……明明心裡完全沒有抵抗的。可能因為我太習慣你們改變後的世界了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00149",
		linknext = "0002_00151",
		line = 2013,
	},
	["0002_00151"] = {
		{"fg", file="rei_02f_00001", file1="rei_02f_00101", file3="rei_02f_00309", path=":fg/rei_02f/", id=30, ch="礼", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0377", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“But I’ve already done this loads of times before, I’m sure I’ll get used to it soon. It’s not like I’m scared. So, if I get approached for sex again, I can just—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“但是，因为以前曾经做过很多次……所以我一直想着反正很快就会习惯！就算发生跟今天一样的事，也不能让人觉得奇怪──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「但是，因為以前曾經做過很多次……所以我一直想著反正很快就會習慣！就算發生跟今天一樣的事，也不能讓人覺得奇怪──」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00150",
		linknext = "0002_00152",
		line = 2026,
	},
	["0002_00152"] = {
