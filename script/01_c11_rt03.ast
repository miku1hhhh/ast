	["0002_00170"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00205", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0380", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“But don’t go making the same mistake I did. I know the stress you must be feeling, trying to fix things.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“但是，你可别勉强喔。因为状况会有很大变化，所以压力应该也很大才对。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「但是，妳可別勉強喔。因為狀況會有很大變化，所以壓力應該也很大才對。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00169",
		linknext = "0002_00171",
		line = 2264,
	},
	["0002_00171"] = {
