			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“We tried playing the classic ‘Your Sexy Big Sis Whispers In Your Ear To Encourage You To Work Harder.wav’ tape, but that just made them jizz themselves and tired them out faster...”",
