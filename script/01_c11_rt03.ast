	},
	["0002_00037"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The well-lubed team of students—very well-acquainted with each other thanks to the constant and literal fucking around—were apparently quite helpful at the beach and shopping district.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也听过几次，人们在海滩和闹区因为做爱后关系好上，然后就自愿帮忙，结果让效率提升。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也聽過幾次，人們在海灘和鬧區因為做愛後關係好上，然後就自願幫忙，結果讓效率提升。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00036",
		linknext = "0002_00038",
		line = 474,
	},
	["0002_00038"] = {
