		text = {
			vo = {
				{"vo", file="rei0396", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Haha, you’re right there! But when I used to go to her place for a sleepover, she’d always say things like ‘Hey Rei, let’s do something really naughty!’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“哈哈，真的。啊，但是去住她家的话，她会邀请人说‘礼酱，来做坏事吧’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「哈哈，真的。啊，但是去住她家的話，她會邀請人說『禮醬，來做壞事吧』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00221",
