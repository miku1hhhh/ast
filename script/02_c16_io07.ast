			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“If I dress like a girl, then surely Daddy and Grandpappy will be kind to me again!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“要是像那次一样穿得像个女孩子，爸爸和舅舅应该就会对我好一点！”",
					{"rt2"},
				},
			},
			tw = {
