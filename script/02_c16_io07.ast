	["0031_00209"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0856", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子", "パペットイクちゃん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Puppet Iku"},
					"“Th’ Onabuta style is a style o’ swordsmanship not meant fer competition. It focuses not only on th’ sword, but jiujitsu as well. Right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子", "傀儡小郁"},
					"“女部田流派不是用来竞技而是用来战斗的剑术喔。所以不只有修习剑术技巧、同时也要修习柔道。对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子", "傀儡小郁"},
					"「女部田流派不是用來競技而是用來戰鬥的劍術喔。所以不只有修習劍術技巧、同時也要修習柔道。對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00208",
		linknext = "0031_00210",
		line = 2943,
	},
	["0031_00210"] = {
