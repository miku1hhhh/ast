			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I’m still alive, obviously. When those two passed away, Iku was rushed away to the hospital for treatment.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
