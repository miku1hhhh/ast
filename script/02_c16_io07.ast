			},
			en = {
				{
					"I’m reminded of the first time Ikuko and I exchanged vibrators.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我回想起第一次跟郁子进行按摩棒对战的那时。",
					{"rt2"},
