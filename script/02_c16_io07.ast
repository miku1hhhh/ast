	["0031_00132"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I connect the dots from what Ikuko has told me until now, I can get an idea of where this is going.",
					{"rt2"},
				},
			},
			cn = {
				{
					"结合郁子到目前为止告诉我的故事，我可以做出一个大概的预测。",
					{"rt2"},
				},
			},
			tw = {
				{
					"結合郁子到目前為止告訴我的故事，我可以做出一個大概的預測。",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00131",
