	["0031_00164"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It maintains a strong belief in perversion in spite of regular criticism from the mainland, and is now trying to make that belief more widespread.",
					{"rt2"},
				},
			},
			cn = {
				{
					"尽管受到了本岛的大量抨击，依旧认为变态行为才是绝对的幸福，现在正试图传播这一点。",
					{"rt2"},
				},
			},
			tw = {
				{
					"儘管受到了本島的大量抨擊，依舊認為變態行為才是絕對的幸福，現在正試圖傳播這一點。",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00163",
		linknext = "0031_00165",
		line = 2284,
	},
	["0031_00165"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"From what Ikuko is telling me, it seems that the Onabuta family line was steeped in old-fashioned ways of thinking.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从郁子的话听来，女武田家族似乎从一开始就有着相当陈旧的思维。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從郁子的話聽來，女武田家族似乎從一開始就有著相當陳舊的思維。",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00164",
		linknext = "0031_00166",
		line = 2294,
	},
	["0031_00166"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s not unnatural for the mind to spiral to extremes following the loss of a family member.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为失去家人而倾向于极端的想法，在他们家并没有那么不自然。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為失去家人而傾向於極端的想法，在他們家並沒有那麼不自然。",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00165",
		linknext = "0031_00167",
		line = 2304,
	},
	["0031_00167"] = {
		{"bgm", file="bgm38", vol=100},
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-113-1-1", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"cgact", file="cgact", id=17, act="浮遊横", loop=4, size=5, time=250, ease="easeinout_sine", lv=17, x=-5, y=-2.5},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0829", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子", "パペットイクちゃん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Puppet Iku"},
					"“Not to mention that the Onabuta household was feared by those around it. Nobody on the outside looking in would say a thing, huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子", "傀儡小郁"},
					"“女田部家周围的人好像都很害怕，谁也没有出来说话。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子", "傀儡小郁"},
					"「女田部家周圍的人好像都很害怕，誰也沒有出來說話。」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00166",
		linknext = "0031_00168",
		line = 2322,
	},
	["0031_00168"] = {
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-115-1-1", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0830", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Exactly. And while Iku wasn’t aware of this at the time, it would seem that the Onabuta family had developed ties with the Yakuza.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“是啊。当时的郁君并不知道，女部田家族好像在做黑道生业。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「是啊。當時的郁君並不知道，女部田家族好像在做黑道生業。」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00167",
		linknext = "0031_00169",
		line = 2338,
	},
	["0031_00169"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="icg02-1-1-11-1", x=-5, y=-2.5, path=":cg/icg02/", lv=18, ev=1, bx=800, by=450},
