	},
	["0031_00112"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The jokes aren’t quite landing, so I figure she’s doing this to keep things light.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我根本连根都跟不上──我猜她是极力地让我不感到灰心才故意这么做的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我根本連根都跟不上──我猜她是極力地讓我不感到灰心才故意這麼做的。",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00111",
		linknext = "0031_00113",
		line = 1512,
	},
	["0031_00113"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She really doesn’t need to though.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明就这不用察言观色到这种程度的说──",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明就這不用察言觀色到這種程度的說──",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00112",
		linknext = "0031_00114",
		line = 1522,
	},
	["0031_00114"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0799", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Her parents, being in their young and virile years, did not feel any pressure not having a male heir to hand down the Onabuta lineage to.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“那时我的父母都还年轻气盛，所以并不急于生个男孩继承女部田流。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「那時我的父母都還年輕氣盛，所以並不急於生個男孩繼承女部田流。」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00113",
		linknext = "0031_00115",
		line = 1534,
	},
	["0031_00115"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0800", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Even so, they banged and they banged, but were never able to produce a spare to their heir. The Onabuta family grew impatient.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“但是，他们行房了一次又一次，也没有看到第二胎的迹象⋯⋯就连女部田家都开始着急了。”",
					{"rt2"},
				},
			},
