	["0031_00223"] = {
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-112-1-1", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0865", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Iku was able to take down the son of another school that was talking smack about the Onabuta style. She even sent his father to the hospital shortly after because she felt bad about sending him alone.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我在短短几秒之内就把说女部田流派落伍了、瞧不起我们的新兴流派的儿子打得落花流水，因为看他一个人太可怜了，所以就把他父亲也当赠品一起打进医院去了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我在短短幾秒之內就把說女部田流派落伍了、瞧不起我們的新興流派的兒子打得落花流水，因為看他一個人太可憐了，所以就把他父親也當贈品一起打進醫院去了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00222",
		linknext = "0031_00224",
		line = 3143,
	},
	["0031_00224"] = {
		{"cgact", file="cgact", id=18, act="振動下", loop=2, size=-30, time=175, ease="easeinout_sine", lv=18, x=-5, y=-2.5},
