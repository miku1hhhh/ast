	["0031_00221"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0864", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Well, that isn’t to say there were never moments where she was praised. Thanks to her intense training, Iku developed tremendous strength.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“其实实际上也不是完全都没有被称赞过喔。熬过了严格的训练之后，郁君练出了强到不可思议的强韧身体喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「其實實際上也不是完全都沒有被稱讚過喔。熬過了嚴格的訓練之後，郁君練出了強到不可思議的強韌身體喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00220",
		linknext = "0031_00222",
		line = 3111,
	},
