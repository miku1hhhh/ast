	},
	["0031_00263"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"While the story was peppered with jokes, it was pretty grandiose when I really thought about it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然从头到尾都是半开玩笑的语气，但──细细品味的话，却是只能用惨烈来形容的故事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然從頭到尾都是半開玩笑的語氣，但──細細品味的話，卻是只能用慘烈來形容的故事。",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00262",
		linknext = "0031_00264",
		line = 3766,
	},
	["0031_00264"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A young girl as beautiful as a flower and as ephemeral as a butterfly whose mother passes away, and is subsequently forced to abandon her femininity for the sake of the family line...",
					{"rt2"},
				},
			},
			cn = {
				{
					"一个原来被万千娇宠的少女──失去了母亲、为了继承女部田流派而被迫放弃当女人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一個原來被萬千嬌寵的少女──失去了母親、為了繼承女部田流派而被迫放棄當女人。",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00263",
		linknext = "0031_00265",
		line = 3776,
	},
	["0031_00265"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s hard to describe succinctly but what happened to Ikuko is nothing short of abuse. No, even “abuse” isn’t strong enough of a word.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我什么都没有说，不过郁子身上发生的事不管怎么想都是虐待──不，说是虐待也都还太温和了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我什麼都沒有說，不過郁子身上發生的事不管怎麼想都是虐待──不，說是虐待也都還太溫和了。",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00264",
		linknext = "0031_00266",
		line = 3786,
	},
	["0031_00266"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was straight up criminal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是很明确的犯罪行为。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那是很明確的犯罪行為。",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00265",
		linknext = "0031_00267",
		line = 3796,
	},
	["0031_00267"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She was lucky to survive when she fell ill, since there’s a really high chance she would’ve died if left alone.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她生病时活了下来真的是运气好，要是这样放着她的话，十有八九他早就没命了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她生病時活了下來真的是運氣好，要是這樣放著她的話，十有八九他早就沒命了。",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00266",
		linknext = "0031_00268",
		line = 3806,
	},
	["0031_00268"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I fully understand what she means when she says the perverted sex law saved her now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她所说的被条例所拯救的事，我终于明白是怎么回事了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她所說的被條例所拯救的事，我終於明白是怎麼回事了。",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00267",
		linknext = "0031_00269",
		line = 3816,
	},
	["0031_00269"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Despite carrying all that history, Ikuko is able to smile now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"尽管背负着这么多的过去，郁子却还是这样笑着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"儘管背負著這麼多的過去，郁子卻還是這樣笑著。",
