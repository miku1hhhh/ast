	["0031_00235"] = {
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-114-1-1", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0874", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Both Daddy and Grandpappy refused to see a doctor and resorted to their own home remedies to get by, but it was no use! Buh-bye!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“拒绝就医，用自己擅长的毅力论尝试自己独创疗法的爸爸和爷爷，不幸地还是一起上了西天！永别了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「拒絕就醫，用自己擅長的毅力論嘗試自己獨創療法的爸爸和爺爺，不幸地還是一起上了西天！永別了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00234",
		linknext = "0031_00236",
		line = 3327,
	},
	["0031_00236"] = {
