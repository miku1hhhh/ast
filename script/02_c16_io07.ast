	["0031_00161"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I think it sounds a bit anachronistic to be honest, but in reality these kinds of stories aren’t unheard of.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我认为这有一定程度算是时代错误──弹实际上，这样的事并不少见。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我認為這有一定程度算是時代錯誤──彈實際上，這樣的事並不少見。",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00160",
		linknext = "0031_00162",
		line = 2254,
	},
	["0031_00162"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We create something of an echo chamber when we live in such a closed society, convincing ourselves that our ideas are the only right ones.",
					{"rt2"},
				},
			},
			cn = {
				{
					"身处封闭的环境会让人对别人说的话充耳不闻，盲目地相信自己的想法是正确的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"身處封閉的環境會讓人對別人說的話充耳不聞，盲目地相信自己的想法是正確的。",
					{"rt2"},
				},
			},
		},
