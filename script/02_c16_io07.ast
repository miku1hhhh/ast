	["0031_00174"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0834", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“The grueling training continued, to the point where Iku would even spit up blood. To her, the most painful thing was never receiving a lick of kindness.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“训练强到会吐血的程度。但对郁来说当时最痛苦的，是他得不到宽容的对待。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「訓練強到會吐血的程度。但對郁來說當時最痛苦的，是他得不到寬容的對待。」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00173",
		linknext = "0031_00175",
		line = 2426,
	},
	["0031_00175"] = {
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
