					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“And so the curtain closes on the Legend of Ikky. Well? What’d you think?”",
					{"rt2"},
				},
			},
			cn = {
