	["0031_00135"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="icg02-1-1-12-1", x=-5, y=-2.5, path=":cg/icg02/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fellatio0021", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"フェラチオウム"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"フェラチオウム", "Blowjob Cockatoo"},
					"“WHAT HAPPENED?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"フェラチオウム", "口交鹦鹉"},
					"“是谁？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"フェラチオウム", "口交鸚鵡"},
					"「是誰？」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00134",
		linknext = "0031_00136",
		line = 1851,
	},
	["0031_00136"] = {
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-115-1-1", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0812", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“The roots of the Onabuta tree ran deep. Rumor has it that Mommy and baby brother died because they were insistent that she have a natural, unassisted birth.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“女部田是一个观念守旧的家族，有传言说母亲他们是死于执着于正确的分娩方式的关系。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「女部田是一個觀念守舊的家族，有傳言說母親他們是死於執著於正確的分娩方式的關係。」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00135",
		linknext = "0031_00137",
		line = 1867,
	},
	["0031_00137"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0813", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“The Onabuta line honors blood and there was to be no replacement for Mommy. Such old-fashioned ways of thinking meant even distant relatives had turned their backs on them long ago.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“同样看重血脉的女部田家，找不到人能够替代母亲。原本其实也有分家的但也因为同样的原因所以被放弃了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「同樣看重血脈的女部田家，找不到人能夠替代母親。原本其實也有分家的但也因為同樣的原因所以被放棄了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00136",
		linknext = "0031_00138",
		line = 1879,
	},
	["0031_00138"] = {
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-113-1-1", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"cgact", file="cgact", id=17, act="浮遊横", loop=4, size=5, time=250, ease="easeinout_sine", lv=17, x=-5, y=-2.5},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0814", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子", "パペットイクちゃん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Puppet Iku"},
					"“With adoption out of the question, there was no heir capable of continuing the family line, and so the bloodline was finished.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子", "傀儡小郁"},
					"“不愿意领养的孩子女部田流的传承也就到此为止了⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子", "傀儡小郁"},
					"「不願意領養的孩子女部田流的傳承也就到此為止了⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00137",
		linknext = "0031_00139",
		line = 1896,
	},
	["0031_00139"] = {
