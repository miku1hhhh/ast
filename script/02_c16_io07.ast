				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She acts and speaks in a light, cheerful tone, but I can’t help but feel it rings flat.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她用朗朗上口的表演语调说话的样子，让人觉得好像有什么地方在空中滑行。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她用朗朗上口的表演語調說話的樣子，讓人覺得好像有什麽地方在空中滑行。",
					{"rt2"},
				},
