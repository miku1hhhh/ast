	["0031_00262"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="icg021111-1", x=-5, y=-2.5, path=":cg/icg02/", lv=18, ev=1, style="blur", blurx=11, blury=11, bx=800, by=450},
		{"transitiontime", time=800},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’m at a loss for words.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我回不上话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我回不上話。",
