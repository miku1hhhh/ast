	["0031_00027"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After what happened yesterday, she probably came to check and make sure I wasn’t crying out in my sleep again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"昨天才──难不成，她是因为担心我又会梦呓，所以才来的吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"昨天才──難不成，她是因為擔心我又會夢囈，所以才來的嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00026",
		linknext = "0031_00028",
		line = 378,
	},
	["0031_00028"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She’s all jokes on the surface, but I know that in reality she pays attention to those around her—even if she tries not to let it show.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然郁子表面上很爱胡闹，但那只是看起来，实际上她很注意周遭的一切。这点我很清楚。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然郁子表面上很愛胡鬧，但那只是看起來，實際上她很注意周遭的一切。這點我很清楚。",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00027",
		linknext = "0031_00029",
		line = 388,
	},
	["0031_00029"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s that side of Ikuko that makes me refuse to do anything dumb or let my libido get the better of me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正因为郁子是这样的──就更不用说她会真的会做出放任自流、追逐欲望这种轻率的事了。",
					{"rt2"},
				},
			},
			tw = {
