		line = 1978,
	},
	["0031_00144"] = {
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-113-1-1", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"cgact", file="cgact", id=17, act="浮遊横", loop=4, size=5, time=250, ease="easeinout_sine", lv=17, x=-5, y=-2.5},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0818", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子", "パペットイクちゃん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Puppet Iku"},
					"“Cut off her hair! Give up those dreams of motherhood! From now on, you’re Iku! Gehehe!!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子", "傀儡小郁"},
					"“把头发剪掉！母亲的事就这么忘掉吧！从今天开始你就是郁了！知道了吗！！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子", "傀儡小郁"},
					"「把頭髮剪掉！母親的事就這麼忘掉吧！從今天開始你就是郁了！知道了嗎！！！」",
					{"rt2"},
				},
			},
		},
