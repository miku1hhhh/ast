	["0031_00225"] = {
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-115-1-1", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0866", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Daddy and Grandpappy didn’t say anything, but they nodded in approval at Iku’s achievement and allowed her to eat a luxurious meal... even if they still refused to make eye contact.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“虽然爸爸跟爷爷什么都没有说，不过对郁君赢了的事郑重地点了点头，还让我吃了平时绝对不会让我吃到的喜欢的的食物。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「雖然爸爸跟爺爺什麼都沒有說，不過對郁君贏了的事鄭重地點了點頭，還讓我吃了平時絕對不會讓我吃到的喜歡的的食物。」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00224",
		linknext = "0031_00226",
		line = 3173,
	},
	["0031_00226"] = {
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-113-1-1", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"cgact", file="cgact", id=17, act="浮遊横", loop=4, size=5, time=250, ease="easeinout_sine", lv=17, x=-5, y=-2.5},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0867", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子", "パペットイクちゃん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Puppet Iku"},
					"“T’was plain udon an’ coffee milk, though! Ain’t exactleh fit fer a king!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子", "傀儡小郁"},
					"“广东炒面跟咖啡牛奶对不对？太寒酸了吧！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子", "傀儡小郁"},
					"「廣東炒麵跟咖啡牛奶對不對？太寒酸了吧！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00225",
		linknext = "0031_00227",
		line = 3190,
	},
	["0031_00227"] = {
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-115-1-1", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0868", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Maybe not, but while Iku had the strength of an adult, her heart was still that of a child’s. To her, this was a great kindness.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“虽然说很穷酸，但尽管郁君是个身体比大人强、心里也还是个小孩子唷。看到那些东西我都发出了‘哇──’的声音，超级开心唷！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「雖然說很窮酸，但儘管郁君是個身體比大人強、心裡也還是個小孩子唷。看到那些東西我都發出了『哇──』的聲音，超級開心唷！」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00226",
		linknext = "0031_00228",
		line = 3206,
	},
	["0031_00228"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0869", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Thinking back on it now, I don’t think Papa or Grandpappy really knew what it would take to make Iku happy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“不过现在回想起来，爸爸跟爷爷大概也不知道要怎么做才能让郁君开心吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「不過現在回想起來，爸爸跟爺爺大概也不知道要怎麼做才能讓郁君開心吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00227",
		linknext = "0031_00229",
		line = 3218,
	},
	["0031_00229"] = {
		{"bgm", stop=1},
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-114-1-1", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0870", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Nonetheless, Iku was quickly developing into an ideal heir to the school of Onabuta. But then there was another abrupt story change!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“但是以女部田流派继承者身份展露头角的郁君，却在这里又迎来了一次意想不到的发展！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「但是以女部田流派繼承者身份展露頭角的郁君，卻在這裡又迎來了一次意想不到的發展！」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00228",
		linknext = "0031_00230",
		line = 3235,
	},
	["0031_00230"] = {
		{"bgm", file="bgm08", vol=100},
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-113-1-1", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"cgact", file="cgact", id=17, act="浮遊横", loop=4, size=5, time=250, ease="easeinout_sine", lv=17, x=-5, y=-2.5},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0871", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子", "パペットイクちゃん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Puppet Iku"},
					"“A sudden plague! All three go’ infected! They prayed in distress! Walked the bays o’ th’ River Styx, they did! And then!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子", "傀儡小郁"},
					"“突然爆发的流行病！一家三口全都一起感染！！！缠绵病榻！看到奈何桥！如此如此这般这般！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子", "傀儡小郁"},
					"「突然爆發的流行病！一家三口全都一起感染！！！纏綿病榻！看到奈何橋！如此如此這般這般！」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00229",
		linknext = "0031_00231",
		line = 3253,
	},
	["0031_00231"] = {
