	["0031_00271"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ikuko’s life as a man was so small and empty, but she was finally able to make friends without needing to pretend to be something else. That was thanks to the FS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"能让一直作为男孩子、生活在狭隘世界里的郁子不用再掩饰自我好好相处的同伴──FS。",
					{"rt2"},
				},
			},
			tw = {
				{
					"能讓一直作為男孩子、生活在狹隘世界裡的郁子不用再掩飾自我好好相處的同伴──FS。",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00270",
		linknext = "0031_00272",
		line = 3846,
	},
	["0031_00272"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It makes sense that she would see them as family.",
					{"rt2"},
				},
