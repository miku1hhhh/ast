	["0031_00143"] = {
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-115-1-1", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0817", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Couldn’t have said it better. But with both their heir and his own wife gone, Daddy and Grandpappy weren’t left with much choice.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“说来也奇怪，继承家业的男丁和妻子同时去世了，爸爸和爷爷也都出了问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「說來也奇怪，繼承家業的男丁和妻子同時去世了，爸爸和爺爺也都出了問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00142",
