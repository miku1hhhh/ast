		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She kept the tone lighthearted, but the subject matter has a way of weighing on you after the fact.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然她的语气很平缓──但当一个人的时候想像力会更强，关于她那悲惨的现实浮现了出来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然她的語氣很平緩──但當一個人的時候想像力會更強，關於她那悲慘的現實浮現了出來。",
					{"rt2"},
				},
			},
		},
