		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Seiran Island really did save her life.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是这个称为青蓝岛的地方拯救了她。",
