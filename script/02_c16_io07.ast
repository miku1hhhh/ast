				},
			},
			cn = {
				{
					name = {"郁子", "傀儡小郁"},
					"“对啊！不久之前，我还是被娇宠着养大的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子", "傀儡小郁"},
					"「對啊！不久之前，我還是被嬌寵著養大的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00174",
