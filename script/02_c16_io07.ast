		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s the middle of the night when I suddenly feel a strange presence. Reflexively, I jolt awake.",
					{"rt2"},
				},
			},
			cn = {
				{
					"半夜──突然有一种奇怪的感觉朝我袭来，我反性地跳了起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"半夜──突然有一種奇怪的感覺朝我襲來，我反性地跳了起來。",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00004",
		linknext = "0031_00006",
		line = 70,
	},
	["0031_00006"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I struggle to peer around the dark room. I can barely see a thing since my eyes haven’t adjusted yet, but there’s definitely somebody in here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我才刚醒、眼睛还不能适应黑暗，根本看不到房间的情况──但我确实能感觉到有人在这里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我才剛醒、眼睛還不能適應黑暗，根本看不到房間的情況──但我確實能感覺到有人在這裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00005",
		linknext = "0031_00007",
		line = 80,
	},
