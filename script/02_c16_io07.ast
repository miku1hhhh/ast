					name = {"郁子", "Ikuko"},
					"“Yup!♪ Especially when it comes to pinning. Maybe it’s just in my nature?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嗯♪特别是寝技唷。很合我的风格嘛～？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嗯♪特別是寢技唷。很合我的風格嘛～？」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00211",
