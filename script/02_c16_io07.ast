					"我提出灵魂拷问。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我提出靈魂拷問。",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00095",
		linknext = "0031_00097",
		line = 1288,
	},
	["0031_00097"] = {
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-111-1-1", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0790", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Because I hate sad stories.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“因为人家讨厌气氛太让人郁闷嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「因為人家討厭氣氛太讓人鬱悶嘛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00096",
		linknext = "0031_00098",
		line = 1304,
	},
	["0031_00098"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Such is her response.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她说。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她說。",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00097",
		linknext = "0031_00099",
		line = 1314,
	},
	["0031_00099"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It would seem the spirit of Misaki hasn’t left us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看起来她并没有被美岬附身的样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看起來她並沒有被美岬附身的樣子。",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00098",
		linknext = "0031_00100",
		line = 1324,
	},
	["0031_00100"] = {
		{"evset", file="icg02", set="icg02", path=":ev/icg02/"},
		{"evset", file="icg02-115-1-1", set="icg02-115", path=":ev/icg02-115/"},
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-115-1-1", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"bgm", stop=1},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0791", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“When Ikky was born, she grew up in a kenjutsu dojo in Nagasaki.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“话说郁子酱是在长崎的一个剑术道馆里出生的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「話說郁子醬是在長崎的一個劍術道館裡出生的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00099",
		linknext = "0031_00101",
		line = 1344,
	},
	["0031_00101"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Before my mind had a moment to catch up, the Legend of Ikky had begun.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我都还没跟上节奏，《上吧郁子传说》就开演了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我都還沒跟上節奏，《上吧郁子傳說》就開演了。",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00100",
		linknext = "0031_00102",
		line = 1354,
	},
	["0031_00102"] = {
		{"bgm", file="bgm14", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0792", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“The dojo focused on a particular type of swordsmanship known as the Onabuta style, which was feared in some circles.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“这是个名为女部田流派的剑道馆，据说女部田流在过去曾独霸一方。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「這是個名為女部田流派的劍道館，據說女部田流在過去曾獨霸一方。」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00101",
		linknext = "0031_00103",
		line = 1367,
	},
	["0031_00103"] = {
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-113-1-1", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"cgact", file="cgact", id=17, act="浮遊横", loop=4, size=5, time=250, ease="easeinout_sine", lv=17, x=-5, y=-2.5},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0793", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子", "パペットイクちゃん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Puppet Iku"},
					"“Hey, but aren’t only boys allowed to learn the ways of the Onabuta style?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子", "傀儡小郁"},
					"“不过说到女部田流，那不是只传男不传女吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子", "傀儡小郁"},
					"「不過說到女部田流，那不是只傳男不傳女嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00102",
		linknext = "0031_00104",
		line = 1384,
	},
	["0031_00104"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She’s actually a talented ventriloquist...",
					{"rt2"},
				},
			},
			cn = {
				{
					"腹语术很纯熟呢⋯⋯",
					{"rt2"},
				},
			},
			tw = {
				{
					"腹語術很純熟呢⋯⋯",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00103",
		linknext = "0031_00105",
		line = 1394,
	},
	["0031_00105"] = {
		{"evset", file="icg02", set="icg02", path=":ev/icg02/"},
		{"evset", file="icg02-111-11", set="icg02-111", path=":ev/icg02-111/"},
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-111-11", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0794", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Wow, so you’ve heard of it! You’re totally right, a cutie pie like little Ikky had no place learning the way of the sword.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“哦，你很清楚呢。没错，郁酱这种超可爱美少女，跟剑术这种东西完全无缘的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「哦，你很清楚呢。沒錯，郁醬這種超可愛美少女，跟劍術這種東西完全無緣的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00104",
		linknext = "0031_00106",
		line = 1413,
	},
	["0031_00106"] = {
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-115-1-1", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0795", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“The Onabuta family line had only ever birthed boys, making it a big surprise when little bundle of joy Ikky was born a girl!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“即使如此，女部田家族是个与姓氏相反、只生得出男孩子的家族，所以突然生出玉酱这个如珠玉一样的孩子──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「即使如此，女部田家族是個與姓氏相反、只生得出男孩子的家族，所以突然生出玉醬這個如珠玉一樣的孩子──」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00105",
		linknext = "0031_00107",
		line = 1429,
	},
	["0031_00107"] = {
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-113-1-1", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"cgact", file="cgact", id=17, act="浮遊横", loop=4, size=5, time=250, ease="easeinout_sine", lv=17, x=-5, y=-2.5},
		{"text"},
		text = {
