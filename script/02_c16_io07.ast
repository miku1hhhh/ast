				},
			},
			tw = {
				{
					name = {"郁子"},
					"「弱小的郁君，感覺自己是從天堂被推下地獄。暴力擊打破碎的心！不斷受到更多的暴力對待！」",
					{"rt2"},
				},
			},
		},
