			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Her once-kind Daddy and Grandpappy had changed, their pampering replaced with strict discipline.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“温柔的爸爸和爷爷像是变了个人，开始严格管教起被溺爱了很久的郁君。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「溫柔的爸爸和爺爺像是變了個人，開始嚴格管教起被溺愛了很久的郁君。」",
					{"rt2"},
				},
			},
