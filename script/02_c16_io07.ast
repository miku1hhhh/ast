			tw = {
				{
					name = {"郁子", "傀儡小郁"},
					"「嬌生慣養！」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00106",
		linknext = "0031_00108",
		line = 1446,
	},
	["0031_00108"] = {
