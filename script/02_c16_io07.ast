					"“Well I knew you’d say no if I came sneaking into your room like this. It’s kind of our routine.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“反正不管怎么样夜袭的话亲爱的你都彻底拒绝就好啦，我们不是这样约定过吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「反正不管怎麼樣夜襲的話親愛的你都徹底拒絕就好啦，我們不是這樣約定過嗎？」",
					{"rt2"},
				},
			},
		},
