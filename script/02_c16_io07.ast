			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Definitely a peculiar way of showing affection...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“还真是独特的宠爱方式呢⋯⋯”",
