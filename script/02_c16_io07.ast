	["0031_00214"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She overpowered me instantly using jiujitsu instead of her sword. Not to mention she’s beaten me in every recent match by pinning me down.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那时她不是用刀，而是使出了柔道技巧在瞬间就将我撂倒了──就算是最近的对练，我也完全敌不过她的技巧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那時她不是用刀，而是使出了柔道技巧在瞬間就將我撂倒了──就算是最近的對練，我也完全敵不過她的技巧。",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00213",
		linknext = "0031_00215",
		line = 3012,
	},
	["0031_00215"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Did you ever think about running away?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯你都没有想过要逃跑吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯妳都沒有想過要逃跑嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00214",
		linknext = "0031_00216",
		line = 3024,
	},
	["0031_00216"] = {
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-115-1-1", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0860", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“You’d think she would, but Iku never felt any resentment towards Daddy and Grandpappy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“一般来说都会这样想的吧。不过呢，郁君从来都没有对爸爸或爷爷怀恨在心过喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「一般來說都會這樣想的吧。不過呢，郁君從來都沒有對爸爸或爺爺懷恨在心過喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00215",
		linknext = "0031_00217",
		line = 3040,
	},
	["0031_00217"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0861", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Besides, still being so young meant that Iku’s world didn’t extend beyond the family hearth. So the concept of running away never even crossed her mind.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“而且，对于还很年幼的郁君来说，家就是整个世界。我从来就没有想过还会有可以逃跑的地方。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「而且，對於還很年幼的郁君來說，家就是整個世界。我從來就沒有想過還會有可以逃跑的地方。」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00216",
		linknext = "0031_00218",
		line = 3052,
	},
	["0031_00218"] = {
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-113-1-1", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"cgact", file="cgact", id=17, act="浮遊横", loop=4, size=5, time=250, ease="easeinout_sine", lv=17, x=-5, y=-2.5},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0862", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子", "パペットイクちゃん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Puppet Iku"},
					"“Tha’ was probably a blessin’ in disguise! Sometimes it’s easier tae be deprived o’ th’ ability tae think!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子", "傀儡小郁"},
					"“某种程度上来说，这可能是不幸中的大幸呢！有时候被夺走了思考能力其实会比较轻松对吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子", "傀儡小郁"},
					"「某種程度上來說，這可能是不幸中的大幸呢！有時候被奪走了思考能力其實會比較輕鬆對吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00217",
		linknext = "0031_00219",
		line = 3069,
	},
	["0031_00219"] = {
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-115-1-1", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0863", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“You may be right. At the same time, there was one reason why Iku trained as hard as she did. She hoped that by training so hard, she would earn that praise and adoration again.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“当时的郁君之所以会努力克服那些严格的训练只有一个原因。‘想要像以前一样被温柔地称赞’这种心情而已。搞不好是因为这样的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「當時的郁君之所以會努力克服那些嚴格的訓練只有一個原因。『想要像以前一樣被溫柔地稱讚』這種心情而已。搞不好是因為這樣的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00218",
		linknext = "0031_00220",
		line = 3085,
	},
	["0031_00220"] = {
		{"cgact", file="cgact", id=18, act="振動下", loop=2, size=-30, time=175, ease="easeinout_sine", lv=18, x=-5, y=-2.5},
		{"se", id=0, loop=0, file="se_a294"},
		{"text"},
		text = {
