	["0031_00170"] = {
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-113-1-1", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"cgact", file="cgact", id=17, act="浮遊横", loop=4, size=5, time=250, ease="easeinout_sine", lv=17, x=-5, y=-2.5},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0831", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子", "パペットイクちゃん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Puppet Iku"},
					"“Rumor has it tha’ the Onabuta style was used fer keepin’ an eye on tha westerners at tha tradin’ port in Nagasaki. I s’ppose they were jus’ followin’ tradition?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子", "傀儡小郁"},
					"“追溯到最开头的话，女部田流派最开始的任务就是监视来到贸易港口长崎的南蛮人。这不就是顺应着时势吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子", "傀儡小郁"},
					"「追溯到最開頭的話，女部田流派最開始的任務就是監視來到貿易港口長崎的南蠻人。這不就是順應著時勢嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00169",
		linknext = "0031_00171",
		line = 2372,
	},
	["0031_00171"] = {
		{"cgdel", id=17, lv=17, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=17, file="icg02-115-1-1", x=-5, y=-2.5, path=":cg/icg02/", lv=17, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0832", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Iku had been told about the rise of the Onabuta style, but there’s no knowing if any of that was really true or not. It may have just been foolish gossip.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“郁君曾经听说过女部田流派的兴起故事，但现在连那是真是假都不知道了。也无法确认那是不是只是个玩笑。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「郁君曾經聽說過女部田流派的興起故事，但現在連那是真是假都不知道了。也無法確認那是不是只是個玩笑。」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00170",
		linknext = "0031_00172",
		line = 2388,
	},
	["0031_00172"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0833", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“In any case, none of that really mattered to Iku at the time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“不过，郁君当时并不在意这种事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「不過，郁君當時並不在意這種事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0031_00171",
