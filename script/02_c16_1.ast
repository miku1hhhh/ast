		{"transitiontime", time=300},
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00222", path=":fg/jun_01f/", id=30, ch="淳之介", lv=9, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hooray!!! ...Wait, you’re so small! And your hair’s short!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“太棒了！！！⋯⋯欸，郁子好小只！！！头发也好短！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「太棒了！！！⋯⋯欸，郁子好小隻！！！頭髮也好短！」",
					{"rt2"},
				},
			},
		},
		linkback = "0029_00051",
		linknext = "0029_00053",
		line = 752,
	},
	["0029_00053"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00211", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0749", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I’m a good bit taller than I was when I first came to the island, though... I barely had any time to sleep at home, but I grew once I came here and got plenty of rest.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“这已经比我刚来岛上的时候高很多了⋯⋯在老家的时候我几乎没有什么睡觉的时间，不过在这边睡得很多所以才长高了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「這已經比我剛來島上的時候高很多了⋯⋯在老家的時候我幾乎沒有什麼睡覺的時間，不過在這邊睡得很多所以才長高了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0029_00052",
		linknext = "0029_00054",
		line = 767,
	},
	["0029_00054"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00214", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
