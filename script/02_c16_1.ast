				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Her expression still looks as composed as ever, even though she’s so small. Kinda creepy, like an adult face on a child’s body...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过那身体那么小，五官却跟现在没有两样，简直就是像在小孩子的身体上贴上大人的脸一样，感觉有点恶心⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過那身體那麼小，五官卻跟現在沒有兩樣，簡直就是像在小孩子的身體上貼上大人的臉一樣，感覺有點噁心⋯⋯」",
					{"rt2"},
				},
			},
		},
