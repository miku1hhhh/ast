			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You even stick your tongue out for photos?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“照片上吐着舌头呢？”",
