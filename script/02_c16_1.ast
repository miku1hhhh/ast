		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0740", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“...And so, as of today, I’d like to start really thinking about a plan to deal with the Armored Hamedori.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“⋯⋯总而言之，我从今天开始会动真格的开始思考‘对付武装Hamedori君的策略’的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「⋯⋯總而言之，我從今天開始會動真格的開始思考『對付武裝Hamedori君的策略』的。」",
					{"rt2"},
				},
			},
		},
