				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Right, doesn’t she?! Miss Touka was so adorable back then, as cute as a doll...! And there was her semi-long hair, and she was wearing a kimono the first time we met...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“对吧对吧？那时候的桐香大人真的就像洋娃娃一样可爱⋯⋯！半长的头发，加上第次见面的时候穿的和服⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「對吧對吧？那時候的桐香大人真的就像洋娃娃一樣可愛⋯⋯！半長的頭髮，加上第次見面的時候穿的和服⋯⋯！」",
					{"rt2"},
				},
			},
		},
