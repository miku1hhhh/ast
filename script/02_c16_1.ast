				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Ikuko’s right... You seemed fine fighting in high places, like at the top of buildings.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“确实⋯⋯在大楼的最顶楼、一些相当高的地方战斗似乎都没什么影响呢你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「確實⋯⋯在大樓的最頂樓、一些相當高的地方戰鬥似乎都沒什麼影響呢你。」",
					{"rt2"},
				},
			},
