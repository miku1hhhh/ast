	["0029_00026"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00203", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0741", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Why are you two acting so unexcited?! Have you just resigned yourself to never beating it?! No thank you, I can’t accept the idea of there being someone stronger than me out there!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“等等你们俩个的士气也太低了吧！？这样真的没问题吗照这下去不就输定了！郁才不要呢我不允许有人比我还强这种事！！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「等等你們倆個的士氣也太低了吧！？這樣真的沒問題嗎照這下去不就輸定了！郁才不要呢我不允許有人比我還強這種事！！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0029_00025",
		linknext = "0029_00027",
		line = 360,
	},
	["0029_00027"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As much as I want to avenge our defeat myself, I don’t know about being woken up at 5 in the morning...",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然一直输下去不是我的风格，但是要早上5点就起来也有点⋯⋯？",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然一直輸下去不是我的風格，但是要早上5點就起來也有點⋯⋯？",
					{"rt2"},
				},
			},
		},
		linkback = "0029_00026",
		linknext = "0029_00028",
		line = 370,
	},
	["0029_00028"] = {
