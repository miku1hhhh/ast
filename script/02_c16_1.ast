					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Female Student A"},
					"“And she’s even with His Sexellency...! What a beautiful picture the two make together... Almost like the perfect fuck-couple!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "女学生A"},
					"“而且连‘性帝’也在⋯⋯！您们两位并排站在一起果然就像画一样呢⋯⋯简直就像是一对绝佳干侣⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "女學生A"},
					"「而且連『性帝』也在⋯⋯！您們兩位並排站在一起果然就像畫一樣呢⋯⋯簡直就像是一對絕佳幹侶⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0029_00099",
		linknext = "0029_00101",
		line = 1396,
	},
	["0029_00101"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00201", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
