	["0029_00037"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file3="ikuko_01m_00301", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0744", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“The first step to winning a battle as a team is learning each other’s strengths! So if you’ll let me ask a basic question, how do you gauge your distance to your enemies, Darling?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“要在团体战获胜的第一件事情就是要先了解同伴们的程度！虽然是像这种基础的问题，不过亲爱的你到底都是怎么抓跟对手之间的距离的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「要在團體戰獲勝的第一件事情就是要先了解同伴們的程度！雖然是像這種基礎的問題，不過親愛的你到底都是怎麼抓跟對手之間的距離的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0029_00036",
		linknext = "0029_00038",
		line = 515,
	},
	["0029_00038"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00218", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well... By steps, I guess?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我吗⋯⋯靠算步数？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我嗎⋯⋯靠算步數？」",
					{"rt2"},
				},
			},
		},
		linkback = "0029_00037",
		linknext = "0029_00039",
		line = 527,
	},
	["0029_00039"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I often think about how many steps it’ll be to an opponent... I think.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我总会思考自己离对手到底还有几步的差距⋯⋯大概是这种感觉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我總會思考自己離對手到底還有幾步的差距⋯⋯大概是這種感覺。",
					{"rt2"},
				},
			},
		},
		linkback = "0029_00038",
		linknext = "0029_00040",
		line = 537,
	},
	["0029_00040"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00202", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="郁子10", id=10, act="振動下", loop=1, size=27.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0745", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Huh! That’s pretty good. It’s hard to translate numbers into reality, so it’s hard for some people to see them as anything more than simple numbers.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“哇喔！挺不错的嘛。因为数字这种东西没有与实感连结的证据，所以某些人来说数字就只会是纯粹的‘数字’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「哇喔！挺不錯的嘛。因為數字這種東西沒有與實感連結的證據，所以某些人來說數字就只會是純粹的『數字』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0029_00039",
		linknext = "0029_00041",
		line = 553,
	},
	["0029_00041"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00219", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But I guess using something concrete like steps makes it easier to accurately judge distance... I see...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但变成‘步数’这类具体的识别，就能更容易地做出正确的判断⋯⋯原来如此。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但變成『步數』這類具體的識別，就能更容易地做出正確的判斷⋯⋯原來如此。」",
					{"rt2"},
				},
			},
		},
		linkback = "0029_00040",
		linknext = "0029_00042",
		line = 565,
	},
	["0029_00042"] = {
