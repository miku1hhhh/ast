			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Okay, that’s pretty good too. Using a practical measure for height can just make things feel scarier. It’s better to use simple numbers here, I guess.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嗯嗯。这也不错。如果具体感受到高度的话，就会加强对高度的恐惧感。所以要反过来，把高度当作单纯的数字来看。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嗯嗯。這也不錯。如果具體感受到高度的話，就會加強對高度的恐懼感。所以要反過來，把高度當作單純的數字來看。」",
					{"rt2"},
				},
			},
		},
