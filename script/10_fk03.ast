		linkback = "0110_00157",
		linknext = "0110_00159",
		line = 2232,
	},
	["0110_00159"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The doctor said I’m getting better, so you don’t have to insist on stuff like carrying bags. And don’t say it’s because you’re a servant either.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“医生也说最近有好转了⋯⋯不要再说自己是仆人就要都自己来拿了喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「醫生也說最近有好轉了⋯⋯不要再說自己是僕人就要都自己來拿了喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00158",
		linknext = "0110_00160",
		line = 2244,
	},
	["0110_00160"] = {
