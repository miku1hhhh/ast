	["0110_00361"] = {
		{"bgm", file="bgm08", vol=100},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00104", file2="fumino_01m_00228", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0538", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“How about sitting me on a triangular wooden horse, putting a ball gag in my mouth so I can’t scream, and scolding me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“那让她一边坐上三角木马然后戴上防叫嘴套，沉浸在文乃的斥责之中呢⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「那讓她一邊坐上三角木馬然後戴上防叫嘴套，沈浸在文乃的斥責之中呢⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00360",
		linknext = "0110_00362",
		line = 5270,
	},
	["0110_00362"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00208", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
