	},
	["0110_00233"] = {
		{"fg", file="asane_01m_00003", file1="asane_01m_00101", file2="asane_01m_00221", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1523", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“No way! I hate cats! They’re such obnoxious free spirits, getting annoyed when you pay attention to them but acting lonely when they’re ignored! Such selfish creatures!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不要啦！麻沙酱不喜欢猫！自由自在，逗它又不理人，不理它又觉得寂寞的任性生物⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不要啦！麻沙醬不喜歡貓！自由自在，逗牠又不理人，不理牠又覺得寂寞的任性生物⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00232",
		linknext = "0110_00234",
		line = 3335,
	},
	["0110_00234"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
