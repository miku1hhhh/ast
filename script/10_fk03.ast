			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“It was a shock to see bags of garlic for just 60 yen. How about baking some in foil for tonight?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“蒜头一袋60元真的吓到了呢⋯⋯今晚就来烤蒜头吃如何？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「蒜頭一袋60元真的嚇到了呢⋯⋯今晚就來烤蒜頭吃如何？」",
					{"rt2"},
				},
			},
		},
