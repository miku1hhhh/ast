			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That’s right, she’s our Tama-Tama from now on. We’ll correct and discipline her together.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊，今后是我们俩个的蛋蛋了。”",
