				},
			},
			tw = {
				{
					name = {"文乃"},
					"「貓咪上廁所會受到壓抑的情感所影響⋯⋯不能只對她兇，和她玩耍也會有幫助⋯⋯原來原來⋯⋯」",
					{"rt2"},
				},
			},
		},
