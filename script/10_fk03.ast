			en = {
				{
					name = {"文乃", "Fumino"},
					"“I’ll take care of everything until then, even training it so it won’t cause any trouble! So please, I beg you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“找到主人领养之前我会负责照顾的，也会教它学乖，不会添任何一个麻烦的⋯⋯！所以，拜托，拜托了⋯⋯！”",
