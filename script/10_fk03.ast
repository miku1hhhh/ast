	["0110_00349"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Let’s work together to teach her where to do her business. Oh, and I’ll get Asa to help too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们一起让蛋蛋记住上厕所的地方吧。啊，也让麻沙酱一起帮忙。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們一起讓蛋蛋記住上廁所的地方吧。啊，也讓麻沙醬一起幫忙。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00348",
		linknext = "0110_00350",
		line = 5095,
	},
	["0110_00350"] = {
