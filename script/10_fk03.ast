	},
	["0110_00245"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The kitten is already purring though, and seems to like people.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过，已经发出呼噜声的话，这只小孩还蛮亲人的嘛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過，已經發出呼嚕聲的話，這隻小孩還蠻親人的嘛。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00244",
		linknext = "0110_00246",
		line = 3497,
	},
	["0110_00246"] = {
		{"fg", file="asane_02m_00003", file1="asane_02m_00101", file3="asane_02m_00301", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1527", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“No means no! We’ve just gotten a new little sister around like that’s a totally normal thing to happen. Any more mouths to feed and we’ll break our food budget!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不要，不可以！我们家都已经多了一个妹妹了，再继续增加要吃饭的生物的话，我们会破产的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不要，不可以！我們家都已經多了一個妹妹了，再繼續增加要吃飯的生物的話，我們會破產的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00245",
		linknext = "0110_00247",
		line = 3513,
	},
	["0110_00247"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file2="fumino_01m_00227", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="文乃7", id=7, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0507", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I shall handle that! If we’re short on food, then... I won’t need meals! Just please, please let us keep it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我会想办法的⋯⋯！不够的话我可以不吃⋯⋯！真的，真的拜托了⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我會想辦法的⋯⋯！不夠的話我可以不吃⋯⋯！真的，真的拜託了⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00246",
		linknext = "0110_00248",
		line = 3529,
	},
	["0110_00248"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", file="asane_02m_00003", file1="asane_02m_00101", file2="asane_02m_00221", file4="asane_02m_00402", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1528", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Shut up! If there’s a cat here too, Bro will pay even less attention to me! You expect me to just accept him being stolen away, first by you and now by a cat too?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“喵可呜了！要是有猫在的话，哥哥对我的疼爱就会越来越少，都已经被文乃占去了，现在连猫都要来抢吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「喵可嗚了！要是有貓在的話，哥哥對我的疼愛就會越來越少，都已經被文乃佔去了，現在連貓都要來搶嗎！」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00247",
		linknext = "0110_00249",
		line = 3546,
	},
	["0110_00249"] = {
