	["0110_00324"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00102", file2="fumino_01m_00217", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="文乃7", id=7, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0523", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Tama-Tama! How could you do something so vile on my master’s bed?! Is this how you pay us back for taking you in?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“蛋蛋！你在主人的棉被上做了什么好事⋯⋯！？捡了你还这样，这是在恩将仇报吗⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「蛋蛋！妳在主人的棉被上做了什麼好事⋯⋯！？撿了妳還這樣，這是在恩將仇報嗎⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00323",
		linknext = "0110_00325",
		line = 4759,
	},
	["0110_00325"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00102", file2="fumino_01m_00203", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
