				{"vo", file="fumino0481", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I’ve never had to tackle such a... complicated feeling before, so it’s hard for me to explain what’s going on in my head.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我、我也是第一次有这种心情，我也不知道该怎么说明才好⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我、我也是第一次有這種心情，我也不知道該怎麼說明才好⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00115",
		linknext = "0110_00117",
		line = 1692,
	},
	["0110_00117"] = {
		{"fg", file="fumino_02l_00001", file1="fumino_02l_00104", file2="fumino_02l_00203", path=":fg/fumino_02l/", id=7, lv=7, head="fumino_02l", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="文乃7", id=7, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After an unusual groan as if she’s at her wits’ end, Fumino turns to me with clenched fists in a fighting pose.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃难得的抱着头念念有词，然后一副我要加油的样子转向我这边。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃難得的抱著頭念念有詞，然後一副我要加油的樣子轉向我這邊。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00116",
		linknext = "0110_00118",
		line = 1706,
	},
	["0110_00118"] = {
		{"fg", file="fumino_02l_00001", file1="fumino_02l_00104", file2="fumino_02l_00204", path=":fg/fumino_02l/", id=7, lv=7, head="fumino_02l", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0482", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Do imagine this. It’s parent’s classroom observation day and my dad’s frolicking around without a care. And the entire world is watching him!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“教学参观日不在乎旁人眼光的父亲，被全世界的人看着的那种感觉⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「教學參觀日不在乎旁人眼光的父親，被全世界的人看著的那種感覺⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00117",
		linknext = "0110_00119",
		line = 1721,
	},
	["0110_00119"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00104", file2="jun_01f_00205", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wow, just hearing that makes me cringe too...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哇啊，这下连我都觉得令人难为情了⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哇啊，這下連我都覺得令人難為情了⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00118",
		linknext = "0110_00120",
		line = 1733,
	},
	["0110_00120"] = {
