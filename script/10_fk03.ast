			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Cut the crap. Aren’t you the one who told me that if you have sex and ejaculate from the heart, you will have nothing left to be proud of?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不要找借口，哥不是说射在心里的话就没了骄傲不是吗⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不要找藉口，哥不是說射在心裡的話就沒了驕傲不是嗎⋯⋯」",
					{"rt2"},
				},
			},
		},
