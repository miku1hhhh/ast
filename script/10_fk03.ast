	["0110_00414"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When she suddenly becomes super serious even after something like that, it does get a little confusing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"突然摆出平常的那副认真模样，这个反差让我有点摸不着头绪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"突然擺出平常的那副認真模樣，這個反差讓我有點摸不著頭緒。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00413",
		linknext = "0110_00415",
		line = 5924,
	},
	["0110_00415"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Even so, as your boyfriend, I’m not sure how I feel about doing things that hurt you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“身为恋人却做出让文乃感到痛的举动⋯⋯这⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「身為戀人卻做出讓文乃感到痛的舉動⋯⋯這⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00414",
		linknext = "0110_00416",
		line = 5935,
	},
	["0110_00416"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0551", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“If it doesn’t hurt, it’s not a punishment. Think nothing of it and keep tightening the rope and making me moan...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“不痛就不是处罚了⋯⋯请不要在意，就将文乃五花大绑让我发出淫荡的娇喊吧⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「不痛就不是處罰了⋯⋯請不要在意，就將文乃五花大綁讓我發出淫蕩的嬌喊吧⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00415",
		linknext = "0110_00417",
		line = 5947,
	},
	["0110_00417"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It seems like an odd thing for someone tied up to be asking for.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这不像是身体被绑着的人会说出的话啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這不像是身體被綁著的人會說出的話啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00416",
		linknext = "0110_00418",
		line = 5957,
	},
	["0110_00418"] = {
