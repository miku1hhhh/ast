	["0110_00204"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00102", file2="misaki_01m_00209", path=":fg/misaki_01m/", id=6, lv=6, head="misaki_01m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1281", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“W-What the...?! She’s tamed someone else’s dog...?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“竟然⋯⋯！在喂养别人家养的狗⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「竟然⋯⋯！在餵養別人家養的狗⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00203",
		linknext = "0110_00205",
		line = 2879,
	},
	["0110_00205"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Perhaps they’re on the same wavelength since they’re both wild beasts...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“应该是因为都是兽类才会和吧⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「應該是因為都是獸類才會和吧⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00204",
		linknext = "0110_00206",
		line = 2891,
	},
	["0110_00206"] = {
		{"fg", file="hinami_01m_00002", file1="hinami_01m_00101", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0983", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I don’t get the chance to look at animals much, so getting a glimpse up close like this is new.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我不太常看到动物，像这般靠近的看感觉很新鲜哪。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我不太常看到動物，像這般靠近的看感覺很新鮮哪。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00205",
		linknext = "0110_00207",
		line = 2906,
	},
	["0110_00207"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00223", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That reminds me, there really aren’t many pets at all on this island. You never see strays around either.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“话说回来，这个岛上的宠物异常的少耶⋯⋯也没看到流浪猫。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「話說回來，這個島上的寵物異常的少耶⋯⋯也沒看到流浪貓。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00206",
		linknext = "0110_00208",
		line = 2918,
	},
	["0110_00208"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00101", file2="misaki_01m_00204", path=":fg/misaki_01m/", id=6, lv=6, head="misaki_01m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1282", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“That’s because they try hard to keep animals out of here. Especially cats, since they can breed so quickly.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“是因为这座岛很积极的不收受动物喔。像猫一不管就会马上倍增呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「是因為這座島很積極的不收受動物喔。像貓一不管就會馬上倍增呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00207",
		linknext = "0110_00209",
		line = 2933,
	},
	["0110_00209"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00203", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“They just need to make sure they’re neutered like this dog then, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就像那只狗被阉掉蛋蛋不就好了⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就像那隻狗被閹掉蛋蛋不就好了⋯⋯？」",
