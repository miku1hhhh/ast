			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Shake... sit... cock... No, that’s not right, it doesn’t mean to stick out your butt where you’ve been neutered. Yeah, that’s a good boy... There, there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“手手⋯⋯坐下⋯⋯鸡鸡⋯⋯不对，鸡鸡，不是露出蛋蛋被阉掉的屁股啦⋯⋯对，乖孩子⋯⋯喔，好乖好乖⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「手手⋯⋯坐下⋯⋯雞雞⋯⋯不對，雞雞，不是露出蛋蛋被閹掉的屁股啦⋯⋯對，乖孩子⋯⋯喔，好乖好乖⋯⋯」",
					{"rt2"},
				},
			},
		},
