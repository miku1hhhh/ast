	["0110_00038"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00211", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Listen to me, Asa. Think about it. Originally, sex was for having children with someone you love.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“听好了，麻沙酱。你仔细想想。所谓性爱，原本就是为了和爱的人制造小孩的行为。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「聽好了，麻沙醬。妳仔細想想。所謂性愛，原本就是為了和愛的人製造小孩的行為。」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00037",
		linknext = "0110_00039",
		line = 562,
	},
	["0110_00039"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00203", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It’s true that I’m no longer a virgin. However, I’m not just engaging in lewd acts for the sake of it. I want to make a baby with Fumino. That’s why I still have my pride.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“的确我已经不是处男了⋯⋯但是并不是因为好色而做，是因为要生小孩要确认爱才做，所以我的骄傲没有不见。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「的確我已經不是處男了⋯⋯但是並不是因為好色而做，是因為要生小孩要確認愛才做，所以我的驕傲沒有不見。」",
					{"rt2"},
				},
			},
		},
