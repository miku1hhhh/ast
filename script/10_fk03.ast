	["0110_00156"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In our recent battle, I injured my left shoulder.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我因为之前的战役而坏了左边肩膀。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我因為之前的戰役而壞了左邊肩膀。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00155",
		linknext = "0110_00157",
		line = 2212,
	},
	["0110_00157"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Although I’ve recovered enough that it doesn’t affect my daily life any more, I still have to hold off on strenuous exercise like jerking off.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不会影响到日常生活，但是像自慰等稍微激烈地运动就要克制。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不會影響到日常生活，但是像自慰等稍微激烈地運動就要克制。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00156",
		linknext = "0110_00158",
		line = 2222,
	},
	["0110_00158"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’m still getting treatment at the hospital for this injury.",
					{"rt2"},
				},
			},
			cn = {
				{
					"到现在还为此回诊追踪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"到現在還為此回診追蹤。",
					{"rt2"},
