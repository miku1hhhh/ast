			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“It’s so little it’s probably still drinking its mother’s milk. What happened to you? Did you get separated from your mom?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“看起来还在喝奶⋯⋯你怎么了呀⋯⋯？和妈妈走散了吗⋯⋯？”",
