			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Love you, Bro. Truth is, I got caught wall hacking and people were teasing me saying I must be a virgin. That got me depressed, but I’m not alone after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“好喜欢哥哥，穿墙之术破功，结果因为被说‘你是处女吧’而沮丧的我，不是一个人呢。嗷呜。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「好喜歡哥哥，穿牆之術破功，結果因為被說『妳是處女吧』而沮喪的我，不是一個人呢。嗷嗚。」",
					{"rt2"},
				},
			},
		},
