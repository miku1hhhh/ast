	["0110_00035"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But with Fumino, the woman I love, I have indeed experienced that manner of ejaculation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可是我却和我爱的人文乃结合，体验了什么叫射在心里。",
