					"“Tama-Tama is kindly requesting your permission to stay as well!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“蛋蛋也说想要打扰我们⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「蛋蛋也說想要打擾我們⋯⋯！」",
					{"rt2"},
				},
			},
		},
