		line = 510,
	},
	["0110_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As long as you don’t ejaculate from the heart, you remain a proud virgin.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不射在心里的话，就会一直是最高荣耀的处男。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不射在心裡的話，就會一直是最高榮耀的處男。",
