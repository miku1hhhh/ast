				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Let’s see... Things like suppressed emotions can have an impact on the cat’s toilet habits... It’s important to play with them too even if you get mad... Indubitably!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“猫咪上厕所会受到压抑的情感所影响⋯⋯不能只对她凶，和她玩耍也会有帮助⋯⋯原来原来⋯⋯”",
