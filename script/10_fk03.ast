	["0110_00652"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file3="fumino_01m_00302", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="文乃7", id=7, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0622", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Tama-Tama loves to bite my feet while kicking like crazy with her back legs. Such an incorrigible creature!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“蛋蛋很喜欢一边咬我的脚一边用她的后脚踢呀踢的⋯⋯真是拿她没办法⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「蛋蛋很喜歡一邊咬我的腳一邊用她的後腳踢呀踢的⋯⋯真是拿她沒辦法⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00651",
		linknext = "0110_00653",
		line = 9017,
	},
	["0110_00653"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Yeah, I’m gonna go a mile and say it’s not working too well for Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"⋯⋯果然好像没什么进展。",
					{"rt2"},
				},
			},
			tw = {
				{
					"⋯⋯果然好像沒什麼進展。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00652",
		linknext = "0110_00654",
		line = 9027,
	},
	["0110_00654"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But Fumino looks pleased anyway. Perhaps there’s some inherent joy in taking care of a difficult child.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过越是爱惹麻烦的孩子越可爱，文乃一脸满足样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過越是愛惹麻煩的孩子越可愛，文乃一臉滿足樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00653",
		linknext = "0110_00655",
		line = 9037,
	},
	["0110_00655"] = {
