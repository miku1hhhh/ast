	["0110_00242"] = {
		{"fg", file="asane_02m_00003", file1="asane_02m_00102", file2="asane_02m_00214", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1526", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Oh, why have you named it already? And what the heck kind of name is that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“怎么已经有名字了啊⋯⋯还有你取得那是什么名字啊⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「怎麼已經有名字了啊⋯⋯還有妳取得那是什麼名字啊⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00241",
		linknext = "0110_00243",
		line = 3462,
	},
	["0110_00243"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file2="fumino_01m_00219", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0506", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“This kitten is cute like a ball and Tama is a common name for cats, so I named her Tama-Tama.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“像蛋一样可爱，加上一般猫咪不都会用这名字吗，所以加起来就是蛋蛋了⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「像蛋一樣可愛，加上一般貓咪不都會用這名字嗎，所以加起來就是蛋蛋了⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00242",
		linknext = "0110_00244",
		line = 3477,
	},
	["0110_00244"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino really doesn’t have a good sense for names.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃看起来没什么取名字的天份啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃看起來沒什麼取名字的天份啊。",
					{"rt2"},
				},
