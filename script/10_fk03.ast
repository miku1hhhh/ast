	["0110_00210"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00102", file2="misaki_01m_00222", path=":fg/misaki_01m/", id=6, lv=6, head="misaki_01m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1283", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I object! How can we limit animals’ right to procreate when humans are free to have all the sex they want?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“怎么这样⋯⋯！人类在自由的交配的时候，却只有动物的交配受到限制吗⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「怎麼這樣⋯⋯！人類在自由的交配的時候，卻只有動物的交配受到限制嗎⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00209",
		linknext = "0110_00211",
		line = 2960,
	},
	["0110_00211"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
		{"text"},
