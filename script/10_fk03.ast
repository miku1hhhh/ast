					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Next, let’s play tag. Run away from me now or I’ll catch you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“接下来就玩鬼抓人游戏吧⋯⋯！不逃走的话会被我抓住喔⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「接下來就玩鬼抓人遊戲吧⋯⋯！不逃走的話會被我抓住喔⋯⋯」",
					{"rt2"},
				},
