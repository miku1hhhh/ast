					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“If it were on my bed, that would be one thing, but doing this to my dear Junnosuke is completely unacceptable! You will repent!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“如果是对我就算了，我不允许你对淳之介这么做⋯⋯！给我好好反省⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「如果是對我就算了，我不允許妳對淳之介這麼做⋯⋯！給我好好反省⋯⋯！」",
					{"rt2"},
				},
			},
		},
