	["0110_00255"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00206", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
