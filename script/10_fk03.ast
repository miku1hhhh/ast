		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0982", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Hey, Tachibana, look! There’s a huge dog over there!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，橘君快看！那边有只大狗狗耶！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，橘君快看！那邊有隻大狗狗耶！」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00200",
		linknext = "0110_00202",
		line = 2829,
	},
	["0110_00202"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That dog lives in the neighborhood. It’s quite ferocious, but for some reason it seems to have taken a liking to Asa...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那只狗是附近邻居养的，蛮凶的喔。不过不知为何倒很亲麻沙酱⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那隻狗是附近鄰居養的，蠻兇的喔。不過不知為何倒很親麻沙醬⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0110_00201",
		linknext = "0110_00203",
		line = 2841,
	},
	["0110_00203"] = {
