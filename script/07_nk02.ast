	["0091_00178"] = {
		{"cgdel", id=2, lv=2, time=0, alphadel=1},
		{"fg", mode=-1, id=4, ch="奈々瀬4", ch_origin="奈々瀬", lv=4, time=0, sync=0},
		{"bg", id=1, file="bg16_1_00000", x=0, y=0, lv=1, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", file2="misaki_01m_00222", path=":fg/misaki_01m/", id=6, lv=6, head="misaki_01m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0427", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“How are you so surprised? Isn’t it obvious? That’s just who you are at your core. Baaad Boooy Makeeer!!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“你为什么要用可爱的声音惊呀！这不是理所当然的吗？你完全就是这种人啦、软烂男·制造机～！！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「妳為什麼要用可愛的聲音驚呀！這不是理所當然的嗎？妳完全就是這種人啦、軟爛男·製造機～！！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00177",
		linknext = "0091_00179",
		line = 2928,
	},
	["0091_00179"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00102", file2="nanase_02m_00214", path=":fg/nanase_02m/", id=4, lv=4, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="奈々瀬4", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0561", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ugh. My friends have been saying that about me for years! ‘You never pick the nice guys’ this and ‘You’re the kind of girl that attracts weirdos’ that!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“⋯⋯唔⋯⋯不知道为什么从以前开始朋友们就时常跟我这样说⋯⋯！‘你好像都喜欢烂男人’或者‘你绝对是会喜欢上怪男人的女人啊’之类的⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「⋯⋯唔⋯⋯不知道為什麼從以前開始朋友們就時常跟我這樣說⋯⋯！『妳好像都喜歡爛男人』或者『妳絕對是會喜歡上怪男人的女人啊』之類的⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00178",
		linknext = "0091_00180",
		line = 2943,
	},
	["0091_00180"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00212", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-605, y=-5},
