				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過，真是抱歉啊⋯⋯老是給你⋯⋯嚼嚼⋯⋯添麻煩了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00040",
