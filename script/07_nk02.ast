			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don’t want that! Listen, you’ve got it wrong. Just, look at the nape of her neck and you’ll understand. Go on, look!!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我才不是油腔滑调！我真的不是这个意思！！我想说的是奈奈濑的魅力只要靠看她的后颈就能完全明白了啦！！你们看──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我才不是油腔滑調！我真的不是這個意思！！我想說的是奈奈瀨的魅力只要靠看她的後頸就能完全明白了啦！！妳們看──！」",
					{"rt2"},
				},
			},
		},
