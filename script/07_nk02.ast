			[5999] = {
				{"transitiontime", time=300, timestamp=90, delay2=6000},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0563", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“B-But I always try to make lovey-dovey meals, like desserts and... Oh, right. I even brought some with me today.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不、不过我有尝试把料理做得比较有恋人的感觉，像是甜点之类的⋯⋯啊、说到甜点，我想说跟你们聊的时候可以配着吃所以我有带些点心来喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不、不過我有嘗試把料理做得比較有戀人的感覺，像是甜點之類的⋯⋯啊、說到甜點，我想說跟你們聊的時候可以配著吃所以我有帶些點心來喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00184",
		linknext = "0091_00186",
		line = 3056,
	},
	["0091_00186"] = {
		{"fg", mode=-1, id=6, ch="美岬6", ch_origin="美岬", lv=6, time=0, sync=0},
		{"fg", file="rei_01m_00001", file1="rei_01m_00102", file2="rei_01m_00209", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2027", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Desserts...? You mean this giant bucket of caramel pudding and the Tupperware filled with almond jelly?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“点心⋯⋯这么大的桶装布丁、还有用大桶子做的杏仁豆腐吗⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「點心⋯⋯這麼大的桶裝布丁、還有用大桶子做的杏仁豆腐嗎⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00185",
		linknext = "0091_00187",
		line = 3072,
	},
	["0091_00187"] = {
		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00102", file2="ikuko_02m_00206", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2071", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Don’t get me wrong, they look delicious, but these are the kinds of things a mother would make a child. Couples would probably enjoy making something more... I dunno, cool?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“你看吧，虽然说看起来是很好吃，但是看起来就像是妈妈会做的东西啊，是情侣的话应该要做一些更能让同年纪的人喜欢的点心吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「妳看吧，雖然說看起來是很好吃，但是看起來就像是媽媽會做的東西啊，是情侶的話應該要做一些更能讓同年紀的人喜歡的點心吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00186",
		linknext = "0091_00188",
		line = 3086,
	},
