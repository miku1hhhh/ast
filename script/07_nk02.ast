	["0091_00221"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00209", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wait, is that some kind of sex position?! Nanase’s got some meat on her bones... I’m not sure I could lift her that high!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么、你是说体位吗⋯⋯！？不过奈奈濑挺有肉的，没有那么轻喔！？”",
