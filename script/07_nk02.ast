		},
		linkback = "0091_00087",
		linknext = "0091_00089",
		line = 1358,
	},
	["0091_00089"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But it’s been nearly half a year now since we started seeing each other.",
					{"rt2"},
