				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“She didn’t seem bothered by that in the least. She really has turned him into a momma’s boy, hasn’t she?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不用怀意，要是你在这样下去，你完全就是个会制造出软烂男的妈妈喔？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不用懷意，要是妳在這樣下去，妳完全就是個會製造出軟爛男的媽媽喔？」",
					{"rt2"},
				},
			},
		},
