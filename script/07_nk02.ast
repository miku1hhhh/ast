			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, hold on! I’ve always had a thing for faces like his! And I looove the way his jaw has gotten sharper as he’s gotten older!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“可是！那张脸从以前就一直是我喜欢的型啊⋯⋯！虽然长大之后下巴变尖了一点，但我还是非～常～的喜欢⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「可是！那張臉從以前就一直是我喜歡的型啊⋯⋯！雖然長大之後下巴變尖了一點，但我還是非～常～的喜歡⋯⋯！」",
					{"rt2"},
				},
			},
		},
