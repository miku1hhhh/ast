				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼、妳是說體位嗎⋯⋯！？不過奈奈瀨挺有肉的，沒有那麼輕喔！？」",
					{"rt2"},
				},
			},
		},
