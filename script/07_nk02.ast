			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Oh, no kidding. There’s nothing to be gained by turning into his mom and constantly picking up after him...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你要是成为一个不管做了什么都是理所当然的妈妈的话，对方就会连感谢都不会有喔⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「妳要是成為一個不管做了什麼都是理所當然的媽媽的話，對方就會連感謝都不會有喔⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00181",
		linknext = "0091_00183",
		line = 2992,
	},
