				{"vo", file="tohka1789", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You’ve always been the type of girl to devote themselves to other people. That’s the kind of sweetheart I would love to have for myself one day♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“奈奈濑同学就是典型的任男人与取予求的类型呢⋯⋯我就想要让这种女人抢走我的爱人啊⋯⋯♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「奈奈瀨同學就是典型的任男人與取予求的類型呢⋯⋯我就想要讓這種女人搶走我的愛人啊⋯⋯♪」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00179",
		linknext = "0091_00181",
		line = 2960,
	},
	["0091_00181"] = {
		{"fg", mode=-1, id=6, ch="美岬6", ch_origin="美岬", lv=6, time=0, sync=0},
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00204", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2070", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“By the way, Nanase. Remember, it’s okay for him to call you Mommy when you let him. But if he starts calling you Mom then you’re too far gone.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“奈奈濑同学你知道吗？“妈妈”只有在玩婴儿Play的时候才可以当喔。在平常就当“妈妈”是不行的啦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「奈奈瀨同學妳知道嗎？「媽媽」只有在玩嬰兒Play的時候才可以當喔。在平常就當「媽媽」是不行的啦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00180",
		linknext = "0091_00182",
		line = 2976,
	},
	["0091_00182"] = {
		{"fg", mode=-1, id=8, ch="桐香8", ch_origin="桐香", lv=8, time=0, sync=0},
		{"fg", file="rei_02m_00001", file1="rei_02m_00102", file2="rei_02m_00224", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
