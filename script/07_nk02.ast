		{"transitiontime", time=300},
		{"fgact", ch="ヒナミ5", id=5, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0359", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Where the heck do you ge-get off?! You can’t just say something like that and expect her to stay at your side like you deserve it without her snapping!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“你看他马上就说出这种话来了。连说出这种话你都还能待在他身边，当然也会当作理所当然啊。这样总有一天他会对你做出很过分的事情来的喔？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「妳看他馬上就說出這種話來了。連說出這種話妳都還能待在他身邊，當然也會當作理所當然啊。這樣總有一天他會對妳做出很過分的事情來的喔？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00221",
		linknext = "0091_00223",
		line = 3667,
	},
	["0091_00223"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00208", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“B-But I don’t think I deserve it! I’m so grateful to Nanase! I love her with everything I am!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我才没有觉得理所当然呢⋯⋯！我一直都很感谢奈奈濑，而且从心底就爱着她耶！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我才沒有覺得理所當然呢⋯⋯！我一直都很感謝奈奈瀨，而且從心底就愛著她耶！」",
					{"rt2"},
				},
			},
		},
