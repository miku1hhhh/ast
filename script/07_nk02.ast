	["0091_00092"] = {
		{"se", id=0, loop=0, file="se_a313b"},
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You said you needed to go to the store, right? My muscles are available if you need a hand with anything heavy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你今天不是要去买东西吗？东西不是很重吗，让我的肌肉来帮忙吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你今天不是要去買東西嗎？東西不是很重嗎，讓我的肌肉來幫忙吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00091",
		linknext = "0091_00093",
		line = 1401,
	},
	["0091_00093"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", file5="nanase_01m_00511", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0538", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Oh, really? Thank you, muscles, that’d be a big help. I was thinking about stocking up on water. Why don’t we call Asa and all go together?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“啊、真的吗？太感谢你的肌肉帮忙了。我正想说要去买水呢，那我叫上麻沙酱，我们三个人一起去吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「啊、真的嗎？太感謝你的肌肉幫忙了。我正想說要去買水呢，那我叫上麻沙醬，我們三個人一起去吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00092",
		linknext = "0091_00094",
		line = 1416,
	},
	["0091_00094"] = {
