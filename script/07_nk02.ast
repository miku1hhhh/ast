				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You knocked it out of the park again, Nanase. Pectoralis Major (Ducky) is very happy!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真不愧是奈奈濑做的料理⋯⋯连大兄(大胸肌)都很开心呢。”",
