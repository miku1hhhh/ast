	["0091_00099"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00102", file2="rei_01m_00217", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2014", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Never mind whether it’s weird or not. Why are you bringing it up now?! We’re in the student council room... enemy turf, remember?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“先不要管糟糕不糟糕什么的⋯⋯你为什么会在这边跟我说这种话啊⋯⋯！？这里可是学生会办公室欸，而且我们两个可是敌对关系喔！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「先不要管糟糕不糟糕什麼的⋯⋯妳為什麼會在這邊跟我說這種話啊⋯⋯！？這裡可是學生會辦公室欸，而且我們兩個可是敵對關係喔！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00098",
		linknext = "0091_00100",
		line = 1534,
	},
	["0091_00100"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", file2="misaki_01m_00222", path=":fg/misaki_01m/", id=6, lv=6, head="misaki_01m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="美岬6", id=6, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0415", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Well, when else was I supposed to bring it up?! We can’t get into our own base, so this was the only place left where we could talk in private!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我也没办法嘛！！我们的基地现在已经不能再去了，要讲秘密的话就只能来这里了啊！！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我也沒辦法嘛！！我們的基地現在已經不能再去了，要講秘密的話就只能來這裡了啊！！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00099",
		linknext = "0091_00101",
		line = 1550,
	},
	["0091_00101"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00102", file2="rei_02m_00223", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
