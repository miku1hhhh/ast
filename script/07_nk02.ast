					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Look, I’m only here because I heard there was going to be some fun girl talk, sooo...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我们是因为听说这里是专属于女孩子们才能好好聊天的地方才来的啦⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我們是因為聽說這裡是專屬於女孩子們才能好好聊天的地方才來的啦⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00115",
		linknext = "0091_00117",
		line = 1855,
	},
	["0091_00117"] = {
