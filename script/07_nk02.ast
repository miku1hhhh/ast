				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I’m sorry to keep... chomp champ... making you go out of your way to make us... champ chomp... such delicious meals all the time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过，真是抱歉啊⋯⋯老是给你⋯⋯嚼嚼⋯⋯添麻烦了。”",
