			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Whoa, he wasn’t kidding. It’s so beautifully pale you wanna lick it up like vanilla ice cream but it’s a symbol of her meticulous nature and... hrrrng... I wanna dip cold noodles into her sweat on a hot daaay...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哇喔太色了吧，那个不经意露出来的后颈，是那种有好好保养才会有的雪白色，完全就把那种一丝不苟的个性显现出来了啊，而且那个流出来的汗个跟本就超越暑气地让人感到全身燥热了⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哇喔太色了吧，那個不經意露出來的後頸，是那種有好好保養才會有的雪白色，完全就把那種一絲不苟的個性顯現出來了啊，而且那個流出來的汗個跟本就超越暑氣地讓人感到全身燥熱了⋯⋯！」",
					{"rt2"},
				},
			},
		},
