				},
			},
			cn = {
				{
					name = {"郁子"},
					"“是男人都会这么说。除了像奈奈濑酱这种被无理要求也不会拒绝的好对付的女人以外，是骗不了其他人的呦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「是男人都會這麼說。除了像奈奈瀨醬這種被無理要求也不會拒絕的好對付的女人以外，是騙不了其他人的呦？」",
					{"rt2"},
