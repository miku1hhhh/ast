	["0091_00153"] = {
		{"fg", mode=-1, id=10, ch="郁子10", ch_origin="郁子", lv=10, time=0, sync=0},
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", file2="hinami_02m_00214", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0355", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Don’t get me wrong, Tachibana is a good guy and always tries his best, but I think he’s letting you mother him sometimes. He won’t grow out of it on his own...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“唔姆，虽然说橘同学是个不认输的好孩子没错，不过只有在对上奈奈濑酱的时候会变成撒娇鬼呢，这样的话他不能好好成长吧⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「唔姆，雖然說橘同學是個不認輸的好孩子沒錯，不過只有在對上奈奈瀨醬的時候會變成撒嬌鬼呢，這樣的話他不能好好成長吧⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00152",
		linknext = "0091_00154",
		line = 2471,
	},
	["0091_00154"] = {
