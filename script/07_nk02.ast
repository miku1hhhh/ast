			[6000] = {
				{"fg", file="nanase_01m_00001", file1="nanase_01m_00104", file3="nanase_01m_00310", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, timestamp=90, delay2=6000, mode=3, x=-5, y=-5},
				{"fgact", ch="奈々瀬4", id=4, act="振動下", loop=6, size=12.5, time=250, ease="easeinout_sine", timestamp=90, delay2=6000},
				{"se", id=0, loop=0, file="se_a185", timestamp=90, delay2=6000},
