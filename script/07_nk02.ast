			en = {
				{
					name = {"桐香", "Touka"},
					"“I think a big reason for that is because Nanase’s so lenient. I bet she’d let me join in for a threesome if asked nice enough❤”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我想大部分的原因是因为奈奈濑同学是那种可以包容一切的人吧。如果拜托她的话，她也会抱持着宽怀的心接受3P吧",
