	["0091_00115"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00102", file2="rei_02m_00204", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-305, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2017", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“G-Get a hold of yourself, Ikuko. That kind of talk is what caused us to lose in the first place! All we can do now is take it on the chin and keep going!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“冷、冷静一点，郁子。就是因为有这样的人，我们才会吃上败仗的⋯⋯！要接受这件事，继续向前看进啊！⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「冷、冷靜一點，郁子。就是因為有這樣的人，我們才會吃上敗仗的⋯⋯！要接受這件事，繼續向前看進啊！⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00114",
		linknext = "0091_00116",
		line = 1817,
	},
