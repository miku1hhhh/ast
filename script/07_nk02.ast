			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, you totally are though! You make his meals, wash his clothes... You’re basically his mom already!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不，奈奈濑同学你已经变成老妈子了！煮饭洗衣打扫，完全就是橘同学的老妈啊！”",
