	},
	["0091_00149"] = {
		{"cgdel", id=8, time=0, alphadel=1, lv=5},
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=9, lv=9, head="tohka_02m", ch_origin="桐香", ch="桐香9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1784", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I dunno. I can’t say I’ve paid much attention to how ugly or pretty his face is, but if that’s the kind of relationship you have then what’s the big deal? Whatever tickles your pickle, so to speak.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我没有意识到脸的美丑的问题所以我不是很懂，不过这是因为这样的关系的话也是挺不错的吧？让人很兴奋。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我沒有意識到臉的美醜的問題所以我不是很懂，不過這是因為這樣的關係的話也是挺不錯的吧？讓人很興奮。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00148",
		linknext = "0091_00150",
		line = 2408,
	},
	["0091_00150"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00203", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2023", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“But it IS a big deal! He knows you like his face and that’s why he acts the way he does! You’re being too soft on him!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不，不行的桐香大人！只是因为长着喜欢的脸就可以让那种男人为所欲为！这样太宠对方了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不，不行的桐香大人！只是因為長著喜歡的臉就可以讓那種男人為所欲為！這樣太寵對方了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00149",
		linknext = "0091_00151",
		line = 2423,
	},
	["0091_00151"] = {
		{"fg", mode=-1, id=5, ch="ヒナミ5", ch_origin="ヒナミ", lv=5, time=0, sync=0},
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00203", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
