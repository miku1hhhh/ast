		text = {
			vo = {
				{"vo", file="nanase0525", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Oh, right. If your muscles are spasming then are you sure you’re getting enough electrolytes? I’ll go get you some lemon and a sports drink. Wait right there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“欸，真的耶。肌肉筋挛的话就表示你的电解质不够喔？我准备了用柠檬跟盐特调的运动饮料喔，等我一下。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「欸，真的耶。肌肉筋攣的話就表示你的電解質不夠喔？我準備了用檸檬跟鹽特調的運動飲料喔，等我一下。」",
					{"rt2"},
				},
			},
		},
