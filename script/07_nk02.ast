			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“What she said! A man who treats you like his mother is useless! If you don’t do something about it now then he’ll act like this forever!”",
					{"rt2"},
				},
			},
			cn = {
				{
