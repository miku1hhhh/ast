			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Please cut that out. Watching you twitch your boobs at everyone is making me lose my appetite...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“你的胸肌在那边抽来抽去的让我一点食欲都没有，所以拜托你不要再弄了可以吗⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「你的胸肌在那邊抽來抽去的讓我一點食慾都沒有，所以拜託你不要再弄了可以嗎⋯⋯？」",
					{"rt2"},
				},
			},
