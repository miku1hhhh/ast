			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“That makes me wonder just what kind of cruel things my Darling is saying! I don’t like it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“咦，那样都算普通的话那亲爱的平常对你说话的时候到底都有多过分啊？郁也觉得这样不行耶。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「咦，那樣都算普通的話那親愛的平常對妳說話的時候到底都有多過分啊？郁也覺得這樣不行耶。」",
					{"rt2"},
				},
			},
		},
