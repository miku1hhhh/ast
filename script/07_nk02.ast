					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Okay, sure, I’d say his face is pretty well put together as faces go, but... I’m not sure I’d go so far as to call him a hottie?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯，比起来的话确实五官是挺好看的啦⋯⋯但那家伙还称不上是帅哥吧⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯，比起來的話確實五官是挺好看的啦⋯⋯但那傢伙還稱不上是帥哥吧⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00141",
		linknext = "0091_00143",
		line = 2284,
	},
	["0091_00143"] = {
