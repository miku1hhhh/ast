		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0570", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“They’ve come all this way, I should make something for everyone to eat. It’s still warm out, but maybe hotpot would be the easiest?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“难得大家都在，不如一边吃饭一边聊怎么样？虽然还有点热，不过吃火锅应该可以吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「難得大家都在，不如一邊吃飯一邊聊怎麼樣？雖然還有點熱，不過吃火鍋應該可以吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00248",
		linknext = "0091_00250",
