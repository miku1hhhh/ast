			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Exactly that! Exactly that! I like how he’s got lips you wanna nibble and the way his nose pinches in the middle and how small his eyes are and how he looks younger when he takes his glasses off!!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“对对对就是那个！有一点点丰满的嘴唇配上尖顶的鼻梁还有那双瞳孔细小的黑眼，没有戴眼镜的时候看起来就很幼齿，我超喜欢的！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「對對對就是那個！有一點點豐滿的嘴唇配上尖頂的鼻樑還有那雙瞳孔細小的黑眼，沒有戴眼鏡的時候看起來就很幼齒，我超喜歡的！！」",
					{"rt2"},
				},
			},
		},
