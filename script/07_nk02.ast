			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But your support and sense of rhythm have been great for muscle development! I have a lot of respect for you, Teach. I can’t wait for the sequel!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“您总是用充满律动感的方式鼓励我们追求肌肉的极限⋯⋯！我很尊敬您、老师！！我一直在等您出续作呢！！！”",
