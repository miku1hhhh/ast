					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「因為淳不是只為了自己而努力的嘛。這一切都是為了我們才做的，對吧？」",
					{"rt2"},
				},
			},
		},
