			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Y-You think so? I mean, we get along pretty well.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“欸⋯⋯是、是这样吗⋯⋯？我们的关系很好啊⋯⋯？”",
					{"rt2"},
