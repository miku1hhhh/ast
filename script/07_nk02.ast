		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00203", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=0},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Easy, ‘Strongest There Is.’ I want to be able to eat a shotgun blast to the gut and fix it with steak.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“当然是‘地表最强’的存在啊。就是那种被狙击枪打到也能靠吃牛排治好的那种。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「當然是『地表最強』的存在啊。就是那種被狙擊槍打到也能靠吃牛排治好的那種。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00023",
		linknext = "0091_00025",
		line = 446,
	},
	["0091_00025"] = {
		{"fg", file="asane_01m_00003", file1="asane_01m_00102", file2="asane_01m_00221", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1138", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“At this rate you’re gonna turn into a meaty black hole and consume all of humanity and become the sinew-larity! Besides, Misaki’s our resident overeater and we don’t need another!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我是真心讨厌变成肌肉男的人所以如果哥哥你真的要变成那种完全是肌肉的球体把人形都给吞噬殆尽的话⋯⋯！就只有那个大食女畔同学搭得上了啦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我是真心討厭變成肌肉男的人所以如果哥哥你真的要變成那種完全是肌肉的球體把人形都給吞噬殆盡的話⋯⋯！就只有那個大食女畔同學搭得上了啦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00024",
		linknext = "0091_00026",
		line = 461,
	},
	["0091_00026"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asa’s being melodramatic. There’s no way I’d grow muscles THAT big.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我并不打算把自己练成麻沙酱担心的那种肌肉男。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我並不打算把自己練成麻沙醬擔心的那種肌肉男。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00025",
		linknext = "0091_00027",
		line = 471,
	},
	["0091_00027"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Growing muscles that are too large runs the risk of reducing one’s stamina.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果肌肉太发达的话，会失去应有的持久力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果肌肉太發達的話，會失去應有的持久力。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00026",
		linknext = "0091_00028",
		line = 481,
	},
	["0091_00028"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I’m to be The Strongest There Is then I can’t risk letting my stamina suffer.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我的目标是成为最强的人，而不是肌肉男。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我的目標是成為最強的人，而不是肌肉男。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00027",
		linknext = "0091_00029",
		line = 491,
	},
	["0091_00029"] = {
		{"se", id=0, loop=0, file="se_a176"},
		{"fgact", ch="麻沙音3", id=3, act="移動", x=400, y=0, time=500},
		{"fg", mode=-1, id=30},
		{"facehide"},
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"fgact", ch="奈々瀬4", id=4, act="移動", x=200, y=0, time=700},
		{"text"},
		delay = {
			[1500] = {
				{"fg", file="nanase_02m_00002", file1="nanase_02m_00101", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=4, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, timestamp=47, delay2=1500, mode=3, x=-205, y=-5},
				{"fgact", ch="奈々瀬4", id=4, act="移動", x=-200, y=0, time=800, timestamp=47, delay2=1500},
			},
			[1499] = {
				{"transitiontime", time=300, timestamp=47, delay2=1500},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0523", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Protein-packed chicken piccata with grilled cheese chikuwa and soy milk. For carbs, we have onigiri and a banana, then avocado and tomato salad for your amino acids. A perfect post-workout menu.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“来，蛋白质的部分是干煎鸡胸肉搭配起司炸竹轮，还有豆浆。碳水化合物的部分则是饭团和香蕉，氨基酸有酪梨拌番茄沙拉。这是训练后的特制食谱喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「來，蛋白質的部分是乾煎雞胸肉搭配起司炸竹輪，還有豆漿。碳水化合物的部分則是飯糰和香蕉，氨基酸有酪梨拌番茄沙拉。這是訓練後的特製食譜喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00028",
		linknext = "0091_00030",
		line = 513,
	},
	["0091_00030"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=0},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Whoa! Nanase, you always outdo yourself!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“太好啦！老是麻烦你呢，奈奈濑⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「太好啦！老是麻煩妳呢，奈奈瀨⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00029",
		linknext = "0091_00031",
		line = 525,
	},
	["0091_00031"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", file2="nanase_01m_00207", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0524", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Now get eating! It’s always best to eat quickly after a workout.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“好了快点吃吧，训练后得尽快补充营养才好吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「好了快點吃吧，訓練後得盡快補充營養才好吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00030",
		linknext = "0091_00032",
		line = 540,
	},
	["0091_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase put together a special breakfast for our day-off just in time for me to finish my workout.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我训练完时，奈奈濑的特制早餐也刚好做好了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我訓練完時，奈奈瀨的特製早餐也剛好做好了。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00031",
		linknext = "0091_00033",
		line = 550,
	},
	["0091_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She puts together meals that help with gaining muscle, and even comes up with meals that let the body rest.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就这样，她每天都会帮我准备能轻松增肌、同时还能让身体充分舒缓的食谱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就這樣，她每天都會幫我準備能輕鬆增肌、同時還能讓身體充分舒緩的食譜。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00032",
		linknext = "0091_00034",
		line = 560,
	},
	["0091_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And she’s always adding something a little extra, to make sure they don’t get boring.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且为了不让菜式太单调，她会花心思变换早餐的菜色。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且為了不讓菜式太單調，她會花心思變換早餐的菜色。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00033",
		linknext = "0091_00035",
		line = 570,
	},
	["0091_00035"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nothing short of professional.",
					{"rt2"},
				},
			},
			cn = {
				{
					"简直就像是专业人士一样对我的菜单进行彻底的管理。",
					{"rt2"},
				},
			},
			tw = {
				{
					"簡直就像是專業人士一樣對我的菜單進行徹底的管理。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00034",
		linknext = "0091_00036",
		line = 580,
	},
	["0091_00036"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=0},
		{"text"},
