					name = {"美岬", "Misaki"},
					"“She’s right! Tachibana may have the face of an angel, but at his core he’s nothing more than a pseudo-impotent, useless ball of muscle!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“就是说啊！橘同学完全就是阳痿肌肉软烂男，全身上下只剩那张脸能看了吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「就是說啊！橘同學完全就是陽痿肌肉軟爛男，全身上下只剩那張臉能看了吧！」",
					{"rt2"},
				},
			},
		},
