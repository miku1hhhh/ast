		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I was such a moron back then. It must have been pretty uncomfortable and awkward for her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当时我还在当机的状态，所以也给奈奈濑造成了不少麻烦吧⋯⋯",
					{"rt2"},
				},
			},
			tw = {
				{
					"當時我還在當機的狀態，所以也給奈奈瀨造成了不少麻煩吧⋯⋯",
					{"rt2"},
				},
