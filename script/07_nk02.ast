		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, the goal’s to be the strongest in the world, but I’ve still got a way to go. Isn’t that right anterior forearm (Z1)?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我的目标是成为世界最强的存在，现在的我还差得远呢⋯⋯对吧，前臂屈腕肌群们⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我的目標是成為世界最強的存在，現在的我還差得遠呢⋯⋯對吧，前臂屈腕肌群們⋯⋯？」",
					{"rt2"},
				},
			},
		},
