	["0091_00245"] = {
		{"fg", file="rei_01m_00002", file1="rei_01m_00101", file2="rei_01m_00221", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2035", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“That’s why you like her? I can’t believe how shallow you are. Doesn’t matter how much training you do, your muscles will always be coated in blubber...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这就是你喜欢人家的理由？还真是轻浮的男人⋯⋯像这种家伙不管再怎么锻炼肌肉还不是油腔滑调的完全靠不住⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這就是你喜歡人家的理由？還真是輕浮的男人⋯⋯像這種傢伙不管再怎麼鍛鍊肌肉還不是油腔滑調的完全靠不住⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00244",
		linknext = "0091_00246",
		line = 3987,
	},
	["0091_00246"] = {
		{"bgm", stop=1},
