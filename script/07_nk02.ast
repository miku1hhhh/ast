			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“True, he could do with being a bit more mindful at times, but... unless something huge comes up it doesn’t really bother me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“他确实是有点迟钝的男人啦⋯⋯不过也没有到太夸张的地步所以我也没那么在意。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「他確實是有點遲鈍的男人啦⋯⋯不過也沒有到太誇張的地步所以我也沒那麼在意。」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00126",
		linknext = "0091_00128",
		line = 2040,
	},
	["0091_00128"] = {
