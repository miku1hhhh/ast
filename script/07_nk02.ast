			cn = {
				{
					name = {"淳之介"},
					"“当然啊交给我吧，奈奈濑的魅力可不单只有外表而已，内在也非常体贴善良，最能表现出这一点的就是脖子中间左下方的那颗痣──唔唔！！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「當然啊交給我吧，奈奈瀨的魅力可不單只有外表而已，內在也非常體貼善良，最能表現出這一點的就是脖子中間左下方的那顆痣──唔唔！！！」",
					{"rt2"},
				},
			},
		},
