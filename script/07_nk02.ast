			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Haaah...❤ I see. Usually new lovers should have a more innocent relationship when they’re just starting out, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“唉⋯⋯",
					{"gaiji", text="①"},
					"呵，我明白你的意思了。你们确实也才刚交往没多久，应该还是比较单纯的关系吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「唉⋯⋯",
					{"gaiji", text="①"},
					"呵，我明白妳的意思了。你們確實也才剛交往沒多久，應該還是比較單純的關係吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00116",
		linknext = "0091_00118",
		line = 1874,
	},
	["0091_00118"] = {
