	["0091_00119"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", file2="hinami_02m_00203", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0351", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“That’s obvious! But I readed manga and stuff and in there couples who just started living together always get all tense over silly stuff!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我知道你们的关系很好啦！但你们应该更像漫画那种、刚开始同居的情侣要有的紧张感觉才对吧⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我知道你們的關係很好啦！但你們應該更像漫畫那種、剛開始同居的情侶要有的緊張感覺才對吧⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00118",
		linknext = "0091_00120",
		line = 1907,
	},
	["0091_00120"] = {
		{"fg", mode=-1, id=8, ch="桐香8", ch_origin="桐香", lv=8, time=0, sync=0},
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00101", file2="misaki_02m_00203", path=":fg/misaki_02m/", id=6, lv=6, head="misaki_02m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0420", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I’ll overlook your adorable way of speaking this time, but these two have been partners from the start. Maybe that’s why they’re not acting like your typical sweethearts do!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“虽然说她的反应很可爱但这是犯规所以我要无视它，他们两个原本就是搭党关系所以就算变成情侣也根本就没有恋人的感觉吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「雖然說她的反應很可愛但這是犯規所以我要無視它，他們兩個原本就是搭黨關係所以就算變成情侶也根本就沒有戀人的感覺吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00119",
		linknext = "0091_00121",
		line = 1923,
	},
	["0091_00121"] = {
