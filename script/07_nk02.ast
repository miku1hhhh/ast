		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0550", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“And that’s why I let him get away with stuff. I just look at him and think, ‘How could I say no to such a pretty face?’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“所以不管淳对我说什么，我都会觉得‘看在那张脸上就算了’这样⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「所以不管淳對我說什麼，我都會覺得『看在那張臉上就算了』這樣⋯⋯」",
					{"rt2"},
				},
			},
		},
