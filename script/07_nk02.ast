			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ugh, Nanase was so close and now she’s so far away... Damn you and your stupid muscles!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“唉，奈奈濑同学变成一个很亲近但又很疏远的存在了啦⋯⋯！可恶，臭肌肉不可原谅⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「唉，奈奈瀨同學變成一個很親近但又很疏遠的存在了啦⋯⋯！可惡，臭肌肉不可原諒⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00038",
		linknext = "0091_00040",
		line = 654,
	},
	["0091_00040"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase’s food tastes so good, I can’t help but feel bad for all the musclers (muscle lovers) in the world that will never get to experience it for themselves.",
					{"rt2"},
				},
			},
			cn = {
				{
					"吃得这么好，简直对不起全世界的肌肉锻炼爱好者。",
					{"rt2"},
				},
			},
			tw = {
				{
					"吃得這麼好，簡直對不起全世界的肌肉鍛鍊愛好者。",
					{"rt2"},
				},
			},
		},
		linkback = "0091_00039",
		linknext = "0091_00041",
		line = 664,
	},
	["0091_00041"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=0},
		{"text"},
		text = {
			ja = {
				{
