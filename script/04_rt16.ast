			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“没错没错！而且这里有四个人所以总共有四百八十颗心喔。请你放心依赖我们吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
