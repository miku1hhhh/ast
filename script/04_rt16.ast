		line = 3269,
	},
	["0072_00238"] = {
		{"fg", file="susuko_02m_00002", file1="susuko_02m_00101", file2="susuko_02m_00217", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0413", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Well, ’Bana’s a pretty simple guy. With us helping, you’ll be as close as two peas in a pod.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“毕竟阿橘很好懂嘛……呢嘻嘻—，只要丝丝子稍～微帮点忙阿橘的鸡鸡就能手到擒来、一鸡必杀啦”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「畢竟阿橘很好懂嘛……呢嘻嘻—，只要絲絲子稍～微幫點忙阿橘的雞雞就能手到擒來、一雞必殺啦」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00237",
		linknext = "0072_00239",
		line = 3284,
	},
	["0072_00239"] = {
		{"fg", file="rei_01f_00006", file1="rei_01f_00103", file2="rei_01f_00206", path=":fg/rei_01f/", id=30, ch="礼", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
