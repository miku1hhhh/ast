				{"vo", file="ikuko1302", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Whoa, now! Overreact much? Big talk for someone weaker than me, though...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“何、何必那么生气嘛……明明就比我还弱—……”",
