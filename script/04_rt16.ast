	["0072_00233"] = {
		{"fg", mode=-1, id=10, ch="郁子10", ch_origin="郁子", lv=10, time=0, sync=0},
		{"fg", file="rin_01m_00002", file1="rin_01m_00101", file2="rin_01m_00205", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0238", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“My sister’s a big devotee of Rei. She won’t tolerate anything that might insult her. And she attacks like a rabid dog.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“毕竟姐姐有点像是礼前辈的狂信徒一样的一面嘛。只要礼前辈被看轻了不管对方是谁都会咬上去。像只狂犬一样真恐怖呢”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「畢竟姐姐有點像是禮前輩的狂信徒一樣的一面嘛。只要禮前輩被看輕了不管對方是誰都會咬上去。像隻狂犬一樣真恐怖呢」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00232",
		linknext = "0072_00234",
		line = 3209,
	},
	["0072_00234"] = {
		{"fg", file="susuko_02m_00002", file1="susuko_02m_00101", file2="susuko_02m_00213", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-605, y=-5},
