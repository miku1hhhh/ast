			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Sorry, I’m just kidding. Anyway, it feels kind of weird to just stand around, so do you wanna go for a walk?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“对不起啦，只是个玩笑嘛。牵着手站在这里不动也挺那个的……总而言之，先走一走吧”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「對不起啦，只是個玩笑嘛。牽著手站在這裡不動也挺那個的……總而言之，先走一走吧」",
					{"rt2"},
				},
			},
		},
