	["0072_00633"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She’s older than me, but she’s looking at me like a child asking for an ice cream.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明比我年长，可是她抬眼恳求的模样却像是纯洁的少女。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明比我年長，可是她抬眼懇求的模樣卻像是純潔的少女。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00632",
