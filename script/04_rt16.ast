	["0072_00156"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00209", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What am I gonna do... She’s gonna realize I’m not the man she thought I was and get all disillusioned...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么办……会不会让她觉得我是个没用的男人，让她幻灭啊……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼辦……會不會讓她覺得我是個沒用的男人，讓她幻滅啊……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00155",
		linknext = "0072_00157",
		line = 1967,
	},
	["0072_00157"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00209", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What could she possibly find enjoyable about going on a date with a man whose only experience of love is through eroge?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对啊……你们想想看嘛。跟除了小黄游以外没有恋爱经验的男人约会到底有什么好玩的……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對啊……妳們想想看嘛。跟除了小黃遊以外沒有戀愛經驗的男人約會到底有什麼好玩的……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00156",
		linknext = "0072_00158",
		line = 1979,
	},
	["0072_00158"] = {
		{"fg", file="asane_01m_00003", file1="asane_01m_00101", file2="asane_01m_00214", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00101", file3="hinami_02m_00303", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00101", file2="nanase_02m_00215", path=":fg/nanase_02m/", id=4, lv=4, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00209", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=4, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I can see it now... I run out of things to say, then I say something stupid about how a situation reminds me of one of my tiddy games, and she thinks I’m weird!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我已经能看到了……在约会的时候明明一直都不怎么说话，可是一遇到类似小黄游的情境与诉就马上快起来然后被她嫌恶心的未来……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我已經能看到了……在約會的時候明明一直都不怎麼說話，可是一遇到類似小黃遊的情境與訴就馬上快起來然後被她嫌噁心的未來……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00157",
		linknext = "0072_00159",
		line = 1998,
	},
	["0072_00159"] = {
