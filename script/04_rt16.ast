	["0072_00216"] = {
		{"fg", file="rei_01m_00007", file1="rei_01m_00103", file2="rei_01m_00207", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’ve been overthinking everything like a massive virgin. She seems pretty chill in comparison.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我从刚才就像是标准处男一样一直想东想西，可是她看起来倒是相当冷静。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我從剛才就像是標準處男一樣一直想東想西，可是她看起來倒是相當冷靜。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00215",
		linknext = "0072_00217",
		line = 2932,
	},
	["0072_00217"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Normally she might deny it agitatedly, but today she seems to be feeling good about being here, saying she’s happy, saying she loves me... It’s increasing the tension even more.",
					{"rt2"},
				},
			},
			cn = {
				{
					"平常明明都会“我才没害羞”“什么都没有”地大声否定的，可是今天却是“我很开心”“我喜欢你”的什么话都老实说出来，让我比平时还更心跳加速。",
					{"rt2"},
				},
			},
			tw = {
				{
					"平常明明都會「我才沒害羞」「什麼都沒有」地大聲否定的，可是今天卻是「我很開心」「我喜歡你」的什麼話都老實說出來，讓我比平時還更心跳加速。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00216",
		linknext = "0072_00218",
		line = 2942,
	},
	["0072_00218"] = {
		{"text"},
		text = {
