	["0072_00612"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ahh, but now we’re silent again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可是，这么一来现场马上又被另一种奇妙的沉默给包围。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可是，這麼一來現場馬上又被另一種奇妙的沉默給包圍。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00611",
		linknext = "0072_00613",
		line = 9312,
	},
	["0072_00613"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This is different from the awkwardness before. It’s a void of quietness, so quiet I can feel every heartbeat.",
					{"rt2"},
				},
			},
			cn = {
				{
					"跟刚才的尴尬不太一样──是令胸中的鼓动飘忽不定的、淡淡的寂静。",
					{"rt2"},
				},
			},
			tw = {
				{
					"跟剛才的尷尬不太一樣──是令胸中的鼓動飄忽不定的、淡淡的寂靜。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00612",
		linknext = "0072_00614",
		line = 9322,
	},
	["0072_00614"] = {
		{"fg", file="rei_02m_00007", file1="rei_02m_00103", file2="rei_02m_00214", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1384", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I just... I just think it’s a little early for touching me there...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那个、啊……我想，要摸那种奇怪的地方……是还、有点太早……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那個、啊……我想，要摸那種奇怪的地方……是還、有點太早……」",
					{"rt2"},
