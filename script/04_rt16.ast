				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Before, I’d probably tease her and joke about it, but she’s got me wrapped around her finger right now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"以前明明都是我觉得好玩在捉弄她，今天却有一种反而被捉弄了的感觉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"以前明明都是我覺得好玩在捉弄她，今天卻有一種反而被捉弄了的感覺。",
					{"rt2"},
				},
