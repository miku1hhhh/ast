	["0072_00176"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s business as usual with this bunch, enough to make me think I’m a fool for letting these worries get the better of me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大家的表现都跟平时一样，让我都觉得刚才感到不安的自己有点蠢了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"大家的表現都跟平時一樣，讓我都覺得剛才感到不安的自己有點蠢了。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00175",
