	["0072_00201"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=29},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, nothing. It’s just that I’m so happy to be on a date with you, a laugh slipped out...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊──，没有，只是一想到自己正在和礼约会，就忍不住笑出了声来……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊──，沒有，只是一想到自己正在和禮約會，就忍不住笑出了聲來……」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00200",
