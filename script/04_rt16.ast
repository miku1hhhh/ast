					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I’m sorry everyone... No, thank you all. I’m counting on you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“各位……不好意思──不、谢谢你们。就靠你们了喔！”",
