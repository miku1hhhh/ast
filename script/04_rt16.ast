				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We were too absorbed in our date to notice that we’ve stumbled into District A, where sex is permitted.",
					{"rt2"},
				},
			},
			cn = {
				{
					"A地区是可以进行性行为的区域。约会似乎让飘飘然的我们都没注意到这件事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"A地區是可以進行性行為的區域。約會似乎讓飄飄然的我們都沒注意到這件事。",
