		line = 3314,
	},
	["0072_00241"] = {
		{"fg", file="rei_01f_00006", file1="rei_01f_00104", file2="rei_01f_00214", path=":fg/rei_01f/", id=30, ch="礼", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1320", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Huh? No... I couldn’t... How would I even start?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“咦……不……那有点……不太对吧……”",
