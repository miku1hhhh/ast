		},
		text = {
			vo = {
				{"vo", file="misaki0278", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“That was a strange interruption. Anyway, Junnosuke, we’re with you every step of the way! Think of us as the boat carrying you to your destination!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“……虽然有奇怪的人进来捣乱，总之淳之介君有我们跟着！尽管放一百二十个心吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「……雖然有奇怪的人進來搗亂，總之淳之介君有我們跟著！儘管放一百二十個心吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00170",
		linknext = "0072_00172",
		line = 2225,
	},
	["0072_00172"] = {
