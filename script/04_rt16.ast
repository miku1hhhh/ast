			},
			en = {
				{
					name = {"奈々瀬", "Nanadori"},
					"“I wanted to take them to a bunch of different places, but I think we should maybe stop sticking our beaks in. Let’s get back to work... Hame!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈dori君"},
					"“对方虽然似乎也带来了不少人，但是看来我们都是多管闲事了呢……褓母的角色就在这里告一段落，我们回去工作吧……hame”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈dori君"},
					"「對方雖然似乎也帶來了不少人，但是看來我們都是多管閒事了呢……褓母的角色就在這裡告一段落，我們回去工作吧……hame」",
					{"rt2"},
				},
			},
		},
