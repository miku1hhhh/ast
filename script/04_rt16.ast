		linknext = "0072_00507",
		line = 7930,
	},
	["0072_00507"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Y’know: “Here, let me get those off you. Wow, we haven’t even done anything and you’re already this wet!”",
