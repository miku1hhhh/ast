	["0072_00228"] = {
		{"fg", file="rei_02f_00006", file1="rei_02f_00104", file2="rei_02f_00214", path=":fg/rei_02f/", id=30, ch="礼", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1317", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Okay... thanks. But I’ve never been on a date before... Can I really be a good girlfriend? It’s stressing me out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这样啊……谢谢你们了。可是，约会我还是第一次……到底能不能扮演好女朋友的角色……我有点不安呢”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這樣啊……謝謝妳們了。可是，約會我還是第一次……到底能不能扮演好女朋友的角色……我有點不安呢」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00227",
		linknext = "0072_00229",
		line = 3128,
	},
	["0072_00229"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00101", file2="ran_01m_00201", file4="ran_01m_00401", path=":fg/ran_01m/", id=13, lv=13, head="ran_01m", ch_origin="蘭", ch="蘭13", mw="mw", sync=0, mode=3, x=-5, y=-5},
