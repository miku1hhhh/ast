	},
	["0072_00235"] = {
		{"fg", file="rei_01f_00006", file1="rei_01f_00102", file2="rei_01f_00224", path=":fg/rei_01f/", id=30, ch="礼", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1318", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“That’s why I feel bad that I’m making you pick up the slack for me at work and then also drafting you in to help with my date...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“可是，都已经把工作推给你们了还要让你们支援我，也太对不起你们了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「可是，都已經把工作推給妳們了還要讓妳們支援我，也太對不起妳們了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00234",
		linknext = "0072_00236",
		line = 3237,
	},
	["0072_00236"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00101", file2="ran_01m_00202", file4="ran_01m_00401", path=":fg/ran_01m/", id=13, lv=13, head="ran_01m", ch_origin="蘭", ch="蘭13", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=100},
		{"fgact", ch="蘭13", id=13, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0113", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Don’t sweat it! This event’s all about making love come true, so we should definitely provide a little aftercare!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“请不要介意！这次活动的主题就是成人之美，组成情侣之后的售后服务自然也该做到花的嘛！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「請不要介意！這次活動的主題就是成人之美，組成情侶之後的售後服務自然也該做到花的嘛！」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00235",
		linknext = "0072_00237",
		line = 3253,
	},
	["0072_00237"] = {
		{"fg", mode=-1, id=14, ch="凛14", ch_origin="凛", lv=14, time=0, sync=0},
		{"fg", file="schubert_01m_00002", file2="schubert_01m_00202", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
