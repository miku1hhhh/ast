		linkback = "0072_00614",
		linknext = "0072_00616",
		line = 9349,
	},
	["0072_00616"] = {
		{"fg", file="rei_02m_00007", file1="rei_02m_00103", file2="rei_02m_00224", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I urge her to finish her sentence, but she puffs out her cheeks, darting her eyes from side to side as she repeatedly stutters a long line of uhhs and umms.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我点头催促她继续说，结果礼搔着脸颊、眼神左右游移、支支吾吾地“呃—”“啊—”个不停。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我點頭催促她繼續說，結果禮搔著臉頰、眼神左右游移、支支吾吾地「呃—」「啊—」個不停。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00615",
		linknext = "0072_00617",
		line = 9362,
	},
	["0072_00617"] = {
		{"fg", file="rei_02m_00007", file1="rei_02m_00103", file2="rei_02m_00206", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She seems more than a little nervous, definitely more than she has been so far today.",
					{"rt2"},
				},
			},
			cn = {
				{
					"感觉好像在被吊什么胃口一样，连我都超乎必要地紧张了起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"感覺好像在被吊什麼胃口一樣，連我都超乎必要地緊張了起來。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00616",
		linknext = "0072_00618",
		line = 9375,
	},
	["0072_00618"] = {
		{"fg", file="rei_02m_00007", file1="rei_02m_00103", file2="rei_02m_00204", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After about 10 seconds of the uhhs and umms, she finally summons the courage to look me in the eye...",
					{"rt2"},
				},
			},
			cn = {
				{
					"她的“呃—”“啊—”持续了总共十秒以上，最后才下定决心正面看进我的双眼──",
					{"rt2"},
				},
			},
			tw = {
				{
					"她的「呃—」「啊—」持續了總共十秒以上，最後才下定決心正面看進我的雙眼──",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00617",
		linknext = "0072_00619",
		line = 9388,
	},
	["0072_00619"] = {
		{"fg", file="rei_02m_00007", file1="rei_02m_00103", file2="rei_02m_00206", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Before losing her cool and looking away again, slowly beginning to speak.",
					{"rt2"},
				},
			},
			cn = {
				{
					"──可是，决心似乎还是不够，让她又再度别开了目光，最后就那样开口了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"──可是，決心似乎還是不夠，讓她又再度別開了目光，最後就那樣開口了。",
					{"rt2"},
				},
			},
		},
