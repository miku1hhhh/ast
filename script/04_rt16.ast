		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=14, lv=14, head="tohka_02m", ch_origin="桐香", ch="桐香14", mw="mw", sync=0, mode=3, x=-5, y=95},
		{"transitiontime", time=500},
		{"fgact", ch="桐香14", id=14, act="移動", x=0, y=-100, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1687", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“If that’s what you want, surely you can just ask him directly what he’d like?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“如果真的很想取悦前辈的话，那每次都问他怎么做他才开心不是最快的了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「如果真的很想取悅前輩的話，那每次都問他怎麼做他才開心不是最快的了嗎？」",
					{"rt2"},
