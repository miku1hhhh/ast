	["0072_00231"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00101", file2="ran_01m_00203", file4="ran_01m_00401", path=":fg/ran_01m/", id=13, lv=13, head="ran_01m", ch_origin="蘭", ch="蘭13", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=100},
		{"fgact", ch="蘭13", id=13, act="振動下", loop=2, size=-12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0112", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“This is about Rei! If I catch you messing around, Onabuta, I’m gonna hit you with the Hanamaru-lyzer!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“这可是礼前辈的约会喔！！要是做出那种事情，就算是女部田同学我也会架到花丸化装置上的喔！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「這可是禮前輩的約會喔！！要是做出那種事情，就算是女部田同學我也會架到花丸化裝置上的喔！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00230",
		linknext = "0072_00232",
		line = 3178,
	},
	["0072_00232"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00206", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
