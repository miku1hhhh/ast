	["0072_00505"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Surely being with her favorite man would be enough to get something going down there...",
					{"rt2"},
				},
			},
			cn = {
				{
					"我原本听说一般而言，光是跟喜欢的男性在一起就会湿的──",
					{"rt2"},
				},
			},
			tw = {
				{
					"我原本聽說一般而言，光是跟喜歡的男性在一起就會濕的──",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00504",
		linknext = "0072_00506",
		line = 7920,
	},
	["0072_00506"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"At least, that’s what I thought would happen based on my contact with the pixelly babes on my computer...",
					{"rt2"},
				},
			},
			cn = {
				{
					"至少，我至今为止隔着萤幕交往过的女主角们都是那样的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"至少，我至今為止隔著螢幕交往過的女主角們都是那樣的。",
					{"rt2"},
				},
			},
		},
