	["0072_00242"] = {
		{"fg", mode=-1, id=12, ch="シューベルト12", ch_origin="シューベルト", lv=12, time=0, sync=0},
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file3="ikuko_01m_00304", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1303", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Ah, Tokie, you don’t know jack-shit about people’s emotions, do you? You should just come out and say it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“啊—是是。桐香酱不懂人心，所以只要在旁边hame啪啪叫一叫就可以了啦”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「啊—是是。桐香醬不懂人心，所以只要在旁邊hame啪啪叫一叫就可以了啦」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00241",
		linknext = "0072_00243",
		line = 3343,
	},
	["0072_00243"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00206", path=":fg/tohka_02m/", id=14, lv=14, head="tohka_02m", ch_origin="桐香", ch="桐香14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file3="ikuko_01m_00301", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1304", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“At any rate, leave the date to me and the team. We’ll have you all lovey-dovey in no time!❤”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“唉，总之有郁我跟在旁边，约会就交给我吧。我会好好让礼酱和亲爱的干柴烈火的啦",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「唉，總之有郁我跟在旁邊，約會就交給我吧。我會好好讓禮醬和親愛的乾柴烈火的啦",
					{"gaiji", text="①"},
					"」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00242",
		linknext = "0072_00244",
		line = 3360,
	},
	["0072_00244"] = {
