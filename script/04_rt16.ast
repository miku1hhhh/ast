					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Don’t worry, we’ll help you out from inside our Hamedori costumes!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“那么我们也可以帮花忙喔！躲在Hamedori君里面！”",
