		{"text"},
		text = {
			vo = {
				{"vo", file="asane0294", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音", "アサドリくん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asadori"},
					"“Hame! Take lots of pictures of us and upload them to social media with #HamedoriTime!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音", "麻沙dori君"},
					"“Hame—！请尽量拍下我们的照片，加上淫照的标签放到SNS上、让我们更红吧啪啪～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音", "麻沙dori君"},
					"「Hame—！請盡量拍下我們的照片，加上淫照的標籤放到SNS上、讓我們更紅吧啪啪～！」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00184",
		linknext = "0072_00186",
		line = 2477,
	},
	["0072_00186"] = {
		{"text"},
		text = {
