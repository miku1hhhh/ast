	["0072_00503"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s just rocks and sand... One of the driest places in the world...",
					{"rt2"},
				},
			},
			cn = {
				{
					"这怎么可能──说到鸟取就是一片黄砂的不毛大地。",
