			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Ariadne Protocol online. Linking internal Hamedori cameras and IFF. IFF target confirmed, disciplinary committee president Rei Tadasugawa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"‘Ariadne协议．启动。将Hamedori君内部摄影机连线至敌我识别系统。敌我识别系统，确认目标为风纪委员长糺川礼’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"『Ariadne協議．啟動。將Hamedori君內部攝影機連線至敵我識別系統。敵我識別系統，確認目標為風紀委員長糺川禮』",
					{"rt2"},
				},
			},
		},
