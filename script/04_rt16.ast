				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「唔姆。而且，我的資料跟淳之介也很要好。很可靠喔」",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00236",
