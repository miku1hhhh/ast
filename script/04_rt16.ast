					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯dori君"},
					"「廁所在那邊dori～！如果跑到了A區的廁所，自己就會被當成廁所了，要多加注意喔dori！」",
					{"rt2"},
				},
			},
		},
