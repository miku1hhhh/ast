	["0072_00383"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Currently, the park is divided into three zones to allow the maximum number of people to enjoy its attractions.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在，这座游乐园为了能让更多人游玩，把设施大致分成了三个区划。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在，這座遊樂園為了能讓更多人遊玩，把設施大致分成了三個區劃。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00382",
		linknext = "0072_00384",
		line = 5978,
	},
	["0072_00384"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And of course, we’ve got District A, District B and District C. And we’re in B, the Chaste Zone.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不用说，当然是A区、B区和C区──而现在我和礼前辈所在的，是禁乱区的B区。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不用說，當然是A區、B區和C區──而現在我和禮前輩所在的，是禁亂區的B區。",
					{"rt2"},
				},
			},
		},
