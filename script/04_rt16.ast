	},
	["0072_00634"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei always wanted a normal romantic relationship, but she gave up after her life turned out anything but normal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一直憧憬着普通的恋爱──可是，因为无法忍受和现实的反差，最后只好放弃了那些梦想的礼。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一直憧憬著普通的戀愛──可是，因為無法忍受和現實的反差，最後只好放棄了那些夢想的禮。",
					{"rt2"},
				},
			},
		},
		linkback = "0072_00633",
		linknext = "0072_00635",
		line = 9591,
	},
	["0072_00635"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The dream she had given up on, right in front of her. She need only reach for it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在、她总算──再度向曾经放弃、舍去的梦想伸出了手也说不定。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在、她總算──再度向曾經放棄、捨去的夢想伸出了手也說不定。",
					{"rt2"},
				},
			},
		},
