		{"fgact", ch="ヒナミ5", id=5, act="振動下", loop=1, size=-20, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1300] = {
				{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", file2="hinami_02m_00203", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, timestamp=4, delay2=1300, mode=3, x=-5, y=-5},
			},
			[1299] = {
				{"transitiontime", time=300, timestamp=4, delay2=1300},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0306", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I am NOT a loli! Back me up, Fumino! Growing and changing is a good thing, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我才不是萝莉呢！哪，文乃酱也这么觉得吧？想要改变吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我才不是蘿莉呢！哪，文乃醬也這麼覺得吧？想要改變吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00016",
		linknext = "0076_00018",
		line = 249,
	},
	["0076_00018"] = {
		{"fg", file="fumino_01m_00007", file1="fumino_01m_00102", file2="fumino_01m_00211", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
