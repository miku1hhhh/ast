			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“She’s been causing a whole heap of problems ever since she was just a committee member!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“啊—确实是个感觉很需要照顾的风纪委员长喔”",
