					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So you somehow managed to get caught up in a cult in this dimension, too...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就连在这边的世界都沉迷于宗教了啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就連在這邊的世界都沉迷於宗教了啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00054",
