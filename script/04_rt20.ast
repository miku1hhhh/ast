		{"fg", file="asane_01m_00001", file1="asane_01m_00101", file2="asane_01m_00229", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0332", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Of course YOU want to change. You wouldn’t want to stay a loli forever.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“唉对萝莉来说当然是那样了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「唉對蘿莉來說當然是那樣了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00015",
		linknext = "0076_00017",
		line = 230,
	},
	["0076_00017"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", file2="hinami_01m_00218", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=-5, y=-5},
