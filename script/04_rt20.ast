		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Regardless of bad or good, things are bound to change anyway.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不论好坏，会改变的事物就是会改变。",
					{"rt2"},
