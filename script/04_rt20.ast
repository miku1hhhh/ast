		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In the end, I suppose no one can say for sure whether change is a good thing or not.",
					{"rt2"},
				},
			},
			cn = {
				{
					"唉──想来变化到底算不算好事，本来就不是能一概而论的吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"唉──想來變化到底算不算好事，本來就不是能一概而論的吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00019",
		linknext = "0076_00021",
		line = 295,
	},
	["0076_00021"] = {
