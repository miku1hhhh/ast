			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Everyone in the FS seems as buddy-buddy as ever. It looks like Rei has nothing to worry about.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“FS的大家看起来感情一如往常的好，真是太好了呢。这样一来礼酱似乎也不用担心了呢”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「FS的大家看起來感情一如往常的好，真是太好了呢。這樣一來禮醬似乎也不用擔心了呢」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00060",
		linknext = "0076_00062",
		line = 1010,
	},
	["0076_00062"] = {
