					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Indeed... With respect to this matter... I believe perhaps some things are better off changing after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“原来……关于那方面……或许是那样没错……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「原來……關於那方面……或許是那樣沒錯……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00017",
		linknext = "0076_00019",
		line = 264,
	},
	["0076_00019"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", file3="hinami_02m_00302", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=-5, y=-5},
