		},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino converts her previous convictions to match Hinami’s. It seems like they both want certain parts of themselves to grow more than others.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为雏见的萝莉话术，文乃一瞬间就改变立场了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為雛見的蘿莉話術，文乃一瞬間就改變立場了。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00018",
		linknext = "0076_00020",
		line = 279,
	},
	["0076_00020"] = {
		{"fgact", ch="麻沙音3", id=3, lv=3, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
