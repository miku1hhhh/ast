				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Well if it isn’t Tachibana! Good morning! If you’re looking for President Rei, she’s not here...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“哎呀……橘君！早安！找礼前辈的话她不在这里喔……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「哎呀……橘君！早安！找禮前輩的話她不在這裡喔……？」",
