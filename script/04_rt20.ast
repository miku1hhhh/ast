		text = {
			vo = {
				{"vo", file="ran0127", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Huh...? Oh, that’s right! I’d almost forgotten that I’m the President of the Disciplinary Committee from today. I tried to mentally prepare myself, but it still doesn’t feel real...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“咦……？啊、啊啊对了！我从今天开始就是风纪委员长了！呜呜—明明老早就做了各种心理准备，可是自觉还是完全不够……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「咦……？啊、啊啊對了！我從今天開始就是風紀委員長了！嗚嗚—明明老早就做了各種心理準備，可是自覺還是完全不夠……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00026",
