		text = {
			vo = {
				{"vo", file="ran0131", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“A rap-top? Some kind of hip-hop sex tool?! Why’d you bring such a thing to school?! Sexual contraband is forbidden—that’s the rule! So I’m confiscating this, FOOL!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“嘻哈型电脑、带到学校不好！为什么要拼命把它带到学校！？坏孩子要惩罚、小肉穴要开发、色情狂要有常识，今天就给你启发！这个要没收、返还要等到下周！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「嘻哈型電腦、帶到學校不好！為什麼要拼命把它帶到學校！？壞孩子要懲罰、小肉穴要開發、色情狂要有常識，今天就給妳啟發！這個要沒收、返還要等到下週！」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00038",
		linknext = "0076_00040",
		line = 643,
	},
