	["0076_00122"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The students and teachers passing by on their way to school stop to gawk at us, grinning and jeering.",
					{"rt2"},
				},
			},
			cn = {
				{
					"路过的学生和老师听到我的声音都回过头来，吵闹之中混合着贼笑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"路過的學生和老師聽到我的聲音都回過頭來，吵鬧之中混合著賊笑。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00121",
		linknext = "0076_00123",
		line = 1858,
	},
	["0076_00123"] = {
