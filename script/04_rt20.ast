	["0076_00054"] = {
		{"fg", file="rin_01m_00002", file1="rin_01m_00101", file2="rin_01m_00213", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0245", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Don’t you worry. It’s all just a matter of time until my sister becomes my puppet. Then everything will be under my control. The teachings of Lord Skeetus will guide us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“唉，反正不久之后姐姐就会变成傀儡、我会掌握实权，所以不用担心啦。这也是塞克罗斯很花丸的引导呢”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「唉，反正不久之後姐姐就會變成傀儡、我會掌握實權，所以不用擔心啦。這也是塞克羅斯很花丸的引導呢」",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00053",
		linknext = "0076_00055",
		line = 899,
	},
	["0076_00055"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
