		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Most of the FS members have wacky personalities, so they make even Hanamaru seem normal in comparison. Somehow, I have a feeling that she’ll be just fine as their leader.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在各种方面上个性都很强烈的FS成员之中，由还算平凡的花丸委员长上位，或许真的是个好主意。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在各種方面上個性都很強烈的FS成員之中，由還算平凡的花丸委員長上位，或許真的是個好主意。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00057",
		linknext = "0076_00059",
		line = 976,
	},
	["0076_00059"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her subordinates run their mouths and tease her from time to time, but that just goes to show how close they are. I have no doubt that they’ll support Hanamaru every step of the way.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说来说去跟部下们也熟到能被开玩笑，今后也一定会以伙伴的身份支持她的吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說來說去跟部下們也熟到能被開玩笑，今後也一定會以夥伴的身分支持她的吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0076_00058",
		linknext = "0076_00060",
		line = 986,
	},
	["0076_00060"] = {
		{"text"},
		text = {
			ja = {
