	["0094_00351"] = {
		{"bg", id=2, file="bg17_1l_00000", x=400, y=0, lv=2, path=":bg/", sync=0, ax=1290, ay=730, bx=-490, by=-280},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobb0120", path=":vo/", ch="gmob"},
			},
			ja = {
				{
					name = {"モブ女B", "女子生徒B"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Female Student B"},
					"“It’s no more possible for a virgin to come up with such kinky techniques than it is for a virgin to get pregnant! That’s some god-tier level stuff!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "女学生B"},
					"“处女不可能做出这种技巧的，这就跟处女怀孕一样不可能啊！要是这是真的，那不就跟神明一样了吗──哈！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "女學生B"},
					"「處女不可能做出這種技巧的，這就跟處女懷孕一樣不可能啊！要是這是真的，那不就跟神明一樣了嗎──哈！」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00350",
		linknext = "0094_00352",
		line = 5384,
	},
	["0094_00352"] = {
