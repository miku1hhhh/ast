			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“So I want everyone to respect those feelings. Then there will have been have meaning behind the pleasure we sacrificed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“所以我希望──各位都能好好尊重这样的情感。为了变态做爱而丧失的快乐，一定也是某种意义上的一种被牺牲。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「所以我希望──各位都能好好尊重這樣的情感。為了變態做愛而喪失的快樂，一定也是某種意義上的一種被犧牲。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00241",
		linknext = "0094_00243",
		line = 3634,
	},
