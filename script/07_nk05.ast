		},
		text = {
			vo = {
				{"vo", file="ikuko2104", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“They probably have the weapons leaked by the SHO—y’know, the riot guns and army knives... They’re more dangerous now than any meagre resistance groups.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“那些人肯定有武器。有从SHO暗中流出的暴徒镇压枪跟军刀⋯⋯是已经超越了单纯的反抗的危险存在。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「那些人肯定有武器。有從SHO暗中流出的暴徒鎮壓槍跟軍刀⋯⋯是已經超越了單純的反抗的危險存在。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00079",
		linknext = "0094_00081",
		line = 1178,
	},
	["0094_00081"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00203", path=":fg/tohka_02m/", id=8, lv=11, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1831", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“It seems they’re all planning some joint campaign in response to what happened with the Erect Elect last night.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“看起来，经过昨晚对‘茎选组’的全面制裁之后，这些组织打算联合起来一起起义的样子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「看起來，經過昨晚對『莖選組』的全面制裁之後，這些組織打算聯合起來一起起義的樣子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00080",
		linknext = "0094_00082",
		line = 1193,
	},
	["0094_00082"] = {
