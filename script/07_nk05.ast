	["0094_00065"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00202", path=":fg/susuko_02m/", id=11, lv=10, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-205, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="スス子11", id=11, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0547", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Hehe, the disciplinary committee’s knickers were in quite the twist! I felt bad for ’em, so I spilled the beans.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“欸嘿嘿，因为被教官们痛骂了一顿所以我有好好反省了丝丝，而且还被请客所以我就都说了喔～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「欸嘿嘿，因為被教官們痛罵了一頓所以我有好好反省了絲絲，而且還被請客所以我就都說了喔～！」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00064",
		linknext = "0094_00066",
		line = 962,
	},
	["0094_00066"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
