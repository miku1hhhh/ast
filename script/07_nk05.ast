			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Where do you think she is?! Did the letter give a location?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你知道确切的地点在哪吗？信里指定的地点是──！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你知道確切的地點在哪嗎？信裡指定的地點是──！？」",
