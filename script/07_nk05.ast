		line = 1009,
	},
	["0094_00069"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Would you open your mouth when you talk?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你到底是要吃东西还是要说话可以选一个吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳到底是要吃東西還是要說話可以選一個嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00068",
		linknext = "0094_00070",
		line = 1021,
	},
	["0094_00070"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00204", path=":fg/tohka_01m/", id=8, lv=11, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1827", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Nonetheless, I was able to get some idea of what investigation had been requested from Inami’s testimony. Tachibana, how much do you know about the pervert extremist groups?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不过，从伊波同学的口供，加上被委托的调查结果，我对情况有大概的了解了。前辈，你有听过所谓的‘变态激进份子’吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不過，從伊波同學的口供，加上被委託的調查結果，我對情況有大概的瞭解了。前輩，你有聽過所謂的『變態激進份子』嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00069",
		linknext = "0094_00071",
		line = 1036,
	},
	["0094_00071"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don’t really know anything about them, honestly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然说我不是很清楚那些“变态激进份子”们⋯⋯",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然說我不是很清楚那些「變態激進份子」們⋯⋯",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00070",
		linknext = "0094_00072",
		line = 1046,
	},
	["0094_00072"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00218", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It’s clearly an underground organization hellbent on reviving the perverted sex law, but you’re saying there’s more than one...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我的确是记得好像有不少地下组织想要复活变态条例的样子⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我的確是記得好像有不少地下組織想要復活變態條例的樣子⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00071",
		linknext = "0094_00073",
		line = 1058,
	},
	["0094_00073"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00203", path=":fg/tohka_02m/", id=8, lv=11, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1828", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“There’s even a virile team within the school working towards that goal, but if we trace their roots then we can guess there must be seven organized perverted sex law extremist groups in action.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“虽然学校里面也有想要透过健康的方式来复活变态条例的团体，不过追本溯源的话，我们认为它们合并成了七个不同的变态激进份子流派。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「雖然學校裡面也有想要透過健康的方式來復活變態條例的團體，不過追本溯源的話，我們認為它們合併成了七個不同的變態激進份子流派。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00072",
		linknext = "0094_00074",
		line = 1073,
	},
	["0094_00074"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00203", path=":fg/rei_02m/", id=9, lv=8, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2066", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“They call themselves the Seven Foolish Pervs—a sexual group rallied together to reinstate the perverted sex law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“他们的名字叫做‘变态七愚人’，是为了复活变态条例而聚集在一起的性产团体。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「他們的名字叫做『變態七愚人』，是為了復活變態條例而聚集在一起的性產團體。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00073",
		linknext = "0094_00075",
		line = 1088,
	},
	["0094_00075"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Isn’t that more members than she said yesterday?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么比昨天还多了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼比昨天還多了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00074",
		linknext = "0094_00076",
		line = 1100,
	},
	["0094_00076"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file3="ikuko_01m_00312", path=":fg/ikuko_01m/", id=10, lv=9, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2103", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“The group you defeated yesterday, Darling, was Inami’s team. The Erect Elect cracked down on the abstinence crew within Minotsuki Academy to maintain an air of perversion in the school.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“其中一个是亲爱的昨天打到的伊波酱的小队。是暗中取缔那些反交尾派，在学校内维持变态行为安稳的‘茎选组’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「其中一個是親愛的昨天打到的伊波醬的小隊。是暗中取締那些反交尾派，在學校內維持變態行為安穩的『莖選組』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00075",
		linknext = "0094_00077",
		line = 1115,
	},
	["0094_00077"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00204", path=":fg/tohka_02m/", id=8, lv=11, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1829", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Opposing them are the No-Nut Brotherhood, who reject those who respect kinky sex. They’re a consolidated military that deign themselves warriors of perversion, preparing for some revolution.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“还有与之对立、独尊变态交尾、排斥非性产者的‘阴囊超高潮派’，跟称自己为变态斗士，准备迎接革命战争的‘连结军’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「還有與之對立、獨尊變態交尾、排斥非性產者的『陰囊超高潮派』，跟稱自己為變態鬥士，準備迎接革命戰爭的『連結軍』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00076",
		linknext = "0094_00078",
		line = 1130,
	},
	["0094_00078"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=8, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2067", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“There’re also the aviation corps who consider themselves ancestors of Hamedori, The Undying Peenix, and the Masturbatory Relief Club who follow perversion from a statistical standpoint.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“其他还有以Hamedori君为祖先的鸟人军团‘不死之鸟(Phoenix)’跟以统计学的角度来追踪变态行为的‘痴情喔齁性处理学会’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「其他還有以Hamedori君為祖先的鳥人軍團『不死之鳥(Phoenix)』跟以統計學的角度來追蹤變態行為的『癡情喔齁性處理學會』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00077",
		linknext = "0094_00079",
		line = 1145,
	},
	["0094_00079"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00204", path=":fg/tohka_01m/", id=8, lv=11, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1830", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Not forgetting the Pervert Order that’s trying to control people with the power of religion... The list goes on, honestly. There are so many all coming together.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“还有以宗教的力量支配民众的教团‘变态性教’，这些各式各样的组织百花争鸣的状态。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「還有以宗教的力量支配民眾的教團『變態性教』，這些各式各樣的組織百花爭鳴的狀態。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00078",
		linknext = "0094_00080",
		line = 1160,
	},
	["0094_00080"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00214", path=":fg/ikuko_01m/", id=10, lv=9, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
