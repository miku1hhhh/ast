		text = {
			vo = {
				{"vo", file="susuko0550", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Eeep! Yeah, all right, cut it out with the biceps yeah?! I’m still trying to get over what happened yesterday, innit. Makes me wanna puke, it’s so gross!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“恶！？住手不要再让我看你怎么锻炼肱二头肌的了。昨天的创伤就已经让我很恶心了我要吐了啦恶恶恶恶⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「噁！？住手不要再讓我看你怎麼鍛鍊肱二頭肌的了。昨天的創傷就已經讓我很噁心了我要吐了啦噁噁噁噁⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00083",
		linknext = "0094_00085",
		line = 1251,
	},
	["0094_00085"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00227", path=":fg/tohka_01m/", id=8, lv=11, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1832", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Our final job as members of the former FS is to dismantle these extremist perverted believers.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“将这些激进的变态行为追随者给解散掉──这就是我们身为前FS最后的工作。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「將這些激進的變態行為追隨者給解散掉──這就是我們身為前FS最後的工作。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00084",
		linknext = "0094_00086",
		line = 1266,
	},
	["0094_00086"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So... this is what that investigation request from before was about.",
					{"rt2"},
				},
			},
			cn = {
				{
					"之前说的被委托的调查内容⋯⋯说的就是这件事。",
