				},
			},
			tw = {
				{
					name = {"凛"},
					"「唔⋯⋯把每個月宗師功俸的恩惠給忘得一乾二淨⋯⋯！等著瞧吧！不管要花多少時間，不管有多難，此仇我必然會報──！」",
					{"rt2"},
				},
			},
		},
