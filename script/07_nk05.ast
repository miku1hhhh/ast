			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“The possibilities are endless! I will restore the perverted sex law, and take the world by storm!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“要做的话方法多得是！现在就是重振变态条例的时候，这样世界就会落到我手里了──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「要做的話方法多得是！現在就是重振變態條例的時候，這樣世界就會落到我手裡了──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00383",
		linknext = "0094_00385",
		line = 5913,
	},
	["0094_00385"] = {
