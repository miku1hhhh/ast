	["0094_00049"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, and you did other stuff like share screenshots of someone else’s writing. You really seemed to like ‘the 3rd scene where the husband gets cucked sooo guuuuuud❤’.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“其他还有像是对喜欢的NTR作者的转发评论‘第三格里从壁橱偷窥着老婆与姘头的淫靡做爱场景真的太赞了",
					{"gaiji", text="①"},
					"’之类的──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「其他還有像是對喜歡的NTR作者的轉發評論『第三格裡從壁櫥偷窺著老婆與姘頭的淫靡做愛場景真的太讚了",
					{"gaiji", text="①"},
					"』之類的──」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00048",
		linknext = "0094_00050",
		line = 716,
	},
	["0094_00050"] = {
		{"se", id=0, loop=0, file="se_a098"},
