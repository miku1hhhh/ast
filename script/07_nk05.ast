		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00216", path=":fg/susuko_02m/", id=11, lv=10, head="susuko_02m", alpha=0, ch_origin="スス子", ch="スス子11", mw="mw", sync=1, a_chr151=1, mode=3, x=-205, y=295},
