			en = {
				{
					name = {"凛", "Rin"},
					"“Oh, shut up already! You see this is all due to your spinelessness, right? YOU should be the ones bowing and apologizing for where we are now!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“你惦惦啦！说到底还不是因为欸你才造成这一切的！你不才应该要低头道歉的吗⋯⋯！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「妳惦惦啦！說到底還不是因為欸妳才造成這一切的！妳不才應該要低頭道歉的嗎⋯⋯！？」",
					{"rt2"},
				},
			},
		},
