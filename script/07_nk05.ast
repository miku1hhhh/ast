	["0094_00188"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s clear they all felt some responsibility for the way things have turned out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她们应该也觉得自己要对这些事负责。",
					{"rt2"},
				},
