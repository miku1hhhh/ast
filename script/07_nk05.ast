	["0094_00067"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00102", file2="ikuko_02m_00205", path=":fg/ikuko_02m/", id=10, lv=9, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2102", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Either way, as we suspected, she used to be one of our numbers. Although I figured that was obvious.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“要怎么说呢，果然跟预料的一样，是之前在我们底下的那些人⋯⋯我原本是这么想的啦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「要怎麼說呢，果然跟預料的一樣，是之前在我們底下的那些人⋯⋯我原本是這麼想的啦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00066",
		linknext = "0094_00068",
		line = 989,
	},
	["0094_00068"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00222", path=":fg/susuko_02m/", id=11, lv=10, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-205, y=-5},
