	["0094_00190"] = {
		{"cgdel", id=22, lv=22, time=500, alphadel=1},
		{"cgdel", id=20, lv=20, time=0, alphadel=1},
		{"bg", id=20, file="bg23_1l_00000", x=400, y=100, lv=20, path=":bg/", sync=0, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="rin_01m_00002", file1="rin_01m_00101", file2="rin_01m_00225", path=":fg/rin_01m/", id=21, lv=21, head="rin_01m", ch_origin="凛", ch="凛21", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[1000] = {
				{"fg", file="rin_01m_00002", file1="rin_01m_00101", file2="rin_01m_00210", path=":fg/rin_01m/", id=21, lv=21, head="rin_01m", ch_origin="凛", ch="凛21", mw="mw", sync=0, timestamp=27, delay2=1000, mode=3, x=395, y=-5},
			},
			[999] = {
				{"transitiontime", time=300, timestamp=27, delay2=1000},
			},
		},
		text = {
			vo = {
				{"vo", file="rin0371", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“To that end, we will receive Katagiri into our order. There, she will be worshipped by all. Surely, she would be, ah-roused by such initiative?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“所以，我们才会接纳片桐，可以说最崇拜片桐的就是我们了。你觉得我们拥有谈判的主动权吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「所以，我們才會接納片桐，可以說最崇拜片桐的就是我們了。你覺得我們擁有談判的主動權嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00189",
		linknext = "0094_00191",
		line = 2938,
	},
	["0094_00191"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobb0090", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男B", "超絶頂志士"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男B", "Loyalist Cumming his Brains Out"},
					"“Don’t be ridiculous! If Katagiri is to be the next in line to serve as our god, then it is only proper that you drop the puns and speak to her with respect!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "超绝顶志士"},
					"“别说傻话了！对象是拥有着唯一真神的血统的片桐殿下的话，得要用最庄重的仪式来迎接她成为天子才行！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "超絕頂志士"},
					"「別說傻話了！對象是擁有著唯一真神的血統的片桐殿下的話，得要用最莊重的儀式來迎接她成為天子才行！」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00190",
		linknext = "0094_00192",
		line = 2950,
	},
	["0094_00192"] = {
		{"fg", file="schubert_01m_00002", file2="schubert_01m_00207", file4="schubert_01m_00402", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=22, lv=22, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト22", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="シューベルト22", id=22, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0374", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“My, oh my. I truly envy those who can get by in life without using their brains. Perhaps that is to be expected, soldiers knowing only how to fight. A lack of, what you’d call... kinktellect.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“哎啊，我好羡慕那些不用动脑就可以动作的盲从者啊⋯⋯武士跟战士说穿了也只是想要打架吧？这是变态知识不足才有的做法吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「哎啊，我好羨慕那些不用動腦就可以動作的盲從者啊⋯⋯武士跟戰士說穿了也只是想要打架吧？這是變態知識不足才有的做法吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00191",
		linknext = "0094_00193",
		line = 2965,
	},
	["0094_00193"] = {
		{"text"},
		text = {
