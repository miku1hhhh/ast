		{"bgm", file="bgm02", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00203", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=1, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...That’s why the opening of a hentai game should start with a flashback scene with the heroine. That’s a better way of getting the relationship across, don’t you think?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯所以啊，H GAME的开头应该要以女主为核心导入回忆画面吧。这样才能表现出深厚的关联性啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯所以啊，H GAME的開頭應該要以女主為核心導入回憶畫面吧。這樣才能表現出深厚的關聯性啊？」",
					{"rt2"},
				},
			},
		},
		linknext = "0094_00002",
		line = 22,
	},
	["0094_00002"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", file2="asane_01m_00203", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", alpha=0, ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=1, a_chr151=1, mode=3, x=195, y=-5},
		{"fgact", ch="麻沙音3", id=3, lv=3, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="麻沙音3", id=3, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1297", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Nah, that’s dumb. It should start with a sex scene obvs! That way players can get a good idea of the sexy potential the game’s got in store.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不，这才不可能呢，你还是先从H场景的角度切入吧。我们玩家会想要知道作品的尺度到底有多大啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不，這才不可能呢，你還是先從H場景的角度切入吧。我們玩家會想要知道作品的尺度到底有多大啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00001",
		linknext = "0094_00003",
		line = 37,
	},
	["0094_00003"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00204", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But there are a ton of games that do that already. Like, if there’re romantic comedy elements then a sex scene with a forgettable heroine feels pointless and distracts from the rest of the work.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“以拔作来说当然很不错，不过如果不添加一些像是爱情喜剧的元素进去的话，跟女主的做爱场景就会变得没有主轴，会降低集中力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「以拔作來說當然很不錯，不過如果不添加一些像是愛情喜劇的元素進去的話，跟女主的做愛場景就會變得沒有主軸，會降低集中力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00002",
		linknext = "0094_00004",
		line = 49,
	},
	["0094_00004"] = {
		{"fg", file="asane_01m_00001", file1="asane_01m_00101", file2="asane_01m_00203", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1298", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“But if you get off right at the start then you can use the refractory period to enjoy the mundane scenes and be ready to get your rocks off again using the branching sex scenes that come after!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那一开始就专注在让人能尻的实用性上啊，这样就可以在后面的日常片段里面享受专注的感觉，而且也能在游戏分歧之后享受激昂多样化的H场景啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那一開始就專注在讓人能尻的實用性上啊，這樣就可以在後面的日常片段裡面享受專注的感覺，而且也能在遊戲分歧之後享受激昂多樣化的H場景啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00003",
		linknext = "0094_00005",
		line = 64,
	},
	["0094_00005"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, we can at least agree that opening on a fight scene when there’s not even a combat system sucks, at least.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“总之，不管哪个角度切入，开场是那种非异能型的战斗场境的H GAME过然还是不行啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「總之，不管哪個角度切入，開場是那種非異能型的戰鬥場境的H GAME過然還是不行啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00004",
		linknext = "0094_00006",
		line = 76,
	},
	["0094_00006"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00101", file2="asane_02m_00204", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
