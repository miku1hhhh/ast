	["0094_00376"] = {
		{"fg", file="rin_01m_00002", file1="rin_01m_00106", file2="rin_01m_00216", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0392", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“And as if the pervert extremist groups weren’t bad enough, but members of my order were even absorbed into that new Crying Mole cult!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“结果变态激进份子就这样解散了，‘变态性教’也被‘哭鼠教’给吸收转化了⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「結果變態激進份子就這樣解散了，『變態性教』也被『哭鼠教』給吸收轉化了⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00375",
