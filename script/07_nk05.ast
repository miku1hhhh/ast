				},
			},
			tw = {
				{
					name = {"光姫"},
					"「你之前說過用肌肉來振興小島的計畫或許很不錯呢！在這裡放上器材，不管事放菜單還是鍛鍊都可以喔，呵呵呵──」",
					{"rt2"},
				},
			},
		},
