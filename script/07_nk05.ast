			tw = {
				{
					name = {"凛"},
					"「怎麼可能──！用肌肉來抵抗化學作用什麼的，這根本就不科學！！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00292",
		linknext = "0094_00294",
		line = 4456,
	},
	["0094_00294"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file3="jun_01f_00303", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You ever heard the saying, ‘your muscles will never betray you’?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“──你没有听过一句话吗？‘只有肌肉不会背叛你。’”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「──妳沒有聽過一句話嗎？『只有肌肉不會背叛你。』」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00293",
		linknext = "0094_00295",
		line = 4468,
	},
	["0094_00295"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Because it’s true. They’ll never betray their master.",
					{"rt2"},
				},
			},
			cn = {
				{
					"肌肉永远不会背叛主人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"肌肉永遠不會背叛主人。",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00294",
		linknext = "0094_00296",
		line = 4478,
	},
	["0094_00296"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There’s no chance they would ever indulge in pleasures against the will of their host.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以它们绝对不会违背宿主的意愿，随着外界的因素耽溺在快感之中。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以它們絕對不會違背宿主的意願，隨著外界的因素耽溺在快感之中。",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00295",
		linknext = "0094_00297",
		line = 4488,
	},
	["0094_00297"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s how we know that aphrodisiacs don’t work on muscles!",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说，春药对于肌肉是没有作用的──！",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說，春藥對於肌肉是沒有作用的──！",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00296",
		linknext = "0094_00298",
		line = 4498,
	},
