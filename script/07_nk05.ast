					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Great! I was sad losing our secret cover, but if you can make something out of it then that works for me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“太好了。没有了一时的皮膜我还觉得有点寂寞，要是这里能开店的话我也会很开心的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「太好了。沒有了一時的皮膜我還覺得有點寂寞，要是這裡能開店的話我也會很開心的。」",
					{"rt2"},
				},
			},
		},
