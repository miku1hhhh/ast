		text = {
			vo = {
				{"vo", file="rin0367", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Skeetus is a false god! All those who fail to serve the one true god will go straight to hell. I should make you kneel and lick my boots cleaner than the Hanamaru family line!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“赛克罗斯是什么鬼！？不信我神的人全部都会下地狱的，所以劝你还是皈依我教，跪下来花丸般地好好把我的鞋子给舔干净吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「賽克羅斯是什麼鬼！？不信我神的人全部都會下地獄的，所以勸你還是皈依我教，跪下來花丸般地好好把我的鞋子給舔乾淨吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00177",
		linknext = "0094_00179",
		line = 2745,
	},
	["0094_00179"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The lanky chick used to be a member of the former FS, so this was to be expected, but...",
					{"rt2"},
				},
			},
			cn = {
				{
					"唉，要是那个高个女是前FS的话，我大概都猜得到是谁了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"唉，要是那個高個女是前FS的話，我大概都猜得到是誰了。",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00178",
