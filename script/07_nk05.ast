	["0094_00181"] = {
		{"cgdel", id=26, lv=26, time=0, alphadel=1},
		{"fg", file="rin_01m_00002", file1="rin_01m_00101", file2="rin_01m_00225", path=":fg/rin_01m/", id=21, lv=21, head="rin_01m", ch_origin="凛", ch="凛21", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0368", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Not just the FS. We have some members of the old SHO here, too. All felt great pain at the annulment of the perverted sex law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“可不是只有FS而已喔。在这里的人都是前SHO的干部。所有人都对废除掉变态条例深感愤怒与心痛──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「可不是只有FS而已喔。在這裡的人都是前SHO的幹部。所有人都對廢除掉變態條例深感憤怒與心痛──」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00180",
		linknext = "0094_00182",
		line = 2786,
	},
	["0094_00182"] = {
		{"cgdel", id=20, lv=20, time=200, alphadel=1, sync=0, rule="eff_009_00000"},
		{"fg", mode=-1, id=21, ch="凛21", ch_origin="凛", lv=21, time=200, sync=0, rule="eff_009_00000"},
		{"fg", file="rei_02m_00001", file1="rei_02m_00102", file2="rei_02m_00203", path=":fg/rei_02m/", id=9, lv=8, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2073", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“So you lower yourselves to petty extremism?! Your ambition made you so sweet... I had no idea you would dirty your hands with such barbarism!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“然后你就成为了激进份子⋯⋯！我原本以为你虽然很有野心但也挺可爱的⋯⋯没想到你居然会使用这种残暴的手段！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「然後妳就成為了激進份子⋯⋯！我原本以為妳雖然很有野心但也挺可愛的⋯⋯沒想到妳居然會使用這種殘暴的手段！」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00181",
		linknext = "0094_00183",
		line = 2805,
	},
	["0094_00183"] = {
