					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Jun! Wh-What’s going on? They started talking about stuff I don’t understand... but they gave me really good tea! I can make you a cup if they let me take some home!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“淳⋯⋯！这、这到底是怎么回事⋯⋯！？从刚刚开始我就不懂你们在说什么⋯⋯还有这个茶是很不错的玉露呢，我等等要一些带回去泡给你们喝喔⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「淳⋯⋯！這、這到底是怎麼回事⋯⋯！？從剛剛開始我就不懂你們在說什麼⋯⋯還有這個茶是很不錯的玉露呢，我等等要一些帶回去泡給你們喝喔⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00149",
		linknext = "0094_00151",
		line = 2263,
	},
	["0094_00151"] = {
