		{"fgact", ch="麻沙音3", id=3, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1300", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You’re always getting those kindsa letters, huh? ‘Pleeeaaase, Nanase, lemme jam that clam! I’ll be waiting with dick in hand, just say the word!’ Total losers...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“在条例颁发前奈奈濑同学的鞋柜里就时常有很多这种‘请跟我打炮吧！我会在几点几分的时候充满欲火地等你的！’这种打炮信呢⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「在條例頒發前奈奈瀨同學的鞋櫃裡就時常有很多這種『請跟我打砲吧！我會在幾點幾分的時候充滿慾火地等妳的！』這種打砲信呢⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00013",
