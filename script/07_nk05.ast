	["0094_00122"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00212", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I didn’t see! But if they’re meeting after school then they can’t be far!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我没有看到！但是要是在放学之后见的话，应该不会太远才对！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我沒有看到！但是要是在放學之後見的話，應該不會太遠才對！」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00121",
		linknext = "0094_00123",
		line = 1857,
	},
	["0094_00123"] = {
		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00102", file2="ikuko_02m_00203", path=":fg/ikuko_02m/", id=10, lv=9, head="ikuko_02m", alpha=0, ch_origin="郁子", ch="郁子10", mw="mw", sync=1, a_chr151=1, mode=3, x=595, y=-5},
		{"fgact", ch="郁子10", id=10, lv=9, act="表示アクション", a1=0, a2=255, time=300, a_chr=151, alpha=255},
		{"fgact", ch="郁子10", id=10, act="移動", x=-200, y=0, time=300},
		{"fgact", ch="郁子10", id=10, act="浮遊", loop=-1, size=2.5, time=100, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2107", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“But that could be anywhere, even if we keep it to school grounds! It’s already been 20 minutes since classes ended. If we don’t hurry then we might never get to eat Nanase’s lunches ever again!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“但学校周边的范围也太广了吧！？而且都已经放学20多分钟了！不快一点的话连奈奈濑同学的便当都会被吃干抹净的──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「但學校周邊的範圍也太廣了吧！？而且都已經放學20多分鐘了！不快一點的話連奈奈瀨同學的便當都會被吃乾抹淨的──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00122",
		linknext = "0094_00124",
		line = 1873,
	},
	["0094_00124"] = {
