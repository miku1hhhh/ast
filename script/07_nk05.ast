			},
			cn = {
				{
					name = {"モブ男C", "超变态传教士"},
					"“奈奈濑洛斯大人说过，性爱是为了让真正相爱的人互相理解⋯⋯也就是说奈奈濑大人她平等地爱着所有人⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "超變態傳教士"},
					"「奈奈瀨洛斯大人說過，性愛是為了讓真正相愛的人互相理解⋯⋯也就是說奈奈瀨大人她平等地愛著所有人⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00354",
		linknext = "0094_00356",
		line = 5432,
	},
	["0094_00356"] = {
