			},
		},
		text = {
			vo = {
				{"vo", file="rin0365", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Naturally. We are lucky enough to be graced with the presence of the order’s founder, Kouki Senba, and our one, true god, Hamedori!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“那当然⋯⋯我们可是有宗师仙波光姬大人，还有身为唯一真神的Hamedori大人在呢──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「那當然⋯⋯我們可是有宗師仙波光姬大人，還有身為唯一真神的Hamedori大人在呢──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00172",
		linknext = "0094_00174",
		line = 2664,
	},
	["0094_00174"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Does she know she’s founded this... religion?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那个人，莫名其妙就成为了宗师吗⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那個人，莫名其妙就成為了宗師嗎⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00173",
		linknext = "0094_00175",
		line = 2676,
	},
	["0094_00175"] = {
		{"fg", file="rin_01m_00002", file1="rin_01m_00101", file2="rin_01m_00226", path=":fg/rin_01m/", id=21, lv=21, head="rin_01m", ch_origin="凛", ch="凛21", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="凛21", id=21, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0366", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“How rude! We are an above-board organization. We pay a tithe to the founder’s bank account on a monthly basis.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“真失礼，她才不是莫名其妙成为宗师的呢，我们可是每个月都好好地将宗师的供奉给汇到她的户头去的花丸班正经的教团呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「真失禮，她才不是莫名其妙成為宗師的呢，我們可是每個月都好好地將宗師的供奉給匯到她的戶頭去的花丸班正經的教團呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00174",
		linknext = "0094_00176",
		line = 2692,
	},
	["0094_00176"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So that’s where that money was coming from...",
					{"rt2"},
				},
			},
			cn = {
				{
					"原来那笔钱是这样来的啊⋯⋯",
					{"rt2"},
				},
			},
			tw = {
				{
					"原來那筆錢是這樣來的啊⋯⋯",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00175",
		linknext = "0094_00177",
		line = 2702,
	},
	["0094_00177"] = {
