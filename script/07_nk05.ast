	["0094_00189"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even though there’s really no reason for them to feel guilty.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但本来，她们就没有必要产生这种自责的念头的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但本來，她們就沒有必要產生這種自責的念頭的。",
