			cn = {
				{
					name = {"桐香"},
					"“把它忘记！把它们都忘记！每个人都会有因为空虚所以捏造出一个人格的时候啦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「把它忘記！把它們都忘記！每個人都會有因為空虛所以捏造出一個人格的時候啦！」",
					{"rt2"},
				},
			},
		},
