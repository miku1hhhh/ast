			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Wait, that’s Rin dressed in that weird outfit? The hell are you up to? Ran’s been worried sick waiting for you to go home!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“咦、穿着那种奇怪衣服的人是凛吗！？你到底在搞什么鬼啊，你姐姐兰正为了你没有回家担心得要死耶⋯⋯！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「咦、穿著那種奇怪衣服的人是凜嗎！？妳到底在搞什麼鬼啊，妳姊姊蘭正為了妳沒有回家擔心得要死耶⋯⋯！？」",
					{"rt2"},
				},
			},
		},
