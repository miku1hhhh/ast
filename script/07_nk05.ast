	},
	["0094_00090"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file3="ikuko_01m_00313", path=":fg/ikuko_01m/", id=10, lv=9, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2105", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“We’re not in the FS anymore. Our assignment is to investigate and dismantle these groups, but we don’t have any more authority than that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我们现在不是FS了喔～被给予的职责只有做调查跟把他们解散掉，除此之外没有其他的权限。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我們現在不是FS了喔～被給予的職責只有做調查跟把他們解散掉，除此之外沒有其他的權限。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00089",
		linknext = "0094_00091",
		line = 1325,
	},
	["0094_00091"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00212", path=":fg/rei_02m/", id=9, lv=8, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2068", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You could say that being assigned these duties keeps us in check. If we mess up then it’s a good enough excuse to evict us from the island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“交给我们这种任务，可以说本来就是为了牵制我们而已。要是做出任何不良动作的话，就可以不分青红皂白地把我们赶出岛了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「交給我們這種任務，可以說本來就是為了牽制我們而已。要是做出任何不良動作的話，就可以不分青紅皂白地把我們趕出島了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00090",
		linknext = "0094_00092",
		line = 1340,
	},
	["0094_00092"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=11, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
