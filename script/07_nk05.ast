		text = {
			vo = {
				{"vo", file="susuko0548", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Shtiiill, the shought neber occurred to deesh half-dreshed viiirginsh what might happen wid the pervert shecks law dishmantled...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“真是没有想到变态条例居然会是被辈前这种处男给瓦解掉的说⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「真是沒有想到變態條例居然會是被輩前這種處男給瓦解掉的說⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00067",
