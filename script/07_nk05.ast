	["0094_00238"] = {
		{"fg", file="nanase_01l_00001", file1="nanase_01l_00101", file2="nanase_01l_00220", path=":fg/nanase_01l/", id=4, lv=4, head="nanase_01l", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0948", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“To me, sex is something that connects us to the people we hold close. It’s a way to really understand the ones we want to know more about.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“对我来说，做爱这种事，是为了跟自己重视的人建立连结的⋯⋯是与真正互相理解的人，更深度了解彼此的一种手段。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「對我來說，做愛這種事，是為了跟自己重視的人建立連結的⋯⋯是與真正互相理解的人，更深度瞭解彼此的一種手段。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00237",
		linknext = "0094_00239",
		line = 3584,
	},
	["0094_00239"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She addresses to the room in desperation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她用尽全力地说着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她用盡全力地說著。",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00238",
		linknext = "0094_00240",
		line = 3594,
	},
	["0094_00240"] = {
		{"fg", file="nanase_01l_00001", file1="nanase_01l_00101", file2="nanase_01l_00223", path=":fg/nanase_01l/", id=4, lv=4, head="nanase_01l", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0949", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Our means may be different, but I feel that perverted sex is important, just like everyone else here does.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这在形式上虽然有点不同⋯⋯但对于变态做爱这种事是重要的这一点，其实大家的想法都是一样的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這在形式上雖然有點不同⋯⋯但對於變態做愛這種事是重要的這一點，其實大家的想法都是一樣的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00239",
		linknext = "0094_00241",
		line = 3609,
	},
	["0094_00241"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She appeals to each and every one of them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她向在场的每一个人强力诉说着。",
