					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "女学生C"},
					"“果然！奈奈濑酱就是神明大人啊⋯⋯！要不然想突破中出接力赛的第二阶段根本就是不可能的啊⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "女學生C"},
					"「果然！奈奈瀨醬就是神明大人啊⋯⋯！要不然想突破中出接力賽的第二階段根本就是不可能的啊⋯⋯！」",
					{"rt2"},
				},
			},
		},
