			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“We’re quite fond of our lives as they are now, so we want to avoid that if we can.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我们对现在的生活挺满意的。所以这是我们无论如何都要避免发生的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我們對現在的生活挺滿意的。所以這是我們無論如何都要避免發生的事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00091",
		linknext = "0094_00093",
		line = 1355,
	},
