		{"fg", file="rin_01m_00002", file1="rin_01m_00101", file2="rin_01m_00213", path=":fg/rin_01m/", id=21, lv=21, head="rin_01m", ch_origin="凛", ch="凛21", mw="mw", sync=0, time=200, rule="eff_008_00000", a_chr60=1, mode=3, x=-5, y=-5},
