				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“少说些冠冕堂皇的话，终归你也不过只是被出人头地的欲望冲昏头的女人罢了──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「少說些冠冕堂皇的話，終歸妳也不過只是被出人頭地的慾望沖昏頭的女人罷了──！」",
					{"rt2"},
				},
