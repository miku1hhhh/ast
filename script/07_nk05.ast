	["0094_00411"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00102", file2="ran_01m_00215", file4="ran_01m_00401", path=":fg/ran_01m/", id=13, lv=13, head="ran_01m", ch_origin="蘭", ch="蘭13", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="蘭13", id=13, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0197", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“I’ve been looking all over for you for days! I’ve been worried SICK! Why didn’t you come home?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“真是的，你这几天到底去了哪里啊！？你一直没有回家，我很担心耶！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「真是的，妳這幾天到底去了哪裡啊！？妳一直沒有回家，我很擔心耶！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00410",
		linknext = "0094_00412",
		line = 6398,
	},
	["0094_00412"] = {
		{"fg", file="rin_01f_00001", file1="rin_01f_00102", file2="rin_01f_00216", path=":fg/rin_01f/", id=30, ch="凛", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0408", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“It’s got nothing to do with you... What happened to your part-time job? How have you been getting by without our scholarship?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“跟姐姐你没有关系吧⋯⋯。再说了，你的打工怎么了。没有奖学金的话就算是我们家也会过得很辛苦吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「跟姊姊你沒有關係吧⋯⋯。再說了，妳的打工怎麼了。沒有獎學金的話就算是我們家也會過得很辛苦吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00411",
		linknext = "0094_00413",
		line = 6411,
	},
	["0094_00413"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00102", file2="ran_01m_00206", file4="ran_01m_00401", path=":fg/ran_01m/", id=13, lv=13, head="ran_01m", ch_origin="蘭", ch="蘭13", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="蘭13", id=13, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0198", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“I took time off to come look for you! I actually ended up taking so much time off that they cut me loose, dummy!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“不做了！我光是找人就忙得焦头烂额了，所以就被野炮店给开除了！真是的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「不做了！我光是找人就忙得焦頭爛額了，所以就被野砲店給開除了！真是的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00412",
		linknext = "0094_00414",
		line = 6427,
	},
	["0094_00414"] = {
		{"fg", file="rin_01f_00001", file1="rin_01f_00102", file2="rin_01f_00219", path=":fg/rin_01f/", id=30, ch="凛", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0409", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“I never asked you to do that... You should’ve known I’d be fine.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“不用担心我⋯⋯你应该知道我没事的吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「不用擔心我⋯⋯妳應該知道我沒事的吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00413",
		linknext = "0094_00415",
		line = 6440,
	},
	["0094_00415"] = {
