		{"fgact", ch="凛14", id=14, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0396", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Him! Junnosuke Tachibana! I will NOT let him get away with this!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“那个男人⋯⋯！橘淳之介⋯⋯！我绝对不会原谅那个男人的⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「那個男人⋯⋯！橘淳之介⋯⋯！我絕對不會原諒那個男人的⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00380",
		linknext = "0094_00382",
		line = 5868,
	},
	["0094_00382"] = {
		{"fg", file="rin_01m_00002", file1="rin_01m_00101", file2="rin_01m_00213", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0397", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“But knowing his name has opened so many doors. I’ll get that gloomy shut-in sister of his and cripple her with the same aphrodisiac!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“不过，只要知道了名字，要对付他的方式就多了。干脆把他那个阴沉的妹妹当人质，用一样的春药把她搞成废人吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「不過，只要知道了名字，要對付他的方式就多了。乾脆把他那個陰沈的妹妹當人質，用一樣的春藥把她搞成廢人吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00381",
		linknext = "0094_00383",
		line = 5883,
	},
	["0094_00383"] = {
		{"fg", file="rin_01m_00002", file1="rin_01m_00101", file2="rin_01m_00211", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0398", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Or I could REALLY give it to him by telling everyone that Nanase Katagiri’s boyfriend was the one who destroyed the perverted sex law!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“而且，片桐奈奈濑的恋人就是摧毁了变态条例的罪魁祸首的本人，这也是很好的煽动素材呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「而且，片桐奈奈瀨的戀人就是摧毀了變態條例的罪魁禍首的本人，這也是很好的煽動素材呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00382",
		linknext = "0094_00384",
		line = 5898,
	},
	["0094_00384"] = {
		{"fg", file="rin_01m_00002", file1="rin_01m_00101", file2="rin_01m_00214", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
