				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Muscles are a constant war with oneself. That’s why we temper ourselves to have a strong will.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为锻炼肌肉是一场与自己的战斗，要用强大的意志来‘锻炼’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為鍛鍊肌肉是一場與自己的戰鬥，要用強大的意志來『鍛鍊』。」",
					{"rt2"},
				},
			},
		},
