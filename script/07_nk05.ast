	["0094_00062"] = {
		{"bgm", file="bgm09", vol=100},
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=8, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2065", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Yesterday evening, we were able to apprehend one of the leaders of a pervert extremist group with the help of Katagiri and yourself. We promptly interrogated her after.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“昨晚，多亏了橘跟片桐的帮忙，我们成功逮到了变态激进份子的首领。我们之后也对她进行了审讯。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「昨晚，多虧了橘跟片桐的幫忙，我們成功逮到了變態激進份子的首領。我們之後也對她進行了審訊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00061",
		linknext = "0094_00063",
		line = 918,
	},
	["0094_00063"] = {
