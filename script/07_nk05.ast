	["0094_00087"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The FS Big Three need to crack down on the FS of old...",
					{"rt2"},
				},
			},
			cn = {
				{
					"在面对前FS们的取缔，FS的三巨头──",
					{"rt2"},
				},
			},
			tw = {
				{
					"在面對前FS們的取締，FS的三巨頭──",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00086",
		linknext = "0094_00088",
		line = 1286,
	},
	["0094_00088"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If your opponents have weapons, are you allowed to use force?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯要是对方有武器的话，只靠实力不是没有用吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯要是對方有武器的話，只靠實力不是沒有用嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00087",
		linknext = "0094_00089",
		line = 1298,
	},
	["0094_00089"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00203", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“To be fair, even without weapons, with your abilities you could leap into any situation and take out anyone who looks suspicious.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“以你们的能力来说，要是对方没有武器的话，马上可以踏进任何怀疑的地方把他们一网打尽──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「以妳們的能力來說，要是對方沒有武器的話，馬上可以踏進任何懷疑的地方把他們一網打盡──」",
					{"rt2"},
				},
			},
		},
