	["0094_00105"] = {
		{"bgm", file="bgm09.5", vol=100},
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00106", file3="tohka_02m_00304", path=":fg/tohka_02m/", id=8, lv=11, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="桐香8", id=8, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00203", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=11, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Seriously though, if we can’t use military force, then how do you intend to deal with these people?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过，要是不能动武的话，你们打算怎么做？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過，要是不能動武的話，妳們打算怎麼做？」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00104",
		linknext = "0094_00106",
		line = 1552,
	},
	["0094_00106"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00215", path=":fg/tohka_02m/", id=8, lv=11, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00204", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=11, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Like, it’d be tough enough avoiding all-out war if it were a well-armed organization, but how do you dismantle something like this?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不对，如果是那样的武装组织的话，很难避免掉打起来。能瓦解他们的方式──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不對，如果是那樣的武裝組織的話，很難避免掉打起來。能瓦解他們的方式──」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00105",
		linknext = "0094_00107",
		line = 1567,
	},
	["0094_00107"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00206", path=":fg/susuko_02m/", id=11, lv=10, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-205, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0551", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“It ain’t gonna be all that hard, actually. These perv extremists aren’t that big a deal, even with the Erect Elect in there. S’just some mish-mash of different organizations at the end of the day.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“没有这种事喔。包括我们‘茎选组’在内的变态激进们子们并不团结。因为我们本来就是各种不同的组织聚集起来的嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「沒有這種事喔。包括我們『莖選組』在內的變態激進們子們並不團結。因為我們本來就是各種不同的組織聚集起來的嘛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00106",
		linknext = "0094_00108",
		line = 1581,
	},
	["0094_00108"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00218", path=":fg/susuko_02m/", id=11, lv=10, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-205, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0552", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“So while they look like some united force on the surface, we gotta check to see who’s trying to seize control beneath the waves, innit!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“所以虽然表免上我们是合作关系，不过私底下却是看谁握有主导权、尤其他的势力互相牵制的状态喔！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「所以雖然表免上我們是合作關係，不過私底下卻是看誰握有主導權、尤其他的勢力互相牽制的狀態喔！」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00107",
		linknext = "0094_00109",
		line = 1596,
	},
	["0094_00109"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00203", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=11},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And that’s when we strike—when they let their guard down, you mean? But how do we do that from the outside?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你的意思是要我们利用这点吗⋯⋯？不过如果不实际渗透的话要怎么做到⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳的意思是要我們利用這點嗎⋯⋯？不過如果不實際滲透的話要怎麼做到⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00108",
		linknext = "0094_00110",
		line = 1608,
	},
	["0094_00110"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00204", path=":fg/susuko_02m/", id=11, lv=10, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-205, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0553", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“We’ll need some sort of beacon or idol to really penetrate ’em. Someone who’ll really encourage more folk to join one side over the other.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“他们这些支持变态行为的组织在寻求一个可以被崇拜的对象，也就是偶像！因为，为了吸引更多的人，能拥有这样的一个人在是很重要的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「他們這些支持變態行為的組織在尋求一個可以被崇拜的對象，也就是偶像！因為，為了吸引更多的人，能擁有這樣的一個人在是很重要的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00109",
		linknext = "0094_00111",
		line = 1623,
	},
	["0094_00111"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00203", path=":fg/rei_01m/", id=9, lv=8, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2069", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You mean the only way to tip the scales is by giving support to some symbolic icon of perversion?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“换句话说，打破了这个平衡，就是支持变态行为的象征性存在。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「換句話說，打破了這個平衡，就是支持變態行為的象徵性存在。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00110",
		linknext = "0094_00112",
		line = 1637,
	},
	["0094_00112"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00204", path=":fg/ikuko_01m/", id=10, lv=9, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2106", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Someone everyone knows, who has influence... and is super popular... Kinda like a pop idol.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“有知名度、也有向心力，还有像偶像一样人气的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「有知名度、也有向心力，還有像偶像一樣人氣的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00111",
		linknext = "0094_00113",
		line = 1651,
	},
	["0094_00113"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00204", path=":fg/tohka_02m/", id=8, lv=11, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1837", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Someone like... Nanase Katagiri.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“也就是说──那个人是，片桐奈奈濑同学。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「也就是說──那個人是，片桐奈奈瀨同學。」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00112",
		linknext = "0094_00114",
		line = 1666,
	},
	["0094_00114"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Back when the perverted sex law was enforced, her influence as the island’s charismatic slut was felt even on the mainland. That’s how popular she was.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从颁布了变态条例开始，她就一直以“万人迷婊子”的身份在岛内外有着压倒性的人气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從頒布了變態條例開始，她就一直以「萬人迷婊子」的身份在島內外有著壓倒性的人氣。",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00113",
		linknext = "0094_00115",
		line = 1676,
	},
	["0094_00115"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even with the law repealed she’d be famous enough to approach all kinds of organizations.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使是在变态条例瓦解后，她也依旧是个会被各种组织招揽的名人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使是在變態條例瓦解後，她也依舊是個會被各種組織招攬的名人。",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00114",
		linknext = "0094_00116",
		line = 1686,
	},
	["0094_00116"] = {
		{"fgact", ch="桐香8", id=8, lv=11, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"fgact", ch="礼9", id=9, lv=8, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"fgact", ch="郁子10", id=10, lv=9, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"fgact", ch="スス子11", id=11, lv=10, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What kind of pervy extremist group would approach a girl like that...",
					{"rt2"},
				},
			},
			cn = {
				{
					"这样的一个女子，是每一个变态激进派都会追捧的存在──",
					{"rt2"},
				},
			},
			tw = {
				{
					"這樣的一個女子，是每一個變態激進派都會追捧的存在──",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00115",
		linknext = "0094_00117",
		line = 1704,
	},
