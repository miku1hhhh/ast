					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Which is why we’re here. We’ve come to put an end to all of this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我才不管呢，我就是来阻止你们的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我才不管呢，我就是來阻止你們的。」",
					{"rt2"},
				},
