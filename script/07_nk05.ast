		{"fg", file="rin_01m_00002", file1="rin_01m_00102", file2="rin_01m_00222", path=":fg/rin_01m/", id=21, lv=21, head="rin_01m", ch_origin="凛", ch="凛21", mw="mw", sync=0, time=200, rule="eff_008_00000", a_chr60=1, mode=3, x=-5, y=-5},
		{"fgact", ch="凛21", id=21, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0362", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Ugh, enough with the pedantic bullshit!! Read the freaking room, would you? This is a deeply serious meeting!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“吵死了，你这个亚斯伯格学生会长！！给我看一下场面啦！！我们在开很重要的会议！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「吵死了，妳這個亞斯伯格學生會長！！給我看一下場面啦！！我們在開很重要的會議！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00166",
		linknext = "0094_00168",
		line = 2568,
	},
	["0094_00168"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00203", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
