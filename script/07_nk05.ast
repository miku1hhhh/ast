		{"fgact", ch="凛21", id=21, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0369", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Oh, frustrated, are we? You can’t make a scene for fear of being linked with us, and that would be sooo terrible for you, wouldn’t it? How does it feel not being in charge anymore?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“是喔？那我们干脆来打一架啊？要是真的打起来，在场的所有人不就都会变成战友，这样施展不开是吗？嗯？前任的高层？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「是喔？那我們乾脆來打一架啊？要是真的打起來，在場的所有人不就都會變成戰友，這樣施展不開是嗎？嗯？前任的高層？」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00182",
		linknext = "0094_00184",
		line = 2822,
	},
