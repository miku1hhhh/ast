			cn = {
				{
					name = {"シューベルト", "假面舞会・舒"},
					"“那是你们的理论吧？按照我的数据显示，片桐同学应该要成为我们“痴情欧齁性处理学会”的理事长，从变态统计数字的角度来看──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "假面舞會・舒"},
					"「那是你們的理論吧？按照我的數據顯示，片桐同學應該要成為我們「癡情歐齁性處理學會」的理事長，從變態統計數字的角度來看──」",
					{"rt2"},
				},
			},
		},
