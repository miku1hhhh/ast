		text = {
			vo = {
				{"vo", file="ikuko2109", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Phew, it’s been a while since I swung a sword. I managed to stop the vial before it got them though!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我很久没有拔刀了，能成功真是太好了～在打到人之前就把瓶子给砍断了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我很久沒有拔刀了，能成功真是太好了～在打到人之前就把瓶子給砍斷了呢。」",
					{"rt2"},
				},
