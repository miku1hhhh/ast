		text = {
			vo = {
				{"vo", file="tohka1839", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Hey, Rin, can you even be a holy maiden if you’re not a virgin? Or have we gotten past that kind of discrimination these days?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呐、凛同学。巫女的话不是一定得要是处女才行吗？啊、还是说现在这样会是一种歧视所以不能限制了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「吶、凜同學。巫女的話不是一定得要是處女才行嗎？啊、還是說現在這樣會是一種歧視所以不能限制了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0094_00165",
		linknext = "0094_00167",
		line = 2551,
	},
	["0094_00167"] = {
		{"bg", id=20, file="bg23_1l_00000", x=400, y=100, lv=20, path=":bg/", sync=0, ax=1290, ay=730, bx=-490, by=-280},
