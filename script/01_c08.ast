				{"fg", file="rin_01l_00001", file1="rin_01l_00102", file2="rin_01l_00220", path=":fg/rin_01l/", id=14, lv=14, head="rin_01l", ch_origin="凛", ch="凛14", mw="mw", sync=0, timestamp=2, delay2=1000, mode=3, x=-5, y=-5},
			},
			[999] = {
				{"transitiontime", time=300, timestamp=2, delay2=1000},
			},
		},
		text = {
			vo = {
				{"vo", file="rin0062", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Argh... T-This is an abuse of authority! Misappropriation of the FS for private use! You’re running afoul of Skeetus’s wishes too! Mizuhiki, let’s report them to the SHO and look down on them all!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“呜咕……职、职权滥用！将FS私有化！这违反了塞克罗斯大人的意志啊！去和SHO报告此事将学生会长们降职吧水引同学！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「嗚咕……職、職權濫用！將FS私有化！這違反了塞克羅斯大人的意志啊！去和SHO報告此事將學生會長們降職吧水引同學！」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00029",
		linknext = "0009_00031",
		line = 417,
	},
	["0009_00031"] = {
		{"fgact", ch="凛14", id=14, act="移動", x=-500, y=0, time=800},
		{"fg", file="mizuhiki_01l_00001", file1="mizuhiki_01l_00102", file2="mizuhiki_01l_00222", file4="mizuhiki_01l_00401", path=":fg/mizuhiki_01l/", id=15, lv=15, head="mizuhiki_01l", alpha=0, ch_origin="水引", ch="水引15", mw="mw", sync=1, a_chr151=1, mode=3, x=795, y=-5},
		{"fgact", ch="水引15", id=15, lv=15, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="水引15", id=15, act="移動", x=-300, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0020", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“But this is a plan to capture the Birds of a Feather, right? Those are SHO orders, and it does seem in line with the FS’s principles of conduct...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“但这是为了捕捉‘Tori公’们的计划吧？SHO也有下这道命令，这似乎也适用于FS的行动理念……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「但這是為了捕捉『Tori公』們的計畫吧？SHO也有下這道命令，這似乎也適用於FS的行動理念……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00030",
		linknext = "0009_00032",
		line = 433,
	},
	["0009_00032"] = {
