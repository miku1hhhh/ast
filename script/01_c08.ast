		text = {
			vo = {
				{"vo", file="rin0063", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“That’s up to how you go about it. If we say the FS is trying to conduct mass erotic hypnosis then go and make a recording on our own, we’ll have an unbreakable alibi.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“这当然和做法有关啊。如果被举报FS借由活动使用色色催眠进行集体催眠，而实际上也将催眠声录下的话，就证据确凿了啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「這當然和做法有關啊。如果被舉報FS藉由活動使用色色催眠進行集體催眠，而實際上也將催眠聲錄下的話，就證據確鑿了啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00031",
		linknext = "0009_00033",
		line = 451,
	},
	["0009_00033"] = {
