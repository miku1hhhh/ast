		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0164", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“...And so we’d like to hold another event as the FS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“……因此，我想要再次用FS来展开活动。”",
