	["0009_00037"] = {
		{"fg", file="schubert_01m_00002", file2="schubert_01m_00202", file4="schubert_01m_00402", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=495, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0080", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“We haven’t had this little time to prepare for an event since the last Shootdown King... I wasn’t in the FS then and couldn’t gather data on it, so I can’t wait...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“准备期间这么短的活动，也只有上次的‘撃坠王’了吧……当时还不是FS所以还不能收集数据，真期待呢……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「準備期間這麼短的活動，也只有上次的『撃墜王』了吧……當時還不是FS所以還不能收集數據，真期待呢……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00036",
		linknext = "0009_00038",
		line = 535,
	},
	["0009_00038"] = {
		{"fg", mode=-1, id=11, ch="スス子11", ch_origin="スス子", lv=11, time=0, sync=0},
		{"fg", mode=-1, id=12, ch="シューベルト12", ch_origin="シューベルト", lv=12, time=0, sync=0},
		{"fg", file="mizuhiki_01m_00001", file1="mizuhiki_01m_00102", file2="mizuhiki_01m_00229", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"fg", file="rin_01m_00001", file1="rin_01m_00101", file2="rin_01m_00226", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="凛14", id=14, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0064", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“I don’t like this! Anything that makes me feel bad is unacceptable! Everyone needs to compromise with me by not doing it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“我讨厌这样！这种让人不愉快的事我是绝对不认同的！大家应该要听我的不要同意！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「我討厭這樣！這種讓人不愉快的事我是絕對不認同的！大家應該要聽我的不要同意！」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00037",
		linknext = "0009_00039",
		line = 555,
	},
	["0009_00039"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00213", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aren’t you sounding a lot like that group from two days ago?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你和前天那些家伙说了一样的话吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳和前天那些傢伙說了一樣的話吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00038",
		linknext = "0009_00040",
		line = 567,
