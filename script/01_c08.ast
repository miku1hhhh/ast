	["0009_00043"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We get straight to a meeting in the student council room after classes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"放学后，我们马上就去了学生会办公室进行讨论。",
					{"rt2"},
				},
			},
			tw = {
				{
					"放學後，我們馬上就去了學生會辦公室進行討論。",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00042",
		linknext = "0009_00044",
		line = 675,
	},
	["0009_00044"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After all, there’s barely any time to plan. We’ve suddenly found ourselves needing to begin preparations tomorrow.",
					{"rt2"},
				},
			},
			cn = {
				{
					"毕竟要从明天就开始准备，所以几乎没有计划的时间。",
					{"rt2"},
				},
			},
			tw = {
				{
					"畢竟要從明天就開始準備，所以幾乎沒有計劃的時間。",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00043",
		linknext = "0009_00045",
		line = 685,
	},
	["0009_00045"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00201", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0168", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Our goal here is to use this event to deploy SHO and FS security in an anomalous manner.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“这次的目的，在于利用活动将SHO和FS的警戒网改造成一种特殊的形式。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「這次的目的，在於利用活動將SHO和FS的警戒網改造成一種特殊的形式。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00044",
		linknext = "0009_00046",
		line = 700,
	},
	["0009_00046"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The NLNS has escape patterns to handle standard deployments, making it easy for them to escape without detection. I imagine that encircling them would be impossible as well.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“通常配置下，NLNS的逃逸模式很难被发现，容易逃脱。几乎无法包围。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「通常配置下，NLNS的逃逸模式很難被發現，容易逃脫。幾乎無法包圍。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00045",
		linknext = "0009_00047",
		line = 712,
	},
	["0009_00047"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00211", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0160", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“We don’t have the authority to change SHO security deployments, so the plan is to hold an event and force them to be stationed in a special way. Right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“郁等人没有权力切换SHO的警备配置，所以借由活动展开时的特殊形式强行执行对吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「郁等人沒有權力切換SHO的警備配置，所以藉由活動展開時的特殊形式強行執行對吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00046",
		linknext = "0009_00048",
		line = 726,
	},
	["0009_00048"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00201", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0174", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“We’ll have the students return to the academy after the event and wait for the Birds of a Feather, or the NLNS, to strike. It’s an expanded version of the tactic used during the Shootdown King.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“活动结束后，学生们回学园汇整，等待‘Tori公’也就是NLNS掉入陷阱……就像桐香大人在“撃坠王”时使用的战法的放大版。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「活動結束後，學生們回學園彙整，等待『Tori公』也就是NLNS掉入陷阱……就像桐香大人在「撃墜王」時使用的戰法的放大版。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00047",
		linknext = "0009_00049",
		line = 740,
	},
