	["0009_00055"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00213", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0161", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Having read the reports, it seems they’ve passed the work entirely on to us, saying that we’re the ones who need to take care of them because they’re Minotsuki students.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我读了报告书，似乎全部交给我们来办。因为是水乃月的学生的事，所以结果也要自行收拾的样子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我讀了報告書，似乎全部交給我們來辦。因為是水乃月的學生的事，所以結果也要自行收拾的樣子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00054",
		linknext = "0009_00056",
		line = 825,
	},
	["0009_00056"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00213", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So they’re not taking any responsibility for it? Is the SHO in this world really okay...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也太甩手掌柜了吧。没问题吗，这边的SHO……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也太甩手掌櫃了吧。沒問題嗎，這邊的SHO……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00055",
