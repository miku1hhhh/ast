			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“According to Schubert and Susuko’s report, the armory’s inventory count really does seem to be off. It’s possible that the SHO is becoming a pretty corrupt organization here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“在舒伯特和丝丝子的报告中，武器库的备品数量果然不吻合。这个世界的SHO，可能彻底堕落了吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「在舒伯特和絲絲子的報告中，武器庫的備品數量果然不吻合。這個世界的SHO，可能徹底墮落了吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00056",
		linknext = "0009_00058",
		line = 852,
	},
	["0009_00058"] = {
