	["0009_00025"] = {
		{"bgm", file="bgm09", vol=100},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Touka says this to a gathering of the entire FS as though it’s business as usual.",
					{"rt2"},
				},
			},
			cn = {
				{
					"桐香在聚集FS所有成员的集会中，一如往常地发言。",
					{"rt2"},
				},
			},
			tw = {
				{
					"桐香在聚集FS所有成員的集會中，一如往常地發言。",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00024",
		linknext = "0009_00026",
		line = 334,
	},
	["0009_00026"] = {
		{"bg", id=13, file="bg23_1l_00000", x=0, y=0, lv=13, path=":bg/", sync=0, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="rin_01l_00001", file1="rin_01l_00102", file2="rin_01l_00209", path=":fg/rin_01l/", id=14, lv=14, head="rin_01l", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
