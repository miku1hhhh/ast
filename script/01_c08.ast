	["0009_00051"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If we capture the NLNS, the leader of the Birds of a Feather will definitely show up to save them. That’s what matters here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只要能确保NLNS的存在，‘Tori公’的首领绝对会现身救援的。这时只要能抓住它就好了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只要能確保NLNS的存在，『Tori公』的首領絕對會現身救援的。這時只要能抓住它就好了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00050",
		linknext = "0009_00052",
		line = 772,
	},
	["0009_00052"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00214", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0169", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“If we can tell the FS and SHO guards to form an encirclement to get them to stand by, we should be able to quickly learn of any suspicious individuals approaching us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“让几名警戒的SHO和FS以展开包围网的名义待机，只要有可疑的人影接近马上就能知道了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「讓幾名警戒的SHO和FS以展開包圍網的名義待機，只要有可疑的人影接近馬上就能知道了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00051",
		linknext = "0009_00053",
		line = 787,
	},
	["0009_00053"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The SHO has given the FS strict orders to capture the Birds of a Feather, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是SHO对FS严格表示要确保‘Tori公’了吧！”",
