		{"fgact", ch="凛14", id=14, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[3500] = {
				{"fg", file="rin_01l_00001", file1="rin_01l_00102", file2="rin_01l_00203", path=":fg/rin_01l/", id=14, lv=14, head="rin_01l", ch_origin="凛", ch="凛14", mw="mw", sync=0, timestamp=1, delay2=3500, mode=3, x=-5, y=-5},
			},
			[3499] = {
				{"transitiontime", time=300, timestamp=1, delay2=3500},
			},
		},
		text = {
			vo = {
				{"vo", file="rin0060", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Wi-With no preparation whatsoever, just like that?! The Lewd Code is right around the corner too, what are you thinking?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“什……什么事前准备都没有就突然开始吗！？变态法也迫在眉梢了，这是在想什么啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「什……什麼事前準備都沒有就突然開始嗎！？變態法也迫在眉梢了，這是在想什麼啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00025",
		linknext = "0009_00027",
		line = 353,
	},
	["0009_00027"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As you might expect, the younger Hanamaru immediately protests.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正如我所想，花丸妹马上就上钩了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正如我所想，花丸妹馬上就上鉤了。",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00026",
		linknext = "0009_00028",
		line = 363,
	},
	["0009_00028"] = {
		{"fg", file="rin_01l_00001", file1="rin_01l_00102", file2="rin_01l_00203", path=":fg/rin_01l/", id=14, lv=14, head="rin_01l", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0061", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Failure would hinder the USP plan! Even a small careless mistake by any one of you dunces will get written up by every scandal-hungry lamestream media outlet out there!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“失败的话就会对USD计划造成阻碍喔！这种时候就算只是有点粗心大意，也会被闻腥而来的无良媒体们大肆报导的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「失敗的話就會對USD計劃造成阻礙喔！這種時候就算只是有點粗心大意，也會被聞腥而來的無良媒體們大肆報導的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00027",
		linknext = "0009_00029",
		line = 378,
	},
	["0009_00029"] = {
		{"cgdel", id=13, lv=13, time=0, alphadel=1},
		{"fg", mode=-1, id=14, ch="凛14", ch_origin="凛", lv=14, time=0, sync=0},
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00202", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00203", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="礼9", id=9, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0173", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“We’ll put together a careful plan to keep that from happening. Or are you saying that you’ve gotten to be so important that you can talk back to the president of the disciplinary committee?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“为了不造成这种局面，我们更要仔细制定计划。还是说凛，你厉害到能让FS风纪委员长闭嘴了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「為了不造成這種局面，我們更要仔細制定計畫。還是說凛，妳厲害到能讓FS風紀委員長閉嘴了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00028",
		linknext = "0009_00030",
		line = 398,
	},
	["0009_00030"] = {
		{"bg", id=13, file="bg23_1l_00000", x=0, y=0, lv=13, path=":bg/", sync=0, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="rin_01l_00001", file1="rin_01l_00102", file2="rin_01l_00217", path=":fg/rin_01l/", id=14, lv=14, head="rin_01l", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
