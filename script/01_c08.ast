		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0167", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Now that everyone’s on board, I’d like to move on to the details of the event.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“感谢大家的配合，接下来讨论详细的活动内容吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「感謝大家的配合，接下來討論詳細的活動内容吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00041",
