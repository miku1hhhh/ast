	["0009_00040"] = {
		{"fgact", ch="凛14", id=14, lv=14, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"fgact", ch="水引15", id=15, lv=15, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I suppose we have Touka’s charisma to thank for none of the other FS members grumbling about it, though.",
					{"rt2"},
				},
			},
			cn = {
				{
					"能让其他FS成员不提出不满，应该说不愧是桐香的魅力吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"能讓其他FS成員不提出不滿，應該說不愧是桐香的魅力吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00039",
		linknext = "0009_00041",
		line = 581,
	},
	["0009_00041"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00201", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00202", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="桐香8", id=8, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0166", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“We’ll be holding it in five days, then. Details will come via summary by tomorrow. I want each squad to understand their responsibilities so we can make this a fun, healthy, and perverted event.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“那就在5天后举行。详细内容明日会进行讨论并配发资料。请各部门确实把握好负责的部分，让我们共创活泼快乐的变态活动吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「那就在5天後舉行。詳細內容明日會進行討論並配發資料。請各部門確實把握好負責的部分，讓我們共創活潑快樂的變態活動吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0009_00040",
		linknext = "0009_00042",
		line = 598,
	},
