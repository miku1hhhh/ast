		},
		text = {
			vo = {
				{"vo", file="schubert0344", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Damn it... Um, well, it’s just someone I’ve seen around campus, I don’t know her name...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“真伤脑筋……呃──名字我不知道。只是在学园里面见过一次……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「真傷腦筋……呃──名字我不知道。只是在學園裡面見過一次……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00307",
		linknext = "0083_00309",
		line = 4016,
	},
	["0083_00309"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh! So, Shu, what’s she like?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“喔──！快说说是什么样的人啊舒君……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「喔──！快說說是什麼樣的人啊舒君……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00308",
		linknext = "0083_00310",
		line = 4028,
	},
	["0083_00310"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00213", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0345", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“I only ran into her accidently... I was spacing out in the corner of the gym during a school assembly... and I tripped over her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“遇见她真的只是偶然……在全校集合的时候，她缩在体育馆的角落里……而我没有注意到，不小心被她给绊倒了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「遇見她真的只是偶然……在全校集合的時候，她縮在體育館的角落裡……而我沒有注意到，不小心被她給絆倒了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00309",
		linknext = "0083_00311",
		line = 4043,
	},
	["0083_00311"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
