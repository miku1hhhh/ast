				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“那三个人不知怎么的感情突然变好了呢……橘君能交到朋友，身为委员长我实在是非常花丸欢喜……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「那三個人不知怎麼的感情突然變好了呢……橘君能交到朋友，身為委員長我實在是非常花丸歡喜……！」",
					{"rt2"},
				},
			},
		},
