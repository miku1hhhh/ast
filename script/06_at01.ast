	["0083_00456"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0400", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You have a chance, Bro... If you decide you want to use it, you can... I can’t do anything with these except touch them when I masturbate and maybe traditional Seiran Island nipple calligraphy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“老哥明明就有吧……只要想用，随时都用得上不是吗……哪像我只有在自慰的时候摸一摸和在进行青蓝岛特产乳头新年书道的时候才有使用机会喔……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「老哥明明就有吧……只要想用，隨時都用得上不是嗎……哪像我只有在自慰的時候摸一摸和在進行青藍島特產乳頭新年書道的時候才有使用機會喔……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00455",
		linknext = "0083_00457",
		line = 6154,
	},
	["0083_00457"] = {
