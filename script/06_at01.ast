	["0083_00419"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I have no idea what kind of lifestyle leads to nightmares like that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"到底要用什么态度生活才会做这种恶梦啊？",
					{"rt2"},
				},
			},
			tw = {
				{
					"到底要用什麼態度生活才會做這種惡夢啊？",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00418",
		linknext = "0083_00420",
		line = 5627,
	},
	["0083_00420"] = {
		{"fg", file="asane_02m_00008", file1="asane_02m_00101", file2="asane_02m_00211", file4="asane_02m_00402", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0386", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I just wanted to make a delicious stew for my dear brother! I knew in the dream I needed old lady broth to do it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“妹妹想要做好吃的饭给老哥吃嘛～！在梦里我就觉得老太婆熬出来的汤无论如何都是必要的啊～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「妹妹想要做好吃的飯給老哥吃嘛～！在夢裡我就覺得老太婆熬出來的湯無論如何都是必要的啊～！」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00419",
		linknext = "0083_00421",
		line = 5642,
	},
	["0083_00421"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00206", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
