			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well then, I’ll make you miso soup with Grandma’s recipe next time...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样啊，那下次我会用老奶奶熬出来的汤做味噌汤给你喝……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣啊，那下次我會用老奶奶熬出來的湯做味噌湯給妳喝……」",
					{"rt2"},
				},
			},
		},
