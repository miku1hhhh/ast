		text = {
			vo = {
				{"vo", file="asane0393", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yay, sleeping with Bro, sleeping with Bro! That’s little sister privilege, eat it Fumino! Ranked, thanks for playing, gg no re!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哇──哇──，跟老哥一起睡、跟老哥一起睡……！这是文乃没有的妹妹特权好啦我赢了排名结束，感谢对战、GG、谢谢大家！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哇──哇──，跟老哥一起睡、跟老哥一起睡……！這是文乃沒有的妹妹特權好啦我贏了排名結束，感謝對戰、GG、謝謝大家！」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00437",
