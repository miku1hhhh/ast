	["0083_00072"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I was just as awkward as he was though, so I couldn’t really gauge the distance between us.",
					{"rt2"},
				},
