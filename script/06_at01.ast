		text = {
			vo = {
				{"vo", file="mizuhiki0584", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“For another example of the type... Yeah, look there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“要说其他属于同一种类型的……来了，喏。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「要說其他屬於同一種類型的……來了，喏。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00338",
		linknext = "0083_00340",
		line = 4489,
	},
	["0083_00340"] = {
		{"bg", id=20, file="bg15_1_1l_00000", x=0, y=0, lv=20, path=":bg/", sync=0, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=21, lv=21, head="tohka_02m", ch_origin="桐香", ch="桐香21", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=500},
		{"fgact", ch="桐香21", id=21, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1725", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“...Right, pass these documents around the SHO. The receipts too. I’ll put together a budget report, so you can pass that on to the student council, okay?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“……对，那份文件请转交给SHO。收据也一样。预算表我之后会整理好的，所以请先送到学生会去吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「……對，那份文件請轉交給SHO。收據也一樣。預算表我之後會整理好的，所以請先送到學生會去吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00339",
		linknext = "0083_00341",
		line = 4505,
	},
	["0083_00341"] = {
		{"cgdel", id=20, lv=20, time=300, alphadel=1, sync=0, rule="eff_009_00000"},
		{"fg", mode=-1, id=21, ch="桐香21", ch_origin="桐香", lv=21, time=300, sync=0, rule="eff_009_00000"},
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00209", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=21, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Look, a pretty girl...! She’s not from our team, but still!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“出现了，总而言之脸长得就是好看的女人……！虽然不是我们队里的人啦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「出現了，總而言之臉長得就是好看的女人……！雖然不是我們隊裡的人啦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00340",
		linknext = "0083_00342",
		line = 4521,
	},
	["0083_00342"] = {
		{"fg", file="schubert_01m_00002", file2="schubert_01m_00203", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0354", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“True, the president is good-looking. And a rare type. You don’t see them much even on TV. She’s very pretty, but—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“没错。会长总之脸就是长得好看。是我们这种小地方难得一见的类型。该说像是演员吗？就算打开电视恐怕都不一定能看到这种程度的。实在是太漂亮了──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「沒錯。會長總之臉就是長得好看。是我們這種小地方難得一見的類型。該說像是演員嗎？就算打開電視恐怕都不一定能看到這種程度的。實在是太漂亮了──」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00341",
		linknext = "0083_00343",
		line = 4536,
	},
	["0083_00343"] = {
		{"fg", file="mizuhiki_01m_00002", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00201", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0585", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“It’s my favorite, but her type is more popular with women, don’t you think? Men tend to find it ‘pretty but not my thing.’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“我是最喜欢那种型啦，但是要说的话算是受女生欢迎的类型吧？男生会说‘虽然很漂亮但并不喜欢’的那种。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「我是最喜歡那種型啦，但是要說的話算是受女生歡迎的類型吧？男生會說『雖然很漂亮但並不喜歡』的那種。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00342",
		linknext = "0083_00344",
		line = 4551,
	},
	["0083_00344"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=21},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oooh, I see! That fits perfectly! Like they’re so beautiful they’re scary...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊～～～～原来如此！说得真好……！确实，该说是太漂亮了反而有点恐怖吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊～～～～原來如此！說得真好……！確實，該說是太漂亮了反而有點恐怖嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00343",
		linknext = "0083_00345",
		line = 4563,
	},
	["0083_00345"] = {
