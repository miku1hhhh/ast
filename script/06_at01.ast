	["0083_00191"] = {
		{"fg", file="asane_02m_00008", file1="asane_02m_00101", file2="asane_02m_00213", path=":fg/asane_02m/", id=3, lv=4, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0372", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Don’t worry about it, my dreams are usually very romantic... Like I get a love potion from mysterious old fortuneteller, or a watch that stops time from the market...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不──要紧不要紧，我的梦大体上都会用很浪漫的方式收尾的啦……像是从不认识的占卜师婆婆手上拿到媚药、或是在漏天上买到能暂停时间的表……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不──要緊不要緊，我的夢大體上都會用很浪漫的方式收尾的啦……像是從不認識的占卜師婆婆手上拿到媚藥、或是在漏天上買到能暫停時間的錶……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00190",
		linknext = "0083_00192",
		line = 2359,
	},
	["0083_00192"] = {
