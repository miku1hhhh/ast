		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0351", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“But someone can be your type even if you don’t have a crush or anything, right? Like with actors, past a certain baseline of attractiveness it’s all a matter of taste.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					[[“可是你看，喜不喜欢姑且不说，至少该有个"喜欢的长相"吧？演艺人员也是那样，只要长相超过了一定程度之后不就会让人如痴如醉吗？”]],
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					[[「可是你看，喜不喜歡姑且不說，至少該有個"喜歡的長相"吧？演藝人員也是那樣，只要長相超過了一定程度之後不就會讓人如癡如醉嗎？」]],
					{"rt2"},
				},
