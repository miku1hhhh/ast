	["0083_00022"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was easy for me to rely on him, but at the same time I felt bad about it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这样的哥哥，让我觉得很可靠，同时也觉得很对不起他。",
					{"rt2"},
				},
			},
