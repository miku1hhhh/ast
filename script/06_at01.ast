			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, really... Well, no need to force yourself to remember that kind of thing...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
