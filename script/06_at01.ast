	["0083_00069"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He must have developed some kind of complex from the bullying he went through before.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我想，那肯定──是因为以前遭遇的欺凌让他留下了心结吧。",
