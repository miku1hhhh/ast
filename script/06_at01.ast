	["0083_00429"] = {
		{"fg", file="asane_01m_00008", file1="asane_01m_00101", file2="asane_01m_00221", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0390", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Come on! Sure, broth painted on the underside of Nanase’s huge boobs is great, but where do you think that umami is concentrated? Get it together, armpit lover!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“为什么啦！显然是仔细从奈奈濑同学丰满的胸部下方仔细摩擦出来的高汤更好吧你以为鲜味成分都被凝缩在哪里啊给我恢复理智好吗这个恋腋下癖男！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「為什麼啦！顯然是仔細從奈奈瀨同學豐滿的胸部下方仔細摩擦出來的高湯更好吧你以為鮮味成分都被凝縮在哪裡啊給我恢復理智好嗎這個戀腋下癖男！」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00428",
		linknext = "0083_00430",
		line = 5767,
	},
	["0083_00430"] = {
		{"se", id=0, loop=0, file="se_b145"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
