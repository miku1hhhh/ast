	["0083_00107"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When I was left behind in a car crushed in the middle of a multiple-vehicle pileup...",
					{"rt2"},
				},
			},
			cn = {
				{
					"在追撞事故里好几台车都压扁了、只剩下我一个人被留在变形的车体里面的时候。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在追撞事故裡好幾台車都壓扁了、只剩下我一個人被留在變形的車體裡面的時候。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00106",
		linknext = "0083_00108",
		line = 1171,
	},
	["0083_00108"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When my beloved parents stopped responding to my voice...",
					{"rt2"},
				},
			},
			cn = {
				{
					"在最喜欢的双亲的回应，终于完全停止了的时候。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在最喜歡的雙親的回應，終於完全停止了的時候。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00107",
		linknext = "0083_00109",
