	["0083_00020"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe it’s because our parents were always justifying things to him with the words “you’re a big brother, after all!”",
