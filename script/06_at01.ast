		line = 4055,
	},
	["0083_00312"] = {
		{"fg", file="schubert_01m_00001", file1="schubert_01m_00102", file2="schubert_01m_00202", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0346", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“She looked up at me all embarrassed and said ‘Don’t worry, it’s fine.’ Then as soon as I blinked, she was gone.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“然后她抬起头，很不好意思地说了‘不会不会，不要紧喔’。接着就在我稍微别开目光的瞬间，她就像存在本身直接消失了一样不见了──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「然後她抬起頭，很不好意思地說了『不會不會，不要緊喔』。接著就在我稍微別開目光的瞬間，她就像存在本身直接消失了一樣不見了──」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00311",
		linknext = "0083_00313",
		line = 4070,
	},
	["0083_00313"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
