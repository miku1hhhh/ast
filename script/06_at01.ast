			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“感觉她总是在一个人自言自语一些非常有水乃月的学生的风格的台词呢……那孩子有点不太对呢，也不是我喜欢的类型。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「感覺她總是在一個人自言自語一些非常有水乃月的學生的風格的台詞呢……那孩子有點不太對呢，也不是我喜歡的類型。」",
					{"rt2"},
				},
			},
		},
