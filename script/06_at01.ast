				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“What’s that, you’re not full? You want to eat from the back mouth too? Okay, let’s find an empty classroom, then...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“咦，还不够？‘想要吃用下面的嘴巴吃的那种！’。说的也是，那就到没有人的教室来第二回合吧……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「咦，還不夠？『想要吃用下面的嘴巴吃的那種！』。說的也是，那就到沒有人的教室來第二回合吧……！」",
					{"rt2"},
				},
