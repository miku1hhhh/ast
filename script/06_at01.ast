					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nanase does that with girls, too... Look into their eyes afterward, and you’ll see ‘glitzy big sister’ written there...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					[[“就算对方是女的也是那样喔，奈奈濑……有机会去看看实际上被她来过这么一下的女生的眼神吧，完全就是"辣妹姐姐大人"的那种感觉喔……”]],
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					[[「就算對方是女的也是那樣喔，奈奈瀨……有機會去看看實際上被她來過這麼一下的女生的眼神吧，完全就是"辣妹姊姊大人"的那種感覺喔……」]],
					{"rt2"},
				},
			},
		},
