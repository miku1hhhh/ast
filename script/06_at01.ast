	["0083_00217"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I guess kids these days find that kind of thing overbearing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从这个年纪的孩子的角度来看，父母过度干涉想必很烦人吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從這個年紀的孩子的角度來看，父母過度干涉想必很煩人吧。",
					{"rt2"},
				},
			},
		},
