			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I don’t know any such person! This is my only home...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“那种人，我才不管……！我的家，就是这个家……”",
