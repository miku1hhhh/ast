	["0083_00066"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I really came to love that awkward kindness of his.",
					{"rt2"},
				},
			},
			cn = {
				{
					"于是我喜欢上了哥哥那份笨拙的温柔。非常喜欢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"於是我喜歡上了哥哥那份笨拙的溫柔。非常喜歡。",
