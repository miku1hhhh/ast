		{"fgact", ch="麻沙音3", id=3, act="浮遊横", loop=-1, size=2.5, time=50, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0384", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I’m trembling like a scared little lamb! Wahh, wahh, pet me! Comfort meee!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“麻沙酱可是正在像恐惧颤抖的小羊一样哭泣喔～！呜咽──呜咽──，好好安慰我、摸摸我的头嘛～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「麻沙醬可是正在像恐懼顫抖的小羊一樣哭泣喔～！嗚咽──嗚咽──，好好安慰我、摸摸我的頭嘛～！」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00413",
		linknext = "0083_00415",
		line = 5561,
	},
	["0083_00415"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00219", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You’re the one scaring people... Well, Asa. What is it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“无耻的是你吧……然后呢，麻沙酱，发生什么事了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「無恥的是妳吧……然後呢，麻沙醬，發生什麼事了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00414",
		linknext = "0083_00416",
		line = 5573,
	},
	["0083_00416"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Did you hear a creepy ghost laugh on the way to the bathroom again? It’s probably just Fumino reading, and if it’s not, youkai are pretty normal by now, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“又是在上厕所的时候看到了呶嘿呶嘿地笑着的幽灵了吗？可是我们已经说好了那只是正在读书的文乃，就算不是也只是妖怪原来原来而已不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「又是在上廁所的時候看到了呶嘿呶嘿地笑著的幽靈了嗎？可是我們已經說好了那只是正在讀書的文乃，就算不是也只是妖怪原來原來而已不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00415",
		linknext = "0083_00417",
		line = 5585,
	},
