	["0083_00287"] = {
		{"fg", file="schubert_01m_00002", file1="schubert_01m_00102", file2="schubert_01m_00216", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0339", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“I don’t think it’d be that weird...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“有那种人也不奇怪吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「有那種人也不奇怪吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00286",
		linknext = "0083_00288",
		line = 3695,
	},
	["0083_00288"] = {
		{"fg", file="mizuhiki_01m_00002", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00214", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="水引15", id=15, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0575", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Nah, no one’s that weird, Nakamura. No man with a girlfriend falls asleep listening to audio porn.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“不，中村君，这世界上才没有那种古怪的男人呢。明明就有恋人，还四处去听成人的语音作品最后被催眠睡倒什么的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「不，中村君，這世界上才沒有那種古怪的男人呢。明明就有戀人，還四處去聽成人的語音作品最後被催眠睡倒什麼的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00287",
		linknext = "0083_00289",
		line = 3711,
	},
	["0083_00289"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hehe, you understand so much, Mizuhiki—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哼哼，水引酱很懂嘛──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哼哼，水引醬很懂嘛──」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00288",
		linknext = "0083_00290",
		line = 3723,
	},
	["0083_00290"] = {
		{"fg", file="mizuhiki_01m_00002", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00207", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="水引15", id=15, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0576", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Ahem, Tachibana ‘understands’ too, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					[[“嘻，橘君不也"懂"吗──？”]],
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					[[「嘻，橘君不也"懂"嗎──？」]],
					{"rt2"},
				},
			},
		},
		linkback = "0083_00289",
		linknext = "0083_00291",
		line = 3739,
	},
	["0083_00291"] = {
		{"fg", file="schubert_01m_00001", file1="schubert_01m_00102", file2="schubert_01m_00218", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0340", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“I think you two could both be a little more open-minded...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“刻、刻板印象不可取喔，两位……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「刻、刻板印象不可取喔，兩位……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00290",
		linknext = "0083_00292",
		line = 3754,
	},
	["0083_00292"] = {
		{"fg", file="mizuhiki_01m_00002", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00202", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0577", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“But Tachibana, couldn’t you have had your pick from that group? They looked like they were in heat around you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“不过那群人，不是可以任橘君挑选吗？所有人都一副发情的雌性的表情嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「不過那群人，不是可以任橘君挑選嗎？所有人都一副發情的雌性的表情嘛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00291",
		linknext = "0083_00293",
		line = 3769,
	},
	["0083_00293"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00208", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Look, I’ve had enough of you insulting my comrades!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别说了，说我的同伴坏话我可是会生气的喔──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別說了，說我的同伴壞話我可是會生氣的喔──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00292",
		linknext = "0083_00294",
		line = 3781,
	},
	["0083_00294"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00201", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0341", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“He’s not wrong though, Junnosuke. What if that was your only chance to escape lifelong bachelorhood?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“可是我觉得她的话与事实相当接近喔，淳之介。不如说，如果错过了这次机会，你八成会单身一辈子吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「可是我覺得她的話與事實相當接近喔，淳之介。不如說，如果錯過了這次機會，你八成會單身一輩子吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00293",
		linknext = "0083_00295",
		line = 3796,
	},
	["0083_00295"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00218", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You might be right about the bachelorhood, but still... I dunno about dating.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我会单身一辈子听起来可信度是满高的啦……可是恋人啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我會單身一輩子聽起來可信度是滿高的啦……可是戀人啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00294",
		linknext = "0083_00296",
		line = 3808,
	},
	["0083_00296"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe it’s just that things have been too crazy dealing with the perverted sex laws until recently.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为至今为止都只想着要推翻变态条例，该说是对我来说太跳跃了吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為至今為止都只想著要推翻變態條例，該說是對我來說太跳躍了嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00295",
		linknext = "0083_00297",
		line = 3818,
	},
	["0083_00297"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Or that even now that things have calmed down it just didn’t occur to me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"或者应该说，虽然状况再度稳定下来了，但我还是没有那样的想法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"或者應該說，雖然狀況再度穩定下來了，但我還是沒有那樣的想法。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00296",
		linknext = "0083_00298",
		line = 3828,
	},
	["0083_00298"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...I don’t know, it just doesn’t appeal to me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……怎么说呢，总觉得提不起那种劲啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……怎麼說呢，總覺得提不起那種勁啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00297",
		linknext = "0083_00299",
		line = 3840,
	},
	["0083_00299"] = {
		{"fg", file="mizuhiki_01m_00002", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00209", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[6300] = {
				{"fg", file="mizuhiki_01m_00002", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00213", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, timestamp=30, delay2=6300, mode=3, x=-405, y=-5},
			},
			[6299] = {
				{"transitiontime", time=300, timestamp=30, delay2=6300},
			},
		},
		text = {
			vo = {
				{"vo", file="mizuhiki0578", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Really? There wasn’t even one of them you were into? I thought they were all pretty good looks-wise... Oh, was it the impotence?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“真意外，在那之中你都没有喜欢上任何一个人吗？如果只看脸，我倒是觉得所有人都不错……啊，是因为阳痿吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「真意外，在那之中你都沒有喜歡上任何一個人嗎？如果只看臉，我倒是覺得所有人都不錯……啊，是因為陽痿嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00298",
		linknext = "0083_00300",
		line = 3858,
	},
	["0083_00300"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00222", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It’s got nothing to do with that! Do all of you have someone you’re into?! How about you, Shu?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“跟阳痿没有关系啦……！不然你们就有喜欢的人了吗！？舒君呢！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「跟陽痿沒有關係啦……！不然你們就有喜歡的人了嗎！？舒君呢！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00299",
		linknext = "0083_00301",
		line = 3870,
	},
	["0083_00301"] = {
