	},
	["0083_00064"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In doing that, he accepted me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"哥哥透过这种方法，接纳了我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"哥哥透過這種方法，接納了我。",
					{"rt2"},
				},
			},
		},
