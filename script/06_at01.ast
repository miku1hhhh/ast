		text = {
			vo = {
				{"vo", file="nanase0436", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Oh... Here, you dropped your pen! It’s fine, don’t worry about it. Oh, right, if I forget my textbook next time, will you share yours? Teehee, bye.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“啊……喏、拿去，这是你掉的笔对吧？没事啦，不用客气。……啊对了，那如果哪天我忘记带教科书了，你就借我看可以吗？呵呵，再见啰。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「啊……喏、拿去，這是你掉的筆對吧？沒事啦，不用客氣。……啊對了，那如果哪天我忘記帶教科書了，你就借我看可以嗎？呵呵，再見囉。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00335",
		linknext = "0083_00337",
		line = 4440,
	},
	["0083_00337"] = {
