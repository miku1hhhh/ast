		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0241", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Good morning, both of you... Your breakfast is ready. Today we have toast with eggs and ham, as Asane requested.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“早安，两位……餐点已经准备好了。今天的早餐应麻沙音同学要求，是土司和火腿蛋。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「早安，兩位……餐點已經準備好了。今天的早餐應麻沙音同學要求，是土司和火腿蛋。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00145",
