			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Oh, and I’m still mad about that tanuki comment! I’m no tanuki!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊，可是刚才说我是狸猫那件事我可不会原谅你喔……！因为麻沙酱不是狸猫嘛……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊，可是剛才說我是狸貓那件事我可不會原諒你喔……！因為麻沙醬不是狸貓嘛……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00439",
		linknext = "0083_00441",
