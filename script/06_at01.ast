			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Right, just taking out perverted sex laws, kidnapping a new housemate, full-body erections, making new laws, going to parallel worlds...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“就是啊，就只有推翻了变态条例、同居人被绑架、全身勃起、制定新的条例、还有去了平行世界之类的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「就是啊，就只有推翻了變態條例、同居人被綁架、全身勃起、制定新的條例、還有去了平行世界之類的……」",
					{"rt2"},
				},
			},
		},
