					name = {"淳之介", "Junnosuke"},
					"“Anyway, our comrades really aren’t like that. They’re very nice and they don’t open their legs for just anyone.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是还请你把我的伙伴们当作例外喔。大家都是非常好的人，不是那种不论对方是谁都可以张开双腿的家伙们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是還請妳把我的夥伴們當作例外喔。大家都是非常好的人，不是那種不論對方是誰都可以張開雙腿的傢伙們。」",
					{"rt2"},
				},
			},
		},
