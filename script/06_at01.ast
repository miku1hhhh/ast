	["0083_00314"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00214", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[5500] = {
				{"fg", file="schubert_01m_00001", file2="schubert_01m_00221", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, timestamp=38, delay2=5500, mode=3, x=395, y=-5},
			},
			[5499] = {
				{"transitiontime", time=300, timestamp=38, delay2=5500},
			},
		},
		text = {
			vo = {
				{"vo", file="schubert0347", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“I kept an eye for her after that, and I never saw her... But I never forgot her voice! It was so clear and beautiful—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“在那之后，我就有意无意地在寻找她的身影，可是就是找不到……可是我无法忘记！那时听到的声音，非常的美、有一种通透的感觉──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
