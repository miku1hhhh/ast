		},
		text = {
			vo = {
				{"vo", file="mizuhiki0582", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“So out of all the members which one is most your type? C’mon, it’s just us here, you can tell us!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“那我反过来问，在你们的成员之中，长相你最喜欢的是谁？好啦好啦，在场的只有我们而已，你就说嘛……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「那我反過來問，在你們的成員之中，長相你最喜歡的是誰？好啦好啦，在場的只有我們而已，你就說嘛……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00328",
		linknext = "0083_00330",
		line = 4334,
	},
	["0083_00330"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00104", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh? Are you backing down...? Hehehe...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“咦──？哎呀这可伤脑筋了……？呼嘿嘿……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「咦──？哎呀這可傷腦筋了……？呼嘿嘿……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00329",
		linknext = "0083_00331",
		line = 4346,
	},
	["0083_00331"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’ve never had many so I’ve never done it myself, but I remember classmates making rankings of the girls in school by looks.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我因为以前没有什么朋友所以没弄过，但是同班同学曾经制作过班上女生颜值的排名之类的呢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我因為以前沒有什麼朋友所以沒弄過，但是同班同學曾經製作過班上女生顏值的排名之類的呢。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00330",
		linknext = "0083_00332",
		line = 4356,
	},
	["0083_00332"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I thought it was gross behavior, but at the same time I wanted to try it just once.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然心中觉得没品，但是我一直很想试一次……！",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然心中覺得沒品，但是我一直很想試一次……！",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00331",
		linknext = "0083_00333",
		line = 4366,
	},
	["0083_00333"] = {
