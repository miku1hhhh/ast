				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I think it suits you just right. Touka is tanuki-like, but you’re surprisingly similar too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“形容得不是很好吗？虽然桐香也满有狸猫样的，但你也意外地狸猫喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「形容得不是很好嗎？雖然桐香也滿有狸貓樣的，但妳也意外地狸貓喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00440",
