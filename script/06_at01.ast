	["0083_00388"] = {
		{"bgm", file="bgm23", vol=100},
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00207", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0359", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Yeah, she’s not bad-looking... I hear she got a good amount of attention under the old laws? She could be popular in the future too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“说的也是，长相也不难看……实际上，在旧条例时代似乎也有不少人进攻喔？今后或许会大受欢迎呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「說的也是，長相也不難看……實際上，在舊條例時代似乎也有不少人進攻喔？今後或許會大受歡迎呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00387",
		linknext = "0083_00389",
		line = 5209,
	},
	["0083_00389"] = {
