				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I think probably the most intense incident, maybe because it was the most recent, was the parallel world thing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过在这些经验之中，也因为是最新的事件，所以印象最深刻的恐怕还是非到平行世界去那件事吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過在這些經驗之中，也因為是最新的事件，所以印象最深刻的恐怕還是非到平行世界去那件事吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00241",
		linknext = "0083_00243",
		line = 3048,
	},
	["0083_00243"] = {
		{"text"},
		text = {
