	["0083_00302"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Okay, then on the count of three, everyone say if you’ve got someone! One, two...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那就数到三所有人一起说有没有！一、二……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那就數到三所有人一起說有沒有！一、二……」",
					{"rt2"},
				},
			},
		},
