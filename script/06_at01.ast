					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Wrong! Sniff, I was sleeping, and tried to put the strange old lady in the pot to cook something for my bro, but I got set on fire!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“才不是啦～！吸吸、麻沙酱本来也已经睡了，可是我想说要做菜给老哥吃、于是把不认识的老婆婆放到锅里煮，然后就有人在我的背上点火～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「才不是啦～！吸吸、麻沙醬本來也已經睡了，可是我想說要做菜給老哥吃、於是把不認識的老婆婆放到鍋裡煮，然後就有人在我的背上點火～！」",
					{"rt2"},
				},
			},
		},
