	["0083_00211"] = {
		{"se", id=0, loop=0, file="se_a141"},
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00201", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“A letter? Huh, usually we only get those when Governor Hitoura writes to Fumino...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“信吗……真稀奇，明明平时都只有仁浦县长寄给文奈的信而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「信嗎……真稀奇，明明平時都只有仁浦縣長寄給文奈的信而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00210",
		linknext = "0083_00212",
		line = 2640,
	},
	["0083_00212"] = {
		{"fg", file="asane_02m_00008", file1="asane_02m_00101", file2="asane_02m_00201", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0377", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Which come every day... no, more like every 12 hours... or 8 hours...? There’s always one in the mailbox, it’s actually a bit scary.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“是啊，一天一封……不，12小时一封……还是说是8小时一封……？每次看信箱几乎都有，有时候会让人觉得有点恐怖呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「是啊，一天一封……不，12小時一封……還是說是8小時一封……？每次看信箱幾乎都有，有時候會讓人覺得有點恐怖呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00211",
		linknext = "0083_00213",
		line = 2655,
	},
	["0083_00213"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Since you won’t share your tablet ID, Fumino...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为文乃不告诉县长自己的平版的ID嘛……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為文乃不告訴縣長自己的平版的ID嘛……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00212",
		linknext = "0083_00214",
		line = 2667,
	},
	["0083_00214"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file2="fumino_01m_00228", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-405, y=-5},
