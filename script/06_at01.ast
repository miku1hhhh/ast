		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“All right! Okay, so with my comrades, first of all... Over there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好……！呃呃，说到我们的伙伴，首先……在那边的是──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好……！呃呃，說到我們的夥伴，首先……在那邊的是──」",
					{"rt2"},
