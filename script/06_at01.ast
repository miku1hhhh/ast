		{"fgact", ch="文乃7", id=7, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0249", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I found this mixed in with the papers... It’s addressed to you, Junnosuke.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“报纸里面夹着这个……是寄给淳之介同学的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「報紙裡面夾著這個……是寄給淳之介同學的。」",
					{"rt2"},
				},
			},
		},
