	["0083_00328"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00206", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, I guess we do have girls of a lot of different types...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们这边确实是凑齐了各种类型的女孩子啦……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們這邊確實是湊齊了各種類型的女孩子啦……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00327",
		linknext = "0083_00329",
		line = 4311,
	},
	["0083_00329"] = {
		{"fg", file="mizuhiki_01m_00002", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00202", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-405, y=-5},
