			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe he’d come to automatically look at his classmates with fear, just like I had.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他大概随时都对同学抱有恐惧感吧。像我一样。",
