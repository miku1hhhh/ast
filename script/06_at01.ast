		linkback = "0083_00231",
		linknext = "0083_00233",
		line = 2906,
	},
	["0083_00233"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Not really the kind of letter you expect someone to send to kids they’ve never met.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然说要写信给连见都没见过的小孩，确实大概也想不出要写什么啦。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然說要寫信給連見都沒見過的小孩，確實大概也想不出要寫什麼啦。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00232",
		linknext = "0083_00234",
		line = 2916,
	},
	["0083_00234"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But since they asked—",
					{"rt2"},
				},
			},
			cn = {
				{
					"可是，要问我们有什么变化──",
					{"rt2"},
				},
			},
			tw = {
				{
					"可是，要問我們有什麼變化──",
					{"rt2"},
				},
