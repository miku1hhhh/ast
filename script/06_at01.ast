			},
			cn = {
				{
					name = {"美岬"},
					"“今天我也在体育课努力作了肛门括约肌运动！感觉屁股看起来好像越来越像嘴巴了，有点产生感情了呢……从今以后就叫它嘻屁吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「今天我也在體育課努力作了肛門括約肌運動！感覺屁股看起來好像越來越像嘴巴了，有點產生感情了呢……從今以後就叫它嘻屁吧！」",
					{"rt2"},
				},
			},
		},
