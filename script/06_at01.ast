		{"extrans", sync=0, time=500, rule="eff_008_00000"},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Dykes like you make me want to throw up!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“──蕾丝边什么的，当然会让人觉得恶心啊！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「──蕾絲邊什麼的，當然會讓人覺得噁心啊！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00046",
		linknext = "0083_00048",
		line = 552,
	},
	["0083_00048"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"With those words he took the letter I gave him and tore it to pieces.",
					{"rt2"},
				},
			},
			cn = {
				{
					"哥哥这么说着，把我递给他的信给撕成了碎片。",
					{"rt2"},
				},
			},
			tw = {
				{
					"哥哥這麼說著，把我遞給他的信給撕成了碎片。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00047",
		linknext = "0083_00049",
		line = 562,
	},
	["0083_00049"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That letter had all of my apologies in it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"把写满了我的歉意的信。",
					{"rt2"},
				},
			},
			tw = {
				{
					"把寫滿了我的歉意的信。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00048",
		linknext = "0083_00050",
		line = 572,
	},
	["0083_00050"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’ve never forgotten his face in that moment.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当时哥哥的表情，我至今都无法忘记。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當時哥哥的表情，我至今都無法忘記。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00049",
		linknext = "0083_00051",
		line = 582,
	},
	["0083_00051"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"His words hurt me, but it was",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然他说的话多令我受伤也记忆犹新啦。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然他說的話多令我受傷也記憶猶新啦。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00050",
		linknext = "0083_00052",
		line = 592,
	},
	["0083_00052"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"the way his face had gone pale that really broke my heart.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可是，哥哥眼看着越来越惨白的表情，更让我伤心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可是，哥哥眼看著越來越慘白的表情，更讓我傷心。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00051",
		linknext = "0083_00053",
		line = 602,
	},
	["0083_00053"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I think my brother was totally defining himself by his duty as an older sibling.",
					{"rt2"},
				},
			},
			cn = {
				{
					"哥哥大概，是那种只凭借着自己身为哥哥的责任感活下来的人吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"哥哥大概，是那種只憑藉著自己身為哥哥的責任感活下來的人吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00052",
		linknext = "0083_00054",
		line = 612,
	},
	["0083_00054"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I wonder now if I was the one who pushed him so far back then.",
					{"rt2"},
				},
			},
			cn = {
				{
					"把那样的哥哥追逼到那步田地的，大概也是我吧？我现在是这么想的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"把那樣的哥哥追逼到那步田地的，大概也是我吧？我現在是這麼想的。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00053",
		linknext = "0083_00055",
		line = 622,
	},
	["0083_00055"] = {
		{"bg", id=1, file="bg20_1_00000", x=0, y=0, lv=1, path=":bg/", sync=0, style="blur", blurx=5, blury=5, ax=805, ay=455, bx=-5, by=-5},
		{"bg", id=29, file="blackband_00000", x=0, y=0, lv=29, path=":bg/", sync=0},
		{"bg", id=1, file="bg20_1_00000", x=0, y=0, lv=1, path=":bg/", sync=0, style="blur", blurx=5, blury=5, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=500, rule="eff_008_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After that we left the island again and got away from the bullying.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在那之后我们又离开了青蓝岛，欺凌自然也断了个干净。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在那之後我們又離開了青藍島，欺凌自然也斷了個乾淨。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00054",
		linknext = "0083_00056",
		line = 638,
	},
	["0083_00056"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Our parents were busy as ever and took less time for me now that I was older.",
					{"rt2"},
				},
			},
			cn = {
				{
					"双亲还是同样忙碌，说着“你已经是个大姐姐了喔”，关怀我的时间越来越少。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雙親還是同樣忙碌，說著「妳已經是個大姊姊了喔」，關懷我的時間越來越少。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00055",
		linknext = "0083_00057",
		line = 648,
	},
	["0083_00057"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I never did make any new friends, though.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然在那之后，我也没有交到新的朋友。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然在那之後，我也沒有交到新的朋友。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00056",
		linknext = "0083_00058",
		line = 658,
	},
	["0083_00058"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Eventually, I noticed my brother was keeping me company again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可是回过神来的时候，哥哥开始陪在我身边了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可是回過神來的時候，哥哥開始陪在我身邊了。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00057",
		linknext = "0083_00059",
		line = 668,
	},
	["0083_00059"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We were often alone at home together, and he would look after me just like he used to.",
					{"rt2"},
				},
			},
			cn = {
				{
					"跟我两人单独待在家里的时间越来越长的哥哥，跟当年一样照顾着我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"跟我兩人單獨待在家裡的時間越來越長的哥哥，跟當年一樣照顧著我。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00058",
		linknext = "0083_00060",
		line = 678,
	},
	["0083_00060"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don’t think anything in my speech or mannerisms really changed, but...",
					{"rt2"},
				},
			},
			cn = {
				{
					"动作也好、语气也好、说话的频率也好，明明都没什么变化。",
					{"rt2"},
				},
			},
			tw = {
				{
					"動作也好、語氣也好、說話的頻率也好，明明都沒什麼變化。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00059",
		linknext = "0083_00061",
		line = 688,
	},
	["0083_00061"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After that incident, my brother stopped saying things like “men are like this” or “women should do that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					"可是自从那次以后，哥哥再也不说“因为是男人”“因为是女人”那一类的话了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可是自從那次以後，哥哥再也不說「因為是男人」「因為是女人」那一類的話了。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00060",
		linknext = "0083_00062",
		line = 698,
	},
	["0083_00062"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Instead of men or women, he’d talk about human beings.",
					{"rt2"},
				},
			},
			cn = {
				{
					[[甚至不说男人或女人，而是说"人类"。]],
					{"rt2"},
				},
			},
			tw = {
				{
					[[甚至不說男人或女人，而是說"人類"。]],
					{"rt2"},
				},
			},
		},
		linkback = "0083_00061",
		linknext = "0083_00063",
		line = 708,
	},
	["0083_00063"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He’d call girls and boys both “people.”",
					{"rt2"},
				},
			},
			cn = {
				{
					[[男孩子女孩子，也被统一成了"人"。]],
					{"rt2"},
				},
			},
			tw = {
				{
					[[男孩子女孩子，也被統一成了"人"。]],
					{"rt2"},
				},
			},
		},
		linkback = "0083_00062",
