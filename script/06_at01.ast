	["0083_00458"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0401", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“‘Two brushes’ sounds like ‘Nippon,’ so it’s good luck. One tit alone... well, the counter word sounds too much like ‘impotence’ for people.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“据说是因为同时使用‘两支’笔谐音‘良辰’很吉利、反之如果只使用一边乳头的‘一支’会让人联想到‘形单影只’所以相当不吉利的样子……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「據說是因為同時使用『兩支』筆諧音『良辰』很吉利、反之如果只使用一邊乳頭的『一支』會讓人聯想到『形單影隻』所以相當不吉利的樣子……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00457",
		linknext = "0083_00459",
		line = 6178,
	},
	["0083_00459"] = {
