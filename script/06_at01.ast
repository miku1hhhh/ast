	["0083_00334"] = {
		{"fg", file="mizuhiki_01f_00001", file1="mizuhiki_01f_00101", file2="mizuhiki_01f_00207", file4="mizuhiki_01f_00401", path=":fg/mizuhiki_01f/", id=30, ch="水引", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0583", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Katagiri, huh. What would you call her type, school idol? A little bit scene, but not enough to be off-putting to normies...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“是片桐同学啊。以类别来说，是学校的偶像那种吧？虽然是辣妹系的，但是不会太奇葩，算是人见人爱的那种吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「是片桐同學啊。以類別來說，是學校的偶像那種吧？雖然是辣妹系的，但是不會太奇葩，算是人見人愛的那種吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00333",
		linknext = "0083_00335",
		line = 4395,
	},
	["0083_00335"] = {
		{"fg", file="schubert_01f_00002", file2="schubert_01f_00203", file4="schubert_01f_00401", file5="schubert_01f_00501", path=":fg/schubert_01f/", id=30, ch="シューベルト", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0352", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“According to my data, she’s the type to ‘unintentionally’ drop things when there’s a guy next to her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“根据我的资料，是会在无意识之间攻陷坐隔壁的男生之类的类型呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「根據我的資料，是會在無意識之間攻陷坐隔壁的男生之類的類型呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00334",
		linknext = "0083_00336",
		line = 4408,
	},
