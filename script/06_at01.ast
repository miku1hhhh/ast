				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Type-wise, I think she and Misaki are the same ‘popular with men’ type? The lewd type, where guys take one look and assume they give great head.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					[[“从类型上来说算是跟畔同学一样"会受男生欢迎"的那种吧？好色女那型，会让人产生‘看起来就很擅长口交’那种先入为主的印象的那种。”]],
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					[[「從類型上來說算是跟畔同學一樣"會受男生歡迎"的那種吧？好色女那型，會讓人產生『看起來就很擅長口交』那種先入為主的印象的那種。」]],
					{"rt2"},
				},
			},
		},
