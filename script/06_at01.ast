	["0083_00099"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I thought that with the two of us working together, we could do anything.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我和老哥、只要兄妹两个人一起，就没有什么是不可能的──我是这么认为的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我和老哥、只要兄妹兩個人一起，就沒有什麼是不可能的──我是這麼認為的。",
					{"rt2"},
				},
			},
		},
