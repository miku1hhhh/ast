		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...Looking back on things, I don’t have a lot of good memories.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……我的过去之中，并没有什么好的回忆。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……我的過去之中，並沒有什麼好的回憶。",
					{"rt2"},
				},
			},
		},
		linknext = "0083_00002",
		line = 45,
	},
	["0083_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Especially not when it comes to my older brother.",
					{"rt2"},
				},
			},
			cn = {
				{
					"特别是关于哥哥，大体上都是不好的回忆。",
					{"rt2"},
				},
			},
			tw = {
				{
					"特別是關於哥哥，大體上都是不好的回憶。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00001",
		linknext = "0083_00003",
		line = 55,
	},
	["0083_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I was the youngest, and a girl, so my parents doted on me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我因为是年记最小的女儿，所以是被双亲宠着长大的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我因為是年記最小的女兒，所以是被雙親寵著長大的。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00002",
		linknext = "0083_00004",
		line = 65,
	},
	["0083_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Both of them always wanted a daughter, so I got special treatment.",
					{"rt2"},
				},
			},
			cn = {
				{
					"父亲也好母亲也好，都是想要女儿的类型，所以总是给我特殊的待遇。",
					{"rt2"},
				},
			},
			tw = {
				{
					"父親也好母親也好，都是想要女兒的類型，所以總是給我特殊的待遇。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00003",
		linknext = "0083_00005",
		line = 75,
	},
	["0083_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Furthermore, I was the kind of child who couldn’t do anything alone, whether it was eating or bathing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"加上我从小就是一个人什么都做不好的孩子，不管是吃饭还是洗澡，如果双亲不在，我自己根本没办法好好做到。",
					{"rt2"},
				},
			},
			tw = {
				{
					"加上我從小就是一個人什麼都做不好的孩子，不管是吃飯還是洗澡，如果雙親不在，我自己根本沒辦法好好做到。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00004",
		linknext = "0083_00006",
		line = 85,
	},
	["0083_00006"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don’t think any brother would take kindly to such a spoiled little sister.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看着这么被溺爱的妹妹，没有哪个做哥哥的会觉得开心的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看著這麼被溺愛的妹妹，沒有哪個做哥哥的會覺得開心的。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00005",
		linknext = "0083_00007",
		line = 95,
	},
	["0083_00007"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"By contrast, my brother was mostly left to his own devices.",
					{"rt2"},
				},
			},
			cn = {
				{
					"哥哥要说哪边的话，可以说是被放着不管长大的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"哥哥要說哪邊的話，可以說是被放著不管長大的。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00006",
		linknext = "0083_00008",
		line = 105,
	},
	["0083_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Our parents were normal people, not the kind to play blatant favorites, so they didn’t neglect him or anything.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们的双亲并不是会很露骨地把想法表现在态度上的类型、而且真的只是普通人，所以就算是哥哥，我想跟其他家庭相比，应该仍然算是相当受到宠爱的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們的雙親並不是會很露骨地把想法表現在態度上的類型、而且真的只是普通人，所以就算是哥哥，我想跟其他家庭相比，應該仍然算是相當受到寵愛的。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00007",
		linknext = "0083_00009",
		line = 115,
	},
	["0083_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s just that if they were both busy with work. What little spare time they had would go to me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只是双亲都忙于工作，而在他们的空闲时间里，被疼爱的总是我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只是雙親都忙於工作，而在他們的空閒時間裡，被疼愛的總是我。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00008",
		linknext = "0083_00010",
		line = 125,
	},
	["0083_00010"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"On the other hand, the old couple who used to live here loved my brother, so maybe it didn’t bother him that much in the end.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过以前住在这栋房子里的爷爷和奶奶也非常宠爱哥哥，所以说不定他也没那么介意吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過以前住在這棟房子裡的爺爺和奶奶也非常寵愛哥哥，所以說不定他也沒那麼介意吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00009",
		linknext = "0083_00011",
		line = 135,
	},
	["0083_00011"] = {
