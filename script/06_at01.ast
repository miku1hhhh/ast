	["0083_00065"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I was still lost in the dark with no idea what to do, but he held out his hand to me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在连我自己都不知道该怎么办的黑暗之中，哥哥对我伸出了一只看不见的手。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在連我自己都不知道該怎麼辦的黑暗之中，哥哥對我伸出了一隻看不見的手。",
					{"rt2"},
				},
			},
		},
