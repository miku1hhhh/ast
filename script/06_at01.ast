	["0083_00224"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I guess they haven’t sent anything for a few months, so it makes sense she wouldn’t know.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这么说起来这几个月他都没写信来，也难怪文乃不知道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這麼說起來這幾個月他都沒寫信來，也難怪文乃不知道。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00223",
		linknext = "0083_00225",
		line = 2807,
	},
	["0083_00225"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Some distant relative of ours, apparently. We’ve never met, but...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“据说是我们的远房亲戚。虽然没见过……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「據說是我們的遠房親戚。雖然沒見過……」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00224",
		linknext = "0083_00226",
		line = 2819,
	},
	["0083_00226"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“They take care of all the estate stuff for us and even let us inherit this house.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不只我们没办法处理的遗产关联的事务全都是他一手包办，这栋房子也是他协助我们继承到的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不只我們沒辦法處理的遺產關聯的事務全都是他一手包辦，這棟房子也是他協助我們繼承到的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00225",
		linknext = "0083_00227",
		line = 2831,
	},
	["0083_00227"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00102", file2="fumino_01m_00203", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="文乃7", id=7, act="振動下", loop=2, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0254", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Oh, what an extremely kind stranger!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					[[“原来原来，确实是"虽然没见过但是感觉人超好"的一位呢……！”]],
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					[[「原來原來，確實是"雖然沒見過但是感覺人超好"的一位呢……！」]],
					{"rt2"},
				},
			},
		},
		linkback = "0083_00226",
		linknext = "0083_00228",
		line = 2847,
	},
	["0083_00228"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“See? They’re some very distant relative on mom’s side, but they always use a fake name for some reason, so we call them that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“懂了吧？我记得是妈妈那边的超级远亲，可是不知道为什么他每次用的都是假名。所以我们才这么称呼他的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「懂了吧？我記得是媽媽那邊的超級遠親，可是不知道為什麼他每次用的都是假名。所以我們才這麼稱呼他的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00227",
		linknext = "0083_00229",
		line = 2859,
	},
	["0083_00229"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They always use gray envelopes with the same seal, so it’s easy to recognize their messages anyway.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然说他每次都会用灰色系的信封和相同的封缄，所以马上就能认出来就是了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然說他每次都會用灰色系的信封和相同的封緘，所以馬上就能認出來就是了。",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00228",
		linknext = "0083_00230",
		line = 2869,
	},
	["0083_00230"] = {
		{"se", id=0, loop=0, file="se_a141"},
		{"fgact", ch="麻沙音3", id=3, lv=3, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"fgact", ch="文乃7", id=7, lv=7, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So, what do we have today—",
					{"rt2"},
				},
			},
			cn = {
				{
					"我看看──，里面写了什么内容呢──",
					{"rt2"},
				},
			},
			tw = {
				{
					"我看看──，裡面寫了什麼內容呢──",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00229",
		linknext = "0083_00231",
		line = 2884,
	},
	["0083_00231"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“‘I haven’t heard from you recently, has anything changed?’ ...That’s it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“‘好久不见，生活有什么变化吗？’……只有样而已呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「『好久不見，生活有什麼變化嗎？』……只有樣而已呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00230",
		linknext = "0083_00232",
		line = 2896,
	},
	["0083_00232"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They’re always like this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个人一直都是这样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個人一直都是這樣。",
