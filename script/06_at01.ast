				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I’m kind of their boss, so... Extra feelings would cause problems for the organization, and... y’know...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“毕竟我是类似上司的立场……要是夹杂更多私情，以组织来说会产生问题……嘀嘀咕咕……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「畢竟我是類似上司的立場……要是夾雜更多私情，以組織來說會產生問題……嘀嘀咕咕……」",
					{"rt2"},
