					"“Ah, the type who gets doujinshi about her where she can’t turn down a random classmate who begs her for sex. A popular type with otaku like us?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					[[“就是会被出那种"被路人同学强烈请求无法去决结果就发生了关系"的同人志的类型呢……会受我们这些阿宅喜欢的那种感觉？”]],
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					[[「就是會被出那種"被路人同學強烈請求無法去決結果就發生了關係"的同人誌的類型呢……會受我們這些阿宅喜歡的那種感覺？」]],
					{"rt2"},
				},
			},
		},
