			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Noo, not the pervy burner fire! I won’t tell anyone you get off to peeking at Nanase’s pits in her dress shirts, so come and sleep with me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“色色火炉点火好可怕啊～！我不会把老哥是个恋腋下癖还会把奈奈濑同学偶尔从白衬衫的袖子里惊鸿一瞥的腋下拿来当小菜的事情说出去的所以陪我一起睡啦～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「色色火爐點火好可怕啊～！我不會把老哥是個戀腋下癖還會把奈奈瀨同學偶爾從白襯衫的袖子裡驚鴻一瞥的腋下拿來當小菜的事情說出去的所以陪我一起睡啦～！」",
					{"rt2"},
				},
			},
		},
