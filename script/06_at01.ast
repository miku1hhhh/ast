			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Head-pats for Fumino only?! No fair! I’ll show you cute, I can ‘Eheheh’ with the best of them, just you wait!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“咦──只有文乃太狡猾了只有文乃太狡猾了麻沙酱也会呶嘿嘿所以要更宠麻沙酱让文乃看看地位的差距嘛～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「咦──只有文乃太狡猾了只有文乃太狡猾了麻沙醬也會呶嘿嘿所以要更寵麻沙醬讓文乃看看地位的差距嘛～！」",
					{"rt2"},
				},
			},
		},
		linkback = "0083_00240",
