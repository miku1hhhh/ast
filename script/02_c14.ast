		},
		text = {
			vo = {
				{"vo", file="ikuko0615", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Multiple lacerations. Mostly blunt trauma... I wonder if he has any broken bones... He seems to be having trouble breathing. Are you okay, Darling...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“好多裂伤，几乎遍体鳞伤了⋯⋯不知道有没有骨折⋯⋯他看起来连呼吸都很困难的样子。亲爱的没事吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「好多裂傷，幾乎遍體鱗傷了⋯⋯不知道有沒有骨折⋯⋯他看起來連呼吸都很困難的樣子。親愛的沒事吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0022_00001",
		linknext = "0022_00003",
		line = 48,
	},
	["0022_00003"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00204", path=":fg/tohka_01m/", id=8, lv=10, head="tohka_01m", alpha=0, ch_origin="桐香", ch="桐香8", mw="mw", sync=1, a_chr151=1, mode=3, x=-205, y=-5},
		{"fgact", ch="桐香8", id=8, lv=10, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="桐香8", id=8, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0541", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“He’s not wheezing, so don’t worry. His respiratory system is normal, and there’s no risk that a bone might have punctured his lungs.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“没有喘鸣之类的状况的话就没什么大碍。呼吸器没有异常，骨头也没有刺到肺部。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「沒有喘鳴之類的狀況的話就沒什麼大礙。呼吸器沒有異常，骨頭也沒有刺到肺部。」",
					{"rt2"},
				},
			},
		},
		linkback = "0022_00002",
		linknext = "0022_00004",
		line = 63,
	},
	["0022_00004"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00203", path=":fg/tohka_02m/", id=8, lv=10, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
