	["0022_00045"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00308", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Are you telling me... that the only one able to best me was Hamedori...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“难不成⋯⋯将我一击击溃的，是那个Hamedori君⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「難不成⋯⋯將我一擊擊潰的，是那個Hamedori君⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0022_00044",
		linknext = "0022_00046",
		line = 726,
	},
	["0022_00046"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00102", file2="ikuko_02m_00229", path=":fg/ikuko_02m/", id=10, lv=9, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0620", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Heh... Never thought the day would come when we’d be weaker than Hamedori...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“是啊⋯⋯我们也没有想到，居然会变得连Hamedori君都不如的说⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「是啊⋯⋯我們也沒有想到，居然會變得連Hamedori君都不如的說⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0022_00045",
		linknext = "0022_00047",
		line = 741,
	},
	["0022_00047"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00201", path=":fg/rei_01m/", id=9, lv=8, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0543", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You said it... That thing doesn’t seem like just some plain old mascot suit.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“真是的⋯⋯看样子，那个东西⋯⋯可能不单单只是个布偶装这么简单⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「真是的⋯⋯看樣子，那個東西⋯⋯可能不單單只是個布偶裝這麼簡單⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0022_00046",
		linknext = "0022_00048",
		line = 755,
	},
	["0022_00048"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00214", path=":fg/tohka_02m/", id=8, lv=10, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0548", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“It appeared to have external armor, and while I’m unsure of its flight time, I believe we should assume that it’s capable of taking to the air.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“看起来布偶外部有着装甲──虽然不知道它能在空中停留多久──不过把它归类成有飞行能力会比较好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「看起來布偶外部有著裝甲──雖然不知道它能在空中停留多久──不過把它歸類成有飛行能力會比較好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0022_00047",
		linknext = "0022_00049",
		line = 769,
	},
	["0022_00049"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
