			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, nobody’s getting beheaded. Don’t worry, we’re letting you go.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没有没有，没有砍头这回事。”",
