		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A type of non-Newtonian fluid whose molecules bond to take on the resistance of a solid when externally stimulated.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是一种经由外部刺激使分子结合而产生对固体抗性的非牛顿流体。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那是一種經由外部刺激使分子結合而產生對固體抗性的非牛頓流體。",
					{"rt2"},
				},
			},
		},
		linkback = "0022_00061",
