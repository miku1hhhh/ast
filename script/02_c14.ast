			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Plus... Even if that thing is a powered suit, it’d require control protocols.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样的话⋯⋯假设那真的是外骨骼动力装的话，控制协议就是一定必要的东西了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣的話⋯⋯假設那真的是外骨骼動力裝的話，控制協議就是一定必要的東西了。」",
					{"rt2"},
				},
			},
		},
