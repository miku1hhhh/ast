		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’ve never known someone of the same sex who worries over me this much. Something about that is reassuring.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在此之前我从未遇过如此关心朋友的同性友人，不知怎么地，他的反应令我感到非常宽慰。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在此之前我從未遇過如此關心朋友的同性友人，不知怎麼地，他的反應令我感到非常寬慰。",
