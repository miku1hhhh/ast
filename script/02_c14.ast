		text = {
			vo = {
				{"vo", file="rei0540", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Aaahh, Junnosuke...! You’re finally awake?! Don’t pass out in a place like that you idiot, are you okay?! You’re so poorly trained, does it hurt anywhere? Get a grip! Get some rest!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“啊啊啊啊啊淳之介⋯⋯！你终于醒啦！你这个在那种场合下失去意识的大笨蛋应该没事吧？肯定是训练不足吧有没有哪里痛？给我好好静养听到没有！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「啊啊啊啊啊淳之介⋯⋯！你終於醒啦！你這個在那種場合下失去意識的大笨蛋應該沒事吧？肯定是訓練不足吧有沒有哪裡痛？給我好好靜養聽到沒有！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0022_00022",
		linknext = "0022_00024",
		line = 393,
	},
	["0022_00024"] = {
		{"se", id=0, stop=1, time=1000},
