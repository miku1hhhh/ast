	["0022_00072"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00102", file2="ikuko_02m_00202", path=":fg/ikuko_02m/", id=10, lv=9, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0622", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“...S-She probably didn’t realize it was you, Darling! There’s no way Asane would try to attack you...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“⋯⋯应、应该是她没有注意到那是亲爱的你吧？如果是麻沙音酱的话，是不可能会攻击淳之介君的⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「⋯⋯應、應該是她沒有注意到那是親愛的你吧？如果是麻沙音醬的話，是不可能會攻擊淳之介君的⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0022_00071",
		linknext = "0022_00073",
		line = 1077,
	},
	["0022_00073"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00102", file2="rei_02m_00202", path=":fg/rei_02m/", id=9, lv=8, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0546", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“And I couldn’t imagine your unathletic little sister being able to fight...! Between that and having no reason to attack you, it must have been someone else...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“而且，我不认为那个肢障一样的橘妹妹有办法战斗⋯⋯！况且她也根本没有攻击的理由，那家伙绝对是别人啦⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「而且，我不認為那個肢障一樣的橘妹妹有辦法戰鬥⋯⋯！況且她也根本沒有攻擊的理由，那傢伙絕對是別人啦⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0022_00072",
		linknext = "0022_00074",
		line = 1092,
	},
	["0022_00074"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=10, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0550", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes, it would be a bit of a hasty conclusion to say it was her inside. The standard, logical hypothesis would be that it was World A’s vice president.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“是啊，要说布偶服里的人是麻沙音同学还言之过早。真要推断的话，里面的人是Ａ世界的学生副会长还比较符合常理吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「是啊，要說布偶服裡的人是麻沙音同學還言之過早。真要推斷的話，裡面的人是Ａ世界的學生副會長還比較符合常理吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0022_00073",
		linknext = "0022_00075",
		line = 1107,
	},
	["0022_00075"] = {
