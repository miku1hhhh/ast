				},
			},
		},
		linkback = "0022_00051",
		linknext = "0022_00053",
		line = 816,
	},
	["0022_00053"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I bet it’s more like a powered suit. If this world is just as advanced as ours was, it shouldn’t be possible to make a bipedal robot on that level.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不如说更像外骨骼动力服之类的吧。像那样可以滞空的双足行走型机器人，要是这里跟我们是同样的文明程度的话是不可能存在的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不如說更像外骨骼動力服之類的吧。像那樣可以滯空的雙足行走型機器人，要是這裡跟我們是同樣的文明程度的話是不可能存在的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0022_00052",
		linknext = "0022_00054",
		line = 828,
	},
	["0022_00054"] = {
