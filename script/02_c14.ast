	["0022_00107"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"You know... This guy really is thoughtful when it comes to his comrades.",
					{"rt2"},
