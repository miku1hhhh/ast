					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「好的桐香大人⋯⋯不過頭部沒有問題嗎？如果只是腦震盪的話到還好，要是真的傷到頭部的話就糟糕了──」",
					{"rt2"},
				},
			},
