					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你这家伙在活动的期间到底都干了什么啊⋯⋯！？虽然说在FS里做爱是OK的，但性骚扰还是禁止的喔！社会舆论还是很麻烦的──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你這傢伙在活動的期間到底都幹了什麼啊⋯⋯！？雖然說在FS裡做愛是OK的，但性騷擾還是禁止的喔！社會輿論還是很麻煩的──！」",
					{"rt2"},
				},
			},
		},
