				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Schubert’s words sound shy as he adjusts his glasses.",
					{"rt2"},
				},
			},
			cn = {
				{
					"舒伯特一边将眼镜推回原位，边腼腆地说道。",
