			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Let’s get his legs elevated and ice his wounds. Bring some ice, Rei. Ikuko, you undress him and put him in a comfortable position.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“把脚抬高冰敷吧！礼去拿冰，郁子先帮他把衣服脱掉，调整到让他比较舒服的姿势先。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「把腳抬高冰敷吧！禮去拿冰，郁子先幫他把衣服脫掉，調整到讓他比較舒服的姿勢先。」",
					{"rt2"},
				},
			},
		},
		linkback = "0022_00003",
		linknext = "0022_00005",
		line = 78,
	},
