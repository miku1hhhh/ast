					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“So wait, is that thing a robot?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“这么说的话，那东西是机器人之类的吗？”",
