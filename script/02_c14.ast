	["0022_00057"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00204", path=":fg/tohka_02m/", id=8, lv=10, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0549", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“This target that we’re now calling the Armored Hamedori was tough enough to deflect Ikuko’s blade, yet it showed some degree of flexibility when bound by my threads.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“被我们称作武装Hamedori君的那家伙，坚硬程度是连郁子的刀都次不进去的。但是我用线束缚它的时候，那家伙又有一定程度的柔软性。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「被我們稱作武裝Hamedori君的那傢伙，堅硬程度是連郁子的刀都次不進去的。但是我用線束縛它的時候，那傢伙又有一定程度的柔軟性。」",
					{"rt2"},
				},
			},
		},
		linkback = "0022_00056",
		linknext = "0022_00058",
		line = 886,
	},
	["0022_00058"] = {
