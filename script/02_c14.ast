	},
	["0022_00102"] = {
		{"fg", file="schubert_01l_00001", file2="schubert_01l_00216", file4="schubert_01l_00401", file5="schubert_01l_00501", path=":fg/schubert_01l/", id=16, lv=16, head="schubert_01l", ch_origin="シューベルト", ch="シューベルト16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0141", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“I was part of the dragnet as part of second squad, but the Birds of a Feather leaped over our cordon in the blink of an eye... What a useless buddy I am to you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“我身为二队成员所以也在包围网之内，不过‘Tori公’瞬间就飞过了警戒线⋯⋯作为搭挡，我真是非常的不称职。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「我身為二隊成員所以也在包圍網之內，不過『Tori公』瞬間就飛過了警戒線⋯⋯作為搭擋，我真是非常的不稱職。」",
					{"rt2"},
				},
			},
		},
		linkback = "0022_00101",
		linknext = "0022_00103",
		line = 1541,
	},
	["0022_00103"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He grips his small tablet and lowers his eyes, regret tinging his expression.",
					{"rt2"},
				},
			},
			cn = {
				{
					"舒伯特紧握住手中的小型平板，低下头、露出了相当后悔的神情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"舒伯特緊握住手中的小型平板，低下頭、露出了相當後悔的神情。",
					{"rt2"},
				},
			},
		},
		linkback = "0022_00102",
		linknext = "0022_00104",
		line = 1551,
	},
	["0022_00104"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“As you can see, I’m fine... Sorry to make you worry.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就跟你看到的一样，我没有什么大碍⋯⋯所以不用担心啦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就跟你看到的一樣，我沒有什麼大礙⋯⋯所以不用擔心啦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0022_00103",
		linknext = "0022_00105",
		line = 1563,
	},
	["0022_00105"] = {
		{"fg", file="schubert_01l_00002", file2="schubert_01l_00205", file4="schubert_01l_00401", file5="schubert_01l_00501", path=":fg/schubert_01l/", id=16, lv=16, head="schubert_01l", ch_origin="シューベルト", ch="シューベルト16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0142", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Oh, no... I’m just glad you’re okay. Not that it means much from someone as useless in combat as me, but I just don’t want you getting hurt.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“怎么说⋯⋯总而言之你平安无事真是太好了。虽然在战斗中派不上用场的我这么说也无济于事，不过我一点也不希望您受到伤害。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「怎麼說⋯⋯總而言之你平安無事真是太好了。雖然在戰鬥中派不上用場的我這麼說也無濟於事，不過我一點也不希望您受到傷害。」",
					{"rt2"},
				},
			},
		},
		linkback = "0022_00104",
		linknext = "0022_00106",
		line = 1578,
	},
	["0022_00106"] = {
		{"text"},
		text = {
