		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My Penetrator uses one as well, but civilians shouldn’t have access to anything on that level yet.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我的“贯穿丸”就使用了这种液体，但像那样程度的东西完全是还没在一般市场上市的产品。",
