				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“We came to back you up as soon as we realized what was happening... But I think we would’ve been taken out too if Tokie hadn’t used her threads.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“虽然说郁跟大家一察觉到不对马上就赶去支援⋯⋯要不是桐香酱祭出线的话，大家搞不好都被干掉了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「雖然說郁跟大家一察覺到不對馬上就趕去支援⋯⋯要不是桐香醬祭出線的話，大家搞不好都被幹掉了。」",
					{"rt2"},
				},
			},
		},
