	["0022_00052"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00102", file2="ikuko_02m_00204", path=":fg/ikuko_02m/", id=10, lv=9, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
