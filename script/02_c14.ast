			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“What, are you trying to get back at me for earlier?! I was on edge after a fight, okay?! Can you blame me?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“乱说什么啊你是在趁机报复我之前的事吗⋯⋯！？刚战斗完我有点精神紧绷好吗！我有什么办法啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「亂說什麼啊你是在趁機報復我之前的事嗎⋯⋯！？剛戰鬥完我有點精神緊繃好嗎！我有什麼辦法啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0022_00096",
		linknext = "0022_00098",
		line = 1475,
	},
	["0022_00098"] = {
		{"bgm", stop=1},
		{"bg", id=15, file="bg32_3l_00000", x=-300, y=0, lv=15, path=":bg/", sync=0, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="schubert_01l_00001", file1="schubert_01l_00102", file2="schubert_01l_00213", file4="schubert_01l_00401", file5="schubert_01l_00501", path=":fg/schubert_01l/", id=16, lv=16, head="schubert_01l", ch_origin="シューベルト", ch="シューベルト16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0140", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“My apologies, Your Sexellency. I never imagined you would be hurt...! Even my data is apologizing!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“非常抱歉，性帝。没想到您会身负伤势──！我连同我的数据们一起向您致歉！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「非常抱歉，性帝。沒想到您會身負傷勢──！我連同我的數據們一起向您致歉！」",
					{"rt2"},
				},
			},
		},
		linkback = "0022_00097",
		linknext = "0022_00099",
		line = 1491,
	},
	["0022_00099"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00218", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, it’s not your fault... Don’t worry about it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哎不是，这也不是你的错⋯⋯不用在意。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哎不是，這也不是你的錯⋯⋯不用在意。」",
