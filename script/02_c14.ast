			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Bertie says adrenaline’s great for recovery! You did say during Rock Hard Climbing that seeing a junior’s undies gets you excited enough to go rock hard yourself, right?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“伯特同学说肾上腺素对治疗最有效了！而且辈前，攀茎男也说看了学妹的内裤之后会兴奋勃起到硬到不行喔！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「伯特同學說腎上腺素對治療最有效了！而且輩前，攀莖男也說看了學妹的內褲之後會興奮勃起到硬到不行喔！」",
					{"rt2"},
				},
			},
		},
		linkback = "0022_00114",
		linknext = "0022_00116",
		line = 1711,
	},
	["0022_00116"] = {
