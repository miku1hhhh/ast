	["0107_00034"] = {
		{"fg", file="asane_02f_00008", file1="asane_02f_00101", file2="asane_02f_00221", path=":fg/asane_02f/", id=30, ch="麻沙音", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1488", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I didn’t even get a summer vacation! I blew the whole summer making some shitty SumoFatty shovelware and when I woke up it was the first day of school!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“因为我没有过暑假啊！莫名其妙开始制作女主角是肥仔的烂游戏，结果暑假就没了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「因為我沒有過暑假啊！莫名其妙開始製作女主角是肥仔的爛遊戲，結果暑假就沒了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00033",
		linknext = "0107_00035",
		line = 492,
	},
	["0107_00035"] = {
