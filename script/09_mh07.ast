		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="mcg02_l010202", x=-96.5, y=-5.5, path=":cg/mcg02_l/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1242", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Junnosuke... I think you know already, but I was raised around mostly grandpas and grandmas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“淳之介君⋯⋯我想你应该知道，我以前生活在很多老爷爷老奶奶在的地方。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「淳之介君⋯⋯我想你應該知道，我以前生活在很多老爺爺老奶奶在的地方。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00087",
