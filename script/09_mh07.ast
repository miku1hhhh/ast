	["0107_00090"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1243", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I felt more affinity for the elderly than kids my own age. I always thought, ‘this is how I want to get old.’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“所以比起同年龄的孩子，我和爷爷奶奶们年纪的人更能相处融洽。想着自己会和他们那样变老。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「所以比起同年齡的孩子，我和爺爺奶奶們年紀的人更能相處融洽。想著自己會和他們那樣變老。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00089",
		linknext = "0107_00091",
		line = 1307,
	},
	["0107_00091"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="mcg02_l010203", x=-96.5, y=-5.5, path=":cg/mcg02_l/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1244", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Old Man Kenzou is the craziest of crazy old men, but it’s fine to be a little off your rocker at that age. I kind of looked up to him for that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“健藏老爷爷就是笨中之人⋯⋯都一大把岁数了还能这么做自己的耍笨，我有点向往呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「健藏老爺爺就是笨中之人⋯⋯都一大把歲數了還能這麼做自己的耍笨，我有點嚮往呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00090",
		linknext = "0107_00092",
		line = 1323,
	},
	["0107_00092"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Misaki’s warmth envelops me as we head down the road to school to the chirping of the cicadas.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我一边感受美岬传过来的体温，一边听着蝉叫走向学校。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我一邊感受美岬傳過來的體溫，一邊聽著蟬叫走向學校。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00091",
		linknext = "0107_00093",
		line = 1333,
	},
	["0107_00093"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We don’t have to cower and hide like we used to.",
					{"rt2"},
				},
			},
			cn = {
				{
					"已经不需要像以前一样躲躲藏藏了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"已經不需要像以前一樣躲躲藏藏了。",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00092",
		linknext = "0107_00094",
		line = 1343,
	},
	["0107_00094"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1245", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“In ten years, twenty years... we’ll both get older until one day we notice we’re the grandma and grandpa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“十年二十年过去，我和淳之介君慢慢变老⋯⋯最后变成老爷爷老奶奶。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「十年二十年過去，我和淳之介君慢慢變老⋯⋯最後變成老爺爺老奶奶。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00093",
		linknext = "0107_00095",
		line = 1355,
	},
	["0107_00095"] = {
		{"text"},
