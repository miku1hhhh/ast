	["0107_00028"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00101", file3="misaki_01f_00308", path=":fg/misaki_01f/", id=30, ch="美岬", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1221", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Asane, we’re already like family. You don’t need to refer to me as Hotori. Call me Misaki.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“麻沙音酱～～我们已经像是家人了，别再叫我畔同学，可以叫我美岬喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「麻沙音醬～～我們已經像是家人了，別再叫我畔同學，可以叫我美岬喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00027",
		linknext = "0107_00029",
		line = 415,
	},
	["0107_00029"] = {
		{"fg", file="asane_01f_00008", file1="asane_01f_00101", file2="asane_01f_00216", path=":fg/asane_01f/", id=30, ch="麻沙音", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
