		{"fg", file="ikuko_01f_00001", file1="ikuko_01f_00101", file3="ikuko_01f_00313", path=":fg/ikuko_01f/", id=30, ch="郁子", lv=10, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2188", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Yeah... I pulled an all-nighter. I usually knock it out in the beginning, but I kept putting it off with all the stuff that went on this summer vacation.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嗯⋯⋯我熬夜了。以前都是会事先就先做完的，今年暑假太多事情了，结果就拖到最后⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嗯⋯⋯我熬夜了。以前都是會事先就先做完的，今年暑假太多事情了，結果就拖到最後⋯⋯」",
					{"rt2"},
				},
			},
		},
