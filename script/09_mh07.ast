				{"vo", file="asane1485", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“In your dreams. I don’t get how my bro thinks a greasy slob like you is beautiful.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我才不要⋯⋯像你这种满身脂肪的大肥仔，美字用在你身上一点都不配⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我才不要⋯⋯像妳這種滿身脂肪的大肥仔，美字用在妳身上一點都不配⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00028",
		linknext = "0107_00030",
		line = 428,
	},
	["0107_00030"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00101", file2="misaki_01f_00214", path=":fg/misaki_01f/", id=30, ch="美岬", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1222", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Well, people who are beautiful on the outside are usually ugly on the inside, right? So it probably works the other way too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“名字里有美字的人，大部分都不美不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「名字裡有美字的人，大部分都不美不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00029",
