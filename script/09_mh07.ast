		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes, for Misaki and I are fated for one another. We share a bond so strong it has the power to create heaven and earth.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我与美岬殿下之间可是有着牢不可摧的羁绊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我與美岬殿下之間可是有著牢不可摧的羈絆。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00125",
		linknext = "0107_00127",
