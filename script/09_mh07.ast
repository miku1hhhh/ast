			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Well, it is a tropical island. The temp does drop a little, but it’s mostly like this all year round.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“整年都这样的岛嘛⋯⋯偶尔气温会低一点没错，但是大致上都这样啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「整年都這樣的島嘛⋯⋯偶爾氣溫會低一點沒錯，但是大致上都這樣啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00044",
		linknext = "0107_00046",
		line = 673,
	},
	["0107_00046"] = {
