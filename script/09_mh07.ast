					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh? She doesn’t remember me? Could it be amnesia?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“什么⋯⋯？我消失在麻沙音酱的记忆中了吗⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「什麼⋯⋯？我消失在麻沙音醬的記憶中了嗎⋯⋯？」",
