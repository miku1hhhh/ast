		{"fg", file="misaki_01f_00001", file1="misaki_01f_00103", file3="misaki_01f_00308", path=":fg/misaki_01f/", id=30, ch="美岬", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1217", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Wake up and smell the coffee! Time to go to school with your big sister!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“起来了啦，和姐姐我们一起去学校吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「起來了啦，和姊姊我們一起去學校吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00016",
		linknext = "0107_00018",
		line = 274,
	},
	["0107_00018"] = {
		{"fg", file="asane_01f_00008", file1="asane_01f_00101", file2="asane_01f_00205", path=":fg/asane_01f/", id=30, ch="麻沙音", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1480", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Is this a nightmare?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“这是恶梦吗⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「這是惡夢嗎⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00017",
		linknext = "0107_00019",
		line = 287,
	},
	["0107_00019"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00103", file2="misaki_01f_00202", path=":fg/misaki_01f/", id=30, ch="美岬", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1218", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Sadly it’s reality. Summer vacation is over, and I am your big sister!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“很可惜的是现实。暑假结束了，我还是麻沙酱的姐姐。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「很可惜的是現實。暑假結束了，我還是麻沙醬的姊姊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00018",
		linknext = "0107_00020",
		line = 300,
	},
	["0107_00020"] = {
		{"fg", file="asane_02f_00008", file1="asane_02f_00101", file2="asane_02f_00211", path=":fg/asane_02f/", id=30, ch="麻沙音", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1481", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Lies. Lies, all of it! My summer vacation never ends, and this walking tub of lard is no sister of mine!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“骗人⋯⋯假的假的⋯⋯我的暑假还没结束，我也不认识这个胖子⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「騙人⋯⋯假的假的⋯⋯我的暑假還沒結束，我也不認識這個胖子⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00019",
		linknext = "0107_00021",
		line = 313,
	},
	["0107_00021"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00102", file2="misaki_01f_00209", path=":fg/misaki_01f/", id=30, ch="美岬", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
