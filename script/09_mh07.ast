					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“So my summer vacay starts today! I’ll need a month off at minimum so I’m gonna listen to Onabuta’s relaxing voice recordings while I go back into hibernation ehehe my Goddess Onabuta zzzzzz...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“所以我的暑假要从今天开始，最少也要休一个月。我现在要去听女部田前辈的声音当安眠曲了，女部田前辈耶嘿嘿⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「所以我的暑假要從今天開始，最少也要休一個月。我現在要去聽女部田前輩的聲音當安眠曲了，女部田前輩耶嘿嘿⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0107_00035",
