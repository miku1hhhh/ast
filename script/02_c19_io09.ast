	["0039_00160"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00229", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1033", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Huh... Ahaha. Being chased off the island and separated from those I care about was pretty heartbreaking.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“这样啊⋯⋯。啊哈哈哈。被驱除出岛、要跟大家分开的时候，我真的很沮丧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「這樣啊⋯⋯。啊哈哈哈。被驅除出島、要跟大家分開的時候，我真的很沮喪。」",
					{"rt2"},
				},
			},
		},
		linkback = "0039_00159",
		linknext = "0039_00161",
		line = 2111,
	},
	["0039_00161"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I didn’t go into that much detail, but she’s sharp enough to get the point.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我明明什么都没说，她也猜能到这么多，果然很敏锐。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我明明什麼都沒說，她也猜能到這麼多，果然很敏銳。",
					{"rt2"},
				},
			},
		},
		linkback = "0039_00160",
		linknext = "0039_00162",
		line = 2121,
	},
	["0039_00162"] = {
