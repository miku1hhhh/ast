	},
	["0039_00072"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1006", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I didn’t know what to do after I couldn’t live in the dorm anymore, so I’ve been sneaking out here to get my hair in order. But now... Sniff...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“回不了宿舍的时候我就知道要糟糕了⋯⋯所以、所以才偷偷摸摸跑出来努力把头发弄好的说⋯⋯呜呜⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「回不了宿舍的時候我就知道要糟糕了⋯⋯所以、所以才偷偷摸摸跑出來努力把頭髮弄好的說⋯⋯嗚嗚⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0039_00071",
		linknext = "0039_00073",
		line = 977,
	},
	["0039_00073"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ikuko sniffs and snorts as the tears flow down her cheeks now that the cat’s out of the bag.",
					{"rt2"},
				},
			},
			cn = {
				{
					"秘密被发现的郁子泪如雨下地哭个不停。",
					{"rt2"},
				},
			},
			tw = {
				{
					"秘密被發現的郁子淚如雨下地哭個不停。",
					{"rt2"},
				},
			},
		},
		linkback = "0039_00072",
