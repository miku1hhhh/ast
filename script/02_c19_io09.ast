			},
			tw = {
				{
					name = {"郁子"},
					"「吶淳之介君，你有聽過那個傳言嗎⋯⋯？那些看過一隊隊長亂髮的人啊⋯⋯一個生還的也沒有喔⋯⋯」",
					{"rt2"},
				},
			},
		},
