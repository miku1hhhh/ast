			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Weeh... Why’d it have to be YOU that found me? You were the only one I didn’t want to see me like this! I don’t think I can deal with this... Goodbye cruel world!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“呜呼⋯⋯明明就只有亲爱的你，我最不想被你看到的⋯⋯明明就不想被你看到的⋯⋯讨厌⋯⋯我还是自杀好了⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嗚呼⋯⋯明明就只有親愛的你，我最不想被你看到的⋯⋯明明就不想被你看到的⋯⋯討厭⋯⋯我還是自殺好了⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0039_00073",
		linknext = "0039_00075",
		line = 1003,
	},
	["0039_00075"] = {
