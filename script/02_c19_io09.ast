					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“You think I wanted to show this much vulnerability to you?! Getting to see my tits and my pussy wasn’t enough for you?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我就是觉得很丢脸！胸部也好小穴也要你想要看的话我就让你看！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我就是覺得很丟臉！胸部也好小穴也要你想要看的話我就讓你看！」",
