	["0039_00081"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1009", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“What’s cute about this, huh? NOTHING! S’like a BIRD’S NEST! Why’s there seaweed in the fricking river?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“哪里可爱了！？哪里！？像鸟巢一样！？还是说像河里的海带一样的地方！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「哪裡可愛了！？哪裡！？像鳥巢一樣！？還是說像河裡的海帶一樣的地方！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0039_00080",
		linknext = "0039_00082",
		line = 1094,
	},
	["0039_00082"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00228", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Relax! I’ve always wanted to see you with bedhead! I’ve already seen you naked at this point, so this is like a new vulnerable side of you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你冷静点！只是被看到头发乱掉的样子而已嘛！一般来讲裸体被人看到才比较丢脸吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳冷靜點！只是被看到頭髮亂掉的樣子而已嘛！一般來講裸體被人看到才比較丟臉吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0039_00081",
		linknext = "0039_00083",
		line = 1106,
	},
	["0039_00083"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1010", path=":vo/", ch="ikuko"},
			},
			ja = {
