			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Everyone may be against me, but I’ve been wondering if maybe you felt the same way.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“大家都变成了敌人⋯⋯我刚刚也才隐约想到，大概亲爱的你就是这种感觉吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「大家都變成了敵人⋯⋯我剛剛也才隱約想到，大概親愛的你就是這種感覺吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0039_00184",
		linknext = "0039_00186",
		line = 2447,
	},
