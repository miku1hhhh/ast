					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I’d be lying if I said it’ll be totally fine. Obviously, it’s a pretty lonely and sad feeling.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我完全没事⋯⋯要是我这样讲的话那肯定是在骗人。果然还是觉得很难过、很落寞。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我完全沒事⋯⋯要是我這樣講的話那肯定是在騙人。果然還是覺得很難過、很落寞。」",
					{"rt2"},
				},
			},
		},
		linkback = "0039_00162",
		linknext = "0039_00164",
		line = 2146,
	},
	["0039_00164"] = {
