	["0039_00175"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00103", file2="ikuko_02m_00222", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1041", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Y’know, I really like you, Junnosuke. That isn’t to say I didn’t like you before but... it’s different now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“大概啊。我真的很喜欢淳之介君你吧。虽然说我从以前就一直很喜欢你，只是……最近有点不一样了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「大概啊。我真的很喜歡淳之介君你吧。雖然說我從以前就一直很喜歡你，只是……最近有點不一樣了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0039_00174",
		linknext = "0039_00176",
		line = 2309,
	},
	["0039_00176"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00103", file3="ikuko_02m_00310", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1042", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“My heart starts to race when I’m around you. And when you saw me before I thought I might actually die of embarrassment, but my heart was pounding like I was in berserker mode.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“跟淳之介君在一起的时候，我的心就会怦怦跳。刚才被看到的时候⋯⋯我都要丢脸死了⋯⋯不知道怎么样，我的心就像进入狂战士模式一样狂跳。”",
					{"rt2"},
				},
			},
			tw = {
