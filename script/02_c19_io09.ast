	["0039_00168"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1037", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“We may have been set up, but that doesn’t mean we’re out of options. We have Tokie and Rey too. We can all fight.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“虽然完全中了对方的计⋯⋯但也不会完全任凭对方摆布的。桐香酱跟礼酱也都在。我们还能对抗下去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「雖然完全中了對方的計⋯⋯但也不會完全任憑對方擺佈的。桐香醬跟禮醬也都在。我們還能對抗下去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0039_00167",
		linknext = "0039_00169",
		line = 2212,
	},
	["0039_00169"] = {
