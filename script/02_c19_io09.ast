					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“YES THERE IS! There’s no relaxing now! It’d be easier just to give up now that you’ve seen my hair like this. This isn’t just a bad hair day. IT’S A BAD HAIR LIFE!”",
