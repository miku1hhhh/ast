		line = 86,
	},
	["0039_00007"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Are the strike force this short-staffed or are they just sending their lesser grunts to try and drive us out?",
					{"rt2"},
				},
			},
			cn = {
				{
					"要不就是他们人手不足、要不就是干脆派出全是母老虎的强袭不对来解决麻烦。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要不就是他們人手不足、要不就是乾脆派出全是母老虎的強襲不對來解決麻煩。",
					{"rt2"},
				},
			},
		},
		linkback = "0039_00006",
