		text = {
			vo = {
				{"vo", file="gmobc0062", path=":vo/", ch="gmob"},
			},
			ja = {
				{
					name = {"モブ女C", "クールフール"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Cool Fool"},
					"“How do you expect them to hear you if you’re that quiet? You gotta be louder. Like this: HHHEEEEEEYYY!!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "蠢酷"},
					"“你还是一样蠢欸，小声一点啦。不要那么那大声⋯⋯呜喔哇哇啊啊啊啊啊啊啊──！！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "蠢酷"},
					"「你還是一樣蠢欸，小聲一點啦。不要那麼那大聲⋯⋯嗚喔哇哇啊啊啊啊啊啊啊──！！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0039_00003",
		linknext = "0039_00005",
		line = 64,
	},
