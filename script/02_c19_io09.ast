		line = 96,
	},
	["0039_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Whichever way you look at it, they’ve basically been leaving us alone. What else are they up to at the minute?",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管是哪种，实际上都是完全放置我们的状态──那么，他们现在到底在做什么？",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管是哪種，實際上都是完全放置我們的狀態──那麼，他們現在到底在做什麼？",
					{"rt2"},
				},
			},
		},
