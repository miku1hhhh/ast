	["0039_00006"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A screech like that would make anyone jump out of their skin. But I’m not just anyone.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我会警觉他们不是很正常的吗他们声音那么大──很明显完全是选错人当搜索人员。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我會警覺他們不是很正常的嗎他們聲音那麼大──很明顯完全是選錯人當搜索人員。",
					{"rt2"},
				},
			},
		},
