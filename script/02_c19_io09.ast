			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Ha... Haha... HaHAhaHAha... I’ve heard that people achieve a sort of zen-like calm when they’re close to dying... You ever hear that?”",
					{"rt2"},
				},
			},
			cn = {
