					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I was forced into sexual activity, ostracized by my classmates. I felt crushed and defeated.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当我被强制进行不情愿的性行为、在班上受人排挤，心中已经快放弃了的时候。",
