			en = {
				{
					"The amusement park quickly fades into the distance as we blast over the shopping district at a terrifying rate.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们的起点游乐园转眼之间已经变成了遥远的彼端，而长长的繁华街也以惊人的速度往后方流逝。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們的起點遊樂園轉眼之間已經變成了遙遠的彼端，而長長的繁華街也以驚人的速度往後方流逝。",
					{"rt2"},
				},
