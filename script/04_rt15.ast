	["0071_00137"] = {
		{"evset", file="rcg02", set="rcg02", path=":ev/rcg02/"},
		{"evset", file="rcg0201010304", set="rcg020101", path=":ev/rcg020101/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="rcg0201010304", x=-5, y=-2.5, path=":cg/rcg02/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=500, draw2=1},
		{"ex", time=500, func="wait"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0233", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Every day is so much fun. Yesterday and today. Tomorrow too, probably. I’m so happy, I start to wonder sometimes if it’s okay to feel this happy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我每一天都过得非常快乐。昨天也好今天也好……明天肯定也会。甚至让我有时候会忍不住想，这么幸福真的可以吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我每一天都過得非常快樂。昨天也好今天也好……明天肯定也會。甚至讓我有時候會忍不住想，這麼幸福真的可以嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00136",
		linknext = "0071_00138",
		line = 1817,
	},
	["0071_00138"] = {
		{"evset", file="rcg02", set="rcg02", path=":ev/rcg02/"},
		{"evset", file="rcg0201010302", set="rcg020101", path=":ev/rcg020101/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="rcg0201010302", x=-5, y=-2.5, path=":cg/rcg02/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0234", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“And that’s all thanks to you, Rei. Because you’re here, I’m the happiest I can possibly be.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“这一切……我觉得全都是多亏了礼酱。因为有礼酱在……我才能这么幸福”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「這一切……我覺得全都是多虧了禮醬。因為有禮醬在……我才能這麼幸福」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00137",
		linknext = "0071_00139",
		line = 1836,
	},
	["0071_00139"] = {
