	["0071_00007"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"At first, we were shocked at the unexpected reactions, but the audience’s excitement is contagious.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然得到了超乎想像的反响让我一开始有点吓到──可是被那闪闪发光的眼神注视、被那快乐的声色呼唤，就连我们也都被那种情绪感染了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然得到了超乎想像的反響讓我一開始有點嚇到──可是被那閃閃發光的眼神注視、被那快樂的聲色呼喚，就連我們也都被那種情緒感染了。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00006",
		linknext = "0071_00008",
		line = 109,
	},
