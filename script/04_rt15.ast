		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I remember fighting alongside her in the other world, the time we spent together, the laughs we shared.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我还记得──在另一个世界里和礼前辈一起奋战、一起生活、一起欢笑。",
