	["0071_00293"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I cut through the air like a knife, a human bullet flying faster than the speed of sound.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我画过空中，用几乎要超越音速的势头、像个人肉炮弹一样直直往前飞。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我畫過空中，用幾乎要超越音速的勢頭、像個人肉砲彈一樣直直往前飛。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00292",
		linknext = "0071_00294",
