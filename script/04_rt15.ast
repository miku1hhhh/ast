	["0071_00020"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The blazing sun on the island is harsh, even into the fall months.",
					{"rt2"},
				},
			},
			cn = {
				{
					"照耀着这常夏的岛屿的阳光，就算过了十月也还是一如往常地强烈。",
					{"rt2"},
				},
			},
			tw = {
				{
					"照耀著這常夏的島嶼的陽光，就算過了十月也還是一如往常地強烈。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00019",
		linknext = "0071_00021",
		line = 296,
	},
	["0071_00021"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And wearing a huge mascot costume in the heat while performing is an even greater burden.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在这样的暑气之中，穿着布偶装表演──",
					{"rt2"},
				},
			},
			tw = {
				{
					"在這樣的暑氣之中，穿著布偶裝表演──",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00020",
		linknext = "0071_00022",
		line = 306,
	},
	["0071_00022"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s one thing to ask the FS, with their special training, but Hinami’s just a normal girl. She can’t handle these conditions easily.",
					{"rt2"},
				},
			},
			cn = {
				{
					"受过特殊训练的FS姑且不论，身为一般参加者的雏见想必相当吃不消吧。",
					{"rt2"},
				},
			},
			tw = {
				{
