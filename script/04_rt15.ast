		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even as I try to cut her off, Hinami continues unabated.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算我用激烈的言词想要把她推开，雏见仍然一步也不退让。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算我用激烈的言詞想要把她推開，雛見仍然一步也不退讓。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00132",
