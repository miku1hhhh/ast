			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You’d better remember this, Rei! No matter what people say to me, no matter how much you try to pull away, I’ll always love you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“记好了喔礼！不管你对我说什么、不管你推开我多少次，我都一样喜欢礼！”",
