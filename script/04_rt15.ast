					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I did everything I could to stay alive! No matter what they asked me to do, I did it without question! I said awful things... Surely you know that, Hinami?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“为了活下去我什么都做过了！不论被按上什么烙印都在所不辞！卑劣的主张我也说过了！雏见你不是也很清楚的吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「為了活下去我什麼都做過了！不論被按上什麼烙印都在所不辭！卑劣的主張我也說過了！雛見妳不是也很清楚的嗎！？」",
					{"rt2"},
				},
			},
		},
