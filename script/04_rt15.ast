	["0071_00351"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ignoring the waves washing over us and soaking her clothes, she embraces me so tightly it hurts.",
					{"rt2"},
				},
			},
			cn = {
				{
					"毫不在意拍上来的波浪、也不惜弄湿衣服，她用几乎让人有点疼痛的力道紧紧地抱住了我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"毫不在意拍上來的波浪、也不惜弄濕衣服，她用幾乎讓人有點疼痛的力道緊緊地抱住了我。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00350",
		linknext = "0071_00352",
		line = 5237,
	},
	["0071_00352"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1278", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I love you! I love you so much! I really love you! I love your smile! I love the way you never give up despite your weakness!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“喜欢你……我喜欢你！我真的喜欢你！！我喜欢你的声音！喜欢你的笑容！喜欢明明就是个弱鸡却绝不放弃的你！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「喜歡你……我喜歡你！我真的喜歡你！！我喜歡你的聲音！喜歡你的笑容！喜歡明明就是個弱雞卻絕不放棄的你！」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00351",
		linknext = "0071_00353",
		line = 5249,
	},
	["0071_00353"] = {
		{"text"},
		text = {
			vo = {
