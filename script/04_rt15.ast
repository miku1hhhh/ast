				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「沒有什麼好不安的喔。不論妳以前做過什麼事情，不論那是多麼難受的事情……如果是妳跟淳君兩個人一起，一定能夠改變的」",
					{"rt2"},
				},
			},
		},
