		{"text"},
		delay = {
			[1500] = {
				{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", file2="hinami_01m_00205", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, timestamp=15, delay2=1500, mode=3, x=-5, y=-5},
			},
			[1499] = {
				{"transitiontime", time=300, timestamp=15, delay2=1500},
			},
		},
		text = {
			vo = {
				{"vo", file="hinami0212", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Aww, thanks! I know it’s good for us to have a place to rest, but... are the guests okay?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“当然可以了！……不过，我们有可以休息的地方倒是无所谓，来玩的大家不要紧吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「當然可以了！……不過，我們有可以休息的地方倒是無所謂，來玩的大家不要緊嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00051",
		linknext = "0071_00053",
		line = 743,
	},
	["0071_00053"] = {
		{"fg", file="rei_01f_00001", file1="rei_01f_00101", file2="rei_01f_00207", path=":fg/rei_01f/", id=30, ch="礼", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1240", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“There are water fountains all around, along with benches and tents for people to rest in. I reckon they’ll be fine. We have emergency response teams here as well, just in case.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“岛上各地都有饮水机，也设置了很多休息用的椅子和帐篷。应该不用担心才对。而且真的发生了什么事的时候也可以在这里做应急处理嘛”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「島上各地都有飲水機，也設置了很多休息用的椅子和帳篷。應該不用擔心才對。而且真的發生了什麼事的時候也可以在這裡做應急處理嘛」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00052",
		linknext = "0071_00054",
		line = 756,
	},
	["0071_00054"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0213", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I see... Everyone worked hard to bring those chairs. I want people to be able to rest if they feel tired.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“这样啊……毕竟是大家努力搬出来的椅子，如果累了希望他们能好好在上面休息呢”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「這樣啊……畢竟是大家努力搬出來的椅子，如果累了希望他們能好好在上面休息呢」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00053",
		linknext = "0071_00055",
		line = 771,
	},
	["0071_00055"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", file2="hinami_02m_00201", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=-5, y=-5},
