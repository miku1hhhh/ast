				},
			},
			cn = {
				{
					name = {"礼"},
					"“行不通的……如果和我在一起，一定会让橘难过……我是、没有让别人……幸福的能力的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「行不通的……如果和我在一起，一定會讓橘難過……我是、沒有讓別人……幸福的能力的……！」",
					{"rt2"},
				},
			},
		},
