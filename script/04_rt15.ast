			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I understand that, but it’s fine. I know it. You and Jun are both the hardest working people I know. So whatever happens, you’ll be able to overcome it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“是啊……可是不要紧的啦。我很清楚。淳君和礼酱都是比任何人都还要努力的人。所以，不论遇到了什么困难，你们绝对都能跨越的”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「是啊……可是不要緊的啦。我很清楚。淳君和禮醬都是比任何人都還要努力的人。所以，不論遇到了什麼困難，你們絕對都能跨越的」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00189",
		linknext = "0071_00191",
		line = 2604,
	},
	["0071_00191"] = {
