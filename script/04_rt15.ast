				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯，没错。当然我是没有要你们今天明天马上就开始交往啦──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯，沒錯。當然我是沒有要你們今天明天馬上就開始交往啦──」",
					{"rt2"},
				},
			},
		},
