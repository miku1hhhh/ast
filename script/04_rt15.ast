			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I love everything about you, Junnosuke!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我喜欢！淳之介的一切！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我喜歡！淳之介的一切！！」",
