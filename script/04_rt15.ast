	["0071_00107"] = {
		{"evset", file="rcg02", set="rcg02", path=":ev/rcg02/"},
		{"evset", file="rcg02_l01010201", set="rcg02_l01", path=":ev/rcg02_l01/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="rcg02_l01010201", x=-312, y=-222, path=":cg/rcg02_l/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1257", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“And that’s why... That’s why I don’t deserve to fall in love...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“所以……所以！像我这种人……是不可以喜欢上别人的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「所以……所以！像我這種人……是不可以喜歡上別人的……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00106",
		linknext = "0071_00108",
		line = 1466,
	},
	["0071_00108"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No matter how honest and friendly I act now, I can’t wash away the sins of my past.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不论现在多努力保持清廉，都无法改变过去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不論現在多努力保持清廉，都無法改變過去。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00107",
		linknext = "0071_00109",
		line = 1476,
	},
	["0071_00109"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My body is corrupted, and no amount of talking can fix that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我的身体已经弄脏了，不论如何挣扎都无法改变这个事实。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我的身體已經弄髒了，不論如何掙扎都無法改變這個事實。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00108",
		linknext = "0071_00110",
		line = 1486,
	},
	["0071_00110"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I need to face it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无法不去面对。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無法不去面對。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00109",
		linknext = "0071_00111",
		line = 1496,
	},
	["0071_00111"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s why, when I talked to him that day, about my past, I gave up on everything.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以──那一天，在我决定把自己的过去告诉他的那个瞬间，我就已经把一切都放弃了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以──那一天，在我決定把自己的過去告訴他的那個瞬間，我就已經把一切都放棄了。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00110",
		linknext = "0071_00112",
		line = 1506,
	},
	["0071_00112"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I gave up on love, on thinking that I’d ever be valid or worthy of being the target of someone’s affections.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我告诉自己我不该揣怀这份恋情──像我这种人，不该对他有所渴望。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我告訴自己我不該揣懷這份戀情──像我這種人，不該對他有所渴望。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00111",
		linknext = "0071_00113",
		line = 1516,
	},
	["0071_00113"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And so I told him everything. About all the crimes I had committed. To unburden myself of him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以，我把一切都说出来了──把我犯下的过错全都摊了开来，想要主动把他推开。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以，我把一切都說出來了──把我犯下的過錯全都攤了開來，想要主動把他推開。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00112",
		linknext = "0071_00114",
		line = 1526,
	},
	["0071_00114"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And yet, he still cared.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可是，我却不禁撒了娇。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可是，我卻不禁撒了嬌。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00113",
		linknext = "0071_00115",
		line = 1536,
	},
	["0071_00115"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was always so fun talking with him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为跟他说话的时光比任何事物都更让我快乐。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為跟他說話的時光比任何事物都更讓我快樂。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00114",
		linknext = "0071_00116",
		line = 1546,
	},
