	["0071_00184"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I wilt under her dazzling smile, only able to feel contempt for myself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被那耀眼的笑容照耀，就连贬低自己也办不到了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被那耀眼的笑容照耀，就連貶低自己也辦不到了。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00183",
		linknext = "0071_00185",
		line = 2509,
	},
	["0071_00185"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0252", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“There’s nothing wrong with it being you, Rei. In fact, it’d be wrong if it weren’t you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“没有礼酱不可以这种事情喔。应该是非礼酱不可才对”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「沒有禮醬不可以這種事情喔。應該是非禮醬不可才對」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00184",
		linknext = "0071_00186",
		line = 2521,
	},
	["0071_00186"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="rcg02_l01020304", x=-312, y=-222, path=":cg/rcg02_l/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=1000, draw2=1},
		{"ex", time=800, func="wait"},
		{"text"},
		text = {
			vo = {
