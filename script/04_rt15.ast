		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She keeps repeating it like a mantra, the words overwhelming us both.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她不断地、不断地重复同样的话，几乎把我压倒。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她不斷地、不斷地重複同樣的話，幾乎把我壓倒。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00353",
