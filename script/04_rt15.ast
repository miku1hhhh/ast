	},
	["0071_00174"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0246", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“You always looked after me. You saved me when things got dangerous. You care so much about me, more than anyone else in the world.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“你一直保护着我。在我危险的时候帮助我。一直都很关心我。比任何人都还要重视我”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「妳一直保護著我。在我危險的時候幫助我。一直都很關心我。比任何人都還要重視我」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00173",
		linknext = "0071_00175",
		line = 2372,
	},
	["0071_00175"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="rcg02_l01010201", x=-1532, y=-672, path=":cg/rcg02_l/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=800, draw2=1},
		{"ex", time=1000, func="wait"},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0247", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“If I forgot my textbook, you’d share yours. If I felt sick, you’d take me to the nurse’s office and stay by my side until I felt better.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“在我忘记带课本的时候礼酱会分给我看。身体不舒服的时候礼酱会带我去医务室。在我好起来以前会一直陪在我身边”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「在我忘記帶課本的時候禮醬會分給我看。身體不舒服的時候禮醬會帶我去保健室。在我好起來以前會一直陪在我身邊」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00174",
		linknext = "0071_00176",
		line = 2389,
	},
	["0071_00176"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0248", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“You helped me with my summer homework projects. You ate lunch with me. You helped me warm up before gym class.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“礼酱会帮我做过暑假的自由研究。会陪我一起吃午饭。在体育课的时候，会陪我一起做暖身操”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「禮醬會幫我做過暑假的自由研究。會陪我一起吃午飯。在體育課的時候，會陪我一起做暖身操」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00175",
		linknext = "0071_00177",
		line = 2401,
	},
	["0071_00177"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hinami’s talking about all these tiny little things, stuff you’d forget about the next day, as if each one is a treasured memory, counting them off on her fingers.",
					{"rt2"},
				},
			},
			cn = {
				{
					"雏见像是在描述什么重要的回忆似地，掰着手指算着那些枝微末节的──真的是，只要隔一天就会忘记了的小事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雛見像是在描述什麼重要的回憶似地，掰著手指算著那些枝微末節的──真的是，只要隔一天就會忘記了的小事。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00176",
		linknext = "0071_00178",
		line = 2411,
	},
	["0071_00178"] = {
		{"evset", file="rcg02", set="rcg02", path=":ev/rcg02/"},
		{"evset", file="rcg02_l01020303", set="rcg02_l01", path=":ev/rcg02_l01/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="rcg02_l01020303", x=-312, y=-222, path=":cg/rcg02_l/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=800},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0249", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“You told me about so many great books. Even when I’d go on and on about the same book constantly during our breaks, you’d smile and join in the conversation.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“介绍了很多好看的书给我看。就算每次下课的时候我都在讲同样一本书的话题，也会笑着听我说”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「介紹了很多好看的書給我看。就算每次下課的時候我都在講同樣一本書的話題，也會笑著聽我說」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00177",
		linknext = "0071_00179",
		line = 2430,
	},
	["0071_00179"] = {
		{"ex", time=500, func="wait"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Why, Hinami?",
					{"rt2"},
				},
			},
			cn = {
				{
					"为什么，雏见。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為什麼，雛見。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00178",
		linknext = "0071_00180",
		line = 2441,
	},
	["0071_00180"] = {
		{"evset", file="rcg02", set="rcg02", path=":ev/rcg02/"},
		{"evset", file="rcg0201020304", set="rcg020102", path=":ev/rcg020102/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="rcg02_l01020304", x=-1532, y=-672, path=":cg/rcg02_l/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=1000},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0250", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“And when you came to my house for a sleepover, we secretly ate cup noodles late at night without my mom knowing. Remember that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“还有到我家来过夜、然后躲着妈妈，在半夜两个人一起吃过泡面对吧”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「還有到我家來過夜、然後躲著媽媽，在半夜兩個人一起吃過泡麵對吧」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00179",
		linknext = "0071_00181",
		line = 2460,
	},
	["0071_00181"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Why are you telling me all this?",
					{"rt2"},
				},
			},
			cn = {
				{
					"为什么她愿意对我这种人、说这么慷慨的话呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"為什麼她願意對我這種人、說這麼慷慨的話呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00180",
		linknext = "0071_00182",
		line = 2470,
	},
	["0071_00182"] = {
		{"evset", file="rcg02", set="rcg02", path=":ev/rcg02/"},
		{"evset", file="rcg02_l01020301", set="rcg02_l01", path=":ev/rcg02_l01/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="rcg02_l01020301", x=-1532, y=-672, path=":cg/rcg02_l/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0251", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I’m happy because you’ve always been there for me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“因为有礼酱在我身边，所以我才能这么幸福喔”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「因為有禮醬在我身邊，所以我才能這麼幸福喔」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00181",
		linknext = "0071_00183",
		line = 2489,
	},
	["0071_00183"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can’t even muster a response anymore.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我已经想不出反驳的话语了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我已經想不出反駁的話語了。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00182",
		linknext = "0071_00184",
