	["0071_00134"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She smiles at me, an angel before a cowardly woman trying to escape the truth.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而是对着想要逃跑的、胆小的我，露出了温柔的微笑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而是對著想要逃跑的、膽小的我，露出了溫柔的微笑。",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00133",
		linknext = "0071_00135",
		line = 1770,
	},
	["0071_00135"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her huge eyes pierce through my costume, as if she sees into my soul.",
					{"rt2"},
