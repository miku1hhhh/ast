	["0071_00104"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1255", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I punished innocent people for so long! I trampled all over their emotions, because I hated them... Because I could never accept them!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我一直！一直一直以来、都在惩罚无辜的人们！一直以来都在践踏他们的思念！因为我恨……因为我无法原谅他们！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我一直！一直一直以來、都在懲罰無辜的人們！一直以來都在踐踏他們的思念！因為我恨……因為我無法原諒他們！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0071_00103",
		linknext = "0071_00105",
		line = 1418,
	},
