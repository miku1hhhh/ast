			},
			en = {
				{
					"Hinami was there, and she gave me the best times of my life, freed from the constraints of the life I didn’t want to lead.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正因为有雏见在，我才能从不情愿的生活方式中解脱，过起现在这像美梦一般的日子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正因為有雛見在，我才能從不情願的生活方式中解脫，過起現在這像美夢一般的日子。",
					{"rt2"},
				},
			},
		},
