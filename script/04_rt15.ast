	["0071_00173"] = {
		{"evset", file="rcg02", set="rcg02", path=":ev/rcg02/"},
		{"evset", file="rcg0201020601", set="rcg020102", path=":ev/rcg020102/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="rcg0201020601", x=-5, y=-2.5, path=":cg/rcg02/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0245", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
