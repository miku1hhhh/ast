					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「真是的，那個人是怎麼回事啊……！最近老是出現在我面前。可是卻不跟我說話，也不插入我……！」",
					{"rt2"},
				},
			},
		},
