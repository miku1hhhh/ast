	["0006_00203"] = {
		{"fg", file="tohka_02ll_00005", file1="tohka_02ll_00101", file3="tohka_02ll_00306", path=":fg/tohka_02ll/", id=8, lv=10, head="tohka_02ll", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"fgact", ch="桐香8", id=8, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"se", id=0, loop=0, file="se_a098"},
		{"se", id=1, loop=0, file="se_a030"},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0087", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Rather than referring to me, Touka Reizeiin, as an inorganic ‘president’ or formal ‘Reizeiin,’ you’d be gracious enough to use Touka, the lone self-symbolizing proper noun given to me by my parents?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“也就是说前辈在叫我冷泉院桐香时，不会毫无感情地叫‘会长’，也不会见外地叫‘冷泉院’，而是会叫父母给我的名字，就是象征我的专有名词‘桐香’对吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「也就是說前輩在叫我冷泉院桐香時，不會毫無感情地叫『會長』，也不會見外地叫『冷泉院』，而是會叫父母給我的名字，就是象徵我的專有名詞『桐香』對嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00202",
		linknext = "0006_00204",
		line = 2705,
	},
	["0006_00204"] = {
