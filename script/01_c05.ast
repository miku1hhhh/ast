	},
	["0006_00527"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This Lewd Land is still the old one, weathered attractions and all.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而这里依然很老旧，游乐设施也上了年纪。",
					{"rt2"},
				},
			},
