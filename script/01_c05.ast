					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“I’ll be recording your every move and assigning demerits each time you act in a way unbecoming of the FS as a Rin-cident! Just remember, I won’t hold back in my SHO reports!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“我会一一记录你们的行动，如果身为FS却做出不恰当行为时，‘花丸点数’会被扣分！并且会毫不留情地向SHO报告！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「我會一一記錄你們的行動，如果身為FS卻做出不恰當行為時，『花丸點數』會被扣分！並且會毫不留情地向SHO報告！」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00480",
		linknext = "0006_00482",
		line = 6499,
	},
	["0006_00482"] = {
		{"fg", file="rin_01m_00001", file1="rin_01m_00101", file2="rin_01m_00203", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
