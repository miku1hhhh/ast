	["0006_00320"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00216", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“In other words, if there’s anything troubling you right now, well... I have to help you out. I have a duty to...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说，如果你现在有什么麻烦……需要有人帮忙的话，我有义务提供援助……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也就是說，如果妳現在有什麼麻煩……需要有人幫忙的話，我有義務提供援助……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00319",
		linknext = "0006_00321",
		line = 4246,
	},
	["0006_00321"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Not only are you a comrade to me, you’re someone I really need to treasure...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对我而言，你既是同伴，同时也是我必须爱护的人……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對我而言，妳既是同伴，同時也是我必須愛護的人……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00320",
		linknext = "0006_00322",
		line = 4257,
	},
	["0006_00322"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00212", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
