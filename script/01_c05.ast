					name = {"礼"},
					"“好，拜托你了！橘，你那个白米的量……真是的，桐香大小姐，你要发呆到什么时候啊！不吃早餐的话，你又会在学园里晕倒喔！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「好，拜託妳了！橘，你那個白米的量……真是的，桐香大小姐，妳要發呆到什麼時候啊！不吃早餐的話，妳又會在學園裡暈倒喔！？」",
					{"rt2"},
				},
			},
		},
