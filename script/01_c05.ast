		{"text"},
		text = {
			vo = {
				{"vo", file="rei0091", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“The stuff you gave me. It really helps keep my hair in check, you know. What a waste, it costs about 20,000 yen...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是你给我的那个。那牌还蛮好用的耶？这个要2万日圆，给我太可惜了吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是妳給我的那個。那牌還蠻好用的耶？這個要2萬日圓，給我太可惜了吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00238",
		linknext = "0006_00240",
