			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Know your place, Susuko! I’ll have you know that this is none other than Mizuhiki Akino, the very individual who selected me to be the SHO special auditor!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“你太瞧不起人了，丝丝子同学！不瞒你说，这位是被花丸提拔的‘SHO特别监察官’──秋野水引！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「妳太瞧不起人了，絲絲子同學！不瞞妳說，這位是被花丸提拔的『SHO特別監察官』──秋野水引！」",
					{"rt2"},
				},
			},
		},
