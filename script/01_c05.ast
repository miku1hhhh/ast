	["0006_00242"] = {
		{"fg", file="tohka_02m_00004", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="桐香8", id=8, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0089", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Oh, did you try that one thing? Camellia oil. Miss Kouki said it works well if you apply it to a comb first.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“对了，你试过那个吗？山茶花油。光姬小姐说只要抹在梳子上直接梳就可以了喔？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「對了，妳試過那個嗎？山茶花油。光姬小姐說只要抹在梳子上直接梳就可以了喔？」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00241",
		linknext = "0006_00243",
		line = 3293,
	},
	["0006_00243"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00227", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="郁子10", id=10, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0086", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Really? I don’t trust anything Kokie says. I’ve already bought about three products that have camellia oil in them...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“咦？人家才不相信珂琪酱说的话呢。而且我已经买过三种添加山茶花油的产品了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「咦？人家才不相信珂琪醬說的話呢。而且我已經買過三種添加山茶花油的產品了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00242",
		linknext = "0006_00244",
		line = 3309,
	},
	["0006_00244"] = {
		{"fg", file="rei_01m_00003", file1="rei_01m_00101", file2="rei_01m_00212", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0092", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You tried straightening it on the mainland and it was back to normal in two days, right? You know, Ran did go to a hair quality improvement salon where they assign you a stylist and...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你不是在本岛烫直过，结果两天就没用了？这么说来，兰好像去过改善发质的发廊，是造型师改善发质──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「妳不是在本島燙直過，結果兩天就沒用了？這麼說來，蘭好像去過改善髮質的髮廊，是造型師改善髮質──」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00243",
		linknext = "0006_00245",
		line = 3324,
	},
