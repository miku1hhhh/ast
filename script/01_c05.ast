			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Honestly, what could that guy have wanted...! I’ve been running into him so often lately. But when he finally says something to me, he won’t even put it inside me a single time...!”",
