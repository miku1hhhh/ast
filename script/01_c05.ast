		{"transitiontime", time=300},
		{"fgact", ch="凛14", id=14, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0020", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Formally speaking, yes, but I’m the one who actually wields the power here. She’s unbelievably impotent when it comes to getting work done. I, the chosen one, will be passing judgment on you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“只是形式上是如此，实权还是操之在我喔！这个人在实务上很糟糕，根本无法让人勃起，所以由天选的我来进行审判。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「只是形式上是如此，實權還是操之在我喔！這個人在實務上很糟糕，根本無法讓人勃起，所以由天選的我來進行審判。」",
					{"rt2"},
				},
			},
		},
