				},
			},
			cn = {
				{
					name = {"礼"},
					"“没错，橘，别在意，快点吃饭吧……FS要是迟到的话，没办法给周遭的人当榜样的……嚼嚼……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「沒錯，橘，別在意，快點吃飯吧……FS要是遲到的話，沒辦法給周遭的人當榜樣的……嚼嚼……」",
					{"rt2"},
				},
			},
		},
