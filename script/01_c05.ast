	},
	["0006_00190"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If we want to get back to our world, we have to become allies in the truest sense.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们为了回到自己的世界，接下来真的得当同伴了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們為了回到自己的世界，接下來真的得當同伴了。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00189",
		linknext = "0006_00191",
		line = 2526,
	},
	["0006_00191"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The bar to doing that is higher than normal thanks to all the time we spent in opposition to one another.",
					{"rt2"},
				},
			},
			cn = {
				{
					"之前敌对了这么久，导致现在要当同伴的难度也变高了。",
