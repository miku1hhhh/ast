		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"You have to prepare breakfast, make enough lunches for everyone, and get ready to go to school.",
					{"rt2"},
				},
			},
			cn = {
				{
					"必须准备早餐，制作固定人数的便当，还得准备去学校。",
					{"rt2"},
				},
			},
			tw = {
				{
					"必須準備早餐，製作固定人數的便當，還得準備去學校。",
					{"rt2"},
				},
			},
		},
