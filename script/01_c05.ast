				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I hear that in group sports, some teams force their players to all call each other by their first names in order to make communication smoother.",
					{"rt2"},
				},
			},
			cn = {
				{
					"好像是在团体竞技之类的，为了让沟通更圆滑，有的队伍会让大家互叫彼此的名字。",
					{"rt2"},
				},
			},
			tw = {
				{
					"好像是在團體競技之類的，為了讓溝通更圓滑，有的隊伍會讓大家互叫彼此的名字。",
					{"rt2"},
				},
			},
		},
