	["0006_00512"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00217", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="スス子11", id=11, act="振動下", loop=3, size=12.5, time=100, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0028", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Nahaha! I mean, all you’ve got is a slightly sizable schlong! You’re a Seiran virgin, right? And anyway, shy’s just not my style!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“啊哈哈，因为阿橘只是肉棒大的青蓝处男啊！而且人家不是胆小鬼喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「啊哈哈，因為阿橘只是肉棒大的青藍處男啊！而且人家不是膽小鬼喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00511",
		linknext = "0006_00513",
		line = 6937,
	},
	["0006_00513"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00201", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
