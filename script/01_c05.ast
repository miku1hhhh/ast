	["0006_00330"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00101", file2="misaki_02m_00222", path=":fg/misaki_02m/", id=6, lv=6, head="misaki_02m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0031", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Direct instruction from His Sexellency?! This kid here isn’t feeling good right now! He barely ate anything for breakfast! Only two bowls of rice, and they weren’t even heaping!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“难不成是‘性帝亲自辅导’吗？但她的身体不舒服！她今天几乎没吃饭！她才吃了两大匙饭啊！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「難不成是『性帝親自輔導』嗎？但她的身體不舒服！她今天幾乎沒吃飯！她才吃了兩大匙飯啊！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00329",
		linknext = "0006_00331",
