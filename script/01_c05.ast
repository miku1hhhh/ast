					name = {"スス子", "Susuko"},
					"“And who might this be? She looks so submissive she’d serve you up a rimjob if you just asked!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“哎呀，这是哪位啊？那个看起来很乖巧，是那种只要拜托她，连肛门都愿意舔的人？”",
