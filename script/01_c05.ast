	["0006_00641"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That reaction I saw from the FS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"FS等人的那些反应。",
