					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「聽說她前幾天加入某宗教的瞬間，一下子被任命為SHO監察官輔佐，一下子又看到蘭君遇到有趣的不幸。從那之後，她就迷上新興宗教了。」",
					{"rt2"},
				},
			},
		},
