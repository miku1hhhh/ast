			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“If you insist on instructing someone... then please, let it be me! Yes, I can take it! Front hole or back one, just as long as you don’t look at my tummy!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“如果你无论如何都要辅导的话……要做的话就找我吧！我会应战的！只要不看我肚子，前面的穴和后面的穴都能玩！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「如果你無論如何都要輔導的話……要做的話就找我吧！我會應戰的！只要不看我肚子，前面的穴和後面的穴都能玩！」",
					{"rt2"},
