			en = {
				{
					name = {"美岬", "Misaki"},
					"“And sure, while I’m a little hesitant for my first dick to be His Sexellency’s, if it was my ass that I’ve thoroughly trained with figures, then... Hey, Fumino? Something the matter? Hellooo?”",
					{"rt2"},
