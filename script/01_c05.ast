			en = {
				{
					name = {"凛", "Rin"},
					"“Especially you, Your Sexellency—I’ve never been able to stand you...! The way you have such a big head just because you have a big dick... Nothing could inconvenience me more...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“尤其是性帝──我从之前就看你不爽……！你不过是屌大了一点，就得意忘形……只会给人添麻烦……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「尤其是性帝──我從之前就看你不爽……！你不過是屌大了一點，就得意忘形……只會給人添麻煩……」",
					{"rt2"},
