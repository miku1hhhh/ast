	["0006_00240"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file3="ikuko_02m_00307", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0085", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Well, it doesn’t work with my hair type... I tried this one that the store attendant told me fixes frizzy hair too, but...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“因为跟人家的发质不合嘛……是店员说可以把睡翘的头发弄直才买的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「因為跟人家的髮質不合嘛……是店員說可以把睡翹的頭髮弄直才買的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00239",
		linknext = "0006_00241",
		line = 3267,
	},
	["0006_00241"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We all chat as we get ready for school.",
