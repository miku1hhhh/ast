	},
	["0006_00642"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It showed me just how badly the people here truly seemed to want the Lewd Code, along with the USP.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看这情况，这里的人只是单纯在期待变态法，或者是USD。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看這情況，這裡的人只是單純在期待變態法，或者是USD。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00641",
		linknext = "0006_00643",
		line = 8558,
	},
	["0006_00643"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They wholeheartedly believe that the two will bring them absolute happiness.",
					{"rt2"},
				},
			},
			cn = {
				{
					"并相信这就是绝对的幸福，一点也不怀疑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"並相信這就是絕對的幸福，一點也不懷疑。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00642",
		linknext = "0006_00644",
		line = 8568,
	},
	["0006_00644"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg0300020502-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0097", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“This world is brimming with a dangerous ideology to a far greater degree than we thought... Staying here for too long will be dangerous.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这个世界比想像中充满了更多危险的思想……长住会有危险的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這個世界比想像中充滿了更多危險的思想……長住會有危險的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00643",
		linknext = "0006_00645",
		line = 8584,
	},
	["0006_00645"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0091", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Yeah, maybe we should just look for a way to get back as soon as possible... The problem is how we do that, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“是啊。得快点找出回去的方法才行……问题在于该怎么回去，只不过……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「是啊。得快點找出回去的方法才行……問題在於該怎麼回去，只不過……」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00644",
		linknext = "0006_00646",
		line = 8596,
	},
	["0006_00646"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She’s right. We don’t know how to get home.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没错，我们不知道回去的方法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒錯，我們不知道回去的方法。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00645",
		linknext = "0006_00647",
		line = 8606,
	},
	["0006_00647"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"While it’s not as if we’re idling away here, if we don’t find a way...",
					{"rt2"},
				},
			},
			cn = {
				{
					"也不能坐以待毙，但必须找出办法才行──",
					{"rt2"},
				},
			},
			tw = {
				{
					"也不能坐以待斃，但必須找出辦法才行──",
