	["0006_00624"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0090", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“And it seems they plan to place at least one SHO base in each prefecture as part of that in order to maintain public order. In other words...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“为此，SHO好像在各个都道府县都至少设了一个据点，来维持治安。也就是说──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「為此，SHO好像在各個都道府縣都至少設了一個據點，來維持治安。也就是說──」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00623",
		linknext = "0006_00625",
		line = 8364,
	},
	["0006_00625"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...They want to invade Japan using perverted sex.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“…………变态要侵略日本了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「…………變態要侵略日本了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00624",
		linknext = "0006_00626",
		line = 8376,
	},
	["0006_00626"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I recall what Governor Hitoura once said to me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我想起了仁浦氏的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我想起了仁浦氏的話。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00625",
		linknext = "0006_00627",
		line = 8386,
	},
	["0006_00627"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So this world is one where his ambitions became a reality...",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说，这里是他的野心化为现实的世界──",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說，這裡是他的野心化為現實的世界──",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00626",
		linknext = "0006_00628",
		line = 8396,
	},
	["0006_00628"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"World B may be in an even more precarious situation than we first thought.",
					{"rt2"},
				},
			},
			cn = {
				{
					"B世界的情况可能比我们想像得还要危险。",
					{"rt2"},
				},
			},
			tw = {
				{
					"B世界的情況可能比我們想像得還要危險。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00627",
		linknext = "0006_00629",
		line = 8406,
	},
	["0006_00629"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00201", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...But they haven’t been able to enact it yet. That must mean there’s major backlash all over the place, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……但目前还没有执行，就表示各地的反对声浪都很大吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……但目前還沒有執行，就表示各地的反對聲浪都很大吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00628",
		linknext = "0006_00630",
		line = 8418,
	},
	["0006_00630"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0096", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“It seems like a segment of politicians are holding it at bay, but it’s only a matter of time. In fact, it’s reached the final stages before enactment at an unusually quick pace.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“虽然是有部分政治家阻挠，但是似乎只是迟早的事。实际上，执行已经以极快的速度在倒数计时了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「雖然是有部分政治家阻撓，但是似乎只是遲早的事。實際上，執行已經以極快的速度在倒數計時了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00629",
		linknext = "0006_00631",
		line = 8430,
	},
	["0006_00631"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’ll have nowhere to run if all of Japan is overrun with perverted sex.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只要日本全都被变态给占满，就无处可逃了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只要日本全都被變態給佔滿，就無處可逃了。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00630",
		linknext = "0006_00632",
		line = 8440,
	},
	["0006_00632"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We’d essentially be left with no freedom.",
					{"rt2"},
				},
			},
			cn = {
				{
					"人们的自由几乎等于零──",
					{"rt2"},
				},
			},
			tw = {
				{
					"人們的自由幾乎等於零──",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00631",
		linknext = "0006_00633",
		line = 8450,
	},
	["0006_00633"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0095", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“And that’s not even the worst of it. The real issue is the USP.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“如果只是那样还好，但是问题在于‘USD’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「如果只是那樣還好，但是問題在於『USD』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00632",
		linknext = "0006_00634",
		line = 8462,
	},
	["0006_00634"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0096", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“The USP Plan—officially known as the United States of Perversion. This would cause the Perverted Sex Law to apply to every state that joins this union.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“USD计划──正式名称是‘United States of Dosukebe’。这也就是说，加盟合众国的国家，全都适用变态条例。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「USD計畫──正式名稱是『United States of Dosukebe』。這也就是說，加盟合眾國的國家，全都適用變態條例。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00633",
		linknext = "0006_00635",
		line = 8474,
	},
	["0006_00635"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00102", file2="jun_01f_00209", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What did you just say?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你说什么──！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳說什麼──！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00634",
		linknext = "0006_00636",
		line = 8486,
	},
	["0006_00636"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It would spread perverted sex to countries around the world, not just Japan.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不光是日本这个国家，变态做爱会普及到世界上各个国家里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不光是日本這個國家，變態做愛會普及到世界上各個國家裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00635",
		linknext = "0006_00637",
		line = 8496,
	},
	["0006_00637"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And it would all be led by Seiran Island.",
					{"rt2"},
				},
			},
			cn = {
