					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So that’s what the FS and the rest of Seiran Island is waiting for so eagerly...”",
					{"rt2"},
				},
			},
			cn = {
