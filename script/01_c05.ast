			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Ugh, I just can’t tame it at all today... I knew that product I used isn’t for me... Rei? What’re you using these days?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“唉，不行……今天完全无法定型……果然现在的护发不适合我呢……对了，礼酱，你现在用的是哪一牌？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「唉，不行……今天完全無法定型……果然現在的護髮不適合我呢……對了，禮醬，妳現在用的是哪一牌？」",
					{"rt2"},
				},
			},
		},
