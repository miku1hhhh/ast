				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「哎呀，這是哪位啊？那個看起來很乖巧，是那種只要拜託她，連肛門都願意舔的人？」",
					{"rt2"},
				},
			},
		},
