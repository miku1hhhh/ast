			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“I was ordered to become the auditor’s aide as soon as talk of the USP began! Yes, it was a divine revelation! These are indeed the wishes of Lord Skeetus, our god of perversion!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“一提到USD的事，我就被任命为监察官辅佐了……！这也就是说天启！我们无疑是受到变态之神‘塞克罗斯大人’的宠召了──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「一提到USD的事，我就被任命為監察官輔佐了……！這也就是說天啓！我們無疑是受到變態之神『塞克羅斯大人』的寵召了──！」",
					{"rt2"},
				},
			},
		},
