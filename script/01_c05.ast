			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I gave it some thought, and I’m certain that the key connecting Worlds A and B was the way you masturbated that day.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我思考了一下，应该当时的自慰是连接A世界与B世界的关键，绝对错不了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我思考了一下，應該當時的自慰是連接A世界與B世界的關鍵，絕對錯不了。」",
					{"rt2"},
				},
			},
		},
