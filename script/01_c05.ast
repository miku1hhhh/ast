		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I know that man—Governor Hitoura—is capable of as much.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是那个男人──仁浦县知事的话，他应该能解决吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是那個男人──仁浦縣知事的話，他應該能解決吧。",
					{"rt2"},
				},
			},
