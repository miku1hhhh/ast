			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“While the FS Auditor ostensibly represents the student body, the role is given out at random. Really, it only serves to inconvenience whomever is appointed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“嗯，虽然FS监察在名义上是学生代表，不过都是随机选出来的，被任命时只觉得麻烦呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「嗯，雖然FS監察在名義上是學生代表，不過都是隨機選出來的，被任命時只覺得麻煩呢。」",
					{"rt2"},
				},
			},
		},
