		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0085", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Haha. There’s no need to be shy, you know. We’re all in the same boat from here on out, so why don’t we act like it and get along?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呵呵，你不需要顾虑我喔，前辈？我们接下来是一条船上的同伴了，就好好相处吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「呵呵，你不需要顧慮我喔，前輩？我們接下來是一條船上的同伴了，就好好相處吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00186",
		linknext = "0006_00188",
		line = 2493,
	},
	["0006_00188"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00102", file2="jun_01f_00213", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Then the least you could do is get changed on your own. In your own room, too...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“既然这样，你至少学着自己换衣服吧，回你自己房间去换……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「既然這樣，妳至少學著自己換衣服吧，回妳自己房間去換……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00187",
		linknext = "0006_00189",
		line = 2505,
	},
	["0006_00189"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...While the words come from someone with no clothes on, they do make sense.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……虽然她全裸，说的话倒有些道理。",
					{"rt2"},
