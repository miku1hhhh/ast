		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was closed down for a time before remodeling in World A and reopening with all-new facilities.",
					{"rt2"},
				},
			},
			cn = {
				{
					"由于在我们A世界，是曾经拆除重建的关系，整体的设施都很新颖。",
