			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“My intellectual curiosity comes before all. I’m able to gather so much new data if I’m with you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“我只不过是求知欲强了点。和你在一起的话，可以收集到很多未知的数据呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「我只不過是求知慾強了點。和你在一起的話，可以收集到很多未知的數據呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00512",
		linknext = "0006_00514",
		line = 6952,
	},
