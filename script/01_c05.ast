			en = {
				{
					name = {"郁子", "Ikuko"},
					"“...Darling, do you know what happens when you grow frizzy hair out?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“……亲爱的，你知道乱翘的头发是长发的话，会发生什么事吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「……親愛的，你知道亂翹的頭髮是長髮的話，會發生什麼事嗎？」",
					{"rt2"},
				},
			},
		},
