		{"fg", mode=-1, id=16, ch="水引16", ch_origin="水引", lv=16, time=0, sync=0},
		{"fg", file="rin_01m_00001", file1="rin_01m_00101", file2="rin_01m_00213", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0022", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“As much as I’m loathe to have this useless piece of dead weight as my superior... This is all for a greater goal. The enactment of the Lewd Code, and even the USP...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“让这种绑手绑脚的废物在上位，实在很让人郁闷……不这也是为了远大的目标。一切都要到变态法制定以及U．S．D为止──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「讓這種綁手綁腳的廢物在上位，實在很讓人鬱悶……不這也是為了遠大的目標。一切都要到變態法制定以及U．S．D為止──」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00460",
		linknext = "0006_00462",
		line = 6234,
	},
	["0006_00462"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00210", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0026", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Oh, right. The Lewd Code’s supposed to be signed super soon. Hope we can get USP’d up already...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“啊，这样啊。变态法的制定工作也已经在进行了嘛。不能快点USD化吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「啊，這樣啊。變態法的制定工作也已經在進行了嘛。不能快點USD化嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00461",
		linknext = "0006_00463",
		line = 6248,
	},
	["0006_00463"] = {
		{"fg", file="schubert_01m_00002", file2="schubert_01m_00202", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0041", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“There’s no need to rush, Susuko. Few are as brilliant as Governor Hitoura. According to my data, there’s a 99% certainty that the USP will become a reality.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“哎呀，别这么着急，丝丝子君。仁浦县知事大人是罕见的天才。根据我的数据，他有99％可以实现USD喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「哎呀，別這麼著急，絲絲子君。仁浦縣知事大人是罕見的天才。根據我的數據，他有99％可以實現USD喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00462",
		linknext = "0006_00464",
		line = 6262,
	},
	["0006_00464"] = {
		{"fg", file="rin_01m_00001", file1="rin_01m_00101", file3="rin_01m_00302", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
