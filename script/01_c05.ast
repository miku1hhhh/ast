	["0006_00621"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0093", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Next, I learned about this Lewd Code that you contacted me about. All it required was a look through the newspaper, of course...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“还有，前辈先前告知的变态法也查出来了。只要看了这则报导就会知道──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「還有，前輩先前告知的變態法也查出來了。只要看了這則報導就會知道──」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00620",
		linknext = "0006_00622",
		line = 8328,
	},
	["0006_00622"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0094", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“To put it bluntly, the Lewd Code appears to be a law that will make the Perverted Sex Law apply to the entire mainland.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“通俗地说就是，变态法是让‘变态条例’适用于本岛各地的法律。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「通俗地說就是，變態法是讓『變態條例』適用於本島各地的法律。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00621",
		linknext = "0006_00623",
		line = 8340,
	},
	["0006_00623"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
