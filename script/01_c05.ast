	["0006_00043"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I suppose something similar did happen in the past when we were engaged in “combat.”",
					{"rt2"},
				},
			},
			cn = {
				{
					"说起来，在很久以前和她“战斗”的时候，好像也发生过类似的事──",
					{"rt2"},
				},
			},
			tw = {
				{
					"說起來，在很久以前和她「戰鬥」的時候，好像也發生過類似的事──",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00042",
		linknext = "0006_00044",
		line = 526,
	},
	["0006_00044"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=11},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“In the future, could you not enter my room unless you have permission? I sometimes give my dick a workout in the morning.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“以后不要随便进我房间。我早上也是要",
					{"ruby", text="自慰"},
					"锻炼",
					{"/ruby"},
					"的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「以後不要隨便進我房間。我早上也是要",
					{"ruby", text="自慰"},
					"鍛鍊",
					{"/ruby"},
					"的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00043",
		linknext = "0006_00045",
		line = 538,
	},
	["0006_00045"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00202", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0063", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“You did wake up thanks to me, right? I thought I needed to show you just how we live here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“可是，多亏这样你才醒来了吧？我想说要好好告诉亲爱的，在这里生活要注意些什么才行嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「可是，多虧這樣你才醒來了吧？我想說要好好告訴親愛的，在這裡生活要注意些什麼才行嘛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00044",
		linknext = "0006_00046",
		line = 553,
	},
	["0006_00046"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"True, I do have close to zero experience living with a large group.",
					{"rt2"},
				},
			},
			cn = {
				{
					"的确，我几乎没有团体生活的经验。",
					{"rt2"},
				},
			},
			tw = {
				{
					"的確，我幾乎沒有團體生活的經驗。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00045",
		linknext = "0006_00047",
		line = 563,
	},
	["0006_00047"] = {
