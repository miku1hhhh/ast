	["0006_00072"] = {
		{"fg", file="rei_01m_00008", file1="rei_01m_00101", file2="rei_01m_00224", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0073", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“That’s just how it is... Even disciplinary committee presidents are sleepy in the morning too... Everyone is... Everyone across the world... Ikuko’s just the exception...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“没办法啊……风纪委员长早上也是很困的……大家都是这样……全世界都是这样……只有郁子例外……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「沒辦法啊……風紀委員長早上也是很睏的……大家都是這樣……全世界都是這樣……只有郁子例外……」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00071",
		linknext = "0006_00073",
		line = 958,
	},
	["0006_00073"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00207", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0072", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Back at home they’d hang me upside down and drop me into a well if I wasn’t up by 4:30 in the morning, so I’m naturally up and ready to go at that hour, even now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“郁家要是早上4点半不起来的话，会被倒吊起来丢到井里，所以现在时间一到，我就会自然地醒过来了。”",
					{"rt2"},
				},
			},
