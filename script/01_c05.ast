			},
			en = {
				{
					name = {"モブ男B", "Insolent Guy"},
					"“You call yourself a pharaoh? More like a fellati-oh! You must be so wet that you could bring a mummy back to life! Time for my sarco-phallus to get you pregnant with your first prince, Cleobitchra!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "高傲型男子"},
					"“你又不是法老王，是在口交吧，含得太湿的话，说不定木乃伊会起死回生呢！？怀个第一王子吧喂！！怀孕吧！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "高傲型男子"},
					"「妳又不是法老王，是在口交吧，含得太濕的話，說不定木乃伊會起死回生呢！？懷個第一王子吧喂！！懷孕吧！！」",
					{"rt2"},
				},
			},
		},
