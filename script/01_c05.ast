		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Classes have ended, which means another day of work to do as “His Sexellency.”",
					{"rt2"},
				},
			},
			cn = {
				{
					"放学后。今天也要执行‘性帝’的业务。",
					{"rt2"},
				},
			},
			tw = {
				{
					"放學後。今天也要執行『性帝』的業務。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00393",
