	},
	["0006_00395"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A lot is expected out of His Sexellency. You could even call me the irreplaceable face of both the FS and the SHO.",
					{"rt2"},
				},
			},
			cn = {
				{
					"众所期待的‘性帝’职责非常大，可说是FS和SHO都难以取代的‘形象’。",
					{"rt2"},
				},
			},
			tw = {
				{
					"眾所期待的『性帝』職責非常大，可說是FS和SHO都難以取代的『形象』。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00394",
		linknext = "0006_00396",
		line = 5284,
	},
	["0006_00396"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But as far as any “direct Sexellent instruction” goes, I’ve been able to escape those duties thanks to Rei coming up with that line about me feeling the effects of the “intravaginal bucket brigade.”",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是关于‘性帝亲自辅导’，是昨天礼前辈随口说的‘中出接力赛’的后遗症所造成的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是關於『性帝親自輔導』，是昨天禮前輩隨口說的『中出接力賽』的後遺症所造成的。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00395",
		linknext = "0006_00397",
		line = 5294,
	},
	["0006_00397"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
