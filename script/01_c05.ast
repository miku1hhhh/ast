					"而带头的就是这座青蓝岛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而帶頭的就是這座青藍島。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00636",
		linknext = "0006_00638",
		line = 8506,
	},
	["0006_00638"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Which is to say—it would be world domination by way of perverted sex.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这表示──变态要征服世界了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這表示──變態要征服世界了。",
					{"rt2"},
