		{"fgact", ch="凛14", id=14, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0024", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Going around Seiran Island’s facilities to motivate tourists and residents to be more perverted is one of His Sexellency’s laudable duties! Now go, work with all the energy of a prison laborer!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“巡逻青蓝岛的设施，提升观光客或居民的变态干劲，也是了不起的性帝的工作！给我绷紧神经，像被关进监狱的犯人一样工作！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「巡邏青藍島的設施，提升觀光客或居民的變態幹勁，也是了不起的性帝的工作！給我繃緊神經，像被關進監獄的犯人一樣工作！」",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00478",
		linknext = "0006_00480",
		line = 6474,
	},
	["0006_00480"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The younger Hanamaru sister stands haughtily behind me, tablet in hand.",
					{"rt2"},
				},
			},
			cn = {
				{
					"花丸妹单手拿着平板，在后方态度高高在上地说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"花丸妹單手拿著平板，在後方態度高高在上地說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00479",
		linknext = "0006_00481",
