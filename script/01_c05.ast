	["0006_00510"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But for whatever reason, these two—and the younger Tachibana—have always treated me like a normal person.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然而，只有这两人──和花丸妹──从一开始就很正常地和我相处。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然而，只有這兩人──和花丸妹──從一開始就很正常地和我相處。",
					{"rt2"},
				},
			},
		},
		linkback = "0006_00509",
