				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“More like you got teamed up with ’Bana as an exception since so many students were scared of him and scurried off.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“因为大家都怕阿橘怕到纷纷逃跑，所以伯特才会破例跟你一组不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「因為大家都怕阿橘怕到紛紛逃跑，所以伯特才會破例跟你一組不是嗎？」",
					{"rt2"},
				},
			},
		},
