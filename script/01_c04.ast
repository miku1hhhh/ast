				},
			},
			tw = {
				{
					name = {"桐香"},
					"「嗯嗯。所以第一堂課之所以報銷，是因為學生自發進行的性產行為對吧。好，我會告知上層部的人。你可以走了♪」",
					{"rt2"},
				},
			},
		},
