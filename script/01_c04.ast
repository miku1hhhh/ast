					name = {"礼", "Rei"},
					"“If anyone’s having a tough time, it must be you. You don’t know your way around your job, so let me know right away if anything comes up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“比起这个，你也挺辛苦的。这都是你不熟悉的工作，有什么问题立刻联络我吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「比起這個，你也挺辛苦的。這都是你不熟悉的工作，有什麼問題立刻聯絡我吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00317",
