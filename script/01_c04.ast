				},
			},
			cn = {
				{
					name = {"礼"},
					"“我反而觉得怀念又有点有趣！你看，大声说话也可以释放压力……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我反而覺得懷念又有點有趣！你看，大聲說話也可以釋放壓力……！」",
					{"rt2"},
				},
			},
		},
