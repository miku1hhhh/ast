					"「問題在於這個嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00361",
		linknext = "0005_00363",
		line = 4928,
	},
	["0005_00363"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0060", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“But in that case, the question becomes Rin. What was she again, the ‘SHO Special Auditor’s Aide’...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“但这样的话，我在意的是凛的事。印象中她说自己是‘SHO特别监察官补佐’……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「但這樣的話，我在意的是凛的事。印象中她說自己是『SHO特別監察官補佐』……」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00362",
		linknext = "0005_00364",
		line = 4940,
	},
	["0005_00364"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Indeed. The FS wields more authority here in World B than it did in World A.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没错，在这个B世界中，FS的权力比A世界还要大。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒錯，在這個B世界中，FS的權力比A世界還要大。",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00363",
		linknext = "0005_00365",
		line = 4950,
	},
	["0005_00365"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0056", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“That certainly seems true. The FS has a lot of power to make decisions on its own, going by old records of its activities.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“你没说错，我看了过往的活动纪录，FS的独立决定权很大。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「妳沒說錯，我看了過往的活動紀錄，FS的獨立決定權很大。」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00364",
		linknext = "0005_00366",
		line = 4962,
	},
	["0005_00366"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0057", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“For example, in World A the FS could only freely hold events inside the school. Here in World B, though, they seem somewhat free to make decisions.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“举例来说，在我们的A世界中，FS可以自由举办的活动仅限办在学园内，但这个B世界似乎可以在某种程度下自由决定。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「舉例來說，在我們的A世界中，FS可以自由舉辦的活動僅限辦在學園內，但這個B世界似乎可以在某種程度下自由決定。」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00365",
		linknext = "0005_00367",
		line = 4974,
	},
	["0005_00367"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You mean... Without SHO permission.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不需要SHO的许可……是这个意思吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不需要SHO的許可……是這個意思吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00366",
		linknext = "0005_00368",
		line = 4986,
	},
	["0005_00368"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The FS’s parent organization is the SHO.",
					{"rt2"},
				},
			},
			cn = {
				{
					"FS的母体是SHO。",
					{"rt2"},
				},
			},
			tw = {
				{
					"FS的母體是SHO。",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00367",
		linknext = "0005_00369",
		line = 4996,
	},
	["0005_00369"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Normal organizations shouldn’t be able to make decisions without permission from their parent organization.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一般组织不可能未经母体许可做出决定。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一般組織不可能未經母體許可做出決定。",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00368",
		linknext = "0005_00370",
		line = 5006,
	},
	["0005_00370"] = {
		{"evset", file="kcg03", set="kcg03", path=":ev/kcg03/"},
		{"evset", file="kcg0300020202-1", set="kcg030002", path=":ev/kcg030002/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg0300020202-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0039", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“And the biggest reason for that... is probably that the FS has Darling, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“最重要的原因……大概是因为FS有亲爱的在吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「最重要的原因……大概是因為FS有親愛的在吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00369",
		linknext = "0005_00371",
		line = 5025,
	},
	["0005_00371"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0061", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Yes, that would be the natural thought. The FS has gotten stronger thanks to ‘His Sexellency’ and his authority... And it wouldn’t be odd for SHO brass to find that bothersome.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“会这样想是很自然的。FS之中有着影响力强的‘性帝’，权利也随之扩大了……SHO上层部觉得碍事也不奇怪。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「會這樣想是很自然的。FS之中有著影響力強的『性帝』，權利也隨之擴大了……SHO上層部覺得礙事也不奇怪。」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00370",
		linknext = "0005_00372",
		line = 5037,
	},
	["0005_00372"] = {
