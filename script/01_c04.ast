				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Phew, finally done submitting the combat report... This stuff is so boring that it tires me out even worse than mission rehearsals...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“唉～，终于提交战斗报告书了……比起战斗预演，写报告无聊到累死我了……”",
