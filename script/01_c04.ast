		{"se", id=0, loop=0, file="se_a003"},
		{"fg", file="schubert_01m_00002", file2="schubert_01m_00214", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", alpha=0, ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=1, a_chr151=1, mode=3, x=195, y=-5},
		{"fgact", ch="シューベルト12", id=12, lv=12, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="シューベルト12", id=12, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0033", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Well, ours is a top-down organization. The president is going to carry a lot of the burden no matter what. According to my data, nearly every day of the year is like that for her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“我们是上情下达的组织，负担一定会集中到会长的身上。在我的数据中，她几乎365天都是那个样子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「我們是上情下達的組織，負擔一定會集中到會長的身上。在我的數據中，她幾乎365天都是那個樣子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00295",
		linknext = "0005_00297",
		line = 4021,
	},
	["0005_00297"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00206", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=-5, y=-5},
