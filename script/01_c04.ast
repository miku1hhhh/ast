					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If I’m vice president... Does that make it unlikely for the NLNS to exist in World B?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只要我还是副会长……B世界出现NLNS的可能性，很低吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只要我還是副會長……B世界出現NLNS的可能性，很低吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00387",
		linknext = "0005_00389",
		line = 5219,
	},
	["0005_00389"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In other words, I never found my old comrades here in this world.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说，这边的我是不可能获得那些同伴的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說，這邊的我是不可能獲得那些同伴的。",
					{"rt2"},
				},
			},
		},
