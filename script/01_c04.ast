				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Like it matters, you two have naturally silky hair... You could go to bed like that and be just fine. You have no idea how much I have to go through...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“不用吧？你们不用做点什么，头发都会又直又顺～～，直接睡也没问题吧～～，都不知道我有多辛苦～～”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「不用吧？妳們不用做點什麼，頭髮都會又直又順～～，直接睡也沒問題吧～～，都不知道我有多辛苦～～」",
					{"rt2"},
				},
			},
		},
