				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“What’s more, as a sacred being chosen by god, you must all watch your mouths when you speak to me, even if you’re His Sexellency. Or else I’ll gin up a report and get you canned just like—”",
