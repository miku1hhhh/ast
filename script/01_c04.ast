	["0005_00213"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00212", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=14},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Anyway, Schubert. Aren’t you in the 5th Division too? Give me some data on them!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“另外，舒伯特，你也是五队的吧！？是数据对吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「另外，舒伯特，你也是五隊的吧！？是數據對吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00212",
