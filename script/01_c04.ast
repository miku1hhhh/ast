				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Let’s call our world ‘World A’ and this one ‘World B’.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“把我们的世界定义为A，这个世界定义为B。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「把我們的世界定義為A，這個世界定義為B。」",
					{"rt2"},
				},
			},
		},
