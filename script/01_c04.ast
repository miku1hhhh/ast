				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「什麼……！？把那個被稱為高難度藝術點的『伸雞的莖月面』……！？竟然有人類能夠成功做到……唔，我的數據裡沒有啊……！」",
					{"rt2"},
				},
			},
		},
