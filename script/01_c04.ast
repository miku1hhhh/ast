				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I know we might feel a certain way about each other after everything that’s happened... But.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“──一路走来发生了好多事，我们双方应该有各种想法吧……不过。”",
					{"rt2"},
				},
			},
			tw = {
