				{"vo", file="ikuko0040", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“So does the NLNS even exist in this world...? You made that organization, didn’t you, Darling?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“话说回来，这个世界上还有NLNS吗……？那是亲爱的创造的组织吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「話說回來，這個世界上還有NLNS嗎……？那是親愛的創造的組織吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00385",
		linknext = "0005_00387",
		line = 5197,
	},
	["0005_00387"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Oh... right.",
					{"rt2"},
				},
			},
			cn = {
				{
					"嗯──也对。",
					{"rt2"},
				},
			},
			tw = {
				{
					"嗯──也對。",
					{"rt2"},
				},
			},
		},
