			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“It could get annoying if the SHO learns about our situation. We’ll need to act carefully going forward.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“如果让SHO知道我们现在的状况可能会引发麻烦。今后有必要多加注意，好好表现才行。”",
