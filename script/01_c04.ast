		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0064", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Heh heh heh! That’s right, it’s my fault. And in that sense it’s your fault too, for being so charming that I can’t help but go after you❤”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呵呵，对对，都是我的错。从这角度来看的话前辈也有错喔。错都错在前辈太有魅力，才让我趋之若鹜，就是这样",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「呵呵，對對，都是我的錯。從這角度來看的話前輩也有錯喔。錯都錯在前輩太有魅力，才讓我趨之若鶩，就是這樣",
					{"gaiji", text="①"},
					"」",
					{"rt2"},
				},
			},
		},
