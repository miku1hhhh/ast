			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“不是，我是二队的喔！最近只是破例和性帝组队成为同伴……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「不是，我是二隊的喔！最近只是破例和性帝組隊成為同伴……」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00213",
		linknext = "0005_00215",
		line = 2851,
	},
	["0005_00215"] = {
		{"fg", file="susuko_02m_00002", file1="susuko_02m_00101", file2="susuko_02m_00205", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
