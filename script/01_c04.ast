					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“What’s the matter, Your Sexellency? I went to the classroom to get you but you’d gone off somewhere.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“性帝，你怎么了？我刚才去教室迎接你，却不知道你跑到哪里去了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「性帝，你怎麼了？我剛才去教室迎接你，卻不知道你跑到哪裡去了。」",
					{"rt2"},
				},
			},
		},
