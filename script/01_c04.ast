			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“This is all confirmation. A test. To see if Schubert remembers his assignment.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我是在做确认。这是测验，确认舒伯特记不记得自己隶属哪里。”",
