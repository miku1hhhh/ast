		{"fgact", ch="礼9", id=9, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0053", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“...Er, well we are used to it! I did this work for so long, picking it back up should be easy!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……啊不是，我们都已经习惯了！这是做了好几年的工作，重新做这些事也轻轻松松！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……啊不是，我們都已經習慣了！這是做了好幾年的工作，重新做這些事也輕輕鬆鬆！」",
					{"rt2"},
				},
			},
		},
		linkback = "0005_00313",
		linknext = "0005_00315",
		line = 4243,
	},
	["0005_00315"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00102", file2="rei_01m_00218", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
