					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Oh, this little girl! This living proof of my rejection! The crystallization of the love between you and Fumino! She’s wonderful! How... Haa... Haa!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“这就是没选我的结果⋯⋯！前辈和文乃的爱的结晶⋯⋯！真是太优秀了⋯⋯啊，啊⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「這就是沒選我的結果⋯⋯！前輩和文乃的愛的結晶⋯⋯！真是太優秀了⋯⋯啊，啊⋯⋯」",
					{"rt2"},
				},
			},
		},
