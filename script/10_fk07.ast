	["0114_00157"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Speaking of which, it seems like there’s a new generation of Blowjob Cockatoos.",
					{"rt2"},
