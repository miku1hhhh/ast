	["0114_00036"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Developing new adult goods means we’re always constantly running racing against deadlines.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们开发新的成人情趣道具时，总是会被时间压得喘不过气来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們開發新的成人情趣道具時，總是會被時間壓得喘不過氣來。",
					{"rt2"},
				},
			},
		},
