	["0114_00052"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even at this age, even with this scarred body, I still haven’t given up the fight.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算到了这个年纪，就算受伤，我们仍然奋战不懈。",
