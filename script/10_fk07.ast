		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She’s always reassuring us in our efforts and when needed, she scolds us as well. She expertly wields both the carrot and the stick to get us on task.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这时能够时而疗愈时而鞭笞大家，一手糖一手鞭子运用自如的就是她了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這時能夠時而療癒時而鞭笞大家，一手糖一手鞭子運用自如的就是她了。",
					{"rt2"},
				},
			},
		},
