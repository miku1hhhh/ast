		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even Fumino started to tear up at his sobbing during his speech at our wedding.",
					{"rt2"},
				},
			},
			cn = {
				{
					"事实是结婚典礼上的致词，仁浦氏嚎啕大哭惹得文乃也流下了泪来。",
					{"rt2"},
				},
