	["0114_00168"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hitoura pops in here and there since he wants to see his granddaughter. But Fumino’s reaction is still the same as always.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在仁浦氏为了见孙女一面，常常会来露脸，但是关系还是没有什么变化。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在仁浦氏為了見孫女一面，常常會來露臉，但是關係還是沒有什麼變化。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00167",
		linknext = "0114_00169",
		line = 1844,
	},
	["0114_00169"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But it’s clear he’s softened up a great deal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过，他不像以前一样那么阴险倒是明智之举。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過，他不像以前一樣那麼陰險倒是明智之舉。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00168",
		linknext = "0114_00170",
