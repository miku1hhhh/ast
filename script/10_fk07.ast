	["0114_00050"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And, as always, I act as the leader and direct my team as we handle our secret activities.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后在“秘密业务”时指挥队伍站在最前线。",
