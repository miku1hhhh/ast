		line = 662,
	},
	["0114_00061"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino’s eyesight gradually worsened from reading too many books. And her special powers went with it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃因为阅读太多书物导致视力下降的同时，栖息在她眼底的那股神秘力量也消失无踪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃因為閱讀太多書物導致視力下降的同時，棲息在她眼底的那股神秘力量也消失無蹤。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00060",
