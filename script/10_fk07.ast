	["0114_00250"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But that’s what makes you beautiful. Ever since we first met.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“包括没发育这件事，那都是你的魅力呀。从我们相遇的时候开始就是。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「包括沒發育這件事，那都是妳的魅力呀。從我們相遇的時候開始就是。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00249",
