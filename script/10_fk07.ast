		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As a result, the Reizeiin Administration drained the swamp in one go and rebuilt itself with sound management.",
					{"rt2"},
				},
			},
			cn = {
