	},
	["0114_00153"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I hear that sometimes, when Mizuhiki gets nostalgic, it’s still her—she’s a “her” now officially—inside Hamedori instead of Rin.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她──在户籍上的性别已经是“女性”了──偶尔回忆过往时会代替花丸妹进到Hamedori君偶装的里面。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她──在戶籍上的性別已經是“女性”了──偶爾回憶過往時會代替花丸妹進到Hamedori君偶裝的裡面。",
					{"rt2"},
				},
			},
		},
