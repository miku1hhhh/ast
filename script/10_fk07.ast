	},
	["0114_00161"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s former Governor Hitoura.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是前县长仁浦氏本人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是前縣長仁浦氏本人。",
					{"rt2"},
				},
			},
		},
