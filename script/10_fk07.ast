		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A hale and hearty old man enters hesitantly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看起来老当益壮的老人诚惶诚恐的走了进来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看起來老當益壯的老人誠惶誠恐的走了進來。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00159",
