	},
	["0114_00167"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hitoura and Fumino still haven’t made up.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦氏和文乃的关系没有改善多少。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦氏和文乃的關係沒有改善多少。",
					{"rt2"},
				},
			},
		},
