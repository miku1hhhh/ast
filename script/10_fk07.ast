	["0114_00155"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We hang out all the time still.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们直到现在也很常玩在一起。",
					{"rt2"},
				},
