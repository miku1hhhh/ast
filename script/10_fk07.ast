	["0114_00246"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I can’t believe my little Fumino has grown up so much...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么小的文乃，现在已经长得这么大了⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那麼小的文乃，現在已經長得這麼大了⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00245",
		linknext = "0114_00247",
		line = 2727,
	},
	["0114_00247"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1078", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“If you’re worried I’ll get bigger, you can put your fears to rest.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我还担心自己会不会长大，真的是杞人忧天呢⋯⋯”",
