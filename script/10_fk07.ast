	["0114_00042"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She’s incredibly popular with our generation. All she has to do is show her face and the money rolls in. She also does a fine job picking up after Misaki’s messes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在我们的这个世代中获得压倒性人气，稍微出点小力案件就到手，美岬惹出来的事只要有她大致都能解决。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在我們的這個世代中獲得壓倒性人氣，稍微出點小力案件就到手，美岬惹出來的事只要有她大致都能解決。",
					{"rt2"},
				},
			},
		},
