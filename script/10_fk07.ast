	["0114_00213"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, he’s—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“特别的客人是──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「特別的客人是──」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00212",
		linknext = "0114_00214",
