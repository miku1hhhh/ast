	},
	["0114_00162"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He’s still keeping himself busy, promoting his popular beverage company Red Nethers. Currently, he’s also been pushing for more athletes to accept his sponsorship.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个人现在仍然活跃着，将受欢迎的能量饮料公司‘红色耻部’的规模扩大，现在还积极的赞助运动选手。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個人現在仍然活躍著，將受歡迎的能量飲料公司『紅色恥部』的規模擴大，現在還積極的贊助運動選手。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00161",
		linknext = "0114_00163",
		line = 1778,
	},
	["0114_00163"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"His lofty reasoning is that he wants to “make sure all talent sees the light of day.”",
					{"rt2"},
				},
			},
			cn = {
				{
					"他的理由似乎是‘想减少才能被埋没的人’，真是高尚的想法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他的理由似乎是『想減少才能被埋沒的人』，真是高尚的想法。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00162",
		linknext = "0114_00164",
		line = 1788,
	},
