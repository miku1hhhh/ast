	},
	["0114_00224"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He’s got a tan now. His face is clearly weathered from all the tough times he must’ve had since.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然岁月的痕迹还有辛劳都刻在了脸上──",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然歲月的痕跡還有辛勞都刻在了臉上──",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00223",
		linknext = "0114_00225",
		line = 2467,
	},
	["0114_00225"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But he looks exactly like he did that day.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但我觉得他都没有变，还是那天的那个样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但我覺得他都沒有變，還是那天的那個樣子。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00224",
		linknext = "0114_00226",
		line = 2477,
	},
	["0114_00226"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1068", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, seems like everyone’s here now. I think we can finally begin Jun and Fumino’s fifth anniversary celebration!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“全员都到齐了，那么──淳和文乃，结婚5周年纪念派对要开始啰！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「全員都到齊了，那麼──淳和文乃，結婚5週年紀念派對要開始囉！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00225",
		linknext = "0114_00227",
		line = 2489,
	},
	["0114_00227"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1035", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Yay! Yippee!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“耶！哇咿！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「耶！哇咿！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00226",
		linknext = "0114_00228",
		line = 2501,
	},
	["0114_00228"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1969", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Let’s start with a commemorative photo. Since we’re all here for once, let’s have one with just the NLNS members, first. Everyone, get close together!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“先拍张纪念照吧。第一张就请NLNS的大家一起，来来来，站好位置。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「先拍張紀念照吧。第一張就請NLNS的大家一起，來來來，站好位置。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00227",
		linknext = "0114_00229",
		line = 2513,
	},
	["0114_00229"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0013", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Damn. You kids are so impatient. You all go on ahead, I’ll catch up later—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“真是不会照顾人的一群家伙⋯⋯你在那边等着，等等我去找你碰面──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「真是不會照顧人的一群傢伙⋯⋯你在那邊等著，等等我去找你碰面──」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00228",
		linknext = "0114_00230",
		line = 2525,
	},
	["0114_00230"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0175", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Okay, Fumika. How about you come play with me while we wait for them?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“文佳，来这边和外公一起玩一边等他们吧⋯⋯！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「文佳，來這邊和外公一起玩一邊等他們吧⋯⋯！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00229",
		linknext = "0114_00231",
		line = 2537,
	},
	["0114_00231"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumika0021", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"文佳"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文佳", "Fumika"},
					"“Wouldn’t you rather to go play with some young woman, instead?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文佳"},
					"“外公跟年轻女生分手的话我就过去⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文佳"},
					"「外公跟年輕女生分手的話我就過去⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00230",
		linknext = "0114_00232",
		line = 2549,
	},
	["0114_00232"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0176", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Ngh! I’m not sure I can go that far anymore at my age.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“唔⋯⋯真是天人交战，这把年纪还要经历这个⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「唔⋯⋯真是天人交戰，這把年紀還要經歷這個⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00231",
		linknext = "0114_00233",
		line = 2561,
	},
	["0114_00233"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2418", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hinami. Can you move closer to the front? If you stand that far back, you look like a tiny loli and I can’t take a photo of that!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“雏见，再往里面站点！不这样的话你太萝莉了会照不到～～”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「雛見，再往裡面站點！不這樣的話妳太蘿莉了會照不到～～」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00232",
		linknext = "0114_00234",
		line = 2573,
	},
	["0114_00234"] = {
		{"text"},
		text = {
			vo = {
