	},
	["0114_00098"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2275", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Aww, Fumika! You have your dad’s face for sure. Promise to marry me when you get older!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“啊，文佳果然眼睛的地方很像亲爱的！你长大以后和郁郁结婚好不好？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「啊，文佳果然眼睛的地方很像親愛的！妳長大以後和郁郁結婚好不好？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00097",
		linknext = "0114_00099",
		line = 1083,
	},
	["0114_00099"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumika0011", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"文佳"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文佳", "Fumika"},
					"“But I have to marry Father when I get older!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文佳"},
					"“我长大了以后不和爸爸结婚不行⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文佳"},
					"「我長大了以後不和爸爸結婚不行⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00098",
		linknext = "0114_00100",
