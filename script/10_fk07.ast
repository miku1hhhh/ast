	["0114_00174"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1326", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“To think, he used to be such a hard-nosed politician, always fighting with the country’s elite. And now he’s just your regular grandaddy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“那个人以前是政府高层非常有手腕的政治家⋯⋯现在就只是个老爷爷了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「那個人以前是政府高層非常有手腕的政治家⋯⋯現在就只是個老爺爺了呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00173",
		linknext = "0114_00175",
