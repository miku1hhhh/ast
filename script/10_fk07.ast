					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Speaking of clothes. He did start getting better about it. Hmm. Oh, where is that picture?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“就连衣服也都越穿越有品味了⋯⋯啊，是放到哪里去了⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「就連衣服也都越穿越有品味了⋯⋯啊，是放到哪裡去了⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00059",
