	["0114_00077"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Our daughter may look and sound like her mother, but she really takes after me in terms of personality.",
					{"rt2"},
				},
			},
			cn = {
				{
					"女儿不管是外观还是口气还是能力都像妈妈，只有性格怎么看都是像我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"女兒不管是外觀還是口氣還是能力都像媽媽，只有性格怎麼看都是像我。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00076",
