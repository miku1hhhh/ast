	},
	["0114_00214"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1075", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Hehe. He’s Father’s one-and-only Master.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“呵呵，是爸爸的⋯⋯唯一的师父喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「呵呵，是爸爸的⋯⋯唯一的師父喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00213",
		linknext = "0114_00215",
		line = 2356,
	},
	["0114_00215"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1328", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Come on in. What are you shuffling your feet about for? Hurry up and come inside! Junnosuke has been waiting forever for this moment!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“你在害躁个什么劲啊！赶快过来呀，淳之介可是等你很久了呢～～”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「你在害躁個什麼勁啊！趕快過來呀，淳之介可是等你很久了呢～～」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00214",
		linknext = "0114_00216",
		line = 2368,
	},
	["0114_00216"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0010", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "???"},
					"“Stop rushing me, pig bitch! Just looking at ya dumb face is making me angry!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋", "？？？"},
					"“喂，等等啊，你这母猪⋯⋯！一看到你的脸我就觉得很不爽⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋", "？？？"},
					"「喂，等等啊，妳這母豬⋯⋯！一看到妳的臉我就覺得很不爽⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00215",
		linknext = "0114_00217",
		line = 2380,
	},
	["0114_00217"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1610", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hey, come already, Mr. Master! You and your Masao-looking face.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“快来呀，师父⋯⋯是说，完全就是小夫的脸耶⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「快來呀，師父⋯⋯是說，完全就是小夫的臉耶⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00216",
		linknext = "0114_00218",
		line = 2392,
	},
	["0114_00218"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0011", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "???"},
					"“God, yer all an annoying bunch of twerps like always, huh! There’s someone I wanted to talk to, first.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋", "？？？"},
					"“啧，还是没变啊，一群臭小鬼⋯⋯！我也有想像你们介绍的人──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋", "？？？"},
					"「嘖，還是沒變啊，一群臭小鬼⋯⋯！我也有想像妳們介紹的人──」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00217",
		linknext = "0114_00219",
		line = 2404,
	},
	["0114_00219"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"His footsteps come closer.",
					{"rt2"},
				},
			},
			cn = {
				{
					"脚步声渐渐接近。",
					{"rt2"},
				},
			},
			tw = {
				{
					"腳步聲漸漸接近。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00218",
		linknext = "0114_00220",
		line = 2414,
	},
	["0114_00220"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s been decades since we last met. At last, he’s here in front of me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"数十年没见的人，近在眼前。",
					{"rt2"},
				},
			},
			tw = {
				{
					"數十年沒見的人，近在眼前。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00219",
		linknext = "0114_00221",
		line = 2424,
	},
	["0114_00221"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It’s been a while, Master.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯好久不见了，师父。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯好久不見了，師父。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00220",
		linknext = "0114_00222",
		line = 2435,
	},
	["0114_00222"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0012", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“You’ve gotten bigger... Junnosuke.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“唷⋯⋯长大了啊⋯⋯淳之介。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「唷⋯⋯長大了啊⋯⋯淳之介。」",
