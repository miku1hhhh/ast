	["0114_00149"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1964", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Looks like you’ll be having a little brother in no time, missy. What do you think, Tachibana?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呵呵，生弟弟也只是时间的问题而已了吧⋯⋯前辈？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「呵呵，生弟弟也只是時間的問題而已了吧⋯⋯前輩？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00148",
