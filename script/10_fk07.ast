	["0114_00055"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My biggest supporter both publicly and privately.",
					{"rt2"},
				},
			},
			cn = {
				{
					"于公于私成为我的支柱的是──",
					{"rt2"},
				},
			},
			tw = {
				{
					"於公於私成為我的支柱的是──",
					{"rt2"},
