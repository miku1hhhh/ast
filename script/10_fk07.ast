	["0114_00152"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mizuhiki and Susuko especially, since they both joined the SHO officially as publicists. They’re showing great promise in web marketing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"尤其是水引酱和丝丝子她们正式进入SHO负责SHO的宣传，也在网络行销上发挥不少实力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"尤其是水引醬和絲絲子她們正式進入SHO負責SHO的宣傳，也在網路行銷上發揮不少實力。",
					{"rt2"},
				},
			},
		},
