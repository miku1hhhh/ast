				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She’s matured more than she looks. She’s gotten even taller than Rei, but still rocks the same frizzy hairstyle.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她的外观更像大人，身高也已超过礼前辈，只有一头乱发完全没变。",
					{"rt2"},
				},
			},
			tw = {
