			},
			en = {
				{
					"However nowadays, she comes up with novel developments in the adult goods industry that are unrivaled. They’ve all become a smash hit.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在则是在开发成人情趣道具上，拥有无人能及崭新的点子王。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在則是在開發成人情趣道具上，擁有無人能及嶄新的點子王。",
					{"rt2"},
				},
			},
		},
