	},
	["0114_00101"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ikuko now works as the SHO’s Strike Force Commander.",
					{"rt2"},
				},
			},
			cn = {
				{
					"郁子是现役的SHO强袭部队队长。",
					{"rt2"},
				},
			},
			tw = {
				{
					"郁子是現役的SHO強襲部隊隊長。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00100",
		linknext = "0114_00102",
		line = 1116,
	},
	["0114_00102"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It seems like she was scouted as an important executive candidate due to the fact that she graduated with top grades from an SHO-designated school.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为她以顶尖成绩毕业于SHO所援助的学校，所以似乎是珍贵的干部候补成员。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為她以頂尖成績畢業於SHO所援助的學校，所以似乎是珍貴的幹部候補成員。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00101",
		linknext = "0114_00103",
		line = 1126,
	},
	["0114_00103"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, she keeps denying promotions saying she wouldn’t be able to step on the battlefield, if she accepted.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过本人却说“要是升官的话就不能打实战了，我才不要”而逃避晋升事宜。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過本人卻說「要是升官的話就不能打實戰了，我才不要」而逃避晉升事宜。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00102",
		linknext = "0114_00104",
		line = 1136,
	},
	["0114_00104"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She still lives her life in typical Ikuko fashion. I can’t help but be impressed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"还真像郁子的作风，傻眼却又更觉钦佩。",
					{"rt2"},
				},
			},
			tw = {
				{
					"還真像郁子的作風，傻眼卻又更覺欽佩。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00103",
		linknext = "0114_00105",
		line = 1146,
	},
	["0114_00105"] = {
