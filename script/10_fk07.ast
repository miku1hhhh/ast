		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Over the years, she’s developed a womanly charm and is constantly proposed to. However, she continues to decline them all, stating she’s married to her work.",
					{"rt2"},
				},
			},
			cn = {
