	["0114_00190"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1966", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Oh yeah, Tachibana. I have a job for you. A secret one, to be specific.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“对了，前辈，我还带了一个工作来──是“秘密业务”相关的咨询。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「對了，前輩，我還帶了一個工作來──是“秘密業務”相關的諮詢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00189",
		linknext = "0114_00191",
		line = 2087,
	},
	["0114_00191"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Another one?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯又是那方面的工作啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯又是那方面的工作啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00190",
		linknext = "0114_00192",
		line = 2098,
	},
	["0114_00192"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1066", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“It seems like THAT is becoming our main line of work these days.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“怎么有种那边变成了我们的本业的感觉。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「怎麼有種那邊變成了我們的本業的感覺。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00191",
		linknext = "0114_00193",
		line = 2110,
	},
	["0114_00193"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The SHO, or rather Touka, acts as our clientele for our secret business.",
					{"rt2"},
				},
			},
			cn = {
				{
					"于是，SHO──不如说是桐香她们──向我们的“秘密业务”提案。",
					{"rt2"},
				},
			},
			tw = {
				{
					"於是，SHO──不如說是桐香她們──向我們的“秘密業務”提案。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00192",
		linknext = "0114_00194",
		line = 2120,
	},
	["0114_00194"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"At first, it was only intended to be a part-time thing, but before I knew it, we started to get involved with trouble from other sources as well.",
					{"rt2"},
				},
			},
			cn = {
				{
					"最一开始是打工性质，后来发现除了SHO以外，其他地方也会把棘手的事委托给我们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"最一開始是打工性質，後來發現除了SHO以外，其他地方也會把棘手的事委託給我們。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00193",
		linknext = "0114_00195",
		line = 2130,
	},
	["0114_00195"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2416", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I have obtained intel that indicates there seem to be some individuals of unscrupulous character plotting to seize power from the SHO.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“有消息表示想夺取SHO权力的坏人正在谋划不好的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「有消息表示想奪取SHO權力的壞人正在謀劃不好的事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00194",
		linknext = "0114_00196",
		line = 2142,
	},
	["0114_00196"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2277", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I heard they’re timing it right when I’m off overseas giving a pervy speech.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“刚好是郁郁会在国外进行变态演说的时间，所以好像有办法处理⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「剛好是郁郁會在國外進行變態演說的時間，所以好像有辦法處理⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00195",
		linknext = "0114_00197",
		line = 2154,
	},
	["0114_00197"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All of their requests are extremely dangerous and difficult affairs.",
					{"rt2"},
				},
			},
			cn = {
				{
					"每个委托都充满危险性，而且也不是那么轻易就能达成。",
					{"rt2"},
				},
			},
			tw = {
				{
					"每個委託都充滿危險性，而且也不是那麼輕易就能達成。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00196",
		linknext = "0114_00198",
		line = 2164,
	},
	["0114_00198"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Always a matter between life-and-death.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一个不小心，就有生命危险。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一個不小心，就有生命危險。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00197",
		linknext = "0114_00199",
		line = 2174,
	},
	["0114_00199"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Touka says at the same time...",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且──",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且──",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00198",
		linknext = "0114_00200",
		line = 2184,
	},
	["0114_00200"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1967", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“If we let this slide, our pervy way of life is at risk. Can you take care of it, Tachibana?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“这样下去，大家的变态就会危险了⋯⋯可以拜托你们吗？前辈？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「這樣下去，大家的變態就會危險了⋯⋯可以拜託你們嗎？前輩？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00199",
		linknext = "0114_00201",
		line = 2196,
	},
	["0114_00201"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, when you put it like that, how can we possibly refuse? Right, everyone?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果是这样的话⋯⋯就不能不接了吧，是不是啊，大家？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果是這樣的話⋯⋯就不能不接了吧，是不是啊，大家？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00200",
		linknext = "0114_00202",
		line = 2207,
	},
	["0114_00202"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fk07_0000", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"株式会社NLNS"},
					"*テキスト*",
					{"rt2"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"株式会社NLNS", "NLNS"},
					"“Yeah!” “Yep!” “Yes!” “Let’s do it!”",
					{"rt2"},
					"“Absolutely!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"株式会社NLNS"},
					"“是啊。”“嗯。”“没错！”“嘿对⋯⋯”",
					{"rt2"},
					"“好⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"株式会社NLNS", "株式會社NLNS"},
					"「是啊。」「嗯。」「沒錯！」「嘿對⋯⋯」",
					{"rt2"},
					"「好⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00201",
		linknext = "0114_00203",
		line = 2223,
	},
	["0114_00203"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After all, we live for stuff like this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"──内心很兴奋。",
					{"rt2"},
				},
			},
			tw = {
				{
					"──內心很興奮。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00202",
		linknext = "0114_00204",
		line = 2233,
	},
	["0114_00204"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When we’re together, anything is possible.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们全员出动的话什么都做得到。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們全員出動的話什麼都做得到。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00203",
		linknext = "0114_00205",
		line = 2243,
	},
	["0114_00205"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No matter how old we get, that will never change.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管几岁都一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管幾歲都一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00204",
		linknext = "0114_00206",
		line = 2253,
	},
	["0114_00206"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1968", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Then we’ll cover the costs of today’s party. Just make sure to write ‘SHO’ on the receipt. We’ll pay for everything.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“今天的派对就交给我们吧。收据的抬头写上SHO的话，我们就会全额负担。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「今天的派對就交給我們吧。收據的抬頭寫上SHO的話，我們就會全額負擔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00205",
		linknext = "0114_00207",
		line = 2265,
	},
	["0114_00207"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2417", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hold on, Miss Touka! Don’t you remember what accounting’s always crying about? We can’t be burning through the budget like this!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“什么，桐香大小姐！？这样会让管钱的贝卡君哭的啦⋯⋯！？很难报销的钱不会下来呀──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「什麼，桐香大小姐！？這樣會讓管錢的貝卡君哭的啦⋯⋯！？很難報銷的錢不會下來呀──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00206",
		linknext = "0114_00208",
		line = 2277,
	},
	["0114_00208"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2278", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Don’t worry, Rei. It’s fine! It’s only this one time. Today’s a special day, remember?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“没关系啦，礼酱。就这次嘛⋯⋯今天可是特别的日子呢，不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「沒關係啦，禮醬。就這次嘛⋯⋯今天可是特別的日子呢，不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00207",
		linknext = "0114_00209",
		line = 2289,
	},
	["0114_00209"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s right. Today is indeed, special.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对，今天是特别的日子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對，今天是特別的日子。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00208",
		linknext = "0114_00210",
		line = 2299,
	},
	["0114_00210"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We’re going to have a special guest drop by.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为什么这么说──因为有位特别的客人要来我们家做客。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為什麼這麼說──因為有位特別的客人要來我們家做客。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00209",
		linknext = "0114_00211",
		line = 2309,
	},
