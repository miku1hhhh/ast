	},
	["0114_00100"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Have to? Wait, I thought you wanted to?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不做不行⋯⋯？你的意思是不想吧⋯⋯！？”",
