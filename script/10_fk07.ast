			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Um. Isn’t it proper manners to stick our tongues out and roll our eyes up for photos?! That’s what you always told us to do before. Right, Ikuko?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“欸，这种时候应该要摆出阿嘿颜照才是正确的做法吧⋯⋯！？以前不都是这样教我们的吗，郁子酱⋯⋯！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「欸，這種時候應該要擺出阿嘿顏照才是正確的做法吧⋯⋯！？以前不都是這樣教我們的嗎，郁子醬⋯⋯！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00234",
		linknext = "0114_00236",
		line = 2597,
	},
	["0114_00236"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2279", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“That’s only a Seiran Island thing! You’ve been doing it so much lately, you’re looking like a freak. How ’bout you be normal for once?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“那只有在青蓝岛上啦！最近的美岬酱就算一脸正经还是很突出呢，你好好点不行嘛～～”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「那只有在青藍島上啦！最近的美岬醬就算一臉正經還是很突出呢，妳好好點不行嘛～～」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00235",
		linknext = "0114_00237",
		line = 2609,
	},
	["0114_00237"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1970", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Looks like the lawful wife and the mistress will be photographed together. Don’t you relish the immorality of it all, Nanase? We should make copies!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“正宫和小三一起照相不会太违背天理吗，奈奈濑⋯⋯！？到时多洗几张照片好了⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「正宮和小三一起照相不會太違背天理嗎，奈奈瀨⋯⋯！？到時多洗幾張照片好了⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00236",
		linknext = "0114_00238",
		line = 2621,
	},
	["0114_00238"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1069", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Stop with the mistress stuff, seriously. Well, I’m all for getting copies, though. They’ll make for a great keepsake. Can I stand by you, Asa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我才不是小三呢⋯⋯不过加洗照片这事我赞成，可以留作纪念──我在麻沙酱的旁边可以吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我才不是小三呢⋯⋯不過加洗照片這事我贊成，可以留作紀念──我在麻沙醬的旁邊可以嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00237",
		linknext = "0114_00239",
		line = 2633,
	},
	["0114_00239"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1611", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Of course, my dear! Stand beside me? Pfft. I’m going to crop it down to just you, process the image, remove the noise, and create a life-size cut-out for my spank bank. Hehehe.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“当然可以！我能够在奈奈濑姐的旁边的话，到时候就把奈奈濑姐的地方裁切出来，经过加工让画质清晰，最后做成人形立牌拿来当我晚上的点心用，嘿嘿⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「當然可以！我能夠在奈奈瀨姊的旁邊的話，到時候就把奈奈瀨姊的地方裁切出來，經過加工讓畫質清晰，最後做成人形立牌拿來當我晚上的點心用，嘿嘿⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00238",
		linknext = "0114_00240",
		line = 2645,
	},
	["0114_00240"] = {
