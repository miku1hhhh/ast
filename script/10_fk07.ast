				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Y-Yeah! Sometimes I’M the one that apologizes!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是、是呀！也有是我道歉的时候啊！？”",
