	["0114_00156"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Only then can we all forget our social status and have a good time fooling around.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那时就会忘记社经地位，然后聊些垃圾话自嗨。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那時就會忘記社經地位，然後聊些垃圾話自嗨。",
