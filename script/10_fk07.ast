		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The powerhouse student council president found herself the most well-loved star since Governor Hitoura.",
					{"rt2"},
				},
			},
			cn = {
				{
					"自此，当初学园里拥有绝对地位的学生会长，摇身一变成为仁浦氏之后的最受欢迎人物。",
					{"rt2"},
				},
			},
			tw = {
				{
					"自此，當初學園裡擁有絕對地位的學生會長，搖身一變成為仁浦氏之後的最受歡迎人物。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00119",
		linknext = "0114_00121",
		line = 1317,
	},
	["0114_00121"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1962", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Tachibana, can you try for a boy next? We can raise him to be our ideal man!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“前辈，接下来生男的给我好嘛⋯⋯！？我要来进行光源氏计划，将他培育成我们理想的对象⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「前輩，接下來生男的給我好嘛⋯⋯！？我要來進行光源氏計畫，將他培育成我們理想的對象⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00120",
		linknext = "0114_00122",
		line = 1329,
	},
	["0114_00122"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was scary how much she remained exactly the same.",
					{"rt2"},
				},
			},
			cn = {
				{
					"很可怕的是她的外观几乎完全没变。",
					{"rt2"},
				},
			},
			tw = {
				{
					"很可怕的是她的外觀幾乎完全沒變。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00121",
		linknext = "0114_00123",
		line = 1339,
	},
	["0114_00123"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even now, she looks exactly the same as when I first looked up at her standing in front of the podium.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在也像那时在讲台上的容姿一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在也像那時在講台上的容姿一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00122",
		linknext = "0114_00124",
		line = 1349,
	},
	["0114_00124"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She has maintained her figure from then. Just like Hinami, if not more so.",
					{"rt2"},
				},
			},
			cn = {
				{
					"和雏见样──甚至在雏见之上──维持着当时的样貌。",
					{"rt2"},
				},
			},
			tw = {
				{
					"和雛見樣──甚至在雛見之上──維持著當時的樣貌。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00123",
		linknext = "0114_00125",
		line = 1359,
	},
	["0114_00125"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Gotta wonder what shady deal she went through to look that young at this age.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这感觉没什么好下场啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這感覺沒什麼好下場啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00124",
		linknext = "0114_00126",
		line = 1370,
	},
	["0114_00126"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As Touka represents our company’s trading partners, we’re not really in any position to crack jokes like we used to.",
					{"rt2"},
				},
			},
			cn = {
				{
					"毕竟，她身为我们的交易对象的代表，原本就不是能像这样开玩笑的立场才对⋯⋯",
					{"rt2"},
				},
			},
			tw = {
				{
					"畢竟，她身為我們的交易對象的代表，原本就不是能像這樣開玩笑的立場才對⋯⋯",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00125",
		linknext = "0114_00127",
		line = 1380,
	},
	["0114_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, sometimes she’ll drop by our home, making silly small-talk all the while, and then leave as suddenly as she comes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"尽管如此，她偶尔会像变魔术一样突然出现在橘家，然后聊聊天后再回去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"儘管如此，她偶爾會像變魔術一樣突然出現在橘家，然後聊聊天後再回去。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00126",
		linknext = "0114_00128",
		line = 1390,
	},
	["0114_00128"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1069", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Touka, please. Not in front of the child. Don’t go teaching her things she doesn’t need to know. You’re always so... blah, blah... indubitably... and also...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“桐香⋯⋯在孩子的面前说这什么话⋯⋯不要污染小孩子⋯⋯为什么你总是⋯⋯叽叽喳喳，原来原来⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「桐香⋯⋯在孩子的面前說這什麼話⋯⋯不要污染小孩子⋯⋯為什麼妳總是⋯⋯嘰嘰喳喳，原來原來⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00127",
		linknext = "0114_00129",
		line = 1402,
	},
	["0114_00129"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumika0014", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"文佳"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文佳", "Fumika"},
					"“I think you should listen to Mother more too, Auntie Touka. She’s always scolding you and you never learn. And... blah, blah... indubitably... also you...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文佳"},
					"“桐香阿姨⋯⋯我觉得你这样不好⋯⋯常常惹妈妈生气怎么都不会反省呢⋯⋯叽叽喳喳⋯⋯原来原来⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文佳"},
					"「桐香阿姨⋯⋯我覺得妳這樣不好⋯⋯常常惹媽媽生氣怎麼都不會反省呢⋯⋯嘰嘰喳喳⋯⋯原來原來⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00128",
		linknext = "0114_00130",
		line = 1414,
	},
	["0114_00130"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1963", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Okay, okay. I get it. I apologize times infinity! But you also better say sorry for calling me Auntie!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“好⋯⋯好⋯⋯还真不好意思⋯⋯是阿姨真对不起呀⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「好⋯⋯好⋯⋯還真不好意思⋯⋯是阿姨真對不起呀⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00129",
		linknext = "0114_00131",
		line = 1426,
	},
	["0114_00131"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This ring-around-the-rosie of arguments has become part of our everyday life.",
					{"rt2"},
				},
			},
			cn = {
				{
					"像这样被骂也是生活日常。",
					{"rt2"},
				},
			},
			tw = {
				{
					"像這樣被罵也是生活日常。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00130",
		linknext = "0114_00132",
		line = 1436,
	},
	["0114_00132"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If these small squabbles are what lets them all get along, then I’ll gladly turn a blind eye to it. Even if Fumino and Fumika say otherwise.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是这样很好玩的话，我想我还是会继续装没看见吧。虽然这样对我们家的两位来说不太好意思。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是這樣很好玩的話，我想我還是會繼續裝沒看見吧。雖然這樣對我們家的兩位來說不太好意思。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00131",
		linknext = "0114_00133",
		line = 1446,
	},
	["0114_00133"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1065", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Jun’s son...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“淳的儿子⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「淳的兒子⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00132",
		linknext = "0114_00134",
		line = 1458,
	},
	["0114_00134"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“W-What’s up guys?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“大、大家怎么了⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「大、大家怎麼了⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00133",
		linknext = "0114_00135",
		line = 1469,
	},
	["0114_00135"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1325", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I-I also think it’s a fantastic idea for you to have another kid! Yes, indeed!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“哇，我也觉得再有一个孩子非常棒⋯⋯！对！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「哇，我也覺得再有一個孩子非常棒⋯⋯！對！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00134",
		linknext = "0114_00136",
		line = 1481,
	},
	["0114_00136"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1031", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I think it would be so nice if you had a son. It’ll make your home even more lively.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“我也是。是男生的话好像也不错⋯⋯家里会因此变得热闹吧⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「我也是。是男生的話好像也不錯⋯⋯家裡會因此變得熱鬧吧⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00135",
		linknext = "0114_00137",
		line = 1493,
	},
	["0114_00137"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1608", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I’m fine either way. Even if some urgent ‘business’ comes up, I can handle it while babysitting him. Fumika, do you want a little brother?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我都可以⋯⋯就算有紧急的“营业”要处理，我来处理就行⋯⋯文佳想要弟弟吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我都可以⋯⋯就算有緊急的“營業”要處理，我來處理就行⋯⋯文佳想要弟弟嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00136",
		linknext = "0114_00138",
		line = 1505,
	},
	["0114_00138"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumika0015", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"文佳"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文佳", "Fumika"},
					"“A little brother... I’d be a big sister... Yes! I’d like one, please!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文佳"},
					"“弟弟⋯⋯比较大⋯⋯姐姐⋯⋯我想要⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文佳"},
					"「弟弟⋯⋯比較大⋯⋯姊姊⋯⋯我想要⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00137",
		linknext = "0114_00139",
		line = 1517,
	},
	["0114_00139"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ugh. She’s not even thinking of her poor mother. So naive!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“唔，不会想到对母体造成负担的，小孩子真是天真无邪啊──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「唔，不會想到對母體造成負擔的，小孩子真是天真無邪啊──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00138",
		linknext = "0114_00140",
		line = 1528,
	},
	["0114_00140"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1070", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“A little brother... Having another child... Being pregnant... I think it would be splendid!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“弟弟⋯⋯做人⋯⋯怀孕⋯⋯说不定是个好主意⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「弟弟⋯⋯做人⋯⋯懷孕⋯⋯說不定是個好主意⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00139",
		linknext = "0114_00141",
		line = 1540,
	},
	["0114_00141"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don’t get carried away, Fumino! Come back to reality!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别随她们起舞了，文乃，回神──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別隨她們起舞了，文乃，回神──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00140",
		linknext = "0114_00142",
		line = 1551,
	},
	["0114_00142"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2414", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Don’t you want more children, Junnosuke? Especially a boy?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“什么嘛，淳之介，你已经不想要小孩了吗？男孩子唷？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「什麼嘛，淳之介，你已經不想要小孩了嗎？男孩子唷？」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00141",
		linknext = "0114_00143",
		line = 1563,
	},
	["0114_00143"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I mean, yeah. I’ve always dreamt of playing catch with a son. But our finances are—!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，老实说和儿子玩传接球是我长久以来的梦想，但是经济状况不容许⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，老實說和兒子玩傳接球是我長久以來的夢想，但是經濟狀況不容許⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00142",
		linknext = "0114_00144",
		line = 1574,
	},
	["0114_00144"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2276", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“This has been bugging me... Fumika, why do you speak so formally to your parents? Even though you’re so blunt with us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“话说回来，文佳为什么和淳之介还有亲戚说话时很有礼貌呢？明明和郁郁说话的时候都没大没小的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「話說回來，文佳為什麼和淳之介還有親戚說話時很有禮貌呢？明明和郁郁說話的時候都沒大沒小的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00143",
		linknext = "0114_00145",
		line = 1586,
	},
	["0114_00145"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumika0016", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"文佳"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文佳", "Fumika"},
					"“Because Mother always speaks like this when she’s in bed with Father. She always looks so happy when she’s tied up with a rope, saying ‘I’m sorry’ and ‘Forgive me’.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文佳"},
					"“因为妈妈在床上和爸爸说话都是很有礼貌的⋯⋯被绳子绑住一边说‘真对不起’还有‘请原谅’，而且还一副高兴的表情⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文佳"},
					"「因為媽媽在床上和爸爸說話都是很有禮貌的⋯⋯被繩子綁住一邊說『真對不起』還有『請原諒』，而且還一副高興的表情⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00144",
		linknext = "0114_00146",
		line = 1598,
	},
	["0114_00146"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1071", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“F-Fumika! N-No, she must be mishearing things!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“文、文佳⋯⋯！不，不是的，大家别误会了⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「文、文佳⋯⋯！不，不是的，大家別誤會了⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00145",
		linknext = "0114_00147",
		line = 1610,
	},
	["0114_00147"] = {
		{"text"},
		text = {
