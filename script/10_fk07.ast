		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Our adventures haven’t wrapped up just yet.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们的冒险依然持续着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們的冒險依然持續著。",
