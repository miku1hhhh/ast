		line = 299,
	},
	["0114_00026"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She also acts as our driver during outings for our “secret business”. Operating any kind of vehicle to safely get us to our destination and back.",
					{"rt2"},
				},
			},
			cn = {
				{
					"“秘密业务”的时候，不管什么交通工具都能驾驭，将我们送到目的地再带着我们回来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"“秘密業務”的時候，不管什麼交通工具都能駕馭，將我們送到目的地再帶著我們回來。",
					{"rt2"},
				},
			},
		},
