					name = {"文佳", "Fumika"},
					"“This album seems to be only of Mother. Don’t you think you took too many pictures, Father?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文佳"},
					"“不过相簿里几乎都只有妈妈的照片⋯⋯爸爸是不是拍太多了⋯⋯？”",
