	["0114_00166"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0171", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Damn it. If this is what I deserve, then I might as well accept it. Agh! No, it’s too painful!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“呃⋯⋯！如果这是我的业障，那我只好接受了⋯⋯真心酸哪⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「呃⋯⋯！如果這是我的業障，那我只好接受了⋯⋯真心酸哪⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00165",
		linknext = "0114_00167",
