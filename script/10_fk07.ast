	["0114_00223"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My master says curtly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"师父生硬的说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"師父生硬的說道。",
					{"rt2"},
				},
