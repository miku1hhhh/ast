	},
	["0114_00025"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even though sometimes she can be a little too innovative and end up driving our company to the brink of bankruptcy, she’s truly a well of inspiration.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然有时还因为她的点子太过新潮而让公司接近破产边缘，但是依然瑕不掩瑜，是个优秀的人才。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然有時還因為她的點子太過新潮而讓公司接近破產邊緣，但是依然瑕不掩瑜，是個優秀的人才。",
					{"rt2"},
				},
			},
		},
