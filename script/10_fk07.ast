	},
	["0114_00056"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1064", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Of course. Other than his wardrobe, I mean. Hehe.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“当然⋯⋯除了衣服以外都很完美⋯⋯嘻嘻⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「當然⋯⋯除了衣服以外都很完美⋯⋯嘻嘻⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00055",
		linknext = "0114_00057",
		line = 620,
	},
	["0114_00057"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My wife, Fumino Tachibana.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我的妻子，橘文乃──",
					{"rt2"},
				},
			},
			tw = {
				{
					"我的妻子，橘文乃──",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00056",
		linknext = "0114_00058",
		line = 630,
	},
	["0114_00058"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She’s in charge of all of the accounting. No matter how much into the red we get, with her wifely intuition she always finds a way out. She’s the backbone of the company.",
					{"rt2"},
				},
			},
			cn = {
				{
					"处理所有行政方面的事务，不管公司营运陷入多苦的状况依然发挥她贤内助的力量扶持着，是我们公司的支柱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"處理所有行政方面的事務，不管公司營運陷入多苦的狀況依然發揮她賢內助的力量扶持著，是我們公司的支柱。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00057",
		linknext = "0114_00059",
		line = 640,
	},
	["0114_00059"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just like with her “secret business,” she was always watching out for us like a hawk.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算是在进行“秘密业务”的时候，她也以鹰眼的身份从后方掩护着我们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算是在進行“秘密業務”的時候，她也以鷹眼的身分從後方掩護著我們。",
					{"rt2"},
				},
			},
		},
		linkback = "0114_00058",
		linknext = "0114_00060",
		line = 650,
	},
	["0114_00060"] = {
		{"text"},
		text = {
