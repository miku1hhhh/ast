			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You say ‘doing nothing but studying’, but they had Rei and Misaki helping them too!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么贴身教导，礼前辈和美岬不也在吗……！”",
