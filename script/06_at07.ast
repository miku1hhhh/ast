	["0089_00010"] = {
		{"fg", file="asane_02m_00003", file1="asane_02m_00101", file2="asane_02m_00203", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1079", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Nanase and Wata spent several months doing nothing but studying and only barely passed their finals. I’m worried if you’ll be able to handle it...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“虽然说让奈奈濑同学和渡渡贴身教导了好几个月，然后在期末考试才勉勉强强越过及格线的人，之后到底跟不跟得上实在是教人担心就是了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「雖然說讓奈奈瀨同學和渡渡貼身教導了好幾個月，然後在期末考試才勉勉強強越過及格線的人，之後到底跟不跟得上實在是教人擔心就是了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00009",
		linknext = "0089_00011",
		line = 139,
	},
	["0089_00011"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00208", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
