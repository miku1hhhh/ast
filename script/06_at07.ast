		{"text"},
		text = {
			vo = {
				{"vo", file="asane1077", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I’m so tired... Leave me be. I don’t have to go to school... Plus, I have important duties to take care of to protect the peace on my game’s server...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“好懒～有什么关系嘛学校什么的不去也无所嘛～我还有守护伺服器和平的谦虚骑士这个工作耶……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「好懶～有什麼關係嘛學校什麼的不去也無所嘛～我還有守護伺服器和平的謙虛騎士這個工作耶……」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00001",
		linknext = "0089_00003",
		line = 45,
	},
	["0089_00003"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00211", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You want to do nothing but play your little MMORPG. Today you become a junior of Class A. You gotta get dressed and look your best!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我不是说过不可以沉迷于MMRPG了吗？今天开始你就是A等部的二年级生了，不正经一点怎么行。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我不是說過不可以沉迷於MMRPG了嗎？今天開始妳就是A等部的二年級生了，不正經一點怎麼行。」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00002",
