	["0089_00026"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But all the work I put into studying was worth it, since I made it into the Advanced Prep Class. You could say I had some unexpected good luck as well.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可是多少用的功没有白费，她还是进了升学班，算是不幸中的大幸吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可是多少用的功沒有白費，她還是進了升學班，算是不幸中的大幸吧。",
					{"rt2"},
				},
			},
		},
