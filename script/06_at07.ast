				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Of course I’d make it. I have people I need to take care of... I have to work for a big business eventually!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“有什么办法？我还有得要供养的家人啊……得要进大企业工作才行……！”",
