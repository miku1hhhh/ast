					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I can’t believe you made it into the Advanced College Prep Class, Bro... I never thought you had the brains...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“没想到老哥居然会进升学班啊……我还觉得你的学力绝对不够呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「沒想到老哥居然會進升學班啊……我還覺得你的學力絕對不夠呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0089_00005",
		linknext = "0089_00007",
		line = 92,
	},
	["0089_00007"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file3="jun_01f_00305", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
