	["0089_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Minotsuki Academy is split into the Advanced College Prep Course, College Prep Course, and Secret Shagniques Course. Which course you’re in determines your classes and your future.",
					{"rt2"},
				},
			},
			cn = {
				{
					"水乃月学园的课程分为特进、升学和性的秘技三种路线，依据志愿，学生会被分进不同的班级。",
					{"rt2"},
				},
			},
			tw = {
				{
					"水乃月學園的課程分為特進、升學和性的秘技三種路線，依據志願，學生會被分進不同的班級。",
					{"rt2"},
				},
			},
		},
