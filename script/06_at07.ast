	["0089_00012"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hinami was the top of her class, and is so smart they say she’d be able to pass anywhere. She managed to get into a prestigious school in the city.",
					{"rt2"},
				},
			},
			cn = {
				{
					"雏见的成绩是学年第一的等级，大家都说不管是什么学校大概都考得上，并且已经决定要考东京都都心的某所名校了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雛見的成績是學年第一的等級，大家都說不管是什麼學校大概都考得上，並且已經決定要考東京都都心的某所名校了。",
					{"rt2"},
				},
