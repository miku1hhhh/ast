	},
	["0086_00282"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00101", file2="asane_02m_00205", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0766", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“So, that was my first love... And I’ve always kept it, in my heart...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“所以说，那是我的初恋……在那之后，一直都、记在心里……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「所以說，那是我的初戀……在那之後，一直都、記在心裡……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00281",
		linknext = "0086_00283",
		line = 4529,
	},
	["0086_00283"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", file2="nanase_01m_00210", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="奈々瀬4", id=4, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0485", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“...Oh, I see. I guess I’ve done something pretty unkind now, if that’s the case.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……这样啊，原来是这么回事。看来我还真是做出了相当残酷的事情呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……這樣啊，原來是這麼回事。看來我還真是做出了相當殘酷的事情呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00282",
		linknext = "0086_00284",
		line = 4545,
	},
	["0086_00284"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00104", file2="asane_02m_00219", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0767", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“N-No, not at all! Really, I’d say you made me happy...! And I even thought I’d rather not tell Bro your secret because of that...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不、不，没有那种事！要说哪边的话我觉得还挺幸运的……！不如说，正因如此，我还想过继续保密下去更有好处……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不、不，沒有那種事！要說哪邊的話我覺得還挺幸運的……！不如說，正因如此，我還想過繼續保密下去更有好處……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00283",
		linknext = "0086_00285",
		line = 4560,
	},
	["0086_00285"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00101", file2="nanase_02m_00220", path=":fg/nanase_02m/", id=4, lv=4, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0486", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“In that case I’d better be sure to be clear now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这样一来，就更得说清楚了，不然没办法开始下一段感情喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這樣一來，就更得說清楚了，不然沒辦法開始下一段感情喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00284",
		linknext = "0086_00286",
		line = 4575,
	},
	["0086_00286"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", file2="nanase_01m_00210", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0487", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“...I’m sorry Asa, the one I love is Jun. Even if someday he becomes someone else’s lover. I’ll probably always feel the same.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……对不起喔麻沙酱，我喜欢的是淳。就算那家伙成为了别人的恋人。恐怕今后也会一直喜欢下去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……對不起喔麻沙醬，我喜歡的是淳。就算那傢伙成為了別人的戀人。恐怕今後也會一直喜歡下去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00285",
		linknext = "0086_00287",
		line = 4590,
	},
	["0086_00287"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", file2="nanase_01m_00220", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0488", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“So I don’t think I can date anyone.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“所以我，无法跟任何人交往。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「所以我，無法跟任何人交往。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00286",
		linknext = "0086_00288",
		line = 4605,
	},
	["0086_00288"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00101", file2="asane_01m_00208", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0768", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yeah... I knew that’s how you felt... That you really love Bro, and you won’t tell him...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“是……就是啊，我知道……奈奈濑同学最喜欢老哥了，而且大概不会说出口……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「是……就是啊，我知道……奈奈瀨同學最喜歡老哥了，而且大概不會說出口……」",
					{"rt2"},
				},
			},
		},
