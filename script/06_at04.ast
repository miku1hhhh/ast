		{"cgact", file="cgact", id=19, act="移動", x=500, y=-200, time=30000, lv=19},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0804", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“...Y’know, Bro, when you were in that other world... and the other you came here, I knew he was a different person right away...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……我啊，在老哥去了别的世界的时候……在对面的老哥跑到这边来的时候，马上就发现是不同人了喔……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……我啊，在老哥去了別的世界的時候……在對面的老哥跑到這邊來的時候，馬上就發現是不同人了喔……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00415",
		linknext = "0086_00417",
		line = 6398,
	},
