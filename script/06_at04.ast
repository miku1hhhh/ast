			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If your plan turns out shoddy, know that I’m gonna beat the crap out of you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“要是企划太烂，我可是会狠狠把你打飞的喔！！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「要是企劃太爛，我可是會狠狠把妳打飛的喔！！！」",
