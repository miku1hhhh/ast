	},
	["0086_00008"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What are you talking about? A brother who doesn’t watch over his little sister’s date is what you call an exit-only asshole!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“胡说什么。不守护妹妹的约会的哥哥，用你的话来说就跟只出不进的肛门是一样的喔──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「胡說什麼。不守護妹妹的約會的哥哥，用妳的話來說就跟只出不進的肛門是一樣的喔──」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00007",
		linknext = "0086_00009",
		line = 100,
	},
