				},
			},
			tw = {
				{
					name = {"凛"},
					"「好啦妳就幫一切可能的忙好讓妹妹逃跑吧！我可不會因為這種小事就放棄復仇的！馬上就會去報復那個婊子了──！」",
					{"rt2"},
				},
			},
		},
