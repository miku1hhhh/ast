			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“...That’s what happened, so tragically I had to give up on the idea.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“……变成了这种感觉，所以不幸这次只能放弃了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「……變成了這種感覺，所以不幸這次只能放棄了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00076",
