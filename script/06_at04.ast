		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asa jumps into my bed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙酱扑进了我的被窝里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"麻沙醬撲進了我的被窩裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00362",
		linknext = "0086_00364",
		line = 5760,
	},
	["0086_00364"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If I don’t let my lonely little sister into bed tonight, when would I!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“今天这种日子，不陪陪我寂寞的妹妹睡觉怎么行嘛……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「今天這種日子，不陪陪我寂寞的妹妹睡覺怎麼行嘛……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00363",
		linknext = "0086_00365",
		line = 5772,
	},
	["0086_00365"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg020102", x=0, y=0, path=":cg/kcg02/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0793", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“That’s what you say... But, Bro, you’re still upset. I can tell y’know, no use hiding it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“还说那种话……老哥也还很低落不是吗──？麻沙酱可是看得出来的喔你可瞒不了我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「還說那種話……老哥也還很低落不是嗎──？麻沙醬可是看得出來的喔你可瞞不了我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00364",
		linknext = "0086_00366",
		line = 5788,
	},
	["0086_00366"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00102", file2="jun_01f_00205", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“My precious little sister got rejected today, it’s natural.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……那当然了，我疼爱的妹妹可是失恋了耶。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……那當然了，我疼愛的妹妹可是失戀了耶。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00365",
		linknext = "0086_00367",
		line = 5800,
	},
	["0086_00367"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don’t blame Nanase. Honestly she was exceptional.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这不是奈奈濑的错，不如说她可以说是棒透了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這不是奈奈瀨的錯，不如說她可以說是棒透了。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00366",
		linknext = "0086_00368",
		line = 5810,
	},
	["0086_00368"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s not Asa’s fault either. All she did was go on a date with the person she liked.",
					{"rt2"},
				},
			},
			cn = {
				{
					"妹妹也没有错。她只是和自己喜欢的人约了会而已。",
					{"rt2"},
				},
			},
			tw = {
				{
					"妹妹也沒有錯。她只是和自己喜歡的人約了會而已。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00367",
		linknext = "0086_00369",
		line = 5820,
	},
	["0086_00369"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No one is at fault, and that’s why it’s sad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正因为没有任何人不对，所以才悲伤。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正因為沒有任何人不對，所以才悲傷。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00368",
		linknext = "0086_00370",
		line = 5830,
	},
	["0086_00370"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...Okay, maybe Touka’s a little bit at fault?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……姆，硬要说的话只有桐香稍微有点错吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……姆，硬要說的話只有桐香稍微有點錯吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00369",
		linknext = "0086_00371",
		line = 5842,
	},
	["0086_00371"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0794", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I don’t think so, she actually was thinking about me more than you’d expect...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不能这么说吧，那个人说不定意外地是为了我才这么做的喔……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不能這麼說吧，那個人說不定意外地是為了我才這麼做的喔……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00370",
		linknext = "0086_00372",
		line = 5854,
	},
	["0086_00372"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hm, it’s true that Touka has a talent for quickly cutting to the root of a problem...",
					{"rt2"},
				},
			},
			cn = {
				{
					"唔──嗯，确实桐香常常有一瞬间看穿了事物的本质的时候……。",
					{"rt2"},
				},
			},
			tw = {
				{
					"唔──嗯，確實桐香常常有一瞬間看穿了事物的本質的時候……。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00371",
