			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“It’s fine, I knew what’d happen... I guess hearing it from you properly is kind of a relief...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不要紧的，我早就知道了……该说是、说清楚了之后感觉果然清爽了不少吗……！”",
