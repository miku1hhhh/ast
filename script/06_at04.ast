			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“So I’m sure this will be my first and last ever date... And I want to enjoy it to the very end!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“所以，因为这次肯定会变成我这辈子最后一次约会……我想要尽全力去享受，直到最后……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「所以，因為這次肯定會變成我這輩子最後一次約會……我想要盡全力去享受，直到最後……！」",
					{"rt2"},
				},
			},
		},
