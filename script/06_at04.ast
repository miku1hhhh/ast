	},
	["0086_00373"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe she considered a host of possible futures and then decided things should go this way.",
					{"rt2"},
				},
			},
			cn = {
				{
					[[说不定是想像了各种可能性与未来之后，决定"这么做比较好"的吧。]],
					{"rt2"},
				},
			},
			tw = {
				{
					[[說不定是想像了各種可能性與未來之後，決定"這麼做比較好"的吧。]],
					{"rt2"},
				},
			},
		},
