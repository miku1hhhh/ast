				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“What? If you’re talking to me right now, I’ll make it into a comic and put it online with a sob story to let everyone... agh!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“什么事啦跟现在的我搭话小心我把你画成‘我遇到了这么难受的事情……希望分享给大家知道’的那种自白漫画晒到网络上去自我安慰──咿噫！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「什麼事啦跟現在的我搭話小心我把妳畫成『我遇到了這麼難受的事情……希望分享給大家知道』的那種自白漫畫曬到網路上去自我安慰──咿噫！」",
					{"rt2"},
				},
			},
		},
