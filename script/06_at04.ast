				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pushing down my sunglasses, I mutter to myself under the hustle and bustle.",
					{"rt2"},
				},
			},
			cn = {
				{
					"取下墨镜，我在喧嚣中自言自语。",
