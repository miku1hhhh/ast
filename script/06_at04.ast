		line = 4620,
	},
	["0086_00289"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", file2="nanase_01m_00222", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
