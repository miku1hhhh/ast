	},
	["0086_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This morning I woke up before 5am, bathed, ate a light breakfast, found Zen, purified my spiritual roots, and jerked off 7 times.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了这个时候，我今天早上五点就起了床、洗了冷水澡、吃了一些粗食、打禅，让自己六根清净之后，打了七次左右手枪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了這個時候，我今天早上五點就起了床、洗了冷水澡、吃了一些粗食、打禪，讓自己六根清淨之後，打了七次左右手槍。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00003",
		linknext = "0086_00005",
		line = 53,
	},
	["0086_00005"] = {
