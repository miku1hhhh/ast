		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0387", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I think it’s actually kind of dirty to follow your little sister on her date...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“在像这样跟踪约会的妹妹的时间点上，我觉得就已经相当脏了耶……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「在像這樣跟蹤約會的妹妹的時間點上，我覺得就已經相當髒了耶……」",
					{"rt2"},
				},
			},
		},
