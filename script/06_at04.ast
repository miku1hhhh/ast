	["0086_00406"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It feels like my uncertainties clear away and all my negative feelings are extinguished.",
					{"rt2"},
				},
			},
			cn = {
				{
					"感觉心里的阴霾逐渐散去，撩乱的负面情绪也像是被浇熄了一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"感覺心裡的陰霾逐漸散去，撩亂的負面情緒也像是被澆熄了一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00405",
		linknext = "0086_00407",
		line = 6274,
	},
	["0086_00407"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0802", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I don’t like seeing you sad because of me, Bro... If my boobs can cheer you up, I’ll share them gladly...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“因为老哥为了我的事情而消沉，我也会很难过嘛……如果捏捏能帮你打起精神，那当然是最好的了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「因為老哥為了我的事情而消沉，我也會很難過嘛……如果捏捏能幫你打起精神，那當然是最好的了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00406",
		linknext = "0086_00408",
		line = 6286,
	},
	["0086_00408"] = {
