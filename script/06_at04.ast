			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Oh yes, I recorded it reflexively... How cute... But I suppose this just shows how serious Junnosuke is about today...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是啊，让我忍不住都拍起电影了……实在太可爱了……不过这也代表今天的淳之介的气魄就是那么非比寻常吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是啊，讓我忍不住都拍起電影了……實在太可愛了……不過這也代表今天的淳之介的氣魄就是那麼非比尋常吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00038",
		linknext = "0086_00040",
		line = 586,
	},
	["0086_00040"] = {
