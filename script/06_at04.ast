					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Plus I think she’d get it, even if I said it was for a three-way with my sister... It’d be disrespectful to Nanase.”",
