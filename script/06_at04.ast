				},
			},
			tw = {
				{
					name = {"スス子", "絲絲店長"},
					"「歡迎光臨！小店名叫絲絲屋，使用的都是青藍島新鮮現撈的魚料喔～！站在料理場的經歷足足有12分鐘的頑固老爹什麼都能捏出來喔～！」",
					{"rt2"},
				},
			},
		},
