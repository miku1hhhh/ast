			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh? Really? Maybe I should wear some glasses just for the look next time. But glasses don’t look so good if you’re fat and the frames poke your face...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“咦～？真的吗～？那我以后就带个平光眼镜好了～。可是胖子戴眼镜的时候镜框会碰到脸上的肉超级难看的对吧～”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「咦～？真的嗎～？那我以後就帶個平光眼鏡好了～。可是胖子戴眼鏡的時候鏡框會碰到臉上的肉超級難看的對吧～」",
					{"rt2"},
				},
			},
		},
