	["0086_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Today is the day of Asa and Nanase’s date.",
					{"rt2"},
				},
			},
			cn = {
				{
					"今天是麻沙酱和奈奈赖约会的日子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"今天是麻沙醬和奈奈賴約會的日子。",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00002",
