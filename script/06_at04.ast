			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Oh, Bro... What are you doing here...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊，是老哥……你怎么啦，跑到这种地方来……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊，是老哥……你怎麼啦，跑到這種地方來……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00162",
		linknext = "0086_00164",
		line = 2618,
	},
	["0086_00164"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00102", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=6},
		{"text"},
		text = {
			ja = {
				{
