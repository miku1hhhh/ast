		text = {
			vo = {
				{"vo", file="tohka1741", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Er, ahem. Nanase has been told that today’s date be unreservedly ‘cliche.’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					[[“呃呃，咳咳。我先前已经通知过奈奈濑同学，今天的约会企划简单来说就是"说好的那些"。”]],
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					[[「呃呃，咳咳。我先前已經通知過奈奈瀨同學，今天的約會企劃簡單來說就是"說好的那些"。」]],
					{"rt2"},
				},
			},
		},
		linkback = "0086_00040",
		linknext = "0086_00042",
		line = 625,
	},
	["0086_00042"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00218", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=8},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Cliche... So, the aquarium, the amusement park, things like that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说好的……像是水族馆、游乐园之类的，是这个意思吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說好的……像是水族館、遊樂園之類的，是這個意思嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00041",
		linknext = "0086_00043",
		line = 637,
	},
	["0086_00043"] = {
