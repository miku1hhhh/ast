	["0086_00378"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file3="jun_01f_00301", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I can’t do that... I could never confess to the person my sister likes just because we could maybe get together.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那种事情，我做不到……对着妹妹喜欢的奈奈濑，只不过是抱着‘说不定能够在一起’这种程度的想法，就跑去告白，绝对不可以。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那種事情，我做不到……對著妹妹喜歡的奈奈瀨，只不過是抱著『說不定能夠在一起』這種程度的想法，就跑去告白，絕對不可以。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00377",
		linknext = "0086_00379",
		line = 5934,
	},
	["0086_00379"] = {
		{"text"},
		text = {
			ja = {
