				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So what’s this plan like, what’s the concept?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“具体而言是什么企划，主题是什么──！？”",
