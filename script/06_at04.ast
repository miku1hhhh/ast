				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“It uses a ball and bat, so it’s basically the same as kinky sex. It’s all about getting in and hitting the ball.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“因为要用球棒和球，所以四舍五入之后大致上就跟变态性交差不多。用球去进攻内角之后就能打进好球带",
					{"gaiji", text="①"},
					"这样啦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「因為要用球棒和球，所以四捨五入之後大致上就跟變態性交差不多。用球去進攻內角之後就能打進好球帶",
					{"gaiji", text="①"},
					"這樣啦。」",
					{"rt2"},
				},
			},
		},
