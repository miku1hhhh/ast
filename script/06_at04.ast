		{"fg", file="asane_01m_00002", file1="asane_01m_00101", file2="asane_01m_00207", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0777", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“The reason you didn’t come is that you knew this would happen and thought I wouldn’t want you to see it, right...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“文乃是因为料想到事情会这么发展，想说我大概不想被人看到失恋的模样，所以才没有来的对吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「文乃是因為料想到事情會這麼發展，想說我大概不想被人看到失戀的模樣，所以才沒有來的對吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00316",
		linknext = "0086_00318",
		line = 5053,
	},
	["0086_00318"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00102", file2="jun_01f_00209", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh? Is that true, Fumino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“咦……是这样吗，文乃？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「咦……是這樣嗎，文乃？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00317",
		linknext = "0086_00319",
		line = 5065,
	},
	["0086_00319"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00102", file2="fumino_01m_00227", path=":fg/fumino_01m/", id=7, lv=10, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0277", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Er, well... Umm... Yes, I thought there was a high chance... And that in that case Asane probably wouldn’t... want me watching...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“那、那个……呃呃……是的，我认为那种可能性很高，所……所以我想，麻沙音同学，大概……不想要、被我看到……所以……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「那、那個……呃呃……是的，我認為那種可能性很高，所……所以我想，麻沙音同學，大概……不想要、被我看到……所以……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00318",
		linknext = "0086_00320",
		line = 5080,
	},
	["0086_00320"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00101", file2="asane_02m_00210", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0778", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Though it’s kind of late for that... You’ve even washed my piss-stained panties... I can’t get embarrassed in front of you at this point...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“虽然事到如今我也不会在意那种事了啦……我都把有点失禁的内裤让你洗了……那种事情有什么好害羞的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「雖然事到如今我也不會在意那種事了啦……我都把有點失禁的內褲讓妳洗了……那種事情有什麼好害羞的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00319",
		linknext = "0086_00321",
		line = 5095,
	},
	["0086_00321"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00209", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And you knew I was watching too?! But you still...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是说，原来我在偷看你也注意到了吗──！？可是，你却……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是說，原來我在偷看妳也注意到了嗎──！？可是，妳卻……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00320",
		linknext = "0086_00322",
		line = 5107,
	},
	["0086_00322"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00101", file2="asane_01m_00201", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0779", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Well you all made a lot of noise... I didn’t mind being watched... Like how I don’t mind family seeing my letters, I guess?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“唉，你们那么吵当然会注意到了……被你们看着也无所谓啦……就像被家人看到自己写的信也不会害羞，那种的？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「唉，你們那麼吵當然會注意到了……被你們看著也無所謂啦……就像被家人看到自己寫的信也不會害羞，那種的？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00321",
		linknext = "0086_00323",
		line = 5122,
	},
	["0086_00323"] = {
