			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“No, I’m talking about situations, not locations. I think Asane would enjoy some more commonplace experiences. Look...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					[[“不，重点不是地点而是情境。也就是说，我想要让麻沙音同学享受一下所谓的"常见套路"。来，请看那边──”]],
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					[[「不，重點不是地點而是情境。也就是說，我想要讓麻沙音同學享受一下所謂的"常見套路"。來，請看那邊──」]],
					{"rt2"},
				},
			},
		},
