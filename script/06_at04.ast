					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, just happened to be passing by! Never thought I’d see you here!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哎呀还真是奇遇啊～！没想到会在这种地方遇到你们～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哎呀還真是奇遇啊～！沒想到會在這種地方遇到妳們～！」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00163",
		linknext = "0086_00165",
		line = 2630,
	},
	["0086_00165"] = {
