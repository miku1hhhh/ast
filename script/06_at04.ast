			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「這確實很常見呢，走在路上都會聽到路人在說『那個人是怎麼回事好帥喔……！』『好像藝人一樣……！』之類的……",
					{"gaiji", text="①"},
					"」",
					{"rt2"},
				},
			},
