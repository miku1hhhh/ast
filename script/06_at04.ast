	["0086_00146"] = {
		{"fg", file="tohka_01m_00002", file1="tohka_01m_00101", file2="tohka_01m_00202", path=":fg/tohka_01m/", id=8, lv=10, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1753", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“No, just the tie in the beginning. I thought she’d be able to do the rest herself. Nanase has plenty of protagonist energy, after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不，指示只有一开始的领带而已。我认为剩下的奈奈濑同学应该会自动做到。毕竟那个人很有主角气质嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不，指示只有一開始的領帶而已。我認為剩下的奈奈瀨同學應該會自動做到。畢竟那個人很有主角氣質嘛。」",
					{"rt2"},
				},
			},
