				{
					name = {"麻沙音", "Asane"},
					"“...What are they all doing over there, anyway?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……从刚才就一直在那里做什么啊，那些人？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……從剛才就一直在那裏做什麼啊，那些人？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00256",
		linknext = "0086_00258",
		line = 4137,
	},
	["0086_00258"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", file2="nanase_01m_00201", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0470", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Maybe they were jealous that we were out having fun alone? They can’t have been trying to hide like that, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“是因为羡慕我们两个人自己出来玩所以就跟过来了吗？那么破绽百出的，怎么可能躲得起来嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「是因為羨慕我們兩個人自己出來玩所以就跟過來了嗎？那麼破綻百出的，怎麼可能躲得起來嘛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00257",
		linknext = "0086_00259",
		line = 4151,
	},
	["0086_00259"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00101", file2="asane_01m_00201", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[3000] = {
				{"fg", file="asane_01m_00002", file1="asane_01m_00102", file2="asane_01m_00214", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, timestamp=59, delay2=3000, mode=3, x=-405, y=-5},
			},
			[2999] = {
				{"transitiontime", time=300, timestamp=59, delay2=3000},
			},
		},
		text = {
			vo = {
				{"vo", file="asane0757", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Oh, they went off... Seriously, what are they doing here...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊，跑掉了……真的，到底是来干嘛的啊……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊，跑掉了……真的，到底是來幹嘛的啊……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00258",
		linknext = "0086_00260",
		line = 4169,
	},
	["0086_00260"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00101", file2="nanase_02m_00201", path=":fg/nanase_02m/", id=4, lv=4, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[4000] = {
				{"fg", file="nanase_02m_00002", file1="nanase_02m_00101", file2="nanase_02m_00210", path=":fg/nanase_02m/", id=4, lv=4, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, timestamp=60, delay2=4000, mode=3, x=395, y=-5},
			},
			[3999] = {
				{"transitiontime", time=300, timestamp=60, delay2=4000},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0471", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“It looks like they’re having fun at least... I know that sort of thing brightens my mood.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“可是看他们那样吵吵闹闹的感觉很开心呢……毕竟那种时候，我感觉总是有点格格不入。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「可是看他們那樣吵吵鬧鬧的感覺很開心呢……畢竟那種時候，我感覺總是有點格格不入。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00259",
		linknext = "0086_00261",
		line = 4187,
	},
	["0086_00261"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00102", file2="asane_02m_00212", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0758", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Y-You’re so mature, Nanase...! That’s why you can be so calm at times like this!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“因、因为奈奈濑同学是成熟的大人嘛……！所以说，是站在冷静的定位上面的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「因、因為奈奈瀨同學是成熟的大人嘛……！所以說，是站在冷靜的定位上面的……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00260",
		linknext = "0086_00262",
		line = 4203,
	},
	["0086_00262"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", file2="nanase_01m_00210", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0472", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, maybe... But it might be nice go wild with Jun like they’re doing, sometime...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯，或许是那样没错啦……我只是想说，我也有点想跟淳像那样上窜下跳的呢──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯，或許是那樣沒錯啦……我只是想說，我也有點想跟淳像那樣上竄下跳的呢──」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00261",
		linknext = "0086_00263",
		line = 4218,
	},
	["0086_00263"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00101", file2="asane_02m_00205", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0759", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“...So, you really... Nanase, my brother is the one you... Um...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……果然，奈奈濑同学……对老哥，这个……那个……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……果然，奈奈瀨同學……對老哥，這個……那個……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00262",
		linknext = "0086_00264",
		line = 4233,
	},
	["0086_00264"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00101", file2="nanase_02m_00210", path=":fg/nanase_02m/", id=4, lv=4, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0473", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yeah... Yeah, I like him... But it’s a secret, okay? For your ears only, Asa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“是啊……嗯，我喜欢他……但是要帮我保密，因为是麻沙酱我才说的喔？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「是啊……嗯，我喜歡他……但是要幫我保密，因為是麻沙醬我才說的喔？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00263",
		linknext = "0086_00265",
		line = 4248,
	},
	["0086_00265"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00101", file2="asane_01m_00214", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0760", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“My Bro’s stupid and impotent so he hasn’t noticed... So if it’s hard for you to say it, I could...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“可是，老哥那个迟钝阳痿男又完全没有注意到……如果很难开口的话，由我来……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「可是，老哥那個遲鈍陽痿男又完全沒有注意到……如果很難開口的話，由我來……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00264",
		linknext = "0086_00266",
		line = 4263,
	},
	["0086_00266"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", file2="nanase_01m_00216", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[3000] = {
				{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", file2="nanase_01m_00207", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, timestamp=61, delay2=3000, mode=3, x=395, y=-5},
			},
			[2999] = {
				{"transitiontime", time=300, timestamp=61, delay2=3000},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0474", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“You don’t have to, it’s fine... Um, it’s true that I like Jun. I’ve liked him for a really long time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“没关系的，你不用做那种事……那个啊，确实我是喜欢淳。从很久以前就一──直喜欢他。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「沒關係的，妳不用做那種事……那個啊，確實我是喜歡淳。從很久以前就一──直喜歡他。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00265",
		linknext = "0086_00267",
		line = 4281,
	},
	["0086_00267"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", file2="nanase_01m_00210", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0475", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“But it’s actually... Well, oddly enough, it isn’t something I feel like he needs to be involved in.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“可是，大概……对我而言，淳有没有跟我在一起并不重要。虽然这也挺不可思议的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「可是，大概……對我而言，淳有沒有跟我在一起並不重要。雖然這也挺不可思議的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00266",
		linknext = "0086_00268",
		line = 4296,
	},
	["0086_00268"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0476", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Jun belongs with someone who’s in love with the person he is now... That’s what would make him most happy, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“淳应该要跟他现在喜欢的人在一起比较好。因为这样，对他来说才是最幸福的不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「淳應該要跟他現在喜歡的人在一起比較好。因為這樣，對他來說才是最幸福的不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00267",
		linknext = "0086_00269",
		line = 4311,
	},
	["0086_00269"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00102", file2="asane_02m_00205", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0761", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“But Nanase, that leaves you with the short end of the stick, forever...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“可是这样奈奈濑同学，不就一直都在吃亏吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「可是這樣奈奈瀨同學，不就一直都在吃虧嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00268",
		linknext = "0086_00270",
		line = 4326,
	},
	["0086_00270"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00101", file2="nanase_02m_00202", path=":fg/nanase_02m/", id=4, lv=4, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0477", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well, I’m used to it. I just said it now because... I wanted to give something back.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“唉，那种的我已经习惯了啦。之所以会忍不住说出来……那个，有点像是小小的报复。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「唉，那種的我已經習慣了啦。之所以會忍不住說出來……那個，有點像是小小的報復。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00269",
		linknext = "0086_00271",
		line = 4341,
	},
	["0086_00271"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00101", file2="nanase_02m_00210", path=":fg/nanase_02m/", id=4, lv=4, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0478", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“...To be honest, those events were pretty traumatic for me. I made the person I like look like that... I still dream about it whenever I run a fever.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……老实说，那个时候的事情给我留下了相当的创伤呢。居然让喜欢的人摆出了那种表情……直到现在，我在发烧的时候都还会梦到那个时候的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……老實說，那個時候的事情給我留下了相當的創傷呢。居然讓喜歡的人擺出了那種表情……直到現在，我在發燒的時候都還會夢到那個時候的事情。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00270",
		linknext = "0086_00272",
		line = 4356,
	},
	["0086_00272"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00101", file2="asane_01m_00228", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0762", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“So you said it... to get that weight off of you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“就是说，是为了消化那份创伤……才说的，是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「就是說，是為了消化那份創傷……才說的，是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00271",
		linknext = "0086_00273",
		line = 4371,
	},
	["0086_00273"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", file2="nanase_01m_00207", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[3000] = {
				{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", file2="nanase_01m_00210", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, timestamp=62, delay2=3000, mode=3, x=395, y=-5},
			},
			[2999] = {
				{"transitiontime", time=300, timestamp=62, delay2=3000},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0479", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Mm, maybe that too... But there’s no getting rid of that memory, and I never want to make Jun look like that again.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯──，唉，也有那种成分吧……但那已经是不可磨灭的记忆，而且我也不想再度让淳摆出那种表情了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯──，唉，也有那種成分吧……但那已經是不可磨滅的記憶，而且我也不想再度讓淳擺出那種表情了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00272",
		linknext = "0086_00274",
		line = 4389,
	},
	["0086_00274"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", file2="nanase_01m_00201", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0480", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I think what I’d like is for both of us to make up our minds and put an end to it...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“所以我希望彼此都能在心里让这件事告一段落，然后就这样结束掉。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「所以我希望彼此都能在心裡讓這件事告一段落，然後就這樣結束掉。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00273",
		linknext = "0086_00275",
		line = 4404,
	},
	["0086_00275"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00101", file2="asane_01m_00227", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0763", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Nanase...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“奈奈濑同学……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「奈奈瀨同學……」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00274",
		linknext = "0086_00276",
		line = 4419,
	},
	["0086_00276"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", file2="nanase_01m_00202", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="奈々瀬4", id=4, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0481", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Hehe, well, I still think sometimes I’d like him to remember me a bit more than other people, on occasion, you know?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“呵呵，唉，不过要是他在跟喜欢的人在一起以后，能够偶尔──只要比其他人更多一点点就好──想起我的事情的话，那就太好了。我还是会这么想的啦？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「呵呵，唉，不過要是他在跟喜歡的人在一起以後，能夠偶爾──只要比其他人更多一點點就好──想起我的事情的話，那就太好了。我還是會這麼想的啦？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00275",
		linknext = "0086_00277",
		line = 4435,
	},
	["0086_00277"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", file2="nanase_01m_00210", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0482", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Even if he doesn’t know it, as long as he keeps me somewhere in his heart... I think that’s enough for me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“就算他没有注意到我的心意，只要有把我记在心中的某一个角落──那就很够了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「就算他沒有注意到我的心意，只要有把我記在心中的某一個角落──那就很夠了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00276",
		linknext = "0086_00278",
		line = 4450,
	},
	["0086_00278"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00101", file2="asane_02m_00221", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0764", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I, I...! I’ve kept that, for, for so long...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我、我……！我、一直记着喔，从很久、以前开始……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我、我……！我、一直記著喔，從很久、以前開始……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00277",
		linknext = "0086_00279",
		line = 4466,
	},
	["0086_00279"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", file2="nanase_01m_00219", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0483", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Asa...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“麻沙酱……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「麻沙醬……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00278",
		linknext = "0086_00280",
		line = 4481,
	},
	["0086_00280"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00101", file2="asane_02m_00224", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0765", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“When I heard about everything from Bro, I remembered... The one girl on this island who spoke to me, with the dyed-brown hair...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“听到老哥提起的时候，我清楚地回想起来了……以前，在这座岛上唯一一个跟我说话的、有点辣妹感的茶色头发的女孩子……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「聽到老哥提起的時候，我清楚地回想起來了……以前，在這座島上唯一一個跟我說話的、有點辣妹感的茶色頭髮的女孩子……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00279",
		linknext = "0086_00281",
		line = 4496,
	},
	["0086_00281"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00101", file2="nanase_02m_00219", path=":fg/nanase_02m/", id=4, lv=4, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
