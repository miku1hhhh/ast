	["0086_00293"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00101", file2="asane_01m_00207", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
