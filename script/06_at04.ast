			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I don’t think I’ll ever date anyone either...! The only ones I love are you and Bro, so...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我想，我以后大概也不会跟任何人交往了……！因为我喜欢的人，只有奈奈濑同学、还有老哥而已……！”",
					{"rt2"},
