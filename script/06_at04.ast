		{"bg", id=1, file="bg22_1l_00000", x=400, y=0, lv=1, path=":bg/", sync=0, time=300, ax=1290, ay=730, bx=-490, by=-280},
		{"bg", id=17, file="bg16_1_00000", x=0, y=0, lv=5, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_024_00000"},
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00207", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=13, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0360", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Men’s yuri or women’s yuri? Recently there’s been a lot of stuff in between as well, but what are you looking for? Realism, lyrical writing?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"‘你说的究竟是女性向百合呢，还是男性向百合呢？最近虽然也有许多观点指出百合应该介于两者之间，可是那些基本上是指偏向写实的、抒情的作品。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"『妳說的究竟是女性向百合呢，還是男性向百合呢？最近雖然也有許多觀點指出百合應該介於兩者之間，可是那些基本上是指偏向寫實的、抒情的作品。』",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00073",
		linknext = "0086_00075",
		line = 1188,
	},
	["0086_00075"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00201", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=13, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0361", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“There’s a divided consciousness here that needs to be addressed in the definition. To go back to roots of the genre there’s S-class yuri as seen in the works of Nobuko Yoshiya.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"‘如果不先做好定义，就会出现认识的偏差。如果说我们认为百合以摇篮期的滥觞吉屋氏所写的“花物语”与“阁楼中的～”等所谓S文化为元祖──’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"『如果不先做好定義，就會出現認識的偏差。如果說我們認為百合以搖籃期的濫觴吉屋氏所寫的「花物語」與「閣樓中的～」等所謂S文化為元祖──』",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00074",
		linknext = "0086_00076",
		line = 1203,
	},
	["0086_00076"] = {
		{"fg", file="schubert_01m_00002", file2="schubert_01m_00211", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=13, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0362", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Extremely narrow definitions would consider only stories about school girls to be yuri, as true GL is about fleeting romance in a period of adolescence where sex and gender are absent...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"‘并且仅把浸透在女学生之间的系统定义为百合，那实在过度片面；而认定仅有成长期特有的不牵涉到性──也就是性爱的淡淡恋情才能算是GL也实在狭隘──’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"『並且僅把浸透在女學生之間的系統定義為百合，那實在過度片面；而認定僅有成長期特有的不牽涉到性──也就是性愛的淡淡戀情才能算是GL也實在狹隘──』",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00075",
		linknext = "0086_00077",
		line = 1218,
	},
	["0086_00077"] = {
