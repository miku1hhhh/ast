			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Ugh, I couldn’t fully uncap the ass for the event character in Butt Bang Baseball again... Mobile games can be so frustrating...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“啧，App版‘自慰实况！腰力全开棒和球’简称实况棒球的活动脚色的直肠上限又扩充失败了……果然社群游戏就是叫人火大……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「嘖，App版『自慰實況！腰力全開棒和球』簡稱實況棒球的活動腳色的直腸上限又擴充失敗了……果然社群遊戲就是叫人火大……！」",
					{"rt2"},
				},
			},
		},
