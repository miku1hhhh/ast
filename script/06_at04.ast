	["0086_00339"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file3="jun_01f_00306", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Until Japan changes its laws and you can find a wife...! I’ll always take care of you...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“直到日本的法律改变、你能够嫁出去的那一天为止……！我绝对会一直照顾你的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「直到日本的法律改變、妳能夠嫁出去的那一天為止……！我絕對會一直照顧妳的……！」",
					{"rt2"},
				},
			},
		},
