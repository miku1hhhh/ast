			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Not at all, I had a great time! We put it all behind us and had a great date, so in the end there was nothing but fun...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那可完全没有，不如说我今天很开心！全都说出去了以后，约会就只剩下开心的部分而已了……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那可完全沒有，不如說我今天很開心！全都說出去了以後，約會就只剩下開心的部分而已了……！」",
					{"rt2"},
				},
			},
		},
