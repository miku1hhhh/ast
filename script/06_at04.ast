		{"fgact", ch="郁子10", id=10, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2036", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Whoa, that’s the first time I’ve heard Tokie’s accent when she wasn’t drunk...! Even though we’re all vowed not to let it slip on pain of death!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“呜哇，这还是我第一次听到没喝醉的桐香酱说出方言……！明明我们是死也不绘书戳方言同盟的，对吧礼酱……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嗚哇，這還是我第一次聽到沒喝醉的桐香醬說出方言……！明明我們是死也不繪書戳方言同盟的，對吧禮醬……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00037",
		linknext = "0086_00039",
		line = 567,
	},
	["0086_00039"] = {
