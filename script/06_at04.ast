		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1739", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes, I had ideas for a number of situations suitable for today’s date, and—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“嗯，由企画了各种活动的我，为今天这场约会想出了合适的主意──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「嗯，由企畫了各種活動的我，為今天這場約會想出了合適的主意──」",
					{"rt2"},
				},
			},
		},
		linkback = "0086_00034",
		linknext = "0086_00036",
		line = 503,
	},
	["0086_00036"] = {
