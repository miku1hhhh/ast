					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“What a fun waitress... Oh, it’s very tasty, there’s a little sugar in their sushi rice mix, which makes it nice and mellow.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“还真是个有意思的店员呢……啊，味道倒不错，醋饭里面有放一点砂糖，口味满柔和的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「還真是個有意思的店員呢……啊，味道倒不錯，醋飯裡面有放一點砂糖，口味滿柔和的。」",
					{"rt2"},
				},
			},
		},
