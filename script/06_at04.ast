	},
	["0086_00325"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00104", file2="fumino_02m_00213", path=":fg/fumino_02m/", id=7, lv=10, head="fumino_02m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=395, y=-5},
