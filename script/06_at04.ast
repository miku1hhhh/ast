			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Don’t make that face, Fumino. The usual cool expression is fine, I don’t mind... Actually, it’s kind of a relief...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不要摆出那种脸啦，文乃。就保持跟平常一样淡定的表情嘛，我不介意的……不如说感觉爽快多了……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不要擺出那種臉啦，文乃。就保持跟平常一樣淡定的表情嘛，我不介意的……不如說感覺爽快多了……！」",
					{"rt2"},
				},
			},
		},
