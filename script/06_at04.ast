	["0086_00324"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00101", file2="asane_02m_00207", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=95, y=-5},
