					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Now, let’s change tack a bit to discuss ‘shoujo manga cliches.’ Naturally, our instructor is...”",
					{"rt2"},
				},
			},
			cn = {
