					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「唉呀，那真是太可惜了。我本來想幫你們泡杯超好喝的紅茶的。下次有機會再享用吧。」",
					{"rt2"},
				},
