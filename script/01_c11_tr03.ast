	["0016_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After classes, I rush to the disciplinary committee room along with Susuko, who I bumped into in the corridor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"放学后，我和在走廊遇到的丝丝子一起，快速赶往风纪委员室。",
					{"rt2"},
				},
			},
			tw = {
				{
					"放學後，我和在走廊遇到的絲絲子一起，快速趕往風紀委員室。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00004",
