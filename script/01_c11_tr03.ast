			cn = {
				{
					"原来如此──是这么回事啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"原來如此──是這麼回事啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00070",
		linknext = "0016_00072",
		line = 943,
	},
	["0016_00072"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In this case, it isn’t the time to get bewildered and fall a step behind.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这可不是因为困惑就退让的时候。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這可不是因為困惑就退讓的時候。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00071",
		linknext = "0016_00073",
		line = 953,
	},
	["0016_00073"] = {
		{"fgact", ch="光姫17", id=17, lv=17, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"fg", mode=-1, id=30},
		{"facehide"},
		{"bg", id=2, file="bg23_1l_00000", x=-100, y=0, lv=2, path=":bg/", sync=0, ax=1290, ay=730, bx=-490, by=-280},
		{"transitiontime", time=300},
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", lv=2, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Do you have any questions regarding the current event? We have the permissions for it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“本次的活动有什么问题吗？我们应该是循正规流程决定的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「本次的活動有什麼問題嗎？我們應該是循正規流程決定的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00072",
		linknext = "0016_00074",
		line = 971,
	},
	["0016_00074"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0012", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "偉そうな集団の代表"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "Snooty Group Representative"},
					"“Yes, we know. However, almost all of your permissions were obtained via ex-post-facto approval. You can’t possibly use such a budget! You must be out of your minds!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "高高在上集团代表"},
					"“是有人来通知，但几乎是以事后申报的方式来申请的对吧。这种做法竟然还动用这么多的预算，真是非常没有常识。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "高高在上集團代表"},
					"「是有人來通知，但幾乎是以事後申報的方式來申請的對吧。這種做法竟然還動用這麼多的預算，真是非常沒有常識。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00073",
		linknext = "0016_00075",
		line = 983,
	},
	["0016_00075"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We aren’t. This project is based on an official process.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“并非没有常识，这是通过正式流程的专案。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「並非沒有常識，這是通過正式流程的專案。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00074",
		linknext = "0016_00076",
		line = 994,
	},
	["0016_00076"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0013", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "偉そうな集団の代表"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "Snooty Group Representative"},
					"“No, you’ve totally lost it! We don’t have time to play around like this when we’re busy with island-wide projects like the perverted sex law and the USP!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "高高在上集团代表"},
					"“就是没有常识吧！明明变态法和USD这类要振兴岛的计划还在进行中，我们没有时间陪你们玩这些啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "高高在上集團代表"},
					"「就是沒有常識吧！明明變態法和USD這類要振興島的計畫還在進行中，我們沒有時間陪你們玩這些啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00075",
		linknext = "0016_00077",
		line = 1006,
	},
	["0016_00077"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Let’s not talk about the timing. We do have the acceptance of Governor Hitoura, who has the final decision.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“先不论时机问题，我们已经获得仁浦县知事的理解了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「先不論時機問題，我們已經獲得仁浦縣知事的理解了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00076",
		linknext = "0016_00078",
		line = 1018,
	},
	["0016_00078"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0014", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "偉そうな集団の代表"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "Snooty Group Representative"},
					"“Even if you talked to him, the information hasn’t reached us, the higher-ups!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "高高在上集团代表"},
					"“就算有告知仁浦县知事，但也没有告知我们上级啊──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "高高在上集團代表"},
					"「就算有告知仁浦縣知事，但也沒有告知我們上級啊──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00077",
		linknext = "0016_00079",
		line = 1030,
	},
	["0016_00079"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don’t think we are responsible for your negligence.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“疏于联系的责任，我认为不在我方。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「疏於聯繫的責任，我認為不在我方。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00078",
		linknext = "0016_00080",
		line = 1042,
	},
	["0016_00080"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0015", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "偉そうな集団の代表"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "Snooty Group Representative"},
					"“What I’m telling you is that you have to inform us as well before proceeding with something on your own!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "高高在上集团代表"},
					"“我是在说你们别擅自擅动组织，要来知会我们！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "高高在上集團代表"},
					"「我是在說你們別擅自擅動組織，要來知會我們！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00079",
		linknext = "0016_00081",
		line = 1054,
	},
	["0016_00081"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just what’s their problem...?",
					{"rt2"},
				},
			},
			cn = {
				{
					"这些家伙是──",
					{"rt2"},
				},
			},
			tw = {
				{
					"這些傢伙是──",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00080",
		linknext = "0016_00082",
		line = 1064,
	},
	["0016_00082"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Right. There were some motherfuckers who gained posts at the central command in the SHO.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没错，是SHO从中央派下来而得到权力的人们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒錯，是SHO從中央派下來而得到權力的人們。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00081",
		linknext = "0016_00083",
		line = 1074,
	},
	["0016_00083"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0016", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "偉そうな集団の代表"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "Snooty Group Representative"},
					"“The governor is too lenient toward you! What will you gain by using such a budget?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "高高在上集团代表"},
					"“县知事大人也太宠你们了！竟然让你们动用这么多预算，到底有什么好处啊！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "高高在上集團代表"},
					"「縣知事大人也太寵你們了！竟然讓你們動用這麼多預算，到底有什麼好處啊！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00082",
		linknext = "0016_00084",
		line = 1086,
	},
	["0016_00084"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Mr. Hitoura is keeping these guys by his side only to control politicians and to bring the national policy of the island to an advantageous position.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这些家伙想要自在操弄政治家，让政策变得对岛更加有利而拥护仁浦氏。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這些傢伙想要自在操弄政治家，讓政策變得對島更加有利而擁護仁浦氏。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00083",
		linknext = "0016_00085",
		line = 1096,
	},
	["0016_00085"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0017", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "偉そうな集団の代表"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "Snooty Group Representative"},
					"“We’re working to maintain this perverted sex law! Without it, you’d be nothing but kids!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "高高在上集团代表"},
					"“我们是为了维护变态条例而工作的！你们要是没有那些条例就只是一般小鬼而已！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "高高在上集團代表"},
					"「我們是為了維護變態條例而工作的！你們要是沒有那些條例就只是一般小鬼而已！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00084",
		linknext = "0016_00086",
		line = 1108,
	},
	["0016_00086"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s who they are.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这些家伙就是这样的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這些傢伙就是這樣的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00085",
		linknext = "0016_00087",
		line = 1118,
	},
	["0016_00087"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"People who only think about budget management, that is, money. They think their power is their right and are not willing budge an inch.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只会想着预算管理之类钱的事情，认为自己理所当然有权利，从不想要造福社会的人们──",
					{"rt2"},
				},
			},
			tw = {
				{
					"只會想著預算管理之類錢的事情，認為自己理所當然有權利，從不想要造福社會的人們──",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00086",
		linknext = "0016_00088",
		line = 1128,
	},
	["0016_00088"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But we have the law. Consequently, we have the right to exercise it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但这里有条例存在，所以我们有权利实行。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但這裡有條例存在，所以我們有權利實行。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00087",
		linknext = "0016_00089",
		line = 1140,
	},
	["0016_00089"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0018", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "偉そうな集団の代表"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "Snooty Group Representative"},
					"“I’m telling you to cooperate in order to keep it! What the hell are you thinking carrying this shit out without an adult’s supervision?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "高高在上集团代表"},
					"“我在说，为了维护这个，你们应该要协助我们！不经过大人确认就擅自决定是想怎样！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "高高在上集團代表"},
					"「我在說，為了維護這個，你們應該要協助我們！不經過大人確認就擅自決定是想怎樣！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00088",
		linknext = "0016_00090",
		line = 1152,
	},
	["0016_00090"] = {
		{"cgdel", id=2, lv=2, time=0, alphadel=1},
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00102", file2="kouki_01m_00213", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="光姫17", id=17, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0049", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“B-But director, the FS also have their right to decide. Interfering with that...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“但、但是理事，他们FS也有一定程度的独自裁决权，要是干涉这个的话──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「但、但是理事，他們FS也有一定程度的獨自裁決權，要是干涉這個的話──」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00089",
		linknext = "0016_00091",
		line = 1169,
	},
