			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Illness... Maybe it is?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“生病……这样说来，搞不好是喔？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「生病……這樣說來，搞不好是喔？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00312",
		linknext = "0016_00314",
		line = 4188,
	},
	["0016_00314"] = {
		{"fg", file="rei_01m_00008", file1="rei_01m_00101", file2="rei_01m_00201", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0412", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Right... Miss Touka can’t live without imposing inner restrictions onto herself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是啊……桐香大人心中好像设下了各种制约，不这样就无法生存的样子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是啊……桐香大人心中好像設下了各種制約，不這樣就無法生存的樣子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00313",
		linknext = "0016_00315",
		line = 4203,
	},
	["0016_00315"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They agree as if it’s nothing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她们若无其事地肯定了我的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她們若無其事地肯定了我的話。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00314",
		linknext = "0016_00316",
		line = 4213,
	},
	["0016_00316"] = {
		{"bgm", file="bgm21", vol=100},
		{"fg", file="jun_01f_00003", file1="jun_01f_00102", file2="jun_01f_00209", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Um... So what kind of an illness... might it be?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呃……那是、怎样的……病？”",
