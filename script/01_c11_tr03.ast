	["0016_00275"] = {
		{"fg", file="tohka_02m_00003", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="桐香8", id=8, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0388", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Hehe! I would be delighted if you could be a member of my family when we’re back in our world.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呵呵，要是我在原本世界也可以跟学长是同一个家族的成员，一定很开心的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「呵呵，要是我在原本世界也可以跟學長是同一個家族的成員，一定很開心的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00274",
		linknext = "0016_00276",
		line = 3678,
	},
	["0016_00276"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00210", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I told you already that I’m not gonna enter the FS. Now, let’s dry your hair.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我说过了吧，我没加入过FS……差不多可以吹头发了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我說過了吧，我沒加入過FS……差不多可以吹頭髮了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00275",
		linknext = "0016_00277",
		line = 3690,
	},
	["0016_00277"] = {
		{"fg", file="tohka_02m_00003", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="桐香8", id=8, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0389", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“But just like in this world, everyone will respect you. You’ll get a lot of student grants and live a stable life!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“但是如果像在这个世界那样被大家尊敬，也得到很多奖学金，就可以安定地生活喔？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「但是如果像在這個世界那樣被大家尊敬，也得到很多獎學金，就可以安定地生活喔？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00276",
		linknext = "0016_00278",
		line = 3706,
	},
	["0016_00278"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, thanks. Now, if we don’t dry your hair, you’ll never go to sleep!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不用了。好了，不吹头发就没办法睡觉啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不用了。好了，不吹頭髮就沒辦法睡覺啊……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00277",
		linknext = "0016_00279",
		line = 3718,
	},
	["0016_00279"] = {
		{"fg", file="tohka_02m_00003", file1="tohka_02m_00101", file2="tohka_02m_00207", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0390", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“But it would be much better for you. You’re not impotent after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“但是这边比较好吧？你也已经不是阳萎了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「但是這邊比較好吧？你也已經不是陽萎了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00278",
		linknext = "0016_00280",
		line = 3733,
	},
	["0016_00280"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00208", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don’t dump more work on me, and stop talking about impotence!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别增加我困扰啊，还有别说什么阳萎……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別增加我困擾啊，還有別說什麼陽萎……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00279",
		linknext = "0016_00281",
		line = 3745,
	},
	["0016_00281"] = {
		{"fg", file="tohka_02m_00003", file1="tohka_02m_00101", file3="tohka_02m_00309", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0391", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Ah, don’t tell me you’re having problems getting hard? It’s all right. There are a few degrees of impotence, so unless it’s serious, it’ll be fine.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“啊，该不会你很在意有点难勃起的事？没关系的，听说阳萎也分成很多程度，只要不是重度就没问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「啊，該不會你很在意有點難勃起的事？沒關係的，聽說陽萎也分成很多程度，只要不是重度就沒問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00280",
		linknext = "0016_00282",
		line = 3760,
	},
	["0016_00282"] = {
