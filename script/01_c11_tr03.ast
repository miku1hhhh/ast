		{"fgact", ch="郁子10", id=10, lv=10, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asperger syndrome, savant syndrome...",
					{"rt2"},
				},
			},
			cn = {
				{
					"亚斯伯格症候群、学者症候群之类的……。",
					{"rt2"},
				},
			},
			tw = {
				{
					"亞斯伯格症候群、學者症候群之類的……。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00326",
