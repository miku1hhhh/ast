		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If we used a simple word to describe a person like her...",
					{"rt2"},
				},
			},
			cn = {
				{
					"这类的词汇如果用更简单的字来表现的话。",
					{"rt2"},
