				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Hehe! I more or less know what was written there. With supporting evidence it isn’t difficult to make a rebuttal argument.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呵呵，我大概猜得到里面写了什么。要是有佐证，建立起反驳的字句也不是多费劲的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「呵呵，我大概猜得到裡面寫了什麼。要是有佐證，建立起反駁的字句也不是多費勁的事。」",
					{"rt2"},
				},
			},
		},
