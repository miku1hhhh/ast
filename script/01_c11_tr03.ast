	},
	["0016_00251"] = {
		{"fg", file="tohka_02m_00003", file1="tohka_02m_00101", file2="tohka_02m_00213", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0381", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“But she can perform her work flawlessly. She looks bitter, but she can do almost everything without training. Thanks to that, my incapability stands out more and she would often get angry at me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“但是无论什么工作都能完成，明明面无表情，但大部分的事情不用训练就能做到。所以我的无能就更加显眼而老是被骂了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「但是無論什麼工作都能完成，明明面無表情，但大部分的事情不用訓練就能做到。所以我的無能就更加顯眼而老是被罵了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00250",
		linknext = "0016_00252",
		line = 3395,
	},
	["0016_00252"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She says it as if she was proud of it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她的语气仿佛在夸耀般，仿佛很骄傲般。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她的語氣彷彿在誇耀般，彷彿很驕傲般。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00251",
		linknext = "0016_00253",
		line = 3405,
	},
	["0016_00253"] = {
		{"fg", file="tohka_02m_00003", file1="tohka_02m_00101", file2="tohka_02m_00228", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0382", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Maybe all my mistakes were just too painful to watch... but I think that protectiveness was simply in her nature. She would always help me from the shadows. She was very kind.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“她大概是看不下去吧……嗯嗯，应该是她的个性就喜欢照顾人啊。她一直都会偷偷帮我，是很温柔的人喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「她大概是看不下去吧……嗯嗯，應該是她的個性就喜歡照顧人啊。她一直都會偷偷幫我，是很溫柔的人喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00252",
		linknext = "0016_00254",
		line = 3420,
	},
	["0016_00254"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Come to think of it, this is the first time I’ve heard about Touka’s past.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说来这样仔细听着桐香过去的事，还是第一次。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說來這樣仔細聽著桐香過去的事，還是第一次。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00253",
		linknext = "0016_00255",
		line = 3430,
	},
	["0016_00255"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00218", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wasn’t your house called Reizeiin of the Ten Virtues...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我确实听过，‘十德的冷泉院’之类的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我確實聽過，『十德的冷泉院』之類的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00254",
		linknext = "0016_00256",
		line = 3442,
	},
	["0016_00256"] = {
		{"fg", file="tohka_02m_00003", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0383", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Oh, you know about it? It appears that my family was called that before its fall. There are very few people who still know the name.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“咦，你竟然知道啊？好像在冷泉院衰败前是被这样叫的，但因为家族已经消失，所以几乎没有人知道这个名字了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「咦，你竟然知道啊？好像在冷泉院衰敗前是被這樣叫的，但因為家族已經消失，所以幾乎沒有人知道這個名字了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00255",
		linknext = "0016_00257",
		line = 3457,
	},
	["0016_00257"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s not like I don’t wanna know more about Touka’s sister and her past.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我也不是对桐香的姐姐、或是对桐香的过去没有兴趣。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我也不是對桐香的姐姐、或是對桐香的過去沒有興趣。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00256",
		linknext = "0016_00258",
		line = 3467,
	},
	["0016_00258"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But there’s something more important...",
					{"rt2"},
				},
			},
			cn = {
				{
					"但比起那个。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但比起那個。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00257",
		linknext = "0016_00259",
		line = 3477,
	},
	["0016_00259"] = {
		{"fg", file="tohka_02m_00003", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="桐香8", id=8, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0384", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Hehe...! I hope Haruka’s doing well.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呵呵……遥香姐姐，不知道过得好不好呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「呵呵……遙香姐姐，不知道過得好不好呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00258",
		linknext = "0016_00260",
		line = 3493,
	},
	["0016_00260"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe it’s because I have a younger sister...",
					{"rt2"},
				},
			},
			cn = {
				{
					"大概因为有妹妹的关系──",
					{"rt2"},
				},
			},
			tw = {
				{
					"大概因為有妹妹的關係──",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00259",
		linknext = "0016_00261",
		line = 3503,
	},
	["0016_00261"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I can’t help putting myself in her sister’s place.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管怎样都会跟自己重叠在一起。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管怎樣都會跟自己重疊在一起。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00260",
		linknext = "0016_00262",
		line = 3513,
	},
	["0016_00262"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file3="jun_01f_00301", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You must miss her when she’s away.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……兄妹分离很寂寞呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……兄妹分離很寂寞呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00261",
		linknext = "0016_00263",
		line = 3525,
	},
	["0016_00263"] = {
		{"fg", file="tohka_02m_00003", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0385", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I only really think about her when I’m reminded of her. She has her own life there, and...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“也只是没有特意回想就会忘记的程度啦。她也有自己的生活，而且──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「也只是沒有特意回想就會忘記的程度啦。她也有自己的生活，而且──」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00262",
		linknext = "0016_00264",
		line = 3540,
	},
	["0016_00264"] = {
		{"fg", file="tohka_02m_00003", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0386", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Now, the FS is my family.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“──现在FS才是我的家人啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「──現在FS才是我的家人啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00263",
		linknext = "0016_00265",
		line = 3555,
	},
	["0016_00265"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She says that so frankly that I momentarily lose my interest in her past.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她这么清楚地表明，也让我失去探究她过去的心情了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她這麼清楚地表明，也讓我失去探究她過去的心情了。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00264",
		linknext = "0016_00266",
		line = 3565,
	},
	["0016_00266"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What I picked up from her words is how she feels about the FS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而更加明确的是桐香对FS的感情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而更加明確的是桐香對FS的感情。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00265",
		linknext = "0016_00267",
		line = 3575,
	},
	["0016_00267"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I never know what she’s thinking, but it looks like she loves all the members.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然搞不清楚她在想什么，但她似乎对大家抱有很深的感情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然搞不清楚她在想什麼，但她似乎對大家抱有很深的感情。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00266",
		linknext = "0016_00268",
		line = 3585,
	},
	["0016_00268"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s why they adore her so much.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以──才这么被仰慕着吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以──才這麼被仰慕著吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00267",
		linknext = "0016_00269",
		line = 3595,
	},
	["0016_00269"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Those feelings must make her really happy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而这份情感一定也让她非常开心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而這份情感一定也讓她非常開心。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00268",
		linknext = "0016_00270",
		line = 3605,
	},
	["0016_00270"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I understand it well since my comrades from the NLNS were like that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我和NLNS的伙伴也是这样，所以我懂。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我和NLNS的夥伴也是這樣，所以我懂。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00269",
		linknext = "0016_00271",
		line = 3615,
	},
	["0016_00271"] = {
		{"fg", file="tohka_02m_00003", file1="tohka_02m_00101", file2="tohka_02m_00228", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0387", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“If I were to go to my sister, she’d have to take care of me and would be unable to do her job.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“而且要是我去姐姐那里，她会因为一直照顾我而没办法好好工作吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「而且要是我去姐姐那裡，她會因為一直照顧我而沒辦法好好工作吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00270",
		linknext = "0016_00272",
		line = 3630,
