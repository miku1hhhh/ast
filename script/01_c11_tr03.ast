		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0126", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Is it even possible to be so incapable? How can you even grow up to be like that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“有这么夸张的人喔？到底是怎么长大的啊……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「有這麼誇張的人喔？到底是怎麼長大的啊……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00016",
		linknext = "0016_00018",
		line = 232,
	},
	["0016_00018"] = {
		{"fg", file="mizuhiki_01m_00001", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00229", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“They can’t perform their usual daily activities, so they need someone to watch over them all the time...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为没办法好好过日常生活，所以不得不派人照顾她……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為沒辦法好好過日常生活，所以不得不派人照顧她……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00017",
		linknext = "0016_00019",
		line = 246,
	},
	["0016_00019"] = {
		{"fgact", ch="スス子11", id=11, act="移動", x=0, y=0, time=800},
		{"fgact", ch="蘭13", id=13, act="移動", x=0, y=0, time=800},
		{"fgact", ch="水引15", id=15, act="移動", x=250, y=0, time=800},
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00207", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", alpha=0, ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=1, a_chr151=1, mode=3, x=-5, y=-5},
		{"fgact", ch="シューベルト12", id=12, lv=12, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="シューベルト12", id=12, act="移動", x=-250, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0105", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Can you provide me with the data on their family environment when they were a child?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“让人很想取得年幼时的家庭环境数据呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「讓人很想取得年幼時的家庭環境數據呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00018",
		linknext = "0016_00020",
		line = 264,
	},
	["0016_00020"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Well, it seems like they’d never suspect I was talking about Touka.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看来她们即使听了这个对话脉络，也还是没想到那是桐香呢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看來她們即使聽了這個對話脈絡，也還是沒想到那是桐香呢。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00019",
		linknext = "0016_00021",
		line = 274,
	},
	["0016_00021"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don’t think they’d even believe me if I told them the truth. After all, the FS deifies the student council president...",
					{"rt2"},
				},
			},
			cn = {
				{
					"大概说了也不会信吧，因为FS把学生会长神格化了……。",
					{"rt2"},
				},
			},
			tw = {
				{
					"大概說了也不會信吧，因為FS把學生會長神格化了……。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00020",
		linknext = "0016_00022",
		line = 284,
	},
	["0016_00022"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It gives me the creeps as Touka’s babysitter.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……作为‘桐香酱照顾员’，实在是有一吐为快的冲动。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……作為『桐香醬照顧員』，實在是有一吐為快的衝動。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00021",
		linknext = "0016_00023",
		line = 294,
	},
	["0016_00023"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00218", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, anyway. I think we all have it rough. Organizing such an event so abruptly... Um, good job.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“反正没有大家那么忙啦。这类活动总是这么突然……呃，真的很突然。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「反正沒有大家那麼忙啦。這類活動總是這麼突然……呃，真的很突然。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00022",
		linknext = "0016_00024",
		line = 306,
	},
	["0016_00024"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00220", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[7500] = {
				{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00215", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, timestamp=2, delay2=7500, mode=3, x=-605, y=-5},
				{"fgact", ch="スス子11", id=11, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine", timestamp=2, delay2=7500},
			},
			[7499] = {
				{"transitiontime", time=300, timestamp=2, delay2=7500},
			},
		},
		text = {
			vo = {
				{"vo", file="susuko0127", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“How many has it been since the beginning of the year? We already held Condom Shootdown King, Athleticum, um... Help me, Bertie!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“今年已经办好几次了呢。除了平常有的‘保险套击坠王’，还有体欲节、还有……数据伯特！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「今年已經辦好幾次了呢。除了平常有的『保險套擊墜王』，還有體慾節、還有……數據伯特！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00023",
		linknext = "0016_00025",
		line = 325,
	},
	["0016_00025"] = {
		{"fg", file="schubert_01m_00002", file2="schubert_01m_00211", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=-255, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0106", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Over 11 events have been held, including Adultery Festa, Lube Splattering Academy, Strip Mahjong, Dick Over Discussion, and Strip Rock Paper Scissors.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“像是‘不伦是文化节’、‘互喷润滑液湿答答学园’、脱衣麻将‘比起胡更想要肉棒’，还有‘先进洞野球拳大会’之类的，共举办了11次以上的活动呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「像是『不倫是文化節』、『互噴潤滑液濕答答學園』、脫衣麻將『比起胡更想要肉棒』，還有『先進洞野球拳大會』之類的，共舉辦了11次以上的活動呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00024",
		linknext = "0016_00026",
		line = 340,
	},
	["0016_00026"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s been more than 10 times just this year...",
					{"rt2"},
				},
			},
			cn = {
				{
					"今年已经办了超过10次活动了啊……。",
					{"rt2"},
				},
			},
			tw = {
				{
					"今年已經辦了超過10次活動了啊……。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00025",
		linknext = "0016_00027",
		line = 350,
	},
	["0016_00027"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Apparently, our Touka carries out a lot of events.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这边的桐香好像也很常办活动的样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這邊的桐香好像也很常辦活動的樣子。",
