					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Touka must be as healthy as a horse...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真亏桐香身体撑得住啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真虧桐香身體撐得住啊……」",
