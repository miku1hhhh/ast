		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hey, what would y’all think about a person who starts sleep talking really fast in the morning, leaves crumbs all over when they eat bread, and can’t drink water properly...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……那个，大家对于早上一边说着像是绕口令般的梦话，面包吃得到处都是，也没办法好好喝水的人有什么想法……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……那個，大家對於早上一邊說著像是繞口令般的夢話，麵包吃得到處都是，也沒辦法好好喝水的人有什麼想法……？」",
					{"rt2"},
				},
			},
		},
