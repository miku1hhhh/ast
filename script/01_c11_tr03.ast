	["0016_00029"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00213", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="スス子11", id=11, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0128", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“No, she ain’t. She passed out the other day, remember?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“完全撑不住吧。之前还差点过劳昏倒不是吗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「完全撐不住吧。之前還差點過勞昏倒不是嗎。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00028",
		linknext = "0016_00030",
		line = 388,
	},
	["0016_00030"] = {
		{"fg", file="mizuhiki_01m_00001", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00207", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=245, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="水引15", id=15, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0022", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Right... She also fainted right in front of the entire student council before I became an inspector. She slapped against the floor. It was such a shocker.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“这么说来……虽然是我当监察官之前发生的事了，但当时真的很冲击耶。集会时在全校学生面前晕倒，发出砰地一声。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「這麼說來……雖然是我當監察官之前發生的事了，但當時真的很衝擊耶。集會時在全校學生面前暈倒，發出砰地一聲。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00029",
		linknext = "0016_00031",
		line = 404,
	},
	["0016_00031"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00101", file2="ran_01m_00205", file4="ran_01m_00401", path=":fg/ran_01m/", id=13, lv=13, head="ran_01m", ch_origin="蘭", ch="蘭13", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0042", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“She also spit blood and blacked out during an FS meeting... We bluffed our way out of it by saying that it was chocolate or strawberry jam, so it ended up without a scandal...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“和FS讨论时还吐血昏倒过……虽然那时候说是巧克力还是草莓酱之类的打混过去了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「和FS討論時還吐血昏倒過……雖然那時候說是巧克力還是草莓醬之類的打混過去了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00030",
		linknext = "0016_00032",
		line = 419,
	},
	["0016_00032"] = {
