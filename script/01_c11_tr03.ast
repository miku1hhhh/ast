					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“But we’ll lose face as subordinates if our president and leader passes out again.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“但要是又让领袖的学生会长倒下，我们这些做部下的也太没面子了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「但要是又讓領袖的學生會長倒下，我們這些做部下的也太沒面子了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00051",
		linknext = "0016_00053",
		line = 702,
	},
	["0016_00053"] = {
