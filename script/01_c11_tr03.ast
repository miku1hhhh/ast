	},
	["0016_00317"] = {
		{"fg", file="ikuko_02m_00003", file1="ikuko_02m_00101", file2="ikuko_02m_00210", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0477", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Touka has a tendency to define things as she likes them to be. She does it frequently.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“桐香酱啊，会无意识地定义‘这个得这样做’、‘那个得那样做’，她很常这样吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「桐香醬啊，會無意識地定義『這個得這樣做』、『那個得那樣做』，她很常這樣吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00316",
		linknext = "0016_00318",
		line = 4241,
	},
	["0016_00318"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I think I know what she’s getting at.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我心中有数。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我心中有數。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00317",
		linknext = "0016_00319",
		line = 4251,
	},
	["0016_00319"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It happened many times during the last few days.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为这几天就发生了好几次这样的事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為這幾天就發生了好幾次這樣的事。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00318",
		linknext = "0016_00320",
		line = 4261,
	},
	["0016_00320"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I know that such people exist in this world.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我也知道这世上有这样的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我也知道這世上有這樣的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00319",
		linknext = "0016_00321",
		line = 4271,
	},
	["0016_00321"] = {
		{"fg", file="rei_01m_00008", file1="rei_01m_00101", file2="rei_01m_00215", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0413", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Like, ‘some food has to be eaten with chopsticks, and some with a fork.’ Or, ‘I don’t understand the mechanics of clothes, and thus I can’t wear them.’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“像是吃东西时不把筷子或叉子分开来使用就‘不行’，因为不知道衣服的构造所以‘不会穿’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「像是吃東西時不把筷子或叉子分開來使用就『不行』，因為不知道衣服的構造所以『不會穿』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00320",
		linknext = "0016_00322",
		line = 4286,
	},
	["0016_00322"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She’s very picky. She can’t live without weirdly restraining herself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有非常强烈的坚持，不给自己很多限制就活不下去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"有非常強烈的堅持，不給自己很多限制就活不下去。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00321",
		linknext = "0016_00323",
		line = 4296,
	},
	["0016_00323"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her ordinary emotions and sensitivity are warped.",
					{"rt2"},
				},
			},
			cn = {
				{
					"跟一般人的情感或观点有些背离。",
					{"rt2"},
				},
			},
			tw = {
				{
					"跟一般人的情感或觀點有些背離。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00322",
		linknext = "0016_00324",
		line = 4306,
	},
	["0016_00324"] = {
		{"fg", file="rei_01m_00008", file1="rei_01m_00101", file2="rei_01m_00201", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0414", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“We could call it being picky if it involved small things. But on this scale, I’d rather say it’s an obsession.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“像这些小事情可能可以解释为坚持，不过大一点的事就几乎是强迫观念了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「像這些小事情可能可以解釋為堅持，不過大一點的事就幾乎是強迫觀念了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00323",
		linknext = "0016_00325",
		line = 4321,
	},
	["0016_00325"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But on the other hand, she developed outstanding talents instead.",
					{"rt2"},
				},
			},
			cn = {
				{
					"相反地，她也拥有比别人更强大而突出的才能。",
					{"rt2"},
				},
			},
			tw = {
				{
					"相反地，她也擁有比別人更強大而突出的才能。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00324",
		linknext = "0016_00326",
		line = 4331,
	},
	["0016_00326"] = {
		{"fg", file="ikuko_02m_00003", file1="ikuko_02m_00101", file2="ikuko_02m_00211", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0478", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“The flagship example... Stairs. She can’t accept an artificial elevation that doesn’t exist in nature. Therefore, she can’t climb them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“最好的例子是……楼梯吧。酱桐香她无法接受自然界没有的人工制造的高低落差。因为不能接受，所以绝对不会踏上去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「最好的例子是……樓梯吧。醬桐香她無法接受自然界沒有的人工製造的高低落差。因為不能接受，所以絕對不會踏上去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00325",
		linknext = "0016_00327",
		line = 4346,
	},
	["0016_00327"] = {
