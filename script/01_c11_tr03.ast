			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Is it normal for you guys to stuff your mouth with strawberry jam during meetings?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“谁会在讨论时突然含着草莓酱啊……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
