	["0016_00111"] = {
		{"bgm", file="bgm09.5", vol=100},
		{"fg", file="tohka_02m_00010", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="桐香8", id=8, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		delay = {
			[3500] = {
				{"fg", file="tohka_02m_00010", file1="tohka_02m_00101", file2="tohka_02m_00213", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, timestamp=4, delay2=3500, mode=3, x=-5, y=-5},
			},
			[3499] = {
				{"transitiontime", time=300, timestamp=4, delay2=3500},
			},
		},
		text = {
			vo = {
				{"vo", file="tohka0351", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You seem to be having an interesting conversation. Welcome, top managers of the SHO. I am Touka Reizeiin, the FS representative and a student council president.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“才觉得好像在聊什么开心的话题呢。原来是SHO上层的大家大驾光临了呀。我是FS代表兼学生会长的冷泉院桐香。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「才覺得好像在聊什麼開心的話題呢。原來是SHO上層的大家大駕光臨了呀。我是FS代表兼學生會長的冷泉院桐香。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00110",
		linknext = "0016_00112",
		line = 1456,
	},
	["0016_00112"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Touka, who should be in the student council room.",
					{"rt2"},
				},
			},
			cn = {
				{
					"──应该在学生会室的桐香。",
					{"rt2"},
				},
			},
			tw = {
				{
					"──應該在學生會室的桐香。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00111",
		linknext = "0016_00113",
		line = 1466,
	},
	["0016_00113"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0352", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I am the representative of the FS. If you have an issue relating to the FS, you should have come to the student council room.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“FS的代表是我，要是有话想说，来学生会室谈就好的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「FS的代表是我，要是有話想說，來學生會室談就好的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00112",
		linknext = "0016_00114",
		line = 1478,
	},
	["0016_00114"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0025", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "偉そうな集団の代表"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "Snooty Group Representative"},
					"“We’re busy here, okay?! We have no time to adjust our plans to your schedule! The FS should be in the committee room!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "高高在上集团代表"},
					"“我、我们也是很忙的！没有时间配合你的行程！FS就应该在风纪委员室才对吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "高高在上集團代表"},
					"「我、我們也是很忙的！沒有時間配合妳的行程！FS就應該在風紀委員室才對吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00113",
		linknext = "0016_00115",
		line = 1490,
	},
	["0016_00115"] = {
		{"fg", file="tohka_02m_00010", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0353", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Well, you’re not wrong. Then, it’s good that I happened to come here for a chat.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“唉呀，说的也是。那还好我刚好来这里玩了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「唉呀，說的也是。那還好我剛好來這裡玩了呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00114",
		linknext = "0016_00116",
		line = 1505,
	},
	["0016_00116"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The men grimace.",
					{"rt2"},
				},
			},
			cn = {
				{
					"男人们的脸变成了苦瓜脸。",
					{"rt2"},
				},
			},
			tw = {
				{
					"男人們的臉變成了苦瓜臉。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00115",
		linknext = "0016_00117",
		line = 1515,
	},
	["0016_00117"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Did they choose a time when Touka was not here on purpose?",
					{"rt2"},
				},
			},
			cn = {
				{
					"这些家伙──难道是故意挑桐香不在的时间来的吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"這些傢伙──難道是故意挑桐香不在的時間來的嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00116",
		linknext = "0016_00118",
		line = 1525,
	},
	["0016_00118"] = {
		{"fg", file="tohka_02m_00010", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0354", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“This event is to promote the perverted sex law as well as the USP plan. I also included in the report that it conforms to the principles of the SHO.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“这个活动是根据变态法，也可以大大宣传USD计划，所以是遵从SHO的理念的活动，这些报告书上都有写喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「這個活動是根據變態法，也可以大大宣傳USD計畫，所以是遵從SHO的理念的活動，這些報告書上都有寫喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00117",
		linknext = "0016_00119",
		line = 1540,
	},
	["0016_00119"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0026", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "偉そうな集団の代表"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "Snooty Group Representative"},
					"“There is a budget for promotion and advertisement! If you use that money as you like, you’ll obstruct our plans as well!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "高高在上集团代表"},
					"“不管是广告还是宣传，都有规定的预算！竟然擅自使用经费，对我们的预定会造成困扰啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "高高在上集團代表"},
					"「不管是廣告還是宣傳，都有規定的預算！竟然擅自使用經費，對我們的預定會造成困擾啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00118",
		linknext = "0016_00120",
		line = 1552,
	},
	["0016_00120"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00215", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="光姫17", id=17, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0050", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Obstruct what? Drinking isn’t the only kind of entertainment, I dare say...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“困扰……不就是想要接待然后喝酒吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「困擾……不就是想要接待然後喝酒嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00119",
		linknext = "0016_00121",
		line = 1567,
	},
	["0016_00121"] = {
		{"fgact", ch="光姫17", id=17, lv=17, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"fg", file="tohka_02m_00010", file1="tohka_02m_00101", file2="tohka_02m_00213", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0355", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“That’s why we first set an upper limit for the funds. Then we take the necessary amount from the general FS budget. Only the sums that exceed the budget are included as additional USP plan costs.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“关于这部分，不仅设定了预算上限，还加上了FS的综合预算，不够的份才会使用到USD计划预备预算才对。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「關於這部分，不僅設定了預算上限，還加上了FS的綜合預算，不夠的份才會使用到USD計畫預備預算才對。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00120",
		linknext = "0016_00122",
		line = 1584,
	},
	["0016_00122"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0027", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "偉そうな集団の代表"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "Snooty Group Representative"},
					"“The FS doesn’t have the capacity to manage their budget to that degree!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "高高在上集团代表"},
					"“FS没有那种管理预算的能力才对！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "高高在上集團代表"},
					"「FS沒有那種管理預算的能力才對！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00121",
		linknext = "0016_00123",
		line = 1596,
	},
	["0016_00123"] = {
		{"fg", file="tohka_02m_00010", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0356", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes, that’s why I only made the proposal. I haven’t done anything else, but I received permission from the accounting administration.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“是啊，所以我只有提案，没有做更多的事。是经理给予我们许可的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「是啊，所以我只有提案，沒有做更多的事。是經理給予我們許可的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00122",
		linknext = "0016_00124",
		line = 1611,
	},
	["0016_00124"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In that case, it’s not Touka to whom they should address their complaints, but the internal SHO.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如此一来，该抱怨的不是桐香，而是SHO内部才对。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如此一來，該抱怨的不是桐香，而是SHO內部才對。",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00123",
		linknext = "0016_00125",
		line = 1621,
	},
	["0016_00125"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0028", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "偉そうな集団の代表"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "Snooty Group Representative"},
					"“So what about these personal affairs?! Are you saying that you had no intention of rebelling against the SHO?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "高高在上集团代表"},
					"“但是，这个人事权又是怎么回事！这不是有造反SHO的意图吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "高高在上集團代表"},
					"「但是，這個人事權又是怎麼回事！這不是有造反SHO的意圖嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00124",
		linknext = "0016_00126",
		line = 1633,
	},
	["0016_00126"] = {
		{"fg", file="tohka_02m_00010", file1="tohka_02m_00101", file2="tohka_02m_00207", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0357", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Well, it is written here that this is one of the suggestions relating to the strategy for making the current top-down decision-making process more flexible.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“关于此点，是因为我们希望目前由上而下的决议过程有更多弹性，所以才作为对策之一提案的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「關於此點，是因為我們希望目前由上而下的決議過程有更多彈性，所以才作為對策之一提案的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00125",
		linknext = "0016_00127",
		line = 1648,
	},
	["0016_00127"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobc0029", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男C", "偉そうな集団の代表"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男C", "Snooty Group Representative"},
					"“Bullshit! You’re just telling us what we wanna hear!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男C", "高高在上集团代表"},
					"“都是小孩子的玩闹话！只是讲得好听点而已吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "高高在上集團代表"},
					"「都是小孩子的玩鬧話！只是講得好聽點而已吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00126",
		linknext = "0016_00128",
		line = 1660,
	},
	["0016_00128"] = {
		{"fg", file="tohka_02m_00010", file1="tohka_02m_00101", file3="tohka_02m_00301", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="桐香8", id=8, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0358", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“But in reality, thanks to the FS’s initial response, many problems have been already solved. For example... eradication of the Yakuza who had taken root on the island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不过实际上，由FS提案而解决的事情也不少喔。例如……把侵蚀岛上的黑道一扫而空之类的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不過實際上，由FS提案而解決的事情也不少喔。例如……把侵蝕島上的黑道一掃而空之類的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0016_00127",
		linknext = "0016_00129",
		line = 1676,
	},
	["0016_00129"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
