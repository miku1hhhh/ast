			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"‘我们正在尝试用雷达捕捉敌人⋯⋯但很奇怪、完全没有反应。也没有平常会出现的电波干扰⋯⋯’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"『我們正在嘗試用雷達捕捉敵人⋯⋯但很奇怪、完全沒有反應。也沒有平常會出現的電波干擾⋯⋯』",
					{"rt2"},
				},
			},
		},
