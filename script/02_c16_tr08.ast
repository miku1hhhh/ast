					{"rt2"},
				},
			},
			en = {
				{
					"The reason for that was that she wanted nothing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这是源自于她是个“什么都不想要的人”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這是源自於她是個「什麼都不想要的人」。",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00195",
		linknext = "0033_00197",
		line = 2894,
	},
	["0033_00197"] = {
		{"fg", file="tohka_02ll_00001", file1="tohka_02ll_00101", file2="tohka_02ll_00202", path=":fg/tohka_02ll/", id=8, lv=8, head="tohka_02ll", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0672", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“At that moment, you appeared. You had faith not allowing you to be satisfied with what you had, passion to make a change, unshakable pride, and conviction to carry out what you want to do.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“你就在这时候出现了。带着一种不安于现状的信念、颠覆性的激情、坚定不移的骄矜，和一种坚守初心的信条。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「你就在這時候出現了。帶著一種不安於現狀的信念、顛覆性的激情、堅定不移的驕矜，和一種堅守初心的信條。」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00196",
		linknext = "0033_00198",
		line = 2909,
	},
	["0033_00198"] = {
		{"fg", file="tohka_01ll_00001", file1="tohka_01ll_00101", file2="tohka_01ll_00210", path=":fg/tohka_01ll/", id=8, lv=8, head="tohka_01ll", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0673", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You didn’t excel in anything else... Still, you never lost to anyone in that respect.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“除此之外，你真的是毫无优点可取⋯⋯但在这一点上，谁都比不过你。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「除此之外，你真的是毫無優點可取⋯⋯但在這一點上，誰都比不過你。」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00197",
		linknext = "0033_00199",
		line = 2924,
	},
	["0033_00199"] = {
		{"fg", file="tohka_01ll_00001", file1="tohka_01ll_00101", file2="tohka_01ll_00213", path=":fg/tohka_01ll/", id=8, lv=8, head="tohka_01ll", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0674", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“No matter how much you struggle or how hard it is to watch, you didn’t accept it, and you chose the path of a warrior.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不管怎么挣扎、不管有多么不堪入目，你从不接受任何东西，总是选择去战斗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不管怎麼掙扎、不管有多麼不堪入目，你從不接受任何東西，總是選擇去戰鬥。」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00198",
		linknext = "0033_00200",
		line = 2939,
	},
	["0033_00200"] = {
		{"fg", file="tohka_02ll_00001", file1="tohka_02ll_00101", file2="tohka_02ll_00228", path=":fg/tohka_02ll/", id=8, lv=8, head="tohka_02ll", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0675", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You had everything that I lacked.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“你拥有我所没有的一切。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「你擁有我所沒有的一切。」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00199",
		linknext = "0033_00201",
		line = 2954,
	},
	["0033_00201"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Touka has been handed from one place to another since she was a child...",
					{"rt2"},
				},
			},
			cn = {
				{
					"从小就辗转于各处的桐香。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從小就輾轉於各處的桐香。",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00200",
		linknext = "0033_00202",
		line = 2964,
	},
	["0033_00202"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"To end up sold to the island and gain what she wanted, what she didn’t want, and then some.",
					{"rt2"},
				},
			},
			cn = {
				{
					"最终被卖到了这座岛来。凭借着与生俱来的天赋得到了“她不希望也不想要”的东西。",
					{"rt2"},
				},
			},
			tw = {
				{
					"最終被賣到了這座島來。憑藉著與生俱來的天賦得到了「她不希望也不想要」的東西。",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00201",
		linknext = "0033_00203",
		line = 2974,
	},
	["0033_00203"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe the lack of desire of this person who wants nothing...",
					{"rt2"},
				},
			},
			cn = {
				{
					"无欲无求，什么都不想要的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無欲無求，什麼都不想要的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00202",
		linknext = "0033_00204",
		line = 2984,
	},
	["0033_00204"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Derived from her unconscious insight.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这可能来于她在无意识之中放弃了一切的缘故。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這可能來於她在無意識之中放棄了一切的緣故。",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00203",
		linknext = "0033_00205",
		line = 2994,
	},
	["0033_00205"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00309", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You want me to like the island, but still you’re favorable toward raising a revolt... Those contradict one another.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“想要我喜欢这座岛却又对造反抱持着好感⋯⋯这很矛盾呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「想要我喜歡這座島卻又對造反抱持著好感⋯⋯這很矛盾呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00204",
		linknext = "0033_00206",
		line = 3006,
	},
	["0033_00206"] = {
		{"fg", file="tohka_01ll_00001", file1="tohka_01ll_00101", file2="tohka_01ll_00228", path=":fg/tohka_01ll/", id=8, lv=8, head="tohka_01ll", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0676", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“True. It doesn’t make sense at all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“是啊，真的。完全说不通呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「是啊，真的。完全說不通呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00205",
		linknext = "0033_00207",
		line = 3021,
	},
	["0033_00207"] = {
		{"fg", file="tohka_01ll_00001", file1="tohka_01ll_00101", file2="tohka_01ll_00202", path=":fg/tohka_01ll/", id=8, lv=8, head="tohka_01ll", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0677", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I just wanted you to keep smiling. I wanted my lovely island to make you forget about everything that happened in the past.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我想让你微笑。我想让你忘记所有过去，住在我最喜欢的这座岛上。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我想讓你微笑。我想讓你忘記所有過去，住在我最喜歡的這座島上。」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00206",
		linknext = "0033_00208",
		line = 3036,
	},
	["0033_00208"] = {
		{"fg", file="tohka_01ll_00001", file1="tohka_01ll_00101", file2="tohka_01ll_00210", path=":fg/tohka_01ll/", id=8, lv=8, head="tohka_01ll", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0678", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Even though... Or rather precisely because of this, I wanted you. It was the first time in my life that I ever wanted something.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“然而……不，这就是我想要你的原因。这是我生命中第一次真正想要一些东西。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"“然而……不，這就是我想要你的原因。這是我生命中第一次真正想要一些東西。”",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00207",
		linknext = "0033_00209",
		line = 3051,
	},
	["0033_00209"] = {
		{"fg", file="tohka_01ll_00001", file1="tohka_01ll_00101", file2="tohka_01ll_00202", path=":fg/tohka_01ll/", id=8, lv=8, head="tohka_01ll", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0679", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“But you were fighting for your pride. I knew I could never have you. That’s why...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“可是，为了自尊而战的你，我是永远得不到的。所以，至少──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「可是，為了自尊而戰的你，我是永遠得不到的。所以，至少──」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00208",
		linknext = "0033_00210",
		line = 3066,
	},
	["0033_00210"] = {
		{"fg", file="tohka_02ll_00001", file1="tohka_02ll_00101", file2="tohka_02ll_00211", path=":fg/tohka_02ll/", id=8, lv=8, head="tohka_02ll", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0680", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I thought that if I can’t have you, then at least I wanted you to have me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“──如果得不到的话，至少，我能拥有‘希望得到’的想法。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「──如果得不到的話，至少，我能擁有『希望得到』的想法。」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00209",
		linknext = "0033_00211",
		line = 3081,
	},
	["0033_00211"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Because I felt like you could give me everything that I don’t have.",
					{"rt2"},
				},
			},
			cn = {
				{
					"‘因为那时，我觉得也许你给了我一些我所没有的东西。’",
					{"rt2"},
				},
			},
			tw = {
				{
					"『因為那時，我覺得也許你給了我一些我所沒有的東西。』",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00210",
		linknext = "0033_00212",
		line = 3091,
	},
	["0033_00212"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s what she says.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她这么说。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她這麼說。",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00211",
		linknext = "0033_00213",
		line = 3101,
	},
	["0033_00213"] = {
		{"fg", file="tohka_02ll_00001", file1="tohka_02ll_00101", file3="tohka_02ll_00313", path=":fg/tohka_02ll/", id=8, lv=8, head="tohka_02ll", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0681", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“However, you were unable to laugh when you were with me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“但是你，和我在一起的时候，总是不会笑。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「但是你，和我在一起的時候，總是不會笑。」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00212",
		linknext = "0033_00214",
		line = 3116,
	},
	["0033_00214"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Touka flashes her usual faint smile.",
					{"rt2"},
				},
			},
			cn = {
				{
					"桐香的脸上总是挂着微笑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"桐香的臉上總是掛著微笑。",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00213",
		linknext = "0033_00215",
		line = 3126,
	},
	["0033_00215"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, her facial expression does not necessarily express her true emotions.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然而，它并不总是吻合她真正的感受。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然而，它並不總是吻合她真正的感受。",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00214",
		linknext = "0033_00216",
