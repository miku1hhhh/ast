		{"fgact", ch="桐香8", id=8, act="浮遊", loop=-1, size=2.5, time=100, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0640", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“The management of Seiran Island told me that they can’t cover the bear hunting budget because they’re covering costs of the pubic pistol maintenance.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“因为青蓝岛的高层管理人员说了‘我们没有聘请猎熊人跟猎熊人下半身野兽的预算’，所以没有请。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「因為青藍島的高層管理人員說了『我們沒有聘請獵熊人跟獵熊人下半身野獸的預算』，所以沒有請。」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00086",
		linknext = "0033_00088",
		line = 1312,
	},
	["0033_00088"] = {
