			tw = {
				{
					name = {"桐香"},
					"「如果是沒有激動的性的對手的話，確實是可以。不過⋯⋯這並不是那麼方便的能力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00148",
