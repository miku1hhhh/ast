	["0033_00039"] = {
		{"fg", file="tohka_01f_00001", file1="tohka_01f_00101", file2="tohka_01f_00204", path=":fg/tohka_01f/", id=30, ch="桐香", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0633", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“It’s because it’s late. Ikuko may wake up, but she has a habit you should know of. She unconsciously tries to cut invaders in half, so you could end up in two pieces if you’re unlucky.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“因为都这个时间了嘛。郁子应该起得来，不过她有不自觉把闯入者砍成两半的习惯，做不好的话，战斗力很可能会减半。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「因為都這個時間了嘛。郁子應該起得來，不過她有不自覺把闖入者砍成兩半的習慣，做不好的話，戰鬥力很可能會減半。」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00038",
		linknext = "0033_00040",
		line = 544,
	},
	["0033_00040"] = {
