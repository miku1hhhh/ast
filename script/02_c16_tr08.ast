	},
	["0033_00158"] = {
		{"fg", file="tohka_01ll_00001", file1="tohka_01ll_00101", file2="tohka_01ll_00201", path=":fg/tohka_01ll/", id=8, lv=8, head="tohka_01ll", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0658", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I was only ever praised for one thing in my training with the Sakimori family, and that was my thread technique in combat. It seems like it’s a weapon that’s been passed down the Reizeiin family.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我啊、即使在驻防家受训的时候，也就只有用丝线战斗的这件事受到夸奖而已。据说那个丝线是冷泉院家代代相传的武器──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我啊、即使在駐防家受訓的時候，也就只有用絲線戰鬥的這件事受到誇獎而已。據說那個絲線是冷泉院家代代相傳的武器──」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00157",
		linknext = "0033_00159",
		line = 2364,
	},
	["0033_00159"] = {
		{"fg", file="tohka_02ll_00001", file1="tohka_02ll_00101", file2="tohka_02ll_00228", path=":fg/tohka_02ll/", id=8, lv=8, head="tohka_02ll", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0659", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Anyway, I lived in a peaceful world. Working as a servant, I barely had any chance to use my combat skills.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“反正世界太平了，战斗力对仆人这个职业来说，几乎没什么派得上用场的地方。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「反正世界太平了，戰鬥力對僕人這個職業來說，幾乎沒什麼派得上用場的地方。」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00158",
		linknext = "0033_00160",
		line = 2379,
	},
	["0033_00160"] = {
		{"fgact", ch="桐香8", id=8, lv=8, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So the only way to utilize her skills was to enter the FS and become a soldier.",
					{"rt2"},
				},
			},
			cn = {
				{
					"使用它的唯一方法是加入FS并成为警卫。",
					{"rt2"},
				},
			},
			tw = {
				{
					"使用它的唯一方法是加入FS並成為警衛。",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00159",
		linknext = "0033_00161",
