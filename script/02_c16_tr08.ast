	["0033_00044"] = {
		{"fg", file="susuko_02f_00001", file1="susuko_02f_00101", file2="susuko_02f_00204", path=":fg/susuko_02f/", id=30, ch="スス子", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
