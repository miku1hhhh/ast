			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I heard that they have been spotted more frequently in the last five years.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我有听说过在过去五年里，目击者的证词有所增加。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我有聽說過在過去五年裡，目擊者的證詞有所增加。」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00084",
		linknext = "0033_00086",
		line = 1284,
	},
	["0033_00086"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00208", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
