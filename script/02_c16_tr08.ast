			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“So unless there are only foes in the area or our allies are very strategic, I can’t use the thread if I don’t want to harm our comrades.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“所以除非这片区域只有敌人，或者有战斗能力极高的盟友，我才会展开丝线。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「所以除非這片區域只有敵人，或者有戰鬥能力極高的盟友，我才會展開絲線。」",
					{"rt2"},
				},
