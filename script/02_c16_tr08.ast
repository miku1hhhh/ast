	},
	["0033_00216"] = {
		{"fg", file="tohka_02ll_00001", file1="tohka_02ll_00101", file2="tohka_02ll_00207", path=":fg/tohka_02ll/", id=8, lv=8, head="tohka_02ll", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0682", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Even now that I’ve already given up as I couldn’t get you... I still wish that you’d take me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“因为得不到，所以我就放弃了⋯⋯但直到现在，我也还是抱持着想要得到你的想法。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「因為得不到，所以我就放棄了⋯⋯但直到現在，我也還是抱持著想要得到你的想法。」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00215",
		linknext = "0033_00217",
		line = 3151,
	},
	["0033_00217"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Unlike Fumino, she isn’t good at expressing her feelings.",
					{"rt2"},
				},
			},
			cn = {
				{
					"与文乃的状况是不同的意思，我想她是不擅于表达感情的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"與文乃的狀況是不同的意思，我想她是不擅於表達感情的。",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00216",
		linknext = "0033_00218",
		line = 3161,
	},
	["0033_00218"] = {
		{"fg", file="tohka_02ll_00001", file1="tohka_02ll_00101", file2="tohka_02ll_00201", path=":fg/tohka_02ll/", id=8, lv=8, head="tohka_02ll", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As I say that, she agrees.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当我这样告诉她时，她回应我“可能是这样也说不定”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當我這樣告訴她時，她回應我「可能是這樣也說不定」。",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00217",
		linknext = "0033_00219",
		line = 3174,
	},
	["0033_00219"] = {
		{"fg", file="tohka_01ll_00001", file1="tohka_01ll_00101", file2="tohka_01ll_00228", path=":fg/tohka_01ll/", id=8, lv=8, head="tohka_01ll", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0683", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“People used to get mad with me so much for smiling all the time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我从以前就常常因为在不该笑的场合笑，所以一直被骂。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我從以前就常常因為在不該笑的場合笑，所以一直被罵。」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00218",
		linknext = "0033_00220",
		line = 3189,
	},
	["0033_00220"] = {
		{"fg", file="tohka_01ll_00001", file1="tohka_01ll_00101", file2="tohka_01ll_00207", path=":fg/tohka_01ll/", id=8, lv=8, head="tohka_01ll", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0684", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“But if I want another person to smile, I have to start with my own self.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“但如果想让别人微笑，自己必须先微笑才行。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「但如果想讓別人微笑，自己必須先微笑才行。」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00219",
		linknext = "0033_00221",
		line = 3204,
	},
	["0033_00221"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s Touka Reizeiin’s innocent and truly kind behavioral pattern...",
					{"rt2"},
				},
			},
			cn = {
				{
					"就是因为这样，她才被大人当成惹事生非的人，继续被人看不起。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就是因為這樣，她才被大人當成惹事生非的人，繼續被人看不起。",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00220",
		linknext = "0033_00222",
		line = 3214,
	},
	["0033_00222"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Derived from her being treated like a burden and given a cold shoulder.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而这是发自冷泉院桐香内心的，一种纯粹的温柔表现。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而這是發自冷泉院桐香內心的，一種純粹的溫柔表現。",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00221",
		linknext = "0033_00223",
		line = 3224,
	},
	["0033_00223"] = {
		{"fg", file="tohka_02ll_00001", file1="tohka_02ll_00101", file2="tohka_02ll_00222", path=":fg/tohka_02ll/", id=8, lv=8, head="tohka_02ll", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0685", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I know well that you hate people like me. I know that you consider me incompatible. However...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我知道你讨厌像我这样的人。有很多事我不擅长、也有很多事无法好好配合。不过──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我知道你討厭像我這樣的人。有很多事我不擅長、也有很多事無法好好配合。不過──」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00222",
		linknext = "0033_00224",
		line = 3239,
	},
	["0033_00224"] = {
		{"fg", file="tohka_02ll_00001", file1="tohka_02ll_00101", file2="tohka_02ll_00228", path=":fg/tohka_02ll/", id=8, lv=8, head="tohka_02ll", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"text"},
		text = {
