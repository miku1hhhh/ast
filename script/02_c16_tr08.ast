		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If there’s no jamming, it means that we’ve encircled them unless the GPS is turned off, but there’s no way the Birds of a Feather would do that...",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果没有干扰，除非我们完全关闭GPS，不然他们将会被我们的网络给包围住，但‘Tori公’应该不会那样做才对。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果沒有干擾，除非我們完全關閉GPS，不然他們將會被我們的網路給包圍住，但『Tori公』應該不會那樣做才對。",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00045",
		linknext = "0033_00047",
		line = 668,
	},
