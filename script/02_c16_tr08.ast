				{"vo", file="tohka0686", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“But I can keep wishing to see your smile, right, Tachibana?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“──不过，我希望你能一直微笑下去，可以吗、前辈？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「──不過，我希望你能一直微笑下去，可以嗎、前輩？」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00223",
		linknext = "0033_00225",
		line = 3254,
	},
	["0033_00225"] = {
