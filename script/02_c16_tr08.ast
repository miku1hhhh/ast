			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“It’s effective against opponents who aren’t very mobile. But otherwise, this ability isn’t so convenient.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“如果是没有激动的性的对手的话，确实是可以。不过⋯⋯这并不是那么方便的能力。”",
