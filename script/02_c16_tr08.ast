	},
	["0033_00153"] = {
		{"fg", file="tohka_01f_00001", file1="tohka_01f_00101", file2="tohka_01f_00228", path=":fg/tohka_01f/", id=30, ch="桐香", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=28},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0655", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“That’s... Hehe! In very limited cases. The characteristics of the thread cause it to cover the entire area that’s under attack. It knows no enemies or allies.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“那个啊……呵呵，那只能维持非常有限的时间。由于丝线的性质，它会在那个空间内产生不分敌我的攻击。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「那個啊……呵呵，那只能維持非常有限的時間。由於絲線的性質，它會在那個空間內產生不分敵我的攻擊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00152",
		linknext = "0033_00154",
		line = 2278,
	},
