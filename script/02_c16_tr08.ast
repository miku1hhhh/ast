		{"cgact", file="cgact", id=1, act="浮遊", loop=-1, size=2.5, time=100, ease="easeinout_sine", lv=1},
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00216", path=":fg/jun_01f/", id=30, ch="淳之介", lv=1, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I’ve never heard of bears inhabiting this place! I thought they’d gone extinct!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“喂我从来没听过这种地方有熊啊！？它们不是已经灭绝了吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「喂我從來沒聽過這種地方有熊啊！？牠們不是已經滅絕了嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00083",
		linknext = "0033_00085",
		line = 1269,
	},
	["0033_00085"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
