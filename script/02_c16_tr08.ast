	["0033_00157"] = {
		{"fg", file="tohka_02ll_00001", file1="tohka_02ll_00101", file2="tohka_02ll_00202", path=":fg/tohka_02ll/", id=8, lv=8, head="tohka_02ll", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0657", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“A long time ago... Shortly after I entered the FS. I used my thread during combat training and I nearly cut off my comrade’s arm.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“以前……就在我刚加入FS的时候。在战斗训练时我差点用丝线砍断了一个FS的胳膊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「以前……就在我剛加入FS的時候。在戰鬥訓練時我差點用絲線砍斷了一個FS的胳膊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00156",
		linknext = "0033_00158",
