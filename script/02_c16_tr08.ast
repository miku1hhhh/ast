		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She was blessed with nothing, but still, she lived innocently. She never felt jealousy or envy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个可怜的女孩之所以能够活得如此纯粹，是因为她没有艳羡和嫉妒的感觉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個可憐的女孩之所以能夠活得如此純粹，是因為她沒有艷羨和嫉妒的感覺。",
					{"rt2"},
				},
