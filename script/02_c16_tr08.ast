		{"fg", file="tohka_01f_00001", file1="tohka_01f_00101", file2="tohka_01f_00202", path=":fg/tohka_01f/", id=30, ch="桐香", lv=29, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
