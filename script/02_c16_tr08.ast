	["0033_00177"] = {
		{"fg", file="tohka_01ll_00001", file1="tohka_01ll_00101", file2="tohka_01ll_00202", path=":fg/tohka_01ll/", id=8, lv=8, head="tohka_01ll", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0665", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Ever since, I’ve decided to never use my threads on my allies or people I love. Never ever.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“从那时起，我就下定决心了……我不会对自己人或在意的人使用‘丝线’攻击。不对，是‘我不能用’才对。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「從那時起，我就下定決心了……我不會對自己人或在意的人使用『絲線』攻擊。不對，是『我不能用』才對。」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00176",
		linknext = "0033_00178",
		line = 2667,
	},
	["0033_00178"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00209", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
