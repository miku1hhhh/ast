				{"cgact", file="cgact", id=28, act="浮遊横", loop=4, size=15, time=50, ease="easeinout_sine", timestamp=43, delay2=2200, lv=28, x=3, y=-0.5},
			},
		},
		text = {
			vo = {
				{"vo", file="tohka0654", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“This skill is originally meant to defend an area. It is essential to install fulcra at appropriate positions beforehand. Otherwise, it would be just a normal thin thread.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“这是以空间作为防御的一种能力。最重要的是要事先将支点放在正确的位置上，否则这就只是普通的细线而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「這是以空間作為防禦的一種能力。最重要的是要事先將支點放在正確的位置上，否則這就只是普通的細線而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0033_00150",
		linknext = "0033_00152",
		line = 2253,
	},
	["0033_00152"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00219", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Still, you can spread it when you fight, right? You often did it before.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过你可以边战斗边拉开线吧？你不是常这样做吗？”",
