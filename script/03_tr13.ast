			en = {
				{
					name = {"郁子", "Ikuko"},
					"“She acts like a middle-aged man. It’s gross and pathetic. Why can she handle face-fucking, but not toothbrushing?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“那样就和中年大叔一样难堪呢──她明明可以做强制口交，为什么却不会刷牙？”",
