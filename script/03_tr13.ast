	["0060_00273"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As soon as she remembers to put away the sauce, she forgets about ketchup. Or she just wanders off without clearing anything.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我还以为她有把酱汁放回去，结果这次换成忘记番茄酱，再下一次则是全部都没有放回去，人就不知道跑去哪里了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我還以為她有把醬汁放回去，結果這次換成忘記番茄醬，再下一次則是全部都沒有放回去，人就不知道跑去哪裡了。",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00272",
		linknext = "0060_00274",
		line = 3654,
	},
	["0060_00274"] = {
