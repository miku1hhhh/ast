		text = {
			vo = {
				{"vo", file="asane0205", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“But I’m so scared I’m not gonna say anything! I have no idea what she’s thinking! She could cut off my limbs, remodel my body to be heavier and more durable, and install it onto a powerful weapon!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“她可怕到我没办法抱怨啦……！那个完全不知道在想什么的笑容实在好可怕！我会不会被切断四肢然后被改造成适合耐重的身体后被迫坐上决战兵器啊奈奈濑！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「她可怕到我沒辦法抱怨啦……！那個完全不知道在想什麼的笑容實在好可怕！我會不會被切斷四肢然後被改造成適合耐重的身體後被迫坐上決戰兵器啊奈奈瀨！」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00406",
