			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If Touka’s going to learn anything, she needs to eat well... On her own, at that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
