					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Things like data are useless. It’s too obvious that our Junnosuke is more adorable...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“资料这种东西根本派不上用场。我们的淳之介更加可爱是显而易见的事实……！”",
					{"rt2"},
				},
			},
