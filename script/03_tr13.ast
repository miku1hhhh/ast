			},
			[6199] = {
				{"transitiontime", time=300, timestamp=31, delay2=6200},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0177", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ultimately, you don’t end the call, but scream ‘I’m coming to you!’ and get the Cum Boost, shouting ‘TOOOOUKA!’ Anyone would figure it out after seeing a person running faster than a bike.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“而且最后还是没挂断，说‘我现在就过去’之后，用比我骑脚踏车还快的速度，一边叫着‘桐香～～！’一边骑高潮脚踏车过去的话，全岛上的人都会发现吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「而且最後還是沒掛斷，說『我現在就過去』之後，用比我騎腳踏車還快的速度，一邊叫著『桐香～～！』一邊騎高潮腳踏車過去的話，全島上的人都會發現吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00305",
		linknext = "0060_00307",
		line = 4220,
	},
	["0060_00307"] = {
