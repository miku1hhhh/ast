	["0060_00323"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=22},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That’s why I’d like Nanase and Fumino to teach me how to cook. The more people taste your food the better, so I had y’all gather here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“此外，我也想让奈奈濑和文乃教我做料理。负责试吃的人越多越好，所以我才请大家过来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「此外，我也想讓奈奈瀨和文乃教我做料理。負責試吃的人越多越好，所以我才請大家過來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00322",
		linknext = "0060_00324",
		line = 4468,
	},
	["0060_00324"] = {
