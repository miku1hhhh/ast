		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Also, she gets negative points every time she makes me angry. It’s an excellent method to get some common sense into her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“还有，只要让我生气点数就会变成负数，所以拿来训练让行为合乎一般常识也很好用哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「還有，只要讓我生氣點數就會變成負數，所以拿來訓練讓行為合乎一般常識也很好用哦。」",
					{"rt2"},
				},
			},
		},
