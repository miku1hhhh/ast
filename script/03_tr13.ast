	["0060_00282"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00212", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=11, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0243", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“That’s right, Junnosuke. In my data. Around 80% of people who said that were victims of domestic abuse.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“没错，淳之介，我的资料也是这么说的。大约有八成的人类遭受过家暴伤害──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「沒錯，淳之介，我的資料也是這麼說的。大約有八成的人類遭受過家暴傷害──」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00281",
		linknext = "0060_00283",
		line = 3812,
	},
