	["0060_00304"] = {
		{"bgm", file="bgm25", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00222", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“H-How?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么、为什么──！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼、為什麼──！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00303",
		linknext = "0060_00305",
		line = 4180,
	},
	["0060_00305"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", file2="asane_01f_00217", path=":fg/asane_01f/", id=30, ch="麻沙音", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0197", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You’re on the phone several hours each day and you always say, ‘You end first. On three! One... Two... Three! Come on! End it!’ Anyone who hears that would figure it out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“什么为什么？你一天和她讲电话十几个小时，我都会听到‘你先挂啦，那我们数到三一起挂断！……喂，挂断啦～～！’的这种声音，当然会发现啰。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「什麼為什麼？你一天和她講電話十幾個小時，我都會聽到『妳先掛啦，那我們數到三一起掛斷！……喂，掛斷啦～～！』的這種聲音，當然會發現囉。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00304",
		linknext = "0060_00306",
		line = 4193,
	},
	["0060_00306"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00101", file2="misaki_02m_00205", path=":fg/misaki_02m/", id=6, lv=6, head="misaki_02m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-205, y=-5},
