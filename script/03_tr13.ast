	["0060_00329"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file3="jun_01f_00305", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=22},
