			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Hmmm... Maybe you’re right. But I have no idea what to call him. What should I call him?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“称呼方式……嗯，说得也是。我不知道该怎么叫他会比较好，不过换个称呼会比较好对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「稱呼方式……嗯，說得也是。我不知道該怎麼叫他會比較好，不過換個稱呼會比較好對吧？」",
					{"rt2"},
				},
			},
		},
