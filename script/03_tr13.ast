			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“What on earth? ...Well, whatever. You just want to make something tasty for the person you love.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“你是用哪种视角看她啊……？算了，你是想说要让很挑食的人吃些什么吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「你是用哪種視角看她啊……？算了，你是想說要讓很挑食的人吃些什麼吧？」",
					{"rt2"},
				},
			},
		},
