	["0060_00326"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file2="fumino_01m_00201", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0154", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I don’t mind if that’s your order... But why do you want to cook? I was going to prepare rice balls...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“如果这是淳之介的命令，文乃是无所谓……不过，你为什么要学做料理……？文乃之后也打算继续做料理啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「如果這是淳之介的命令，文乃是無所謂……不過，你為什麼要學做料理……？文乃之後也打算繼續做料理啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00325",
		linknext = "0060_00327",
		line = 4511,
	},
	["0060_00327"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=22},
		{"text"},
		text = {
