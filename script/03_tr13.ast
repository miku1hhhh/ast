		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“They say your tastes get defined while you’re still a child. I want her to have taste buds as sharp as a razor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“据说味觉的品味会在年幼时养成，我希望将她培育成将来有敏锐味觉的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「據說味覺的品味會在年幼時養成，我希望將她培育成將來有敏銳味覺的人。」",
					{"rt2"},
				},
			},
		},
