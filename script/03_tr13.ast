			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“就是啊，就算是我重要的朋友淳之介，说他比我们的学生会长还可爱也太夸张了……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「就是啊，就算是我重要的朋友淳之介，說他比我們的學生會長還可愛也太誇張了……！」",
					{"rt2"},
				},
			},
		},
