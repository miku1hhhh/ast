			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“When it comes to Junnosuke’s cuteness, the president would go in heat, get wet like a bitch, and take him to a hotel.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“只要有我家淳之介的可爱之处，会长也会像个雌性般发情，用湿透的小穴把他带去旅馆吧～～”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「只要有我家淳之介的可愛之處，會長也會像個雌性般發情，用濕透的小穴把他帶去旅館吧～～」",
					{"rt2"},
				},
			},
		},
