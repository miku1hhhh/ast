					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“失去视觉、身体无法动弹，前辈会对什么都做不了的我做什么呢……？我非常有兴趣",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「失去視覺、身體無法動彈，前輩會對什麼都做不了的我做什麼呢……？我非常有興趣",
					{"gaiji", text="①"},
					"」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00095",
		linknext = "0060_00097",
		line = 1437,
	},
