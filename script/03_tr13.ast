		linknext = "0060_00442",
		line = 6443,
	},
	["0060_00442"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", file2="misaki_01m_00206", path=":fg/misaki_01m/", id=23, lv=23, head="misaki_01m", ch_origin="美岬", ch="美岬23", mw="mw", sync=0, mode=3, x=-355, y=-5},
