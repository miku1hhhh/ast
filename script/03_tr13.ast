	["0060_00316"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00201", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=22},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Let me introduce her to you officially. This is my girlfriend, Touka Reizeiin.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“让我重新介绍，她是成为我女朋友的冷泉院桐香。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「讓我重新介紹，她是成為我女朋友的冷泉院桐香。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00315",
		linknext = "0060_00317",
		line = 4365,
	},
	["0060_00317"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=22},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She can talk proudly about everything and multitask while she’s working. She’s great at combat, but she sucks at life. My fat-assed girl has many faces. I’m so proud of her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她会用得意的表情诉说事物、可以同时执行许多工作、战斗力也非常高，不过实际上，她有非常脱线的一面，其实就连日常生活也无法顺利进行，是我自豪的大屁股女友──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「她會用得意的表情訴說事物、可以同時執行許多工作、戰鬥力也非常高，不過實際上，她有非常脫線的一面，其實就連日常生活也無法順利進行，是我自豪的大屁股女友──」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00316",
		linknext = "0060_00318",
		line = 4377,
	},
	["0060_00318"] = {
