			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“The president aside, Jun is another problem... Why is he saying that he won’t have sex outside the punishment?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“会长虽然有很多问题，不过淳也是呢……除了惩罚以外，他似乎没有做任何色色的事，会长是这么说的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「會長雖然有很多問題，不過淳也是呢……除了懲罰以外，他似乎沒有做任何色色的事，會長是這麼說的……」",
					{"rt2"},
				},
			},
		},
