				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I see! When the results are shown in a form as simple as a stamp card, Miss Touka can easily stay motivated!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“原来如此……！只要有集点卡这种浅显易懂的成果，就能随时维持桐香大人的干劲！是促使她自立的跨时代支援系统──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「原來如此……！只要有集點卡這種淺顯易懂的成果，就能隨時維持桐香大人的幹勁！是促使她自立的跨時代支援系統──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00041",
