			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“啊──好好好，我不认为她是那么残酷的人，所以你就多花点时间，慢慢接受她吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「啊──好好好，我不認為她是那麼殘酷的人，所以妳就多花點時間，慢慢接受她吧……」",
