				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Yeah! Double suicide is the scariest! Consequently, we need to use our overall power and think of a strategy to make them a decent couple!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“没错！最让人害怕的就是自杀！所以我们要集结全队员之力，想出让桐香大人成为像样情侣的作战！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「沒錯！最讓人害怕的就是自殺！所以我們要集結全隊員之力，想出讓桐香大人成為像樣情侶的作戰！」",
					{"rt2"},
				},
			},
		},
