				},
			},
			tw = {
				{
					name = {"郁子"},
					"「她可能沒有發現，或是對被人觀看感覺到快感吧，別理她……啊──要是伊波醬也在這裡負責吐槽就會輕鬆多了呢～～」",
					{"rt2"},
				},
			},
		},
