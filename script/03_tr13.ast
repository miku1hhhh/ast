	["0060_00361"] = {
		{"fg", file="tohka_02m_00010", file1="tohka_02m_00102", file3="tohka_02m_00314", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-505, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1033", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“No, it’s not like I’m scared or anything. I just need to break away from my past. Many wounds reopen when people grow up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不对这真的不是恐怖这种感情哦这个嘛硬要说的话该说是与过去的告别吧我目前正在感受这是人在成长过程中必经的伤痛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不對這真的不是恐怖這種感情哦這個嘛硬要說的話該說是與過去的告別吧我目前正在感受這是人在成長過程中必經的傷痛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0060_00360",
		linknext = "0060_00362",
		line = 5071,
	},
	["0060_00362"] = {
