					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Because she misses people so much... We only hoped that we didn’t hurt her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“会长她啊，是个相当容易寂寞的人，所以啊⋯⋯希望她不要觉得受伤了才好⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「會長她啊，是個相當容易寂寞的人，所以啊⋯⋯希望她不要覺得受傷了才好⋯⋯」",
					{"rt2"},
				},
			},
		},
