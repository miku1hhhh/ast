	},
	["0047_00088"] = {
		{"fg", file="tohka_01m_00004", file1="tohka_01m_00101", file2="tohka_01m_00202", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0811", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“In a sense, living in this world was like a dream for me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“⋯⋯在这边这个世界的生活，对我来说、某种程度上就像梦一样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「⋯⋯在這邊這個世界的生活，對我來說、某種程度上就像夢一樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0047_00087",
		linknext = "0047_00089",
		line = 1123,
	},
	["0047_00089"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She speaks naturally as if we were just chatting.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她以闲聊般自然的语气说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她以閒聊般自然的語氣說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0047_00088",
		linknext = "0047_00090",
		line = 1133,
	},
	["0047_00090"] = {
		{"fg", file="tohka_02m_00004", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0812", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You’re right beside me. I’ve always wanted you to be close to us as your comrade.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“你就在我身边。作为伙伴待在我们的身边，这才是我真的期望的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「你就在我身邊。作為夥伴待在我們的身邊，這才是我真的期望的事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0047_00089",
		linknext = "0047_00091",
		line = 1148,
	},
	["0047_00091"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, I can clearly hear the notes of anguish in her voice.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是她的声音，明显地夹杂着痛苦。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是她的聲音，明顯地夾雜著痛苦。",
					{"rt2"},
				},
			},
		},
		linkback = "0047_00090",
		linknext = "0047_00092",
		line = 1158,
	},
	["0047_00092"] = {
		{"fg", file="tohka_02m_00004", file1="tohka_02m_00101", file2="tohka_02m_00205", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0813", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I was hesitant at first. Then I started getting used to it. I lessened the distance between us, and believed that we got closer to each other.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“最初觉得很困惑，但后来也就习惯了，和你之间的距离缩小了，就觉得稍微可以相处的融洽一点──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「最初覺得很困惑，但後來也就習慣了，和你之間的距離縮小了，就覺得稍微可以相處的融洽一點──」",
					{"rt2"},
				},
			},
		},
		linkback = "0047_00091",
		linknext = "0047_00093",
		line = 1173,
	},
	["0047_00093"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She lets out a heavy sigh.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我能听得到痛苦的叹息声。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我能聽得到痛苦的嘆息聲。",
					{"rt2"},
				},
			},
		},
		linkback = "0047_00092",
		linknext = "0047_00094",
		line = 1183,
	},
	["0047_00094"] = {
		{"fg", file="tohka_02m_00004", file1="tohka_02m_00101", file2="tohka_02m_00207", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0814", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“In the past I had to fight my comrades, and more than that, my beloved relative.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我和以前的伙伴战斗,甚至到了和挚爱的亲人战斗的地步。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我和以前的夥伴戰鬥,甚至到了和摯愛的親人戰鬥的地步。」",
					{"rt2"},
				},
			},
		},
		linkback = "0047_00093",
		linknext = "0047_00095",
		line = 1198,
	},
	["0047_00095"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"How Touka lived in this world doesn’t make sense to her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"跟这一边桐香的……这样的便利性，对她来说毫无意义。",
					{"rt2"},
				},
			},
			tw = {
				{
					"跟這一邊桐香的……這樣的便利性，對她來說毫無意義。",
