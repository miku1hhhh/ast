			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Yes! I talked to the others later! We agreed that the president would’ve never betrayed us, so we thought of a plan to revive the Big Three!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“是的。在那之后丝丝跟所有人都谈过了……‘这样的会长是绝对不会背叛我们的’,于是大家一起制定了三巨头复活计划。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「是的。在那之後絲絲跟所有人都談過了……『這樣的會長是絕對不會背叛我們的』,於是大家一起制定了三巨頭復活計劃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0047_00001",
		linknext = "0047_00003",
		line = 35,
	},
