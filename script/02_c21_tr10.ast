				{"vo", file="susuko0306", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“How should I put it...? Um, when I was little, I Iost my mother and... Uhm...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“该怎么说了，我也说不清……我因为从小就失去妈妈的关系……那个……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「該怎麼說了，我也說不清……我因為從小就失去媽媽的關係……那個……」",
					{"rt2"},
				},
			},
		},
		linkback = "0047_00046",
		linknext = "0047_00048",
		line = 571,
	},
	["0047_00048"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00206", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0307", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“And I feel like every time the president has to go back after spending time with the FS... she unconsciously makes the same face as I did back then.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“跟FS的大家再一起吵吵闹闹的，但回家的时候…….会长她会突然间……感觉那个时候和我的表情很相像呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「跟FS的大家再一起吵吵鬧鬧的，但回家的時候…….會長她會突然間……感覺那個時候和我的表情很相像呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0047_00047",
		linknext = "0047_00049",
		line = 586,
	},
	["0047_00049"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Is she talking about the Touka of this world?",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个是在说这边的桐香吧。",
					{"rt2"},
