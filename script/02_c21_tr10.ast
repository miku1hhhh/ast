		text = {
			vo = {
				{"vo", file="susuko0312", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Well, we were worried all the time, but we didn’t panic! Your Sexellency has been with the president after all!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“好吧，虽然一直很担心，但也并不着急！因为会长她啊，有性帝在一旁跟着嘛！所以。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「好吧，雖然一直很擔心，但也並不著急！因為會長她啊，有性帝在一旁跟著嘛！所以。」",
					{"rt2"},
				},
			},
		},
		linkback = "0047_00061",
		linknext = "0047_00063",
		line = 766,
	},
