					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don’t get ahead of yourself kid, this didn’t count. You’re still a kid... You’re still my cute baby sister...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不要得意忘形了小姑娘，这个不算数，所以你还是小孩……还是我可爱的妹妹喔……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不要得意忘形了小姑娘，這個不算數，所以妳還是小孩……還是我可愛的妹妹喔……！」",
					{"rt2"},
				},
			},
		},
