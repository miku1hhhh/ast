	["0084_00063"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00217", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=0, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		delay = {
			[1000] = {
				{"se", id=0, loop=0, file="se_a141", timestamp=14, delay2=1000},
			},
		},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hey, no flushing non-toilet paper, okay?! Look at what you wrote when you were seven, ‘Thanks to big bro I can go to the potty all on my own now...’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我不是说过不可以把卫生纸以外的东西冲进马桶里面吗！？这边这封7岁的信上面也也着‘多亏了葛格我现在会一个人上厕所了喔’──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我不是說過不可以把衛生紙以外的東西沖進馬桶裡面嗎！？這邊這封7歲的信上面也也著『多虧了葛格我現在會一個人上廁所了喔』──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00062",
