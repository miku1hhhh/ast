			},
			tw = {
				{
					name = {"麻沙音"},
					"「這些、是麻沙醬在兒童時代寫給老哥的信……！？不是應該已經死了嗎──！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00042",
		linknext = "0084_00044",
		line = 597,
	},
	["0084_00044"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file3="jun_01f_00310", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
