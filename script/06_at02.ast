					"“什么什么，老哥那个是怎么了？咦，是保险箱？呜呵──原来连橘家都有隐藏的财产沉睡吗怎么办要当作T资金运用然后用于怎么有趣地无视畔同学吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「什麼什麼，老哥那個是怎麼了？咦，是保險箱？嗚呵──原來連橘家都有隱藏的財產沉睡嗎怎麼辦要當作T資金運用然後用於怎麼有趣地無視畔同學嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00035",
		linknext = "0084_00037",
		line = 500,
	},
	["0084_00037"] = {
