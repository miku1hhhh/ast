		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...I’m sorry, I just wanted keep my precious sister’s precious letters close at hand, and it seems like that hurt you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……刚才真是对不起啊，因为我忍不住想要炫耀我自豪的妹妹写给我的信，所以一直想着要保存好，看来反而是伤害到你了──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……剛才真是對不起啊，因為我忍不住想要炫耀我自豪的妹妹寫給我的信，所以一直想著要保存好，看來反而是傷害到妳了──」",
					{"rt2"},
				},
			},
		},
