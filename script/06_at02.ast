	["0084_00059"] = {
		{"fg", file="asane_02m_00003", file1="asane_02m_00102", file3="asane_02m_00302", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-205, y=-5},
		{"fgact", ch="麻沙音3", id=3, act="移動", x=200, y=0, time=400},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0443", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yeah, I’m so great I can chew and digest laminated letters okay, so just throw them out!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“对啦都已经大到会想要把被护贝过的信给吃进胃里消化掉了啦所以赶快丢掉啦！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「對啦都已經大到會想要把被護貝過的信給吃進胃裡消化掉了啦所以趕快丟掉啦！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00058",
		linknext = "0084_00060",
		line = 845,
	},
	["0084_00060"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Mom, you should really see this one she wrote when she was 11. It’s so nice, I still re-read it whenever I feel down.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就是啊妈妈，这封11岁的真的是很感人。值到现在我在情绪低落的时候都还会拿出来看喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就是啊媽媽，這封11歲的真的是很感人。值到現在我在情緒低落的時候都還會拿出來看喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00059",
		linknext = "0084_00061",
		line = 857,
	},
	["0084_00061"] = {
