					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“A scene-ish girl goes to the beach to take her mind off a romantic failure, then while she’s swimming a voice calls her from the rocks to comfort her, and then they fuck.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“失恋跑到海边转换心情的时候被好像是来玩水有点辣妹那种感觉的女孩说了‘摆出那种表情太浪费了",
					{"gaiji", text="①"},
					"’然后被拉到礁石后面迎接了初体验的那种。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「失戀跑到海邊轉換心情的時候被好像是來玩水有點辣妹那種感覺的女孩說了『擺出那種表情太浪費了",
					{"gaiji", text="①"},
					"』然後被拉到礁石後面迎接了初體驗的那種。」",
					{"rt2"},
				},
			},
		},
