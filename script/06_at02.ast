					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“No problem, Bro, I have my own stiff shoulders, backache, and dry eye to deal with from too much sleep and video games!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“没关系啦老哥，麻沙酱也因为打太多电动还有睡太多，所以干眼、肩颈僵硬又腰痛，这也算是一石二鸟……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「沒關係啦老哥，麻沙醬也因為打太多電動還有睡太多，所以乾眼、肩頸僵硬又腰痛，這也算是一石二鳥……！」",
					{"rt2"},
				},
			},
		},
