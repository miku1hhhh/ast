			},
			cn = {
				{
					name = {"麻沙音"},
					"“你说纤细……有多纤细？弄湿的宣纸那种程度？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「你說纖細……有多纖細？弄濕的宣紙那種程度？」",
					{"rt2"},
