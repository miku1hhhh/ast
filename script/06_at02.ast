					"“欸欸老哥感觉舒服吗……？不应该说感觉如何……？夸下那么多海口之后还输给了妹妹感觉如何……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「欸欸老哥感覺舒服嗎……？不應該說感覺如何……？誇下那麼多海口之後還輸給了妹妹感覺如何……！？」",
					{"rt2"},
				},
			},
		},
