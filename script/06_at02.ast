			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Aaaaah! No, don’t, you can’t! Give it, I’m going to the bathroom! I’ll use it wipe and then flush it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊啊啊啊啊啊啊啊啊啊啊啊！！不行、就是有那个真的不行！给我，我现在就去厕所！我要用那个擦屁股然后冲进马桶里！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊啊啊啊啊啊啊啊啊啊啊啊！！不行、就是有那個真的不行！給我，我現在就去廁所！我要用那個擦屁股然後沖進馬桶裡！」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00061",
		linknext = "0084_00063",
