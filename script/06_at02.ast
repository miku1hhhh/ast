					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Heh, these are the ones from when you were five, these when you were six, and this is a listing for just the ones you sent on my birthday. Here’s the catalogue.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哼，这边是你5岁的时候给我的信。整理在这个资料夹的是6岁的时候，这边这个则是把你在我生日的时候给我的东西列成的表。这个是目录。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哼，這邊是妳5歲的時候給我的信。整理在這個資料夾的是6歲的時候，這邊這個則是把妳在我生日的時候給我的東西列成的表。這個是目錄。」",
					{"rt2"},
				},
			},
		},
