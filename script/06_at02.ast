	["0084_00064"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"fg", file="asane_02m_001-1", file1="asane_02m_002-1", file2="asane_02m_003-1", file3="asane_02m_00402", path=":fg/asane_02m/", id=4, lv=4, head="asane_02m", ch_origin="麻沙音", ch="麻沙音4", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"fg", file="asane_02m_00003", file1="asane_02m_00104", file2="asane_02m_00211", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="浮遊横", loop=30, size=5, time=50, ease="easeinout_sine"},
		{"fgact", ch="麻沙音4", id=4, lv=4, act="表示アクション", alpha=0, alphadel=1, style="reset", time=400},
		{"fgact", ch="麻沙音4", id=4, act="移動", x=0, y=1000, time=600},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0445", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Why are you doing this to meeeee?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“你为什么要做这种事啊啊啊啊啊啊啊！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「你為什麼要做這種事啊啊啊啊啊啊啊！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00063",
		linknext = "0084_00065",
		line = 923,
	},
	["0084_00065"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00208", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=0},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Because my precious little sister’s letters are worth more than any vow, obviously!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“当然是因为最爱的妹妹写给我的信比任何一种贞操都更重要啊！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「當然是因為最愛的妹妹寫給我的信比任何一種貞操都更重要啊！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00064",
		linknext = "0084_00066",
		line = 935,
	},
	["0084_00066"] = {
		{"fg", file="asane_02m_00003", file1="asane_02m_00104", file2="asane_02m_00221", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0446", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“But it’s so embarrassing! My most shameful secrets! When I was a spineless little baby!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“就说那很丢脸了啦！那对我来说是黑历史啦！对麻沙酱来说扭扭捏捏的同年时代是黑历史啊──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「就說那很丟臉了啦！那對我來說是黑歷史啦！對麻沙醬來說扭扭捏捏的同年時代是黑歷史啊──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00065",
		linknext = "0084_00067",
		line = 950,
	},
	["0084_00067"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00212", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=0},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How could you call such a sweet little girl shameful! Look, this one from Mother’s Day even says ‘sorry for always hiding behind you big bro!’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别把这么温柔的孩子当成黑历史来对待啊！你看，在母亲节这天收到的信上也写着‘一直躲在哥哥背后真是对不起喔’──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別把這麼溫柔的孩子當成黑歷史來對待啊！你看，在母親節這天收到的信上也寫著『一直躲在哥哥背後真是對不起喔』──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00066",
		linknext = "0084_00068",
		line = 963,
	},
	["0084_00068"] = {
		{"fg", file="asane_01m_00003", file1="asane_01m_00104", file3="asane_01m_00301", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0447", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Noo, please, I’m gonna die of shame...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“真是、真的有够丢脸的不敢相信……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「真是、真的有夠丟臉的不敢相信……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00067",
		linknext = "0084_00069",
		line = 978,
	},
	["0084_00069"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00102", file2="jun_01f_00209", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=0},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Why’s your face all red, Asa? Did those letters you ate go down the wrong way?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么了麻沙酱，脸怎么那么红？是刚才吃下去的那些信让你吃坏肚子了吗──？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼了麻沙醬，臉怎麼那麼紅？是剛才吃下去的那些信讓妳吃壞肚子了嗎──？」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00068",
		linknext = "0084_00070",
		line = 990,
	},
	["0084_00070"] = {
		{"fg", file="asane_01m_00003", file1="asane_01m_00104", file2="asane_01m_00214", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0448", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Absolutely, they went straight to my head and now I’m gonna throw up, so take everything from that safe, throw it straight in the garbage and forget about it, Bro! You stupid virgin!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“是啦都已经坏到直冲脑门快要吐出来了啦所以赶快把保险箱放下把手上那些东西都丢掉然后把一切都忘掉啦这个死处男臭老哥！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「是啦都已經壞到直衝腦門快要吐出來了啦所以趕快把保險箱放下把手上那些東西都丟掉然後把一切都忘掉啦這個死處男臭老哥！」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00069",
		linknext = "0084_00071",
		line = 1005,
	},
	["0084_00071"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00228", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=0},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nope, these are my treasures! Even if I give up my virginity someday, these I’ll never let go!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“有什么关系，这些可是我的宝物耶！就算有丢掉童子之身的一天只有这些信我视觉不会丢掉的！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「有什麼關係，這些可是我的寶物耶！就算有丟掉童子之身的一天只有這些信我視覺不會丟掉的！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00070",
		linknext = "0084_00072",
		line = 1017,
	},
	["0084_00072"] = {
		{"fg", file="asane_02m_00003", file1="asane_02m_00104", file2="asane_02m_00215", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
