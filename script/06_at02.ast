		},
		text = {
			vo = {
				{"vo", file="asane0449", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Never mind then, just stooooop already! I’ll die! I’ll bite my tongue and die right here, right now!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不会有那种事啦真是的呃呃呃呃呃真的拜托你不要这样！我会去死喔！？我现在就咬舌自尽给你看！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不會有那種事啦真是的呃呃呃呃呃真的拜託你不要這樣！我會去死喔！？我現在就咬舌自盡給你看！」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00071",
		linknext = "0084_00073",
		line = 1036,
	},
	["0084_00073"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"cgact", file="cgact", id=1, act="浮遊", loop=5, size=2.5, time=50, ease="easeinout_sine", lv=1},
		{"fg", file="jun_01f_00003", file1="jun_01f_00102", file3="jun_01f_00305", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=1, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hey, no dying! You can’t die, you have to write me more letters!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“笨、别死啊！活着多写几封信给我啊──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「笨、別死啊！活著多寫幾封信給我啊──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00072",
		linknext = "0084_00074",
		line = 1050,
	},
	["0084_00074"] = {
		{"fg", file="asane_01m_00003", file1="asane_01m_00104", file3="asane_01m_00301", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0450", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Never! If you don’t throw those out, I’ll never speak to you again! And I won’t eat or go to school either!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“绝对不写！如果你不把那些信丢掉我就再也不跟你说话了！不吃饭也不上学了！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「絕對不寫！如果你不把那些信丟掉我就再也不跟你說話了！不吃飯也不上學了！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00073",
		linknext = "0084_00075",
		line = 1065,
	},
	["0084_00075"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00209", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, I should really share these with Nanase! Next time she visits I’ll show her!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对了，就跟奈奈濑分享这感动吧！下次她来的时候我就把这些拿给她看──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對了，就跟奈奈瀨分享這感動吧！下次她來的時候我就把這些拿給她看──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00074",
		linknext = "0084_00076",
		line = 1077,
	},
	["0084_00076"] = {
