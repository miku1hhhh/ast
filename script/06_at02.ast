					"“That does require some tender care... Aww, I’m sorry, it’s okay... You always talk to mommy about anything...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“那可真得郑重对待呢……对不起喔，乖乖……什么事情都可以跟妈妈说喔……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「那可真得鄭重對待呢……對不起喔，乖乖……什麼事情都可以跟媽媽說喔……」",
					{"rt2"},
				},
			},
		},
