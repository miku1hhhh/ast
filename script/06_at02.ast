			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“And now that I’ve stroked and sucked cock, maybe I’ve advanced a half-step toward adulthood...?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哎呀，飞机也打过了小鸡鸡也含过了，麻沙酱应该算是在成为大人的阶梯上前进了半步了吧……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哎呀，飛機也打過了小雞雞也含過了，麻沙醬應該算是在成為大人的階梯上前進了半步了吧……！？」",
					{"rt2"},
				},
			},
		},
