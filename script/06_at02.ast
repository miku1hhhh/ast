			cn = {
				{
					name = {"淳之介"},
					"“我选了尽可能容易打的小菜。原本手边的实体本为了应对奈奈濑和文乃所以处理掉了，可是最近总算出了电子版了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我選了儘可能容易打的小菜。原本手邊的實體本為了應對奈奈瀨和文乃所以處理掉了，可是最近總算出了電子版了。」",
					{"rt2"},
				},
			},
