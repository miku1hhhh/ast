			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I won’t stand for this! Gh, urgh! Nomnomnom! There, I ate them up, there’s no more left, right?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“这种东西！！咕、咳！哈姆哈姆哈姆、咕嘟！好啦我吞下去啦，已经没有我写的信了吧！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「這種東西！！咕、咳！哈姆哈姆哈姆、咕嘟！好啦我吞下去啦，已經沒有我寫的信了吧！？」",
					{"rt2"},
