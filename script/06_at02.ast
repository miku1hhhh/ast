	["0084_00045"] = {
		{"fg", file="asane_02m_00003", file1="asane_02m_00102", file2="asane_02m_00221", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=1, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0438", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Whaaat?! I know I snuck into your room to steal then and had Fumino burn them in the garden, how do you still have them?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哈啊啊啊啊啊啊！？我明明某一天擅自溜进了老哥的房间里偷出来还让文乃在后院里放火烧掉了为什么还有剩啊！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哈啊啊啊啊啊啊！？我明明某一天擅自溜進了老哥的房間裡偷出來還讓文乃在後院裡放火燒掉了為什麼還有剩啊！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00044",
		linknext = "0084_00046",
		line = 625,
	},
	["0084_00046"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Those where fakes I had Fumino prepare one night. I transferred the originals to this safe.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那些是诱饵。文乃一个晚上就帮我准备好了喔。真东西我早就移到这里来了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那些是誘餌。文乃一個晚上就幫我準備好了喔。真東西我早就移到這裡來了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00045",
		linknext = "0084_00047",
		line = 637,
	},
	["0084_00047"] = {
		{"fg", file="asane_01m_00003", file1="asane_01m_00102", file2="asane_01m_00221", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=5, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
