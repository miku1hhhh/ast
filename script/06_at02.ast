					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I thought I’d put the letters here so mom and dad could see them... See what a great daughter you have?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我想说放在这里的话，爸爸妈妈也能看到……爸、吗，麻沙酱长大了，对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我想說放在這裡的話，爸爸媽媽也能看到……爸、嗎，麻沙醬長大了，對吧？」",
					{"rt2"},
				},
			},
		},
