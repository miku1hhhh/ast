				{"vo", file="asane0439", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You showed them to her?! Also, how many sides was she playing?! Also also, when was this?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“你怎么擅自拿给她看啊！是说那家伙到底是几重间谍啊！还有那些真的到底是什么时候的东西啊！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「你怎麼擅自拿給她看啊！是說那傢伙到底是幾重間諜啊！還有那些真的到底是什麼時候的東西啊！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00046",
		linknext = "0084_00048",
		line = 653,
	},
	["0084_00048"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=0, mw="mw", mode=1, sync=0, x=-5, y=-5},
