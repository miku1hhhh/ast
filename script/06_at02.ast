					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“So you need to come up with a replacement for your dear old left hand, then...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“也就是说需要想出平时爱用的左手的代替品是吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「也就是說需要想出平時愛用的左手的代替品是嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00114",
		linknext = "0084_00116",
		line = 1667,
	},
	["0084_00116"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00218", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=6},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I considered some kind of automated onahole... It’d be nice on occasion, but it won’t work for everyday use.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为此我原本想使用电动飞机杯……但是那东西偶尔还好，无法每天使用。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為此我原本想使用電動飛機杯……但是那東西偶爾還好，無法每天使用。」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00115",
		linknext = "0084_00117",
		line = 1679,
	},
	["0084_00117"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00218", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=6},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“When I’m reading my online hentai manga, I want climax at the climax, and an automated system wouldn’t be synced up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为电动飞机杯无法跟这类的电子色情漫画连动，所以没办法在最棒的场景高潮。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為電動飛機杯無法跟這類的電子色情漫畫連動，所以沒辦法在最棒的場景高潮。」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00116",
		linknext = "0084_00118",
		line = 1691,
	},
	["0084_00118"] = {
