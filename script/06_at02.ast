	["0084_00012"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When she came with me to the osteopathy clinic, she also got told her body was inhuman and it was amazing she was alive, and I guess she took it seriously.",
					{"rt2"},
				},
			},
			cn = {
				{
					"跟着我一起去了整骨院的妹妹也被说了“这已经不是人类的身体了”“真亏你能活到现在啊”之类的老套台词，而且完全信以为真了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"跟著我一起去了整骨院的妹妹也被說了「這已經不是人類的身體了」「真虧妳能活到現在啊」之類的老套台詞，而且完全信以為真了。",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00011",
		linknext = "0084_00013",
		line = 172,
	},
