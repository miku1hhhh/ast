	["0084_00252"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“As delicate as a young man who turns hikikomori after entering a trade school to pursue his dreams and realizing all his classmates only enrolled to slack off and party.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“大概就跟找到了未来想做的事情进了专科学校以后发现同学都是随便就入学整天只会玩的家伙因为理想和现实的落差最后闭门不出的儿子一样纤细。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「大概就跟找到了未來想做的事情進了專科學校以後發現同學都是隨便就入學整天只會玩的傢伙因為理想和現實的落差最後閉門不出的兒子一樣纖細。」",
					{"rt2"},
				},
			},
		},
		linkback = "0084_00251",
		linknext = "0084_00253",
		line = 3506,
	},
	["0084_00253"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
