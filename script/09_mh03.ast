		line = 83,
	},
	["0103_00007"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When I got bullied as a kid, one girl reached out to me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"很久很久以前，当时遭遇霸凌的我，有个女生向我伸出了援手。",
					{"rt2"},
				},
			},
			tw = {
				{
					"很久很久以前，當時遭遇霸凌的我，有個女生向我伸出了援手。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00006",
		linknext = "0103_00008",
		line = 93,
	},
	["0103_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Thanks to that girl, I didn’t break. Thanks to her, I am who I am today.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为有她在我才没有崩溃的。有现在的我，都是要拜她所赐。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為有她在我才沒有崩潰的。有現在的我，都是要拜她所賜。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00007",
		linknext = "0103_00009",
		line = 103,
	},
	["0103_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All the more reason I want to apologize properly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以──我想好好的道歉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以──我想好好的道歉。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00008",
