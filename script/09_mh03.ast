		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The expression “getting it off my chest” doesn’t quite fit.",
					{"rt2"},
				},
			},
			cn = {
				{
					"心中大石放下──我觉得这说法和我的感觉不太像。",
					{"rt2"},
				},
			},
			tw = {
				{
					"心中大石放下──我覺得這說法和我的感覺不太像。",
