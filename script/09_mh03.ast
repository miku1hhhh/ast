	["0103_00016"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She’s easy on the throttle, light on the brakes, and always checks her mirrors and blind spots. There’s not a single reason for her to get slapped with a warning.",
					{"rt2"},
				},
			},
			cn = {
				{
					"缓慢滑行并且安全确认也不马虎。这样还有什么理由会被叫停呢──",
					{"rt2"},
				},
			},
			tw = {
				{
					"緩慢滑行並且安全確認也不馬虎。這樣還有什麼理由會被叫停呢──",
					{"rt2"},
				},
			},
		},
