	["0103_00020"] = {
		{"fg", file="kouki_01f_00002", file1="kouki_01f_00101", file2="kouki_01f_00203", path=":fg/kouki_01f/", id=30, ch="光姫", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=16},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0165", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Driving without a license is illegal! Reflect on your grievous crimes!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“无照驾驶是违法的！你给我待在那边好好反省一会儿！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「無照駕駛是違法的！妳給我待在那邊好好反省一會兒！」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00019",
		linknext = "0103_00021",
		line = 284,
	},
	["0103_00021"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00101", file2="misaki_01f_00225", path=":fg/misaki_01f/", id=30, ch="美岬", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=22},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0805", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“No wayyy! This is tyranny! Besides, isn’t it illegal to suddenly throw somebody in jail for nothing, too?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“怎么会这样⋯⋯！真是蛮横！突然把人关起来这也是违法的好嘛──！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「怎麼會這樣⋯⋯！真是蠻橫！突然把人關起來這也是違法的好嘛──！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00020",
		linknext = "0103_00022",
		line = 297,
	},
	["0103_00022"] = {
		{"fg", file="kouki_01f_00001", file1="kouki_01f_00101", file2="kouki_01f_00224", path=":fg/kouki_01f/", id=30, ch="光姫", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=16},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0166", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“No use arguing! We’ve had to step up our policing since the perverted sex law was abolished. Don’t worry, I’ll give you pork cutlets on rice so you can retain your honor. Now face your sins!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“什么借口都没用！条例没了以后的现在，过渡期间的取缔必须要强化才行！看到同情的份上，我可以请你吃猪排饭，你就好好思过悔改吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「什麼藉口都沒用！條例沒了以後的現在，過渡期間的取締必須要強化才行！看到同情的份上，我可以請妳吃豬排飯，妳就好好思過悔改吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00021",
		linknext = "0103_00023",
		line = 310,
	},
	["0103_00023"] = {
		{"se", id=0, loop=0, file="se_a072"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Senba ignores Misaki, who is clinging to her in tears, and quickly leaves us in the jail cell.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管美岬的哭诉，仙波同学留我们在牢房后走了出去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管美岬的哭訴，仙波同學留我們在牢房後走了出去。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00022",
		linknext = "0103_00024",
		line = 321,
	},
