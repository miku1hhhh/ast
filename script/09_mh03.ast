			},
			[4999] = {
				{"transitiontime", time=300, timestamp=28, delay2=5000},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0830", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I wish I could have been your rock like Nanase was. Maybe I am jealous after all. I didn’t know anything, and I couldn’t do anything...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我也想像奈奈濑同学一样，成为帮助你的力量⋯⋯怎么说呢，有点不甘心。我什么都不知道，也什么都做不了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我也想像奈奈瀨同學一樣，成為幫助你的力量⋯⋯怎麼說呢，有點不甘心。我什麼都不知道，也什麼都做不了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00160",
		linknext = "0103_00162",
		line = 2344,
	},
	["0103_00162"] = {
