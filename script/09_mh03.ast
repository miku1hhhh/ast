				},
			},
		},
		linkback = "0103_00064",
		linknext = "0103_00066",
		line = 1016,
	},
	["0103_00066"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00206", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=6},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I used to get bullied pretty bad back when I lived here on the island...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我⋯⋯从很久以前就在这岛上的时候⋯⋯曾经被霸凌过。”",
