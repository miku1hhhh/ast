		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A big smile lights up Misaki’s face, which makes me smile too.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看着美岬满脸笑容，我也跟着笑了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看著美岬滿臉笑容，我也跟著笑了。",
