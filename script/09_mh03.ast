	["0103_00165"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s like if some other guy supported Misaki when she went through major body image issues.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当我发现美岬对自己的体型在意到有点病态时，若那个时候不是我在她身旁支持着她的话──",
					{"rt2"},
				},
			},
			tw = {
				{
					"當我發現美岬對自己的體型在意到有點病態時，若那個時候不是我在她身旁支持著她的話──",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00164",
		linknext = "0103_00166",
		line = 2393,
	},
	["0103_00166"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Of course, I’d be thankful for it, but I would also wish that I could have been the one to be her pillar of support instead.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当然我想我会感激那个人──但也一定会想要自己就是那个人成为支撑她的力量。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當然我想我會感激那個人──但也一定會想要自己就是那個人成為支撐她的力量。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00165",
		linknext = "0103_00167",
		line = 2403,
	},
