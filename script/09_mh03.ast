		},
		text = {
			vo = {
				{"vo", file="misaki0836", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“A lot has happened with you and Nanase, and you fucked a lot of people for my sake... I’m sure you had to do a lot of things you didn’t want to.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“和奈奈濑同学发生这么多事，又为了我和很多人做爱⋯⋯我想其中一定有你不情愿、你讨厌的事吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「和奈奈瀨同學發生這麼多事，又為了我和很多人做愛⋯⋯我想其中一定有你不情願、你討厭的事吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00179",
		linknext = "0103_00181",
		line = 2580,
	},
	["0103_00181"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00103", file3="misaki_01m_00308", path=":fg/misaki_01m/", id=6, lv=6, head="misaki_01m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0837", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“But... I love you as you are now, all that stuff included. Please cherish all of it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“但是⋯⋯我最喜欢经历这些过后现在的淳之介君了⋯⋯不管什么事都要好好珍惜。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「但是⋯⋯我最喜歡經歷這些過後現在的淳之介君了⋯⋯不管什麼事都要好好珍惜。」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00180",
		linknext = "0103_00182",
		line = 2595,
	},
	["0103_00182"] = {
