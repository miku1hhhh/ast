		line = 1110,
	},
	["0103_00074"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I was never able to stand up for myself back then.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那时的我，最后依然无力[|反击。]",
