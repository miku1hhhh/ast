	["0103_00040"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The pork is soft with Misaki’s saliva. The savory juices seep out and fill my mouth.",
					{"rt2"},
				},
			},
			cn = {
				{
					"带有美岬唾液的猪排，在嘴中能感觉到它的软嫩，溢出的肉汁那美味充满口腔。",
					{"rt2"},
				},
			},
			tw = {
				{
					"帶有美岬唾液的豬排，在嘴中能感覺到它的軟嫩，溢出的肉汁那美味充滿口腔。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00039",
		linknext = "0103_00041",
		line = 622,
	},
	["0103_00041"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her face fills my field of vision as I eat the masticated mixture. A refreshing scent like dewy summer grass wafts into my nostrils.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一边吃着猪排一边看着美岬，仿佛飘着夏天青草般的清香骚弄着鼻子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一邊吃著豬排一邊看著美岬，彷彿飄著夏天青草般的清香騷弄著鼻子。",
					{"rt2"},
				},
			},
		},
