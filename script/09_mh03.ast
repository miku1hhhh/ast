	},
	["0103_00185"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The little boy and girl who used to walk downtrodden under the heavy burden of their complexes are no more.",
					{"rt2"},
				},
			},
			cn = {
				{
					"过去总是苦于自卑情结的少年少女已不复在。",
					{"rt2"},
				},
			},
			tw = {
				{
					"過去總是苦於自卑情結的少年少女已不復在。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00184",
		linknext = "0103_00186",
		line = 2642,
	},
	["0103_00186"] = {
