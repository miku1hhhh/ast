		line = 113,
	},
	["0103_00010"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For the day I messed up. The day I made her cry.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了那一天犯下的过错。惹她哭的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了那一天犯下的過錯。惹她哭的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00009",
		linknext = "0103_00011",
		line = 123,
	},
	["0103_00011"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And if possible, I want to thank her too.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后如果可以的话，再向她道谢──对，我想向她道谢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後如果可以的話，再向她道謝──對，我想向她道謝。",
					{"rt2"},
				},
			},
