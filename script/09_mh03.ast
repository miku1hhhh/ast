	},
	["0103_00077"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00211", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=6},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I got bullied so relentlessly, that I had come to hate everything. That’s when a lone girl reached out to me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“每天每天我被霸凌对一切感到厌恶的时候⋯⋯有一个女生向我伸出了援手。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「每天每天我被霸凌對一切感到厭惡的時候⋯⋯有一個女生向我伸出了援手。」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00076",
		linknext = "0103_00078",
		line = 1152,
	},
	["0103_00078"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00101", file3="nanase_01m_00308", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00211", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=4, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She told me with a kind smile that my complex was just my individuality.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那个女生说我一直在意的部分，其实也算是个性的一种，然后总是微笑以对。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那個女生說我一直在意的部分，其實也算是個性的一種，然後總是微笑以對。」",
					{"rt2"},
				},
			},
		},
