		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In the end, it turns out the SHO isn’t the police. We had been arrested and jailed without cause. So after we get a stern talking-to from Senba, she releases us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"之后，因为SHO也不是警察单位，所以并没有逮捕、拘留等这些权限。所以我们在仙波同学反覆谆谆教诲后获得释放。",
					{"rt2"},
				},
			},
			tw = {
				{
					"之後，因為SHO也不是警察單位，所以並沒有逮捕、拘留等這些權限。所以我們在仙波同學反覆諄諄教誨後獲得釋放。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00150",
		linknext = "0103_00152",
