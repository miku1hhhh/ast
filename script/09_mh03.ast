	["0103_00075"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The fact I was able to stand up to the NLNS with the crazy goal to crush the perverted law...",
					{"rt2"},
				},
			},
			cn = {
				{
					"后来我成立了NLNS，有勇无谋的就是想要摧毁变态条例──",
					{"rt2"},
				},
			},
			tw = {
				{
					"後來我成立了NLNS，有勇無謀的就是想要摧毀變態條例──",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00074",
		linknext = "0103_00076",
		line = 1130,
	},
	["0103_00076"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...is probably all thanks to the one girl who stuck by me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"──我想也许是因为当时有她在我身旁吧。",
