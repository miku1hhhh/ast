			vo = {
				{"vo", file="nanase0996", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“It’s fine, really. Hehe... But you know, I really feel like I’ve blown it all out of my system now. I feel a lot lighter.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“没在意啦。呵呵⋯⋯不过呢，总算是可以将全部抛诸脑外了⋯⋯觉得无比清爽啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「沒在意啦。呵呵⋯⋯不過呢，總算是可以將全部拋諸腦外了⋯⋯覺得無比清爽啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00143",
		linknext = "0103_00145",
		line = 2079,
	},
	["0103_00145"] = {
