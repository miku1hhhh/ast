	["0103_00080"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She furrows her brow and opens her mouth as if to say something. I wonder what she’s thinking behind those clear eyes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看似略带悲伤的眉毛一皱，好像在说什么一样的张开了嘴──她那双清澈的眼里，现在照映着的是什么呢。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看似略帶悲傷的眉毛一皺，好像在說什麼一樣的張開了嘴──她那雙清澈的眼裡，現在照映著的是什麼呢。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00079",
		linknext = "0103_00081",
		line = 1190,
	},
	["0103_00081"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00208", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But I did something terrible to that girl. Even though she helped me so much, I cruelly betrayed her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是我却对那个女生做了很过分的事⋯⋯对帮助过我的女生⋯⋯我背叛了她而且是用最糟的方式。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是我卻對那個女生做了很過分的事⋯⋯對幫助過我的女生⋯⋯我背叛了她而且是用最糟的方式。」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00080",
		linknext = "0103_00082",
		line = 1202,
	},
	["0103_00082"] = {
