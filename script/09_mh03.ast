	["0103_00126"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00101", file5="nanase_02m_00515", path=":fg/nanase_02m/", id=4, lv=4, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-5, y=-5},
