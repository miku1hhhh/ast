		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s a bit cliché, but I think the best word for the feeling washing over me is “relief.”",
					{"rt2"},
				},
			},
			cn = {
				{
					"一句话，太好了──虽然是陈腔滥调，但却是能最表达我的感觉的一句话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一句話，太好了──雖然是陳腔濫調，但卻是能最表達我的感覺的一句話。",
					{"rt2"},
				},
