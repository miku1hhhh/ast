		{"extrans", sync=0, time=300},
		{"fg", file="misaki_02f_00001", file1="misaki_02f_00101", file2="misaki_02f_00225", path=":fg/misaki_02f/", id=30, ch="美岬", lv=18, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0806", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Sob sob... I can’t believe the pigs have thrown us in the pig pen... I’m so sorry, Junnosuke...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“呜呜呜⋯⋯猪猪最终还是被关进猪圈了啦⋯⋯淳之介同学，对不起⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗚嗚嗚⋯⋯豬豬最終還是被關進豬圈了啦⋯⋯淳之介同學，對不起⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00023",
		linknext = "0103_00025",
		line = 382,
	},
	["0103_00025"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00208", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, I’m as shocked as you about this. Who knew you needed a license to drive?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不⋯⋯无照驾驶，我也没想到啊。”",
