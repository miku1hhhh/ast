	["0103_00043"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Our tongues intertwine, each savoring the meaty morsel in tandem. The dissonance between taste, sight, and smell intoxicates me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"享受两舌交缠与猪排带来的美味，味觉和视觉与嗅觉无法连成一气，这让我的脑中感到一阵酥麻。",
					{"rt2"},
				},
			},
			tw = {
				{
					"享受兩舌交纏與豬排帶來的美味，味覺和視覺與嗅覺無法連成一氣，這讓我的腦中感到一陣酥麻。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00042",
		linknext = "0103_00044",
		line = 654,
	},
	["0103_00044"] = {
		{"text"},
		text = {
