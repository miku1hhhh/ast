			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Huh? Why? I’m actually following the speed limit for once! We need to meet up with Nanase.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“什么？怎么样吗！我可是很难得的有遵守法定速度呢！我们要去见奈奈濑同学！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「什麼？怎麼樣嗎！我可是很難得的有遵守法定速度呢！我們要去見奈奈瀨同學！」",
					{"rt2"},
				},
