					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I planned to take this to my grave, but you had to come out of the blue and remind me...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“本来是想把这件事带进坟墓里的⋯⋯没想到竟会在这种时候⋯⋯”",
