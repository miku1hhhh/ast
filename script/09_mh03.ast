	["0103_00014"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00101", file2="misaki_01f_00222", path=":fg/misaki_01f/", id=30, ch="美岬", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=16},
		{"text"},
		text = {
