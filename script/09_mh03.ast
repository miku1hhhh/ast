	["0103_00068"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00211", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=6},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Every day people would point their fingers at me and say my wiener was so big it’s disgusting.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“他们说我鸡鸡太大真令人恶心⋯⋯每一天都在背后对我指指点点。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「他們說我雞雞太大真令人噁心⋯⋯每一天都在背後對我指指點點。」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00067",
		linknext = "0103_00069",
		line = 1055,
	},
