			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“You say that a lot. We went to the same school, so we probably passed by each other at some point, but I didn’t exactly stand out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
