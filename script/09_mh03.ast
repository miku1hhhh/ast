	},
	["0103_00026"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00101", file2="misaki_01f_00225", path=":fg/misaki_01f/", id=30, ch="美岬", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0807", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“We’ve always taken it being okay for granted... Sob... What should we do? We still have to meet Nanase.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“一直以来都是这样开的呀⋯⋯呜呜，明明非见奈奈濑同学不可的说⋯⋯这下怎么办才好⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「一直以來都是這樣開的呀⋯⋯嗚嗚，明明非見奈奈瀨同學不可的說⋯⋯這下怎麼辦才好⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00025",
		linknext = "0103_00027",
		line = 407,
	},
	["0103_00027"] = {
