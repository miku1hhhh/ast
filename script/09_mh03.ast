			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“你说的我完全听不懂⋯⋯你们平常到底都在玩什么把戏啊⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「你說的我完全聽不懂⋯⋯你們平常到底都在玩什麼把戲啊⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00127",
		linknext = "0103_00129",
		line = 1812,
	},
	["0103_00129"] = {
