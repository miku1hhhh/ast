	},
	["0103_00073"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It was horrible. But I couldn’t do anything about it... I even took it out on Asa sometimes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以一直很痛苦⋯⋯但是又束手无策⋯⋯总是迁怒麻沙酱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以一直很痛苦⋯⋯但是又束手無策⋯⋯總是遷怒麻沙醬。」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00072",
