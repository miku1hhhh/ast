		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The chewed-up pork cutlet passes from her lips to mine.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从美岬叠上来的唇中，猪排送了过来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從美岬疊上來的唇中，豬排送了過來。",
