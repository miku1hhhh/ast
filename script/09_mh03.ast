				{"transitiontime", time=300, timestamp=9, delay2=4500},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0972", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I happened to see you two getting dragged to the slammer and wound up following you in a panic. Sigh... There’s no more perverted law, so what were you two even doing?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我刚好看到淳之介同学和你被带走啊。所以才慌慌张张地跟了过来。唉⋯⋯已经没有变态条例了还这样⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我剛好看到淳之介同學和妳被帶走啊。所以才慌慌張張地跟了過來。唉⋯⋯已經沒有變態條例了還這樣⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00048",
		linknext = "0103_00050",
		line = 791,
	},
	["0103_00050"] = {
