		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0799", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Engine, ready! Safety, check! Junnosuke by my side, check!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“引擎没问题！安全确认过关！旁边淳之介同学也坐好了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「引擎沒問題！安全確認過關！旁邊淳之介同學也坐好了！」",
					{"rt2"},
				},
			},
		},
		linknext = "0103_00002",
		line = 28,
	},
	["0103_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aikaze—Our trusty pal who sank to the bottom of the ocean during our escape from SHO headquarters after the sexual mayhem broke out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"爱风──因做爱骚动而爆炸的SHO总部逃出来时，沉入海底的我的好伙伴。",
					{"rt2"},
				},
			},
			tw = {
				{
					"愛風──因做愛騷動而爆炸的SHO總部逃出來時，沈入海底的我的好夥伴。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00001",
		linknext = "0103_00003",
		line = 38,
	},
	["0103_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I thought she would rust at the bottom of the sea, but through my devotion, I managed to find her sunk wreckage. With the help of old man Kenzo, I successfully salvaged her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我以为它就会沉在海底然后慢慢生锈──后来靠着我对它的爱，找到了它沉没的点，靠着健藏老先生们的帮助而打捞成功。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我以為它就會沈在海底然後慢慢生銹──後來靠著我對它的愛，找到了它沈沒的點，靠著健藏老先生們的幫助而打撈成功。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00002",
		linknext = "0103_00004",
		line = 48,
	},
	["0103_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Afterward, I did more modifications to make her engines roar again. Revived and reformed Aikaze Mk. III.",
					{"rt2"},
				},
			},
			cn = {
				{
					"后来为了让它再次动起来而进行大幅改造后，它就以爱风改二之姿复活了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"後來為了讓它再次動起來而進行大幅改造後，它就以愛風改二之姿復活了。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00003",
		linknext = "0103_00005",
		line = 58,
	},
	["0103_00005"] = {
		{"fg", file="misaki_01f_00001", file1="misaki_01f_00101", file3="misaki_01f_00310", path=":fg/misaki_01f/", id=30, ch="美岬", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=16},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0800", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Junnosuke, are you ready to have that talk with Nanase?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“淳之介同学！你有做好心理准备向奈奈濑同学坦白了吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「淳之介同學！你有做好心理準備向奈奈瀨同學坦白了嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00004",
		linknext = "0103_00006",
		line = 71,
	},
	["0103_00006"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file3="jun_01f_00302", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. Ready as ever.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊啊──那当然！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊啊──那當然！」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00005",
