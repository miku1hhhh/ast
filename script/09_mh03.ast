	["0103_00063"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There’s no doubt that I have her to thank for helping me become who I am today. I’ve always wanted to tell her that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"之所以有现在的我，无疑是因为过往有她在的关系──我一直都想和她说这件事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"之所以有現在的我，無疑是因為過往有她在的關係──我一直都想和她說這件事。",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00062",
