				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It feels as if I’m eating Misaki herself—a thought that is indescribably arousing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就好像是我在品尝着美岬一样──这股无法形容的兴奋。",
