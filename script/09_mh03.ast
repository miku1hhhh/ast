					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Nahaha... I guess I am a bit jealous. I’m green with envy at her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“噗哈哈⋯⋯这样说可能真的是吃醋。我在嫉妒奈奈濑同学。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「噗哈哈⋯⋯這樣說可能真的是吃醋。我在嫉妒奈奈瀨同學。」",
