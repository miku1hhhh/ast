			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「本來是想把這件事帶進墳墓裡的⋯⋯沒想到竟會在這種時候⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00125",
		linknext = "0103_00127",
		line = 1785,
	},
	["0103_00127"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00211", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I had a flashback when I tried to kiss Misaki wearing a paper bag over her face with a picture of you on it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“美岬那时头戴着贴了奈奈濑同学照片的纸袋，然后我要亲过去的时候，突然记忆涌现──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「美岬那時頭戴著貼了奈奈瀨同學照片的紙袋，然後我要親過去的時候，突然記憶湧現──」",
					{"rt2"},
				},
			},
		},
		linkback = "0103_00126",
		linknext = "0103_00128",
		line = 1797,
	},
	["0103_00128"] = {
		{"fg", file="nanase_01m_00002", file1="nanase_01m_00102", file5="nanase_01m_00513", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-5, y=-5},
