			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Really? I thought these looked pretty spiffy. I’d really like one.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“我是觉得蛮潮的啊⋯⋯这件我也很想要。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「我是覺得蠻潮的啊⋯⋯這件我也很想要。」",
					{"rt2"},
				},
			},
		},
