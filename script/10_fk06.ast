		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0615", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“I think Tachibana wants to act cool in front of Fumino, so he can’t risk asking to make out or anything.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“橘君在文乃面前太会装帅了，所以没办法顺利的调情吧⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「橘君在文乃面前太會裝帥了，所以沒辦法順利的調情吧⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00043",
		linknext = "0113_00045",
		line = 834,
	},
	["0113_00045"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file3="rei_02m_00311", path=":fg/rei_02m/", id=22, lv=22, head="rei_02m", ch_origin="礼", ch="礼22", mw="mw", sync=0, mode=3, x=-605, y=-5},
