			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yes! Well done, Jun! You’ve really... Oh. You’ve grown up so much. It looks like I’m not needed anymore!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“没错，淳好了不起⋯⋯！自己采取行动⋯⋯啊，你也变得如此成熟了吗⋯⋯已经不再需要我了嘛⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「沒錯，淳好了不起⋯⋯！自己採取行動⋯⋯啊，你也變得如此成熟了嗎⋯⋯已經不再需要我了嘛⋯⋯！」",
					{"rt2"},
				},
			},
		},
