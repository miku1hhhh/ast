			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I can see all kinds of people from up here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“在这个地方⋯⋯我看过各种各样的人⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「在這個地方⋯⋯我看過各種各樣的人⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_01236",
		linknext = "0113_01238",
		line = 17660,
	},
	["0113_01238"] = {
		{"fg", mode=-1, id=30},
		{"facehide"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1045", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Happy people, excited people, joyful people. And even confused people, troubled people, hurting people. The whole gambit.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“开心的、快乐的、高兴的⋯⋯还有迷惘的、困扰的、痛苦的⋯⋯真的是各种类型都有。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「開心的、快樂的、高興的⋯⋯還有迷惘的、困擾的、痛苦的⋯⋯真的是各種類型都有。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_01237",
		linknext = "0113_01239",
		line = 17674,
	},
	["0113_01239"] = {
		{"cgdel", id=13, lv=13, time=0, alphadel=1},
		{"fg", mode=-1, id=14, ch="文乃14", ch_origin="文乃", lv=14, time=0, sync=0},
