		{"fg", file="fumino_01m_00007", file1="fumino_01m_00101", file2="fumino_01m_00220", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
