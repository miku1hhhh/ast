	},
	["0113_01285"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="fcg03010102", x=-45, y=-97.5, path=":cg/fcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1055", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Yes, that’s a good idea. Let’s try to live our life together, ordinarily and happily.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“嗯⋯⋯好。为了我们的日常生活⋯⋯能够再更自然而然地幸福。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「嗯⋯⋯好。為了我們的日常生活⋯⋯能夠再更自然而然地幸福。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_01284",
		linknext = "0113_01286",
		line = 18266,
	},
	["0113_01286"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’m sure that’s what they’ve been trying to tell me all this time.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我想她们想表达的──就是这么回事吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我想她們想表達的──就是這麼回事吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_01285",
		linknext = "0113_01287",
		line = 18276,
	},
