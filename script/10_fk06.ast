		{"fg", file="kouki_01f_00001", file1="kouki_01f_00101", file2="kouki_01f_00202", path=":fg/kouki_01f/", id=30, ch="光姫", lv=23, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0198", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Hi, I’m Kouki Senba, and I’ll be your guide on today’s ‘Ex-squid-it Underwater Adventure!’. I’ll make sure to show you all the comforts of the deep sea!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"‘接下来是我仙波光姬来为大家进行“魅惑鱼群派对”的导览⋯⋯我会带领大家前往心旷神怡的深海世界⋯⋯’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"『接下來是我仙波光姬來為大家進行“魅惑魚群派對”的導覽⋯⋯我會帶領大家前往心曠神怡的深海世界⋯⋯』",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00564",
		linknext = "0113_00566",
		line = 8733,
	},
	["0113_00566"] = {
