		{"fg", file="mizuhiki_01m_00002", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00214", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=21, lv=21, head="mizuhiki_01m", ch_origin="水引", ch="水引21", mw="mw", sync=0, time=200, rule="eff_009_00000", a_chr60=1, mode=3, x=595, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0624", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Tachibana is a virgin. And as you know, virgins are all delusional. This is total classic date fantasy of them to run into a Chad and fight him off. I’m sure he’s dreamt of this day over and over!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“说到橘君就想到处男，说到处男就想到妄想⋯⋯说到约会妄想的话，就是要被小混混扯上关系然后打跑他们吧。橘君应该也有好几次幻想过这样的剧情才对。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「說到橘君就想到處男，說到處男就想到妄想⋯⋯說到約會妄想的話，就是要被小混混扯上關係然後打跑他們吧。橘君應該也有好幾次幻想過這樣的劇情才對。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00347",
