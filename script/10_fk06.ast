			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Look, Fumino. We want to do this for you guys. That’s why we’re busting our asses right now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“听好了，文乃。大家都想为你们俩做点什么啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「聽好了，文乃。大家都想為妳們倆做點什麼啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00073",
