		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I feel her arm tighten around mine.",
					{"rt2"},
				},
			},
			cn = {
				{
					"手腕上的力道加深。",
					{"rt2"},
