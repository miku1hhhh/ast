		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1938", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I, Touka Reizeiin, and Misaki shall be the Cheer Squad. As in, we’ll be cheering you all on.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我想为她们加油，啦啦队就由美岬同学和我、冷泉院桐香来担当吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我想為她們加油，啦啦隊就由美岬同學和我、冷泉院桐香來擔當吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00056",
