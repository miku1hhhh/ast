			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Why would you go and tell her like that? Now they’ve got the upper hand on us NLNS girls. We could have gotten closer to Darling.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“为什么礼酱要说出来？难得可以比NLNS的大家还占上风，还要强的说。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「為什麼禮醬要說出來？難得可以比NLNS的大家還佔上風，還要強的說。」",
					{"rt2"},
				},
			},
