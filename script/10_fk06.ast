			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Wow! You sound just like him!♪ Amazing! Haha! Good girl, good girl!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“很会模仿嘛♪厉害呀嗯厉害呀嗯。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「很會模仿嘛♪厲害呀嗯厲害呀嗯。」",
					{"rt2"},
				},
