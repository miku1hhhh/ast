	["0113_01334"] = {
		{"bgm", file="bgm27", vol=100},
		{"fgact", ch="麻沙音3", id=3, lv=3, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If the two of us spend all our time together, there will probably be more times like this in the future.",
					{"rt2"},
				},
			},
			cn = {
				{
					"两人过生活的话，未来一定也会有这样的时候吧。",
