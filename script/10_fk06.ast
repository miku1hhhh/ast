	["0113_00351"] = {
		{"fg", file="asane_02m_00002", file1="asane_02m_00102", file2="asane_02m_00214", path=":fg/asane_02m/", id=23, lv=23, head="asane_02m", ch_origin="麻沙音", ch="麻沙音23", mw="mw", sync=0, mode=3, x=-5, y=-5},
