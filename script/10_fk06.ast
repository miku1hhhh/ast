		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"You can’t not get excited when coins, smoke bombs, handguns, katanas and chairs are being thrown around right in front of you.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也是啦，这么近距离的看到硬币和烟火，另外还有手枪以及日本刀，甚至是丢椅子攻击，当然会很嗨。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也是啦，這麼近距離的看到硬幣和煙火，另外還有手槍以及日本刀，甚至是丟椅子攻擊，當然會很嗨。",
					{"rt2"},
				},
			},
		},
