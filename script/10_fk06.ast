		{"text"},
		text = {
			vo = {
				{"vo", file="rei2387", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Then we’ll just have to go the extra mile. Let’s give these lovebirds the best date and make out session ever!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那么，就让我们来帮助他吧──！这对新鲜情侣，我们帮她们来场最棒的约会，还有让她们好好的调情当作礼物送给她们吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那麼，就讓我們來幫助他吧──！這對新鮮情侶，我們幫她們來場最棒的約會，還有讓她們好好的調情當作禮物送給她們吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00044",
		linknext = "0113_00046",
		line = 849,
	},
