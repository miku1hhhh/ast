		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2253", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“But like, Fumino, shouldn’t you just like ask him yourself? That way you’ll know for sure.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“可是，这种不是应该要去问本人吗？那才是最快最正确的呀。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「可是，這種不是應該要去問本人嗎？那才是最快最正確的呀。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00015",
		linknext = "0113_00017",
