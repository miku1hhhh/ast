				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼⋯⋯俗氣！？這件衣服嗎──！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_01321",
		linknext = "0113_01323",
		line = 18909,
	},
	["0113_01323"] = {
		{"fg", file="schubert_01m_00002", file1="schubert_01m_00102", file2="schubert_01m_00205", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=11, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0414", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Junnosuke, I’m speaking to you as a friend. Even the shirt you’re wearing now is atrocious. Look, it even says so in my database.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“淳之介，身为朋友给你忠告⋯⋯你现在穿的这件也相当俗气，我的资料库中如此显示着⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「淳之介，身為朋友給你忠告⋯⋯你現在穿的這件也相當俗氣，我的資料庫中如此顯示著⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_01322",
		linknext = "0113_01324",
		line = 18923,
	},
	["0113_01324"] = {
		{"fg", file="mizuhiki_01m_00002", file1="mizuhiki_01m_00102", file2="mizuhiki_01m_00209", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=14, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
