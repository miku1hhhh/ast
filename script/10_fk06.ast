			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「文乃別幫著說話了，這樣只會顯得更悲哀呀⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00067",
		linknext = "0113_00069",
		line = 1276,
	},
	["0113_00069"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file3="rei_02m_00316", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
