			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Gotcha. Hmm, her usual kimono will peg her as the Horny Joan of Arc immediately. We’ll need something else, right, Rei?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
