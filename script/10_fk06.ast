		text = {
			vo = {
				{"vo", file="schubert0408", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Exactly! Making out and fooling around is great and all, but they’re just stepping stones on the path to S.E.X.! If he ain’t getting horny, it’s boring! So, I’ve prepared a little something extra!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“没错！变态和调情虽然不一样，但是最后终点都是SEX！也就是没有让人心痒难耐的话就没有意义了！所以，我们准备的是～～”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「沒錯！變態和調情雖然不一樣，但是最後終點都是SEX！也就是沒有讓人心癢難耐的話就沒有意義了！所以，我們準備的是～～」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00574",
		linknext = "0113_00576",
		line = 8906,
	},
	["0113_00576"] = {
		{"fg", file="kouki_01f_00001", file1="kouki_01f_00103", file2="kouki_01f_00207", path=":fg/kouki_01f/", id=30, ch="光姫", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=23},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0199", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Please look to your left! Hehe. Here is a group of rays. Their white, moist mouths open and shut, open and shut. Just gobbling up that sea water. Yes, look very closely❤”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"‘请看左手边⋯⋯呵呵，是魟鱼⋯⋯魟鱼的鱼群来啰⋯⋯又白又丰厚的嘴巴，啪嗒啪嗒的动着⋯⋯在看我们这边了喔⋯⋯",
					{"gaiji", text="①"},
					"’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"『請看左手邊⋯⋯呵呵，是魟魚⋯⋯魟魚的魚群來囉⋯⋯又白又豐厚的嘴巴，啪嗒啪嗒的動著⋯⋯在看我們這邊了喔⋯⋯",
					{"gaiji", text="①"},
					"』",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00575",
		linknext = "0113_00577",
		line = 8919,
	},
	["0113_00577"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00211", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=24, lv=24, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト24", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0409", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“You may ask why this tour is so popular! That is because Senba’s the guide! She provides such sensuous, hypnotic commentary!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“为什么这个水上行程会这么有人气啊！有一说是因为仙波不知为何只有这个导览时会用很情色的方式解说的关系啊！也可能说是她下了催眠还什么的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「為什麼這個水上行程會這麼有人氣啊！有一說是因為仙波不知為何只有這個導覽時會用很情色的方式解說的關係啊！也可能說是她下了催眠還什麼的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00576",
		linknext = "0113_00578",
		line = 8934,
	},
	["0113_00578"] = {
