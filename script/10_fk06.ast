		{"fgact", ch="礼9", id=9, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2389", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hold on, let me set this straight. Normal clothes! I don’t mean T-shirts with weird sayings or surrealistic prints on them!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“先说好啰，我说的是普通的衣服喔⋯⋯！？胸口那边印有奇怪字样或是奇怪图样的不是那种喔⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「先說好囉，我說的是普通的衣服喔⋯⋯！？胸口那邊印有奇怪字樣或是奇怪圖樣的不是那種喔⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00062",
		linknext = "0113_00064",
		line = 1196,
	},
	["0113_00064"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", file2="nanase_01m_00214", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=595, y=-5},
