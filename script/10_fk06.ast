				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“But even if he is, I should at least...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“但是⋯⋯身为当事人却一点作为也没有的话⋯⋯”",
