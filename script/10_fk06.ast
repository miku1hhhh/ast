			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Huh? But it’s Misaki that’s always going on her weight. Oh where is she, anyways? In the bathroom?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“咦⋯⋯？每到这种时候，小美岬就会说“我才重呢”！，但怎么没出现啊？是去上厕所了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「咦⋯⋯？每到這種時候，小美岬就會說“我才重呢”！，但怎麼沒出現啊？是去上廁所了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00563",
		linknext = "0113_00565",
		line = 8712,
	},
	["0113_00565"] = {
