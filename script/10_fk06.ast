	},
	["0113_01240"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’ve heard this speech before from her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她的这段演说，我也有听过。",
