		{"fg", file="nanase_01m_00002", file1="nanase_01m_00102", file3="nanase_01m_00301", path=":fg/nanase_01m/", id=21, lv=21, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬21", mw="mw", sync=0, time=200, rule="eff_009_00000", a_chr60=1, mode=3, x=-605, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1059", path=":vo/", ch="nanase"},
