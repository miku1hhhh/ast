		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"People long for the company of others.",
					{"rt2"},
				},
			},
			cn = {
				{
					"人总是在寻求着谁。",
					{"rt2"},
				},
			},
			tw = {
				{
					"人總是在尋求著誰。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_01252",
		linknext = "0113_01254",
		line = 17915,
	},
	["0113_01254"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She knows that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她知道这件事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她知道這件事。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_01253",
		linknext = "0113_01255",
		line = 17925,
	},
	["0113_01255"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Which means she’s been searching for someone this whole time.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说，她自己也在寻求着谁。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說，她自己也在尋求著誰。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_01254",
		linknext = "0113_01256",
		line = 17935,
	},
	["0113_01256"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And now that she’s found him. She doesn’t need those special eyes anymore.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而找到那个谁的她──已经不再需要这眼睛了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而找到那個誰的她──已經不再需要這眼睛了。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_01255",
		linknext = "0113_01257",
		line = 17945,
	},
	["0113_01257"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Those divinely bestowed eyes that can see through anything.",
					{"rt2"},
