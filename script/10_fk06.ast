			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“To be treated this dismissively, this is not in my... never mind. Since it’s for my dear friend Junnosuke, I shall lend you all my services!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“大家的反应我的数据里没有⋯⋯不过为了友人淳之介，让我在这边脱胎换骨吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「大家的反應我的數據裡沒有⋯⋯不過為了友人淳之介，讓我在這邊脫胎換骨吧！」",
					{"rt2"},
				},
