	["0113_00517"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’ve been dying to go ever since I came to Seiran Island.",
					{"rt2"},
				},
			},
			cn = {
