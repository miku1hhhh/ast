	["0113_01276"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I have no fear in trusting you, Fumino. So then, let me support you, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我依赖着文乃无所畏惧──而文乃将会如此扶持着我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我依賴著文乃無所畏懼──而文乃將會如此扶持著我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_01275",
		linknext = "0113_01277",
		line = 18166,
	},
	["0113_01277"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If it means helping her, I’m sure just like today...",
					{"rt2"},
				},
			},
			cn = {
				{
					"如此一来，一定会像今天一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如此一來，一定會像今天一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_01276",
		linknext = "0113_01278",
		line = 18176,
	},
	["0113_01278"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My left hand will become useful once more.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我的左手也能够起到作用。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我的左手也能夠起到作用。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_01277",
		linknext = "0113_01279",
		line = 18186,
	},
	["0113_01279"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So, just loosen up a bit. Let some weight off your shoulders.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以就照字面说的⋯⋯我会稍微放松肩膀的力量的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以就照字面說的⋯⋯我會稍微放鬆肩膀的力量的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_01278",
		linknext = "0113_01280",
		line = 18198,
	},
	["0113_01280"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I say while hitting my left shoulder.",
					{"rt2"},
				},
			},
			cn = {
				{
					"敲敲还在肿胀的左肩，我如此说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"敲敲還在腫脹的左肩，我如此說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_01279",
		linknext = "0113_01281",
		line = 18208,
	},
	["0113_01281"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase said she wished for me and Fumino to be more open with each other.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑说过若我们能够是多少互相倾诉的关系会更好。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨說過若我們能夠是多少互相傾訴的關係會更好。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_01280",
		linknext = "0113_01282",
		line = 18218,
	},
	["0113_01282"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Touka also told me to ease up on myself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"桐香也说过要我稍微将肩膀的力量放松这样会更好。",
					{"rt2"},
				},
			},
			tw = {
				{
					"桐香也說過要我稍微將肩膀的力量放鬆這樣會更好。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_01281",
		linknext = "0113_01283",
		line = 18228,
	},
	["0113_01283"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They were all concerned about the two of us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我也是，她也是，总是顾虑着彼此的关系──",
					{"rt2"},
				},
			},
			tw = {
				{
					"我也是，她也是，總是顧慮著彼此的關係──",
					{"rt2"},
				},
			},
		},
		linkback = "0113_01282",
		linknext = "0113_01284",
		line = 18238,
	},
	["0113_01284"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Let’s not worry them any longer.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“今后我们不要再顾虑彼此了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「今後我們不要再顧慮彼此了。」",
