			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“There’s no way he’d be in the mood to make out with you in a shirt like that!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“你要是穿那种衣服的话，就算是气氛正好也完全不会让人想要跟你调情的喔⋯⋯！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「妳要是穿那種衣服的話，就算是氣氛正好也完全不會讓人想要跟妳調情的喔⋯⋯！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00063",
		linknext = "0113_00065",
		line = 1211,
	},
	["0113_00065"] = {
