			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry about that. I got swept up looking at the ocean.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“抱歉抱歉，一个不小心被海吸走注意后就发现我们分开了⋯⋯”",
