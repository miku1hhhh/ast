		{"fgact", ch="麻沙音22", id=22, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1600", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“What the hell?! My bro, the ultra-mega-virgin-at-heart, actually pulled it off? This wasn’t in my database!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“什么⋯⋯！？内心完全就是还没登大人的处男的哥哥竟然采取行动了⋯⋯这不在我的预料中啊⋯⋯！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「什麼⋯⋯！？內心完全就是還沒登大人的處男的哥哥竟然採取行動了⋯⋯這不在我的預料中啊⋯⋯！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00501",
		linknext = "0113_00503",
		line = 7748,
	},
	["0113_00503"] = {
		{"fg", file="tohka_01m_00002", file1="tohka_01m_00101", file3="tohka_01m_00309", path=":fg/tohka_01m/", id=21, lv=21, head="tohka_01m", ch_origin="桐香", ch="桐香21", mw="mw", sync=0, mode=3, x=-5, y=-5},
