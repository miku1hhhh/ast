	["0113_00533"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The moment we set sail is truly the most exciting.",
					{"rt2"},
				},
			},
			cn = {
				{
					"乘船出航这瞬间真让人内心激动啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"乘船出航這瞬間真讓人內心激動啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00532",
		linknext = "0113_00534",
		line = 8303,
	},
	["0113_00534"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But the sudden appearance of a school of beautifully colored fish is akin to discovering a precious gem.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且色彩鲜艳的鱼群突然出现更让人有种像是发现宝藏般的心情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且色彩鮮豔的魚群突然出現更讓人有種像是發現寶藏般的心情。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00533",
		linknext = "0113_00535",
		line = 8313,
	},
	["0113_00535"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can’t wait to look all of these up on an app later. My excitement’s at an all-time high.",
					{"rt2"},
				},
			},
			cn = {
				{
					"运用应用程式查看鱼的资料还能满足求知欲，简直让人情绪爆嗨的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"運用應用程式查看魚的資料還能滿足求知慾，簡直讓人情緒爆嗨的。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00534",
		linknext = "0113_00536",
		line = 8323,
	},
	["0113_00536"] = {
		{"text"},
		text = {
