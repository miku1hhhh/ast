					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“原来如此，那就推他一把吧⋯⋯橘君意外地很要面子呢──假装是聊天内容暗示他的话，他应该就会照做了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「原來如此，那就推他一把吧⋯⋯橘君意外地很要面子呢──假裝是聊天內容暗示他的話，他應該就會照做了。」",
					{"rt2"},
				},
			},
		},
