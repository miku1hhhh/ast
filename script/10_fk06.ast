			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Yeah! Now the thing about happy endings is you really gotta make sure you only gently squeeze and twist while you stroke or else—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“对呀，屁股的部分，括约肌使力的话，左边和右边的肉就会很结实，就是要成为那种关系！不然的话，两个人就会──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「對呀，屁股的部分，括約肌使力的話，左邊和右邊的肉就會很結實，就是要成為那種關係！不然的話，兩個人就會──」",
					{"rt2"},
				},
			},
		},
