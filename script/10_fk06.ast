			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「這次的釣魚行程，不是光只有看喔⋯⋯約會調情的最後大絕是什麼啊，那邊的淳之介的妹妹妳說說看！」",
					{"rt2"},
				},
			},
		},
