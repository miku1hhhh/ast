	["0113_01241"] = {
		{"fg", mode=-1, id=30},
		{"facehide"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1047", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Everyone is looking for someone. Whether they’re happy or sad. All of them are always searching.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“人总是在寻求着谁⋯⋯幸福的人，不幸的人都是⋯⋯一定随时都在寻找着某个人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「人總是在尋求著誰⋯⋯幸福的人，不幸的人都是⋯⋯一定隨時都在尋找著某個人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_01240",
		linknext = "0113_01242",
		line = 17721,
	},
	["0113_01242"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Seiran Island’s most famous girl sincerely pours her heart out to me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"青蓝岛上最有名的少女，真挚地敞开心胸，诉说着自己的心境。",
					{"rt2"},
				},
			},
			tw = {
				{
					"青藍島上最有名的少女，真摯地敞開心胸，訴說著自己的心境。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_01241",
		linknext = "0113_01243",
		line = 17731,
	},
	["0113_01243"] = {
		{"fg", mode=-1, id=30},
		{"facehide"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1048", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“So I used to pray. I prayed for the power to find who I was looking for. For eyes that could find what I was wishing for. And...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“所以，我许下愿望⋯⋯想要能够找到那个谁的力量⋯⋯想要能够找到所寻之物的眼睛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「所以，我許下願望⋯⋯想要能夠找到那個誰的力量⋯⋯想要能夠找到所尋之物的眼睛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_01242",
		linknext = "0113_01244",
		line = 17745,
	},
	["0113_01244"] = {
