	["0113_00102"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00101", file2="ran_01m_00201", file4="ran_01m_00401", path=":fg/ran_01m/", id=13, lv=13, head="ran_01m", alpha=0, ch_origin="蘭", ch="蘭13", mw="mw", sync=1, a_chr151=1, mode=3, x=595, y=-5},
