			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I don’t think that’s the kind of cheer we need now, Tokie. But wow, I didn’t think Darling could rise up to the challenge.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“桐香酱，他们不是你表现的那种感觉⋯⋯不过郁郁也觉得很意外呢，以为亲爱的没那个担当呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「桐香醬，他們不是妳表現的那種感覺⋯⋯不過郁郁也覺得很意外呢，以為親愛的沒那個擔當呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00503",
		linknext = "0113_00505",
		line = 7780,
	},
	["0113_00505"] = {
