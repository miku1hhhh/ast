			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Heh, heh. Well done, Tachibana. A t-shirt with a chopped-up salmon and a bangle that looks like it was sold on Fwish. No lady can resist this get-up!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“呵呵，真不愧是橘君呢⋯⋯银皮鲑鱼上衣配上很像在漏天买的银饰⋯⋯这样搭配不管哪个女生都能轻易弄到手⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「呵呵，真不愧是橘君呢⋯⋯銀皮鮭魚上衣配上很像在漏天買的銀飾⋯⋯這樣搭配不管哪個女生都能輕易弄到手⋯⋯！」",
					{"rt2"},
				},
			},
		},
