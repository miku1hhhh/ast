		{"fg", mode=-1, id=30},
		{"facehide"},
		{"fg", file="fumino_01l_00010", file1="fumino_01l_00101", file2="fumino_01l_00202", path=":fg/fumino_01l/", id=12, lv=12, head="fumino_01l", ch_origin="文乃", ch="文乃12", mw="mw", sync=0, mode=3, x=595, y=-1005},
		{"transitiontime", time=1000},
		{"cgact", file="cgact", id=11, act="移動", x=-5, y=245, time=40000, lv=11},
		{"fgact", ch="文乃12", id=12, act="移動", x=0, y=500, time=40000},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino1046", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“But what they all have in common is that they’re searching for someone else.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“但是这些人全都⋯⋯好像在寻找着谁一样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「但是這些人全都⋯⋯好像在尋找著誰一樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_01238",
