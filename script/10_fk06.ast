		{"fg", file="nanase_02m_00002", file1="nanase_02m_00102", file2="nanase_02m_00209", path=":fg/nanase_02m/", id=21, lv=21, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬21", mw="mw", sync=0, time=200, rule="eff_009_00000", a_chr60=1, mode=3, x=-605, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1058", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Huh. Looks like Jun is really into fishing and boats. He hasn’t said anything like that before. He only eats as much fish as the next person.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“咦，淳有这么喜欢船和鱼呀⋯⋯？好像没怎么听他提过⋯⋯鱼的料理也没看他怎么吃过⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「咦，淳有這麼喜歡船和魚呀⋯⋯？好像沒怎麼聽他提過⋯⋯魚的料理也沒看他怎麼吃過⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00518",
		linknext = "0113_00520",
		line = 8028,
	},
	["0113_00520"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00101", file3="ikuko_01m_00311", path=":fg/ikuko_01m/", id=22, lv=22, head="ikuko_01m", ch_origin="郁子", ch="郁子22", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="郁子22", id=22, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2267", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Hehe. He only shares it with the boys! I only learned about it through the FS’s information network, so I’ve been holding onto this juicy info for my own date with him someday.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“呵呵呵，因为这是只有对男生朋友才说的啊♪是郁郁用FS的情报网才得到的消息呢。本来是想着有一天邀他约会时派上用场的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「呵呵呵，因為這是只有對男生朋友才說的啊♪是郁郁用FS的情報網才得到的消息呢。本來是想著有一天邀他約會時派上用場的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00519",
		linknext = "0113_00521",
		line = 8043,
	},
	["0113_00521"] = {
