			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“这次的钓鱼行程，不是光只有看喔⋯⋯约会调情的最后大绝是什么啊，那边的淳之介的妹妹你说说看！”",
					{"rt2"},
