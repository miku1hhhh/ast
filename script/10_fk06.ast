		text = {
			vo = {
				{"vo", file="misaki1306", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“No, fucking around and making out are two totally different things. Calling out each other’s names lovingly, feeling each other’s assholes. That’s what pure love is about!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“色色和调情是不一样的！低声细语的叫着对方的名字，抚摸着彼此，碰着彼此的穴穴，这样才是热恋中的情侣呀！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「色色和調情是不一樣的！低聲細語的叫著對方的名字，撫摸著彼此，碰著彼此的穴穴，這樣才是熱戀中的情侶呀！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00042",
		linknext = "0113_00044",
		line = 812,
	},
	["0113_00044"] = {
