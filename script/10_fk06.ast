				},
			},
			cn = {
				{
					name = {"凛"},
					"“姐，他好俗喔。又没要他读太宰的书，还吹嘘勒。拿着腥啪客就像是典型的麻烦学生样，然后还在那边自我陶醉⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「姊，他好俗喔。又沒要他讀太宰的書，還吹噓勒。拿著腥啪客就像是典型的麻煩學生樣，然後還在那邊自我陶醉⋯⋯」",
					{"rt2"},
				},
			},
		},
