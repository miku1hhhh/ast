		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After the True Perverted Sex Law was put in place, it now has normal rides installed as well.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这边在真变态条例颁布以后，也设置了一些游乐设施，俨然已变成了大型主题乐园。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這邊在真變態條例頒布以後，也設置了一些遊樂設施，儼然已變成了大型主題樂園。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00189",
		linknext = "0113_00191",
		line = 3023,
	},
	["0113_00191"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s a great place to hang out—and I realize, I’ve never taken the time to try it out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说到玩这里是最适合的地方了。话说回来，我好像也没有好好玩过这里。",
