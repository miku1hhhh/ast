					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Oh. What’s that over there? On your ten o’clock. The fish in the water there. It’s long and thin.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“嗯⋯⋯在那边的是什么呢⋯⋯？10点钟的方向，在水里⋯⋯是细细长长的鱼呢⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「嗯⋯⋯在那邊的是什麼呢⋯⋯？10點鐘的方向，在水裡⋯⋯是細細長長的魚呢⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00557",
		linknext = "0113_00559",
		line = 8625,
	},
	["0113_00559"] = {
