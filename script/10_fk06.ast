					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "伯dori君"},
					"「還有花圈以及變態遊樂園8585倍享受道具，另外還有與我們Hamedori君一起擺出阿嘿顏的紀念照拍攝！」",
					{"rt2"},
				},
			},
		},
