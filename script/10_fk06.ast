		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Sorry, Fumino. My hand lost its grip before I could think. My left shoulder is still kind of stiff, it seems.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对不起呀，文乃，手比我想的还要使不上力⋯⋯我左边的肩膀好像还没恢复原状。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對不起呀，文乃，手比我想的還要使不上力⋯⋯我左邊的肩膀好像還沒恢復原狀。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00453",
		linknext = "0113_00455",
		line = 7063,
	},
