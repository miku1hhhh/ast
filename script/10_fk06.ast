	["0113_00556"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Then, as if to ease her own nerves, she makes herself smile.",
					{"rt2"},
				},
			},
			cn = {
				{
					"接着，像是要缓解紧张的心情，文乃摆出了笑脸。",
					{"rt2"},
				},
			},
			tw = {
				{
					"接著，像是要緩解緊張的心情，文乃擺出了笑臉。",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00555",
		linknext = "0113_00557",
