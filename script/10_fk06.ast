					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Virgins like him are totally weak to sappy dates, huh. We’ll handle it, hehe.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“处男就是王道类似这样的约会行程，他肯定会马上沦陷⋯⋯那就拜托你们安排啦⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「處男就是王道類似這樣的約會行程，他肯定會馬上淪陷⋯⋯那就拜託妳們安排啦⋯⋯！」",
					{"rt2"},
				},
			},
		},
