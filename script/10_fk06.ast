	},
	["0113_00051"] = {
		{"cgdel", id=25, lv=25, time=0, alphadel=1},
		{"fg", mode=-1, id=26, ch="文乃26", ch_origin="文乃", lv=26, time=0, sync=0},
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00201", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1936", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“All right, then, let’s divvy up our roles. Okay, representatives for NLNS and FS, Ikuko and Hinami, you two will plan the make out session.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“那么，我们就来决定谁要准备什么吧。我想想⋯⋯当天的调情招数安排交给NLNS和FS的纯情代表郁子以及雏见吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「那麼，我們就來決定誰要準備什麼吧。我想想⋯⋯當天的調情招數安排交給NLNS和FS的純情代表郁子以及雛見吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00050",
		linknext = "0113_00052",
		line = 993,
	},
	["0113_00052"] = {
		{"fg", mode=-1, id=8, ch="桐香8", ch_origin="桐香", lv=8, time=0, sync=0},
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file3="ikuko_02m_00308", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2257", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Leave it to me! It’s less exciting the more ordinary it is... So how about we aim for something more ‘extraordinary’?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“交给郁郁吧～～♪像一般日常的话就不会有紧张心扑通跳的感觉，约会就是要‘非日常’感吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「交給郁郁吧～～♪像一般日常的話就不會有緊張心撲通跳的感覺，約會就是要“非日常”感吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00051",
		linknext = "0113_00053",
		line = 1009,
	},
	["0113_00053"] = {
		{"fg", file="hinami_01m_00001", file1="hinami_01m_00101", file2="hinami_01m_00202", path=":fg/hinami_01m/", id=5, lv=5, head="hinami_01m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1010", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Extraordinary sounds extra fun! Then let’s have them start at different spots. Their hearts will be pounding once they finally meet!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“非日常感嘛！感觉很有趣耶！那么约会当天各自集合如何！？等对方来的时候很容易心扑通的跳嘛⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「非日常感嘛！感覺很有趣耶！那麼約會當天各自集合如何！？等對方來的時候很容易心撲通的跳嘛⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00052",
		linknext = "0113_00054",
		line = 1023,
	},
	["0113_00054"] = {
		{"fg", mode=-1, id=5, ch="ヒナミ5", ch_origin="ヒナミ", lv=5, time=0, sync=0},
		{"fg", mode=-1, id=10, ch="郁子10", ch_origin="郁子", lv=10, time=0, sync=0},
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00213", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1937", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Asane and Mizuhiki will be Special Advisors in charge of figuring out what he likes.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“前辈喜欢什么安排就交给我们来，特别顾问就由麻沙音酱和水引酱担当。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「前輩喜歡什麼安排就交給我們來，特別顧問就由麻沙音醬和水引醬擔當。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00053",
		linknext = "0113_00055",
		line = 1041,
	},
	["0113_00055"] = {
		{"fg", mode=-1, id=8, ch="桐香8", ch_origin="桐香", lv=8, time=0, sync=0},
		{"fg", file="asane_02m_00001", file1="asane_02m_00101", file2="asane_02m_00223", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
