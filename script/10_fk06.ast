		{"bg", id=20, file="bg22_1l_00000", x=-400, y=0, lv=20, path=":bg/", sync=0, time=200, rule="eff_009_00000", a_chr60=1, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="rei_02m_00002", file1="rei_02m_00101", file3="rei_02m_00306", path=":fg/rei_02m/", id=21, lv=21, head="rei_02m", ch_origin="礼", ch="礼21", mw="mw", sync=0, time=200, rule="eff_009_00000", a_chr60=1, mode=3, x=395, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2394", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You like it, Junnosuke? Today’s theme is ‘sunny’ and ‘mature’! It’s easy as cream pie to dress her up so cute.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“淳之介你觉得如何呢⋯⋯！今天的主题是‘盛装打扮’还有‘大人样’喔。毕竟可爱风对文乃来说太简单了──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「淳之介你覺得如何呢⋯⋯！今天的主題是“盛裝打扮”還有“大人樣”喔。畢竟可愛風對文乃來說太簡單了──」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00143",
		linknext = "0113_00145",
		line = 2367,
	},
	["0113_00145"] = {
		{"fg", file="nanase_02m_00002", file1="nanase_02m_00101", file2="nanase_02m_00203", path=":fg/nanase_02m/", id=22, lv=22, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬22", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase1049", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yeah, but just looking cute wouldn’t cut it, so we aged her up a bit so you can really feel how extraordinary today’s date will be.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那样的话开心的只有淳而已，所以要故意让文乃穿得成熟一点，让约会感出来，才会觉得是非日常──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那樣的話開心的只有淳而已，所以要故意讓文乃穿得成熟一點，讓約會感出來，才會覺得是非日常──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00144",
		linknext = "0113_00146",
		line = 2381,
	},
