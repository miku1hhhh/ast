		text = {
			vo = {
				{"vo", file="mizuhiki0614", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“They keep roasting you and yet you just keep at it, Misaki. Incredible. But I can’t say I don’t agree. You two do need to get more intimate with each other.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“畔同学被这样吐槽还没崩溃，真有你的⋯⋯不过，我也是这么觉得呢，你们两个应该再坦诚一点比较好呀。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「畔同學被這樣吐槽還沒崩潰，真有妳的⋯⋯不過，我也是這麼覺得呢，妳們兩個應該再坦誠一點比較好呀。」",
					{"rt2"},
				},
			},
		},
