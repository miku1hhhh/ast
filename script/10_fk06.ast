		{"fg", file="tohka_02m_00002", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=21, lv=21, head="tohka_02m", ch_origin="桐香", ch="桐香21", mw="mw", sync=0, time=200, rule="eff_009_00000", a_chr60=1, mode=3, x=-605, y=-5},
