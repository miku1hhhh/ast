				},
			},
			tw = {
				{
					name = {"水引"},
					"「橘君的事放心交給我們來安排⋯⋯呵呵呵，讓我們來幫她們安排一場深具青藍島風格的約會行程──！」",
					{"rt2"},
				},
			},
		},
