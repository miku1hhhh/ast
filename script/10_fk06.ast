			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yeah, he’s definitely that kind of virgin. Probs also fantasized about a shooter coming into school and taking him down all by himself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥是那方面的初学者⋯⋯就是上课时会将自己幻想的情节写下那种。幻想着有恐怖份子突然袭来，然后自己一个人将他们全部击倒⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥是那方面的初學者⋯⋯就是上課時會將自己幻想的情節寫下那種。幻想著有恐怖份子突然襲來，然後自己一個人將他們全部擊倒⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00350",
		linknext = "0113_00352",
		line = 5512,
	},
