	["0113_00502"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00102", file2="asane_01m_00209", path=":fg/asane_01m/", id=22, lv=22, head="asane_01m", ch_origin="麻沙音", ch="麻沙音22", mw="mw", sync=0, mode=3, x=595, y=-5},
