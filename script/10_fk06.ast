				},
			},
			tw = {
				{
					name = {"文乃"},
					"「對不起，對不起⋯⋯啊啊，我竟然對主人說出這樣的話⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_01327",
		linknext = "0113_01329",
		line = 18988,
	},
	["0113_01329"] = {
