	["0113_00569"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00101", file2="ikuko_01m_00214", path=":fg/ikuko_01m/", id=24, lv=24, head="ikuko_01m", ch_origin="郁子", ch="郁子24", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2269", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“This must just be fun for her. Kokie loves getting lots of people all worked up. She is pretty cute. Not as cute as me, of course.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“只是因为爱出风头吧。光姬酱只是喜欢被很多人围绕称赞的工作吧。反正她长得也好看，刚刚好不是吗？虽然还是比郁郁弱了点⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
