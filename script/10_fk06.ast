	["0113_00558"] = {
		{"fg", file="fumino_01l_00010", file1="fumino_01l_00101", file2="fumino_01l_00211", path=":fg/fumino_01l/", id=7, lv=7, head="fumino_01l", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
