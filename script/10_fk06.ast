		{"fgact", ch="蘭13", id=13, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0220", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Oh, isn’t that Tachibana? Top of the moaning to you! What are you doing here with coffee in hand?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“这不是橘君吗！早安啊！怎么在这里喝着咖啡呀？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「這不是橘君嗎！早安啊！怎麼在這裡喝著咖啡呀？」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00101",
		linknext = "0113_00103",
		line = 1847,
	},
	["0113_00103"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hanamaru? Heh, just reading my book. Dazai G-Spot’s ‘No Longer Hard’.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是花丸委员长啊⋯⋯哈，我正在看太宰茎治的‘阴茎失格’呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是花丸委員長啊⋯⋯哈，我正在看太宰莖治的“陰莖失格”呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00102",
		linknext = "0113_00104",
		line = 1859,
	},
	["0113_00104"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It’s about a man who suffers from impotence and keeps trying to make suicide-pacts with different women. In the end, he overdoses on Viagra. It’s so relatable.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为阳痿而苦，和许多女性殉情都未果，最后因为壮阳药中毒而死⋯⋯我对太宰非常感同身受呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為陽痿而苦，和許多女性殉情都未果，最後因為壯陽藥中毒而死⋯⋯我對太宰非常感同身受呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00103",
		linknext = "0113_00105",
		line = 1871,
	},
	["0113_00105"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00101", file2="ran_01m_00207", file4="ran_01m_00401", path=":fg/ran_01m/", id=13, lv=13, head="ran_01m", ch_origin="蘭", ch="蘭13", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0221", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Ah, yes. Published by Poonguin Books, right? A classic that rivals even Tits-n-Ass Souseki.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“啊啊，子宫文库出版的书。与高潮漱石先生齐名的经典名作。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「啊啊，子宮文庫出版的書。與高潮漱石先生齊名的經典名作。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00104",
		linknext = "0113_00106",
		line = 1886,
	},
	["0113_00106"] = {
