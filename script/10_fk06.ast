			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Not to brag but I’m quite confident we’d ruin any date we get involved with if we helped out. We’ll restrain ourselves this time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我不是在自夸，只要和我们扯到关系的话，约会行程一定会被破坏，我们有这样的自信⋯⋯所以我们会好好自律的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我不是在自誇，只要和我們扯到關係的話，約會行程一定會被破壞，我們有這樣的自信⋯⋯所以我們會好好自律的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00057",
		linknext = "0113_00059",
		line = 1110,
	},
	["0113_00059"] = {
