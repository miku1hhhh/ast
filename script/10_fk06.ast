		{"fgact", ch="ハメ11", id=11, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0590", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子", "ススドリくん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susudori"},
					"“Your prize is a FuckPass! It allows you to board rides as fast as any quickie! With this, you’ll be able to enjoy any of our lurid attractions in a jizzy!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝dori君"},
					"“作为纪念，园内任一游乐设施都能够瞬间做的啪啪走票券算给您！有这票券就能够啪啪地享受游乐设施了，恭喜。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲dori君"},
					"「作為紀念，園內任一遊樂設施都能夠瞬間做的啪啪走票券算給您！有這票券就能夠啪啪地享受遊樂設施了，恭喜。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00222",
		linknext = "0113_00224",
		line = 3463,
	},
	["0113_00224"] = {
