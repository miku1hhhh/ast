				},
			},
			en = {
				{
					"I can’t help but smile back as well.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而我也跟着笑容浮现。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而我也跟著笑容浮現。",
					{"rt2"},
