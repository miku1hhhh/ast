				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I felt like along the way I saw many faces resembling the NLNS and FS girls.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在游轮上我似乎有好几次看到了很像NLNS和FS的成员的脸孔。",
