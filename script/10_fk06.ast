		linknext = "0113_00529",
		line = 8186,
	},
	["0113_00529"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00211", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=26, lv=26, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト26", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0406", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“There’s a glass window at the bottom of this boat where you can see the fish. We’ve always wanted to try it out at least once, you see.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“这艘邮轮呢，船底的部分是玻璃，可以从这边观看鱼喔。我们之前有多想坐一次看看这样的船呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「這艘郵輪呢，船底的部分是玻璃，可以從這邊觀看魚喔。我們之前有多想坐一次看看這樣的船呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00528",
		linknext = "0113_00530",
		line = 8201,
	},
