		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And from today on, our happiness really will begin.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这样的话，我们就从今天开始。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這樣的話，我們就從今天開始。",
