				{"vo", file="rei2391", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Oh yeah, I gave my sister a bunch of clothes before when she’d always shove them back at me. I’m sure I still have ’em. Another chance to dress up a cutie, hee hee!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“好，之前送给妹妹被退回的衣服有很多⋯⋯！可以让可爱的女生穿上的话真是再好不过了⋯⋯嘿嘿嘿。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「好，之前送給妹妹被退回的衣服有很多⋯⋯！可以讓可愛的女生穿上的話真是再好不過了⋯⋯嘿嘿嘿。」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00068",
		linknext = "0113_00070",
		line = 1291,
	},
	["0113_00070"] = {
