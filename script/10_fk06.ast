			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“They’re fighting in such close quarters! If it were me, I’d take a step back and let off three covering shots. Then, after regrouping we’d go on a midrange offensive and—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“好激烈的近身战啊⋯⋯！如果是我的话，首先会把距离先拉开，接着为了掩护开三枪，让小队重整以后改进行中距离战⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「好激烈的近身戰啊⋯⋯！如果是我的話，首先會把距離先拉開，接著為了掩護開三槍，讓小隊重整以後改進行中距離戰⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0113_00280",
		linknext = "0113_00282",
		line = 4439,
	},
	["0113_00282"] = {
