	},
	["0113_00068"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", file3="nanase_01m_00306", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=595, y=-5},
