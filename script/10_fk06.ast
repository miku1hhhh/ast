		line = 19061,
	},
	["0113_01335"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But we’ll no longer hold back our thoughts.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，停止保持沉默吧。",
					{"rt2"},
