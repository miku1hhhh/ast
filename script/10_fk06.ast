	["0113_00564"] = {
		{"fg", file="hinami_02m_00002", file1="hinami_02m_00101", file2="hinami_02m_00212", path=":fg/hinami_02m/", id=23, lv=23, head="hinami_02m", ch_origin="ヒナミ", ch="ヒナミ23", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami1023", path=":vo/", ch="hinami"},
