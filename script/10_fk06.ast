	["0113_00394"] = {
		{"fg", file="fumino_01m_00010", file1="fumino_01m_00106", file2="fumino_01m_00228", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0827", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“If you keep interfering with our date, then you won’t be invited to our wedding!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“若是一直妨碍我们俩的约会的话，我们的结婚典礼就不叫你了⋯⋯！”",
