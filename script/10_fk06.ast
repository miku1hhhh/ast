			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯，也许一开始是那样没错⋯⋯不过因为刚刚的事，所以让淳有了些想法也说不定⋯⋯呵呵。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯，也許一開始是那樣沒錯⋯⋯不過因為剛剛的事，所以讓淳有了些想法也說不定⋯⋯呵呵。」",
					{"rt2"},
				},
			},
		},
