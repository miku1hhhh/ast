			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I’m so sorry. So terribly sorry. Oh, what terrible words I’ve said to you!”",
