	["0113_00568"] = {
		{"fg", file="rei_01m_00002", file1="rei_01m_00102", file2="rei_01m_00224", path=":fg/rei_01m/", id=23, lv=23, head="rei_01m", ch_origin="礼", ch="礼23", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2405", path=":vo/", ch="rei"},
			},
			ja = {
