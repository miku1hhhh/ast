				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Yes, that’s true. But, when I try to ask him that sort of thing, my face just... goes beet red.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“话是这样说没错⋯⋯但是，要是就这样直接问本人的话⋯⋯总觉得好害躁⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「話是這樣說沒錯⋯⋯但是，要是就這樣直接問本人的話⋯⋯總覺得好害躁⋯⋯」",
					{"rt2"},
				},
			},
		},
