				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You don’t have anything to apologize for, Nanase. Morning wood, hickeys and cream pies are a totally normal thing for couples to enjoy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不需要道歉喔，奈奈濑。若是情侣的话，一早就勃起、印上吻痕跟内射之类的事情都是很理所当然的。”",
					{"rt2"},
				},
			},
			tw = {
