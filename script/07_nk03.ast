				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Okay, I think we’re all done here. How you doing, Asa? ... Asa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
