					name = {"淳之介"},
					"“因为太在意奈奈濑了而搞得夜不能眠，忍不住就手淫起来了，我懂得……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為太在意奈奈瀨了而搞得夜不能眠，忍不住就手淫起來了，我懂得……！」",
					{"rt2"},
				},
