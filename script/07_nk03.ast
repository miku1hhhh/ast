					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我……因為淳說想做所以很開心……被觸摸的時候，就會變成……那種色情的感覺……」",
					{"rt2"},
				},
			},
		},
