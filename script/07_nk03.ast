	["0092_00056"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00102", file2="ran_01m_00208", file4="ran_01m_00401", path=":fg/ran_01m/", id=13, lv=13, head="ran_01m", ch_origin="蘭", ch="蘭13", mw="mw", sync=0, mode=3, x=-5, y=-5},
