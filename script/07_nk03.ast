	["0092_00115"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00216", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Dammit. No matter how much I practice, my art will never be able to capture how kind you are!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……可恶，就算我的绘画技术再好，也无法画出你内心的温柔啊……！”",
					{"rt2"},
				},
			},
			tw = {
