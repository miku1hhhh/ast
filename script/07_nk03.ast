	["0092_00449"] = {
		{"bgm", file="bgm31", vol=100},
		{"fg", file="asane_01m_00003", file1="asane_01m_00104", file2="asane_01m_00221", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=1, size=22.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1191", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Right now?! Ho-Hold up, I’m not ready for this! Not to say that it wouldn’t be a huge honor, but there’s a little voice in my head asking me if it’s really okay, and...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“现在开始！？等，怎么会，我都还没有心理准备耶！不对，倒不如说很荣幸可以加入你们，但脑子里又在想着是不是真的能参加。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「現在開始！？等，怎麼會，我都還沒有心理準備耶！不對，倒不如說很榮幸可以加入你們，但腦子裡又在想著是不是真的能參加。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00448",
		linknext = "0092_00450",
		line = 6322,
	},
	["0092_00450"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, we mean it. You’re my sister, after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只要我们两个都说好，不就好了嘛？因为你是我的妹妹啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「只要我們兩個都說好，不就好了嘛？因為你是我的妹妹啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00449",
		linknext = "0092_00451",
		line = 6334,
	},
	["0092_00451"] = {
		{"fg", file="asane_01m_00003", file1="asane_01m_00104", file2="asane_01m_00215", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1192", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“But I’d feel awkward getting in the middle of you two, and I know this is some kind of weird first step I probably shouldn’t take even though I kind of forced it you guys by being a brat and...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“但是我果然还是很在意要介入情侣之间嘛，即使这样你们还是愿意让烦人的我加入，但我真的不知道该不该踏出第一步。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「但是我果然還是很在意要介入情侶之間嘛，即使這樣你們還是願意讓煩人的我加入，但我真的不知道該不該踏出第一步。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00450",
		linknext = "0092_00452",
		line = 6349,
	},
	["0092_00452"] = {
