					name = {"礼"},
					"“怎么说呢，在遮掩起来之前，有什么想说说的吗，片桐你……有抱怨之类的……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「怎麼說呢，在遮掩起來之前，有什麼想說說的嗎，片桐你……有抱怨之類的……？」",
					{"rt2"},
