		{"fgact", ch="蘭13", id=13, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0192", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“No I’m serious, I’m looking for my younger sister! She didn’t come home before curfew last night. It’s morning now and there’s still no sign of her!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“才不是这样，我是在找我妹妹！最近总是过了门禁时间也不回家，今天甚至是到早上了还没回来呢……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「才不是這樣，我是在找我妹妹！最近總是過了門禁時間也不回家，今天甚至是到早上了還沒回來呢……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00055",
		linknext = "0092_00057",
		line = 743,
	},
	["0092_00057"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00102", file2="ran_01m_00215", file4="ran_01m_00401", path=":fg/ran_01m/", id=13, lv=13, head="ran_01m", ch_origin="蘭", ch="蘭13", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0193", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“I was sure Rin would have taken part in an event like this but I can’t find her anywhere. I’d like to think there’s nothing to worry about, but...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“想说是凛的话会参加这种活动，结果也没找到……！因为是那孩子的关系，想说不用太过担心啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「想說是凜的話會參加這種活動，結果也沒找到……！因為是那孩子的關係，想說不用太過擔心啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00056",
		linknext = "0092_00058",
		line = 758,
	},
	["0092_00058"] = {
