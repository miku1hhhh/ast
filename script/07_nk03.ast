		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“With all that said and done, she’s really been working hard for us lately. We should do something...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就算撇开这个不谈，最近也为了我们两个的事努力着，必须为她做点什么……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就算撇開這個不談，最近也為了我們兩個的事努力著，必須為她做點什麼……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00426",
		linknext = "0092_00428",
		line = 6014,
	},
	["0092_00428"] = {
		{"fg", file="nanase_02m_00003", file1="nanase_02m_00101", file2="nanase_02m_00219", path=":fg/nanase_02m/", id=4, lv=4, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0748", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“If her lack of appetite is down to sleep deprivation... Then getting enough sleep is the most important thing. Maybe exercise would help?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“吃不下饭的原因是因为睡眠不足吧……我觉得果然还是要有充足的睡眠比较重要……那么，做运动呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「吃不下飯的原因是因為睡眠不足吧……我覺得果然還是要有充足的睡眠比較重要……那麼，做運動呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00427",
		linknext = "0092_00429",
		line = 6029,
	},
	["0092_00429"] = {
