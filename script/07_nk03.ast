		{"text"},
		text = {
			vo = {
				{"vo", file="asane1174b", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hey, Bro. I’ve been up all night reading this argument about whether it’s sexier to censor d*cks or c*nts in porno games... or whether they should be censored at all and—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我说──哥哥，在色情游戏中，色情用语修正成小●比较色情，或是●穴比较色情，还是修正色情用语很多于之类的，跟大家一起热线讨论到天明──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我說──哥哥，在色情遊戲中，色情用語修正成小●比較色情，或是●穴比較色情，還是修正色情用語很多於之類的，跟大家一起熱線討論到天明──」",
					{"rt2"},
				},
			},
		},
