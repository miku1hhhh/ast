				{"vo", file="nanase0751", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“No, you’re totally fine. I trained a bunch as a scout, remember? You can rest your weight on me more and hold on tighter if you need.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这个重量没事的，麻沙酱。在做侦查员时有特别训练过。所以可以在放松点，抱着我就行了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這個重量沒事的，麻沙醬。在做偵查員時有特別訓練過。所以可以在放鬆點，抱著我就行了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00460",
		linknext = "0092_00462",
		line = 6521,
	},
	["0092_00462"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asa squishes her face into to Nanase’s cleavage.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑一把就拉着麻沙酱，将她的脸贴近自己的胸部。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨一把就拉著麻沙醬，將她的臉貼近自己的胸部。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00461",
		linknext = "0092_00463",
		line = 6531,
	},
	["0092_00463"] = {
		{"evset", file="nhcg03", set="nhcg03", path=":ev/nhcg03/"},
		{"evset", file="nhcg03010101010202", set="nhcg03010", path=":ev/nhcg03010/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="nhcg03010101010202", x=0, y=0, path=":cg/nhcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1195", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I can’t believe I’m so close to Na-Na-Nanase’s na-na-naked body! I wanna build a house in the prime real estate between these supple mounds and live there off the passive income rent-free!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“奈奈奈，奈奈濑同学软绵绵的两团就赤裸裸地在我眼前……！？想要在软得要命山谷之间建一栋房，然后一生不劳而获的在那生活……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「奈奈奈，奈奈瀨同學軟綿綿的兩團就赤裸裸地在我眼前……！？想要在軟得要命山谷之間建一棟房，然後一生不勞而獲的在那生活……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00462",
		linknext = "0092_00464",
		line = 6550,
	},
	["0092_00464"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asa’s nostrils twitch and her breathing quickens amid her rambling.",
					{"rt2"},
				},
			},
			cn = {
				{
					"妹妹边兴奋边干尽十足地说着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"妹妹邊興奮邊幹盡十足地說著。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00463",
		linknext = "0092_00465",
		line = 6560,
	},
	["0092_00465"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It feels kinda weird, but she’s family.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然是有点恶心，但毕竟还是我重要的亲人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然是有點噁心，但畢竟還是我重要的親人。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00464",
		linknext = "0092_00466",
		line = 6570,
	},
	["0092_00466"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I have to pitch in and do what I can for her health.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但为了妹妹的健康，我也要挺身相助。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但為了妹妹的健康，我也要挺身相助。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00465",
		linknext = "0092_00467",
		line = 6580,
	},
	["0092_00467"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So... How does this threesome thing work anyway?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“话虽这么说……但是该怎么去3P比较好啊……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「話雖這麼說……但是該怎麼去3P比較好啊……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00466",
		linknext = "0092_00468",
		line = 6591,
	},
	["0092_00468"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’ve only done stuff in a one-on-one, pure love, monogamous kind of way until now, so I’m not sure what to do next.",
					{"rt2"},
				},
			},
			cn = {
				{
					"基本上，我只玩过1对1的纯爱色情游戏，所以不是很清楚该怎么做。",
					{"rt2"},
				},
			},
			tw = {
				{
					"基本上，我只玩過1對1的純愛色情遊戲，所以不是很清楚該怎麼做。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00467",
		linknext = "0092_00469",
		line = 6601,
	},
	["0092_00469"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0752", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well this is something Asa’s always wanted to try. Why don’t we ask her?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这应该是麻沙酱所希望的，不如问一下她的意见如何？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這應該是麻沙醬所希望的，不如問一下她的意見如何？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00468",
		linknext = "0092_00470",
		line = 6613,
	},
	["0092_00470"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Right. Okay then. How would you like us to start, Asa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然是这样说，麻沙酱你想要怎么做呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然是這樣說，麻沙醬你想要怎麼做呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00469",
		linknext = "0092_00471",
		line = 6624,
	},
	["0092_00471"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1196", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yeah, no, hold up, I’ve been fantasizing about this for a while. If we think about it from a ‘what to put into who’ standpoint then I haven’t really addressed that personally.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不是，等一下，其实我一直在思考这个。我还没想好该插入哪一边这个问题，虽然这真的是个很简单的问题就是了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不是，等一下，其實我一直在思考這個。我還沒想好該插入哪一邊這個問題，雖然這真的是個很簡單的問題就是了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00470",
		linknext = "0092_00472",
		line = 6636,
	},
	["0092_00472"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1197", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Having been allowed into this ménage à trois at my own request it’s not exactly an obvious stance to take but as your sister of course I have some trepidation about you putting it in me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“身为妹妹的我混进两人的做爱，本来定位就不是那么好区分的，而且我对于自己要被插入还是抱有一丝不安呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「身為妹妹的我混進兩人的做愛，本來定位就不是那麼好區分的，而且我對於自己要被插入還是抱有一絲不安呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00471",
		linknext = "0092_00473",
		line = 6648,
	},
	["0092_00473"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1198", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Dammit, if I just had more time I could’ve systematically summarized my position in this threesome in a paper, submitted it for academic review and constructed a super dense theory on the matter!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“可恶，明明只要有时间，我就能有系统地统整出3P时妹妹的站位并写成论文提交给学会，然后再构筑出缜密的理论……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「可惡，明明只要有時間，我就能有系統地統整出3P時妹妹的站位並寫成論文提交給學會，然後再構築出縝密的理論……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00472",
		linknext = "0092_00474",
		line = 6660,
	},
	["0092_00474"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I feel like that was a lot of words to say very little. Just... think about what you want to try.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们也不是很能理解太复杂的事，还是先想想你想要做的事吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們也不是很能理解太複雜的事，還是先想想妳想要做的事吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00473",
		linknext = "0092_00475",
		line = 6671,
	},
	["0092_00475"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1199", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“What I want to try... Nanase’s your lover so... I guess I wanna help you make her feel good! Like... an assistant!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“想做的事情啊……果，果然奈奈濑同学是我哥的恋人……也就是说，我能不能就当着助手呢……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「想做的事情啊……果，果然奈奈瀨同學是我哥的戀人……也就是說，我能不能就當著助手呢……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00474",
		linknext = "0092_00476",
		line = 6683,
	},
	["0092_00476"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0753", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Will that be enough to satisfy you though, Asa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不过这样的话，麻沙酱就没法满足吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不過這樣的話，麻沙醬就沒法滿足吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00475",
		linknext = "0092_00477",
		line = 6695,
	},
	["0092_00477"] = {
		{"evset", file="nhcg03", set="nhcg03", path=":ev/nhcg03/"},
		{"evset", file="nhcg03_l010101020302", set="nhcg03_l0", path=":ev/nhcg03_l0/"},
		{"bg", id=19, file="nhcg03_l010101020302", x=-52.5, y=0, path=":cg/nhcg03_l/", lv=19, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1200", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I-I-It’d be an honor for a virgin like me just to be a part of your lovemaking!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“怎怎怎怎怎么会呢，像我这样的处女光是能加入你们就已经非常的高兴了啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「怎怎怎怎怎麼會呢，像我這樣的處女光是能加入你們就已經非常的高興了啊……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00476",
		linknext = "0092_00478",
		line = 6712,
	},
	["0092_00478"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0754", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“You can stop being so humble. Just tell us what you want to try.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“别说这么卑微的话啊……真的，说说看你想做的事吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「別說這麼卑微的話啊……真的，說說看妳想做的事吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00477",
		linknext = "0092_00479",
		line = 6724,
	},
	["0092_00479"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0755", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I have a little experience with this kind of thing and I remember feeling kind of left out only being able to kiss Jun and do nothing else.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“虽然之前我也有3P的经验啦……但那时候只是跟淳接吻而已……是觉得有点寂寞呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「雖然之前我也有3P的經驗啦……但那時候只是跟淳接吻而已……是覺得有點寂寞呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00478",
		linknext = "0092_00480",
		line = 6736,
	},
	["0092_00480"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0756", path=":vo/", ch="nanase"},
			},
