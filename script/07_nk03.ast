				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hey, what’s going— Asa?! The hell did you do to my little sister?! You may be my muscle mentor but that doesn’t mean you can mess with my fam—!!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“唔哇，怎么了怎么了……呃，麻沙酱！？混帐东西，你们到底对我妹妹做了什么！？就算你是肌肉老师，这样的事也不能原谅──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「唔哇，怎麼了怎麼了……呃，麻沙醬！？混帳東西，你們到底對我妹妹做了什麼！？就算你是肌肉老師，這樣的事也不能原諒──！」",
					{"rt2"},
				},
			},
		},
