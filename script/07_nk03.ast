		text = {
			vo = {
				{"vo", file="ikuko2081", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I gave her a once over and it doesn’t seem to be dehydration. She doesn’t seem sick or injured either. Maybe she’s just not getting enough sleep?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“暂时观察了一下她的状况，既没有脱水的症状，好像也不是生病或是受伤之类的。应该就是单纯睡眠不足吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「暫時觀察了一下她的狀況，既沒有脫水的症狀，好像也不是生病或是受傷之類的。應該就是單純睡眠不足吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00094",
		linknext = "0092_00096",
		line = 1388,
	},
	["0092_00096"] = {
