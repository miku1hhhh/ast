		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She’s not the brightest tool in the shed as far as my classmates go, but when it comes to her little sister she’s a model sibling.",
					{"rt2"},
				},
			},
			cn = {
				{
					"作为同学她是有点散漫，但在对家人方面确实是靠得住的姐姐。",
					{"rt2"},
				},
			},
			tw = {
				{
					"作為同學她是有點散漫，但在對家人方面確實是靠得住的姊姊。",
					{"rt2"},
				},
			},
		},
