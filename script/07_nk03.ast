		{"fg", file="asane_01m_00001", file1="asane_01m_00101", file3="asane_01m_00303", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1182", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I heard every moment of it! I was sitting in the living room when that happened! Nanase knows I was! YOU EVEN WISHED ME GOOD MORNING!!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“听得清清楚楚的啦！！当时我就在客厅里啊！奈奈濑也知道的吧！哥哥在之前还跟我说‘嘿，早安啊’的啊……！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「聽得清清楚楚的啦！！當時我就在客廳裡啊！奈奈瀨也知道的吧！哥哥在之前還跟我說『嘿，早安啊』的啊……！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00392",
		linknext = "0092_00394",
		line = 5434,
	},
	["0092_00394"] = {
		{"fg", file="tohka_01f_00001", file1="tohka_01f_00101", file2="tohka_01f_00228", path=":fg/tohka_01f/", id=30, ch="桐香", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1806", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Oh my, are you going to hide? You were showing him your neck from the start, weren’t you? You wanted him to see that big ol’ hickey, hm?❤”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“哎呀，是藏起来了吗？脖子，应该一开始就有吻痕了吧？而且还特别显眼又很大……对吧",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「哎呀，是藏起來了嗎？脖子，應該一開始就有吻痕了吧？而且還特別顯眼又很大……對吧",
					{"gaiji", text="①"},
					"」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00393",
		linknext = "0092_00395",
		line = 5447,
