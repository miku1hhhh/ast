		{"bg", id=2, file="bg11_1l_00000", x=-300, y=0, lv=2, path=":bg/", sync=1, style="blur", blurx=11, blury=11, alpha=0, a_chr151=1, ax=1290, ay=730, bx=-490, by=-280},
		{"cgact", file="cgact", id=2, lv=2, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"cgact", file="cgact", id=2, act="移動", x=595, y=-5, time=20000, lv=2},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0346", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛", "白装束の女"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Woman in White"},
					"“...And that is all the Perverted Freedom Movement currently occurring on Seiran Island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛", "一身白的女性"},
					"“──……以上是，现在发生在青兰岛上的〝变态自由活动〞的全部。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "一身白的女性"},
					"「──……以上是，現在發生在青蘭島上的〝變態自由活動〞的全部。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00874",
		linknext = "0092_00876",
		line = 12032,
	},
	["0092_00876"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The other members visibly shudder when the woman sitting at the center of the round table finishes speaking.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当坐在圆桌中央的女人终于把话说完后，其他的成员都浑身一震。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當坐在圓桌中央的女人終於把話說完後，其他的成員都渾身一震。",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00875",
		linknext = "0092_00877",
		line = 12042,
	},
	["0092_00877"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0365", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト", "マスカレード・シュウ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Masquerade-Shu"},
					"“I’d no idea the scale had grown that much... So many really wish for the Perverted Law to be reinstated that badly?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "假面舞会・舒"},
					"“没想到，会有这种规模的人在活动着……这是否意味着有许多人希望能恢复〝变态条例〞呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "假面舞會・舒"},
					"「沒想到，會有這種規模的人在活動著……這是否意味著有許多人希望能恢復〝變態條例〞呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00876",
		linknext = "0092_00878",
		line = 12054,
	},
	["0092_00878"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0515", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子", "だんだら模様の女"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Zigzag-Sleeved Girl"},
					"“Correct... This trend is in our control. The only question is when we use it... Don’t you agree?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "横条纹女"},
					"“没错，是这样的……时代就掌握在我们的手中。要到什么时候才可以使用这股力量……这样还不够吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "橫條紋女"},
					"「沒錯，是這樣的……時代就掌握在我們的手中。要到什麼時候才可以使用這股力量……這樣還不夠吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00877",
		linknext = "0092_00879",
		line = 12066,
	},
	["0092_00879"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0347", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛", "白装束の女"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Woman in White"},
					"“There will be no surprises. I have a firm grasp on all ongoing activities... They are mere puppets dancing as I pull the strings.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛", "一身白的女性"},
					"“是啊，所以不需要吃惊……能掌握所有活动人士的就是我……他们就只不过是傀儡罢了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "一身白的女性"},
					"「是啊，所以不需要吃驚……能掌握所有活動人士的就是我……他們就只不過是傀儡罷了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00878",
		linknext = "0092_00880",
		line = 12078,
	},
	["0092_00880"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0366", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト", "マスカレード・シュウ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Masquerade-Shu"},
					"“There was nothing in my data to suggest she would gain this much power...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "假面舞会・舒"},
					"“我的数据并没有显示出，她拥有这么大的力量啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "假面舞會・舒"},
					"「我的數據並沒有顯示出，她擁有這麼大的力量啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00879",
		linknext = "0092_00881",
		line = 12090,
	},
	["0092_00881"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0516", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子", "だんだら模様の女"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Zigzag-Sleeved Girl"},
					"“Bertie, don’t sat your ‘data’ line! You’ll blow your cover!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "横条纹女"},
					"“啊，贝特先生请停止说出会暴露身份的台词。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "橫條紋女"},
					"「啊，貝特先生請停止說出會暴露身分的台詞。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00880",
		linknext = "0092_00882",
		line = 12102,
	},
	["0092_00882"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0367", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト", "マスカレード・シュウ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Masquerade-Shu"},
					"“Oh, sure. And you’re a total enigma, yourself. You give yourself away every time you open your mouth!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "假面舞会・舒"},
					"“你才是吧，那个特殊的语玮词，马上就会被拆穿了吧……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "假面舞會・舒"},
					"「你才是吧，那個特殊的語瑋詞，馬上就會被拆穿了吧……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00881",
		linknext = "0092_00883",
		line = 12114,
	},
	["0092_00883"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0348", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛", "白装束の女"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Woman in White"},
					"“We are no longer the organization we once were... It is thanks to the divine revelation that we have been able to unite them and rally them together.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛", "一身白的女性"},
					"“我们原本就是身处于不同组织……之所以能集合在一起，凝聚成一股力量，完全是因为天意的缘故。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "一身白的女性"},
					"「我們原本就是身處於不同組織……之所以能集合在一起，凝聚成一股力量，完全是因為天意的緣故。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00882",
		linknext = "0092_00884",
		line = 12126,
	},
	["0092_00884"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0349", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛", "白装束の女"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Woman in White"},
					"“We have God on our side.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛", "一身白的女性"},
					"“因为我们……与神同在。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "一身白的女性"},
					"「因為我們……與神同在。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00883",
		linknext = "0092_00885",
		line = 12138,
	},
	["0092_00885"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0517", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子", "だんだら模様の女"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Zigzag-Sleeved Girl"},
					"“Yes, let us believe that for now. If things stay like this I will be forced back to Susukino... and we have to pay for your meals too. Isn’t that right Icarus?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "横条纹女"},
					"“是呢，现在就让我们相信吧……在这样下去我就会像脱水一般灰飞烟灭……还有花费你的吃饭钱……是吧，口交鹦鹉。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "橫條紋女"},
					"「是呢，現在就讓我們相信吧……在這樣下去我就會像脫水一般灰飛煙滅……還有花費你的吃飯錢……是吧，口交鸚鵡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00884",
		linknext = "0092_00886",
		line = 12150,
	},
	["0092_00886"] = {
		{"se", id=0, loop=0, file="se_a294"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fellatio0084", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"フェラチオウム", "朽ちぬ翼のイカロス"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"フェラチオウム", "Everlasting Wings of Icarus"},
					"“GUHRURURU! THAT’S ENTIRELY UP TO YOU, DUH! GUHRURU...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"フェラチオウム", "不朽翅膀的伊卡洛斯"},
					"“啾啵啵啵……！只看名字就决定了吧！啾啵啵啵啵……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"フェラチオウム", "不朽翅膀的伊卡洛斯"},
					"「啾啵啵啵……！只看名字就決定了吧！啾啵啵啵啵……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00885",
		linknext = "0092_00887",
		line = 12163,
	},
	["0092_00887"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0350", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛", "白装束の女"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Woman in White"},
					"“Yes. Everything awaits the return of ‘they who shan’t be named even with the mouth below.’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛", "一身白的女性"},
					"“没错，这一切都会……回到〝连下面的人都不敢提起的名字的那个人〞回来的那一天──”",
					{"rt2"},
				},
			},
			tw = {
