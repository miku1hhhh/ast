			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Pfft, this is just how I wind down. Why, embarrassed?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呵，因为这就是我日常〝放松〞的方式……会害羞吗？”",
