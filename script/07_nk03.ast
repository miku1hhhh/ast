			en = {
				{
					name = {"モブ男C", "Silver-Toothed Rabblerouser"},
					"“Compared to the mainland, our sexual resources are less than a thousandth of theirs. Despite this, how is it that we have been able to fight for so long? It is because our goal is a sexual one.”",
					{"rt2"},
