	["0092_00111"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wait, wait, don’t move! I’ll remember everything better if I draw it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“等一下等一下，姿势跑掉了……！像这个样子画下来的话，才会更加记住啊。”",
