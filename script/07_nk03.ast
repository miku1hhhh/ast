			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“W-Well, y’see... Nanase’s been over at our house so much lately. A-And I’m super happy about that and all, but...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“话，话说回来，奈奈濑能一直来家里玩……那真的是，非常让人开心地是呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「話，話說回來，奈奈瀨能一直來家裡玩……那真的是，非常讓人開心地是呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00104",
		linknext = "0092_00106",
		line = 1561,
	},
	["0092_00106"] = {
