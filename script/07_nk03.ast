		{"transitiontime", time=300},
		{"fgact", ch="奈々瀬4", id=4, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0821", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“She needed this, remember? Come on, let’s leave her to rest. I’ll put the blanket over her so she doesn’t catch a cold.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“应该是太累了吧，就这样让她睡吧。来吧，给她盖上毯子，别让她着凉了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「應該是太累了吧，就這樣讓她睡吧。來吧，給她蓋上毯子，別讓她著涼了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0092_00842",
		linknext = "0092_00844",
		line = 11564,
	},
