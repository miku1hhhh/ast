		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It might not work 100% of the time, but a simple conversation can help us fix misunderstandings and begin to bridge the gaps between us as people.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然这世界上的事未必都是如此，但如果我们交流一下，就可以消除误会，相互理解。",
