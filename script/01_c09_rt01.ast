			ja = {
				{
					name = {"モブ男B", "陰毛にこだわる男"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男B", "Pube Connoisseur"},
					"“Huh? Oh yeah! You’re right! This is the optimal amount of hair for a pair of ’nards this size! I was carried away thinking about my own bushy mane!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "执着阴毛男"},
					"“欸……没错啊！对于这么大的蛋蛋来说现在这样的柴鱼阴毛量才是对完美的！是我过度参考自己的阴毛标准了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "執著陰毛男"},
					"「欸……沒錯啊！對於這麼大的蛋蛋來說現在這樣的柴魚陰毛量才是對完美的！是我過度參考自己的陰毛標準了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00124",
		linknext = "0002_00126",
		line = 1711,
	},
	["0002_00126"] = {
