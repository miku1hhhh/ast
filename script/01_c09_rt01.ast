				},
			},
			cn = {
				{
					name = {"礼"},
					"“所以说，我们主要的功用就是将决定的事项传达给这些现场的FS，还有依据状况作出最佳的人事调整这两项。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「所以說，我們主要的功用就是將決定的事項傳達給這些現場的FS，還有依據狀況作出最佳的人事調整這兩項。」",
					{"rt2"},
				},
			},
		},
