		{"transitiontime", time=300},
		{"fg", file="jun_01f_00006", file2="jun_01f_00201", path=":fg/jun_01f/", id=30, ch="淳之介", lv=2, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hey, Bro, don’t you think those balls have the perfect amount of pube flakes just the way they are?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“──这位大哥，那些听到我的声音就膨胀起来的脏玉烧⋯⋯现在上面柴鱼阴毛的份量不是看起来更刚好吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「──這位大哥，那些聽到我的聲音就膨脹起來的髒玉燒⋯⋯現在上面柴魚陰毛的份量不是看起來更剛好嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00123",
		linknext = "0002_00125",
		line = 1699,
	},
	["0002_00125"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobb0025", path=":vo/", ch="bmob"},
