	["0002_00127"] = {
		{"fg", file="jun_01f_00006", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If talking to me made you squirt everywhere, why not use it like an ice rink and skate to where you need to be? That’d be super efficient!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“跟我讲话的话爱液就会爆流的话，要不要干脆就用溜的？这样效率会更高喔？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「跟我講話的話愛液就會爆流的話，要不要乾脆就用溜的？這樣效率會更高喔？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00126",
		linknext = "0002_00128",
		line = 1734,
	},
	["0002_00128"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobb0033", path=":vo/", ch="gmob"},
			},
			ja = {
				{
					name = {"モブ女B", "効率を重視するFS女子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Efficiency-Loving FS Girl"},
					"“Huh? Wow! What an amazing suggestion! It’s so much faster than running! Of course you’d come up with such a naughty yet clever answer, Your Sexellency!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "重视效率的FS女子"},
					"“咦⋯⋯啊！真的欸！比用跑的还快欸！居然知道这种密技⋯⋯真不愧是性帝大人！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "重視效率的FS女子"},
					"「咦⋯⋯啊！真的欸！比用跑的還快欸！居然知道這種密技⋯⋯真不愧是性帝大人！」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00127",
		linknext = "0002_00129",
		line = 1746,
	},
	["0002_00129"] = {
		{"fg", file="jun_01f_00006", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, I was inspired by a time I slipped on some splooge I forgot to clean up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“其实是有一次我不小心踩到我忘记处理的精液滑倒了⋯⋯我也是从这边得到启发的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「其實是有一次我不小心踩到我忘記處理的精液滑倒了⋯⋯我也是從這邊得到啟發的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00128",
		linknext = "0002_00130",
		line = 1758,
	},
	["0002_00130"] = {
