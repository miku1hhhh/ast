			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Hmm? It’s rare to see Your Sexellency out and about without getting freaky. Are you deep in thought? You seem to be looking at Tadasugawa...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“哼嗯？没想到被称作性帝的人也会这样要勃起不勃起的。你在想事情吗？你好像在看着糺川前辈耶。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「哼嗯？沒想到被稱作性帝的人也會這樣要勃起不勃起的。你在想事情嗎？你好像在看著糺川前輩耶。」",
					{"rt2"},
				},
			},
		},
		linkback = "0032_00025",
		linknext = "0032_00027",
		line = 366,
	},
