	["0027_00124"] = {
		{"bgm", file="bgm27", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0723", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“You two were thick as thieves, it makes sense that you’d feel lost without her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“因为你们之前一直在一起嘛⋯⋯你果然还是会很寂寞吧。要是麻沙音酱不在身边的话。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「因為你們之前一直在一起嘛⋯⋯你果然還是會很寂寞吧。要是麻沙音醬不在身邊的話。」",
					{"rt2"},
				},
			},
		},
