	["0027_00148"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ikuko, Touka, Rei... They’re all irreplaceable friends experiencing similar circumstances.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管是郁子、桐香、还是礼前辈，都是遭遇了同样境遇下、我无可取代的伙伴。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管是郁子、桐香、還是禮前輩，都是遭遇了同樣境遇下、我無可取代的夥伴。",
					{"rt2"},
				},
			},
		},
		linkback = "0027_00147",
		linknext = "0027_00149",
		line = 1784,
	},
	["0027_00149"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ikuko’s right. I could go back to the NLNS, but that’s not the right way forward.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正如郁子所说，即使我能回到NLNS──那里也没有未来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正如郁子所說，即使我能回到NLNS──那裡也沒有未來。",
					{"rt2"},
				},
			},
		},
		linkback = "0027_00148",
