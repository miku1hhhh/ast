		line = 1794,
	},
	["0027_00150"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It might give me some peace, but then there’d be no way for us to leave this world.",
					{"rt2"},
