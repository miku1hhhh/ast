	["0027_00147"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They aren’t a replacement for the NLNS.",
					{"rt2"},
				},
			},
			cn = {
