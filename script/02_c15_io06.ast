	["0027_00129"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0725", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“They’re your friends, right? Our circumstances may be different but that doesn’t really change anything. I’m sure they’d take you back if you explained everything to them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“大家、都是淳之介君重要的伙伴吧？虽然状况不同，但本质应该都没有变才对⋯⋯如果你把一切都说开，我想你应该也还是会被接受吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「大家、都是淳之介君重要的夥伴吧？雖然狀況不同，但本質應該都沒有變才對⋯⋯如果你把一切都說開，我想你應該也還是會被接受吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0027_00128",
		linknext = "0027_00130",
		line = 1566,
	},
	["0027_00130"] = {
		{"evset", file="icg01", set="icg01", path=":ev/icg01/"},
