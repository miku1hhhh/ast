	["0027_00160"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’m already soaked through so an umbrella means nothing to me at this point, and yet Ikuko’s here shielding me with it anyway.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我全身都湿透了，此时打伞也毫无意义──但郁子却勇敢地为我挡雨。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我全身都濕透了，此時打傘也毫無意義──但郁子卻勇敢地為我擋雨。",
					{"rt2"},
				},
			},
		},
		linkback = "0027_00159",
		linknext = "0027_00161",
		line = 1925,
	},
	["0027_00161"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I thought you said tragic backstories made you wanna vomit.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯你不是讨厌到那种沉浸在悲剧里的人讨厌到想吐吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯妳不是討厭到那種沉浸在悲劇裡的人討厭到想吐嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0027_00160",
		linknext = "0027_00162",
		line = 1936,
	},
	["0027_00162"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="icg01010101", x=-5, y=-2.5, path=":cg/icg01/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0732", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“True... It’s strange. I don’t feel that way now. Maybe because it’s you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“也是呢⋯⋯但是、为什么呢？我完全不觉得讨厌呢。是因为是亲爱的所以才不讨厌吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「也是呢⋯⋯但是、為什麼呢？我完全不覺得討厭呢。是因為是親愛的所以才不討厭嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0027_00161",
		linknext = "0027_00163",
		line = 1952,
	},
	["0027_00163"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She genuinely pondered this, amused, and shrugged her shoulders with a wry smile.",
					{"rt2"},
				},
			},
			cn = {
				{
					"心中疑惑的郁子觉得有些奇怪、还是苦笑着耸了耸肩。",
					{"rt2"},
				},
			},
			tw = {
				{
					"心中疑惑的郁子覺得有些奇怪、還是苦笑著聳了聳肩。",
					{"rt2"},
				},
			},
		},
		linkback = "0027_00162",
