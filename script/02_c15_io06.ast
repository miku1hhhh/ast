	},
	["0027_00165"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But even if I can’t fill that void, there’s still somebody in this world that cares this much about me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是──即使我不能填补那个空缺，我也有非常像这样爱慕着我的朋友。",
					{"rt2"},
				},
			},
