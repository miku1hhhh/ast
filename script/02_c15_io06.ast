		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Anyone who saw me must’ve thought I’d lost my mind. It only makes sense that they would worry.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从旁看来这完全就是失魂落魄的模样──会担心也是理所当然的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從旁看來這完全就是失魂落魄的模樣──會擔心也是理所當然的。",
					{"rt2"},
				},
			},
		},
