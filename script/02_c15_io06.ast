	["0027_00142"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I’m sorry for being like this even though I have you guys.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我身边，明明就有郁子你们在。”",
