	},
	["0027_00144"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don’t have any of my friends from back then either, not Nanase, not Hinami... not Misaki or Fumino...",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑、雏见、美岬、文乃──那时的伙伴们没有一个在。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨、雛見、美岬、文乃──那時的夥伴們沒有一個在。",
					{"rt2"},
				},
			},
		},
		linkback = "0027_00143",
		linknext = "0027_00145",
		line = 1744,
	},
	["0027_00145"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I do have people willing to help me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"尽管如此，还是有人可以伸出援手。",
					{"rt2"},
				},
			},
			tw = {
				{
					"儘管如此，還是有人可以伸出援手。",
					{"rt2"},
				},
			},
		},
		linkback = "0027_00144",
