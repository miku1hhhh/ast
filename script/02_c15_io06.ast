	["0027_00143"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don’t have Asane though.",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙音不在我的身边。",
					{"rt2"},
				},
			},
			tw = {
				{
					"麻沙音不在我的身邊。",
