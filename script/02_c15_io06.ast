	["0027_00127"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="icg01010102", x=-5, y=-2.5, path=":cg/icg01/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0724", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“You know, even in this world you can probably still go back to the BoaF—I mean, the NLNS—if you feel like it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“⋯⋯就算在这边的世界，只要你想的话，还是可以回到Tori公──噢不是、我是说NLNS那里去也说不定喔？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「⋯⋯就算在這邊的世界，只要你想的話，還是可以回到Tori公──噢不是、我是說NLNS那裡去也說不定喔？」",
					{"rt2"},
				},
			},
		},
		linkback = "0027_00126",
		linknext = "0027_00128",
		line = 1543,
	},
	["0027_00128"] = {
