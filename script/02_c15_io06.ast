	["0027_00164"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Asane is the only one who can fill this Asane-shaped hole in my heart.",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙音不在而造成的那个缺口，果然还是只有麻沙音本人能够填补。",
					{"rt2"},
				},
			},
			tw = {
				{
					"麻沙音不在而造成的那個缺口，果然還是只有麻沙音本人能夠填補。",
					{"rt2"},
				},
			},
