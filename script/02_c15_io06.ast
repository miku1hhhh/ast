				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“And since it’s you I’ll lend a hand. With me around we’d have the power of hundred people, after all!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“如果是为了淳之介君，我也会帮忙的。如果有我在的话⋯⋯应该能以一抵百对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「如果是為了淳之介君，我也會幫忙的。如果有我在的話⋯⋯應該能以一抵百對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0027_00129",
