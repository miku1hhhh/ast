			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I will make this world mine through perversion.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我将透过变态行为掌控这个世界。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我將透過變態行為掌控這個世界。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00214",
		linknext = "0034_00216",
		line = 2917,
	},
	["0034_00216"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Now it makes sense.",
					{"rt2"},
				},
			},
			cn = {
				{
					"啊啊，这样就说得通了。",
					{"rt2"},
				},
