		text = {
			vo = {
				{"vo", file="ikuko0921", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Yikes... Not much you could really say to that... As the FS, that is...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“哎啊⋯⋯看起来刚刚、是连表示异议的机会都不给我们呢⋯⋯对这边的FS来说是这样没错、可是呢⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「哎啊⋯⋯看起來剛剛、是連表示異議的機會都不給我們呢⋯⋯對這邊的FS來說是這樣沒錯、可是呢⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00156",
		linknext = "0034_00158",
		line = 2157,
	},
	["0034_00158"] = {
