	["0034_00270"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sometimes you just need to summon the courage to jump out of the frying pan and into the fire.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有时候也是需要进虎穴的勇气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"有時候也是需要進虎穴的勇氣。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00269",
		linknext = "0034_00271",
		line = 3618,
	},
	["0034_00271"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0701", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“If there is a possibility, it would have to be SHO headquarters. Data on everything should be stored there, but—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“现在剩下的线索，只剩下SHO本部大楼了吧。那里的话应该储存了所有的资料才对──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「現在剩下的線索，只剩下SHO本部大樓了吧。那裡的話應該儲存了所有的資料才對──」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00270",
		linknext = "0034_00272",
		line = 3630,
	},
	["0034_00272"] = {
