			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“You’ve got a set of balls on you, haven’t you? As a man, don’t you feel the desire to rise to the top?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“你应该也有睪丸吧？是个男人的话，你难道不想要靠着自己的力量往上爬吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「你應該也有睪丸吧？是個男人的話，你難道不想要靠著自己的力量往上爬嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00047",
		linknext = "0034_00049",
		line = 624,
	},
	["0034_00049"] = {
