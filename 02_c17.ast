		line = 609,
	},
	["0034_00048"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00214", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0002", path=":vo/", ch="hitoura"},
