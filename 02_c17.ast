		line = 3352,
	},
	["0034_00250"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00218", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...Hey, Touka. What kind of person is Sakimori anyway?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯是说桐香，驻防老人到底是个什么样的人物啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯是說桐香，駐防老人到底是個什麼樣的人物啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00249",
		linknext = "0034_00251",
		line = 3364,
	},
	["0034_00251"] = {
		{"evset", file="kcg03", set="kcg03", path=":ev/kcg03/"},
		{"evset", file="kcg0300040201-1", set="kcg030004", path=":ev/kcg030004/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg0300040201-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0697", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Well... I’ve only heard about him second-hand myself. But it seems he was a capable man even within his family’s long history.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“是呢、我对他的认识也仅限于传闻而已⋯⋯就算是在那个历史渊源已久的驻防家里，他也是个叛徒般的存在。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「是呢、我對他的認識也僅限於傳聞而已⋯⋯就算是在那個歷史淵源已久的駐防家裡，他也是個叛徒般的存在。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00250",
		linknext = "0034_00252",
		line = 3383,
	},
	["0034_00252"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg0300050201-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0698", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Always calm and collected, and logical to a fault. Like a man who managed everything mathematically—which is why his elopement was so shocking, according to my sister.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“总是沉着冷静，是个极端的理性主义者、一切都用数字衡量的人物──这就是为什么我姐姐会说，他做出私奔这种事非常令人震惊的原因。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「總是沉著冷靜，是個極端的理性主義者、一切都用數字衡量的人物──這就是為什麼我姐姐會說，他做出私奔這種事非常令人震驚的原因。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00251",
		linknext = "0034_00253",
		line = 3399,
	},
	["0034_00253"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Someone who committed an act of rebellion for the sake of a master in spite of their otherwise assured status.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是个明明得到了高位，却为此背叛了主人的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是個明明得到了高位，卻為此背叛了主人的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00252",
		linknext = "0034_00254",
		line = 3409,
	},
	["0034_00254"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In other words, Sakimori was always a passionate person.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说，驻防老人本来就是一个多情的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說，駐防老人本來就是一個多情的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00253",
		linknext = "0034_00255",
		line = 3419,
	},
	["0034_00255"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Which is also why he became so enraged when Hitoura stole his daughter away...",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以仁浦把他女儿抢走时，才会那么激动──",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以仁浦把他女兒搶走時，才會那麼激動──",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00254",
