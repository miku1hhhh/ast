	["0034_00123"] = {
		{"bgm", file="bgm09.5", vol=100},
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00201", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[3000] = {
				{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00202", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, timestamp=14, delay2=3000, mode=3, x=-5, y=-5},
			},
			[2999] = {
				{"transitiontime", time=300, timestamp=14, delay2=3000},
			},
		},
		text = {
			vo = {
				{"vo", file="hitoura0004", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Ah, and you must be Tachibana—er, or perhaps I should call you His Sexellency? What a pleasure it is.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“喔、你就是橘──啊不、还是应该称你性帝？这还真是⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「喔、你就是橘──啊不、還是應該稱你性帝？這還真是⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00122",
		linknext = "0034_00124",
		line = 1655,
	},
	["0034_00124"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00223", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, please... Sir.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“玩笑话就免了──仁浦大人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「玩笑話就免了──仁浦大人。」",
