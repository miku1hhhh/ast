	["0034_00222"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00211", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0030", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I see. Hah... You really are Reizeiin’s dog, aren’t you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“是吗、哼⋯⋯果然啊，你也不过是冷泉院手下的狗而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「是嗎、哼⋯⋯果然啊，你也不過是冷泉院手下的狗而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00221",
		linknext = "0034_00223",
		line = 3000,
	},
	["0034_00223"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
