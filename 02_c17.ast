		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...Is someone I could have been, if only I’d accepted this man’s invitation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"──正是接受了这个男人的邀请、if线的我自己。",
