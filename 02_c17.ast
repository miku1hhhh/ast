	["0034_00174"] = {
		{"fg", file="hitoura_01l_00001", file1="hitoura_01l_00102", file2="hitoura_01l_00216", path=":fg/hitoura_01l/", id=17, lv=17, head="hitoura_01l", ch_origin="仁浦", ch="仁浦17", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=500},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I call out to the man contemplating on the beach. He turns around with a shocked expression.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当我在海滩上呼唤那个中年人时，他转过身来，露出惊讶的表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當我在海灘上呼喚那個中年人時，他轉過身來，露出驚訝的表情。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00173",
		linknext = "0034_00175",
		line = 2407,
	},
	["0034_00175"] = {
		{"cgdel", id=2, lv=2, time=0, alphadel=1},
		{"fg", mode=-1, id=17, ch="仁浦17", ch_origin="仁浦", lv=17, time=0, sync=0},
		{"bgm", file="bgm03", vol=100},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00102", file2="hitoura_01m_00214", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0013", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Hrmph... You surprised me. How did you know I’d be here? This is a secret spot of mine, one I haven’t told anyone about...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“嗯⋯⋯吓了我一跳，你怎么会知道我在这里？这里是我的秘密，我从来都没有告诉过任何人⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「嗯⋯⋯嚇了我一跳，你怎麼會知道我在這裡？這裡是我的秘密，我從來都沒有告訴過任何人⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00174",
		linknext = "0034_00176",
		line = 2426,
	},
	["0034_00176"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00218", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I just had a feeling. A shot in the dark, that’s all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没什么。只是被我猜中了而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒什麼。只是被我猜中了而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00175",
		linknext = "0034_00177",
		line = 2438,
	},
	["0034_00177"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’ve spoken to this man here twice before.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我第二次，在此地与仁浦展开了谈话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我第二次，在此地與仁浦展開了談話。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00176",
		linknext = "0034_00178",
		line = 2448,
	},
	["0034_00178"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But there’s no way he’d know that, since it didn’t happen in this world.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当然，因为上次并不是在这个世界，这男人对此一无所知。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當然，因為上次並不是在這個世界，這男人對此一無所知。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00177",
		linknext = "0034_00179",
		line = 2458,
	},
	["0034_00179"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I feel a tinge of nostalgia as I face off against the man I once defeated.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我边感到一丝怀念，边和曾经打倒的男人对峙着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我邊感到一絲懷念，邊和曾經打倒的男人對峙著。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00178",
		linknext = "0034_00180",
		line = 2468,
	},
	["0034_00180"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00207", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0014", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Hmm, what sharp instincts. Having excellent intuition is the first requirement to being a good man.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“哼嗯⋯⋯你的第六感还真敏锐。直觉过人也是一个好男人的首要条件。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「哼嗯⋯⋯你的第六感還真敏銳。直覺過人也是一個好男人的首要條件。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00179",
		linknext = "0034_00181",
		line = 2483,
	},
	["0034_00181"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00210", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, that’s just about the only thing I have going for me, though I’m not a fan of defining what makes a man and what makes a woman.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我对区分男女这种事一点兴趣也没有，这大概是我唯一的可取之处。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我對區分男女這種事一點興趣也沒有，這大概是我唯一的可取之處。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00180",
		linknext = "0034_00182",
		line = 2495,
	},
	["0034_00182"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00212", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0015", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Surely there’s more. You have that powerful penis of yours, do you not?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“唯一的可取之处、不是这样吧？你可是有着那个强大的男根不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「唯一的可取之處、不是這樣吧？你可是有著那個強大的男根不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00181",
		linknext = "0034_00183",
		line = 2510,
	},
	["0034_00183"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
