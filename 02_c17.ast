			cn = {
				{
					name = {"仁浦"},
					"“我不过是搜寻了学校的数据而已。只要有了大致的条件，要彻底的筛出结果其实很容易。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我不過是搜尋了學校的數據而已。只要有了大致的條件，要徹底的篩出結果其實很容易。」",
