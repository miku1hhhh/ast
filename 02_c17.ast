		line = 3948,
	},
	["0034_00295"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But then, this hashtag began to be used in a way this person didn’t intend.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是该Tag已经偏离他或她的目的，另作他用了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是該Tag已經偏離他或她的目的，另作他用了。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00294",
		linknext = "0034_00296",
		line = 3958,
	},
	["0034_00296"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Most likely by people who thought they could get attention by using whatever hashtags are being talked about at the moment.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果是类似的话题，就可以透过蹭Tag来引起注意⋯⋯肯定有人这么想过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果是類似的話題，就可以透過蹭Tag來引起注意⋯⋯肯定有人這麼想過。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00295",
		linknext = "0034_00297",
		line = 3968,
	},
	["0034_00297"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Gradually, it started to be used to talk about gender theorists, about misogyny, about restricting drawn pornography, for attacking other accounts...",
					{"rt2"},
				},
			},
			cn = {
				{
					"渐渐地，它变成了一个关于性别论的讨论、关于歧视女性的讨论、关于二次元色情监管的讨论、关于账号攻击的讨论──",
					{"rt2"},
				},
			},
			tw = {
				{
					"漸漸地，它變成了一個關於性別論的討論、關於歧視女性的討論、關於二次元色情監管的討論、關於賬號攻擊的討論──",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00296",
		linknext = "0034_00298",
		line = 3978,
	},
	["0034_00298"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It ended up turning into what you might call a mark of cringe.",
					{"rt2"},
				},
			},
			cn = {
				{
					"它已经变成了所谓“引战用的Tag”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"它已經變成了所謂「引戰用的Tag」。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00297",
		linknext = "0034_00299",
		line = 3988,
	},
	["0034_00299"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Having strayed so far from its original purpose, it stirred up a viral level of outrage and the original account quietly disappeared.",
					{"rt2"},
				},
			},
			cn = {
				{
					"偏离了原本的主题、在网络上大炎上，原本的帐号就这么消失了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"偏離了原本的主題、在網路上大炎上，原本的帳號就這麼消失了。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00298",
		linknext = "0034_00300",
		line = 3998,
	},
	["0034_00300"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This was the article’s conclusion.",
					{"rt2"},
				},
			},
			cn = {
				{
					"‘自己提起勇气的指责却没有人愿意听取导致失败，并不是自身的失败。’",
					{"rt2"},
				},
			},
			tw = {
				{
					"『自己提起勇氣的指責卻沒有人願意聽取導致失敗，並不是自身的失敗。』",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00299",
		linknext = "0034_00301",
		line = 4008,
	},
	["0034_00301"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"“But just because people stopped listening to those brave accusations does not mean that they ended in failure.”",
					{"rt2"},
				},
			},
			cn = {
				{
					"这篇文章最后做出了这样的总结。",
