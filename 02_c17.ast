	["0034_00265"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As a fappist, it’s just so humiliating.",
					{"rt2"},
				},
			},
			cn = {
				{
					"作为一个自慰家⋯⋯这真的是，非常屈辱的一件事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"作為一個自慰家⋯⋯這真的是，非常屈辱的一件事。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00264",
		linknext = "0034_00266",
		line = 3560,
	},
	["0034_00266"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg0300050201-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0700", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“The only lead we have is the vice president who swapped positions with you, Tachibana. But we haven’t been able to learn a single new thing about him either.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“毕竟唯一的线索，也只有被前辈替代的原副会长而已。不过那边的情报也完全停滞了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「畢竟唯一的線索，也只有被前輩替代的原副會長而已。不過那邊的情報也完全停滯了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00265",
		linknext = "0034_00267",
		line = 3576,
	},
	["0034_00267"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...We can’t keep sitting back and waiting.",
					{"rt2"},
				},
			},
			cn = {
				{
					"⋯⋯已经没有时间袖手旁观了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"⋯⋯已經沒有時間袖手旁觀了。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00266",
		linknext = "0034_00268",
		line = 3586,
	},
	["0034_00268"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We have to act no matter what, even if it’s somewhat dangerous.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即时有些风险，我们也不得不这么做。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即時有些風險，我們也不得不這麼做。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00267",
		linknext = "0034_00269",
		line = 3596,
	},
	["0034_00269"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...This is no time to be picky about our methods.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯已经时间选手段了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯已經時間選手段了。」",
					{"rt2"},
				},
