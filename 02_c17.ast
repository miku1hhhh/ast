					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“My answer is no.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我的答案是NO。”",
