		linkback = "0034_00223",
		linknext = "0034_00225",
		line = 3022,
	},
	["0034_00225"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I stand on my own two legs. I don’t intend on treating anyone like my savior.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我靠的是我自己。不会归顺于任何人之下。”",
					{"rt2"},
				},
			},
			tw = {
