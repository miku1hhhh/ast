					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「啊、搞不好那是個好主意⋯⋯！話說回來後天我們都會被叫去做活動報告吧？」",
					{"rt2"},
				},
			},
		},
