	["0034_00117"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It brings a smile to my face to have these people around me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为有他们在，我才能展开笑容。",
					{"rt2"},
