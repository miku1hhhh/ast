	["0034_00224"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I know this answer to be the right one.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我对这个答覆无比肯定。",
					{"rt2"},
