	["0034_00132"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"fg", file="tohka_01m_00004", file1="tohka_01m_00101", file2="tohka_01m_00202", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00211", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0006", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“To continue—the FS’s high level of independence has even become a problem for the SHO. Many are saying that this is not how a subordinate division ought to act.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我们继续前言──目前，即便对SHO来说，FS的独立性还是太高了。也有不少声音说，这样并不像个附属组织。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我們繼續前言──目前，即便對SHO來說，FS的獨立性還是太高了。也有不少聲音說，這樣並不像個附屬組織。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00131",
		linknext = "0034_00133",
		line = 1790,
	},
	["0034_00133"] = {
		{"fg", file="tohka_02m_00004", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0688", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I believe I have explained to you in the past that the independence of educational institutions makes it uniquely difficult for the judiciary to interfere.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我想我之前跟大家解释过，教育机构从一开始就是独立的，应该具有司法难以介入这个特性才对。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我想我之前跟大家解釋過，教育機構從一開始就是獨立的，應該具有司法難以介入這個特性才對。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00132",
		linknext = "0034_00134",
		line = 1805,
	},
	["0034_00134"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00207", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0007", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I’m well aware of that. But realistically speaking, your budget comes from the SHO. Is ignoring its wishes the socially sensible thing to do?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“这点我理解，但实际上预算是来自于SHO。无视这种意图，合乎社会道理的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「這點我理解，但實際上預算是來自於SHO。無視這種意圖，合乎社會道理的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00133",
		linknext = "0034_00135",
		line = 1820,
	},
	["0034_00135"] = {
		{"fg", file="tohka_01m_00004", file1="tohka_01m_00101", file2="tohka_01m_00211", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0689", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“The FS’s discretionary independence has allowed us to produce results. You’re liable to ruin the benefits we provide if you need an organization that will faithfully follow orders from the top.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“正因为我们可以独自做出决定，FS才能有实际。需要忠实执行上级组织指示的组织的话，说不定会毁掉FS的优点吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「正因為我們可以獨自做出決定，FS才能有實際。需要忠實執行上級組織指示的組織的話，說不定會毀掉FS的優點吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00134",
		linknext = "0034_00136",
		line = 1835,
	},
	["0034_00136"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Though they’re keeping their voices in check, the two are going at it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然语气很平静，但彼此都在较着劲。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然語氣很平靜，但彼此都在較著勁。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00135",
		linknext = "0034_00137",
		line = 1845,
	},
	["0034_00137"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"While I’d rate myself as the better talker—Touka is a pretty clever negotiator herself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"要说到能言善道的话我觉得自己绝对有分──不过桐香肯定也是佼佼者。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要說到能言善道的話我覺得自己絕對有分──不過桐香肯定也是佼佼者。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00136",
		linknext = "0034_00138",
		line = 1855,
	},
	["0034_00138"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00214", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0008", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I see. And so this is why your organization has its own unique views on the Lewd Code and the USP?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“原来如此。正是因为有这样的组织在，所以你才会产生了对抗变态法跟USD这样的独立思想、的意思吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「原來如此。正是因為有這樣的組織在，所以你才會產生了對抗變態法跟USD這樣的獨立思想、的意思嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00137",
		linknext = "0034_00139",
		line = 1870,
	},
	["0034_00139"] = {
		{"fg", file="tohka_01m_00004", file1="tohka_01m_00101", file2="tohka_01m_00201", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Touka’s expression is the only one that remains unchanged.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只有桐香还保持镇定。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只有桐香還保持鎮定。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00138",
		linknext = "0034_00140",
		line = 1883,
	},
	["0034_00140"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But her verbal assault does stop.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但她那尖锐的舌锋停了下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但她那尖銳的舌鋒停了下來。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00139",
		linknext = "0034_00141",
		line = 1893,
	},
	["0034_00141"] = {
		{"bg", id=17, file="bg16_1l_00000", x=-350, y=0, lv=17, path=":bg/", sync=0, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="rin_01l_00001", file1="rin_01l_00101", file3="rin_01l_00307", path=":fg/rin_01l/", id=18, lv=18, head="rin_01l", ch_origin="凛", ch="凛18", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
