	},
	["0034_00256"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg0300020201-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0699", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Though I’m sure his ideology is an extreme one. After all, he became a politician just before eloping to guarantee his safety and purged his conservative relatives in the family.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不过他的思想很激进这点无庸置疑。因为他为了不让其他人插手，在私奔前就成为了政治家、肃清了驻防家保守派的亲族们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不過他的思想很激進這點無庸置疑。因為他為了不讓其他人插手，在私奔前就成為了政治家、肅清了駐防家保守派的親族們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00255",
		linknext = "0034_00257",
		line = 3445,
	},
	["0034_00257"] = {
		{"evset", file="kcg03", set="kcg03", path=":ev/kcg03/"},
		{"evset", file="kcg030004020401", set="kcg030004", path=":ev/kcg030004/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg030004020401", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0894", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“So he won their favor, gained power, then turned around to elope and crush his family members? I don’t know if that’s clever or just plain ruthless...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“在私奔前就利用刚获得的权力碾压对方吗？到底是该说这是聪明还是惨忍呢⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「在私奔前就利用剛獲得的權力碾壓對方嗎？到底是該說這是聰明還是慘忍呢⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00256",
		linknext = "0034_00258",
		line = 3464,
	},
	["0034_00258"] = {
