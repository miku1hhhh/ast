	["0034_00221"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I answer without a moment of hesitation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我斩钉截铁地回道。",
					{"rt2"},
