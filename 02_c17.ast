	},
	["0034_00217"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s right. The former student council vice president, the guy now with the Birds of a Feather...",
					{"rt2"},
				},
			},
			cn = {
				{
					"没错，那个组成‘Tori公’的、身为前任学生副会长的男人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒錯，那個組成『Tori公』的、身為前任學生副會長的男人。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00216",
