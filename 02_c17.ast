				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Fine, then. Writhe around in your suffocating position. That is one way to live your life.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“那你就在那个令人窒息的位置上努力挣扎吧，那也是一种生活方式就是了──”",
