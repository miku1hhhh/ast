	["0034_00142"] = {
		{"fg", file="ran_01l_00001", file1="ran_01l_00102", file2="ran_01l_00209", file4="ran_01l_00401", path=":fg/ran_01l/", id=19, lv=19, head="ran_01l", alpha=0, ch_origin="蘭", ch="蘭19", mw="mw", sync=1, a_chr151=1, mode=3, x=595, y=-5},
		{"fgact", ch="蘭19", id=19, lv=19, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="蘭19", id=19, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0079", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“R-Rin...! Don’t tell me that when they said all of that, you were...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“凛、凛⋯⋯！你那时候，确实也是──！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「凜、凜⋯⋯！妳那時候，確實也是──！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00141",
		linknext = "0034_00143",
		line = 1923,
	},
	["0034_00143"] = {
		{"fg", file="rin_01l_00001", file1="rin_01l_00101", file3="rin_01l_00301", path=":fg/rin_01l/", id=18, lv=18, head="rin_01l", ch_origin="凛", ch="凛18", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0169", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“My job is to assist in the observation of the FS. If the bug I hid in the disciplinary committee room just so happens to pick something up, I have no choice but to report it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“我的职责是协助监视FS。既然风纪委员室里的窃听器偶然录到了，我就必须报告上去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「我的職責是協助監視FS。既然風紀委員室裡的竊聽器偶然錄到了，我就必須報告上去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00142",
		linknext = "0034_00144",
		line = 1938,
	},
	["0034_00144"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This little brat...!",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个小屁妞──",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個小屁妞──",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00143",
		linknext = "0034_00145",
		line = 1948,
	},
	["0034_00145"] = {
		{"cgdel", id=17, lv=17, time=0, alphadel=1},
		{"fg", mode=-1, id=18, ch="凛18", ch_origin="凛", lv=18, time=0, sync=0},
		{"fg", mode=-1, id=19, ch="蘭19", ch_origin="蘭", lv=19, time=0, sync=0},
		{"fg", file="tohka_02m_00004", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0690", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“We were simply debating hypotheticals. Or is the SHO planning on engaging in the suppression of free speech?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我们只是在争论可能性。还是说SHO要压制言论？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我們只是在爭論可能性。還是說SHO要壓制言論？」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00144",
		linknext = "0034_00146",
		line = 1969,
	},
	["0034_00146"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, Touka shows why she’s the head of the FS. She isn’t ceding ground.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过，不愧是身为FS的领导者，桐香没有退缩。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過，不愧是身為FS的領導者，桐香沒有退縮。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00145",
		linknext = "0034_00147",
		line = 1979,
	},
	["0034_00147"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00201", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0009", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I have no complaints about your ideology. However, it is your job to support an environment that allows the village’s residents and students to have safe and healthy perverted sex.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我不是不满意诸君的想法，不过你们的工作是帮助岛上的居民和学生安全健康地进行变态性爱这件事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我不是不滿意諸君的想法，不過你們的工作是幫助島上的居民和學生安全健康地進行變態性愛這件事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00146",
		linknext = "0034_00148",
		line = 1994,
	},
	["0034_00148"] = {
		{"fg", file="tohka_02m_00004", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0691", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“So you mean to say that it would run contrary to the FS’s founding ideals if we were to be critical of the Lewd Code and the USP, both the will of the people?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“若是对具有民意支持的变态法、USD抱持着批判的态度，这就是与FS原本的行动理念相左，是这个意思吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「若是對具有民意支持的變態法、USD抱持著批判的態度，這就是與FS原本的行動理念相左，是這個意思嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00147",
		linknext = "0034_00149",
		line = 2009,
	},
	["0034_00149"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00207", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0010", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“That wasn’t the FS’s consensus of opinion—it was your personal view. What would that be if not the misappropriation of the organization?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“这不是FS的共识──而只是你们的意见。不得不说这就是将组织私物化。不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「這不是FS的共識──而只是你們的意見。不得不說這就是將組織私物化。不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00148",
		linknext = "0034_00150",
		line = 2024,
	},
	["0034_00150"] = {
		{"fg", file="tohka_01m_00004", file1="tohka_01m_00101", file2="tohka_01m_00202", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0692", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“The opinions of an organization and the individuals within it should be considered separately. It’s not as though every family member of a criminal is genetically predisposed to crime.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“组织意见和个人意见应该切割来看才对吧？并不是所有的罪犯家属都有犯罪基因的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「組織意見和個人意見應該切割來看才對吧？並不是所有的罪犯家屬都有犯罪基因的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00149",
		linknext = "0034_00151",
		line = 2039,
	},
	["0034_00151"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00202", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[3400] = {
				{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00201", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, timestamp=15, delay2=3400, mode=3, x=395, y=-5},
			},
			[3399] = {
				{"transitiontime", time=300, timestamp=15, delay2=3400},
			},
		},
		text = {
			vo = {
				{"vo", file="hitoura0011", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Indeed, we are a family. It’s fine that you’ve developed an awareness of yourself as the head of an organization made powerful by His Sexellency, but perhaps you ought to listen to your parent too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“没错，我们都是一家人。虽然借由‘色帝’的存在获得力量成为组织的领导，萌生这样的自我意识自然是好事，但仍应该听从上级的话不吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「沒錯，我們都是一家人。雖然藉由『色帝』的存在獲得力量成為組織的領導，萌生這樣的自我意識自然是好事，但仍應該聽從上級的話不嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00150",
		linknext = "0034_00152",
		line = 2057,
	},
	["0034_00152"] = {
		{"fg", file="tohka_02m_00004", file1="tohka_02m_00101", file2="tohka_02m_00213", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0693", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I apologize, but you see, I’m an abandoned child. I’ve never known what it means to have a parent, and it seems I’ve caused you undue worry as a result.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“十分抱歉，可惜我是个孤儿。劳您多费心来关照我不识父母了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「十分抱歉，可惜我是個孤兒。勞您多費心來關照我不識父母了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00151",
		linknext = "0034_00153",
		line = 2072,
	},
	["0034_00153"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00207", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=395, y=-5},
