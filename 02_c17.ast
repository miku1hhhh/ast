	["0034_00184"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00218", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0016", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“It is truly a pity that you’ll never do more than serve under that dead-eyed girl.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“这样对你，和那个‘无欲无求的少’在一起，实在是太可惜了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「這樣對你，和那個『無欲無求的少』在一起，實在是太可惜了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00183",
		linknext = "0034_00185",
		line = 2537,
	},
	["0034_00185"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The man gazes into the evening calm with a sigh.",
					{"rt2"},
				},
			},
			cn = {
				{
					"男人一边看着风平浪静的夕滩，一边叹惋着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"男人一邊看著風平浪靜的夕灘，一邊嘆惋著。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00184",
		linknext = "0034_00186",
		line = 2547,
	},
	["0034_00186"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00211", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0017", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“The fact is that the FS relies too heavily on you. You ought to be a symbol, but now you are just too great a figure on the island. I wouldn’t be surprised if you’ve developed some ulterior motives.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“⋯⋯实际上，FS太过依赖你了。对现在的青岚岛来说，一个可以成为像征的存在实在太伟大了。会萌生出不轨之意也不足为奇。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「⋯⋯實際上，FS太過依賴你了。對現在的青嵐島來說，一個可以成為像徵的存在實在太偉大了。會萌生出不軌之意也不足為奇。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00185",
		linknext = "0034_00187",
		line = 2562,
	},
	["0034_00187"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Please don’t get the wrong idea. We aren’t plotting anything. We intend to keep on doing our jobs, just like we always have.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“请不要误会。我们可没有那种低劣的想法。一如既往，我们会尽忠职守。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「請不要誤會。我們可沒有那種低劣的想法。一如既往，我們會盡忠職守。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00186",
		linknext = "0034_00188",
		line = 2574,
	},
	["0034_00188"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00204", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0018", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Then why is the FS growing increasingly independent? Why try to claim your own authority, and even determine your own budget?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“那FS又为何要加强独立性呢？你们是想获得自主决定权和预算权吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「那FS又為何要加強獨立性呢？你們是想獲得自主決定權和預算權嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00187",
		linknext = "0034_00189",
		line = 2589,
	},
	["0034_00189"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That... I don’t know.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个──我也不清楚。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個──我也不清楚。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00188",
		linknext = "0034_00190",
		line = 2600,
	},
	["0034_00190"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There’s no way we can figure out what Touka and the others were originally plotting in this world.",
					{"rt2"},
				},
			},
			cn = {
				{
					"原本这世界的桐香等人的意图，我们无从知晓。",
					{"rt2"},
				},
			},
			tw = {
				{
					"原本這世界的桐香等人的意圖，我們無從知曉。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00189",
		linknext = "0034_00191",
		line = 2610,
	},
	["0034_00191"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, I have to be smart here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，我得要好好应付才行。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，我得要好好應付才行。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00190",
		linknext = "0034_00192",
		line = 2620,
	},
	["0034_00192"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I need to act as myself from this world if I want to get information out of him too.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了探取情报，我得好好扮演这个世界的自己才行。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了探取情報，我得好好扮演這個世界的自己才行。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00191",
		linknext = "0034_00193",
		line = 2630,
	},
	["0034_00193"] = {
		{"bgm", file="bgm36", vol=100},
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00201", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0019", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“An organization that places too much of a burden on a single part of itself is not a healthy one. Surely you must be feeling stressed as well.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“只有组织里的某部分负担过大，对组织来说是不健康的。你也会因此产生压力不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「只有組織裡的某部分負擔過大，對組織來說是不健康的。你也會因此產生壓力不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00192",
		linknext = "0034_00194",
		line = 2646,
	},
	["0034_00194"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What if I said I am?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我要是回答‘是’呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我要是回答『是』呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00193",
		linknext = "0034_00195",
		line = 2658,
	},
	["0034_00195"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00207", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0020", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Then I would simply answer by saying to come to my side. I’m the only one who can save you from the ridiculous spotlight that’s been cast on you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“‘到我身旁来。’，我只会这样会回你。现在能把你从这种成为众矢之的的困境里救出来的人，也就只有我了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「『到我身旁來。』，我只會這樣會回你。現在能把你從這種成為眾矢之的的困境裡救出來的人，也就只有我了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00194",
		linknext = "0034_00196",
		line = 2673,
	},
	["0034_00196"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00306", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Save me? You almost sound like some sort of good guy here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“拯救我什么的，说得像是你是正义使者一样呢──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「拯救我什麼的，說得像是你是正義使者一樣呢──」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00195",
		linknext = "0034_00197",
		line = 2685,
	},
	["0034_00197"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00201", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0021", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I am an evil man. But that is exactly why there are some people only I can save. Am I mistaken?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我是坏人喔。所以被我救的人也是。不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我是壞人喔。所以被我救的人也是。不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00196",
		linknext = "0034_00198",
		line = 2700,
	},
	["0034_00198"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Governor Hitoura is the same in this world too.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个世界的仁浦县知事也没变。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個世界的仁浦縣知事也沒變。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00197",
		linknext = "0034_00199",
		line = 2710,
	},
	["0034_00199"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He’s made himself a villain and tries to carry out that role.",
					{"rt2"},
				},
			},
			cn = {
				{
					"自己做下作当坏人的决定，并好好扮演自己的角色。",
					{"rt2"},
				},
			},
			tw = {
				{
					"自己做下作當壞人的決定，並好好扮演自己的角色。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00198",
		linknext = "0034_00200",
		line = 2720,
	},
	["0034_00200"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He’ll never stop until he realizes his goals.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在达到目的之前，绝对不会放弃。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在達到目的之前，絕對不會放棄。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00199",
		linknext = "0034_00201",
		line = 2730,
	},
	["0034_00201"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00214", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0022", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“The Lewd Code is now looking very likely to become a reality. Whatever those politicians in the central government might say, it’s only a matter of time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“目前，变态法已经到了定案的阶段了。虽然中央的政客们还在为此争论不休，不过通过也只是时间的问题而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「目前，變態法已經到了定案的階段了。雖然中央的政客們還在為此爭論不休，不過通過也只是時間的問題而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00200",
		linknext = "0034_00202",
		line = 2745,
	},
	["0034_00202"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00204", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0023", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“But I need talent into order to make sure it’s carried out right. Someone who will be a symbol, an exemplar for the great masses.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“但我们需要人来实现它。一个能成为许多人的榜样和象征的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「但我們需要人來實現它。一個能成為許多人的榜樣和象徵的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00201",
		linknext = "0034_00203",
		line = 2760,
	},
	["0034_00203"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That’s no different from what the FS is doing. Aren’t you being hypocritical here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那就和FS的做法一样了，这不是双标吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那就和FS的做法一樣了，這不是雙標嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00202",
		linknext = "0034_00204",
		line = 2772,
	},
	["0034_00204"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00207", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0024", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“It’s a matter of scale, and of what comes next. Stay in the FS and you’ll never leave this small, enclosed world. But in the SHO, your future holds freedom.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“这得要端看规模与未来的发展。FS所追求的不过是一个封闭世界的结果。而SHO瞩目的是自由的未来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「這得要端看規模與未來的發展。FS所追求的不過是一個封閉世界的結果。而SHO矚目的是自由的未來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00203",
		linknext = "0034_00205",
		line = 2787,
	},
	["0034_00205"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I knew it...",
					{"rt2"},
				},
			},
			cn = {
				{
					"果然是这样──",
					{"rt2"},
				},
			},
			tw = {
				{
					"果然是這樣──",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00204",
		linknext = "0034_00206",
		line = 2797,
	},
	["0034_00206"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00201", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0025", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“The FS’s authority only stretches to this island’s edges. However powerful it might become, they’ll never be able to affect the nation or the world.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“FS的权力仅能作用于岛上。无论你有多大的权力，它对整个国家或世界都不起作用。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「FS的權力僅能作用於島上。無論你有多大的權力，它對整個國家或世界都不起作用。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00205",
		linknext = "0034_00207",
		line = 2812,
	},
	["0034_00207"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hitoura sees Touka, or the FS Big Three in general, as a nuisance.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦察觉到桐香和FS三巨头全都是麻烦。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦察覺到桐香和FS三巨頭全都是麻煩。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00206",
		linknext = "0034_00208",
		line = 2822,
	},
	["0034_00208"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00205", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0026", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Youngest daughter of the Reizeiin of the Ten Virtues or not, she can only lead those within the Academy, nothing more. She’s too childish for anything more than that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“即便是人称‘十全十美的冷泉院’家的么女，也只能领导学园里的人，除此以外不能做更多了。接下来要做的事，那个女孩还太小不足以承担。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「即便是人稱『十全十美的冷泉院』家的么女，也只能領導學園裡的人，除此以外不能做更多了。接下來要做的事，那個女孩還太小不足以承擔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00207",
		linknext = "0034_00209",
		line = 2837,
	},
	["0034_00209"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The sight of the charismatic Touka using His Sexellency and rousing the masses must be an eyesore to him, as head of the SHO.",
					{"rt2"},
				},
			},
			cn = {
				{
					"利用“性帝”鼓吹人们的桐香，对SHO的代表来说肯定很碍事吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"利用「性帝」鼓吹人們的桐香，對SHO的代表來說肯定很礙事吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00208",
		linknext = "0034_00210",
		line = 2847,
	},
	["0034_00210"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00204", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0027", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“In that case, wouldn’t the right thing to do be for you to take the reins of the FS and fight for the future? You have that power.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“如此，你不更该掌握住FS，为未来而战吗？你分明拥有那种能力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「如此，你不更該掌握住FS，為未來而戰嗎？你分明擁有那種能力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00209",
		linknext = "0034_00211",
		line = 2862,
	},
	["0034_00211"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He wants full control over the FS when he expands the perverted sex law in the form of the Lewd Code.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在变态条例成功扩张，成为变态法之际，就能一举将FS一并落入囊中。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在變態條例成功擴張，成為變態法之際，就能一舉將FS一併落入囊中。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00210",
		linknext = "0034_00212",
		line = 2872,
	},
	["0034_00212"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But this world’s Touka managed to hold him off, and that’s what’s making him loathe her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，因为有这个世界的桐香的牵制，所以没有达成。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，因為有這個世界的桐香的牽制，所以沒有達成。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00211",
		linknext = "0034_00213",
		line = 2882,
	},
	["0034_00213"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s why he created the position of SHO special auditor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"会设置SHO特别监察官这种职位肯定也是为了这个目的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"會設置SHO特別監察官這種職位肯定也是為了這個目的。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00212",
		linknext = "0034_00214",
		line = 2892,
	},
	["0034_00214"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s even why he secretly formed the Birds of a Feather. To take all power away from the current FS...",
					{"rt2"},
				},
			},
			cn = {
				{
					"暗地里组织‘Tori公’这种组织的理由。也不过是为了将FS的权利完全夺取过来──",
					{"rt2"},
				},
			},
			tw = {
				{
					"暗地裡組織『Tori公』這種組織的理由。也不過是為了將FS的權利完全奪取過來──",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00213",
		linknext = "0034_00215",
		line = 2902,
	},
	["0034_00215"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00217", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
