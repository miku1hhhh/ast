			en = {
				{
					name = {"礼", "Rei"},
					"“So she had some other goal... Maybe there was some reason she needed authority and independence...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是不是、有别的目的呢⋯⋯因为有无论如何都得透过权力、透过拥有决定权才能做的事⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是不是、有別的目的呢⋯⋯因為有無論如何都得透過權力、透過擁有決定權才能做的事⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00244",
		linknext = "0034_00246",
		line = 3312,
	},
	["0034_00246"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We think, but we come up with nothing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"想了又想，仍是没有主意。",
					{"rt2"},
				},
			},
			tw = {
				{
					"想了又想，仍是沒有主意。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00245",
		linknext = "0034_00247",
		line = 3322,
	},
	["0034_00247"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If enough time passes, we’ll become synchronized with ourselves in this world and understand what we were thinking.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽说随着时间的推移，记忆同步完成后，我们就会明白这个世界的自己是什么想法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖說隨著時間的推移，記憶同步完成後，我們就會明白這個世界的自己是什麼想法。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00246",
		linknext = "0034_00248",
		line = 3332,
	},
	["0034_00248"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But we can’t just wait for that to happen.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，我们已经没有时间等下去了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，我們已經沒有時間等下去了。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00247",
		linknext = "0034_00249",
		line = 3342,
	},
	["0034_00249"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In fact, we’d like all the help we can get to make sure it doesn’t happen, but...",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了防止这种情况发生，帮助越多越好──",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了防止這種情況發生，幫助越多越好──",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00248",
