	},
	["0034_00045"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He said he wanted me to be his right-hand man.",
					{"rt2"},
				},
			},
			cn = {
				{
					"想要我当他的左右手，他这么说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"想要我當他的左右手，他這麼說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00044",
		linknext = "0034_00046",
		line = 589,
	},
	["0034_00046"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It seemed he needed more war potential for the days to come—to realize the Lewd Code and the USP.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了将来──为了变态法与USD，我需要拥有战力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了將來──為了變態法與USD，我需要擁有戰力。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00045",
		linknext = "0034_00047",
		line = 599,
	},
	["0034_00047"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And so he wanted me to be his right-hand man—someone who possessed overwhelming strength.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为此，我想要有个有压倒性实力的人作为自己的剑──他说。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為此，我想要有個有壓倒性實力的人作為自己的劍──他說。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00046",
