	["0034_00243"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg0300020501-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0696", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“None at all... Of course this would happen if the FS gained enough power to interfere with SHO business. Was she such a dummy that she didn’t even realize that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“真是的⋯⋯如果是为了让FS有足够的力量干涉SHO，这种发展就很理所当然。连这个都看不出来的，就只有笨蛋了不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「真是的⋯⋯如果是為了讓FS有足夠的力量干涉SHO，這種發展就很理所當然。連這個都看不出來的，就只有笨蛋了不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00242",
		linknext = "0034_00244",
		line = 3284,
	},
	["0034_00244"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg0300020201-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
