		text = {
			vo = {
				{"vo", file="hitoura0012", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Hmph... That’s all I have to say. Sorry to bother you all so suddenly. I’ll be taking my leave.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“哼……我要说的就这些了。抱歉突然打扰你们了──那就告辞了，诸位。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「哼……我要說的就這些了。抱歉突然打擾你們了──那就告辭了，諸位。」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00152",
		linknext = "0034_00154",
		line = 2093,
	},
