				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...I’m going to go talk to him real quick! Take my bag back to the dorm if this goes long!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“──我还要去找那男人说些事！要是我晚来得晚的话就先帮我把包包拿回宿舍去！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「──我還要去找那男人說些事！要是我晚來得晚的話就先幫我把包包拿回宿舍去！」",
					{"rt2"},
				},
			},
		},
