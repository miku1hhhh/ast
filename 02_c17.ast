	["0034_00125"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I bow deeply, using the same level of deference Rei has shown him in the past.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我学着礼前辈称呼的敬语，深深地低下了头。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我學著禮前輩稱呼的敬語，深深地低下了頭。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00124",
		linknext = "0034_00126",
		line = 1677,
	},
	["0034_00126"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This should be the most natural attitude to take, given the power balance between the SHO and the FS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"考虑到SHO和FS的权力平衡，这样的态度应该最自然──",
					{"rt2"},
				},
			},
			tw = {
				{
					"考慮到SHO和FS的權力平衡，這樣的態度應該最自然──",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00125",
		linknext = "0034_00127",
		line = 1687,
	},
	["0034_00127"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00207", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0005", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Hmm, so the rumors are true about you having mellowed out. You used to stay quiet and stone-faced no matter what anyone said—what’s brought about this change in you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“哼嗯，跟谣传的一样，你还真的变得圆滑了呢。以前不管对你说什么你都板着一张面无表情的脸──你到底产生了什么样的心境变化呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「哼嗯，跟謠傳的一樣，你還真的變得圓滑了呢。以前不管對你說什麼你都板著一張面無表情的臉──你到底產生了什麼樣的心境變化呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00126",
		linknext = "0034_00128",
		line = 1702,
	},
	["0034_00128"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“──────”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「──────」",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00127",
