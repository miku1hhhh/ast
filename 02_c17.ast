		{"bg", id=18, file="oldncg06_l01-1", x=-500, y=-400, path=":cg/oldncg06_l/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=1000},
		{"cgact", file="cgact", id=18, act="移動", x=0, y=150, time=1000, lv=18},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Seated just past him is Touka Reizeiin, head of the FS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"FS的代表、冷泉院桐香坐在那儿。",
