	["0034_00042"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I grit my teeth. Was this it?",
					{"rt2"},
				},
			},
			cn = {
				{
					"我紧咬着牙，想着该不会就要在这儿被将死了吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我緊咬著牙，想著該不會就要在這兒被將死了吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00041",
		linknext = "0034_00043",
		line = 554,
	},
	["0034_00043"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But Hitoura said something unexpected instead.",
					{"rt2"},
				},
