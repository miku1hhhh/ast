			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“...Why was I trying this hard to increase the FS’s authority in this world?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“⋯⋯这个世界的我，为什么要把FS的权力强化到这种程度？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「⋯⋯這個世界的我，為什麼要把FS的權力強化到這種程度？」",
