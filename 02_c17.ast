			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“...Will you seize control of this world alongside me?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“⋯⋯你不想跟我一起掌握世界吗？”",
