	["0034_00041"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I will admit, I broke out in a cold sweat when our enemy’s leader appeared before us.",
					{"rt2"},
