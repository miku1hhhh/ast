				{"vo", file="hitoura0029", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Don’t you want to join me, young man?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“你不跟我一起来吗──年轻人？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「你不跟我一起來嗎──年輕人？」",
