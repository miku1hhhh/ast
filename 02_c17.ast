				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Plain old masturbation didn’t work. The obvious move is to use that sex sleeve... but you couldn’t recreate it, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“如果普通的自慰没有用的话。我最先想到的是用那个飞机杯⋯⋯不过那个应该不能复制出来吧？”",
