	["0034_00130"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Perhaps this matched his image of “His Sexellency,” as he gives a resigned chuckle and sits up straight.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这模样或许和他记忆中的‘性帝’相符，他苦笑地说了句“算了”、纠正了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這模樣或許和他記憶中的『性帝』相符，他苦笑地說了句「算了」、糾正了。",
					{"rt2"},
				},
			},
		},
		linkback = "0034_00129",
