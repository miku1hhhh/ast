	["0043_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Somewhere that allowed every kind of perverted act that’s prohibited on the mainland.",
					{"rt2"},
				},
			},
			cn = {
				{
