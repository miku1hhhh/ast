	},
	["0043_00084"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00216", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Agh... It’s no good. I end up closing my eyes out of fear every time, no matter how often I do this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可恶⋯⋯不行。不管试几次都还是会因为害怕所以闭上眼──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可惡⋯⋯不行。不管試幾次都還是會因為害怕所以閉上眼──」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00083",
		linknext = "0043_00085",
		line = 1109,
	},
	["0043_00085"] = {
