		{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", file2="nanase_02m_00203", path=":fg/nanase_02m/", id=4, lv=4, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-205, y=-5},
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00203", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=195, y=-5},
