	["0043_00056"] = {
		{"fg", file="mizuhiki_01f_00001", file1="mizuhiki_01f_00101", file2="mizuhiki_01f_00207", path=":fg/mizuhiki_01f/", id=30, ch="水引", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0121", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Of course you will, Asane... There won’t be any need for ‘His Sexellency’ if we just have a new symbol.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“那当然啊，麻沙音酱⋯⋯只要有了新的象征，就不需要‘性帝’了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「那當然啊，麻沙音醬⋯⋯只要有了新的象徵，就不需要『性帝』了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00055",
		linknext = "0043_00057",
		line = 668,
	},
	["0043_00057"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There’s plenty of funding to be found in the SHO military development budget.",
					{"rt2"},
				},
			},
			cn = {
				{
					"资金方面，有SHO的军事开发费支持所以万分充足。",
					{"rt2"},
				},
			},
			tw = {
				{
					"資金方面，有SHO的軍事開發費支持所以萬分充足。",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00056",
		linknext = "0043_00058",
		line = 678,
	},
	["0043_00058"] = {
		{"fg", file="mizuhiki_01f_00001", file1="mizuhiki_01f_00101", file2="mizuhiki_01f_00204", path=":fg/mizuhiki_01f/", id=30, ch="水引", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0122", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“He won’t be shackled by anything if the student council president falls from grace.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“要是他失去学生会长的身份，不就同等于没有了束缚他的枷锁了吗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「要是他失去學生會長的身份，不就同等於沒有了束縛他的枷鎖了嗎。」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00057",
		linknext = "0043_00059",
		line = 691,
	},
	["0043_00059"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’m sure the residents here would never imagine that their tax dollars are being used for something like this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那些岛民们肯定连想都没有想过，自己缴的血汗钱会被用在这个地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那些島民們肯定連想都沒有想過，自己繳的血汗錢會被用在這個地方。",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00058",
		linknext = "0043_00060",
		line = 701,
	},
	["0043_00060"] = {
		{"fg", file="mizuhiki_01f_00001", file1="mizuhiki_01f_00101", file2="mizuhiki_01f_00203", path=":fg/mizuhiki_01f/", id=30, ch="水引", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0123", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“This is our only opportunity to get revenge. We’re going to be the ones to do this. For his sake. For the sake of his freedom...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“能报仇的机会就只有现在了。我们一起来吧。为了他、为了他的自由──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「能報仇的機會就只有現在了。我們一起來吧。為了他、為了他的自由──」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00059",
		linknext = "0043_00061",
		line = 714,
	},
	["0043_00061"] = {
		{"fg", file="asane_03m_00002", file2="asane_03m_00204", path=":fg/asane_03m/", id=3, lv=3, head="asane_03m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0090", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“...Okay. I’ll put together an automatic control program, then. I’ll be counting on you to handle the mass production side.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“⋯⋯知道了。那么自动控制程式由我来。大量生产规划就交给你了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「⋯⋯知道了。那麼自動控制程式由我來。大量生產規劃就交給你了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00060",
		linknext = "0043_00062",
		line = 729,
	},
	["0043_00062"] = {
