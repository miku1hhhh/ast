	["0043_00066"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He said he could make anything, so long as he had the parts—and so I believed him and got him to help us develop the Armored Hamedori.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有零件的话不管什么都能做──我信了他的话，让他协助了武装Hamedori君的开发。",
					{"rt2"},
				},
			},
			tw = {
				{
					"有零件的話不管什麼都能做──我信了他的話，讓他協助了武裝Hamedori君的開發。",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00065",
