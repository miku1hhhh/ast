	["0043_00090"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00214", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You’re the one person I don’t want to hear that from.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就你没有资格说这句话。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就你沒有資格說這句話。」",
