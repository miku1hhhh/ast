		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But unconsciously, everyone refused to accept me for who I am.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管是谁都下意识地否定我的存在。",
