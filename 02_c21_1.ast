	["0043_00091"] = {
		{"fg", mode=-1, id=4, ch="奈々瀬4", ch_origin="奈々瀬", lv=4, time=0, sync=0},
		{"fg", mode=-1, id=5, ch="ヒナミ5", ch_origin="ヒナミ", lv=5, time=0, sync=0},
		{"fg", mode=-1, id=6, ch="美岬6", ch_origin="美岬", lv=6, time=0, sync=0},
		{"fg", mode=-1, id=7, ch="文乃7", ch_origin="文乃", lv=7, time=0, sync=0},
		{"bg", id=1, file="bg29_1l_00000", x=-450, y=0, lv=1, path=":bg/", sync=0, ax=1290, ay=730, bx=-490, by=-280},
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00211", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1075", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I trained like this with no lifeline back at home, but it wasn’t useful at all, you know. It just made me a little better at landing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“虽然说郁在老家做这个训练的时候没有绑安全绳，不过绑了也没什么用喔？学会了怎么着地之后。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「雖然說郁在老家做這個訓練的時候沒有綁安全繩，不過綁了也沒什麼用喔？學會了怎麼著地之後。」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00090",
		linknext = "0043_00092",
		line = 1223,
	},
	["0043_00092"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00307", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Getting better at landing is what’s important here—Touka, do it again!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“看样子学会着地是最重要的呢──桐香、再来一次！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「看樣子學會著地是最重要的呢──桐香、再來一次！」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00091",
		linknext = "0043_00093",
		line = 1235,
	},
	["0043_00093"] = {
		{"bgm", stop=1},
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00215", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0789", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You know, Tachibana. Don’t you often scream as you fight? And what you’re saying is often unintelligible.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“这么说来──前辈你在战斗时，似乎都不太吼叫呢？还是说是想叫也叫不出来呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「這麼說來──前輩你在戰鬥時，似乎都不太吼叫呢？還是說是想叫也叫不出來呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00092",
		linknext = "0043_00094",
		line = 1250,
	},
	["0043_00094"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00212", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0961", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Huh, I do remember hearing about athletes sometimes screaming in order to cover up their fear, or possibly to remove any mental limits they have...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这么说我也听过竞技者会透过大叫来分散恐惧感、或者释放极限这种事──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這麼說我也聽過競技者會透過大叫來分散恐懼感、或者釋放極限這種事──」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00093",
		linknext = "0043_00095",
		line = 1264,
	},
