			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“We believed what all of you, the student council president included, said.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“我们大家都相信着学生会长你们啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「我們大家都相信著學生會長你們啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00211",
