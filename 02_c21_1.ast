		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00201", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_024_00000"},
		{"fg", file="hinami_02f_00001", file1="hinami_02f_00101", file2="hinami_02f_00205", path=":fg/hinami_02f/", id=30, ch="ヒナミ", lv=1, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0096", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Hey, but, are you really gonna be able to break her tablet while you’re fighting against her and those Hamedoris? Don’t those missiles really just track you everywhere...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“可是可是，有办法在边与麻沙音酱跟Hamedori君一同战斗的同时破坏平板吗？那个导弹真得紧追不放啊……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「可是可是，有辦法在邊與麻沙音醬跟Hamedori君一同戰鬥的同時破壞平板嗎？那個導彈真得緊追不放啊……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00162",
		linknext = "0043_00164",
		line = 2309,
	},
	["0043_00164"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I have to do more than just avoid the missiles. They won’t stop until I deflect them and destroy the cameras they use.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不仅仅是要避开跟反弹这些导弹，要是不把监视镜头给破坏的话，一切都停步下来的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不僅僅是要避開跟反彈這些導彈，要是不把監視鏡頭給破壞的話，一切都停步下來的。",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00163",
		linknext = "0043_00165",
		line = 2319,
	},
	["0043_00165"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Destroying her tablet while facing both those and multiple opponents is as close as you can get to an impossible task.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在这种情况下，和许多人对战还要边破坏平板，可以说是不可能的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在這種情況下，和許多人對戰還要邊破壞平板，可以說是不可能的。",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00164",
		linknext = "0043_00166",
		line = 2329,
	},
	["0043_00166"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There is one possibility... doesn’t the SHO have anti-radiation missiles or something?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“还有件事──SHO的装备里，难道没有反辐射源导弹之类的东西吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「還有件事──SHO的裝備裡，難道沒有反輻射源導彈之類的東西嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00165",
		linknext = "0043_00167",
		line = 2341,
	},
	["0043_00167"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00203", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0795", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“They do. Equipment that detects the source of radio waves and automatically fires riot bullets in its direction. It only exists in this world, but...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“有的。能侦查发送电波的源头，并自动发射防爆弹的装备。是只存在于这个世界之中的装备──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「有的。能偵查發送電波的源頭，並自動發射防爆彈的裝備。是只存在於這個世界之中的裝備──」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00166",
		linknext = "0043_00168",
		line = 2356,
	},
	["0043_00168"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00102", file2="rei_01m_00206", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0964", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“...But there’s no way for us to get our hands on those now. Would it really be possible for us to make them?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“但现在我们手头上根本没有这东西。能做得出来吗──？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「但現在我們手頭上根本沒有這東西。能做得出來嗎──？」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00167",
		linknext = "0043_00169",
		line = 2371,
	},
	["0043_00169"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00218", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
		{"text"},
		text = {
