			},
			tw = {
				{
					name = {"健蔵老人"},
					"「我只能用這種方式來贖罪⋯⋯不過⋯⋯你要做的事，簡直是個看不見、摸不到的妄想⋯⋯」",
					{"rt2"},
				},
