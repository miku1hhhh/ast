				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我剛才利用自己的影薄，使出了『美岬美岬變不見』試著進行偵察，不過大樓裡的SHO守衛多到快要溢出來⋯⋯要入侵沒有那麼容易⋯⋯」",
					{"rt2"},
				},
			},
		},
