	["0043_00006"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For me, someone constantly oppressed until I had no choice but to hide a part of myself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"始终被迫害者，最后学会了隐藏的我的，归处。",
					{"rt2"},
				},
			},
			tw = {
				{
					"始終被迫害者，最後學會了隱藏的我的，歸處。",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00005",
