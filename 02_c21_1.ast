	},
	["0043_00113"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I managed to keep my eyes open, so next is landing. I’m gonna go wash my face before doing another dive, but we’ll keep going once I’m done!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“眼睛睁得开的话，接下来就剩着地了。再继续跳之前，我先去洗个脸。等等再开始！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「眼睛睜得開的話，接下來就剩著地了。再繼續跳之前，我先去洗個臉。等等再開始！」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00112",
		linknext = "0043_00114",
		line = 1542,
	},
	["0043_00114"] = {
