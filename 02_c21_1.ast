			en = {
				{
					name = {"美岬", "Misaki"},
					"“That’d mean we’d just have to steal them from the SHO armory amidst all the confusion.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“3D列印机的话，倒是可以趁乱从SHO的武器库里抢过来，可是──”",
