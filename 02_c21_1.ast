		{"fg", file="rei_02f_00001", file1="rei_02f_00102", file2="rei_02f_00209", path=":fg/rei_02f/", id=30, ch="礼", lv=12, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0965", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Schubert...?! And Susuko, and everyone else?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“舒伯特⋯⋯！？丝丝子、还有大家──？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「舒伯特⋯⋯！？絲絲子、還有大家──？」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00178",
		linknext = "0043_00180",
		line = 2526,
	},
	["0043_00180"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00202", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="スス子11", id=11, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0286", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“S’right, Sir! Well, Rin’s not here. Heh, I had Blowbo say where you were stationed, then we waited for our shot and showed up to give you some support!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“早──啊！凛酱不在啊。嘿嘿，我让啾啪酱把位子跟我说，所以就趁机过来帮忙啦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「早──啊！凜醬不在啊。嘿嘿，我讓啾啪醬把位子跟我說，所以就趁機過來幫忙啦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00179",
		linknext = "0043_00181",
		line = 2542,
	},
	["0043_00181"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nearly every member of the FS has gathered here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"FS的所有成员几乎都在。",
					{"rt2"},
				},
			},
			tw = {
				{
					"FS的所有成員幾乎都在。",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00180",
		linknext = "0043_00182",
		line = 2552,
	},
	["0043_00182"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00211", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0192", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“We too have been ordered to provide overnight security for SHO headquarters, as the probability of intruders appearing increases at that time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“因为晚上入侵者来访的可能性提高了的关系，今天起我们也被命令在SHO总部大楼执行夜间警备了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「因為晚上入侵者來訪的可能性提高了的關係，今天起我們也被命令在SHO總部大樓執行夜間警備了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00181",
		linknext = "0043_00183",
		line = 2567,
	},
	["0043_00183"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00204", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0193", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Though we are not authorized to approach the armory... we should be able to cause a commotion, given our numbers. While I don’t have the data to back that up, I believe it’s possible.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“我没有靠近武器库的权限……但是，凭这些人数的话，应该能引起些骚动的。虽然我的数据库里没资料，但我相信是可能的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「我沒有靠近武器庫的權限……但是，憑這些人數的話，應該能引起些騷動的。雖然我的數據庫裡沒資料，但我相信是可能的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00182",
		linknext = "0043_00184",
		line = 2582,
	},
	["0043_00184"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00201", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[4500] = {
				{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00202", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, timestamp=18, delay2=4500, mode=3, x=395, y=-5},
			},
			[4499] = {
				{"transitiontime", time=300, timestamp=18, delay2=4500},
			},
		},
		text = {
			vo = {
				{"vo", file="susuko0287", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“What’s more, we’re slightly superior to the Birds of a Feather when it comes to arms! We should be able to swiftly set it up and send it over to you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“而且，若是关于军备方面的话，跟“Tori公”不同，我们还有一整天的时间！肯定在短时间内装备好并送过来的喔！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「而且，若是關於軍備方面的話，跟“Tori公”不同，我們還有一整天的時間！肯定在短時間內裝備好並送過來的喔！」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00183",
		linknext = "0043_00185",
		line = 2600,
	},
	["0043_00185"] = {
		{"fg", file="nanase_01f_00001", file1="nanase_01f_00101", file2="nanase_01f_00204", path=":fg/nanase_01f/", id=30, ch="奈々瀬", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0120", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“If we have this many people, we should be able to stir up some noise, attract their attention, and maybe even slip in without much trouble at all... This just might work!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“要是有这些人数的话，引起骚动也能够吸引到目光，我们也可以更轻易地潜入……说不订行得通──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「要是有這些人數的話，引起騷動也能夠吸引到目光，我們也可以更輕易地潛入……說不訂行得通──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00184",
		linknext = "0043_00186",
		line = 2613,
	},
