			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Welcome back... That was your 112th jump in total.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“欢迎回来⋯⋯加上这次的话总共弹跳了112次。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「歡迎回來⋯⋯加上這次的話總共彈跳了112次。」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00082",
		linknext = "0043_00084",
