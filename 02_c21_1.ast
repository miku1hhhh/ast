	["0043_00211"] = {
		{"fg", file="susuko_02m_00002", file1="susuko_02m_00101", file2="susuko_02m_00219", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0290", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“We got so shaken up back there and shot away at you like they said to do... But the truth is...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“当时我就懵了，好像是就照着大家说得把枪给放下了…….实际上呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「當時我就懵了，好像是就照著大家說得把槍給放下了…….實際上呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00210",
		linknext = "0043_00212",
		line = 2978,
	},
	["0043_00212"] = {
