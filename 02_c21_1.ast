	["0043_00161"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And while systems like her ECM must originate from her home PC, she must be remotely accessing it via that tablet of hers.",
					{"rt2"},
				},
			},
			cn = {
				{
					"尽管ECM之类的的根本是在家用电脑上进行操作的,但远程操控应该是她手边的那台平板。",
					{"rt2"},
				},
			},
			tw = {
				{
					"盡管ECM之類的的根本是在家用電腦上進行操作的,但遠程操控應該是她手邊的那台平板。",
					{"rt2"},
				},
