	["0043_00012"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Discrimination in the form of “what’s normal,” the idea that it’s only natural for men to be men, and for women to be women.",
					{"rt2"},
				},
			},
			cn = {
				{
					"男人就是男人、女人就是女人，从名称开始，天经地义般的歧视。",
					{"rt2"},
				},
			},
			tw = {
				{
					"男人就是男人、女人就是女人，從名稱開始，天經地義般的歧視。",
					{"rt2"},
				},
			},
		},
