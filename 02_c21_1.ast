				{"vo", file="nanase0118", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I do think that facing off against Hamedori directly would have the higher probability of success, though...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“要是选概率比较高的那个的话，肯定会直接跟Hamedori君对上的──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「要是選概率比較高的那個的話，肯定會直接跟Hamedori君對上的──」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00145",
		linknext = "0043_00147",
		line = 2057,
	},
	["0043_00147"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No. We won’t be able to win if we do that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，那样会赢不了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，那樣會贏不了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00146",
		linknext = "0043_00148",
		line = 2069,
	},
	["0043_00148"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", file2="nanase_01m_00219", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-205, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There’s no way for us to put up a fight against Hamedori as we are now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在的我们根本没有可以对付那个Hamedori君的办法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在的我們根本沒有可以對付那個Hamedori君的辦法。",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00147",
		linknext = "0043_00149",
		line = 2082,
	},
	["0043_00149"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Only defeat would await us if we challenged that thing to battle.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算开打，也只能吃下败果。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算開打，也只能吃下敗果。",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00148",
		linknext = "0043_00150",
		line = 2092,
	},
	["0043_00150"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There is just one way for us to put ourselves on the same level as the Armored Hamedori, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“能对付武装Hamedori君的办法只有一个。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「能對付武裝Hamedori君的辦法只有一個。」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00149",
		linknext = "0043_00151",
		line = 2104,
	},
	["0043_00151"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Asane’s assistance is an absolutely necessary component of that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“要做到那个，就不能少了麻沙音的帮忙。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「要做到那個，就不能少了麻沙音的幫忙。」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00150",
		linknext = "0043_00152",
		line = 2116,
	},
	["0043_00152"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In the end.",
					{"rt2"},
				},
			},
			cn = {
				{
					"果然，对我来说。",
					{"rt2"},
				},
			},
			tw = {
				{
					"果然，對我來說。",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00151",
		linknext = "0043_00153",
		line = 2126,
	},
	["0043_00153"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I just need to have Asane.",
					{"rt2"},
				},
			},
			cn = {
				{
					"麻沙音是无论如何都不可或缺的一个存在。",
					{"rt2"},
				},
			},
			tw = {
				{
					"麻沙音是無論如何都不可或缺的一個存在。",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00152",
		linknext = "0043_00154",
		line = 2136,
	},
	["0043_00154"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00210", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0793", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“If that’s how you feel, then let’s defeat Asane and drag her over to our side.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“按前辈这么说的话，我们就把麻沙音同学给打倒，把她拉到我们的阵营来吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「按前輩這麼說的話，我們就把麻沙音同學給打倒，把她拉到我們的陣營來吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00153",
		linknext = "0043_00155",
		line = 2150,
	},
	["0043_00155"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00211", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1077", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“But it sounds like a lot of SHO members are standing by around the building...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“但是，大楼的周围似乎有不少SHO守着呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「但是，大樓的周圍似乎有不少SHO守著呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00154",
		linknext = "0043_00156",
		line = 2164,
	},
	["0043_00156"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00201", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0963", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Yeah, that would be a problem if we wanted to break through them... We’d all have to work together to throw them off, even in a best-case scenario.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“要突破的话，是啊……估计在怎么保守，也要在这里的所有人都不来捣乱才有可能吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「要突破的話，是啊……估計在怎麼保守，也要在這裡的所有人都不來搗亂才有可能吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00155",
		linknext = "0043_00157",
		line = 2178,
	},
	["0043_00157"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", file2="nanase_02m_00203", path=":fg/nanase_02m/", id=4, lv=4, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-205, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0119", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“It’ll be difficult for us to coordinate if Asa’s ECM is active. We should assume that changing our positions will be next to impossible.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“很难在麻纱酱的ECM运行时取得同步。变更配置之类的，基本上是不可能的呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「很難在麻紗醬的ECM運行時取得同步。變更配置之類的，基本上是不可能的呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00156",
		linknext = "0043_00158",
		line = 2193,
	},
	["0043_00158"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00203", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0794", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“And even if we do manage to get Tachibana to the top floor, there are those autonomous Armored Hamedoris there. It seems far from a promising plan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“而且就算把前辈你一个人送到了最顶层──在那边也会有自主型钢铁Hamedori君在等着你。这恐怕很难说服她的吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「而且就算把前輩你一個人送到了最頂層──在那邊也會有自主型鋼鐵Hamedori君在等著你。這恐怕很難說服她的吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00157",
		linknext = "0043_00159",
		line = 2208,
	},
	["0043_00159"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There’s a way to solve both of those problems—we break Asane’s tablet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“能解决那两个问题就只有──破坏掉麻沙音的平板了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「能解決那兩個問題就只有──破壞掉麻沙音的平板了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00158",
		linknext = "0043_00160",
		line = 2220,
	},
