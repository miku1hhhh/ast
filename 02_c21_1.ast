		text = {
			vo = {
				{"vo", file="nanase0113", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I think that’s the normal reaction to have... And wait, why not just have this lifeline attached to you from the start...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“虽然说这是正常的反应⋯⋯不过你一开始就用救生索不就好了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「雖然說這是正常的反應⋯⋯不過你一開始就用救生索不就好了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00084",
		linknext = "0043_00086",
		line = 1135,
	},
	["0043_00086"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00305", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Because then I won’t feel like my life is in danger. There’d be no point in this training.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样的话就没有办法感受到有生命危险。也就没有训练的意义了啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣的話就沒有辦法感受到有生命危險。也就沒有訓練的意義了啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00085",
		linknext = "0043_00087",
		line = 1147,
	},
	["0043_00087"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00102", file2="hinami_02m_00206", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0092", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“But you did just barely bump into the ground earlier when the president sneezed and messed up her timing...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“不过刚才桐香在接的时候打了个喷嚏，你有点擦到地面了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「不過剛才桐香在接的時候打了個噴嚏，你有點擦到地面了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00086",
		linknext = "0043_00088",
		line = 1161,
	},
	["0043_00088"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00210", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
