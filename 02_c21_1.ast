			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“No, I remember Tachibana as being a little more reserved... Maybe it’s my fault he turned out like this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“没有啊，我记忆里的橘君也是比较拘谨一点的人没错⋯⋯果然是我不太会看人吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「沒有啊，我記憶裡的橘君也是比較拘謹一點的人沒錯⋯⋯果然是我不太會看人嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00115",
		linknext = "0043_00117",
		line = 1597,
	},
	["0043_00117"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00211", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-205, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1076", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Really? Darling’s always been like that in our world. He’s constantly making so much noise, and he’s so hot-blooded that his veins might burst, even though he tries to act cool.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“欸──在我们世界的那个亲爱的一直都是这种感觉喔？一直都很吵，想要装得冷酷却因为太热血了所以就是看起来很热血的模样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「欸──在我們世界的那個親愛的一直都是這種感覺喔？一直都很吵，想要裝得冷酷卻因為太熱血了所以就是看起來很熱血的模樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00116",
		linknext = "0043_00118",
		line = 1611,
	},
	["0043_00118"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file3="rei_01m_00309", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
