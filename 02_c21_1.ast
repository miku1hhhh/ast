	["0043_00162"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If the SHO really is on high alert, though, it should be nearly impossible to sneak into my home and cut off the signal at the source.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，如果SHO认真地戒备起来的话，要潜入橘家并切断源头的话，基本来说是不可能的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，如果SHO認真地戒備起來的話，要潛入橘家並切斷源頭的話，基本來說是不可能的。",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00161",
		linknext = "0043_00163",
		line = 2273,
	},
