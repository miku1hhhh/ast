					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "一般青蓝岛人A"},
					"“软趴趴的一点都不像个男人⋯⋯既然有肉棒的话那就认真点勃起啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "一般青藍島人A"},
					"「軟趴趴的一點都不像個男人⋯⋯既然有肉棒的話那就認真點勃起啊！」",
					{"rt2"},
				},
			},
		},
