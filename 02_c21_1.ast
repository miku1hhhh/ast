				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“But if he’s making this much noise, I guess it means he’s managed to sleep off the damage he took earlier...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嘛，能这么吵的话，应该是经过一个晚上总算把那时候的伤都养好了吧──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嘛，能這麼吵的話，應該是經過一個晚上總算把那時候的傷都養好了吧──」",
					{"rt2"},
				},
			},
		},
