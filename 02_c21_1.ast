		{"fg", file="misaki_01m_00001", file1="misaki_01m_00102", file2="misaki_01m_00214", path=":fg/misaki_01m/", id=6, lv=6, head="misaki_01m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0133", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I’ve always imagined him as having a really annoyed expression, but was he always this ridiculous of a person, Nanase?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“在我的印象里他总是板着一张脸，难道他从以前就是这种会乱来的人吗，奈奈濑同学？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「在我的印象裡他總是板著一張臉，難道他從以前就是這種會亂來的人嗎，奈奈瀨同學？」",
					{"rt2"},
				},
			},
		},
		linkback = "0043_00114",
		linknext = "0043_00116",
		line = 1580,
	},
	["0043_00116"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", file2="nanase_01m_00210", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
