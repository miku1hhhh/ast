					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“A bump is fine. I’ve worked on my body.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只是擦到而已没关系，这是训练嘛。”",
