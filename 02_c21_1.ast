		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Formerly an engineer, it seems that he even worked on designing fighter planes in the past.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他以前是个工程师，似乎曾经参与过战斗机的设计。",
