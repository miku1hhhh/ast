		{"fg", file="schubert_01m_00001", file2="schubert_01m_00205", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=13, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=-355, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0426", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Precisely. I don’t have any data on it, but I’m fairly certain that any new character with glasses would be dead in the water.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“对啊。虽然我的数据库里没有，但戴眼镜的角色应该不受欢迎吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「對啊。雖然我的數據庫裡沒有，但戴眼鏡的角色應該不受歡迎吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00017",
		linknext = "0123_00019",
		line = 299,
	},
	["0123_00019"] = {
		{"fg", file="mizuhiki_01m_00001", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00229", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=345, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
