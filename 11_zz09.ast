			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Yeah, I agree. If you were to put a new character with glasses into this game... it would just seem really out of touch.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“我和你们意见一致。如今还在〇〇游戏里推出眼镜角色……嗯，这种行为可以说是没搞懂时代的变迁。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「我的意見也一樣。如今還在成人遊戲裡推出眼鏡角色……嗯，我覺得是沒搞懂時代的變遷。」",
					{"rt2"},
				},
			},
		},
