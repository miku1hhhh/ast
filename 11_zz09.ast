		{"cgdel", id=18, time=0, alphadel=1, lv=18},
		{"cgact", file="cgact", act="表示アクション", alpha=0, id=2, lv=2, time=300, alphadel=1, style="reset"},
		{"fg", file="ran_01m_00001", file1="ran_01m_00102", file2="ran_01m_00209", file4="ran_01m_00401", path=":fg/ran_01m/", id=13, lv=13, head="ran_01m", ch_origin="蘭", ch="蘭13", mw="mw", sync=0, mode=3, x=695, y=-5},
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", file2="misaki_01m_00222", file4="misaki_01m_00401", path=":fg/misaki_01m/", id=6, lv=6, head="misaki_01m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"fg", file="teshima_01m_00001", file2="teshima_01m_00219", path=":fg/teshima_01m/", id=16, lv=16, head="teshima_01m", ch_origin="手嶋", ch="手嶋16", mw="mw", sync=0, mode=3, x=-705, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="teshima0017", path=":vo/", ch="teshima"},
			},
			ja = {
				{
					name = {"手嶋"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"手嶋", "Teshima"},
					"“Are ya crazy?! In our industry, ‘glasses’ is basically a synonym for ‘unpopular!’ And every man of culture knows it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"手嶋"},
					"“你没疯吧！？在这个业界里，眼镜可是没人气的代名词啊！这在任侠界可是常识！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"手嶋"},
					"「妳沒瘋吧！？在這個業界裡，眼鏡可是沒人氣的代名詞喔！這在俠義界可是常識！」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00014",
		linknext = "0123_00016",
		line = 250,
	},
	["0123_00016"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"transitiontime", time=300},
		{"fgact", ch="美岬6", id=6, act="振動下", loop=2, size=-25, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1368", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Exactly! In fact, the normal standard number of glasses girls in games these days is ",
					{"exfont", style="italic"},
					"ZERO[/i]!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“没错！最近〇〇游戏里没有半个眼镜角色可以说是主流──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「沒錯！最近成人遊戲裡沒有半個眼鏡角色可以說是主流──」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00015",
		linknext = "0123_00017",
		line = 265,
	},
	["0123_00017"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00228", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=6},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It would be the height of stupidity to give a new character ",
					{"exfont", style="italic"},
					"glasses[/i], of all things, as a ploy for attention! We’re all on the same page about that, right?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“让备受瞩目的新角色戴眼镜根本就是愚蠢至极！大家也这么觉得吧！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「讓受到關注的新角色戴眼鏡根本愚蠢至極！大家也這麼覺得吧！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0123_00016",
		linknext = "0123_00018",
		line = 277,
	},
	["0123_00018"] = {
