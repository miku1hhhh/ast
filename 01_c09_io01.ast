			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I’ve only heard her name. It was... Fumiko Kotobuki, if I remember right.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“只是名字的话我倒是听过喔。记得是叫……琴吹史子吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「只是名字的話我倒是聽過喔。記得是叫……琴吹史子吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00079",
		linknext = "0001_00081",
		line = 1210,
	},
	["0001_00081"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00219", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It was a woman? Come to think of it, that sounds a lot like Fumino’s name.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“原来是女性吗……而且名字跟文乃还真是难以言喻地像啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「原來是女性嗎……而且名字跟文乃還真是難以言喻地像啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00080",
