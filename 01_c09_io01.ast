		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file2="ikuko_02m_00213", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0219", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Hmm... There was a lot of resistance when the law first went into effect. I think making those kinds of puns out of familiar words was one way they adjusted.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嗯……毕竟在条例刚出来的时候，据说大家对色色的抵抗感还很强嘛。是不是想透过身边常见的词语一点一点让大家习惯呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嗯……畢竟在條例剛出來的時候，據說大家對色色的抵抗感還很強嘛。是不是想透過身邊常見的詞語一點一點讓大家習慣呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00141",
		linknext = "0001_00143",
		line = 2097,
	},
	["0001_00143"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00201", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
