				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You have a pretty big appetite. You were stuffing your face at every booth too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“郁子也挺能吃的呢。刚才明明在摊贩上吃过不少东西了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「郁子也挺能吃的呢。剛才明明在攤販上吃過不少東西了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00159",
