		text = {
			vo = {
				{"vo", file="ikuko0183", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Location spotting and security training. It’s our job to make sure nothing goes wrong on the day of the big game and we don’t hit any bumps. Everything should be as smooth as Hinami’s chest.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“现场的调整和警备指导。如果跟雏见酱的胸部一样平铺直述，就是要我们‘为了不要在大蜜穴逃脱当天发生什么问题先给我准备好’的意思。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「現場的調整和警備指導。如果跟雛見醬的胸部一樣平舖直述，就是要我們『為了不要在大蜜穴逃脫當天發生什麼問題先給我準備好』的意思。」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00017",
		linknext = "0001_00019",
		line = 317,
	},
	["0001_00019"] = {
