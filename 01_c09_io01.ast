	["0001_00117"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Pressure from the mainland through Sakimori already got the perverted sex law abolished once in World A.",
					{"rt2"},
				},
			},
			cn = {
				{
					"实际上在A世界里，因为驻防老人带来的本岛的压力──变态条例也曾经有一度完全瓦解。",
					{"rt2"},
				},
			},
			tw = {
				{
					"實際上在A世界裡，因為駐防老人帶來的本島的壓力──變態條例也曾經有一度完全瓦解。",
