			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Probably. Either way, at this point it’s ingrained. No one thinks twice about whether they enjoy fucking anymore.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“或许吧。唉，虽然现在已经完全流于形式了啦。毕竟大家都觉得做爱很快乐是理所当然的了嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「或許吧。唉，雖然現在已經完全流於形式了啦。畢竟大家都覺得做愛很快樂是理所當然的了嘛。」",
					{"rt2"},
				},
			},
