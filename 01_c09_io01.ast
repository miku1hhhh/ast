		text = {
			vo = {
				{"vo", file="ikuko0223", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“*munch, munch* Well, my parents made sure I was always stuffed, so I could be ready for any situation, you know? I’m totally good to fight on a full stomach.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嚼嚼……嗯～。还可以吧，毕竟在老家的时候还为了要让我在任何状态之下都能够战斗，还被硬弄成满腹状态过嘛。就吃这点东西，我还是可以普通地战斗的喔？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嚼嚼……嗯～。還可以吧，畢竟在老家的時候還為了要讓我在任何狀態之下都能夠戰鬥，還被硬弄成滿腹狀態過嘛。就吃這點東西，我還是可以普通地戰鬥的喔？」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00160",
		linknext = "0001_00162",
		line = 2343,
	},
	["0001_00162"] = {
