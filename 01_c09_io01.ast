			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oooh, look at all these booths! One cockolate banana, please! And a cotton cum-dy! Let me get down and dirty with a preggo pita too! Huh? Hello?! Is anybody there? Hey!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“呜呵～有好多摊位喔！啊，请给我一根老二立香蕉！还有那话糖！然后让我在沙为妈感受一下母爱！咦咦！喂喂！？还是没注意到我！？喂～！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「嗚呵～有好多攤位喔！啊，請給我一根老二立香蕉！還有那話糖！然後讓我在沙為媽感受一下母愛！咦咦！喂喂！？還是沒注意到我！？喂～！！」",
					{"rt2"},
				},
			},
		},
