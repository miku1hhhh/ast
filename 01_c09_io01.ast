	["0001_00146"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When I think about all this being the sick plan of depressingly lecherous sex addicts to reduce the people’s reluctance to fuck... it makes me sick.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果说是积极到让人郁闷的色色推进派为了减少对色色的抵抗感而想出的方法──真让人想想都无语。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果說是積極到讓人鬱悶的色色推進派為了減少對色色的抵抗感而想出的方法──真讓人想想都無語。",
					{"rt2"},
				},
			},
