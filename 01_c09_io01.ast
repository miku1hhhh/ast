	},
	["0001_00147"] = {
		{"fgact", ch="郁子10", id=10, lv=10, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And to be honest, I’ve felt my own reluctance toward that sort of thing slowly slipping away since I’ve been back.",
					{"rt2"},
				},
			},
			cn = {
				{
					"确实，在回到岛上后至今为止的日子里──我对那类事物的抵抗感也逐渐消失了。",
					{"rt2"},
				},
			},
			tw = {
				{
