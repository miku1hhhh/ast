		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0254", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“What was I supposed to do, let her hit me? I could see those punches coming from a mile away!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“因为挨下那种简单易懂的拳头不是很丢脸吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「因為挨下那種簡單易懂的拳頭不是很丟臉嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00259",
		linknext = "0001_00261",
		line = 3843,
	},
	["0001_00261"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00220", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
