	["0001_00032"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00219", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Strike force... Does that mean she’s your direct subordinate? I’ve never seen her before.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“强袭部队──也就是说，是郁子直属的部下吗？我还是第一次见到……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「強襲部隊──也就是說，是郁子直屬的部下嗎？我還是第一次見到……」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00031",
		linknext = "0001_00033",
		line = 503,
	},
	["0001_00033"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file3="ikuko_01m_00314", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
