			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“With a parent like that, she must be someone interesting.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“既然有那样的家长，小孩想必也色彩浓烈吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「既然有那樣的家長，小孩想必也色彩濃烈吧。」",
