			},
			cn = {
				{
					"郁子把整套商品大致都塞进了肚子哩，然后擦了擦嘴。",
					{"rt2"},
				},
			},
			tw = {
				{
					"郁子把整套商品大致都塞進了肚子哩，然後擦了擦嘴。",
					{"rt2"},
