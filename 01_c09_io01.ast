	["0001_00045"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0029", path=":vo/", ch="gmob"},
			},
			ja = {
				{
					name = {"モブ女C", "チンコバナナちゃん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Cockolate ’Nana"},
					"“I’m glad you asked! We have two types of chocolate, dark and pink! Plus, we drizzled a little of our original white chocolate blend on the tip to stand in for that tasty love juice!❤”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "老二立香蕉酱"},
					"“是的！这次我们准备了黑色和粉色两种颜色♪另外！龟头部分滴上了我们独家调制的白巧克力，好表现出前列腺液的感觉",
