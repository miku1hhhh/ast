	["0001_00077"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ikuko stuffs the rest of her banana into her mouth and wipes it with her handkerchief.",
					{"rt2"},
