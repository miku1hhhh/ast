		{"text"},
		delay = {
			[5400] = {
				{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file3="ikuko_01m_00312", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, timestamp=7, delay2=5400, mode=3, x=-5, y=-5},
			},
			[5399] = {
				{"transitiontime", time=300, timestamp=7, delay2=5400},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko0188", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“She’s not very good about following directions. Something with her simian brain. I asked her to help set up today but as you can see, she’s just stuffing her mouth full of nanners.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“这孩子因为脑袋里面过于只剩下肌肉，所以就算下了指示也不会乖乖跟上来呢。今天也是，我明明叫她去帮忙布置场地了，可是却不知道为什么正在到处吃香蕉不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「這孩子因為腦袋裡面過於只剩下肌肉，所以就算下了指示也不會乖乖跟上來呢。今天也是，我明明叫她去幫忙布置場地了，可是卻不知道為什麼正在到處吃香蕉不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00032",
		linknext = "0001_00034",
		line = 521,
	},
	["0001_00034"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00214", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I’m surprised she has a position in the FS at all...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真亏她能留在FS的精锐部队里啊……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真虧她能留在FS的精銳部隊裡啊……？」",
