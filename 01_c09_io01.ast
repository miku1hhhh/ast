		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But still... going against the mainland would take careful preparation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可是──如果是来自本岛的对象，想必是不论如何都不得不采取慎重的态度吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可是──如果是來自本島的對象，想必是不論如何都不得不採取慎重的態度吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00115",
