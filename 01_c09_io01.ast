			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Only at restaurants. I guess there were some complaints from the tourists. Stuff like ordering a chocolate milk but getting it with jizz in it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“也就只有餐厅之类的才有就是了～。说是因为收到了很多次观光客的投诉。‘我点了巧克力牛奶结果里面混着精液，害我不小心喝下去了耶！？’那种。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「也就只有餐廳之類的才有就是了～。說是因為收到了很多次觀光客的投訴。『我點了巧克力牛奶結果裡面混著精液，害我不小心喝下去了耶！？』那種。」",
					{"rt2"},
				},
			},
		},
