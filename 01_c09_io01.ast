	},
	["0001_00035"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file3="ikuko_02m_00306", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0189", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“The first squad is kind of like that. They get stuck with the rejects from the other squads.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“一队就是这样的啦。其他部队处理不来的孩子通常都会被推给我们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「一隊就是這樣的啦。其他部隊處理不來的孩子通常都會被推給我們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00034",
		linknext = "0001_00036",
		line = 548,
	},
	["0001_00036"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00213", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0027", path=":vo/", ch="gmob"},
			},
			ja = {
				{
					name = {"モブ女C", "クールそうなFS女子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Cool-Looking FS Girl"},
					"“There you are! Did you forget what we’re supposed to be doing today?! Ah! C-Commander One-butt! Your Sexellency! My sincerest apologies for Gori’s behavior!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "有点酷的FS女子"},
					"“大只女同学……总算找到你了。你忘记我们今天的职责了吗？……啊！田、田中队长！连性帝也在！大只女同学的事情真是太抱歉了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "有點酷的FS女子"},
					"「大隻女同學……總算找到妳了。妳忘記我們今天的職責了嗎？……啊！田、田中隊長！連性帝也在！大隻女同學的事情真是太抱歉了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00035",
		linknext = "0001_00037",
		line = 563,
	},
	["0001_00037"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00218", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
