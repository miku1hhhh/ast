			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Yeah. Supposedly she changed her name after she got married, but I heard she has a daughter in the A-level class.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“对吧。虽然听说现在已经结婚了，姓氏也不一样了。还有，据说那人的小孩现在正在就读学园的A等部喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「對吧。雖然聽說現在已經結婚了，姓氏也不一樣了。還有，據說那人的小孩現在正在就讀學園的A等部喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00081",
		linknext = "0001_00083",
		line = 1240,
	},
	["0001_00083"] = {
