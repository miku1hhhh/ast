			cn = {
				{
					"我放了一口菜到嘴里。虽然是爱爱烧烤生殖这种用尽全力意图使人食欲减退的名字，可是吃起来倒是挺香的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我放了一口菜到嘴裡。雖然是愛愛燒烤生殖這種用盡全力意圖使人食慾減退的名字，可是吃起來倒是挺香的。",
					{"rt2"},
				},
			},
		},
