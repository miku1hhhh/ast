				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I can’t deny their skills, though... Anyway, getting back on topic—tell me about these cockolate bananas of yours.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“她们确实也很有实力就是了啦。……然后呢，老二立香蕉酱。所谓超级唔齁的老二立香蕉又是怎样的东西呢？”",
