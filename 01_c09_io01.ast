			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I’ll spare you the details since we’re eating, but I can empty my stomach in a pinch, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“因为在吃饭的时候说这些有点没品，所以我平时是不太说的，但是就算要把胃袋整个排空也是轻轻松松喔！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「因為在吃飯的時候說這些有點沒品，所以我平時是不太說的，但是就算要把胃袋整個排空也是輕輕鬆鬆喔！」",
					{"rt2"},
				},
			},
		},
