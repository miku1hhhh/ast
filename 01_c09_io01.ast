	["0001_00149"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There is no thought without language. People need words to express the concepts behind them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"人类在思考的时后，言语是必不可少的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"人類在思考的時後，言語是必不可少的。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00148",
		linknext = "0001_00150",
		line = 2184,
	},
	["0001_00150"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It seems so simple now. The path to perverted law has been paved through the very words they speak, slinking its way into the minds of these islanders without them even noticing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"首先从言语开始侵蚀，然后让条例一点一点地浸透到大家的思想之中──感觉好像能看出这样的路线规划。",
					{"rt2"},
				},
			},
			tw = {
				{
					"首先從言語開始侵蝕，然後讓條例一點一點地浸透到大家的思想之中──感覺好像能看出這樣的路線規劃。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00149",
		linknext = "0001_00151",
		line = 2194,
	},
