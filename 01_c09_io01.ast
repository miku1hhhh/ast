					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Cool Fool"},
					"“Come on, Gorillina, we have to get back to preparing! Now we’ll have to run to make up for the time we lost! That means 20 kilos worth of reflection!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "蠢酷"},
					"“大只女同学，快点回去帮忙布置吧。动作快一点，为了弥补进度得要用跑的回去了……说的也是……为了表示反省，就跑个20公里吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "蠢酷"},
					"「大隻女同學，快點回去幫忙布置吧。動作快一點，為了彌補進度得要用跑的回去了……說的也是……為了表示反省，就跑個20公里吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00039",
		linknext = "0001_00041",
		line = 622,
	},
