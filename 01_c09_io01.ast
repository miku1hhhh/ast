	["0001_00113"] = {
		{"fgact", ch="郁子10", id=10, lv=10, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When it comes down to it, this is a tourist spot. It seems they do have to cater to their clientele.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可是说来说去这座岛都是观光地──对于顾客所说的话，似乎还是有意外地老实的时候。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可是說來說去這座島都是觀光地──對於顧客所說的話，似乎還是有意外地老實的時候。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00112",
		linknext = "0001_00114",
		line = 1734,
	},
	["0001_00114"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For one, non-coital perverted acts are restricted during the XXX Olympiad to prepare everyone for their lustful arrival.",
					{"rt2"},
				},
			},
			cn = {
				{
					"好比说在体欲节之类的活动里，为了因应观光客的参与，竞赛内容会被限制为性交以外的色色行为。",
					{"rt2"},
				},
			},
			tw = {
				{
					"好比說在體慾節之類的活動裡，為了因應觀光客的參與，競賽內容會被限制為性交以外的色色行為。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00113",
		linknext = "0001_00115",
		line = 1744,
	},
	["0001_00115"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If the protest earlier had been arranged by islanders, they would have been branded as anti-copulators and crushed with impunity.",
					{"rt2"},
				},
			},
			cn = {
				{
					"以前的抗议活动也一样，如果参与的是岛上的居民，肯定马上就会被认定为反交尾势力、被武力镇压才对。",
					{"rt2"},
				},
			},
			tw = {
				{
					"以前的抗議活動也一樣，如果參與的是島上的居民，肯定馬上就會被認定為反交尾勢力、被武力鎮壓才對。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00114",
		linknext = "0001_00116",
		line = 1754,
	},
	["0001_00116"] = {
