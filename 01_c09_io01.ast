			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Apparently at first they forced everyone to make jokes and act like they were enjoying themselves.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“在做爱之类的时候，不也说一开始要故意说点有趣的话，好营造出愉快的气氛吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「在做愛之類的時候，不也說一開始要故意說點有趣的話，好營造出愉快的氣氛嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00142",
		linknext = "0001_00144",
		line = 2112,
	},
	["0001_00144"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Could that be why the people here have that weird way of moaning?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……你不会是在说──这座岛上的人总是会喊出异常有趣的娇喘，就是因为这个吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……妳不會是在說──這座島上的人總是會喊出異常有趣的嬌喘，就是因為這個吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00143",
		linknext = "0001_00145",
		line = 2124,
	},
	["0001_00145"] = {
