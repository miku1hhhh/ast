	["0001_00078"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00214", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0200", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“People say there was a student who came up with some kind of pervy proverbs when the perverted sex law was first enacted. They stuck, and the idea spread.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“据说是在制定变态条例当时的某个学生起的头……然后那人开始制作起了变态谚语，受到周遭的好评，于是才广为流传的喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「據說是在制定變態條例當時的某個學生起的頭……然後那人開始製作起了變態諺語，受到周遭的好評，於是才廣為流傳的喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00077",
		linknext = "0001_00079",
		line = 1180,
	},
	["0001_00079"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00205", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I’d like to meet whoever that was...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“起头的那人到底是谁啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「起頭的那人到底是誰啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00078",
		linknext = "0001_00080",
		line = 1192,
	},
	["0001_00080"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00213", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
