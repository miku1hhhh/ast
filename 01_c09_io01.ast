	["0001_00259"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00213", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That’s because you dodged every single punch and they all ended up hitting me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“还不是因为你闪过了礼前辈所有的攻击……！就是因为这样我才要额外受气……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「還不是因為妳閃過了禮前輩所有的攻擊……！就是因為這樣我才要額外受氣……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00258",
		linknext = "0001_00260",
		line = 3828,
	},
	["0001_00260"] = {
		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file3="ikuko_02m_00306", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
