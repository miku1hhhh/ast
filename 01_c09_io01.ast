	["0001_00262"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Despite my deriding Ikuko for escaping judgement, I had actually tried to dodge like she did—which resulted in me getting smacked upside the head.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说是这么说，但是我也学着郁子，尝试过闪躲攻击──可是却漂亮地被打中了脑门。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說是這麼說，但是我也學著郁子，嘗試過閃躲攻擊──可是卻漂亮地被打中了腦門。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00261",
		linknext = "0001_00263",
		line = 3865,
	},
	["0001_00263"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I wasn’t able to anticipate the coming blows before they struck.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在闪躲之前，就连看都看不清楚。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在閃躲之前，就連看都看不清楚。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00262",
		linknext = "0001_00264",
		line = 3875,
	},
	["0001_00264"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Watching Ikuko phase around Rei’s attacks without even standing up from her kneeling position made me realize her visual acuity is way off the charts.",
					{"rt2"},
				},
			},
			cn = {
				{
					"能够在正座的姿势下轻松闪过那些攻击，几乎已经是可以上街头卖艺的等级了──让我重新体会到郁子的动态势力究竟有多么卓越。",
					{"rt2"},
				},
			},
			tw = {
				{
					"能夠在正座的姿勢下輕鬆閃過那些攻擊，幾乎已經是可以上街頭賣藝的等級了──讓我重新體會到郁子的動態勢力究竟有多麼卓越。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00263",
		linknext = "0001_00265",
		line = 3885,
	},
