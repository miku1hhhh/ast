				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“‘When there’s a countdown, you never know if 0 is the moment the protagonist c*ms or if it’s the click after,’ ‘there’s a visible trend in the writer’s fetishes...’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“还有‘〇〇倒计时的时候，搞不清究竟是变成零的那一刻就〇还是零之后再〇’，以及‘最好〇的场景往往就那么几个’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「『常常搞不懂是射精倒數變成零時射精還是零之後射精』、『結果使用的場景常常是那幾個』。」",
					{"rt2"},
				},
			},
		},
