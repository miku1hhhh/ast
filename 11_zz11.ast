		text = {
			vo = {
				{"vo", file="sutohka0142", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Sorry. We also would have accepted ‘they’re lax with contraception,’ ‘The guy turns see-through,’ ‘The guy yells “I’m c’mming!” exactly one click out,’ ‘The guy’s c*ck size changes every CG...’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“很遗憾。其他还有‘男女主的避孕观念让人震惊’、‘通常会把男主的身体画成透明’、‘〇〇场景的前一句台词通常是“要〇了！”’、‘不同CG里，〇〇的大小也往往不同’。 ”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「很可惜。其他還有『常常沒有避孕觀念』、『主角的身體常常變透明』、『射精前一句常常是「要射了！！」』、『陰莖的大小常常隨著圖改變』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0125_00028",
		linknext = "0125_00030",
		line = 537,
	},
	["0125_00030"] = {
