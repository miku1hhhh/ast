			en = {
				{
					name = {"郁子", "Ikuko"},
					"“The last Friday of every month is Eroge Day, when all the p*rn games drop, so I have a marathon shl*ckfest all weekend, and then on Monday, Darling and I compare notes! It’s a blast!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“每个月的最后一个星期五是黄油发售日，也就是超级色色日，我会用星期五外加一整个周末来一场黄油马拉松，爽个不停，到了星期一再去跟亲爱的讨论感想！这超有趣的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「從月底星期五的成人遊戲日通稱白金成人日開始到六日的淫蕩成人遊戲馬拉松，星期一再跟親愛的討論感想！這超有趣的！」",
					{"rt2"},
				},
			},
