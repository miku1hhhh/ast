		{"cgact", file="cgact", id=27, act="移動", x=-100.5, y=0, time=1000, lv=27},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0609", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Heh heh. Controlling threads of any kind is my specialty. I’ll send her all around school until she gets tired and falls asleep to make sure she stays away from the base.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘嘻嘻、操控线之类的不过是小菜一碟。我会让文乃同学追着毛线在学校里到处跑直到筋疲力竭睡着，不会让她有机会靠近基地的。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『嘻嘻、操控線之類的不過是小菜一碟。我會讓文乃同學追著毛線在學校裡到處跑直到筋疲力竭睡著，不會讓她有機會靠近基地的。』",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00144",
		linknext = "0030_00146",
		line = 2088,
	},
