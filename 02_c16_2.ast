	["0030_00211"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0027", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Indeed. His attitude changed completely the moment he secured Fumino. That wretched little boy...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘没错。在保护了文乃之后，马上就翻脸不认人了。真是可恶的小子──’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『沒錯。在保護了文乃之後，馬上就翻臉不認人了。真是可惡的小子──』",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00210",
		linknext = "0030_00212",
		line = 3058,
	},
	["0030_00212"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He seems to spit the words out as he says them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"令人作恶。老人这么说。",
					{"rt2"},
				},
			},
			tw = {
				{
					"令人作噁。老人這麼說。",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00211",
