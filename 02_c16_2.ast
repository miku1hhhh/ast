	["0030_00072"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00214", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[7000] = {
				{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, timestamp=6, delay2=7000, mode=3, x=-5, y=-5},
			},
			[6999] = {
				{"transitiontime", time=300, timestamp=6, delay2=7000},
			},
		},
		text = {
			vo = {
				{"vo", file="tohka0606", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“But due to the effect of my overwritten memories, I was unsure of who is missing and who has been added. I’m sorry, Tachibana.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“但是，由于记忆覆盖的影响，我不知道究竟是少了谁、又多了谁。很对不起，前辈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「但是，由於記憶覆蓋的影響，我不知道究竟是少了誰、又多了誰。很對不起，前輩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00071",
		linknext = "0030_00073",
		line = 995,
	},
	["0030_00073"] = {
