		text = {
			vo = {
				{"vo", file="misaki0077", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ugh, I’m starving. History class really makes you so hungry with all those people whose names remind you of food, like Julius Caesar and Francis Bacon... Hm? What’s this rich, meaty aroma...?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“唔唔，好饿啊。果然历史课上出现查理鳗大帝和小野莓子之类跟食物很像的名字就让我觉得饿了……嗯，这浓厚的肉香是──！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「唔唔，好餓啊。果然歷史課上出現查理鰻大帝和小野莓子之類跟食物很像的名字就讓我覺得餓了……嗯，這濃厚的肉香是──！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00113",
		linknext = "0030_00115",
		line = 1553,
	},
	["0030_00115"] = {
		{"se", id=3, loop=1, file="se_a173"},
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00202", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", alpha=0, ch_origin="郁子", ch="郁子10", mw="mw", sync=1, a_chr151=1, mode=3, x=595, y=-5},
		{"fgact", ch="郁子10", id=10, lv=10, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="郁子10", id=10, act="移動", x=-200, y=0, time=700},
		{"fgact", ch="美岬6", id=6, act="移動", x=-400, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0759", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Come right on by! Today’s a special FS clearance! We’ve got young ladies and tender cuts of meat, or as we call it, the Miss Steaks of Youth sale!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“欢迎光临！今天是FS的清仓大拍卖喔！“可以尽情大啖肉类跟美少女的大促销”简称“啖美肉”热销中喔！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「歡迎光臨！今天是FS的清倉大拍賣喔！「可以盡情大啖肉類跟美少女的大促銷」簡稱「啖美肉」熱銷中喔！」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00114",
		linknext = "0030_00116",
		line = 1570,
	},
	["0030_00116"] = {
		{"fg", file="misaki_02m_00001", file1="misaki_02m_00101", file3="misaki_02m_00305", path=":fg/misaki_02m/", id=6, lv=6, head="misaki_02m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-405, y=-5},
