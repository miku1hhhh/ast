					{"rt2"},
				},
			},
			en = {
				{
					"Which is why I’m having dreams that belong to the person whose position I swapped into...",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以我才会梦见被我替代了的他所做的梦，之类的──",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以我才會夢見被我替代了的他所做的夢，之類的──",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00057",
		linknext = "0030_00059",
		line = 804,
	},
	["0030_00059"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00214", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0602", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I’m unsure if this has anything to do with that—but it seems that the gender ratio of this world’s Minotsuki Academy differs from our world.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不知道是不是跟那个有关，这个世界的水月学园和我们的世界，男女生的比例好像不太一样啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不知道是不是跟那個有關，這個世界的水月學園和我們的世界，男女生的比例好像不太一樣啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00058",
		linknext = "0030_00060",
		line = 819,
	},
	["0030_00060"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00219", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
