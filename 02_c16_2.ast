	["0030_00064"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00219", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There’s an extra girl in this world...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这边的世界，女学生多了一名⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這邊的世界，女學生多了一名⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00063",
		linknext = "0030_00065",
		line = 882,
	},
	["0030_00065"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00204", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0604", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I thought that perhaps the numbers were off and performed a count myself, but I reached the same conclusion. I did of course include the absent Asane and the cross-dressing Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我怀疑数字是不是有误，所以我实际上数了数，但它们与这份文件的数字相同。当然，这包括了缺席的麻纱音同学，还有男装的文乃同学。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我懷疑數字是不是有誤，所以我實際上數了數，但它們與這份文件的數字相同。當然，這包括了缺席的麻紗音同學，還有男裝的文乃同學。」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00064",
		linknext = "0030_00066",
		line = 897,
	},
	["0030_00066"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00209", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You hand-counted everyone...? And wait, you remember the gender ratio of our school in our old world?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你都数过了吗⋯⋯？还是说，你还记得前一个世界的比例吗⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳都數過了嗎⋯⋯？還是說，妳還記得前一個世界的比例嗎⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00065",
		linknext = "0030_00067",
		line = 909,
	},
	["0030_00067"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0605", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I do, as I’m the student council president. That much is the bare minimum.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“是的，因为我是学生会长。这不是应该的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「是的，因為我是學生會長。這不是應該的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00066",
		linknext = "0030_00068",
		line = 924,
	},
	["0030_00068"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00209", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
