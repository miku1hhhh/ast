			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Was there no discussion about money?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“他没有提到资金的事情吗？”",
