			},
			cn = {
				{
					"然后，我身前的监视器在杂讯过后浮现了一个身影。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後，我身前的監視器在雜訊過後浮現了一個身影。",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00195",
		linknext = "0030_00197",
		line = 2881,
	},
	["0030_00197"] = {
		{"se", id=0, stop=1, time=1000},
		{"bgm", file="bgm07", vol=100},
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file2="sakimori_01f_00201", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0023", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“...Ah. It’s been quite some time, boy. Though I was under the impression that you’d never be contacting me again.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘⋯⋯哦。好久不见了呢，小子。我还以为我再也不会收到你的联络了呢。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『⋯⋯哦。好久不見了呢，小子。我還以為我再也不會收到你的聯絡了呢。』",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00196",
		linknext = "0030_00198",
		line = 2896,
	},
	["0030_00198"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hey, I’m not happy about being here either. There’s something I just have to ask you, though...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我才不是因为想看你而来的。不过，我有无论如何也要问你的问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我才不是因為想看你而來的。不過，我有無論如何也要問你的問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00197",
		linknext = "0030_00199",
		line = 2908,
	},
	["0030_00199"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Every moment counts. I get straight to business.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无论如何这都是赞浪费时间。我立刻进入正题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無論如何這都是讚浪費時間。我立刻進入正題。",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00198",
		linknext = "0030_00200",
		line = 2918,
	},
	["0030_00200"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The leader here... of the ‘Birds of a Feather.’ He’s a guy, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这里──‘Tori公’的队长是个男的，没有错吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這裡──『Tori公』的隊長是個男的，沒有錯吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00199",
		linknext = "0030_00201",
		line = 2930,
	},
	["0030_00201"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0024", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Indeed... A young man of small stature. His body was not as well-developed as yours.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘没错⋯⋯他是个娇小的少年。跟你那发育了的体格不一样。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『沒錯⋯⋯他是個嬌小的少年。跟你那發育了的體格不一樣。』",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00200",
		linknext = "0030_00202",
		line = 2942,
	},
	["0030_00202"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00103", file2="jun_01f_00210", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh? Really? Heh, well I guess I do work out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“欸？是吗？唔、因为我有在做肌肉训练嘛──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「欸？是嗎？唔、因為我有在做肌肉訓練嘛──」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00201",
		linknext = "0030_00203",
		line = 2954,
	},
	["0030_00203"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0025", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“It was not my intention to praise you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘我不是在夸你⋯⋯’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『我不是在誇你⋯⋯』",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00202",
		linknext = "0030_00204",
		line = 2966,
	},
	["0030_00204"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You said you can barely contact him now... Why is that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你说你现在很难取得这边的联系，但是……这是为什么？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你說你現在很難取得這邊的聯繫，但是……這是為什麼？」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00203",
		linknext = "0030_00205",
		line = 2978,
	},
	["0030_00205"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It just doesn’t make sense.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，正常情况下应该是不可能的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，正常情況下應該是不可能的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00204",
		linknext = "0030_00206",
		line = 2990,
	},
	["0030_00206"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It takes funding to go on the run. The Birds of a Feather would have no choice but to stop their activities if you cut off their supply of money.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“逃亡是要花钱的。如果你切断你的资助，‘Tori公’的行动就不得不停止。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「逃亡是要花錢的。如果你切斷你的資助，『Tori公』的行動就不得不停止。」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00205",
		linknext = "0030_00207",
		line = 3002,
	},
	["0030_00207"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sakimori scowls.",
					{"rt2"},
				},
			},
			cn = {
				{
					"驻防老人皱了皱眉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"駐防老人皺了皺眉。",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00206",
		linknext = "0030_00208",
		line = 3012,
	},
	["0030_00208"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He glares at me for a bit, lets out a quiet sigh, then closes his eyes, as though he’s made up his mind about something.",
					{"rt2"},
				},
			},
			cn = {
				{
					"瞪了我一眼后，他轻轻叹了口气，像是下定了决心似的闭上了眼睛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"瞪了我一眼後，他輕輕嘆了口氣，像是下定了決心似的閉上了眼睛。",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00207",
		linknext = "0030_00209",
		line = 3022,
	},
	["0030_00209"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0026", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“...They did not agree to my conditions regarding funding.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘……资金的部分，是因为他们没有接受我们的条件。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『……資金的部分，是因為他們沒有接受我們的條件。』",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00208",
		linknext = "0030_00210",
		line = 3034,
	},
	["0030_00210"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Conditions...? You mean Fumino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“条件⋯⋯是文乃吗？”",
