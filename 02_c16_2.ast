	},
	["0030_00254"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0611", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“It isn’t necessarily to escape from the perverted sex law, is it? Just as Sakimori had an ulterior motive, with perversion and such being secondary to him.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不单只是为了逃避变态条例这种理由吧？驻防老人应该别有目的，变态法例什么的只不过是附带的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不單只是為了逃避變態條例這種理由吧？駐防老人應該別有目的，變態法例什麼的只不過是附帶的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00253",
		linknext = "0030_00255",
		line = 3578,
	},
