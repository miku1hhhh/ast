	["0030_00257"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg0300020501-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0763", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“If there’s anyone else out there who wants to get their hands on Fumino, it’d be the yakuza who’ve already been wiped out, and...”",
					{"rt2"},
				},
			},
			cn = {
