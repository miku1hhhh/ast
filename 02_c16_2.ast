			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“If it vanished in your mouth, that means it doesn’t count as eating it! Calorie free! Next one, bam!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“在嘴里就化掉的话就跟没有吃到一样的意思所以是零卡路里喔，来，下一盘！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「在嘴裡就化掉的話就跟沒有吃到一樣的意思所以是零卡路里喔，來，下一盤！」",
					{"rt2"},
				},
			},
		},
