	["0030_00070"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She remembered every student’s face, then visually confirmed the number and gender ratio of the student body...? Is that even possible?",
					{"rt2"},
				},
			},
			cn = {
				{
					"记住所有学生的脸，然后目测确认他们的人数和男女比例……这种事现实里真的做得到吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"記住所有學生的臉，然後目測確認他們的人數和男女比例……這種事現實裡真的做得到嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00069",
		linknext = "0030_00071",
		line = 967,
	},
	["0030_00071"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No, I could see Touka being able to do it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不，是桐香的话做得到也很合理。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不，是桐香的話做得到也很合理。",
					{"rt2"},
