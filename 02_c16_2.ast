		{"text"},
		text = {
			vo = {
				{"vo", file="rei0809", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“What’s your plan for her? I doubt it’ll be easy to get her to stop. She doesn’t even seem to have much of an appetite, so she’d only eat a little bit of meat...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你打算怎么做？那孩子的话就不是这么简单可以拖住的吧？她看起来吃得也少就算给她吃肉她也吃不了多少的吧──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你打算怎麼做？那孩子的話就不是這麼簡單可以拖住的吧？她看起來吃得也少就算給她吃肉她也吃不了多少的吧──」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00130",
		linknext = "0030_00132",
		line = 1857,
	},
	["0030_00132"] = {
