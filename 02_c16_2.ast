		line = 62,
	},
	["0030_00006"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"You know, the teacher for class 2 did take over for Ms. Minase when she was out with a fever once. While he did get sidetracked a lot, I enjoyed his class.",
					{"rt2"},
				},
			},
			cn = {
				{
					"话说回来有一次水无濑老师发烧请假就是2班的老师来代课，虽然说他讲课会讲到偏题、不过内容还满有趣的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"話說回來有一次水無瀨老師發燒請假就是2班的老師來代課，雖然說他講課會講到偏題、不過內容還滿有趣的。",
					{"rt2"},
				},
			},
		},
