		text = {
			vo = {
				{"vo", file="misaki0082", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ohh, it’s about as big as little Wata?! Eating all this is sure to make me fa—munch, munch, gulp...! It melted away in my mouth?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“哇啊跟小只的渡酱一样大小的烤肉！？要是吃下去的话肯定会胖的唔姆唔姆、嗯、咦──！肉在嘴里化开了──！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「哇啊跟小隻的渡醬一樣大小的烤肉！？要是吃下去的話肯定會胖的唔姆唔姆、嗯、咦──！肉在嘴裡化開了──！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00123",
		linknext = "0030_00125",
		line = 1743,
	},
	["0030_00125"] = {
