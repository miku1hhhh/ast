			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“What a science-fictiony yet hunger-stimulating name...! And not only do I love the color red, I’m starving too...! Oh, but I need to hurry to the base, everyone’ll be waiting...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“多让人胃口大开的名字啊⋯⋯！我想成为一个美少女、肚子也很饿⋯⋯！但不快点去基地的话，会让大家等的──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「多讓人胃口大開的名字啊⋯⋯！我想成為一個美少女、肚子也很餓⋯⋯！但不快點去基地的話，會讓大家等的──」",
					{"rt2"},
				},
			},
		},
