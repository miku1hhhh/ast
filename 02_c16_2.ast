		{"text"},
		text = {
			vo = {
				{"vo", file="minase0004", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"水無瀬先生"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Ms. Minase"},
					"“Let’s begin today’s class. I’ll be passing around a test preparation handout, so please have your handbooks ready.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“好了开始上课吧。待会我会把讲义发下去，大家自己拿喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「好了開始上課吧。待會我會把講義發下去，大家自己拿喔。」",
					{"rt2"},
				},
			},
		},
		linknext = "0030_00002",
		line = 22,
	},
	["0030_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fourth period begins.",
					{"rt2"},
				},
			},
			cn = {
				{
					"今天的第四节课开课了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"今天的第四節課開課了。",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00001",
		linknext = "0030_00003",
		line = 32,
	},
	["0030_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Our school has two classical literature teachers: for second years, Ms. Minase teaches classes 1 and 3, while a different teacher is responsible for class 2.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们学校总共有两名古文老师，水无濑老师负责2年级的1、3两班，2班则由另一位老师负责。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們學校總共有兩名古文老師，水無瀨老師負責2年級的1、3兩班，2班則由另一位老師負責。",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00002",
		linknext = "0030_00004",
		line = 42,
	},
	["0030_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Though Ms. Minase is a relatively good in-class teacher, I always end up getting sleepy in classical lit, a subject I don’t have much interest in.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然水无濑老是算是比较会教课的类型，不过我对古文没有什么兴趣，上着上着就犯了困。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然水無瀨老是算是比較會教課的類型，不過我對古文沒有什麼興趣，上著上著就犯了睏。",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00003",
		linknext = "0030_00005",
		line = 52,
	},
	["0030_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Especially when it’s during fourth period, which is just before lunch. It’s right when my concentration begins to give out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"尤其是早上第4节课，差不多是我集中力用尽的时候了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"尤其是早上第4節課，差不多是我集中力用盡的時候了。",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00004",
