	["0030_00217"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So there was another organization or individual willing to give the Birds of a Feather money so that they could keep escaping?",
					{"rt2"},
				},
			},
			cn = {
				{
					"出钱让‘Tori公’逃走的组织或个人，是否还有其他人？",
					{"rt2"},
				},
			},
			tw = {
				{
					"出錢讓『Tori公』逃走的組織或個人，是否還有其他人？",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00216",
		linknext = "0030_00218",
		line = 3122,
	},
	["0030_00218"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00305", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You’re telling me there’s yet another eccentric old man out there?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“除了你这个异想天开的老头以外，居然还有人──？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「除了你這個異想天開的老頭以外，居然還有人──？」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00217",
		linknext = "0030_00219",
		line = 3134,
	},
	["0030_00219"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0029", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“You’ve got some nerve saying that to my face. Have you even heard of etiquette...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘当着本人的面说这种话，也太失礼了吧⋯⋯’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『當著本人的面說這種話，也太失禮了吧⋯⋯』",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00218",
		linknext = "0030_00220",
		line = 3146,
	},
	["0030_00220"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00306", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What about that was rude? Politician or whatever else you are, you’ve been terrible to Fumino...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哪里失礼了？我是不知道你是政客还是什么之类的，但你对文乃做了很过分的事⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哪裡失禮了？我是不知道你是政客還是什麼之類的，但你對文乃做了很過分的事⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00219",
		linknext = "0030_00221",
		line = 3158,
	},
	["0030_00221"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0030", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“I’ve not done a thing...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘我什么都没做……’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『我什麼都沒做……』",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00220",
		linknext = "0030_00222",
		line = 3170,
	},
	["0030_00222"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00307", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But you were planning to, weren’t you?! I may have beaten the shit out of you on that roof, but I’m still not satisfied!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你想做不是吗──！？虽然我在那个屋顶上狠狠地揍了你一顿，但我还没气消呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你想做不是嗎──！？雖然我在那個屋頂上狠狠地揍了你一頓，但我還沒氣消呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00221",
		linknext = "0030_00223",
		line = 3182,
	},
	["0030_00223"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0031", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“You did...?! What kind of person mercilessly beats an elderly man...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘你做过这种事吗⋯⋯！？连老人都打⋯⋯？’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『你做過這種事嗎⋯⋯！？連老人都打⋯⋯？』",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00222",
		linknext = "0030_00224",
		line = 3194,
	},
	["0030_00224"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00213", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hey, I was in danger of straight-up losing that fight, you know...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，那个时候我也快打不过⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，那個時候我也快打不過⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00223",
		linknext = "0030_00225",
		line = 3206,
	},
	["0030_00225"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0032", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“So all of those muscles are just for aesthetics? Hah! Seems you’re not as impressive as I thought, losing to an old man like me...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘什么，你那肌肉只是装饰品吗？竟然输给这样的老头子，这种事还叫没什么吗……！’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『什麼，你那肌肉只是裝飾品嗎？竟然輸給這樣的老頭子，這種事還叫沒什麼嗎……！』",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00224",
		linknext = "0030_00226",
		line = 3218,
	},
	["0030_00226"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00222", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It was after I’d fought a few hundred of your troops thanks to your stupid schemes!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我那是在跟你计谋出现的几百人军队战斗完之后好吗！！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我那是在跟你計謀出現的幾百人軍隊戰鬥完之後好嗎！！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00225",
		linknext = "0030_00227",
		line = 3230,
	},
	["0030_00227"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Seems like this geezer still gets me heated.",
					{"rt2"},
				},
			},
			cn = {
				{
					"果然对上这个老人，我的态度就会变得很不逊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"果然對上這個老人，我的態度就會變得很不遜。",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00226",
		linknext = "0030_00228",
		line = 3240,
	},
	["0030_00228"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s not like I’ve lost my memories of what happened between us, or about the way he treated Fumino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那时候的记忆并没有被消除，他对文乃做了什么事我也不可能会忘记。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那時候的記憶並沒有被消除，他對文乃做了什麼事我也不可能會忘記。",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00227",
		linknext = "0030_00229",
		line = 3250,
	},
	["0030_00229"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He really isn’t someone that I can bring myself to trust.",
					{"rt2"},
				},
			},
			cn = {
				{
					"果然，对我来说，这家伙是信不得的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"果然，對我來說，這傢伙是信不得的。",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00228",
		linknext = "0030_00230",
		line = 3260,
	},
	["0030_00230"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But the same goes for him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过，这对他来说也是一样的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過，這對他來說也是一樣的。",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00229",
		linknext = "0030_00231",
		line = 3270,
	},
	["0030_00231"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...Why didn’t you tell me about this? None of this would’ve happened if you’d let me know earlier.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“──你为什么不告诉我这个事实？如果你早点告诉我，就不会发生这样的事了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「──你為什麼不告訴我這個事實？如果你早點告訴我，就不會發生這樣的事了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00230",
		linknext = "0030_00232",
		line = 3282,
	},
	["0030_00232"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0033", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“What duty did I have to do so? Perhaps we’ve agreed to assist one another, but I don’t believe we’re allies. Or perhaps I’m mistaken?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘我有什么义务要这么做？虽然我跟你姑且算是结了盟，不过我们并不是伙伴的关系吧？’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『我有什麼義務要這麼做？雖然我跟你姑且算是結了盟，不過我們並不是夥伴的關係吧？』",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00231",
		linknext = "0030_00233",
		line = 3294,
	},
	["0030_00233"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00305", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Have you forgotten who has the upper hand here? I’ll crush you if you keep on running your mouth.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你是不是忘了还有权力关系？再说这种瞧不起人的话小心我揍扁你喔！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你是不是忘了還有權力關係？再說這種瞧不起人的話小心我揍扁你喔！」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00232",
		linknext = "0030_00234",
		line = 3306,
	},
	["0030_00234"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0034", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“You mean to snitch? Very well, then. If you have the time to search out the SHO and whatever remains of those ruffians, of course.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘你想要告密吗？那也行。要是我有闲工夫找到SHO和暴徒的余党的话，再告诉你吧。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『你想要告密嗎？那也行。要是我有閒工夫找到SHO和暴徒的餘黨的話，再告訴你吧。』",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00233",
		linknext = "0030_00235",
		line = 3318,
	},
	["0030_00235"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This old piece of shit...",
					{"rt2"},
				},
			},
			cn = {
				{
					"这死老头──",
					{"rt2"},
				},
			},
			tw = {
				{
					"這死老頭──",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00234",
		linknext = "0030_00236",
		line = 3328,
	},
	["0030_00236"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Sakimori doesn’t want to show me all the cards in his hand.",
					{"rt2"},
				},
			},
			cn = {
				{
					"驻防老人也还没把他手上的牌全部向我摊开。",
					{"rt2"},
				},
			},
			tw = {
				{
					"駐防老人也還沒把他手上的牌全部向我攤開。",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00235",
		linknext = "0030_00237",
		line = 3338,
	},
	["0030_00237"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If anything, he’s trying to figure out what I don’t know in order to gain an advantage over me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"相反，在与我的谈话中，他试图通过刺探我们不知道的讯息来取得优势。",
					{"rt2"},
				},
			},
			tw = {
				{
					"相反，在與我的談話中，他試圖通過刺探我們不知道的訊息來取得優勢。",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00236",
		linknext = "0030_00238",
		line = 3348,
	},
	["0030_00238"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0035", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Sneaking into this base will surely grow taxing. Let me give you a way of contacting me. I’ll send a satellite phone to the address you gave me. Use it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘每次潜入基地都很困难。我提供给你跟我联络的方式。这边会打卫星电话到你以前住的地方去，你用那个跟我联络就行了──’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『每次潛入基地都很困難。我提供給你跟我聯絡的方式。這邊會打衛星電話到你以前住的地方去，你用那個跟我聯絡就行了──』",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00237",
		linknext = "0030_00239",
		line = 3360,
	},
	["0030_00239"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But if he still decided to answer me, that must mean he still sees me as useful, at least in some small way.",
					{"rt2"},
				},
			},
			cn = {
				{
					"还会答我的电话，可能是因为他仍觉得我有利用价值。",
					{"rt2"},
				},
			},
			tw = {
				{
					"還會答我的電話，可能是因為他仍覺得我有利用價值。",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00238",
		linknext = "0030_00240",
		line = 3370,
	},
	["0030_00240"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Or maybe...",
					{"rt2"},
				},
			},
			cn = {
				{
					"不、或者说。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不、或者說。",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00239",
		linknext = "0030_00241",
		line = 3380,
	},
	["0030_00241"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What if there was some other reason?",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果有其他的理由的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果有其他的理由的話。",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00240",
		linknext = "0030_00242",
		line = 3390,
	},
	["0030_00242"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...Could it be the situation with Fumino’s mother?",
					{"rt2"},
				},
			},
			cn = {
				{
					"⋯⋯是因为文乃母亲的事吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"⋯⋯是因為文乃母親的事嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00241",
		linknext = "0030_00243",
		line = 3400,
	},
	["0030_00243"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This old man must see his daughter—Fumika—as precious enough to make it worth listening to what some foul-mouthed brat has to say.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对于这个老人来说，他的女儿──文歌小姐，肯定是一个重要到了他会愿意为了她，好好去听一个嘴臭小子讲的话的那种存在吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對於這個老人來說，他的女兒──文歌小姐，肯定是一個重要到了他會願意為了她，好好去聽一個嘴臭小子講的話的那種存在吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00242",
		linknext = "0030_00244",
		line = 3410,
	},
	["0030_00244"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...Yeah, I won’t hesitate to call you if there’s anything else I want to ask.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯没问题，如果还有什么想问的，尽管联系我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯沒問題，如果還有什麼想問的，儘管聯繫我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00243",
		linknext = "0030_00245",
		line = 3422,
	},
	["0030_00245"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Our interests align, but that’s it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们只是利害一致的关系而已。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們只是利害一致的關係而已。",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00244",
		linknext = "0030_00246",
		line = 3432,
	},
	["0030_00246"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’m sure he’s fine with that kind of relationship too.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以彼此之间应该是没有问题的。",
					{"rt2"},
				},
