					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Is this a Brazilian barbecue?! And meat that doesn’t make you fat...? This is amazing! I want to build a house and live here!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“跟碗子乔麦面一样──！？吃下去也不会肥的肉什么的⋯⋯简直太棒了，我要在这里定居！！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「跟碗子喬麥麵一樣──！？吃下去也不會肥的肉什麼的⋯⋯簡直太棒了，我要在這裡定居！！！」",
					{"rt2"},
				},
			},
		},
