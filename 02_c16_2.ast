			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don’t think there’s any need for you to apologize here—but still.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这种事不用抱歉啦，不过──”",
