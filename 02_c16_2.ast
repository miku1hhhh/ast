		{"bg", id=18, file="kcg0300020501-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"msgoff", time=1},
		{"extrans", sync=0, time=600, rule="eff_033_00000"},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0610", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“...So to summarize, Sakimori has already cut off his funding for the Birds of a Feather?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“⋯⋯我整理一下资讯，驻防已经完全中止了队‘Tori公’的出资了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「⋯⋯我整理一下資訊，駐防已經完全中止了隊『Tori公』的出資了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00248",
		linknext = "0030_00250",
		line = 3511,
	},
	["0030_00250"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. But only in the last couple of months. Until then—until Fumino was found, they acted similarly to the way we did.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊。但这似乎是过去两个月的情况。在那之前──在他找到文乃之前，他的行为方式似乎与我们相似。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊。但這似乎是過去兩個月的情況。在那之前──在他找到文乃之前，他的行為方式似乎與我們相似。」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00249",
		linknext = "0030_00251",
		line = 3523,
	},
	["0030_00251"] = {
		{"evset", file="kcg03", set="kcg03", path=":ev/kcg03/"},
		{"evset", file="kcg0300020201-1", set="kcg030002", path=":ev/kcg030002/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg0300020201-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0762", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“So that means there’s someone out there shelling out money to help them get away from the perverted sex law. Doesn’t that seem a little too eccentric?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“这么说，是有人在暗处提供那些逃避变态条例的人资金啰。简直是疯了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「這麼說，是有人在暗處提供那些逃避變態條例的人資金囉。簡直是瘋了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00250",
		linknext = "0030_00252",
		line = 3542,
	},
	["0030_00252"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0822", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Yeah. I don’t know who in their right mind would do that. I couldn’t believe it when I heard someone was funding the NLNS too, if I’m being honest...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“没错，我想是疯了。说真的当我知道NLNS有出资者的时候，我也是有种‘欸？真的假的？’的感觉⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「沒錯，我想是瘋了。說真的當我知道NLNS有出資者的時候，我也是有種『欸？真的假的？』的感覺⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00251",
		linknext = "0030_00253",
		line = 3554,
	},
	["0030_00253"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00214", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
