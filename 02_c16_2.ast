	["0030_00053"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Right. Nanase was with me when I discovered that base. The reasons the other members joined are slightly different too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯。不过我发现那个基地的时候，在我身边的人变成了奈奈濑。招集其他人的动机也有很微妙的差异。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯。不過我發現那個基地的時候，在我身邊的人變成了奈奈瀨。招集其他人的動機也有很微妙的差異。」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00052",
		linknext = "0030_00054",
		line = 746,
	},
	["0030_00054"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00204", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0755", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Things change in dreams for no good reason, so that could be one possibility. If it’s not, though...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“梦会随着想法改变之类的，虽然说也不是没有这种可能性。但你看起来好像不是这样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「夢會隨著想法改變之類的，雖然說也不是沒有這種可能性。但你看起來好像不是這樣。」",
					{"rt2"},
				},
			},
		},
