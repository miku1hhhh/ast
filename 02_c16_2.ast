			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Knowledge is the key to cuisine. Whether it’s meat or girls, you start by searing the surface like a one-pump chump, then go slow and low for longer than a death gripper until they’re hot and ready!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“烹饪就是一种知识的化身。肉跟女孩子一样，像早泄一样轻轻烤过表面、迟射一样慢火烹饪，让肉变得美味──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「烹飪就是一種知識的化身。肉跟女孩子一樣，像早洩一樣輕輕烤過表面、遲射一樣慢火烹飪，讓肉變得美味──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00116",
		linknext = "0030_00118",
		line = 1604,
	},
