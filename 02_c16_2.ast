				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Please don’t badmouth my team.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“请不要说我团队的坏话。”",
