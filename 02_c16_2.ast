			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“This is the gender ratio of all students as recorded in Academy documents, while this is our world’s.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“这是学校文件上的男女学生比例。而我们的世界的，是这份。”",
