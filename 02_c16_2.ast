	["0030_00215"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0028", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“What do you think? Of course there was... But the damned lot claimed they’d found a new source of funding.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘这不是显而易见吗……不过他说他得到了新的资金来源。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『這不是顯而易見嗎……不過他說他得到了新的資金來源。』",
					{"rt2"},
				},
			},
		},
		linkback = "0030_00214",
