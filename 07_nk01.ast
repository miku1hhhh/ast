		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0181", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Music is the oldest artform created by man and there’s a dreamy band looking to use that power to change the world back to its once peaceful perversion! This is Finger☆Bang☆Dream!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“这可是从有人类以来就流传下来世界上最古老的艺术，用这种音乐的力量就能和平的把世界改造成变态的模样，是梦幻的乐团，Finger☆Bang☆Dream！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「這可是從有人類以來就流傳下來世界上最古老的藝術，用這種音樂的力量就能和平的把世界改造成變態的模樣，是夢幻的樂團，Finger☆Bang☆Dream！」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00203",
		linknext = "0090_00205",
		line = 2898,
	},
	["0090_00205"] = {
