	},
	["0090_00201"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00101", file2="ran_01m_00203", file4="ran_01m_00401", path=":fg/ran_01m/", id=13, lv=13, head="ran_01m", ch_origin="蘭", ch="蘭13", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0180", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Of coc— Uh, course!! And I’m not the only one! There’s a ton of organizations out there working to revive the perverted sex law, look!!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“这是理所棒然的吧！可不是只有我一个人！现在可是有很多组织正在为了推动变态条例的复活而努力的，你们看！！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「這是理所棒然的吧！可不是只有我一個人！現在可是有很多組織正在為了推動變態條例的復活而努力的，你們看！！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00200",
		linknext = "0090_00202",
		line = 2842,
	},
