	},
	["0090_00049"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, nobody gives me sass if I call them out for being a loser. They take one look at me and realize I’d turn them into mist with my pinky finger.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对了，就是如果有人说话惹恼我的话，我就会想着‘像这种货色我要是拿出真本事一拳就可把他干掉了’之类的⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對了，就是如果有人說話惹惱我的話，我就會想著『像這種貨色我要是拿出真本事一拳就可把他幹掉了』之類的⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00048",
		linknext = "0090_00050",
		line = 663,
	},
	["0090_00050"] = {
		{"fg", file="asane_01m_00003", file1="asane_01m_00102", file2="asane_01m_00205", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
