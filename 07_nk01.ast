					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“现在这种身材就是‘没有多发达但还算有料’的程度啊！我这样就算大肌肌的话是因为你根本就训练不足好吗！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「現在這種身材就是『沒有多發達但還算有料』的程度啊！我這樣就算大肌肌的話是因為你根本就訓練不足好嗎！」",
					{"rt2"},
				},
			},
		},
