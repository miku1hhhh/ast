	["0090_00217"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00101", file2="ran_01m_00202", file4="ran_01m_00401", path=":fg/ran_01m/", id=13, lv=13, head="ran_01m", ch_origin="蘭", ch="蘭13", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0185", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“And why wouldn’t they?! We’d be sure to drum up all kinds of business with Legendary Floozy Nanase as the face of Seiran Island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“没错！身为传说中的婊子的片桐同学可是作为‘青蓝岛的象征人物’、被各个组织给追捧着呦！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「沒錯！身為傳說中的婊子的片桐同學可是作為『青藍島的象徵人物』、被各個組織給追捧著呦！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00216",
		linknext = "0090_00218",
		line = 3111,
	},
	["0090_00218"] = {
		{"cgact", file="cgact", act="表示アクション", alpha=0, id=12, time=300, alphadel=1, style="reset"},
		{"text"},
		text = {
			ja = {
