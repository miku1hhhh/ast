					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Breakfast’s ready! Today we have omelet with boiled spinach and deluxe bacon! Jun, be sure to eat your chicken filet and raw egg too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“来。今天是菠菜煎蛋卷搭特制培根！淳要配着鸡胸肉还有生鸡蛋一起吃喔！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「來。今天是菠菜煎蛋捲搭特製培根！淳要配著雞胸肉還有生雞蛋一起吃喔！」",
					{"rt2"},
				},
			},
		},
