	["0090_00348"] = {
		{"cgdel", id=11, lv=11, time=300, alphadel=1},
		{"fg", mode=-1, id=12, ch="桐香12", ch_origin="桐香", lv=12, time=0, sync=0},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=12, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Anyway, eat up. Normally I wouldn’t want to share Nanase’s cooking with anyone but my little sister, but we have to look out for each other in times of need.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“唉，总之先吃吧。原本我是一口都不想把奈奈濑的料理分给我跟我妹以外的人，不过有困难的时候还是要互相帮忙啦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「唉，總之先吃吧。原本我是一口都不想把奈奈瀨的料理分給我跟我妹以外的人，不過有困難的時候還是要互相幫忙啦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00347",
		linknext = "0090_00349",
		line = 5037,
