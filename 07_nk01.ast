				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「副會長去賣Hamedori的套裝了、水姬則是追隨著仁浦前縣長不知道去了哪裡⋯⋯畢竟那傢伙是個不折不扣的大叔控⋯⋯」",
					{"rt2"},
				},
			},
		},
