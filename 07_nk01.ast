			},
			en = {
				{
					name = {"モブ男B", "Turtle Shell Bondage Hero"},
					"“PLEASE Nanase! Let us use you as our Captain O-Face, symbol of Seiran Island!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "龟甲缚英雄"},
					"“拜托你了片桐同学！我希望你能以‘高潮脸队长’的身份作为青蓝岛的象征⋯⋯！”",
