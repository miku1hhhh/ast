		},
		text = {
			vo = {
				{"vo", file="ran0179", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“You see?! So how do you think I feel not being able to conduct regular track maintenance?! Tch, they’ve been exposing the Hanamaru family to shame ever since the warring states period!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“对不对！这几个月来我可是连一根肉棒都没有射精管理到耶！？啧、花丸家可是从战国时代就开始曝露耻部了耶⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「對不對！這幾個月來我可是連一根肉棒都沒有射精管理到耶！？嘖、花丸家可是從戰國時代就開始曝露恥部了耶⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00198",
		linknext = "0090_00200",
		line = 2815,
	},
	["0090_00200"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobd0060", path=":vo/", ch="mob"},
