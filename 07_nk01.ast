		line = 3625,
	},
	["0090_00258"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00203", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[3000] = {
				{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00213", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=46, delay2=3000, mode=3, x=-605, y=-5},
			},
			[2999] = {
				{"transitiontime", time=300, timestamp=46, delay2=3000},
			},
		},
		text = {
			vo = {
				{"vo", file="rei1993", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Making artificial flowers. It’s the only part-time job we can do at school, but a box of these costs 115 yen to make and SOMETIMES people don’t even come pick ’em up! Honestly...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“做假花。在学校也能做的副业只有这个⋯⋯可是一箱也只能赚115日圆而已！而且有时候收货的人还不来！到底是想怎样啊真是的⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「做假花。在學校也能做的副業只有這個⋯⋯可是一箱也只能賺115日圓而已！而且有時候收貨的人還不來！到底是想怎樣啊真是的⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00257",
		linknext = "0090_00259",
		line = 3643,
	},
	["0090_00259"] = {
		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file2="ikuko_02m_00208", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2045", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“You’ll make yourself sick counting the cost of every flower. Why don’t you ask someone else to help?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“0.5日圆、0.5日圆⋯⋯这样一朵一朵数着钱一边做会生病的啦～要不要找其他人一起帮忙呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「0.5日圓、0.5日圓⋯⋯這樣一朵一朵數著錢一邊做會生病的啦～要不要找其他人一起幫忙呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00258",
