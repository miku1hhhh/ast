	},
	["0090_00051"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What? It feels good having people think that my benevolence is what’s keeping them from needing to breathe through a straw.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“一想到‘这种货色之所以还活着是因为我善良’，我就能宽容大量了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「一想到『這種貨色之所以還活著是因為我善良』，我就能寬容大量了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00050",
		linknext = "0090_00052",
		line = 690,
	},
	["0090_00052"] = {
