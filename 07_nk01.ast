		{"fg", file="ran_01m_00001", file1="ran_01m_00101", file2="ran_01m_00203", file4="ran_01m_00401", path=":fg/ran_01m/", id=13, lv=13, head="ran_01m", ch_origin="蘭", ch="蘭13", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="蘭13", id=13, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0178", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“I don’t see the problem. Minotsuki Academy’s never had a set uniform! Come on, I can’t be alone in this. Surely you all hate how the main island repealed the perverted sex law too?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“有什么关系反正水乃月本来就可以自由选择服装！变态条例因为本岛那种愚蠢的压力所以被废除掉，你们难道就不会不甘心吗！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「有什麼關係反正水乃月本來就可以自由選擇服裝！變態條例因為本島那種愚蠢的壓力所以被廢除掉，你們難道就不會不甘心嗎！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00196",
		linknext = "0090_00198",
		line = 2784,
	},
	["0090_00198"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmobb0085", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男B", "体育会系な男子生徒"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男B", "Sporty Male Student"},
					"“W-Well... Sure, it sucks the D-train’s no longer in service these days, but...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男B", "体育型男学生"},
					"“这个嘛⋯⋯肉棒电车停运这一点是让我觉得很难过啦⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男B", "體育型男學生"},
					"「這個嘛⋯⋯肉棒電車停運這一點是讓我覺得很難過啦⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00197",
		linknext = "0090_00199",
		line = 2796,
	},
	["0090_00199"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00101", file2="ran_01m_00204", file4="ran_01m_00401", path=":fg/ran_01m/", id=13, lv=13, head="ran_01m", ch_origin="蘭", ch="蘭13", mw="mw", sync=0, mode=3, x=-5, y=-5},
