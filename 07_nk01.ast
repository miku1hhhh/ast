			},
			cn = {
				{
					"这么说来我好像有听过这类的事⋯⋯感觉不太妙啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這麼說來我好像有聽過這類的事⋯⋯感覺不太妙啊。",
