	["0090_00271"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Now, there’s something I hadn’t considered when we were fighting.",
					{"rt2"},
				},
			},
			cn = {
				{
					"跟她对战时，我连想都没有想过这件事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"跟她對戰時，我連想都沒有想過這件事。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00270",
		linknext = "0090_00272",
		line = 3883,
	},
	["0090_00272"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It seems student body president Touka Reizeiin is pretty useless.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过，会长、冷泉院桐香她似乎比想像中的还要废的样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過，會長、冷泉院桐香她似乎比想像中的還要廢的樣子。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00271",
		linknext = "0090_00273",
		line = 3893,
	},
	["0090_00273"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Everyone has found themselves a part time job here or there, but it looks like those suitable for her are few and far between.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大家都用各式各样的方式做副业赚钱，不过几乎完全没有她能做的打工。",
					{"rt2"},
				},
			},
			tw = {
				{
					"大家都用各式各樣的方式做副業賺錢，不過幾乎完全沒有她能做的打工。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00272",
		linknext = "0090_00274",
		line = 3903,
	},
	["0090_00274"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Who knows how long she can keep going like this? Without the help of the two FS members she may not even be able to come to school.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且她的日常起居也很诡异，好像没有FS的另外两个人帮忙的话，她连学校都没办法自己来的样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且她的日常起居也很詭異，好像沒有FS的另外兩個人幫忙的話，她連學校都沒辦法自己來的樣子。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00273",
