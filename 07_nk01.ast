		{"se", id=5, loop=1, file="se_d016", vol=50},
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00206", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=395, y=-5},
