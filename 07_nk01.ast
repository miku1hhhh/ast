	["0090_00162"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00214", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0149", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“It’s not like that, although 31 isn’t a bad age to rid oneself of the shackles of corporate life!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“才没有这回事，31岁正好是适合脱离领人薪水的打工仔身份的好年纪！”",
