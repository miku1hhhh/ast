			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Nom nom... Oh, speaking of work, do you mind if I return the box tomorrow?”",
