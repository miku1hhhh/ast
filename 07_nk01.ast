	["0090_00085"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her posture holding the ladle is sleek and beautiful. Her skin as pure as fresh snow.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她的身姿纤长秀美、皮肤也如同一捧新雪般白皙透亮。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她的身姿纖長秀美、皮膚也如同一捧新雪般白皙透亮。",
					{"rt2"},
				},
			},
		},
