					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男A", "人好好的男学生"},
					"“喔喔、委员长好聪明啊！这样一来就能获得向心力了！那我们要组织什么样的团队呢！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男A", "人好好的男學生"},
					"「喔喔、委員長好聰明啊！這樣一來就能獲得向心力了！那我們要組織什麼樣的團隊呢！？」",
					{"rt2"},
				},
			},
		},
