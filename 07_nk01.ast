	["0090_00155"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I thought my idea was pretty solid though. Who wouldn’t want to focus on their gains on an island paradise?",
					{"rt2"},
				},
			},
			cn = {
				{
					"枉费我觉得这座长年处于夏季的岛跟锻炼很合，是个好主意的说⋯⋯",
					{"rt2"},
				},
			},
			tw = {
				{
					"枉費我覺得這座長年處於夏季的島跟鍛鍊很合，是個好主意的説⋯⋯",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00154",
