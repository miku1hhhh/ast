	["0090_00320"] = {
		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file2="ikuko_02m_00212", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2055", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Well, unlike other families we’re kicking it down here in the poorhouse. Not only that but we lost a ton of FS members. They were like family to us too...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“跟其他人不一样，我们最后活得很困苦，还跟几乎同等于家人们的FS们分开了──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「跟其他人不一樣，我們最後活得很困苦，還跟幾乎同等於家人們的FS們分開了──」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00319",
		linknext = "0090_00321",
		line = 4586,
	},
