					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Zigzag-Sleeved Girl"},
					"“Preparations are well underway. But, let’s not be too hasty. Right, Icarus?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "横条纹女"},
					"“准备得很顺利喔。不过可不能操之过急──对吧，伊卡洛斯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "橫條紋女"},
					"「準備得很順利喔。不過可不能操之過急──對吧，伊卡洛斯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00006",
