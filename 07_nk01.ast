	["0090_00169"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00206", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0151", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“I didn’t save a single penny during all my time working at the SHO. My younger sister and I would spend it all on customizations for our rifles and handguns, and they even took those away...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“因为要负担妹妹的生活费还有客制的来福枪啊、手枪那些费用，我在SHO工作的时候连一块钱都没有存到喔。我就是这样子生活的⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「因為要負擔妹妹的生活費還有客制的來福槍啊、手槍那些費用，我在SHO工作的時候連一塊錢都沒有存到喔。我就是這樣子生活的⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00168",
		linknext = "0090_00170",
		line = 2407,
	},
	["0090_00170"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
		{"text"},
