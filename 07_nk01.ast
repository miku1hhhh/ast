	},
	["0090_00219"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Push comes to shove, I may have to start using my muscles as a deterrent.",
					{"rt2"},
				},
			},
			cn = {
				{
					"算了，反正要是怎么样的话我会用肌肉来对付他们的──",
					{"rt2"},
				},
			},
			tw = {
				{
					"算了，反正要是怎麼樣的話我會用肌肉來對付他們的──",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00218",
		linknext = "0090_00220",
		line = 3133,
	},
	["0090_00220"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00101", file2="ran_01m_00203", file4="ran_01m_00401", path=":fg/ran_01m/", id=13, lv=13, head="ran_01m", ch_origin="蘭", ch="蘭13", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0186", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“And yet our class is the only one sitting around with their thumbs up their butts! Most we’ve done is march nude around the capitol building until we all caught colds!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“但是，居然就只有我们班什么动作都没有！我们就只有全裸在国会大下前面坐着，最后还感冒了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「但是，居然就只有我們班什麼動作都沒有！我們就只有全裸在國會大下前面坐著，最後還感冒了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00219",
		linknext = "0090_00221",
		line = 3148,
	},
	["0090_00221"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="girla0003", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"元気で明るい女子生徒"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"元気で明るい女子生徒", "Bright-and-Cheery Girl"},
					"“Oh yeah, that kinda sucked. They ended up calling the police on us because Ran forgot to apply for a demonstration permit.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"元気で明るい女子生徒", "活泼开朗的女学生"},
					"“啊，那个真的很辛苦呢，兰酱忘记申请示威游行了所以最后还出动了防暴警察。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"元気で明るい女子生徒", "活潑開朗的女學生"},
					"「啊，那個真的很辛苦呢，蘭醬忘記申請示威遊行了所以最後還出動了防暴警察。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00220",
		linknext = "0090_00222",
		line = 3160,
	},
	["0090_00222"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="girlc0004", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"引っ込み思案な女子生徒"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"引っ込み思案な女子生徒", "Timid Female Student"},
					"“And that wasn’t all. Poor Hamedori was trying to keep himself warm, but was arrested for having his penis out and yelling ‘Plap plap!’ Apparently they thought he was starting some new religion...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"引っ込み思案な女子生徒", "消极的女学生"},
					"“而且因为太冷了，所以我就穿着Hamedori君的布偶装来用肉棒保暖，因为同时还说着‘Paco Paco’所以被警察误以为是新兴宗教给逮补了呢⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"引っ込み思案な女子生徒", "消極的女學生"},
					"「而且因為太冷了，所以我就穿著Hamedori君的布偶裝來用肉棒保暖，因為同時還說著『Paco Paco』所以被警察誤以為是新興宗教給逮補了呢⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00221",
		linknext = "0090_00223",
		line = 3172,
	},
	["0090_00223"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="girlb0005", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"大人っぽい女子生徒"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"大人っぽい女子生徒", "Mature-Acting Female Student"},
					"“No wonder the island’s been getting teased online. I saw some people calling the island ‘weird as fuck’ and that we should be ‘nuked clean.’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"大人っぽい女子生徒", "有成熟感的女学生"},
					"“我记得没错的话，网络新闻上面还有‘变态岛果然是个诡异的地方’、‘应该要用核弹净化这些淫乱种族才对’之类的言论呢⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"大人っぽい女子生徒", "有成熟感的女學生"},
					"「我記得沒錯的話，網路新聞上面還有『變態島果然是個詭異的地方』、『應該要用核彈淨化這些淫亂種族才對』之類的言論呢⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00222",
		linknext = "0090_00224",
		line = 3184,
	},
	["0090_00224"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Isn’t that kind of a drag on the other classes?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样不是反而扯了其他班的后腿吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣不是反而扯了其他班的後腿嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00223",
		linknext = "0090_00225",
		line = 3196,
	},
	["0090_00225"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00101", file2="ran_01m_00203", file4="ran_01m_00401", path=":fg/ran_01m/", id=13, lv=13, head="ran_01m", ch_origin="蘭", ch="蘭13", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0187", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Only because we’ve been doing it wrong until now! It’s vital that we change focus and target the needs of the consumer—the tourists! We must abuse them into self-abuse!!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“我们哪里有做错！要依据观光客的需要来改变组织已满足消费者是很重要的！所以重点就是要能提供客制化服务啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「我們哪裡有做錯！要依據觀光客的需要來改變組織已滿足消費者是很重要的！所以重點就是要能提供客製化服務啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00224",
		linknext = "0090_00226",
		line = 3211,
	},
	["0090_00226"] = {
