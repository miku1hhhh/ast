		line = 4805,
	},
	["0090_00331"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don’t regret anything I did, besides one thing...",
					{"rt2"},
				},
			},
			cn = {
				{
					"⋯⋯对于我的所作所为，我只有在一点上后悔过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"⋯⋯對於我的所作所為，我只有在一點上後悔過。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00330",
		linknext = "0090_00332",
		line = 4815,
	},
	["0090_00332"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...but that doesn’t have anything to do with these girls.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而这一点，与她们并没有关系。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而這一點，與她們並沒有關係。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00331",
		linknext = "0090_00333",
		line = 4825,
	},
	["0090_00333"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So even if they were to treat me coldly, I would deserve it. And I had felt ready for that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以被他们冷落也是理所当然的，我也有自信能承受这一切。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以被他們冷落也是理所當然的，我也有自信能承受這一切。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00332",
		linknext = "0090_00334",
		line = 4835,
	},
	["0090_00334"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But here they are, talking to me like nothing was ever wrong.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然而，她们却表现得稀松平常的与我说话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然而，她們卻表現得稀鬆平常的與我說話。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00333",
		linknext = "0090_00335",
		line = 4845,
	},
	["0090_00335"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00218", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I was ready to get punched in the face, at least once.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我还以为至少要被揍个一次呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我還以為至少要被揍個一次呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00334",
		linknext = "0090_00336",
		line = 4857,
	},
	["0090_00336"] = {
		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file2="ikuko_02m_00222", path=":fg/ikuko_02m/", id=10, lv=9, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[5000] = {
				{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file3="ikuko_02m_00301", path=":fg/ikuko_02m/", id=10, lv=9, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, timestamp=80, delay2=5000, mode=3, x=595, y=-5},
			},
			[4999] = {
				{"transitiontime", time=300, timestamp=80, delay2=5000},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko2058", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“But you said so before—a win’s a win and winners get to choose. It’s my fault for losing, end of story. The only one still giving you mouth is Rei.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“所以我那时候不就说了吗？胜利的人是政府，赢家不管做什么都可以。所以说输了是郁不好。这一切都结束了，还在抱怨的只有礼酱而已喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「所以我那時候不就說了嗎？勝利的人是政府，贏家不管做什麼都可以。所以說輸了是郁不好。這一切都結束了，還在抱怨的只有禮醬而已喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00335",
		linknext = "0090_00337",
		line = 4874,
	},
	["0090_00337"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00102", file3="rei_02m_00305", path=":fg/rei_02m/", id=9, lv=8, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="礼9", id=9, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2004", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“And why shouldn’t I?! He chased us out of our own home! It’s natural to be mad! I had to sell my entire Tokusatsu collection. DO YOU KNOW HOW LONG THAT TOOK ME TO MAKE?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我会抱怨不是很正常吗⋯⋯！？都被赶出家门了！？会生气是很正常的吧！我还不得不把我一直收藏的特摄周边给卖了耶！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我會抱怨不是很正常嗎⋯⋯！？都被趕出家門了！？會生氣是很正常的吧！我還不得不把我一直收藏的特攝周邊給賣了耶！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00336",
		linknext = "0090_00338",
		line = 4889,
	},
	["0090_00338"] = {
