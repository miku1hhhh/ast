	["0090_00056"] = {
		{"fg", file="asane_02m_00003", file1="asane_02m_00101", file2="asane_02m_00211", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1115", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I want my brother back—the one who’d hyperventilate when he exercised too much and was only moderately toned with his shirt off. Not this muscle dork!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我才不要大肌肌猛男啦──把那个过度锻炼会出现喘不过气、没有那么多发达肌肉但脱了衣服身材还算有料的哥哥还给我～！！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我才不要大肌肌猛男啦──把那個過度鍛鍊會出現喘不過氣、沒有那麼多發達肌肉但脫了衣服身材還算有料的哥哥還給我～！！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00055",
		linknext = "0090_00057",
		line = 764,
	},
	["0090_00057"] = {
