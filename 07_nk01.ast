			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, I’m glad you’re getting back on your feet. I’ve gotta go grab some food myself, so I’ll be going.”",
					{"rt2"},
				},
			},
			cn = {
				{
