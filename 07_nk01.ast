			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No way. You’d lose track part way and wander off. Why don’t you just carry on with your data entry job?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不行，桐香大人您做假花做到一半就会整个人飘走最后歪掉。请在那边继续您Key In资料的兼职工作。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不行，桐香大人您做假花做到一半就會整個人飄走最後歪掉。請在那邊繼續您Key In資料的兼職工作。」",
					{"rt2"},
				},
			},
		},
