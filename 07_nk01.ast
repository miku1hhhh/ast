					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tadasugawa, Commander. What are you two doing with those?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“糺川前辈跟中队长，你们在做什么东西啊，这个？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「糺川前輩跟中隊長，妳們在做什麼東西啊，這個？」",
