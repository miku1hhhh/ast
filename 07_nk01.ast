	["0090_00346"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I wonder if there is another world out there where we fought for the same side.",
					{"rt2"},
				},
			},
			cn = {
				{
					"会有可以理解她、也让她理解的世界存在吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"會有可以理解她、也讓她理解的世界存在嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00345",
		linknext = "0090_00347",
		line = 5011,
	},
	["0090_00347"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I like to think that if such a world existed then she might be happy there.",
					{"rt2"},
				},
			},
			cn = {
				{
					"要是真的有那样的世界那应该很不错吧。我偶尔会这样想。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要是真的有那樣的世界那應該很不錯吧。我偶爾會這樣想。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00346",
