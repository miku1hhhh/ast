		linkback = "0090_00142",
		linknext = "0090_00144",
		line = 2071,
	},
	["0090_00144"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Incidentally, Kouki isn’t aware that it was my sister and I who dismantled the perverted sex law in the first place.",
					{"rt2"},
				},
			},
			cn = {
				{
					"顺带一提，仙波小姐她并不知道把变态条例给瓦解掉的，就是我们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"順帶一提，仙波小姐她並不知道把變態條例給瓦解掉的，就是我們。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00143",
		linknext = "0090_00145",
		line = 2081,
	},
	["0090_00145"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Though we’d crossed swords, it seems she really has no idea.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她们奋力而战，却完全不知道情况。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她們奮力而戰，卻完全不知道情況。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00144",
		linknext = "0090_00146",
		line = 2091,
	},
	["0090_00146"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Whether it’s because we pulled through or what, it was gratifying for us members of the former NLNS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"搞不好是因为被排除在圈子外，不过从NLNS的角度来看，无论是哪种都值得庆幸就是了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"搞不好是因為被排除在圈子外，不過從NLNS的角度來看，無論是哪種都值得慶幸就是了。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00145",
		linknext = "0090_00147",
		line = 2101,
	},
	["0090_00147"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00218", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But, I heard all the staff left the island once the SHO was defeated.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“SHO都解散了⋯⋯我有听说好像所有的员工都离开岛上了的样子⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「SHO都解散了⋯⋯我有聽說好像所有的員工都離開島上了的樣子⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00146",
		linknext = "0090_00148",
		line = 2113,
	},
	["0090_00148"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00201", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0142", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“That’s right. Governor Hitoura helped every one of us find new employment in the end. Roughly 80% of our members landed new jobs.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“对啊，最后是仁浦大人帮忙一个个转介工作，所以大概有八成左右的员工都有新工作了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「對啊，最後是仁浦大人幫忙一個個轉介工作，所以大概有八成左右的員工都有新工作了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00147",
		linknext = "0090_00149",
		line = 2128,
	},
	["0090_00149"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00207", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0143", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“As for us remaining 20%... Well, we liked the island too much to leave.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“剩下的两成⋯⋯就是像我这种、太喜欢这座岛所以不想离开的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「剩下的兩成⋯⋯就是像我這種、太喜歡這座島所以不想離開的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00148",
		linknext = "0090_00150",
		line = 2143,
	},
	["0090_00150"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Kouki’s eyes drift as she stares out at the sea spread out before her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仙波小姐微眯着眼，看向眼前广阔的大海。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仙波小姐微瞇著眼，看向眼前廣闊的大海。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00149",
		linknext = "0090_00151",
