				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But the SHO is long gone, so what could they...?",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过，已经瓦解的SHO发出委托，这到底是──？",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過，已經瓦解的SHO發出委託，這到底是──？",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00356",
