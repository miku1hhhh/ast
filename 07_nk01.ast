			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Oh, no need to worry. It’s probably just all the money I’d garnered when I was a Toenly Fans affiliate all flooding in all at once! Just a sign of my hard work♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“不用担心的，你们还真爱紧张。那一定是我之前当YoukakuTuber时的收益之类的，到现在才汇总在一起汇过来的！呵呵，大家都很辛苦呢♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「不用擔心的，你們還真愛緊張。那一定是我之前當YoukakuTuber時的收益之類的，到現在才匯總在一起匯過來的！呵呵，大家都很辛苦呢♪」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00172",
		linknext = "0090_00174",
		line = 2461,
	},
	["0090_00174"] = {
		{"fg", file="asane_02m_00001", file1="asane_02m_00102", file2="asane_02m_00222", path=":fg/asane_02m/", id=3, lv=4, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-405, y=-5},
