					name = {"光姫"},
					"「我想開個『隱家咖啡店』，當咖啡店的老闆度過餘生！」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00159",
		linknext = "0090_00161",
		line = 2286,
	},
	["0090_00161"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
