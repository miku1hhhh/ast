	["0090_00156"] = {
		{"bgm", file="bgm08", vol=100},
		{"fg", file="kouki_01m_00002", file1="kouki_01m_00101", file2="kouki_01m_00202", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="光姫17", id=17, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0146", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Hrrrm, but there’s no use in being down in the dumps about it! I can’t stay out of work forever. I have my little sister to think about!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“⋯⋯唉，不过我不会这样就郁闷的！我还有个妹妹所以也不能一直无职下去呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「⋯⋯唉，不過我不會這樣就鬱悶的！我還有個妹妹所以也不能一直無職下去呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00155",
		linknext = "0090_00157",
		line = 2234,
	},
	["0090_00157"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And just like that, her mood shifts and she smiles brightly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她很快就转换了心情，露出了灿烂的笑容。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她很快就轉換了心情，露出了燦爛的笑容。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00156",
		linknext = "0090_00158",
		line = 2244,
	},
	["0090_00158"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00214", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0147", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“I thought about it and figured this was my chance! I could follow the dream I’ve had ever since I was small!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“想一想这搞不好也是个转机！我啊，从小就一直有个梦想喔！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「想一想這搞不好也是個轉機！我啊，從小就一直有個夢想喔！」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00157",
		linknext = "0090_00159",
		line = 2259,
	},
	["0090_00159"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00219", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
		{"text"},
		text = {
