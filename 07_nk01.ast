	},
	["0090_00152"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00203", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, once I’ve built my muscles up enough I was thinking of opening a muscle museum.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我要用肌肉来振兴它，总有一天我会开一间肌肉博物馆来──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我要用肌肉來振興它，總有一天我會開一間肌肉博物館來──」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00151",
