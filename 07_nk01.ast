	["0090_00269"] = {
		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file2="ikuko_02m_00214", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2046", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Touka, you really are selective about when you show your natural clumsiness. Why don’t you go be clumsy over there?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“桐香酱会在奇怪的地方发挥她那天生的迟钝呢，这种时候她就会变成天然的花瓶，完全派不上用场。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「桐香醬會在奇怪的地方發揮她那天生的遲鈍呢，這種時候她就會變成天然的花瓶，完全派不上用場。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00268",
		linknext = "0090_00270",
		line = 3856,
	},
	["0090_00270"] = {
