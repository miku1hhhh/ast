		{"text"},
		text = {
			vo = {
				{"vo", file="gmobb0119", path=":vo/", ch="gmob"},
			},
			ja = {
				{
					name = {"モブ女B", "ロックな女子生徒"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Rocker Student Girl"},
					"“Uh... I think music has the power to change our minds, so... Heeey! Who’s ready to change how they think about getting nasty?!”",
