	["0090_00138"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00218", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What are you doing here? With the SHO gone, there isn’t really any need for guardsmen now, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“仙波小姐您来这里做什么呢？SHO也不在了，应该也不用做巡逻的工作了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「仙波小姐您來這裡做什麼呢？SHO也不在了，應該也不用做巡邏的工作了吧？」",
					{"rt2"},
				},
			},
		},
