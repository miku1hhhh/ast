	["0090_00249"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After losing that autonomy, the girls were even kicked out of the disciplinary committee room.",
					{"rt2"},
				},
			},
			cn = {
				{
					"失去了在校园的自主权，她们也被赶出了风纪委员室。",
					{"rt2"},
				},
			},
			tw = {
				{
					"失去了在校園的自主權，她們也被趕出了風紀委員室。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00248",
		linknext = "0090_00250",
		line = 3515,
	},
	["0090_00250"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That left them only the student council room, which they can use freely since Reizeiin is head of the student council.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过因为冷泉园是学生会长的关系，学生会室还是可以让她们自由使用。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過因為冷泉園是學生會長的關係，學生會室還是可以讓她們自由使用。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00249",
		linknext = "0090_00251",
