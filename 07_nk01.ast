	["0090_00006"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A man wearing a mask covering more than half of his face asks a woman sitting diagonally from him at a round table.",
					{"rt2"},
				},
			},
			cn = {
				{
					"戴着遮住了大半张脸的面具的男性对着坐在圆桌对面的女子问。",
					{"rt2"},
				},
			},
			tw = {
				{
					"戴著遮住了大半張臉的面具的男性對著坐在圓桌對面的女子問。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00005",
		linknext = "0090_00007",
		line = 75,
	},
	["0090_00007"] = {
		{"text"},
		text = {
			vo = {
