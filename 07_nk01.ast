				{"vo", file="ran0188", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“We have to make everyone aware that perversion is a gold tier sport. That’s why I have come up with the perfect name for a team of fresh-faced teens: The Ball Touchers!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“果然还是要让大家认识到变态行为是一种跟花丸一样完美的运动吧？由爽朗的性少年性少女们组成的运动队伍‘淫乱队’！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「果然還是要讓大家認識到變態行為是一種跟花丸一樣完美的運動吧？由爽朗的性少年性少女們組成的運動隊伍『淫亂隊』！」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00226",
		linknext = "0090_00228",
		line = 3238,
	},
	["0090_00228"] = {
		{"text"},
		text = {
