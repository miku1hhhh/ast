			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“President Clumsy, at your service. Hello hello...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我是天生的花瓶学生会长……大家好啊，好久不见了……”",
					{"rt2"},
