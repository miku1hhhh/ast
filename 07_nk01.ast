			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You can climb that ladder on your own. You don’t need to drag me onto it...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不要把你妹拖下水，要往下一个阶段去你自己去爬楼梯就好啦⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不要把你妹拖下水，要往下一個階段去你自己去爬樓梯就好啦⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00041",
		linknext = "0090_00043",
		line = 569,
	},
	["0090_00043"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh come on. You know NLNS stands for No Love, No Strength, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“NLNS 是No Love, No Shoulder muscle。(没有爱就没有三角肌)的简称喔？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「NLNS 是No Love, No Shoulder muscle。(沒有愛就沒有三角肌)的簡稱喔？」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00042",
		linknext = "0090_00044",
		line = 581,
	},
	["0090_00044"] = {
