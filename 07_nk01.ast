		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1763", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Rei, would you let me make some flowers? I’d like to show my good side in front of my upperclassman.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呐礼，你能不能也让我做一朵假花啊？我也想让前辈看看我厉害的地方。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「吶禮，妳能不能也讓我做一朵假花啊？我也想讓前輩看看我厲害的地方。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00265",
