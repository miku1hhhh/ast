			en = {
				{
					name = {"光姫", "Kouki"},
					"“True... but I still wake up early on days where I used to be on duty. Sooo, I just volunteer instead.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“是这样没错⋯⋯不过每到值早班的时候日子我都还是很早就醒了。所以才像这样当义工巡逻啦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「是這樣沒錯⋯⋯不過每到值早班的時候日子我都還是很早就醒了。所以才像這樣當義工巡邏啦。」",
					{"rt2"},
				},
			},
		},
