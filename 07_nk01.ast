	["0090_00047"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You’re missing out, y’know. Working on my muscles has brought me nothing but benefits!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但锻炼肌肉真的是一件很好的事啊⋯⋯！”",
