		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1107", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Pleeeaaase stop twitching your chest at meee!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“讨厌死了啦不要挤出你肩膀的肌肉让它弹来弹去的啦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「討厭死了啦不要擠出你肩膀的肌肉讓它彈來彈去的啦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00039",
		linknext = "0090_00041",
		line = 541,
	},
	["0090_00041"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00212", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You’re half my size. If you don’t learn to love my muscles then we’ll never be ready for the ‘next step’!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你是我的另一半灵魂耶。要是麻沙酱你不喜欢我的肌肉的话，我就没办法往‘下一个阶段’迈进了啊──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你是我的另一半靈魂耶。要是麻沙醬妳不喜歡我的肌肉的話，我就沒辦法往『下一個階段』邁進了啊──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00040",
		linknext = "0090_00042",
		line = 553,
	},
	["0090_00042"] = {
		{"fg", file="asane_01m_00003", file1="asane_01m_00101", file2="asane_01m_00216", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
