	["0090_00176"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00202", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="光姫17", id=17, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0154", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Guess I should start looking for a good place to set up shop. Gotta make sure it’s somewhere out of the way so it lives up to the name. But the interior needs to be chic...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“所以，我才想要找个一个好的房源。毕尽是隐家，所以还是要远离人烟的地方比较好、内部装潢也要精致一点──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「所以，我才想要找個一個好的房源。畢盡是隱家，所以還是要遠離人煙的地方比較好、內部裝潢也要精緻一點──」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00175",
		linknext = "0090_00177",
		line = 2500,
	},
	["0090_00177"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But to see someone who’s had her heart broken pick herself up like this...",
					{"rt2"},
				},
			},
			cn = {
				{
					"⋯⋯不过，曾今经历过挫折的人，也像现在这样努力振作起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"⋯⋯不過，曾今經歷過挫折的人，也像現在這樣努力振作起來。",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00176",
