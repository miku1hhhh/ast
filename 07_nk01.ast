		{"fgact", ch="礼9", id=9, act="振動下", loop=2, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2002", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Can you really blame me?! She’s so cuuute...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“可是、可是桐香大人真的很可爱嘛⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「可是、可是桐香大人真的很可愛嘛⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00317",
		linknext = "0090_00319",
		line = 4559,
	},
	["0090_00319"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You sound like a married couple bickering over their child...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么有一种在讨论要怎么养小孩的夫妻的感觉⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼有一種在討論要怎麼養小孩的夫妻的感覺⋯⋯」",
