			},
			en = {
				{
					name = {"モブ男D", "Silent Male Student"},
					"“I’m getting the impression we’re getting into TMI territory here, but... I didn’t know you were THAT frustrated, Ran.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男D", "寡言男学生"},
					"“虽然我觉得这好像不是能说的话题⋯⋯不过花丸委员长真的有那么不甘心吗⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男D", "寡言男學生"},
					"「雖然我覺得這好像不是能說的話題⋯⋯不過花丸委員長真的有那麼不甘心嗎⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00199",
