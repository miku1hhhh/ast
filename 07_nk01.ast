				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Uhm, is... everything okay? Why are you staring at me like that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯⋯⋯干么啦、怎么了？为什么要这样盯着我看？”",
