	["0090_00345"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even now, she can’t see things from my perspective.",
					{"rt2"},
				},
			},
