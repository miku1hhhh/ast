	["0090_00352"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00219", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=12},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, I don’t have any problem with that. Why, busy?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“欸？那是无所谓啦⋯⋯你有事要忙吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「欸？那是無所謂啦⋯⋯妳有事要忙嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00351",
		linknext = "0090_00353",
		line = 5114,
	},
	["0090_00353"] = {
		{"fg", file="tohka_02m_00012", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=10, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1778", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I am. Somebody got me an introduction for new part time work. It’s been a while since I felt like I could be useful somewhere.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“对啊，其实是有人介绍了一份不错的打工，罕见的轮到我了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「對啊，其實是有人介紹了一份不錯的打工，罕見的輪到我了呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00352",
		linknext = "0090_00354",
		line = 5129,
	},
	["0090_00354"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00203", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=12},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Is that okay? Are these two gonna be all right without you around? I can go if you—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯没问题吗？你们两个没有跟着一起吗？要不要我跟着去⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯沒問題嗎？你們兩個沒有跟著一起嗎？要不要我跟著去⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00353",
		linknext = "0090_00355",
		line = 5141,
	},
	["0090_00355"] = {
		{"fg", file="tohka_02m_00012", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=10, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1779", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“No need, it’s my kind of work. It’s basically a research request from the former SHO.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“嗯，是适合我做的工作所以没关系。毕竟是旧SHO发来的调查委托。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「嗯，是適合我做的工作所以沒關係。畢竟是舊SHO發來的調查委託。」",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00354",
		linknext = "0090_00356",
		line = 5156,
	},
	["0090_00356"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Makes sense that the old representative of the FS would be good for this kind of request from the former SHO.",
					{"rt2"},
				},
			},
			cn = {
				{
					"确实，如果是旧SHO的委托的话，也就只有前FS的代表能出场了⋯⋯",
					{"rt2"},
				},
			},
			tw = {
				{
					"確實，如果是舊SHO的委託的話，也就只有前FS的代表能出場了⋯⋯",
					{"rt2"},
				},
			},
		},
		linkback = "0090_00355",
		linknext = "0090_00357",
		line = 5166,
	},
	["0090_00357"] = {
		{"text"},
		text = {
