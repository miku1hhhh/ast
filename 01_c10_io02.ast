		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She had no siblings. No relatives at all. No one but herself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没有兄弟姐妹、孤苦伶仃，孤独终老──",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒有兄弟姐妹、孤苦伶仃，孤獨終老──",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00349",
