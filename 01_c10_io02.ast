				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I try my best to say it naturally, but instead it comes out a little forced.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我尽力说得好像这没什么，但这搞不好反而更刻意。",
