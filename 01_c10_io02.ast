	},
	["0001_00209"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Coincidence or not, Ikuko’s part of the FS now. She’s found her family. I’m glad I could give that to her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算一切只是巧合，但郁子能加入FS、和这些家人一起生活，真是太好了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算一切只是巧合，但郁子能加入FS、和這些家人一起生活，真是太好了。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00208",
		linknext = "0001_00210",
		line = 2778,
	},
	["0001_00210"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file3="ikuko_01m_00301", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0342", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Although, I’d like to be actual family with you, Junnosuke! If you know what I mean!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我希望你啊，跟我能不要只是看起来像、而是成为真正的家人喔？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我希望你啊，跟我能不要只是看起來像、而是成為真正的家人喔？」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00209",
		linknext = "0001_00211",
		line = 2793,
	},
	["0001_00211"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00210", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Heh. If you want to be part of my family, then I’ll have to be part of yours, you know.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哼……成为我的家人，就意味着我也成为了家人了唷？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哼……成為我的家人，就意味著我也成為了家人了唷？」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00210",
		linknext = "0001_00212",
		line = 2805,
	},
	["0001_00212"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00209", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Allow me to explain. In my haste to come up with a witty response, I have utterly failed to do so.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我想要回她一个相当诙谐的反驳作为声明，不过我想不出来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我想要回她一個相當詼諧的反駁作為聲明，不過我想不出來。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00211",
		linknext = "0001_00213",
		line = 2818,
	},
	["0001_00213"] = {
