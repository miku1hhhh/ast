					name = {"凛", "Rin"},
					"“You should know better though, Sis. The Anti-Copulation Front is full of grade-A, gung-ho freaks. You’re gonna get run down if you don’t gold-star the fuck up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“不过这样不是很好吗，姐姐？不是跟你说过了反交尾势力都是些只会叫嚣没三小实力的家伙吗，像你这样一点也不花丸的作风被碾死也是应该的嘛？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「不過這樣不是很好嗎，姐姐？不是跟妳說過了反交尾勢力都是些只會叫囂沒三小實力的傢伙嗎，像妳這樣一點也不花丸的作風被碾死也是應該的嘛？」",
					{"rt2"},
				},
			},
		},
