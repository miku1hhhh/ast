				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Come to think of it, I don’t think I’ve ever seen you look tired.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“话说回来，我好像没见过郁子睡眼惺忪的样子呢。”",
