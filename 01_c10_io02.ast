					name = {"淳之介", "Junnosuke"},
					"“There you go again...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你又自作主张⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳又自作主張⋯⋯」",
