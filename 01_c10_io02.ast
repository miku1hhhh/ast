					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“No, it’s different. I haven’t seen it since I came to the island. It’s sort of like kaiten-yaki, but the inside is more like okonomiyaki.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
