				{"vo", file="ikuko0362", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Hee-hee♪ Today will be our affection level anniversary. Don’t forget♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嘿嘿♪今天是亲爱的好感度上升纪念日。我记录一下，免得之后忘记♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嘿嘿♪今天是親愛的好感度上升紀念日。我記錄一下，免得之後忘記♪」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00340",
		linknext = "0001_00342",
		line = 4740,
	},
	["0001_00342"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00213", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=14},
		{"text"},
		text = {
