	["0001_00343"] = {
		{"bgm", stop=1},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I give a little scowl in protest... but I can’t deny it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我虽然皱着眉头──也无法完全否认。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我雖然皺著眉頭──也無法完全否認。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00342",
		linknext = "0001_00344",
		line = 4763,
	},
	["0001_00344"] = {
		{"fgact", ch="郁子10", id=10, lv=10, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After listening to her talk about her family this morning, I’ve grown... “intrigued” might be the wrong word.",
					{"rt2"},
				},
			},
			cn = {
				{
					"今天早上直接从郁子的嘴里听到家人的事，我就对她产生了兴趣──啊、说是兴趣有点不对。",
					{"rt2"},
				},
			},
			tw = {
				{
					"今天早上直接從郁子的嘴裡聽到家人的事，我就對她產生了興趣──啊、說是興趣有點不對。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00343",
		linknext = "0001_00345",
		line = 4775,
	},
	["0001_00345"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But there’s no talking around the fact that I’ve become more interested in her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但我确实是比之前更在意起郁子的事了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但我確實是比之前更在意起郁子的事了。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00344",
		linknext = "0001_00346",
		line = 4785,
	},
	["0001_00346"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I remember the pain of losing my own parents like it was yesterday.",
					{"rt2"},
				},
			},
			cn = {
				{
					"父母双双丧命时的绝望感，我至今都还记得。",
					{"rt2"},
				},
			},
			tw = {
				{
					"父母雙雙喪命時的絕望感，我至今都還記得。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00345",
		linknext = "0001_00347",
		line = 4795,
	},
	["0001_00347"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I was thrown into the world not knowing a thing, without even a second to mourn.",
					{"rt2"},
				},
			},
			cn = {
				{
					"还不知道怎么生存就得自力更生，我不得不为自己的未来考虑而没时间去难过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"還不知道怎麼生存就得自力更生，我不得不為自己的未來考慮而沒時間去難過。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00346",
		linknext = "0001_00348",
		line = 4805,
	},
	["0001_00348"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But Asa gave me the strength to move on.",
					{"rt2"},
				},
			},
			cn = {
				{
					"尽管如此，我还是觉得我可以做点什么，因为有麻沙酱在。",
					{"rt2"},
				},
			},
			tw = {
				{
					"儘管如此，我還是覺得我可以做點什麼，因為有麻沙醬在。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00347",
		linknext = "0001_00349",
		line = 4815,
	},
	["0001_00349"] = {
