		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00201", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah. I was tired until a minute ago, but this morning stroll woke me right up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊，刚才还觉得困、不过走一走就醒了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊，剛才還覺得困、不過走一走就醒了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00178",
		linknext = "0001_00180",
		line = 2412,
	},
	["0001_00180"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The fresh, early-morning air is even crisper than usual.",
					{"rt2"},
				},
			},
			cn = {
				{
					"清晨的空气比往常清新宜人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"清晨的空氣比往常清新宜人。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00179",
		linknext = "0001_00181",
		line = 2422,
	},
	["0001_00181"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A deep breath fills my lungs with the scent of budding flowers and fresh stream water carried on the wind.",
					{"rt2"},
				},
			},
			cn = {
				{
					"风中夹杂着含苞欲放的花香和清澈的河水清香，深吸一口气，整个人都充满了清新的空气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"風中夾雜著含苞欲放的花香和清澈的河水清香，深吸一口氣，整個人都充滿了清新的空氣。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00180",
		linknext = "0001_00182",
		line = 2432,
	},
	["0001_00182"] = {
