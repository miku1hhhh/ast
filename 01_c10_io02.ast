					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在撸的時候啊。得要是一種不會被任何人打擾、在短時內隨心所欲、變得自由⋯⋯獲得救贖的感覺才行。就讓我一個人靜靜地大快朵頤⋯⋯」",
					{"rt2"},
				},
			},
