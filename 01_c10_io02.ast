	},
	["0001_00184"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00211", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[5300] = {
				{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file3="ikuko_02m_00301", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, timestamp=24, delay2=5300, mode=3, x=-5, y=-5},
			},
			[5299] = {
				{"transitiontime", time=300, timestamp=24, delay2=5300},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko0334", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“When I lived at home they taught me how to last for three whole days without sleep. I’d have the stamina for a 72-hour fuckathon if you were up for it, Darling.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“在老家的时候，我被教过能三天三夜不睡觉战斗的方法。要是想的话我也可以跟亲爱的你来场连续72小时的耐久做爱喔？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「在老家的時候，我被教過能三天三夜不睡覺戰鬥的方法。要是想的話我也可以跟親愛的你來場連續72小時的耐久做愛喔？」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00183",
		linknext = "0001_00185",
		line = 2472,
	},
	["0001_00185"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00214", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
