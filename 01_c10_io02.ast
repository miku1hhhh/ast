		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“When we have a fap, we want to fap freely, without interruption. We want to feel relaxed. To be alone somewhere quiet and comfortable...”",
