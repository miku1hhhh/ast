	},
	["0001_00199"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00211", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0337", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I’m not really sure but I think they were just trying to get rid of us. Touka and Rei didn’t have anywhere to go back to on the mainland either.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“这点我虽然不太懂，不过我觉得那是一种解脱。而且不管是桐香酱还是礼酱，她们也在本岛也没有可以回去的地方就是了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「這點我雖然不太懂，不過我覺得那是一種解脫。而且不管是桐香醬還是禮醬，她們也在本島也沒有可以回去的地方就是了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00198",
		linknext = "0001_00200",
		line = 2651,
	},
	["0001_00200"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00211", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0338", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“We would have been an inconvenience if we stayed on the island, so they probably thought the first thing to do was drive us out. I don’t know what they would have done after that though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“像我们这样的人要是留在岛上就麻烦了，所以我想第一要务是把这些人赶出去对吧？虽然说我不知道之后会想做什么就是了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「像我們這樣的人要是留在島上就麻煩了，所以我想第一要務是把這些人趕出去對吧？雖然說我不知道之後會想做什麼就是了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00199",
		linknext = "0001_00201",
		line = 2666,
	},
	["0001_00201"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When I think back on the situation, it’s clear that the returning FS with no place to go home to wouldn’t have received a warm welcome.",
					{"rt2"},
				},
			},
			cn = {
				{
					"考虑到当时的情况──我不认为他们会厚待没有返家的FS们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"考慮到當時的情況──我不認為他們會厚待沒有返家的FS們。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00200",
		linknext = "0001_00202",
		line = 2676,
	},
	["0001_00202"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00229", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0339", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“So anyway, I’m all alone. The FS is my family.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“这么说，就是因为我总是只有自己孤身一个人，所以FS对我来说就像家人一样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「這麼說，就是因為我總是只有自己孤身一個人，所以FS對我來說就像家人一樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00201",
		linknext = "0001_00203",
		line = 2691,
	},
	["0001_00203"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ikuko looks toward the school building. I see something flash in her eyes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"郁子将视线转向校舍的时候，眼中映出了某种转瞬即逝的东西。",
					{"rt2"},
				},
			},
			tw = {
				{
					"郁子將視線轉向校舍的時候，眼中映出了某種轉瞬即逝的東西。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00202",
		linknext = "0001_00204",
		line = 2701,
	},
	["0001_00204"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file3="ikuko_02m_00310", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[4300] = {
				{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00202", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, timestamp=25, delay2=4300, mode=3, x=-5, y=-5},
			},
			[4299] = {
				{"transitiontime", time=300, timestamp=25, delay2=4300},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko0340", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I’m grateful for everything you’ve done for me, Junnosuke. Thank you. For keeping us all together back then.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“所以啊，我真的很感谢淳之介君……谢谢你。那个时候，是你将我们联系了起来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「所以啊，我真的很感謝淳之介君……謝謝你。那個時候，是你將我們聯繫了起來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00203",
		linknext = "0001_00205",
		line = 2719,
	},
	["0001_00205"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her sudden smile catches me off guard and I reflexively look away.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她突地绽放的笑容让我的心不由自主地颤动了一下，我不禁移开了视线。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她突地綻放的笑容讓我的心不由自主地顫動了一下，我不禁移開了視線。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00204",
		linknext = "0001_00206",
		line = 2729,
	},
	["0001_00206"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00218", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That was just a coincidence... Besides, it was both of us who got things rolling.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……那只是巧合而已，我们也只是顺水推舟而已，没什么好谢的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……那只是巧合而已，我們也只是順水推舟而已，沒什麼好謝的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00205",
		linknext = "0001_00207",
		line = 2741,
	},
	["0001_00207"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00207", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0341", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Still. It meant a lot to me. Thank you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“就算是这样也没关系。我那时候真的很高兴喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「就算是這樣也沒關係。我那時候真的很高興喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00206",
		linknext = "0001_00208",
		line = 2756,
	},
	["0001_00208"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...Oh.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯是吗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯是嗎。」",
					{"rt2"},
