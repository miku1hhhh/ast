		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nagasaki, eh? Now I get why she ordered the noodle plate and milkshake yesterday.",
					{"rt2"},
				},
			},
			cn = {
				{
					"原来是长崎啊──这么说的话，她昨天点了广东炒面跟长崎奶昔也就很合理了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"原來是長崎啊──這麼說的話，她昨天點了廣東炒麵跟長崎奶昔也就很合理了。",
					{"rt2"},
				},
			},
		},
		linkback = "0001_00336",
