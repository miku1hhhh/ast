				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You’re damn right, Mozart! Get it wrong again and we’ll have a whole band of composers: Bach, Chopin, Beethoven, Schubert!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“没错莫札特！要是下次再搞错就要叫你巴哈、萧邦、贝多芬跟舒伯特，让你们组成乐团了！！”",
