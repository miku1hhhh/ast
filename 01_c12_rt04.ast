		{"transitiontime", time=700},
		{"se", id=0, stop=1, time=2000},
		{"fg", file="rei_01f_00001", file1="rei_01f_00101", file2="rei_01f_00219", path=":fg/rei_01f/", id=30, ch="礼", lv=1, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0480", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“What if we had been able to convince ourselves like she did... Brainwash ourselves into accepting this island’s old ways... Would we have avoided all the pain and suffering we went through?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……要是像那样……能像是洗脑那样染上其他思想……让人习惯……也就不用这么辛苦了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……要是像那樣……能像是洗腦那樣染上其他思想……讓人習慣……也就不用這麼辛苦了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00159",
		linknext = "0004_00161",
		line = 2638,
	},
	["0004_00161"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00218", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
