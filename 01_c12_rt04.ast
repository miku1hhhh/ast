				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「沒錯莫札特！要是下次再搞錯就要叫你巴哈、蕭邦、貝多芬跟舒伯特，讓你們組成樂團了！！」",
					{"rt2"},
				},
			},
		},
