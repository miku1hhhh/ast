			},
			cn = {
				{
					name = {"凛"},
					"“呵呵呵……这是最棒的余兴节目……不愧是观光大使……简直是会走动的观光资源……！看了这样的好东西，都想献上之前被塞克罗斯开光过的灵验开运肉壶了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「呵呵呵……這是最棒的餘興節目……不愧是觀光大使……簡直是會走動的觀光資源……！看了這樣的好東西，都想獻上之前被塞克羅斯開光過的靈驗開運肉壺了。」",
					{"rt2"},
				},
			},
		},
