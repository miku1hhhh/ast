			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Don’t get clever with me! You’re not Beethoven, you’re Schubert! Have you forgotten your name, you piece of Chopin?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不要讲那些有的没的！首先你不是贝多芬是舒伯特吧！连自己名字也记不住吗萧邦！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不要講那些有的沒的！首先你不是貝多芬是舒伯特吧！連自己名字也記不住嗎蕭邦！？」",
					{"rt2"},
				},
			},
		},
