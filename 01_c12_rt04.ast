	["0004_00162"] = {
		{"cgact", file="cgact", act="表示アクション", alpha=0, id=9, time=500, alphadel=1, style="reset"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I had been able to accept the old law, would I have been happier? It’s pointless to even think about it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"要是能接受旧条例会比较幸福吗──现在想这种事也没意义。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要是能接受舊條例會比較幸福嗎──現在想這種事也沒意義。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00161",
		linknext = "0004_00163",
		line = 2662,
	},
	["0004_00163"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s precisely because I couldn’t accept the old law that I fought against it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就是因为办不到，所以我们才要继续奋斗。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就是因為辦不到，所以我們才要繼續奮鬥。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00162",
		linknext = "0004_00164",
		line = 2672,
	},
	["0004_00164"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Besides, even if we had accepted it, it would only have brought us momentary bliss—the same way a dispassionate one-night stand would.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算大家能接受──结果那还是跟暂时的性行为一样，只是刹那间的幸福而已。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算大家能接受──結果那還是跟暫時的性行為一樣，只是剎那間的幸福而已。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00163",
		linknext = "0004_00165",
		line = 2682,
	},
	["0004_00165"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And Rei should know better than anyone the dangers that come along with being steeped in that kind of exclusionary thinking.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈应该也很明白接受这种排他思想的危险性。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩應該也很明白接受這種排他思想的危險性。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00164",
		linknext = "0004_00166",
		line = 2692,
	},
	["0004_00166"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This island is almost too obvious an example of a perverted thought taken to the extreme. Rin really wasn’t in a position to laugh at Senba’s misfortune.",
					{"rt2"},
				},
			},
			cn = {
				{
					"推动变态信仰的这个岛就是很显着的例子──像是宣称自己是神的代言人的花丸妹妹，也没有可以笑仙波小姐的立场。",
					{"rt2"},
				},
			},
			tw = {
				{
					"推動變態信仰的這個島就是很顯著的例子──像是宣稱自己是神的代言人的花丸妹妹，也沒有可以笑仙波小姐的立場。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00165",
		linknext = "0004_00167",
		line = 2702,
	},
	["0004_00167"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Not to mention myself, with my twisted virgin obsession...",
					{"rt2"},
				},
			},
			cn = {
				{
					"当然，对处女抱有扭曲信仰的我也────",
					{"rt2"},
				},
			},
			tw = {
				{
					"當然，對處女抱有扭曲信仰的我也────",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00166",
