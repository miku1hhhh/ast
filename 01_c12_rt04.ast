			},
			en = {
				{
					name = {"礼", "Rei"},
					"“This costs 800 yen a bottle! It’s got ions! And germanium! It’ll stop all thought interceptions, conceptions and whatever else you’d like!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这是一杯要800元的水！有非常多负离子跟锗，有很好的治疗效果！也就是说喝了就能打断窃听脑波效果，妄想也会消失！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這是一杯要800元的水！有非常多負離子跟鍺，有很好的治療效果！也就是說喝了就能打斷竊聽腦波效果，妄想也會消失！」",
					{"rt2"},
				},
			},
		},
