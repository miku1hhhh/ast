		},
		text = {
			vo = {
				{"vo", file="rei0620", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“The day after the party we just had, she ate the sushi we accidentally froze and said it was ‘crunchy and tasty...’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不久前她才在派对隔天把冷冻的寿司给搞错吃了下去，还说出‘脆脆的很好吃’这种话呢⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不久前她才在派對隔天把冷凍的壽司給搞錯吃了下去，還說出『脆脆的很好吃』這種話呢⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00045",
		linknext = "0026_00047",
		line = 598,
	},
	["0026_00047"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file3="ikuko_01m_00304", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
