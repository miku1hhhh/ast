		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...Schubert, the Birds of a Feather have always had the upper hand on the FS, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯舒伯特，我们FS一直以来对上‘Tori公’时都落于下风、对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯舒伯特，我們FS一直以來對上『Tori公』時都落於下風、對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00073",
		linknext = "0026_00075",
		line = 1033,
	},
	["0026_00075"] = {
		{"fg", file="schubert_01l_00001", file2="schubert_01l_00214", file4="schubert_01l_00401", file5="schubert_01l_00501", path=":fg/schubert_01l/", id=12, lv=12, head="schubert_01l", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=-5, y=-5},
