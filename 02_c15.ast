	["0026_00145"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00102", file2="jun_01f_00209", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What? The one I’ve heard so much about?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“欸，仙波小姐传说中的妹妹──！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
