			},
			[1999] = {
				{"transitiontime", time=300, timestamp=13, delay2=2000},
			},
		},
		text = {
			vo = {
				{"vo", file="schubert0156", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Hm? Yes, they appeared about six months ago. We’ve been able to discover them eight times in total, but they’ve gotten away before we could so much as gather information on them each time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“嗯？是啊，‘Tori公’大约是在半年前出现的。在那段时间里，一共被我们发现了8次。不过每次都是连情报都没有搜集到就让他们给跑了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「嗯？是啊，『Tori公』大約是在半年前出現的。在那段時間裡，一共被我們發現了8次。不過每次都是連情報都沒有蒐集到就讓他們給跑了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00074",
		linknext = "0026_00076",
		line = 1051,
	},
	["0026_00076"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00209", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
