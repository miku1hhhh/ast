	["0026_00062"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00102", file2="susuko_02m_00205", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="スス子11", id=11, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0228", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Stop, stop. Didn’t you get slapped around and smacked to the ground...? Are you really making yourself up to look nice, natural, and pretty like some cosmetics salesgirl?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“不不不，你是被暴揍过是吗……怎么看起来像擅长化妆的女生一样自然？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「不不不，妳是被暴揍過是嗎……怎麼看起來像擅長化妝的女生一樣自然？」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00061",
		linknext = "0026_00063",
		line = 850,
	},
	["0026_00063"] = {
		{"fg", file="rin_01m_00001", file1="rin_01m_00101", file2="rin_01m_00216", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0158", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“This is what happens when you lack faith. If you’d had Skeetus’s protection, you could simply have said ‘Let there be cum’ to create enough semen to shoot them down with ejaculatory power.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“那是因为你没有足够的信仰之心。如果你有塞克罗斯的加持，就可以靠咏唱‘来精’让精子在那里诞生、利用射精的威力击落其他敌人喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「那是因為你沒有足夠的信仰之心。如果你有塞克羅斯的加持，就可以靠詠唱『來精』讓精子在那裡誕生、利用射精的威力擊落其他敵人喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00062",
		linknext = "0026_00064",
		line = 864,
	},
	["0026_00064"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00214", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What kind of awful god is that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真是令人讨厌的神啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真是令人討厭的神啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00063",
		linknext = "0026_00065",
		line = 876,
	},
	["0026_00065"] = {
		{"fg", file="rin_01m_00001", file1="rin_01m_00101", file2="rin_01m_00222", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="凛14", id=14, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0159", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“I can’t believe you let the Anti-Copulation Front get away after holding an event of that size... This will cost you a lot of stars! You’re responsible for this, President. What do you have to say?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“都举办那么大规模的活动了，结果还是让反交尾势力给逃了⋯⋯花丸点要大扣分喔！会长身为负责人难道都不该表示吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「都舉辦那麼大規模的活動了，結果還是讓反交尾勢力給逃了⋯⋯花丸點要大扣分喔！會長身為負責人難道都不該表示嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00064",
		linknext = "0026_00066",
		line = 892,
	},
	["0026_00066"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00212", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=595, y=-5},
