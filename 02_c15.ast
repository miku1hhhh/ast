	["0026_00009"] = {
		{"fg", file="sakimori_01f_00001", file1="sakimori_01f_00101", file2="sakimori_01f_00201", file3="sakimori_01f_00301", path=":fg/sakimori_01f/", id=30, ch="防人老人", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0019", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Is that not what you truly desire? Not to merely run from the enemy, but to be gifted the means to fight back against them?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘你真的不想要吗？比起逃跑，能让你挺身作战的技能。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『你真的不想要嗎？比起逃跑，能讓你挺身作戰的技能。』",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00008",
		linknext = "0026_00010",
		line = 112,
	},
