	["0026_00087"] = {
		{"fg", file="schubert_01m_00002", file2="schubert_01m_00207", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=495, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0159", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“As unforgivable as the Birds of a Feather’s wicked acts of rejecting perversion may be... This too will be resolved by the creation of the Lewd Code and the USP.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“虽然说我不能容忍‘Tori公’否定变法行为的这种恶行⋯⋯不过这也是在变态法跟USD实施之前而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「雖然說我不能容忍『Tori公』否定變法行為的這種惡行⋯⋯不過這也是在變態法跟USD實施之前而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00086",
		linknext = "0026_00088",
		line = 1229,
	},
	["0026_00088"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00202", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-5, y=-5},
