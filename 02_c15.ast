	["0026_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What reason would the FS in this world have to reject the USP, though?",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是这个世界的FS有什么理由拒绝USD呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是這個世界的FS有什麼理由拒絕USD呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00126",
		linknext = "0026_00128",
		line = 1768,
	},
	["0026_00128"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Its establishment should only be a positive for them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"成立USD的话，对FS来说应该只有好处才是。",
					{"rt2"},
				},
			},
			tw = {
				{
					"成立USD的話，對FS來說應該只有好處才是。",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00127",
		linknext = "0026_00129",
		line = 1778,
