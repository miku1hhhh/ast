	["0026_00067"] = {
		{"fg", file="rin_01m_00001", file1="rin_01m_00101", file3="rin_01m_00304", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0160", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“She’s not listening to me at all...! This always happens, everyone praising her for her charisma while she ignores the voices of the masses...! Divine punishment awaits you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“完全不听人话啊这个人⋯⋯！总是一副很有魅力很受爱戴的样子却完全不听取民意⋯⋯！总有一天你会遭报应的⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「完全不聽人話啊這個人⋯⋯！總是一副很有魅力很受愛戴的樣子卻完全不聽取民意⋯⋯！總有一天妳會遭報應的⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00066",
		linknext = "0026_00068",
		line = 921,
	},
