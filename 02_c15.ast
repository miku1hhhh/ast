	},
	["0026_00155"] = {
		{"evset", file="kcg03", set="kcg03", path=":ev/kcg03/"},
		{"evset", file="kcg0300010201-1", set="kcg030001", path=":ev/kcg030001/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg0300010201-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0716", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Well, top of the list needs to be pulling whoever is inside the Armored Hamedori out of that thing... But it’s not like we can hold another event already.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“总之，得尽快把武装Hamedori君的藏镜人给找出来⋯⋯但不可能在这个时间段举办活动。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「總之，得盡快把武裝Hamedori君的藏鏡人給找出來⋯⋯但不可能在這個時間段舉辦活動。」",
					{"rt2"},
