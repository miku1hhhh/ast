				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“That is... what that would mean, but... Oh, I don’t get it...! Are these my feelings, or are they the old me’s feelings, I can’t tell...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“应该、是这样⋯⋯吧⋯⋯不对、我不知道⋯⋯！这到底是我的心情、还是原本的我的感觉。我分辨不出来⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「應該、是這樣⋯⋯吧⋯⋯不對、我不知道⋯⋯！這到底是我的心情、還是原本的我的感覺。我分辨不出來⋯⋯」",
					{"rt2"},
				},
			},
		},
