					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“That might become more clear as our memories keep getting overwritten, but...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“如果记忆覆盖持续下去的话，说不定会变得更明了⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「如果記憶覆蓋持續下去的話，說不定會變得更明瞭⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00129",
		linknext = "0026_00131",
		line = 1803,
	},
	["0026_00131"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
