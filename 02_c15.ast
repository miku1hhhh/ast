	["0026_00105"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00212", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“They want you all to refocus yourselves because people who say those kinds of things could very well appear! You were getting carried away, and they were setting you straight!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“会出现那种人也没什么奇怪的，所以大家要绷紧神经──她们是想要对太过安逸的你们这么说。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「會出現那種人也沒什麼奇怪的，所以大家要繃緊神經──她們是想要對太過安逸的你們這麼說。」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00104",
		linknext = "0026_00106",
		line = 1480,
	},
	["0026_00106"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file3="jun_01f_00307", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
