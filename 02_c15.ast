	["0026_00011"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0020", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Do you not despise this law, which disregards and tramples on the rights of minorities?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘你难道不讨厌这个对少数人置之不理、践踏他们心灵的条例吗？’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『你難道不討厭這個對少數人置之不理、踐踏他們心靈的條例嗎？』",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00010",
		linknext = "0026_00012",
		line = 134,
	},
	["0026_00012"] = {
