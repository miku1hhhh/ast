	["0026_00148"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So World A’s vice president is in the same position as me in this world.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也就是说，A世界的副会长和我B世界的情况是一样的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也就是說，A世界的副會長和我B世界的情況是一樣的。",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00147",
		linknext = "0026_00149",
		line = 2077,
	},
	["0026_00149"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hold on. But didn’t that promotional video already exist when I came here? The timeline doesn’t seem to match up...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“等一下。我来的时候应该已经有那个广告了。是不是时间错位了⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「等一下。我來的時候應該已經有那個廣告了。是不是時間錯位了⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00148",
		linknext = "0026_00150",
		line = 2089,
	},
	["0026_00150"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0626", path=":vo/", ch="rei"},
			},
