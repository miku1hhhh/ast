	["0026_00006"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Appearing after some static, the mysterious old man asks me a question.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从沙尘暴里出现的神秘老人，对着我问。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從沙塵暴裡出現的神秘老人，對著我問。",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00005",
		linknext = "0026_00007",
		line = 76,
	},
	["0026_00007"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0018", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“You, young one who came running to this place. Is that not what you wish for?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘你不想要吗？逃跑到这里来的年轻人。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『你不想要嗎？逃跑到這裡來的年輕人。』",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00006",
		linknext = "0026_00008",
		line = 88,
	},
