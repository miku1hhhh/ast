	["0026_00146"] = {
		{"evset", file="kcg03", set="kcg03", path=":ev/kcg03/"},
		{"evset", file="kcg0300040301-1", set="kcg030004", path=":ev/kcg030004/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg0300040301-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0715", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“She doesn’t take after her sister at all. It was great, she really has it together and is so serious about her work! She is weaker than me, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“好加在她跟她姐姐不像，是个很踏实的人，对工作也很有热忱呢～。唔，不过跟郁比的话还是弱了点啦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「好加在她跟她姐姐不像，是個很踏實的人，對工作也很有熱忱呢～。唔，不過跟郁比的話還是弱了點啦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00145",
		linknext = "0026_00147",
		line = 2057,
	},
	["0026_00147"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Putting aside Ikuko’s thoughts on Senba.",
					{"rt2"},
				},
			},
			cn = {
				{
					"先不去管郁子对仙波小姐的评价如何。",
