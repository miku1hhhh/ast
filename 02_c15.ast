			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“对啊！要是整个世界都变态化了，逃跑的人肯定没有立足之地！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「對啊！要是整個世界都變態化了，逃跑的人肯定沒有立足之地！」",
					{"rt2"},
				},
			},
		},
