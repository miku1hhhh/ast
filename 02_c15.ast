				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...What do you mean?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯怎么回事？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯怎麼回事？」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00118",
		linknext = "0026_00120",
		line = 1673,
	},
	["0026_00120"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00203", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0594", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“In other words—our consciousnesses in this world made us say that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“也就说，这是这边世界的我们自己的意识要我们说的──就是这样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「也就說，這是這邊世界的我們自己的意識要我們說的──就是這樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00119",
		linknext = "0026_00121",
		line = 1688,
	},
	["0026_00121"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"These three, but from World B?",
					{"rt2"},
				},
			},
			cn = {
				{
					"是指B世界的FS？",
					{"rt2"},
				},
			},
			tw = {
				{
					"是指B世界的FS？",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00120",
		linknext = "0026_00122",
		line = 1698,
	},
	["0026_00122"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We’ve already gone over the idea that our memories are gradually being overwritten.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从之前开始我们就一直推测着，我们的记忆正在被一点一点地覆盖。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從之前開始我們就一直推測著，我們的記憶正在被一點一點地覆蓋。",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00121",
		linknext = "0026_00123",
		line = 1708,
	},
	["0026_00123"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So have things proceeded to the point where our memories have been eaten into, forcing us to state the opinions we held in this world?",
					{"rt2"},
				},
			},
			cn = {
				{
					"继续这么下去、到最后记忆会被侵蚀、然后说出这个世界的自己想说的意见吗──？",
					{"rt2"},
				},
			},
			tw = {
				{
					"繼續這麼下去、到最後記憶會被侵蝕、然後說出這個世界的自己想說的意見嗎──？",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00122",
		linknext = "0026_00124",
		line = 1718,
	},
	["0026_00124"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00209", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hold on... So you’re saying that you three were against the USP in this world?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“等等……所以你的意思是说，B世界的你们是反对USD的吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「等等……所以妳的意思是說，B世界的妳們是反對USD的嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00123",
		linknext = "0026_00125",
		line = 1730,
	},
	["0026_00125"] = {
