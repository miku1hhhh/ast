	["0026_00153"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Obscured by the mascot suit that is Hamedori, we can’t make out the profile of this young man who would have been in my position.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有关那个和我有着一样职务的少年的一切资讯，都因为被隐藏在Hamedori君的布偶服后，所以看不到。",
					{"rt2"},
				},
			},
			tw = {
				{
					"有關那個和我有著一樣職務的少年的一切資訊，都因為被隱藏在Hamedori君的布偶服後，所以看不到。",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00152",
		linknext = "0026_00154",
		line = 2140,
	},
	["0026_00154"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg0300010301-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0597", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Our memories are already being overwritten. The Lewd Code will be enacted soon... I think we’ll need to come up with a plan at once.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我们的记忆已经被覆盖了。变态法实施的日期也很近⋯⋯有必要尽快制定对策。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我們的記憶已經被覆蓋了。變態法實施的日期也很近⋯⋯有必要盡快制定對策。」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00153",
		linknext = "0026_00155",
