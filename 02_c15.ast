			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Turning an entire country perverted would put the SHO under government control. The freedoms we’ve been allowed until now may become restricted by the state...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“国家变态化，意味着SHO这个组织将成为国营企业。一直以来允许的自由，可能会受到国家的限制也说不定⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「國家變態化，意味著SHO這個組織將成為國營企業。一直以來允許的自由，可能會受到國家的限制也說不定⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00093",
