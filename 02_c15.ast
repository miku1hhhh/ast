				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“M-Maybe you’re sick...?! So even you get sick, Ikuko? Is everything okay? Do you have your insurance card? Should I take you to the hospital? What should we do, Miss Touka?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“该、该不会是生病了吧⋯⋯！？连你都会这样吗郁子、不要紧吗？你有健保卡吗？要不要我送你去医院？桐香大人我们该怎么办才好！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「該、該不會是生病了吧⋯⋯！？連妳都會這樣嗎郁子、不要緊嗎？妳有健保卡嗎？要不要我送妳去醫院？桐香大人我們該怎麼辦才好！？」",
					{"rt2"},
				},
			},
		},
