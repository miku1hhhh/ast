			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Gaaah! How dare you make a fool of Rin Hanamaru, SHO auditor’s aide and god’s disciple! Fine, then I’ll just report this! The SHO is pretty ticked off at the Birds of a Feather too, after all!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“噫！你居然小看位列SHO监察官辅佐、身为神使的花丸凛我！啊啊对了这样吧我去检举那个吧，反正SHO也一直都很不爽‘Tori公’！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「噫！你居然小看位列SHO監察官輔佐、身為神使的花丸凜我！啊啊對了這樣吧我去檢舉那個吧，反正SHO也一直都很不爽『Tori公』！」",
					{"rt2"},
				},
			},
		},
