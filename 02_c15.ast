		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0160", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“T-That’s right, you three... You said that since the enactment of the perverted sex law, it was our role to convey the splendor of perverted sex to all nations of the world...”",
