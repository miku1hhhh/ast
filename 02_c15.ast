	},
	["0026_00184"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00207", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What’s the matter, it seems like you haven’t been coming to school at all. I’ve been worried, you’re not there every time I come to your class. You know you shouldn’t be playing hooky, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么了，你似乎好久没来学校了。每次我往教室里看你都不在，哥哥很担心你喔？翘课是不行的吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼了，妳似乎好久沒來學校了。每次我往教室裡看妳都不在，哥哥很擔心妳喔？翹課是不行的吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00183",
		linknext = "0026_00185",
		line = 2529,
	},
	["0026_00185"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00201", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Your attendance is bad enough on its own, plus you’re not keeping up with your schoolwork. You’re close to flunking, okay? The school’s gonna axe you if you don’t shape up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你的出席率免强算够，功课也跟不上，差点就不及格。这样下去肯定会被退学吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你的出席率免強算夠，功課也跟不上，差點就不及格。這樣下去肯定會被退學吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00184",
		linknext = "0026_00186",
		line = 2541,
	},
	["0026_00186"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I plan on getting sick of washing and drying your panties in about fifty years, so wait no that doesn’t matter Asa, just jump in my arms and hug me tight...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“还要过50年我才会讨厌洗你的内裤这种事所以啊、啊算了不管这个了总之麻沙酱，跳哥哥身上让我好好抱紧你吧⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「還要過50年我才會討厭洗妳的內褲這種事所以啊、啊算了不管這個了總之麻沙醬，跳哥哥身上讓我好好抱緊你吧⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00185",
		linknext = "0026_00187",
		line = 2553,
	},
	["0026_00187"] = {
