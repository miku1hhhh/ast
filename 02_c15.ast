	["0026_00138"] = {
		{"evset", file="kcg03", set="kcg03", path=":ev/kcg03/"},
		{"evset", file="kcg0300040505-1", set="kcg030004", path=":ev/kcg030004/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg0300040505-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0595", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“That I still remember. I made a proposal, asking if he’d act as our poster boy in exchange for an exemption from sexual acts.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“这个我还记得。我以免除性行为作为交换条件，希望他能替代我作为活看板，用这点与他达成了协议。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「這個我還記得。我以免除性行為作為交換條件，希望他能替代我作為活看板，用這點與他達成了協議。」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00137",
		linknext = "0026_00139",
		line = 1938,
	},
	["0026_00139"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Your poster boy...? So you mean being Hamedori in that video?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“活看板⋯⋯？这么说的话，是那个、广告里的Hamedori君、吗──？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「活看板⋯⋯？這麼說的話，是那個、廣告裡的Hamedori君、嗎──？」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00138",
		linknext = "0026_00140",
		line = 1950,
	},
	["0026_00140"] = {
		{"evset", file="kcg03", set="kcg03", path=":ev/kcg03/"},
		{"evset", file="kcg0300040501-1", set="kcg030004", path=":ev/kcg030004/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg0300040501-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0625", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Yeah. Normally it’s the student council president who has to be out there facing the public. But you know how Miss Touka isn’t cut out for that kind of work...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是啊。按理来说，那种抛头露面的工作应该是由学生会长来做。不过你看、因为她的那个嘛、所以那样的工作完全不适合桐香大人⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是啊。按理來說，那種拋頭露面的工作應該是由學生會長來做。不過你看、因為她的那個嘛、所以那樣的工作完全不適合桐香大人⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00139",
		linknext = "0026_00141",
		line = 1969,
	},
	["0026_00141"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg0300040501-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0713", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“She’ll wander off the moment you take your eyes off of her too. That’s why we had the vice president take the role instead, along with our secretary Mizuki.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“注意到的时候早就不知道跑去哪了呢。所以才会让副会长跟当书记的水姬酱替代她来做的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「注意到的時候早就不知道跑去哪了呢。所以才會讓副會長跟當書記的水姬醬替代她來做的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00140",
		linknext = "0026_00142",
		line = 1985,
	},
	["0026_00142"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00218", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Mizuki...? I want to say she’s on another work trip to the mainland right now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“水姬、说到她⋯⋯如果我没记错的话，她又到本岛出差了──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「水姬、說到她⋯⋯如果我沒記錯的話，她又到本島出差了──」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00141",
		linknext = "0026_00143",
		line = 1997,
	},
	["0026_00143"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I think I heard something about the brass taking an interest in her and asking her to stay for longer, along with that FS girl named Bootlicker or something.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大概跟着那些逢迎谄媚的FS女子们一起，受到那些大官们的宠爱、所以又延长差旅时间了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"大概跟著那些逢迎諂媚的FS女子們一起，受到那些大官們的寵愛、所以又延長差旅時間了。",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00142",
		linknext = "0026_00144",
		line = 2007,
	},
	["0026_00144"] = {
