		linkback = "0026_00042",
		linknext = "0026_00044",
		line = 548,
	},
	["0026_00044"] = {
		{"fg", file="rei_02m_00008", file1="rei_02m_00101", file2="rei_02m_00201", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0619", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“There’s no time, I guess I’ll just toss everything on your rice, dump miso soup on top, then wash it down your throat by force.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“已经没有时间了啦把配菜放在饭上面混着汤一起给我吞下去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「已經沒有時間了啦把配菜放在飯上面混著湯一起給我吞下去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00043",
		linknext = "0026_00045",
		line = 563,
	},
	["0026_00045"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00206", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0707", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Whaaat? I went to all that trouble making it. I know Tokie’s taste is so basic that she only ever calls food ‘tasty’ or ‘edible,’ but I don’t want you disrespecting my cooking.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“什么、这是我难得做的欸。虽然桐香酱是个不管吃什么都只会说‘好吃’、‘这能吃’的木舌头，但也不要这样糟蹋郁做的料理啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「什麼、這是我難得做的欸。雖然桐香醬是個不管吃什麼都只會說『好吃』、『這能吃』的木舌頭，但也不要這樣糟蹋郁做的料理啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00044",
		linknext = "0026_00046",
		line = 577,
	},
	["0026_00046"] = {
		{"fg", file="rei_01m_00008", file1="rei_01m_00101", file2="rei_01m_00205", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
