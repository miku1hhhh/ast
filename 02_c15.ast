				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...If that happens, we won’t be able to return to our old selves.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯但这样的话，我们就无法维持自我了。”",
