		{"fgact", ch="郁子10", id=10, lv=10, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="郁子10", id=10, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0709", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Hm? What is this feeling... Joy, welling up from the bottom of my heart despite my beloved Darling flirting with some guy I don’t even know...?! Oh no, what’s going on, Rei?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“这到底是什么感觉呢⋯⋯一想到我最喜欢的亲爱的跟不知名的男人打情骂悄，就会从心底涌上一种、开心的感觉⋯⋯！？讨厌啦、这到底是怎么回事啊礼酱！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「這到底是什麼感覺呢⋯⋯一想到我最喜歡的親愛的跟不知名的男人打情罵悄，就會從心底湧上一種、開心的感覺⋯⋯！？討厭啦、這到底是怎麼回事啊禮醬！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00080",
		linknext = "0026_00082",
		line = 1139,
	},
	["0026_00082"] = {
