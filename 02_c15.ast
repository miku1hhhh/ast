				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She somehow seems even more spaced out than usual...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“感觉好像比平常都还要迟钝欸⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「感覺好像比平常都還要遲鈍欸⋯⋯」",
