			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And I’m with them! Getting carried away, getting fucked, it can all wait until after the USP is formed. It’s like they say, save your wood until you’re out of the woods...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我也是这么想的。要糜烂还是要放送都得等到USD成立之后才行。想干就得好好夹紧小穴，说得没错吧⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我也是這麼想的。要糜爛還是要放送都得等到USD成立之後才行。想幹就得好好夾緊小穴，說得沒錯吧⋯⋯！」",
					{"rt2"},
				},
			},
		},
