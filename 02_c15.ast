		text = {
			vo = {
				{"vo", file="ikuko0708", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Listen, I don’t have high expectations of her. I saw the way she followed that up by saying ‘Oh, so that’s why you can’t spell rice without ice! Heh heh heh!’ and guffawing to herself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我有看到她在那之后还边说着‘啊、所以才会脆脆的啊，呵呵呵呵’边一个人大笑，我对她可没有任何期待喔？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我有看到她在那之後還邊說著『啊、所以才會脆脆的啊，呵呵呵呵』邊一個人大笑，我對她可沒有任何期待喔？」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00046",
		linknext = "0026_00048",
		line = 620,
	},
	["0026_00048"] = {
