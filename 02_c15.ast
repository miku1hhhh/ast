		text = {
			vo = {
				{"vo", file="ran0066", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“I heard the Birds of a Feather sicced their succubus familiar on you, only for you to transform your junk into a scythe to sweep them away and mow them down... Impressive as ever!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“任凭‘Tori公’召唤出使魔淫魔来袭击，您的肉棒都会像镰鼬一样变成镰刀状展开狂风将他们轻松收割⋯⋯真不愧是性帝！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「任憑『Tori公』召喚出使魔淫魔來襲擊，您的肉棒都會像鎌鼬一樣變成鐮刀狀展開狂風將他們輕鬆收割⋯⋯真不愧是性帝！」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00056",
		linknext = "0026_00058",
		line = 789,
	},
	["0026_00058"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00210", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Heh. But of course... As if I’d need to display my full strength just to drive off a couple of sitting ducks.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哼、那当然⋯⋯区区鸳鸯的程度，要逼退他们犯不着全力以赴──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哼、那當然⋯⋯區區鴛鴦的程度，要逼退他們犯不著全力以赴──」",
					{"rt2"},
				},
			},
		},
		linkback = "0026_00057",
		linknext = "0026_00059",
		line = 801,
	},
	["0026_00059"] = {
		{"text"},
		text = {
			vo = {
