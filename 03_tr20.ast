		{"evset", file="tcg0702050701", set="tcg070205", path=":ev/tcg070205/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="tcg0702050701", x=-42, y=-65, path=":cg/tcg07/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[7000] = {
				{"se", id=0, loop=0, file="se_b013", timestamp=3, delay2=7000},
			},
		},
		text = {
			vo = {
				{"vo", file="kirika0007", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"霧香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"霧香", "Kirika"},
					"“Ew! Daddy! Why would you marry someone like this?! Did she force you? Or did you feel bad for her? It would be a shame if something happened to her... I can make it look like an accident...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"霧香", "雾香"},
					"“爹地为什么会跟这种人结婚呢……？威胁？还是被她抓到弱点……？我会伪装成事故，想办法处理掉她吧……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"霧香"},
					"「爹地為什麼會跟這種人結婚呢……？威脅？還是被她抓到弱點……？我會偽裝成事故，想辦法處理掉她吧……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00053",
		linknext = "0067_00055",
		line = 738,
	},
	["0067_00055"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I married your mother because I love her. Now, Kirika... put that thread away.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这全部都是爱呀，雾香……所以收起线吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這全部都是愛呀，霧香……所以收起線吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00054",
		linknext = "0067_00056",
		line = 749,
	},
	["0067_00056"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s really bizarre how good Kirika is at using that thread as a weapon. In fact, she can master just about any trick short of pulling a rabbit out of a hat. She is definitely her mother’s child.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但那异常擅长使用线，以及变出鸽子的手法以外其他都擅长的部分，这些都在在显示她真的是桐香的孩子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但那異常擅長使用線，以及變出鴿子的手法以外其他都擅長的部分，這些都在在顯示她真的是桐香的孩子。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00055",
		linknext = "0067_00057",
		line = 759,
	},
	["0067_00057"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Who taught you how to use that thing, anyway? It’s dangerous.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“还有，是谁教你这么危险的念头的……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「還有，是誰教妳這麼危險的念頭的……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00056",
