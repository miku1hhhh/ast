	},
	["0067_00081"] = {
		{"cgdel", id=19, lv=19, time=0, alphadel=1, evmaskoff=1},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="tcg0702040501", x=-42, y=-65, path=":cg/tcg07/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=1000},
		{"text"},
		text = {
			vo = {
				{"vo", file="kirika0010", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"霧香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"霧香", "Kirika"},
					"“There’s no way I want to end up like Mom! And the SHO is totally lame anyway. If I join them, my head will start to rot just like Auntie Misaki!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"霧香", "雾香"},
					"“绝对不要！SHO已经退流行了！进到那边的话脑袋会变得跟美岬阿姨一样！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"霧香"},
					"「絕對不要！SHO已經退流行了！進到那邊的話腦袋會變得跟美岬阿姨一樣！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00080",
		linknext = "0067_00082",
		line = 1044,
	},
	["0067_00082"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If I tell Ms. Fumino what you just said, she’s gonna be really angry with you...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你这样说会惹文乃生气喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳這樣說會惹文乃生氣喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00081",
		linknext = "0067_00083",
