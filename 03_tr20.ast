			},
		},
		text = {
			vo = {
				{"vo", file="kirika0004", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"霧香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"霧香", "Kirika"},
					"“Could you two keep your hands off of each other for two seconds?! Why are you all over each other in front of your teenage daughter anyway?! Besides, you’re getting crumbs everywhere! UGH!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"霧香", "雾香"},
					"“不要一脸傻笑的在小孩子面前讲这种话，到底在想什么啊？有想过思春期的女儿会怎么想吗？然后吃面包的时候不要掉屑屑啊，这都几次了啊爹地──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"霧香"},
					"「不要一臉傻笑的在小孩子面前講這種話，到底在想什麼啊？有想過思春期的女兒會怎麼想嗎？然後吃麵包的時候不要掉屑屑啊，這都幾次了啊爹地──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00040",
		linknext = "0067_00042",
		line = 559,
	},
	["0067_00042"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Our daughter is a complete daddy’s girl—but I’m not sure if that’s a good thing or not.",
					{"rt2"},
				},
			},
			cn = {
				{
					"……因此，虽然是女儿但也跟我很亲，不知道是好是坏。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……因此，雖然是女兒但也跟我很親，不知道是好是壞。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00041",
		linknext = "0067_00043",
		line = 569,
	},
	["0067_00043"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’m not complaining, though. I am much happier to be loved by my daughter than despised.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但比起被最爱的女儿讨厌，还是被她喜欢更幸福，这件事是无庸置疑的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但比起被最愛的女兒討厭，還是被她喜歡更幸福，這件事是無庸置疑的。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00042",
		linknext = "0067_00044",
		line = 579,
	},
	["0067_00044"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There there, my little princess! It looks like your mother has wounded your delicate little teenaged heart...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“噢──乖乖，抱歉啊，妈妈伤害了你这颗思春期的心……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「噢──乖乖，抱歉啊，媽媽傷害了妳這顆思春期的心……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00043",
		linknext = "0067_00045",
		line = 590,
	},
	["0067_00045"] = {
		{"evset", file="tcg07", set="tcg07", path=":ev/tcg07/"},
		{"evset", file="tcg07_l020509-1", set="tcg07_l02", path=":ev/tcg07_l02/"},
		{"cgdel", id=19, lv=19, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=19, file="tcg07_l020509-1", x=-2, y=-159, path=":cg/tcg07_l/", lv=19, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kirika0005", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"霧香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"霧香", "Kirika"},
					"“I’m all right... but if it comes right down to it, you’ll abandon Mom and run away with me, right...? And I’ll be your widdle princess forever and ever, right Daddy?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"霧香", "雾香"},
					"“没关系，不用介意爹地……但真的发生什么事时，就丢下妈咪两个人生活吧……？所以要把女儿好好养大、好好爱护女儿喔……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"霧香"},
					"「沒關係，不用介意爹地……但真的發生什麼事時，就丟下媽咪兩個人生活吧……？所以要把女兒好好養大、好好愛護女兒喔……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00044",
		linknext = "0067_00046",
		line = 609,
	},
	["0067_00046"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For some reason, Kirika takes after Asa much more than her mother and me. Maybe it’s because the two of them spend so much time together?",
					{"rt2"},
				},
			},
			cn = {
				{
					"……不知道为什么，比起我跟桐香，雾香反而更像麻沙酱，可能因为她们常常待在一起吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……不知道為什麼，比起我跟桐香，霧香反而更像麻沙醬，可能因為她們常常待在一起吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00045",
		linknext = "0067_00047",
		line = 619,
	},
	["0067_00047"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My younger sister was completely devastated when Touka and I got married. Because of that, she threw herself into her studies.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我那妹妹因为异常害怕桐香嫁给我，所以也非常努力的读书了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我那妹妹因為異常害怕桐香嫁給我，所以也非常努力的讀書了。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00046",
		linknext = "0067_00048",
		line = 629,
	},
	["0067_00048"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As a result, she became fiercely independent—compared to me, at least. I suppose you could call that a lucky break.",
					{"rt2"},
				},
			},
			cn = {
				{
					"结果，她居然因此能够自力更生，可以说是歪打正着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"結果，她居然因此能夠自力更生，可以說是歪打正著。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00047",
		linknext = "0067_00049",
		line = 639,
	},
	["0067_00049"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After that, Asa ended up finding her perfect career. Now she works in tech designing and selling apps.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是跟网络相关的工作──制作App然后由公司贩卖──是相当适合麻沙酱的工作。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是跟網路相關的工作──製作App然後由公司販賣──是相當適合麻沙醬的工作。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00048",
		linknext = "0067_00050",
		line = 649,
	},
	["0067_00050"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even though my little sister is so busy with work, she still manages to make it over to our house about every other day. That’s why Kirika thinks that Asa would make a much better mother than her own.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但我亲爱的妹妹还是两天会到我家一次，女儿更是将她当作母亲一般。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但我親愛的妹妹還是兩天會到我家一次，女兒更是將她當作母親一般。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00049",
		linknext = "0067_00051",
		line = 659,
	},
	["0067_00051"] = {
		{"cgdel", id=19, lv=19, time=0, alphadel=1, evmaskoff=1},
		{"evset", file="tcg07", set="tcg07", path=":ev/tcg07/"},
		{"evset", file="tcg0702040101", set="tcg070204", path=":ev/tcg070204/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="tcg0702040101", x=-42, y=-65, path=":cg/tcg07/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1670", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“But don’t you think Mommy has improved a bit, Kirika? Lately I’ve been able to make it up most of the stairs without throwing up if I’m really careful!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“但是妈咪最近也有点进步了唷雾香，最近虽然只有一点点，但稍微可以自己一个人爬楼梯了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「但是媽咪最近也有點進步了唷霧香，最近雖然只有一點點，但稍微可以自己一個人爬樓梯了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00050",
		linknext = "0067_00052",
		line = 680,
	},
	["0067_00052"] = {
		{"evset", file="tcg07", set="tcg07", path=":ev/tcg07/"},
		{"evset", file="tcg0702040501", set="tcg070204", path=":ev/tcg070204/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="tcg0702040501", x=-42, y=-65, path=":cg/tcg07/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kirika0006", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"霧香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"霧香", "Kirika"},
					"“You can’t call two stairs ‘most,’ Mom! If you were a baseball player, you’d be batting less than 0.200! You’d be cut from the team! If you don’t shape up, you’re gonna get cut from this family, too!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"霧香", "雾香"},
					"“爬楼梯也只有两格吧，占整体比例也只有两成啊，如果是打击者的话不擅长防守也会被Fire的，妈咪会防守吗？不会吧？那这样就只能从家族成员名单中被Fire了……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"霧香"},
					"「爬樓梯也只有兩格吧，佔整體比例也只有兩成啊，如果是打擊者的話不擅長防守也會被Fire的，媽咪會防守嗎？不會吧？那這樣就只能從家族成員名單中被Fire了……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00051",
		linknext = "0067_00053",
		line = 699,
	},
	["0067_00053"] = {
		{"evset", file="tcg07", set="tcg07", path=":ev/tcg07/"},
		{"evset", file="tcg07020505-1", set="tcg070205", path=":ev/tcg070205/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="tcg07020505-1", x=-42, y=-65, path=":cg/tcg07/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1671", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Oh, but your mother really knows how to handle a bat! Hehe, just ask your father all about it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“唉呀，但棒子的话我可是用得很顺手呢？呵呵，让爹地跟你说说，我怀你的时候的事吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「唉呀，但棒子的話我可是用得很順手呢？呵呵，讓爹地跟妳說說，我懷妳的時候的事吧。」",
					{"rt2"},
				},
			},
		},
