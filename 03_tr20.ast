	["0067_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For years, I experienced it all. I spent plenty of my days arguing, fighting, and blowing up at the others. I also did my fair share looking after everyone in the process.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为很多事情而生气、发怒、斥责，就这样一边照顾她日子一边过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為很多事情而生氣、發怒、斥責，就這樣一邊照顧她日子一邊過。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00001",
		linknext = "0067_00003",
		line = 31,
	},
	["0067_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Now that I think about it, almost 10 years have gone by.",
					{"rt2"},
				},
			},
			cn = {
				{
					"注意到时，已经过了10年了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"注意到時，已經過了10年了。",
					{"rt2"},
				},
			},
		},
