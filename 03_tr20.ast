			},
			ja = {
				{
					name = {"霧香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"霧香", "Kirika"},
					"“You’re hopeless, Mom! I’ll take care of it—just sit down already! Ugh... Do I have to do everything around here...?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"霧香", "雾香"},
					"“啊啊真是的，之后我来弄，你坐好！……妈咪真的是什么都不会呢……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"霧香"},
					"「啊啊真是的，之後我來弄，妳坐好！……媽咪真的是什麼都不會呢……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00036",
