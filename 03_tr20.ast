		{"bg", id=18, file="tcg0702050101", x=-42, y=-65, path=":cg/tcg07/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=1000},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We struggled a lot, but we made it through somehow.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为会有点麻烦，还是别提了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為會有點麻煩，還是別提了。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00020",
		linknext = "0067_00022",
		line = 300,
	},
	["0067_00022"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I know that we put everyone in the NLNS and FS through a whole lot of trouble in the process, but all of us are still very close even now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也给原NLNS或FS的大家也添了不少麻烦，但大家还是感情很好。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也給原NLNS或FS的大家也添了不少麻煩，但大家還是感情很好。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00021",
		linknext = "0067_00023",
		line = 310,
	},
	["0067_00023"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I feel really blessed to have so many amazing people in my life.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这样的伙伴们，让我更加觉得贵重。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這樣的夥伴們，讓我更加覺得貴重。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00022",
		linknext = "0067_00024",
		line = 320,
	},
	["0067_00024"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What’s this? You made me breakfast again today...?! Heh, this has to be true love!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么，今天也为了我做了料理吗……！？呵，这是‘爱’吧──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「什麼，今天也為了我做了料理嗎……！？呵，這是『愛』吧──」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00023",
		linknext = "0067_00025",
		line = 331,
	},
	["0067_00025"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1667", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Seasoned to perfection with the unmistakable spice of true love❤”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“没错，是爱的礼物",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「沒錯，是愛的禮物",
					{"gaiji", text="①"},
					"」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00024",
		linknext = "0067_00026",
		line = 343,
	},
	["0067_00026"] = {
		{"evset", file="tcg07", set="tcg07", path=":ev/tcg07/"},
		{"evset", file="tcg0702050501", set="tcg070205", path=":ev/tcg070205/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="tcg0702050501", x=-42, y=-65, path=":cg/tcg07/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kirika0001", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"霧香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"霧香", "Kirika"},
					"“Mom! Don’t take all the credit! I’m the one who seasoned the food! If you did it, it’d taste all weird! On top of that, you destroyed the cutting board with your threads!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"霧香", "雾香"},
					"“由妈咪试味道的话又会变得很奇怪，所以是女儿调整的喔……！妈咪根本只是用线把沾板切碎而已嘛……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"霧香"},
					"「由媽咪試味道的話又會變得很奇怪，所以是女兒調整的喔……！媽咪根本只是用線把沾板切碎而已嘛……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00025",
		linknext = "0067_00027",
		line = 362,
	},
	["0067_00027"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Off of the island, Touka would still struggle in most aspects of daily life.",
					{"rt2"},
				},
			},
			cn = {
				{
					"桐香就算离开这座岛，也还是什么都不会。",
					{"rt2"},
				},
			},
			tw = {
				{
					"桐香就算離開這座島，也還是什麼都不會。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00026",
		linknext = "0067_00028",
		line = 372,
	},
	["0067_00028"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That much never changed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她无法成长。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她無法成長。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00027",
		linknext = "0067_00029",
		line = 382,
	},
	["0067_00029"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But she’s still just as strong, beautiful, and incredibly endearing as she has always been.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只有从出生就自带的坚强、美丽及可爱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只有從出生就自帶的堅強、美麗及可愛。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00028",
		linknext = "0067_00030",
		line = 392,
	},
	["0067_00030"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It seems that Seiran Island is where she truly belongs after all.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以，她只能待在这里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以，她只能待在這裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00029",
		linknext = "0067_00031",
		line = 402,
	},
	["0067_00031"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She sometimes buzzes back and forth to the SHO Headquarters to help out with particularly tricky tasks. Or when I’m overwhelmed with work.",
					{"rt2"},
				},
			},
			cn = {
				{
					"偶尔悠哉的晃到SHO本社大楼，处理了麻烦的事或我负责的大量工作然后离开。",
					{"rt2"},
				},
			},
			tw = {
				{
					"偶爾悠哉的晃到SHO本社大樓，處理了麻煩的事或我負責的大量工作然後離開。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00030",
		linknext = "0067_00032",
		line = 412,
	},
	["0067_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"With all of her charisma and talent, Touka would be the perfect candidate to lead the SHO. However, she doesn’t have the slightest interest in such ambitions.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那领袖气质让她被视为下个领导者，但她还是一样一点出风头的意思都没有。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那領袖氣質讓她被視為下個領導者，但她還是一樣一點出風頭的意思都沒有。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00031",
		linknext = "0067_00033",
		line = 422,
	},
	["0067_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In her words, having a place to belong—and protecting it—is far more important than a career.",
					{"rt2"},
				},
			},
			cn = {
				{
					"比起工作，她更想要好好重视自己的生活之处。",
					{"rt2"},
				},
			},
			tw = {
				{
					"比起工作，她更想要好好重視自己的生活之處。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00032",
		linknext = "0067_00034",
		line = 432,
	},
	["0067_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So if that’s what really makes her happy, then I have absolutely no regrets about settling down on Seiran Island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她这么跟我说，让我觉得选择这个岛，一点都不后悔。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她這麼跟我說，讓我覺得選擇這個島，一點都不後悔。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00033",
		linknext = "0067_00035",
		line = 442,
	},
	["0067_00035"] = {
		{"evset", file="tcg07", set="tcg07", path=":ev/tcg07/"},
		{"evset", file="tcg0702051101", set="tcg070205", path=":ev/tcg070205/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="tcg0702051101", x=-42, y=-65, path=":cg/tcg07/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kirika0002", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"霧香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"霧香", "Kirika"},
					"“Mom, you were supposed to be in charge of the toast! Now it’s getting all burnt because you’re too busy being all lovey-dovey with Daddy! And the eggs! Ew, can you even call these eggs anymore?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"霧香", "雾香"},
					"“欸等等，妈咪，在你调情的时候，你负责的烤吐司要焦掉了！？这边的荷包蛋也……这是荷包蛋吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"霧香"},
					"「欸等等，媽咪，在妳調情的時候，妳負責的烤吐司要焦掉了！？這邊的荷包蛋也……這是荷包蛋嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00034",
		linknext = "0067_00036",
		line = 461,
	},
	["0067_00036"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It wasn’t just Touka’s looks that remained unchanged. Her personality and quirks are the same as ever, too.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后，没变的不止外表，内在也是。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後，沒變的不止外表，內在也是。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00035",
