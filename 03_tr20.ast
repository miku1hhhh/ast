	["0067_00080"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That’s why Susuko, Schubert, and Mizuhiki always come to visit you! Besides, the SHO aren’t all bad...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而且丝丝子、舒君、水引酱也会来玩啊……SHO没有那么糟……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而且絲絲子、舒君、水引醬也會來玩啊……SHO沒有那麼糟……」",
					{"rt2"},
				},
			},
		},
