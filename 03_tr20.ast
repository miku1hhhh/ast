	["0067_00096"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Though it may not always seem like it, Touka and Kirika have a very close mother-daughter relationship.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算是这样，母女相处还是像朋友一般感情很好。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算是這樣，母女相處還是像朋友一般感情很好。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00095",
		linknext = "0067_00097",
		line = 1223,
	},
	["0067_00097"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The two of them actually love going out together without me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"意外的还常排除我，母女两个人一起出门。",
					{"rt2"},
				},
			},
			tw = {
				{
					"意外的還常排除我，母女兩個人一起出門。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00096",
		linknext = "0067_00098",
		line = 1233,
	},
	["0067_00098"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s because for Touka, there really is nothing more important than family.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对桐香而言，家人比什么都还重要。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對桐香而言，家人比什麼都還重要。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00097",
		linknext = "0067_00099",
