	},
	["0067_00099"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She loves us with all her heart, but she doesn’t play favorites. She loves us both equally.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以对于“新的家人”的爱，也跟原本的大家是同等级的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以對於「新的家人」的愛，也跟原本的大家是同等級的。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00098",
		linknext = "0067_00100",
		line = 1253,
	},
	["0067_00100"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’ve started to suspect that Touka argues with Kirika on purpose—in order to push Kirika closer to me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以说不定跟女儿拌嘴，也只是为了让女儿跟父亲感情更亲密的作战也说不定。",
