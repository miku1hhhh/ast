		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1675", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You mean to tell me that you would abandon your career and your social standing just to stay by my side?! Oh! I love you so much! Take me now!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“抛弃社会关系、立场就只为了待在我身边……喜欢，请抱抱我吧……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「拋棄社會關係、立場就只為了待在我身邊……喜歡，請抱抱我吧……！」",
					{"rt2"},
				},
			},
		},
