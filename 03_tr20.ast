	},
	["0067_00083"] = {
		{"evset", file="tcg07", set="tcg07", path=":ev/tcg07/"},
		{"evset", file="tcg0702040801", set="tcg070204", path=":ev/tcg070204/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="tcg0702040801", x=-42, y=-65, path=":cg/tcg07/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kirika0011", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"霧香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"霧香", "Kirika"},
					"“Eep...! Forget I said anything! Ms. Fumino has never been anything but nice to me... but for some reason she freaks me out right down to the cellular level!!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"霧香", "雾香"},
					"“嗯咕……！明明没有怎样，记忆中也只有被疼爱的部分，但为什么细胞却这么害怕文乃老师……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"霧香"},
					"「嗯咕……！明明沒有怎樣，記憶中也只有被疼愛的部分，但為什麼細胞卻這麼害怕文乃老師……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00082",
		linknext = "0067_00084",
		line = 1074,
	},
	["0067_00084"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She definitely gets her fear of Fumino from her mother.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看起来对文乃的恐惧，是来自妈妈的遗传。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看起來對文乃的恐懼，是來自媽媽的遺傳。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00083",
		linknext = "0067_00085",
		line = 1084,
	},
	["0067_00085"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s like an instinct that has been passed down through the Reizeiin family’s very DNA.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可能是刻在冷泉院的细胞里吧……",
					{"rt2"},
				},
			},
			tw = {
				{
					"可能是刻在冷泉院的細胞裡吧……",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00084",
		linknext = "0067_00086",
		line = 1094,
	},
	["0067_00086"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"These days, Fumino is teaching flower arrangement, tea ceremony, and etiquette courses on Seiran Island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃是青蓝岛的花道、茶道、插花等，还有舞蹈教室的老师。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃是青藍島的花道、茶道、插花等，還有舞蹈教室的老師。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00085",
		linknext = "0067_00087",
		line = 1104,
	},
	["0067_00087"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her lessons are wildly popular. Kirika attends as well, but these days all of the classes are full.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那里非常繁盛，女儿也有去，每天都有很多学生。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那裡非常繁盛，女兒也有去，每天都有很多學生。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00086",
		linknext = "0067_00088",
		line = 1114,
	},
	["0067_00088"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nowadays, the island’s horny Joan of Arc is getting along well with everyone.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她被称为变态贞德老师，受到学生们的喜爱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她被稱為變態貞德老師，受到學生們的喜愛。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00087",
		linknext = "0067_00089",
		line = 1124,
	},
	["0067_00089"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I start to get swamped with work, Fumino swoops in to clean or do just about anything else that needs doing. She still has a heart of gold.",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在也是，在我很忙的时候，来帮忙打扫、做很多事。一如往常是个温柔的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在也是，在我很忙的時候，來幫忙打掃、做很多事。一如往常是個溫柔的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00088",
		linknext = "0067_00090",
		line = 1134,
	},
	["0067_00090"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And as for Misaki? I’ll admit that I used to think of her as little more than our group’s eccentric pet.",
					{"rt2"},
				},
			},
			cn = {
				{
					"顺带一提，至于美岬，可能就被当作是只有趣的宠物的样子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"順帶一提，至於美岬，可能就被當作是隻有趣的寵物的樣子。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00089",
		linknext = "0067_00091",
		line = 1144,
	},
	["0067_00091"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But she became a freelance consultant and got filthy rich. Now she is collaborating with Asane to analyze stock prices and fluctuation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但其实她也很会赚钱，跟麻沙音一起以自由人的身份进行股价分析、评论等。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但其實她也很會賺錢，跟麻沙音一起以自由人的身份進行股價分析、評論等。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00090",
		linknext = "0067_00092",
		line = 1154,
	},
	["0067_00092"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Misaki is world-class when it comes to anal... ysis.",
					{"rt2"},
				},
			},
			cn = {
				{
					"理由是因为“分析师”这个名称跟后穴发音相近。",
					{"rt2"},
				},
			},
			tw = {
				{
					"理由是因為「分析師」這個名稱跟後穴發音相近。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00091",
