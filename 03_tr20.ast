				},
			},
			en = {
				{
					"Much time has passed since the Lewd War and the events that followed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"──……那之后，过了很多年。",
					{"rt2"},
				},
			},
			tw = {
				{
					"──……那之後，過了很多年。",
					{"rt2"},
				},
