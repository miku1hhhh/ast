		{"evset", file="tcg07_l02051001", set="tcg07_l02", path=":ev/tcg07_l02/"},
		{"bg", id=19, file="tcg07_l02051001", x=-2, y=-59, path=":cg/tcg07_l/", lv=19, ev=1, alpha=0, sync=1, a_chr151=1, bx=800, by=450},
		{"cgact", file="cgact", id=19, lv=19, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255, x=-2, y=-59},
		{"cgact", file="cgact", id=19, act="移動", x=0, y=-900, time=30000, lv=19},
		{"text"},
		text = {
			vo = {
				{"vo", file="kirika0008", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"霧香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"霧香", "Kirika"},
					"“Miss Ikuko. She said she’d share you with me—fifty-fifty. But Auntie Rei started crying and made us stop. Then she started crying even more because I called her ‘Auntie.’ Wata consoled her...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"霧香", "雾香"},
					"“郁子小姐……她说成功了的话爹地就一人一半……但被礼阿姨哭着阻止了……然后因为叫她‘阿姨’她哭得更惨了……渡酱安慰她了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"霧香"},
					"「郁子小姐……她說成功了的話爹地就一人一半……但被禮阿姨哭著阻止了……然後因為叫她『阿姨』她哭得更慘了……渡醬安慰她了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00057",
		linknext = "0067_00059",
		line = 788,
	},
	["0067_00059"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Our daughter is naturally gifted with physical abilities. She’s being trained day in and day out by the fearsome Rei and Ikuko.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那过高的体能，则是由礼前辈及郁子锻炼出来的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那過高的體能，則是由禮前輩及郁子鍛鍊出來的。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00058",
		linknext = "0067_00060",
		line = 798,
	},
	["0067_00060"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When it comes to hand-to-hand combat, I bet my daughter could have even taken me down when I was in my prime.",
					{"rt2"},
				},
			},
			cn = {
				{
					"真的要说的话，她的战斗力可能比我全盛时期还要更强了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"真的要說的話，她的戰鬥力可能比我全盛時期還要更強了。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00059",
		linknext = "0067_00061",
		line = 808,
	},
	["0067_00061"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Speaking of Rei and Ikuko—both of them are working on Seiran Island now, too.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈跟郁子现在也在青蓝岛工作。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩跟郁子現在也在青藍島工作。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00060",
		linknext = "0067_00062",
		line = 818,
	},
	["0067_00062"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei found a steady job in order to help put her younger siblings through school. She’s hard at work recruiting for the SHO.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈为了弟弟们的学费，便就任已确立的工作岗位，现在也在训练SHO的新兵们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩為了弟弟們的學費，便就任已確立的工作崗位，現在也在訓練SHO的新兵們。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00061",
		linknext = "0067_00063",
		line = 828,
	},
	["0067_00063"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The once-feared disciplinary committee president herself has been reduced to a puddle of mush by her beloved Touka’s daughter. She’s head-over-heels for Kirika—so now she’s just doting “Auntie Rei.”",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然是魔鬼教官，但对桐香的女儿雾香却非常宠爱。所以被当成好搞定的阿姨。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然是魔鬼教官，但對桐香的女兒霧香卻非常寵愛。所以被當成好搞定的阿姨。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00062",
		linknext = "0067_00064",
		line = 838,
	},
	["0067_00064"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As for Ikuko, she got a full-ride scholarship to study at a big university on the mainland. But she found herself back on Seiran Island after that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"郁子的话，有领了奖学金去首都的大学念书，却跟我一样又回到了青蓝岛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"郁子的話，有領了獎學金去首都的大學唸書，卻跟我一樣又回到了青藍島。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00063",
		linknext = "0067_00065",
		line = 848,
	},
	["0067_00065"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She began her career as the commander of the SHO Strike Force. However, due of her outstanding performance and academic record, she was promoted all the way to a stuffy management position.",
					{"rt2"},
				},
			},
			cn = {
				{
					"最初是担任SHO强袭部队的队长，但因为高学历的关系，马上就成功晋升成管理阶层。",
					{"rt2"},
				},
			},
			tw = {
				{
					"最初是擔任SHO強襲部隊的隊長，但因為高學歷的關係，馬上就成功晉升成管理階層。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00064",
		linknext = "0067_00066",
		line = 858,
	},
	["0067_00066"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ikuko said it herself that she would much rather be fighting in the trenches than working in a boring old office. But there are no wars to fight on Seiran Island these days.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然本人常常碎碎念“不能进行实战很无聊！”，但基本上现在的青蓝岛本来就没有战斗的机会。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然本人常常碎碎念「不能進行實戰很無聊！」，但基本上現在的青藍島本來就沒有戰鬥的機會。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00065",
		linknext = "0067_00067",
		line = 868,
	},
	["0067_00067"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But when I asked her why she had returned to the island during peace time, she replied, “I guess I just like being here with everyone after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					"问她为什么回来，她就说“还是跟大家在一起最棒了”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"問她為什麼回來，她就說「還是跟大家在一起最棒了」。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00066",
		linknext = "0067_00068",
		line = 878,
	},
	["0067_00068"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"To this day, Hinami hasn’t changed a bit, either. She actually became one of Kirika’s playmates, too.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后容貌一点都没变的雏见，不知道为什么跟女儿很亲密，还常一起出去玩。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後容貌一點都沒變的雛見，不知道為什麼跟女兒很親密，還常一起出去玩。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00067",
		linknext = "0067_00069",
		line = 888,
	},
	["0067_00069"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hinami is now working in the childcare field.",
					{"rt2"},
				},
			},
			cn = {
				{
					"雏见的工作是与幼教有关。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雛見的工作是與幼教有關。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00068",
		linknext = "0067_00070",
		line = 898,
	},
	["0067_00070"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rather than becoming a nursery school teacher, Hinami is using data she collects in order to develop safer playground equipment and baby products.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但并非幼稚园老师，而是以在当地取得的资料为基础，开发安全的游乐设施或宝宝用品等。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但並非幼稚園老師，而是以在當地取得的資料為基礎，開發安全的遊樂設施或寶寶用品等。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00069",
		linknext = "0067_00071",
		line = 908,
	},
	["0067_00071"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When she used to volunteer at Baby Me Creche, she was always saying how much she loved playing with kids.",
					{"rt2"},
				},
			},
			cn = {
				{
					"本人是说“跟小孩子玩很快乐！”，也很常去母爱幼稚园当志工。",
					{"rt2"},
				},
			},
			tw = {
				{
					"本人是說「跟小孩子玩很快樂！」，也很常去母愛幼稚園當志工。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00070",
		linknext = "0067_00072",
		line = 918,
	},
	["0067_00072"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Come to think of it, Hinami is basically just a big kid herself. That’s probably why she went into childcare. But no matter what the reason, she was a huge help to us when Kirika was growing up.",
					{"rt2"},
				},
			},
			cn = {
				{
					"好像是因为“本人那样就很像小孩了”这样的理由被采用，但也是好好发挥了她的优点，女儿小时候也受到她很多的照顾。",
					{"rt2"},
				},
			},
			tw = {
				{
					"好像是因為「本人那樣就很像小孩了」這樣的理由被採用，但也是好好發揮了她的優點，女兒小時候也受到她很多的照顧。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00071",
		linknext = "0067_00073",
		line = 928,
	},
	["0067_00073"] = {
		{"cgdel", id=19, lv=19, time=0, alphadel=1, evmaskoff=1},
		{"evset", file="tcg07", set="tcg07", path=":ev/tcg07/"},
		{"evset", file="tcg0702041001", set="tcg070204", path=":ev/tcg070204/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="tcg0702041001", x=-42, y=-65, path=":cg/tcg07/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=1000},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1672", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Hehe, if you get any stronger, I think you’ll have to become the student council president just like your mother!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呵呵，变那么强的话，雾香未来也可能会变成水乃月的学生会长呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「呵呵，變那麼強的話，霧香未來也可能會變成水乃月的學生會長呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00072",
		linknext = "0067_00074",
		line = 949,
	},
	["0067_00074"] = {
		{"bg", id=19, file="tcg07_l02040101", x=-2, y=-259, path=":cg/tcg07_l/", lv=19, ev=1, bx=800, by=450},
		{"transitiontime", time=500},
		{"cgact", file="cgact", id=19, act="移動", x=0, y=200, time=10000, lv=19},
		{"text"},
		text = {
			vo = {
				{"vo", file="kirika0009", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"霧香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"霧香", "Kirika"},
					"“No way! I wanna be a cool working woman like Nanase! I’m gonna have style, a career, and a family! I’ll be the perfect woman, and Daddy and I will leave you behind on this stupid island!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"霧香", "雾香"},
					"“才不要！我要像奈奈濑小姐一样变成工作能力强的女子！工作、时髦、家务全都完美的帅气大人，然后跟爹地一起离开这座岛！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"霧香"},
					"「才不要！我要像奈奈瀨小姐一樣變成工作能力強的女子！工作、時髦、家事全都完美的帥氣大人，然後跟爹地一起離開這座島！」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00073",
		linknext = "0067_00075",
		line = 964,
	},
	["0067_00075"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase is working her ass off at a huge company outside of the island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑在岛外的大企业，认真的工作。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨在島外的大企業，認真的工作。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00074",
		linknext = "0067_00076",
		line = 974,
	},
	["0067_00076"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She must be moving up in the company, because she’s making a ton of money. When I asked her about her salary, it was more than twice what any of us are making on this island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"好像发展得也很不错，年收入大概是我们的2.5倍，令人惊讶。",
					{"rt2"},
				},
			},
			tw = {
				{
					"好像發展得也很不錯，年收入大概是我們的2.5倍，令人驚訝。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00075",
		linknext = "0067_00077",
		line = 984,
	},
	["0067_00077"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even so, she takes trips back to the island on weekends. Whenever she comes back, she treats us all to her elaborate home-cooked meals.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算这样，周末也还是会回到这里，做好吃的料理给我们吃。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算這樣，週末也還是會回到這裡，做好吃的料理給我們吃。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00076",
		linknext = "0067_00078",
		line = 994,
	},
	["0067_00078"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She and Touka are attending the same cooking class and getting along really well with one another, too. Touka even listens to Nanase’s work troubles from time to time.",
					{"rt2"},
				},
			},
			cn = {
				{
					"跟桐香的料理教室也还在持续，感情还不错，她偶尔也会听奈奈濑抱怨工作。",
					{"rt2"},
				},
			},
			tw = {
				{
					"跟桐香的料理教室也還在持續，感情還不錯，她偶爾也會聽奈奈瀨抱怨工作。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00077",
		linknext = "0067_00079",
		line = 1004,
	},
	["0067_00079"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“B-But Kirika! Your mom was an amazing student council president!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但、但是妈咪以前当会长的时候，也很帅啊……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但、但是媽咪以前當會長的時候，也很帥啊……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00078",
