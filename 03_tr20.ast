	["0067_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Thanks to the help of Nanase, Ikuko, and all of the others, I somehow managed to get into the school’s advanced levels after all.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那之后，我在奈奈濑、郁子以及大家的帮助下，总算进入了特进课程。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那之後，我在奈奈瀨、郁子以及大家的幫助下，總算進入了特進課程。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00004",
		linknext = "0067_00006",
		line = 68,
	},
	["0067_00006"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As a third-year student, Hinami and the others continued to tutor me. Because of that, I scraped by and barely managed to get into the university of my choice.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算升上A等部三年级，还是得让雏见他们教我功课，才让我勉强得以走在想走的路上──",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算升上A等部三年級，還是得讓雛見他們教我功課，才讓我勉強得以走在想走的路上──",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00005",
		linknext = "0067_00007",
		line = 78,
	},
	["0067_00007"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But after all was said and done, I returned to Seiran Island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"最后，却还是回到了青蓝岛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"最後，卻還是回到了青藍島。",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00006",
		linknext = "0067_00008",
		line = 88,
	},
	["0067_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"You might think that I came back here to make sure that the tyrannical rule of the perverted sex laws would never rise again. However, that was more of an afterthought in my decision.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了对被我改过的变态条例负责──这也是一个理由，但只是顺带的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了對被我改過的變態條例負責──這也是一個理由，但只是順帶的。",
					{"rt2"},
				},
			},
		},
