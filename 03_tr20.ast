		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="tcg0702050801", x=-42, y=-65, path=":cg/tcg07/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1673", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Hehehe, my little Kirika is the cutest! Your uniform looks perfect—and your face is just gorgeous! At this rate, you’re going to steal your daddy right out from under me! You mustn’t get any cuter!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呵呵呵，你这么可爱又这么适合穿制服，脸蛋又完美，可不能就这样抢走爹地啊？你认真起来的话，妈咪会输的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「呵呵呵，妳這麼可愛又這麼適合穿制服，臉蛋又完美，可不能就這樣搶走爹地啊？妳認真起來的話，媽咪會輸的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00092",
		linknext = "0067_00094",
		line = 1183,
	},
	["0067_00094"] = {
		{"evset", file="tcg07", set="tcg07", path=":ev/tcg07/"},
		{"evset", file="tcg07020506-1", set="tcg070205", path=":ev/tcg070205/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="tcg07020506-1", x=-42, y=-65, path=":cg/tcg07/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kirika0012", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"霧香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"霧香", "Kirika"},
					"“Mom, stop! I’m not THAT cute! If you search for ‘schoolgirls’ online, they look way sexier. And their skirts are much shorter! If my skirt was shorter, maybe Daddy would give me more allowance...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"霧香", "雾香"},
					"“咦？真讨厌啦妈咪。我真的那么可爱吗？在网络上穿制服直播，就会有有钱又有闲的特殊爹地们给我零用钱吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"霧香"},
					"「咦？真討厭啦媽咪。我真的那麼可愛嗎？在網路上穿制服直播，就會有有錢又有閒的特殊爹地們給我零用錢嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0067_00093",
		linknext = "0067_00095",
		line = 1202,
	},
	["0067_00095"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, no... Has Auntie Asa been letting you use the internet by yourself again...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“又是听麻沙姑姑讲了一堆有的没的了吧……”",
