					"“All that matters is that I reign supreme, and everyone else lies below me. That is how humans are truly shaped...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“没错……只有我站在顶点，其他人都在下方……那就是人类应有的姿态……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「沒錯……只有我站在頂點，其他人都在下方……那就是人類應有的姿態……」",
					{"rt2"},
