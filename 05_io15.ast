	["0079_00107"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ikuko was never interested in anime because of the environment she grew up in, but she’s beginning to show interest after playing my eroge.",
					{"rt2"},
				},
			},
			cn = {
				{
					"据说郁子因为成长环境的关系，几乎没有积过动画──但是以我的色情游戏为契机，她最近也开始对各种事物表现出了兴趣。",
					{"rt2"},
				},
			},
			tw = {
				{
					"據說郁子因為成長環境的關係，幾乎沒有積過動畫──但是以我的色情遊戲為契機，她最近也開始對各種事物表現出了興趣。",
					{"rt2"},
				},
			},
		},
