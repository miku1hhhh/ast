				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我也非常在意呢两位究竟如何共度良宵如何败北希望前辈能够亲口具体地描述给我听可能的话请从实际的行为发生之前的情境开始──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我也非常在意呢兩位究竟如何共度良宵如何敗北希望前輩能夠親口具體地描述給我聽可能的話請從實際的行為發生之前的情境開始──！」",
					{"rt2"},
				},
			},
		},
