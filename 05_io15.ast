			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Of course ’Bana can’t beat Ikuko. It’s like laws of physics and stuff. Or are you like one of those old-fashioned people who think men have to be stronger than women?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“辈前赢不过有有同学不是理所当然的吗？是‘身为男人一定得要比女人强才行──！’那种的吗？真跟不上潮流啊──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「輩前贏不過有有同學不是理所當然的嗎？是『身為男人一定得要比女人強才行──！』那種的嗎？真跟不上潮流啊──」",
					{"rt2"},
				},
			},
		},
