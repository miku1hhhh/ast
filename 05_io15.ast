				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I loved the part where that guy who’s just an old dude in the real world takes on a mommy avatar in the net and everyone calls him mommy!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“平常是普通的大叔之类的人在电脑世界里面用的是妈妈型的虚拟形象，其他人都叫他妈妈那种感觉，怎么说呢，很棒呢～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「平常是普通的大叔之類的人在電腦世界裡面用的是媽媽型的虛擬形象，其他人都叫他媽媽那種感覺，怎麼說呢，很棒呢～！」",
					{"rt2"},
				},
			},
		},
