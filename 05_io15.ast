			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I got so worried when the Lust Machine went berserk and uncensored all the mommy’s private parts and the whole service was on the verge of shutting down.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“在Make-Love Machine失控之后，开始到处删除妈妈们下半身的马赛克、差点迫使平台停止营运的时候我紧张得要死，好担心接下来会怎么样呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「在Make-Love Machine失控之後，開始到處刪除媽媽們下半身的馬賽克、差點迫使平台停止營運的時候我緊張得要死，好擔心接下來會怎麼樣呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00110",
		linknext = "0079_00112",
		line = 1805,
	},
