		{"text"},
		text = {
			vo = {
				{"vo", file="rin0277", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“What are you so mad about? It’s all true. I’m pretty much in the same boat right now.”",
