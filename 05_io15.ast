				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I know in those rapey games strong-minded girls can get scared when you snap at them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“……如果是在凌辱类型的游戏里面的话，突然对好胜的女人发狠倒是可以马上让对方变得战战兢兢的啦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「……如果是在凌辱類型的遊戲裡面的話，突然對好勝的女人發狠倒是可以馬上讓對方變得戰戰兢兢的啦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00081",
		linknext = "0079_00083",
		line = 1348,
	},
	["0079_00083"] = {
