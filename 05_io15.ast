		{"text"},
		delay = {
			[10000] = {
				{"fg", file="rin_01m_00002", file1="rin_01m_00101", file3="rin_01m_00312", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, timestamp=72, delay2=10000, mode=3, x=-405, y=-5},
			},
			[9999] = {
				{"transitiontime", time=300, timestamp=72, delay2=10000},
			},
		},
		text = {
			vo = {
				{"vo", file="rin0278", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“By now I should’ve been rich enough to go to the disco every day on my private chopper with diamond fillings in my teeth, but how ridiculous... oh excuse me, I meant Rin-diculous...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“原本我应该已经装着钻石假牙整天泡舞厅说到交通就是自家用直升机的了……世事难如人意……啊啊失礼了。是难花人丸呀……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「原本我應該已經裝著鑽石假牙整天泡舞廳說到交通就是自家用直升機的了……世事難如人意……啊啊失禮了。是難花人丸呀……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00608",
		linknext = "0079_00610",
		line = 8327,
	},
	["0079_00610"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0279", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Now I live like a beast... but now I’ve figured it all out. I’ve made fun of so many people in the past, but in the end, humans are no different than beasts.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“如今只能过着像野兽一样的生活……可是因此我也理解了。虽然我以前鄙视过各种人……但是所谓人和野兽终究没有分别……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「如今只能過著像野獸一樣的生活……可是因此我也理解了。雖然我以前鄙視過各種人……但是所謂人和野獸終究沒有分別……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00609",
		linknext = "0079_00611",
		line = 8339,
	},
	["0079_00611"] = {
		{"fg", file="rin_01m_00002", file1="rin_01m_00101", file3="rin_01m_00315", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0280", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Arguing amongst each other, trying to prove your supremacy... It’s all nothing more than quarrels between animals. It’s all so foolish.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“人类之间互相夸耀自己的优越性、想要占据优势之类的……那种事情就跟动物互咬差不多……实在太傻气了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「人類之間互相誇耀自己的優越性、想要佔據優勢之類的……那種事情就跟動物互咬差不多……實在太傻氣了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00610",
		linknext = "0079_00612",
		line = 8354,
	},
