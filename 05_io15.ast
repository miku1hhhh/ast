			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ikuko is not interested in weak men. If I don’t get any stronger, she’s gonna dump me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是郁子对弱小的家伙没有兴趣……我要是不变强，会倍郁子抛弃的！”",
