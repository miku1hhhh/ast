	["0079_00085"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00101", file2="ran_01m_00206", file4="ran_01m_00401", path=":fg/ran_01m/", id=13, lv=13, head="ran_01m", ch_origin="蘭", ch="蘭13", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0148", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“I don’t know. She hasn’t been home since that party we had. She’s been contacting me so I’m assuming she’s fine, but I’m so worried I can barely sleep at night.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“我也不知道……自从派对那一天以后她就没有回家……因为她偶尔会联络家里，所以人好像是平安啦……实在让我担心得晚上都花不着丸……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「我也不知道……自從派對那一天以後她就沒有回家……因為她偶爾會聯絡家裡，所以人好像是平安啦……實在讓我擔心得晚上都花不著丸……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00084",
		linknext = "0079_00086",
		line = 1397,
	},
	["0079_00086"] = {
