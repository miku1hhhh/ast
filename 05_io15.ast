		{"text"},
		text = {
			vo = {
				{"vo", file="rei1947", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“She’s one of the top-class FS members in its history. Even with your superpowers like full-body erection and ejaculation rocket flight, victory is not an easy task.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“毕竟郁子在历代的FS里面也是最强级别的嘛……就算你能够让全身勃起、或是靠射精在天上飞来飞去，想必也不是那么容易战胜的吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「畢竟郁子在歷代的FS裡面也是最強級別的嘛……就算你能夠讓全身勃起、或是靠射精在天上飛來飛去，想必也不是那麼容易戰勝的吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00006",
		linknext = "0079_00008",
		line = 100,
	},
	["0079_00008"] = {
