				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“I see. I do remember Rin always saying that it feels good to scare the shit out of people who are full of themselves.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“原来如此……这么说起来凛也常说类似的话呢！说是吓得意忘形的人特别爽什么的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「原來如此……這麼說起來凜也常說類似的話呢！說是嚇得意忘形的人特別爽什麼的。」",
					{"rt2"},
				},
			},
