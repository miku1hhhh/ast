	["0079_00613"] = {
		{"fg", file="rin_01m_00002", file1="rin_01m_00101", file3="rin_01m_00311", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0281", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“As I crawled through dirt, merely surviving, I heard the voice of almighty Skeetus, the god of perversion. And then I understood that there’s no hierarchy amongst humans.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“在地上苟活之间，我听到了色情之神……赛克罗斯大人的声音。然后理解了。人与人之间，是不需要上下关系的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「在地上苟活之間，我聽到了色情之神……賽克羅斯大人的聲音。然後理解了。人與人之間，是不需要上下關係的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00612",
		linknext = "0079_00614",
		line = 8381,
	},
