			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Then come with me, Blowbo. Life in the dark can be quite comforting... From here, we’ll show them...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“……那么就跟我来吧啾啪公。在黑暗中活下去意外地舒适喔……就从这里开始……给这个世界一点颜色瞧瞧吧……”",
					{"rt2"},
				},
			},
			tw = {
