	["0079_00040"] = {
		{"fg", ch="水引15", mode=-1, lv=15, id=15},
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00225", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=5, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0305", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“If losing isn’t your objective, then why do you wish to win against the commander?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“说是不打算输，反过来淳之介又为什么那么想赢过中队长呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「說是不打算輸，反過來淳之介又為什麼那麼想贏過中隊長呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00039",
		linknext = "0079_00041",
		line = 672,
	},
	["0079_00041"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00222", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=15},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I mean, sure I can’t beat her in a real fight, but if I can’t even beat her in bed, how can the two of us maintain any power balance?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“毕竟……普通的战斗打不赢姑且不说，如果连夜里的战斗都打不赢，那力量关系不就不均衡了吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「畢竟……普通的戰鬥打不贏姑且不說，如果連夜裡的戰鬥都打不贏，那力量關係不就不均衡了嗎……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0079_00040",
		linknext = "0079_00042",
		line = 684,
	},
	["0079_00042"] = {
