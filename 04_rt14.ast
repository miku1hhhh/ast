		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase speaks slowly, as if she’s turning her words over in her head before she says them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"奈奈濑品味着每一字一句似地，编织着话语。",
					{"rt2"},
				},
			},
			tw = {
				{
					"奈奈瀨品味著每一字一句似地，編織著話語。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00307",
		linknext = "0070_00309",
		line = 4697,
	},
	["0070_00309"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She’s pushing me to do what I couldn’t do back then...",
					{"rt2"},
				},
			},
			cn = {
				{
					"那一天的我们没能做到的──为了这次能够做到，她想要推我一把。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那一天的我們沒能做到的──為了這次能夠做到，她想要推我一把。",
					{"rt2"},
				},
			},
