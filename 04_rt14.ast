				},
			},
			tw = {
				{
					name = {"麻沙音", "麻沙dori君"},
					"「因為她說會給我舊的『密集跟拍性器情報雜誌啪啪』……有我想要的、現在已經買不到了的奈奈瀨姊特集……」",
					{"rt2"},
				},
			},
		},
