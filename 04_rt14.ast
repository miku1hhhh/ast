	},
	["0070_00304"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0348", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬", "ナナドリくん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanadori"},
					"“It’s fine. I just... don’t want you to end up regretting what you’re doing now in the future. If there’s any doubt still in your mind, then you should...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈dori君"},
					"“……没关系，已经没关系了。只是……我不希望你再留下相同的后悔。如果，你还有遗憾的话……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈dori君"},
					"「……沒關係，已經沒關係了。只是……我不希望你再留下相同的後悔。如果，你還有遺憾的話……」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00303",
		linknext = "0070_00305",
		line = 4651,
	},
	["0070_00305"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0349", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬", "ナナドリくん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanadori"},
					"“You should go and talk to Rei again.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈dori君"},
					"“再试着、面对礼前辈最后一次……也没什么不好吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈dori君"},
					"「再試著、面對禮前輩最後一次……也沒什麼不好吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00304",
		linknext = "0070_00306",
		line = 4663,
	},
	["0070_00306"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0350", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬", "ナナドリくん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanadori"},
					"“We went our separate ways and ended up so far apart. It took us so long to get back to where we are.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈dori君"},
					"“虽然我们、就那样错身而过……然后远远分开……花了这么久的时间才心意相通……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈dori君"},
					"「雖然我們、就那樣錯身而過……然後遠遠分開……花了這麼久的時間才心意相通……」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00305",
		linknext = "0070_00307",
		line = 4675,
	},
	["0070_00307"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0351", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬", "ナナドリくん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanadori"},
					"“But Rei’s still here. You still have time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈dori君"},
					"“可是礼前辈还在这里。如果是现在……我想、一定还来得及的”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈dori君"},
					"「可是禮前輩還在這裡。如果是現在……我想、一定還來得及的」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00306",
		linknext = "0070_00308",
		line = 4687,
	},
	["0070_00308"] = {
