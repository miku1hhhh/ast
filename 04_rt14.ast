	["0070_00288"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0340", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I think about it sometimes. I wonder what would’ve happened if I had stayed on the island. How do you think things would’ve ended up?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……我偶尔会想。那个时候，如果我没有搬家……我们彼此都一直留在岛上，事情到底会变成怎么样呢……我说，你觉得呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……我偶爾會想。那個時候，如果我沒有搬家……我們彼此都一直留在島上，事情到底會變成怎麼樣呢……我說，你覺得呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00287",
		linknext = "0070_00289",
		line = 4452,
	},
	["0070_00289"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Honestly? No idea.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“会……怎么样呢？我不知道”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「會……怎麼樣呢？我不知道」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00288",
		linknext = "0070_00290",
		line = 4463,
	},
	["0070_00290"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0341", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Exactly. Maybe we would’ve become friends again, maybe we would’ve stayed distant and never ended up with what we have now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“……是啊。说不定我们会和好……说不定会就那样渐行渐远，也不会发展成现在这样的关系”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「……是啊。說不定我們會和好……說不定會就那樣漸行漸遠，也不會發展成現在這樣的關係」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00289",
		linknext = "0070_00291",
		line = 4475,
	},
	["0070_00291"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0342", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“But I did regret how things turned out for a long time... I still do.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“可是……我果然还是一直很后悔……到现在，都还有点后悔”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「可是……我果然還是一直很後悔……到現在，都還有點後悔」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00290",
		linknext = "0070_00292",
		line = 4487,
	},
	["0070_00292"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0343", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I wish I had asked to put off moving away for a little. Even if I had to stay behind on the island by myself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“那个时候，要是我任性一点，让家里延后搬家的时间就好了。就算是耍赖，只有我一个人留下来也好”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「那個時候，要是我任性一點，讓家裡延後搬家的時間就好了。就算是耍賴，只有我一個人留下來也好」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00291",
		linknext = "0070_00293",
		line = 4499,
	},
	["0070_00293"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0344", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I always wished I had come to see you one more time, Tachibana.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“在最后，要是有去见橘君最后一面就好了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「在最後，要是有去見橘君最後一面就好了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00292",
		linknext = "0070_00294",
		line = 4511,
	},
	["0070_00294"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0345", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I wanted to apologize. For crying, for hurting you...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我哭了真是对不起、我伤害你了真是对不起……那个时候，要是能说出口就好了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我哭了真是對不起、我傷害你了真是對不起……那個時候，要是能說出口就好了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00293",
		linknext = "0070_00295",
		line = 4523,
	},
	["0070_00295"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It’s not something you have to apologize for, Nanase.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……也不是该由奈奈濑来道歉的事情吧”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……也不是該由奈奈瀨來道歉的事情吧」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00294",
		linknext = "0070_00296",
		line = 4534,
	},
	["0070_00296"] = {
