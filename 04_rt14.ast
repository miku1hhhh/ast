					"“Did you know? People think mandarin ducks mate for life, but they actually pick a new sexual partner every year!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛", "Hamedo凛君"},
					"“在这里补充一点洨知识hame！虽然都说鸳鸯夫妇，可是鸳鸯其实是一种每年都会换对象的鸟喔啪啪！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛", "Hamedo凜君"},
					"「在這裡補充一點洨知識hame！雖然都說鴛鴦夫婦，可是鴛鴦其實是一種每年都會換對象的鳥喔啪啪！」",
					{"rt2"},
				},
			},
		},
