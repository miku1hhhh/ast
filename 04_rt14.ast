	["0070_00317"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There’s no denying there will be pain.",
					{"rt2"},
				},
			},
			cn = {
				{
					"跟她在一起──肯定会有让彼此心痛的事情发生吧。",
