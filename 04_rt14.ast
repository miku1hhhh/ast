				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanadori"},
					"“Never would’ve thought we’d end up helping the FS like this, huh?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈dori君"},
					"“话又说回来……没想到我们会有像这样协助FS的一天呢。以前可完全无法想像”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈dori君"},
					"「話又說回來……沒想到我們會有像這樣協助FS的一天呢。以前可完全無法想像」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00216",
		linknext = "0070_00218",
		line = 3532,
	},
	["0070_00218"] = {
