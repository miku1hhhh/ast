		{"fg", file="rei_02f_00001", file1="rei_02f_00101", file3="rei_02f_00317", path=":fg/rei_02f/", id=30, ch="礼", lv=9, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1222", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼", "ハメドレイくん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Hamedo-Rei"},
					"“Hame! Today, you graduate from being disgusting gross fake penguin maggots into beautiful, flawless Hamedoris!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼", "Hame奴隶君"},
					"“Hame！从今天开始你们就从长脚冒牌恶烂臭企鹅毕业，成为真正的Hamedori君了啪啪！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "Hame奴隸君"},
					"「Hame！從今天開始你們就從長腳冒牌噁爛臭企鵝畢業，成為真正的Hamedori君了啪啪！」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00031",
		linknext = "0070_00033",
		line = 530,
	},
	["0070_00033"] = {
