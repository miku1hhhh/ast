			cn = {
				{
					name = {"モブ男B", "Yamedori君男性"},
					"“嗯嗯！就算舍弃信仰变成Yamedori君也只能同意交往了！！希望你能够用你的得意技巧帮我把股间的刀刃完全出鞘！！”",
