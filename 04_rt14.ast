		linkback = "0070_00300",
		linknext = "0070_00302",
		line = 4615,
	},
	["0070_00302"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00220", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I did something terrible to you, and then ran away... I shut you out... I’m really...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“让奈奈濑留下恐怖的回忆、逃走、疏远…………真的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「讓奈奈瀨留下恐怖的回憶、逃走、疏遠…………真的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00301",
		linknext = "0070_00303",
		line = 4627,
	},
	["0070_00303"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00208", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nanase... I’m really sorry.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“奈奈濑……那个时候，真的很对不起……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「奈奈瀨……那個時候，真的很對不起……」",
					{"rt2"},
