					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanadori"},
					"“Obviously! I’m your partner in crime!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈dori君"},
					"“嗯，那当然了？毕竟是你的搭档啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈dori君"},
					"「嗯，那當然了？畢竟是你的搭檔啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00368",
		linknext = "0070_00370",
		line = 5537,
	},
	["0070_00370"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0360", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬", "ナナドリくん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanadori"},
					"“It wouldn’t be like you to stay mopey forever. You need to be rock-hard, body and mind. That means your heart, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈dori君"},
					"“……没有活力的淳根本不像淳。如果能让自己全身都勃起的话……当然也可以让心勃起吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈dori君"},
					"「……沒有活力的淳根本不像淳。如果能讓自己全身都勃起的話……當然也可以讓心勃起吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00369",
		linknext = "0070_00371",
		line = 5549,
	},
	["0070_00371"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase’s kind words rejuvenate my flagging, flaccid heart.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我那软趴趴的心，随着奈奈濑的话语逐渐重生。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我那軟趴趴的心，隨著奈奈瀨的話語逐漸重生。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00370",
		linknext = "0070_00372",
		line = 5559,
	},
