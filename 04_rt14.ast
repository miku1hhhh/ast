		{"text"},
		text = {
			vo = {
				{"vo", file="hamedori0041", path=":vo/", ch="hamedori"},
			},
			ja = {
				{
					name = {"ハメドリくん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ハメドリくん", "Hamedori"},
					"“Hey, everyone! It’s time for our famous H/ero show! Why not come and watch? Tentacle battles on the most perverted stage of all!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ハメドリくん", "Hamedori君"},
					"‘各位～！到了大家期待已久的H． ERO秀的时间hame啰～！希望大家务必能来看看我的括约（活跃）！在变态舞台上和我触手（握手）吧！’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ハメドリくん", "Hamedori君"},
					"『各位～！到了大家期待已久的H．ERO秀的時間hame囉～！希望大家務必能來看看我的括約（活躍）！在變態舞台上和我觸手（握手）吧！』",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00176",
		linknext = "0070_00178",
		line = 2990,
	},
