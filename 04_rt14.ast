				{
					name = {"スス子", "Susudori"},
					"“That doesn’t make any sense? How can there already be a legend when the event hasn’t been held before?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝dori君"},
					"“为什么第一次举办的活动会有那种传承啊hame──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲dori君"},
					"「為什麼第一次舉辦的活動會有那種傳承啊hame──！」",
					{"rt2"},
				},
			},
		},
