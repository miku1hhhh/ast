	["0070_00215"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We chat absentmindedly as deafening noises come from the stage.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们一边聊着不着边际的话题，一边无意地听着舞台上传来的声响。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們一邊聊著不著邊際的話題，一邊無意地聽著舞台上傳來的聲響。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00214",
		linknext = "0070_00216",
		line = 3509,
	},
	["0070_00216"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The ecstatic cheers don’t seem like reality, they seem so far away considering that the action is happening just behind us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那热烈过了头的声音不知为何有点缺乏现实感，明明就在我们的正后方，可是感觉却像是很遥远的地方发生的事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那熱烈過了頭的聲音不知為何有點缺乏現實感，明明就在我們的正後方，可是感覺卻像是很遙遠的地方發生的事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00215",
		linknext = "0070_00217",
		line = 3519,
	},
	["0070_00217"] = {
		{"fg", file="nanase_01f_00001", file1="nanase_01f_00101", file2="nanase_01f_00210", path=":fg/nanase_01f/", id=30, ch="奈々瀬", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0324", path=":vo/", ch="nanase"},
