	["0070_00319"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe it’s just as she said. Every time I see another man on the island, I’ll be filled with jealousy and revulsion.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就跟她说的一样，或许每次和岛上的男性错身而过都会让我有强烈的厌恶感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就跟她說的一樣，或許每次和島上的男性錯身而過都會讓我有強烈的厭惡感。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00318",
		linknext = "0070_00320",
		line = 4822,
	},
