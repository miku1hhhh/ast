		{"text"},
		text = {
			vo = {
				{"vo", file="rei1223", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼", "ハメドレイくん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Hamedo-Rei"},
					"“I’m sure you know this already, but because this is the first time this event is being held, there’s a legend that if you confess to your crush during the event, your love is sure to come true!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼", "Hame奴隶君"},
					"“我想你们应该都很清楚hame，相传在第一次举办的本活动中告白的话，恋情就能实现啪啪！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "Hame奴隸君"},
					"「我想你們應該都很清楚hame，相傳在第一次舉辦的本活動中告白的話，戀情就能實現啪啪！」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00033",
		linknext = "0070_00035",
		line = 561,
	},
	["0070_00035"] = {
