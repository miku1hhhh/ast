			},
			en = {
				{
					name = {"桐香", "Toudori"},
					"“Hamedori is modeled on the mandarin duck, which mates for life!♪ That’s why it’s a great symbol of love and companionship!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香", "桐dori君"},
					"“Hamedori君的原型是鸳鸯……是男女关系好到会被用来比喻神仙伴侣的鸟类hame♪看得出来是想要借用这层关系把活动搞得更盛大的远大计划呢啪啪。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香", "桐dori君"},
					"「Hamedori君的原型是鴛鴦……是男女關係好到會被用來比喻神仙伴侶的鳥類hame♪看得出來是想要借用這層關係把活動搞得更盛大的遠大計畫呢啪啪。」",
					{"rt2"},
				},
			},
		},
