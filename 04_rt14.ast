	["0070_00092"] = {
		{"se", id=2, loop=0, file="se_d007"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A nightmarish chant breaks out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"热烈的Hamedori喊声像噩梦一样反覆。",
					{"rt2"},
				},
			},
			tw = {
				{
					"熱烈的Hamedori喊聲像噩夢一樣反覆。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00091",
		linknext = "0070_00093",
		line = 1692,
	},
	["0070_00093"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They’re really going crazy for this. It feels like this chanting could go on forever.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那热度之惊人，几乎让人担忧这喊声会不会永远不结束。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那熱度之驚人，幾乎讓人擔憂這喊聲會不會永遠不結束。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00092",
		linknext = "0070_00094",
		line = 1702,
	},
	["0070_00094"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I feel like when I finally shuffle off this mortal coil, this moment is going to flash before my eyes instead of something really important.",
					{"rt2"},
				},
			},
			cn = {
				{
					"感觉哪天我要死了的时候，这一幕好像也会夹杂在走马灯里面。",
					{"rt2"},
				},
			},
			tw = {
				{
					"感覺哪天我要死了的時候，這一幕好像也會夾雜在走馬燈裡面。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00093",
		linknext = "0070_00095",
		line = 1712,
	},
	["0070_00095"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I definitely don’t want to remember this on my death bed, but it’s too late. This moment is burned into my synapses and will stay there until they fizzle out.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明是绝对不想在临死之际回想起来的光景，可是因为实在是太强烈了，不小心深深地刻在了记忆里面。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明是絕對不想在臨死之際回想起來的光景，可是因為實在是太強烈了，不小心深深地刻在了記憶裡面。",
					{"rt2"},
				},
			},
		},
