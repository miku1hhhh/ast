	["0070_00300"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0347", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬", "ナナドリくん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanadori"},
					"“Jun... Do you still regret what happened that day?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈dori君"},
					"“淳你……现在还在后悔、那天发生的事情吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈dori君"},
					"「淳你……現在還在後悔、那天發生的事情嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00299",
		linknext = "0070_00301",
		line = 4603,
	},
	["0070_00301"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00206", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
