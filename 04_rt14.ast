	["0070_00369"] = {
		{"fgact", ch="ハメ4", id=4, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0359", path=":vo/", ch="nanase"},
