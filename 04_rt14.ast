			ja = {
				{
					name = {"美岬", "アーマーミサドリくん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Armored Misadori"},
					"“I heard you talking about it the other day, and I thought it sounded fun, so I got Asane and Akino to make it for me! Old Man Kenzou helped out too!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬", "武装美岬dori君"},
					"‘前阵子听淳之介君说过以后觉得挺有意思的，所以就拜托麻沙音酱和秋野同学帮我做了hame！建藏爷爷也帮忙了喔啪啪！’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬", "武裝美岬dori君"},
					"『前陣子聽淳之介君說過以後覺得挺有意思的，所以就拜託麻沙音醬和秋野同學幫我做了hame！建藏爺爺也幫忙了喔啪啪！』",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00017",
		linknext = "0070_00019",
		line = 301,
	},
	["0070_00019"] = {
