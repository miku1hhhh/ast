	["0070_00198"] = {
		{"bgm", file="bgm01", vol=100},
		{"fg", file="hame_01m_00001", path=":fg/hame_01m/", id=4, lv=4, head="hame_01m", ch_origin="ハメ", ch="ハメ4", mw="mw", sync=0, mode=3, x=-5, y=-35},
		{"transitiontime", time=300},
		{"fg", file="nanase_02f_00001", file1="nanase_02f_00101", file2="nanase_02f_00210", path=":fg/nanase_02f/", id=30, ch="奈々瀬", lv=4, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0320", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬", "ナナドリくん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanadori"},
					"“I was a little worried about you at first, but you seem to be doing pretty well!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈dori君"},
					"“我原本还有点担心……但是看来你还满努力的嘛？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈dori君"},
					"「我原本還有點擔心……但是看來你還滿努力的嘛？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00197",
		linknext = "0070_00199",
		line = 3284,
	},
	["0070_00199"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Duh! The glorious hero of the Lewd War won’t be laid low by something as minor as heartbreak! Not for long, at least.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呼……这是理所当然的吧？变态战役的英雄怎么能因为区区失恋就一蹶不振呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呼……這是理所當然的吧？變態戰役的英雄怎麼能因為區區失戀就一蹶不振呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00198",
		linknext = "0070_00200",
		line = 3296,
	},
	["0070_00200"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You’re doing pretty amazing yourself, Nanase. You were so embarrassed at first.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“奈奈濑才了不起呢。一开始明明那么不好意思的”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「奈奈瀨才了不起呢。一開始明明那麼不好意思的」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00199",
		linknext = "0070_00201",
		line = 3308,
	},
	["0070_00201"] = {
		{"fg", file="nanase_02f_00001", file1="nanase_02f_00101", file2="nanase_02f_00210", path=":fg/nanase_02f/", id=30, ch="奈々瀬", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0321", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬", "ナナドリくん"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanadori"},
					"“It’s hard work, I’ve got to apply myself fully! Besides, seeing you giving it your all and jumping into the fray made me feel more confident doing the same.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈dori君"},
					"“唉，毕竟被狠狠操练过了嘛？……而且，看到你那样全心投入……就想说我也得好好加油这样”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈dori君"},
					"「唉，畢竟被狠狠操練過了嘛？……而且，看到你那樣全心投入……就想說我也得好好加油這樣」",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00200",
		linknext = "0070_00202",
		line = 3321,
	},
	["0070_00202"] = {
