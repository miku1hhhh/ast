	["0070_00099"] = {
		{"se", id=0, loop=0, file="se_d007"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All the Hamedoris go around saying similar horny platitudes, making the crowd emit some of the strangest noises I’ve ever heard. I’m talking shit like “Hagyahhh!” and “Pyeeaaahhh!”",
					{"rt2"},
				},
			},
			cn = {
				{
					"Hamedori君们四处说着差不多的台词，而观众们也“哈呀咿咿咿咿”的“哔呀啊啊啊啊啊”的、兴奋地报以非人哉的叫喊声。",
					{"rt2"},
				},
			},
			tw = {
				{
					"Hamedori君們四處說著差不多的台詞，而觀眾們也「哈呀咿咿咿咿」的「嗶呀啊啊啊啊啊」的、興奮地報以非人哉的叫喊聲。",
					{"rt2"},
				},
			},
		},
		linkback = "0070_00098",
		linknext = "0070_00100",
		line = 1782,
	},
	["0070_00100"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe they’re not even real people.",
					{"rt2"},
				},
			},
