			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Ugh... Sister...! I connected my computer to the internet and it got some kinda bug called a virus...? I went and got some mosquito repellant, but it doesn’t seem to work!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“呜呜呜呜，姐姐……！连到网络上之后，电脑就说出现了叫做病毒的害虫……！虽然我点了蚊香，可是却一直没有好转……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「嗚嗚嗚嗚，姊姊……！連到網路上之後，電腦就說出現了叫做病毒的害蟲……！雖然我點了蚊香，可是卻一直沒有好轉……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0088_00447",
		linknext = "0088_00449",
		line = 5784,
	},
	["0088_00449"] = {
