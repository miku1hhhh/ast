					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「剛從巨根電腦回來，正在練習打字喔…等到黃昏大概就會出來做晚飯了吧……」",
					{"rt2"},
				},
			},
		},
