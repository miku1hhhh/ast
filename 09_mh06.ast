			en = {
				{
					"“Although we could take the easy way out and delay the game due to the game’s main staff being tossed in prison, I can’t let us give in to the temptation.”",
					{"rt2"},
				},
			},
			cn = {
				{
					"“因主要成员入狱必须延期”本来可以用这说法──但是不能仗着这样做。",
					{"rt2"},
				},
			},
			tw = {
				{
					"「因主要成員入獄必須延期」本來可以用這說法──但是不能仗著這樣做。",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00028",
		linknext = "0106_00030",
