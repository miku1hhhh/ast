	},
	["0106_00030"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We said we would finish during summer break, so we have to finish it...",
					{"rt2"},
				},
			},
			cn = {
				{
					"既然说要在暑假期间完成，怎么样都要完成才对。",
