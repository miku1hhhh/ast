					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Shut up, I need to be with you 29 hours a day, 468 days a year!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“吵死了，麻沙将想要29小时468天，都和哥哥在一起嘛！”",
