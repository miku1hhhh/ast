			},
			cn = {
				{
					name = {"美岬"},
					"“太好了！最终版本写好了！这都要靠已攻略过的其他美岬路线帮忙，才能有这么感动的路线展开！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「太好了！最終版本寫好了！這都要靠已攻略過的其他美岬路線幫忙，才能有這麼感動的路線展開！」",
					{"rt2"},
				},
			},
		},
