		text = {
			vo = {
				{"vo", file="09_mh06_0002", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"美岬・麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬・麻沙音", "Misaki & Asane"},
					"“We are no NPCs! Forever fatties! Love and peace? NO! Chub and beef? YES! Calories will show us the way!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬・麻沙音"},
					"“我～～不再是路人！我是肥仔！爱与和平？不──！肥仔与牛肉！耶斯！劈出一条热量之路！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬・麻沙音"},
					"「我～～不再是路人！我是肥仔！愛與和平？不──！肥仔與牛肉！耶斯！劈出一條熱量之路！」",
					{"rt2"},
				},
			},
		},
