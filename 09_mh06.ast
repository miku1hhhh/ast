			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I’m gonna stick to you like glue and bug you for stuff forever and ever! You gotta be there for me, Bro! Our bloodline’ll be finished if you kick the bucket before I do!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我这一辈子都要黏着你耍无赖，所以哥你也要一辈子都宠着我喔，要是比我先死的话我就把大家都杀光光──！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我這一輩子都要黏著你耍無賴，所以哥你也要一輩子都寵著我喔，要是比我先死的話我就把大家都殺光光──！！」",
					{"rt2"},
				},
			},
		},
