		linknext = "0106_00017",
		line = 289,
	},
	["0106_00017"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I think it’s about time you learned how many hours there are in a day and days in a year, sweet sister of mine.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好～～一天有几小时和一年有几天，你差不多该记起来了吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好～～一天有幾小時和一年有幾天，妳差不多該記起來了吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0106_00016",
		linknext = "0106_00018",
		line = 301,
	},
	["0106_00018"] = {
		{"fg", file="asane_01l_00001", file1="asane_01l_00101", file2="asane_01l_00211", path=":fg/asane_01l/", id=3, lv=3, head="asane_01l", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=200},
		{"text"},
		text = {
