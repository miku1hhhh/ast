					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I thought maybe if we fight even harder to change things, you’ll be able to smile again like you used to. That’s just my two yen.”",
					{"rt2"},
				},
			},
			cn = {
				{
