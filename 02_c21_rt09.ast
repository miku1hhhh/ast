		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s easy enough to consider that World B’s Rei may have been impacted by her closeness with His Sexellency, Junnosuke Tachibana.",
					{"rt2"},
				},
			},
			cn = {
				{
					"足以想像，因为与性帝──橘淳之介较为亲近，所以对B世界的礼前辈发生了影响。",
					{"rt2"},
				},
			},
			tw = {
				{
					"足以想像，因為與性帝──橘淳之介較為親近，所以對B世界的禮前輩發生了影響。",
					{"rt2"},
				},
			},
		},
		linkback = "0046_00058",
		linknext = "0046_00060",
		line = 851,
	},
	["0046_00060"] = {
