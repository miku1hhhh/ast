		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just like her, he was forced into unwanted sexual situations to help his family... and even forced into becoming a spokesperson.",
					{"rt2"},
				},
			},
			cn = {
				{
					"和她一样，为了家人被迫进行了非自愿的性行为──此外，性帝更被当成了活看板。",
					{"rt2"},
				},
			},
			tw = {
				{
					"和她一樣，為了家人被迫進行了非自願的性行為──此外，性帝更被當成了活看板。",
					{"rt2"},
				},
			},
		},
