	["0046_00063"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00207", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0979", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Thanks, Hinami. I’m just happy that you feel that way. I wish that the version of me from this world was able to hear it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……谢谢，雏见。光是有这种心情就足够了……其实,这些话是属于这个世界的我应该听的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……謝謝，雛見。光是有這種心情就足夠了……其實,這些話是屬於這個世界的我應該聽的。」",
					{"rt2"},
				},
			},
		},
