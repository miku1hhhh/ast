			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“It’s just... Rei, you seem so sad sometimes, and lately it’s like I never see you smiling.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“怎么说呢……礼酱偶尔会露出很哀伤表情，最近也不怎么笑了。”",
