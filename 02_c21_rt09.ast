		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0112", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Anyway, a Rei is a Rei! You went through a lot, but you kept going! You’re amazing! You’re fantastic! You’re super cool!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“总之！礼酱就是礼酱！现在的礼酱也经历不少事情，即便如此还是很努力了！真棒！真了不起！好帅气！”",
					{"rt2"},
				},
			},
			tw = {
