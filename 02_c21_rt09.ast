					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Oh yeah... But the Rei from the other world would... Wait, what? Which world was which again? Oh no, I’m so confused...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，这样啊……会是这样嘛。但是，那个世界的礼酱也……奇怪？是变成哪个世界来着……哎呀奇怪？嗯嗯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，這樣啊……會是這樣嘛。但是，那個世界的禮醬也……奇怪？是變成哪個世界來著……哎呀奇怪？嗯嗯？」",
					{"rt2"},
				},
