			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那个啊，我啊。至今为止，为了帮助麻沙音酱的哥哥，为了秋野君……此我和大家一起努力过。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那個啊，我啊。至今為止，為了幫助麻沙音醬的哥哥，為了秋野君……此我和大家一起努力過。」",
					{"rt2"},
