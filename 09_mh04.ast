				{"vo", file="misaki0854", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“If I had to choose between a life on a scant 1000 calories a day versus 10,000, I’d choose the latter, without a doubt. In my final moments, I want to be able to proudly claim I lived a full life.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“一天只吃一千卡热量的人和一天吃下一万卡热量的人他们的人生⋯⋯现在我可以拍拍胸脯说，会说自己幸福的一定是后者啦！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「一天只吃一千卡熱量的人和一天吃下一萬卡熱量的人他們的人生⋯⋯現在我可以拍拍胸脯說，會說自己幸福的一定是後者啦！」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00026",
		linknext = "0104_00028",
		line = 435,
	},
