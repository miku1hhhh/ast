			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“We’re making an eroge at MisaSoft called NukiFatty where you have to conquer various versions of me. I want consent from you for the indubitable Misaki to use that line!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我现在在做一款名叫自干肥仔的色情游戏，有很多种不同风格的我要进行攻略！在这之中，有一个风格是原来风美岬，刚刚说的是想用在她的台词里，所以想要文乃答应我们使用。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
