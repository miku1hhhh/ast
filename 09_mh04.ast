		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Unlike a moment earlier, he doesn’t deny us instantly. He’s wavering.",
					{"rt2"},
				},
			},
			cn = {
				{
					"和刚才不同，他没有马上说不。一定是有所动摇了吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"和剛才不同，他沒有馬上說不。一定是有所動搖了吧。",
