	},
	["0104_00152"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", file2="misaki_01m_00221", path=":fg/misaki_01m/", id=6, lv=6, head="misaki_01m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0879", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Also, it just so happens that there are two islanders who need help right here right now...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不过，这么一说，站在您眼前的就是需要帮助的岛民啊⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不過，這麼一說，站在您眼前的就是需要幫助的島民啊⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00151",
		linknext = "0104_00153",
		line = 2551,
	},
	["0104_00153"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00102", file2="hitoura_01m_00201", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0136", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“...You’ve got more guts than I thought.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“你⋯⋯真是人不可貌相，这话说得可真有胆量啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「妳⋯⋯真是人不可貌相，這話說得可真有膽量啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00152",
		linknext = "0104_00154",
		line = 2566,
	},
	["0104_00154"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=6, head="misaki_01m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="美岬6", id=6, act="振動下", loop=4, size=10, time=75, ease="easeinout_sine"},
		{"text"},
		delay = {
			[5000] = {
				{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", file2="misaki_01m_00229", path=":fg/misaki_01m/", id=6, lv=6, head="misaki_01m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, timestamp=51, delay2=5000, mode=3, x=395, y=-5},
			},
			[4999] = {
				{"transitiontime", time=300, timestamp=51, delay2=5000},
			},
		},
		text = {
			vo = {
				{"vo", file="misaki0880", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Ahaha, what are you saying? I’ve got plenty of gut! If you let Asane tell it, I’m a gross fatty!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“啊哈哈，您在说什么啊。不只是胆量，我从头到脚都很有份量。总是被麻沙音酱说我又胖又恶呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「啊哈哈，您在說什麼啊。不只是膽量，我從頭到腳都很有份量。總是被麻沙音醬說我又胖又噁呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00153",
		linknext = "0104_00155",
		line = 2585,
	},
	["0104_00155"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00102", file2="hitoura_01m_00216", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Unsure how to react to that statement, Hitoura’s face contorts into something between a wry smile and bewilderment.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦氏听到这番话却不知道该做何反应，露出了困惑及苦笑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦氏聽到這番話卻不知道該做何反應，露出了困惑及苦笑。",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00154",
		linknext = "0104_00156",
		line = 2598,
	},
	["0104_00156"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The charismatic governor, creator of the perverted law, breaks form in front of the angelic Misaki.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算是制造出变态条例的厉害县知事，也终究是人──站在天使美岬的面前，也无法维持原样了吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算是製造出變態條例的厲害縣知事，也終究是人──站在天使美岬的面前，也無法維持原樣了吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00155",
		linknext = "0104_00157",
		line = 2608,
	},
	["0104_00157"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s like watching an older version of myself when I first got to know her. I can’t help but feel some camaraderie with him.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就好像看到当初刚认识美岬时的自己，让人觉得似乎距离有些拉近了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就好像看到當初剛認識美岬時的自己，讓人覺得似乎距離有些拉近了。",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00156",
		linknext = "0104_00158",
		line = 2618,
	},
	["0104_00158"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00203", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=6},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So... will you give us permission to use this perverted parody?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“容我再提一次──是否能给我们变态恶搞的使用许可呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「容我再提一次──是否能給我們變態惡搞的使用許可呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00157",
		linknext = "0104_00159",
		line = 2630,
	},
	["0104_00159"] = {
