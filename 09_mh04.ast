	["0104_00138"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00211", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=6},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Life derives its spice from giving trivial things your all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“连鸡毛小事也都全力以赴，这才会让人生充满色彩──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「連雞毛小事也都全力以赴，這才會讓人生充滿色彩──」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00137",
		linknext = "0104_00139",
		line = 2341,
	},
	["0104_00139"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If you’re too lazy to give a damn about anything, then you will lead a meaningless life of consumption.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“觉得是鸡毛小事就不[|披荆斩棘的话]，只是虚度人生罢了──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「覺得是雞毛小事就不[|披荊斬棘的話]，只是虛度人生罷了──」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00138",
