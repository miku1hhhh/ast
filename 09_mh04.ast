			},
			[6499] = {
				{"transitiontime", time=300, timestamp=48, delay2=6500},
			},
		},
		text = {
			vo = {
				{"vo", file="hitoura0130", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I can’t argue with that... However, I can neither grant the permission you’re looking for lightly. The words you’re parodying are not my own.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“我不是不懂你的意思⋯⋯而是，我无法轻易答应给出许可。毕竟这也不是我说的话啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「我不是不懂你的意思⋯⋯而是，我無法輕易答應給出許可。畢竟這也不是我說的話啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00140",
		linknext = "0104_00142",
