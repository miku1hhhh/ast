	["0104_00180"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00102", file2="kouki_01m_00208", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", ch_origin="光姫", ch="光姫17", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0171", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“It’s nothing to do with that... You just talked with Hitoura about what’s going to happen with the perverted stuff, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“不是这个⋯⋯你们刚才和仁浦大人说的，那个关于变态什么什么的⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「不是這個⋯⋯你們剛才和仁浦大人說的，那個關於變態什麼什麼的⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00179",
		linknext = "0104_00181",
		line = 3081,
	},
	["0104_00181"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=6},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah... I mulled it over, and I found it’d be pointless without the pervy stuff. So I came to discuss that with him.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊啊──我们也是烦恼了很久，最后觉得没有变态果然不行，所以就来找仁浦氏谈这事了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊啊──我們也是煩惱了很久，最後覺得沒有變態果然不行，所以就來找仁浦氏談這事了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00180",
		linknext = "0104_00182",
		line = 3093,
	},
