		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"With a scowl, Hitoura looks back and forth between me and Misaki.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁甫先生面有难色的来回看着我和美岬。",
