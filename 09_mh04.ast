	},
	["0104_00142"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As can be expected of the former governor. Of course he isn’t going to make this easy for us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"应该说果然是前县长吗，不是这么容易就打发的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"應該說果然是前縣長嗎，不是這麼容易就打發的。",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00141",
		linknext = "0104_00143",
		line = 2392,
	},
	["0104_00143"] = {
		{"fg", file="misaki_02l_00001", file1="misaki_02l_00101", file2="misaki_02l_00218", path=":fg/misaki_02l/", id=6, lv=6, head="misaki_02l", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0877", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“I suppose a man who hurtles from an exploding building on a truck and then jumps into the ocean with his hands wrapped around his sex doll is cut from a different cloth...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不亏是从爆炸的大楼中开着车冲出来，手里还抱着充气娃娃跳进海的人啊⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不虧是從爆炸的大樓中開著車衝出來，手裡還抱著充氣娃娃跳進海的人啊⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00142",
		linknext = "0104_00144",
		line = 2407,
	},
	["0104_00144"] = {
