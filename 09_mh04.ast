		text = {
			vo = {
				{"vo", file="misaki0849", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Sluuurrrrrrp! Mmm! You gut flora had better be ready for the carbpocalypse, ’cause these calories are a-comin’! Yes, my love, my life—garlic ramen is the BESTEST!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“吸吸咬咬，嚼嚼！嗯！满满糖质的混浊液体，热量暴徒，益生菌的敌人！这就是我爱的蒜味拉面！棒呆了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「吸吸咬咬，嚼嚼！嗯！滿滿醣質的混濁液體，熱量暴徒，益生菌的敵人！這就是我愛的蒜味拉麵！棒呆了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00016",
		linknext = "0104_00018",
		line = 269,
	},
	["0104_00018"] = {
