	["0104_00151"] = {
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00102", file2="hitoura_01m_00215", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-405, y=-5},
