			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“This is the last time, but I do owe you for saving my and my daughter’s lives. Besides, you two don’t seem like you’ll leave until I approve.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“虽然我们彼此已经谁也不欠谁，而又是我女儿和我的救命恩人的拜托⋯⋯我自然是不答应也不是啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「雖然我們彼此已經誰也不欠誰，而又是我女兒和我的救命恩人的拜託⋯⋯我自然是不答應也不是啊。」",
					{"rt2"},
				},
			},
		},
