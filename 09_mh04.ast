					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“If we can’t use this bit in NukiFatty, then it’s doomed to mediocrity as an unpolished product! Please, we beg of you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“不能用这段子的话，自干肥仔就没了画龙点睛的效果，沦为很普的作品的！真的拜托！请容我们用！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「不能用這段子的話，自幹肥仔就沒了畫龍點睛的效果，淪為很普的作品的！真的拜託！請容我們用！」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00131",
		linknext = "0104_00133",
