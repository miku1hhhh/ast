			},
			tw = {
				{
					"仁浦氏的表情一僵，陷入沈默。",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00145",
		linknext = "0104_00147",
		line = 2453,
	},
	["0104_00147"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00211", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0132", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Modesty is a virtue, but I will say I still hold a lot of influence over this island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“自己说虽然有点不好意思，但是这座岛上，我的脸到现在依然有些作用。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「自己說雖然有點不好意思，但是這座島上，我的臉到現在依然有些作用。」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00146",
		linknext = "0104_00148",
		line = 2468,
	},
	["0104_00148"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00204", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[3000] = {
				{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00211", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, timestamp=49, delay2=3000, mode=3, x=-405, y=-5},
			},
			[2999] = {
				{"transitiontime", time=300, timestamp=49, delay2=3000},
			},
		},
		text = {
			vo = {
				{"vo", file="hitoura0133", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“The perverted law is no more, and the island is unsettled. Sham advisories and negotiations all over the place. It’s a mess.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“条例没了以后，百业待兴⋯⋯所以，我在很多地方担任类似顾问、斡旋的角色。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「條例沒了以後，百業待興⋯⋯所以，我在很多地方擔任類似顧問、斡旋的角色。」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00147",
		linknext = "0104_00149",
		line = 2486,
	},
	["0104_00149"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00215", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[7500] = {
				{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00206", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, timestamp=50, delay2=7500, mode=3, x=-405, y=-5},
			},
			[7499] = {
				{"transitiontime", time=300, timestamp=50, delay2=7500},
			},
		},
		text = {
			vo = {
				{"vo", file="hitoura0134", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I have no doubt my perverted law was what led to the sexual mayhem, and what happened to Fumino... I will remain here doing what I can until the island becomes stable.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“做爱骚动还有文乃的事情──都是我的变态条例致使的。在岛还没有完全安定下来，我可以做的我就尽量做。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「做愛騷動還有文乃的事情──都是我的變態條例致使的。在島還沒有完全安定下來，我可以做的我就盡量做。」",
					{"rt2"},
				},
			},
		},
		linkback = "0104_00148",
		linknext = "0104_00150",
		line = 2504,
	},
	["0104_00150"] = {
