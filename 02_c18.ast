			cn = {
				{
					name = {"淳之介"},
					"“欸？啊不⋯⋯没有什么、没什么特别的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「欸？啊不⋯⋯沒有什麼、沒什麼特別的事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00213",
		linknext = "0036_00215",
		line = 2914,
	},
	["0036_00215"] = {
		{"fg", file="mizuhiki_01m_00001", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00214", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[2000] = {
				{"fg", file="mizuhiki_01m_00001", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00210", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, timestamp=33, delay2=2000, mode=3, x=-5, y=-5},
			},
			[1999] = {
				{"transitiontime", time=300, timestamp=33, delay2=2000},
			},
		},
		text = {
			vo = {
				{"vo", file="mizuhiki0042", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Umm... I think you could talk to me about it if something’s troubling you, or if it’s about masturbation...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“那个⋯⋯如果你有什么烦恼，像是自慰之类的，我可以听你说喔⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「那個⋯⋯如果你有什麼煩惱，像是自慰之類的，我可以聽你說喔⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00214",
		linknext = "0036_00216",
		line = 2932,
	},
	["0036_00216"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...I can’t just come out and tell her about these feelings of distress.",
					{"rt2"},
				},
			},
			cn = {
				{
					"⋯⋯这种懊恼并不是可以顺着这种情况随意说出口的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"⋯⋯這種懊惱並不是可以順著這種情況隨意說出口的。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00215",
		linknext = "0036_00217",
		line = 2942,
	},
	["0036_00217"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00301", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...There’s an eccentric old man that I know. I just can’t bring myself to like him because of a bunch of stuff that happened in the past.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯我有个认识的顽固老头。从以前就因为各种原因，所以没有办法喜欢他。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯我有個認識的頑固老頭。從以前就因為各種原因，所以沒有辦法喜歡他。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00216",
		linknext = "0036_00218",
		line = 2954,
	},
	["0036_00218"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00309", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And I guess you could say that it’s no big deal... But I was just wondering if I could make things between us at least a little better.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以说虽然也没有什么事⋯⋯不过我也稍稍在想，到底要对他怎么办才好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以說雖然也沒有什麼事⋯⋯不過我也稍稍在想，到底要對他怎麼辦才好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00217",
		linknext = "0036_00219",
		line = 2966,
	},
	["0036_00219"] = {
		{"fg", file="mizuhiki_01m_00001", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00220", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I tell Akino about my problems in a fairly vague way.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我含糊其辞地对秋野说。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我含糊其辭地對秋野說。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00218",
		linknext = "0036_00220",
		line = 2979,
	},
	["0036_00220"] = {
		{"fg", file="mizuhiki_01m_00001", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00225", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She gives me a wide-eyed stare, then looks down.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她瞪大双眼看着我，接着垂下了眼。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她瞪大雙眼看著我，接著垂下了眼。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00219",
		linknext = "0036_00221",
		line = 2992,
	},
	["0036_00221"] = {
		{"fg", file="mizuhiki_01m_00001", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00210", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0043", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“...I don’t think you need to force yourself to like someone.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“⋯⋯我是觉得，不用强迫自己非得喜欢对方也没关系喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「⋯⋯我是覺得，不用強迫自己非得喜歡對方也沒關係喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00220",
		linknext = "0036_00222",
		line = 3007,
	},
	["0036_00222"] = {
		{"fg", file="mizuhiki_01m_00001", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00211", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0044", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“It’s hard to change how you see someone, after all... Once you feel a certain way about them, it’s pretty hard to change that, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“因为、人的认识是很难改变的⋯⋯一旦保持着某种想法，就很难去扭转，不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「因為、人的認識是很難改變的⋯⋯一旦保持著某種想法，就很難去扭轉，不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00221",
		linknext = "0036_00223",
		line = 3022,
	},
	["0036_00223"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00218", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hey, I know that the heart’s a difficult thing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我知道，人的心思很难懂。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我知道，人的心思很難懂。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00222",
		linknext = "0036_00224",
		line = 3034,
	},
	["0036_00224"] = {
		{"fg", file="mizuhiki_01m_00001", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00210", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0045", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Yeah. I mean... For example, weren’t those activists that came to the island earlier biased against it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“是啊，因为⋯⋯比方说，之前岛上的那些积极份子们，也对青蓝岛抱有偏见对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「是啊，因為⋯⋯比方說，之前島上的那些積極份子們，也對青藍島抱有偏見對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00223",
		linknext = "0036_00225",
		line = 3049,
	},
	["0036_00225"] = {
		{"fg", file="mizuhiki_01m_00001", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00207", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0046", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Do you really think that the day is going to come... when they’ll be able to understand perverted sex?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“总有一天，那些人也能理解变态做爱之类的⋯⋯橘君你有想过吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「總有一天，那些人也能理解變態做愛之類的⋯⋯橘君你有想過嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00224",
		linknext = "0036_00226",
		line = 3064,
	},
	["0036_00226"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00301", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...I don’t think so.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯我没有想过这种事呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯我沒有想過這種事呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00225",
		linknext = "0036_00227",
		line = 3076,
	},
	["0036_00227"] = {
		{"fg", file="mizuhiki_01m_00001", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00228", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0047", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“And maybe the opposite is true too... But the world is a big place. There are always going to be people you can’t see eye-to-eye with.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“反之亦然，但⋯⋯天地之大，总是有人格格不入。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「反之亦然，但⋯⋯天地之大，總是有人格格不入。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00226",
		linknext = "0036_00228",
		line = 3091,
	},
	["0036_00228"] = {
		{"fg", file="mizuhiki_01m_00001", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00229", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0048", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“If there’s no need to do that... why bother trying to change things?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“若是没有这些人⋯⋯这样不也很好吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「若是沒有這些人⋯⋯這樣不也很好嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00227",
		linknext = "0036_00229",
		line = 3106,
	},
	["0036_00229"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That would mean losing the opportunity to actually understand them, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但如果那样的话，就会失去正确理解对方的机会。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但如果那樣的話，就會失去正確理解對方的機會。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00228",
		linknext = "0036_00230",
		line = 3118,
	},
	["0036_00230"] = {
		{"fg", file="mizuhiki_01m_00001", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00220", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When I hear the words coming out of my mouth, I understand.",
					{"rt2"},
				},
			},
			cn = {
				{
					"听到我自己的话，我理解了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"聽到我自己的話，我理解了。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00229",
		linknext = "0036_00231",
		line = 3131,
	},
	["0036_00231"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I am biased against Sakimori’s feelings.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我对驻防老人保持的情感是有偏见的。",
					{"rt2"},
				},
			},
			tw = {
				{
