				{"vo", file="rin0173", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Oh my god, this is workplace bullying! Disgusting, what year do you think this is...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“哇喔，这不是职场霸凌吗⋯⋯就算是时代错误也很糟糕、太差劲了⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「哇喔，這不是職場霸凌嗎⋯⋯就算是時代錯誤也很糟糕、太差勁了⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00110",
		linknext = "0036_00112",
		line = 1587,
	},
	["0036_00112"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00214", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
