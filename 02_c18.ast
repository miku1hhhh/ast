				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『⋯⋯小子，進展如何？』",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00172",
		linknext = "0036_00174",
		line = 2428,
	},
	["0036_00174"] = {
		{"bgm", file="bgm07", vol=100},
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00210", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“They’re going well. I’ve already gone ahead and started using the new line.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“非常好。很新回路了很快就能用了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「非常好。很新迴路了很快就能用了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00173",
		linknext = "0036_00175",
		line = 2441,
	},
	["0036_00175"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I go around to the back of school, where nobody is, then get in contact with Sakimori.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我绕到校舍后面没人来的地方，联系了驻防老人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我繞到校舍後面沒人來的地方，聯繫了駐防老人。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00174",
		linknext = "0036_00176",
		line = 2451,
	},
	["0036_00176"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0037", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“What is it you need, then? Surely you didn’t contact me just to chat.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘那么，有什么事吗？你不会是为了聊天才联系我的吧？’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『那麽，有什麽事嗎？你不會是為了聊天才聯繫我的吧？』",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00175",
		linknext = "0036_00177",
		line = 2463,
	},
	["0036_00177"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Of course I didn’t. I want you to make me a program that can extract data from a specific piece of hardware. Software isn’t my specialty, unfortunately.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“当然。当然。我想请你帮我写个譨从特定的硬体中撷取数据的程式。因为我并不擅长写程式。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「當然。當然。我想請你幫我寫個譨從特定的硬體中擷取數據的程式。因為我並不擅長寫程式。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00176",
		linknext = "0036_00178",
		line = 2475,
	},
	["0036_00178"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0038", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Hmm. A bit of a hard task for an old man like me, but I’ll have one of our engineers create it. It shouldn’t take long.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘唔嗯，对老头子我来说是有点挑战、让老头子家的技术人员来做吧。这样的话就用不了那么多时间。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『唔嗯，對老頭子我來說是有點挑戰、讓老頭子家的技術人員來做吧。這樣的話就用不了那麼多時間。』",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00177",
		linknext = "0036_00179",
		line = 2487,
	},
	["0036_00179"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I need it by the end of classes today, and I want you to deliver it to SHO headquarters. The leaders of the FS should be there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“时限是今天放学前。我希望你们能送到SHO总部大楼去。FS的头领会在那里的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「時限是今天放學前。我希望你們能送到SHO總部大樓去。FS的頭領會在那裡的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00178",
		linknext = "0036_00180",
		line = 2499,
	},
	["0036_00180"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0039", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“It should get there in time if I send it express. All the more convenient if you need it at SHO headquarters, one of the island’s ports of entry.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘快马加鞭的话应该来得及。在有入岛审查所在SHO总部大楼的话也很方便。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『快馬加鞭的話應該來得及。在有入島審查所在SHO總部大樓的話也很方便。』",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00179",
		linknext = "0036_00181",
		line = 2511,
	},
	["0036_00181"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That takes care of my biggest concern.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这样一来，最麻烦的事就解决了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這樣一來，最麻煩的事就解決了。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00180",
		linknext = "0036_00182",
		line = 2521,
	},
	["0036_00182"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The deal went so well it almost feels anticlimactic.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这场交易顺利到几乎让人扫兴的地步。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這場交易順利到幾乎讓人掃興的地步。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00181",
		linknext = "0036_00183",
		line = 2531,
	},
	["0036_00183"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...What kind of information have you discovered about the Lewd Code?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯关于变态法，你那边有什么新情报吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯關於變態法，你那邊有什麼新情報嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00182",
		linknext = "0036_00184",
		line = 2543,
	},
	["0036_00184"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0040", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Nothing beyond what you can learn in the national papers. It should only be a matter of time now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘除了国家报纸上出现的内容外，别无其他。照这么下去过关只是时间的问题。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『除了國家報紙上出現的內容外，別無其他。照這麼下去過關只是時間的問題。』",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00183",
		linknext = "0036_00185",
		line = 2555,
	},
	["0036_00185"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Isn’t there anything you can do? You’re a big shot, aren’t you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你不也是高官吗？你就不做些什么吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你不也是高官嗎？你就不做些什麼嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00184",
		linknext = "0036_00186",
		line = 2567,
	},
	["0036_00186"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0041", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“Even I have my limits. That is just how much momentum the public has put behind it. Of course, there still is one way...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘即便是我，能力也是有限的。世界的浪潮就是这么大。不过还是有办法的──’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『即便是我，能力也是有限的。世界的浪潮就是這麼大。不過還是有辦法的──』",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00185",
		linknext = "0036_00187",
		line = 2579,
	},
	["0036_00187"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00305", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I’m never agreeing to anything that involves using Fumino.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我不许你利用文乃。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我不許你利用文乃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00186",
		linknext = "0036_00188",
		line = 2591,
	},
	["0036_00188"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I lay down the law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我警告他。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我警告他。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00187",
		linknext = "0036_00189",
		line = 2601,
	},
	["0036_00189"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Yes, the easiest way to take down Seiran Island as it is now would be to stir up a scandal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"想要毁掉青蓝岛的现状，最好的办法就是把丑闻拖出来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"想要毀掉青藍島的現狀，最好的辦法就是把醜聞拖出來。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00188",
		linknext = "0036_00190",
		line = 2611,
	},
	["0036_00190"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But that’s the one thing I won’t let happen.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，只有这个不行。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，只有這個不行。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00189",
		linknext = "0036_00191",
		line = 2621,
	},
	["0036_00191"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0042", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“I do not understand why you are so obsessed with my granddaughter. A single young girl is all it would take to change the world. Is that not but a small price to pay?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘我不懂为什么对你会对我孙女如此执着。要是这世界可以被区区一个小女孩改变，那岂不是太廉价了？’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『我不懂為什麼對你會對我孫女如此執著。要是這世界可以被區區一個小女孩改變，那豈不是太廉價了？』",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00190",
		linknext = "0036_00192",
		line = 2633,
	},
	["0036_00192"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Just try it. I’ll break into your mansion right now and give you a beating so bad that you’ll never wake up from it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你试试看。我现在马上就会杀进你的府邸，把你揍到再也醒不过来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你試試看。我現在馬上就會殺進你的府邸，把你揍到再也醒不過來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00191",
		linknext = "0036_00193",
		line = 2645,
	},
	["0036_00193"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...But at the end of the day, I still can’t bring myself to trust this old man.",
					{"rt2"},
				},
			},
			cn = {
				{
					"──果不其然，我现在还不能相信这个老人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"──果不其然，我現在還不能相信這個老人。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00192",
		linknext = "0036_00194",
		line = 2655,
	},
	["0036_00194"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0043", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
