		text = {
			vo = {
				{"vo", file="ikuko0957", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“What if it’s true? Maybe we should just give up and get along with everyone here? Aren’t you finding communal life fun, Darling?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“你心里是怎么想的？干脆就在这边跟大家快乐生活下去吧？像这样的生活很快乐不是吗？亲爱的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「你心裡是怎麼想的？乾脆就在這邊跟大家快樂生活下去吧？像這樣的生活很快樂不是嗎？親愛的。」",
					{"rt2"},
				},
			},
		},
