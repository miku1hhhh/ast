				},
			},
			cn = {
				{
					name = {"モブ女A", "FS女学生A"},
					"“这怎么、可能⋯⋯虽然桐香大人他们、真的说出了反对变态法之类的话，可是⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "FS女學生A"},
					"「這怎麼、可能⋯⋯雖然桐香大人他們、真的說出了反對變態法之類的話，可是⋯⋯」",
					{"rt2"},
				},
			},
		},
