	["0036_00582"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file3="jun_01f_00305", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What’s the meaning of this, Akino...?! A coup? Have your ambitions gotten the better of you?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你到底是在想什么，秋野！！居然做搞出政变什么的，你是不是被野心冲昏头了！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳到底是在想什麼，秋野！！居然做搞出政變什麼的，妳是不是被野心沖昏頭了！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00581",
		linknext = "0036_00583",
		line = 8373,
	},
	["0036_00583"] = {
		{"fg", file="mizuhiki_02m_00001", file1="mizuhiki_02m_00101", file2="mizuhiki_02m_00204", path=":fg/mizuhiki_02m/", id=15, lv=15, head="mizuhiki_02m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0069", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“It’s quite simple... This was my aim from the start. Everything was a part of this plan, even becoming the SHO special auditor.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“没有这回事喔⋯⋯我的目标从一开始就是这个。当SHO的特别监察官，也都是为了这个计划。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「沒有這回事喔⋯⋯我的目標從一開始就是這個。當SHO的特別監察官，也都是為了這個計劃。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00582",
		linknext = "0036_00584",
		line = 8388,
	},
	["0036_00584"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So then, the leader of the Birds of a Feather...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也就是说，‘Tori公’的首领是──”",
