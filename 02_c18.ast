				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不要做無謂的戰鬥降低我們的戰力！他們的目標就是將我們逐一擊破，跟他們保持距離、限制住他們的行動！」",
					{"rt2"},
				},
			},
		},
