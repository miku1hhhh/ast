					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don’t even joke about that—there’s only one option for me, and that’s getting back to the world I came from.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别乱开玩笑──对我而言选择只有回到原本的世界这一个。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別亂開玩笑──對我而言選擇只有回到原本的世界這一個。」",
					{"rt2"},
				},
			},
		},
