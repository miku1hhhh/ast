	["0036_00047"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00201", path=":fg/rei_02m/", id=9, lv=8, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-205, y=-5},
