	["0036_00114"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"fg", file="rin_01m_00001", file1="rin_01m_00102", file2="rin_01m_00228", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"fgact", ch="凛14", id=14, act="移動", x=200, y=0, time=200},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0174", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Could you please put that emergency ration of yours away?! It looks so disgusting!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“给我把那个紧急食物带走！！那张表情也太恶了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「給我把那個緊急食物帶走！！那張表情也太噁了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00113",
		linknext = "0036_00115",
		line = 1631,
	},
	["0036_00115"] = {
		{"fg", file="susuko_02m_00002", file1="susuko_02m_00101", file2="susuko_02m_00215", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0266", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“How could you slander my cute little Blowbo like that?! What if he dies from the severe shock and takes you with him?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“你怎么能对可爱的啾啪酱做出这种事来呢！要是它因为太过震所以在被凛酱带走的路上死掉了的话要怎么办！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「妳怎麼能對可愛的啾啪醬做出這種事來呢！要是牠因為太過震所以在被凜醬帶走的路上死掉了的話要怎麼辦！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00114",
		linknext = "0036_00116",
		line = 1646,
	},
	["0036_00116"] = {
		{"fg", file="rin_01m_00001", file1="rin_01m_00101", file2="rin_01m_00218", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0175", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Simple. If he does, I’ll make sure your next meager little meal has an extra dish of yakitori.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“这还不简单，真的死掉的话就帮丝丝子同学你那穷酸的餐食加一道烤鸡吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「這還不簡單，真的死掉的話就幫絲絲子同學你那窮酸的餐食加一道烤雞吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00115",
		linknext = "0036_00117",
		line = 1661,
	},
	["0036_00117"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"While they all looked like enemies alike to me from the outside...",
					{"rt2"},
				},
			},
			cn = {
				{
					"从外头来看，他们只是一群“敌人”而已。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從外頭來看，他們只是一群「敵人」而已。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00116",
		linknext = "0036_00118",
		line = 1671,
	},
	["0036_00118"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...It turns out they’re all such different people when I really get to know them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"掀开了那层表皮后，果然有所不同。",
					{"rt2"},
				},
			},
			tw = {
				{
					"掀開了那層表皮後，果然有所不同。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00117",
		linknext = "0036_00119",
		line = 1681,
	},
	["0036_00119"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00219", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“A lot of people have older sisters in the FS. Isn’t that the case for Touka too?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“FS里有姐姐的人很多耶，我记得桐香应该也是吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「FS裡有姐姐的人很多耶，我記得桐香應該也是吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00118",
		linknext = "0036_00120",
		line = 1693,
	},
	["0036_00120"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00214", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0176", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Tadasugawa has a younger brother and sister, though. And I have a younger sister myself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“不过糺川前辈有弟弟妹妹喔，我也有一个妹妹。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「不過糺川前輩有弟弟妹妹喔，我也有一個妹妹。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00119",
		linknext = "0036_00121",
		line = 1708,
	},
	["0036_00121"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00207", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You too? Same as me, then.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你也有妹妹吗？跟我一样呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你也有妹妹嗎？跟我一樣呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00120",
		linknext = "0036_00122",
		line = 1720,
	},
	["0036_00122"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00202", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0177", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“I look after her quite often due to the gap in age between us, but she’s just so spoiled.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“因为差了几岁，所以我时常照顾她，不过她相当任性呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「因為差了幾歲，所以我時常照顧她，不過她相當任性呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00121",
		linknext = "0036_00123",
		line = 1735,
	},
	["0036_00123"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I know what you mean. I bet she begs you to have threesomes with preppy girls, doesn’t she?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊啊、果然是被要求跟辣妹3P对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊啊、果然是被要求跟辣妹3P對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00122",
		linknext = "0036_00124",
		line = 1747,
	},
	["0036_00124"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00209", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"fg", file="susuko_02m_00002", file1="susuko_02m_00102", file2="susuko_02m_00205", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0267", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“He says such strange things with such a straight face.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“理所当然似的说出了奇怪的话欸。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「理所當然似的說出了奇怪的話欸。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00123",
		linknext = "0036_00125",
		line = 1764,
	},
	["0036_00125"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00222", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yep, that’s just how little sisters are! They just won’t stop begging you for preppy threesomes!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我真的被妹妹卢小过要跟辣妹3P好吗！！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我真的被妹妹盧小過要跟辣妹3P好嗎！！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00124",
		linknext = "0036_00126",
		line = 1776,
	},
	["0036_00126"] = {
		{"fg", file="susuko_02m_00002", file1="susuko_02m_00101", file2="susuko_02m_00215", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0268", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Stop slandering little sisters.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“不要再让妹妹们风评被害了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「不要再讓妹妹們風評被害了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00125",
		linknext = "0036_00127",
		line = 1791,
	},
	["0036_00127"] = {
		{"fg", file="rin_01m_00001", file1="rin_01m_00101", file2="rin_01m_00212", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"fgact", ch="凛14", id=14, act="移動", x=-200, y=0, time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0176", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Oh, it really is true that this place is full of poor urchins. The pedigreed Hanamaru family has lived on this island for decades and my parents are fine and well. I don’t understand your struggles.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“哎呀呀、贫穷人家的孩子还真的是很多呢。我们花丸家可是在青蓝岛上扎根数十年的正统名门，何况双亲也都健在，实在是无法理解你们大家的艰辛呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「哎呀呀、貧窮人家的孩子還真的是很多呢。我們花丸家可是在青藍島上扎根數十年的正統名門，何況雙親也都健在，實在是無法理解你們大家的艱辛呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00126",
		linknext = "0036_00128",
		line = 1806,
	},
	["0036_00128"] = {
		{"fg", file="susuko_02m_00002", file1="susuko_02m_00101", file2="susuko_02m_00202", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="スス子11", id=11, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0269", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Hey, ’Bana. That omelet seems tasty. Here, let me check it for poison.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“啊、橘同学的煎蛋看起来很好吃耶。我来帮你吃吃看有没有毒。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「啊、橘同學的玉子燒看起來很好吃耶。我來幫你吃吃看有沒有毒。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00127",
		linknext = "0036_00129",
		line = 1822,
	},
	["0036_00129"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hold on! Regardless of rank, I won’t forgive anyone who puts their hands on my omelet!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“喂喂喂不要觊觎我的煎蛋喔！就算你是后辈我也不会原谅你的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「喂喂喂不要覬覦我的玉子燒喔！就算妳是後輩我也不會原諒你的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00128",
		linknext = "0036_00130",
		line = 1834,
	},
	["0036_00130"] = {
		{"fg", file="schubert_01m_00002", file2="schubert_01m_00202", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0178", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Haha! Indeed, His Sexellency is like an entirely different person when it comes to his omelet!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“哈哈、一牵涉到煎蛋性帝整个人都变了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「哈哈、一牽涉到玉子燒性帝整個人都變了呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00129",
		linknext = "0036_00131",
		line = 1849,
	},
	["0036_00131"] = {
		{"fg", file="rin_01m_00001", file1="rin_01m_00101", file2="rin_01m_00215", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0177", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Oh sure so that’s how you ignore me no argument at all so I guess that means I win I crushed you another victory that’s all from me since I’m focusing on my meal now goodbye.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“啊──好吧好吧像你们这种无视我的方式不就反证了是我赢了吗。好喔完全胜利今天也是我赢了呢，我可是要集中心神去吃饭了所以后面就不回你们了喔再会吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「啊──好吧好吧像你們這種無視我的方式不就反證了是我贏了嗎。好喔完全勝利今天也是我贏了呢，我可是要集中心神去吃飯了所以後面就不回你們了喔再會吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00130",
		linknext = "0036_00132",
		line = 1864,
	},
	["0036_00132"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00214", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
