			},
		},
		text = {
			vo = {
				{"vo", file="hinami0071", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Nope! I started hiding partway through, just like I was told! Then the FS put me under their protection and took me away, saying it was too dangerous for little girls...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“嗯！，我跟他们说的一样，半路就躲起来了！然后FS说‘这对小孩子很危我们别边吧’，我就被他们带去保护了⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「嗯！，我跟他們說的一樣，半路就躲起來了！然後FS說『這對小孩子很危我們別邊吧』，我就被他們帶去保護了⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00717",
		linknext = "0036_00719",
		line = 11037,
	},
