					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "???"},
					"“...As you’ve seen, an informant has let us know that the FS, an organization subordinate to the SHO consisting of Minotsuki Academy students, has long been opposed to the Lewd Code.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引", "？？？"},
					"‘⋯⋯如各位所见，由水乃月学院的学生所构成的SHO附属组织FS，许久之前就被通报他们反对‘变态法’。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引", "？？？"},
					"『⋯⋯如各位所見，由水乃月學院的學生所構成的SHO附屬組織FS，許久之前就被通報他們反對『變態法』。』",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00450",
		linknext = "0036_00452",
		line = 6307,
	},
	["0036_00452"] = {
