		{"fgact", ch="美岬6", id=6, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0080", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Yes, but they got away... What about you, are you hurt?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“是啊、我们错过了⋯⋯不过那边的人怎么样了、有受伤吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「是啊、我們錯過了⋯⋯不過那邊的人怎麼樣了、有受傷嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00716",
		linknext = "0036_00718",
		line = 11020,
	},
	["0036_00718"] = {
