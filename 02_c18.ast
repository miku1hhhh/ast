			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Yes, it’s me. Mizuhiki Akino, the leader of the so-called Anti-Copulation Front... The one to destroy all your hopes and dreams.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“没错，就是我。我秋野水引就是‘反交尾势力’的首领──破坏你们梦想的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「沒錯，就是我。我秋野水引就是『反交尾勢力』的首領──破壞你們夢想的人。」",
					{"rt2"},
				},
			},
		},
