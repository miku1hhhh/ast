					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“That’s right, after all that work to be freed from perversion... I’m not letting it run my life again. So how’s your preparation going, Junnosuke?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“对啊，好不容易才从中解放的说。我可不想再被变态法给继续左右⋯⋯对了淳之介。你准备得如何？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「對啊，好不容易才從中解放的說。我可不想再被變態法給繼續左右⋯⋯對了淳之介。你準備得如何？」",
					{"rt2"},
				},
			},
