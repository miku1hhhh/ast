					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“In my world, I’m your leader. We kept fighting together, and you get seriously injured, but we still win in the very end!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在我的世界里，我是你们的队长，我们一起并肩作战、虽然说你后面会身受重伤、不过最后我们还是获得了胜利！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在我的世界裡，我是你們的隊長，我們一起並肩作戰、雖然說妳後面會身受重傷、不過最後我們還是獲得了勝利！」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00307",
		linknext = "0036_00309",
		line = 4087,
	},
