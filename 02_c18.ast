	["0036_00205"] = {
		{"fg", file="mizuhiki_01m_00001", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00229", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0039", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“What are you doing here...? Were you calling someone...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“怎么了，你怎么会在这种地方⋯⋯？打电话吗⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「怎麼了，你怎麼會在這種地方⋯⋯？打電話嗎⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00204",
		linknext = "0036_00206",
		line = 2805,
	},
	["0036_00206"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It seems like she just arrived. She didn’t hear what I was saying.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她似乎现在才出现。我刚才的对话没有被听到吧──",
					{"rt2"},
				},
			},
			tw = {
				{
					"她似乎現在才出現。我剛才的對話沒有被聽到吧──",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00205",
		linknext = "0036_00207",
		line = 2815,
	},
	["0036_00207"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00218", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I was eating with everyone until just a second ago... Someone I know contacted me, that’s all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“刚刚我还在跟大家一起吃饭⋯⋯只是刚好、有个熟人来找我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「剛剛我還在跟大家一起吃飯⋯⋯只是剛好、有個熟人來找我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00206",
		linknext = "0036_00208",
		line = 2827,
	},
	["0036_00208"] = {
		{"fg", file="mizuhiki_01m_00001", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00211", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[4000] = {
				{"fg", file="mizuhiki_01m_00001", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00207", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, timestamp=32, delay2=4000, mode=3, x=-5, y=-5},
			},
			[3999] = {
				{"transitiontime", time=300, timestamp=32, delay2=4000},
			},
		},
		text = {
			vo = {
				{"vo", file="mizuhiki0040", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Heh... You really do get along with Susuko and the others so well. I guess boys really do like cheerful girls like that, huh...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“嘻嘻⋯⋯你跟丝丝子感情很好呢。橘同学。果然男孩子们，还是喜欢像她那样开朗的女生对吧⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「嘻嘻⋯⋯你跟絲絲子感情很好呢。橘同學。果然男孩子們，還是喜歡像她那樣開朗的女生對吧⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00207",
		linknext = "0036_00209",
		line = 2845,
	},
	["0036_00209"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00309", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don’t know if I could generalize, but I don’t dislike them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“大家普遍是怎么想的我不清楚，不过我不讨厌她就是了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「大家普遍是怎麼想的我不清楚，不過我不討厭她就是了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00208",
		linknext = "0036_00210",
		line = 2857,
	},
	["0036_00210"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...Me, an anti-copulator, liking the FS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"⋯⋯身为反交尾势力的我，喜欢FS什么的。",
