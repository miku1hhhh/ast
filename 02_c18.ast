			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“而且以前不管在干什么大肉棒都会不管不顾地插进来，真的是连一点放松小穴的时间都没有呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「而且以前不管在幹什麼大肉棒都會不管不顧地插進來，真的是連一點放鬆小穴的時間都沒有呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00156",
