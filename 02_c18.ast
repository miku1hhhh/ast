	["0036_00721"] = {
		{"fg", file="mizuhiki_02m_00001", file1="mizuhiki_02m_00101", file2="mizuhiki_02m_00226", path=":fg/mizuhiki_02m/", id=15, lv=15, head="mizuhiki_02m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=595, y=-5},
