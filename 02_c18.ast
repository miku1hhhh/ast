			tw = {
				{
					"而是不熟悉的人聲。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00453",
		linknext = "0036_00455",
		line = 6347,
	},
	["0036_00455"] = {
		{"bg", id=19, file="kcg06_l0101", x=-350, y=-121.5, path=":cg/kcg06_l/", lv=19, ev=1, bx=800, by=450},
		{"transitiontime", time=1000},
		{"cgact", file="cgact", id=19, act="移動", x=0, y=-600.5, time=20000, lv=19},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Well, no. Not exactly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不，这么说并不正确。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不，這麼說並不正確。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00454",
		linknext = "0036_00456",
		line = 6360,
	},
	["0036_00456"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0053", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "???"},
					"“While you are free to have your own personal opinions, you cannot be allowed to bring them into an organization under a public service corporation.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引", "？？？"},
					"‘我们尊重个人思想的自由──不过身为一个公益社团法人的附属组织，这样的行为是不被允许的。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引", "？？？"},
					"『我們尊重個人思想的自由──不過身為一個公益社團法人的附屬組織，這樣的行為是不被允許的。』",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00455",
		linknext = "0036_00457",
		line = 6372,
	},
	["0036_00457"] = {
		{"cgact", file="cgact", act="表示アクション", alpha=0, id=19, lv=19, time=1000, alphadel=1, style="reset", x=0, y=-600.5},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s a strange voice, but one coming from someone I know.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是由认识的人所发出的，并不那么惯常所听到的声线。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那是由認識的人所發出的，並不那麼慣常所聽到的聲線。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00456",
		linknext = "0036_00458",
		line = 6384,
	},
	["0036_00458"] = {
		{"bg", id=19, file="kcg06_l0101", x=-350, y=-121.5, path=":cg/kcg06_l/", lv=19, ev=1, bx=800, by=450},
		{"transitiontime", time=1000},
		{"cgact", file="cgact", id=19, act="移動", x=-700, y=-0.5, time=30000, lv=19},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0054", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "???"},
					"“It is unforgivable to make such opinions those of the organization.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引", "？？？"},
					"‘更别说把它当作组织的观点，这种事是不能被容许的。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引", "？？？"},
					"『更別說把它當作組織的觀點，這種事是不能被容許的。』",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00457",
		linknext = "0036_00459",
		line = 6399,
	},
	["0036_00459"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s not the timid, unsure voice that I’m always used to.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一改往日胆怯、低落的语气。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一改往日膽怯、低落的語氣。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00458",
		linknext = "0036_00460",
		line = 6409,
	},
	["0036_00460"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s a stately voice, one I can even hear smirking at times.",
					{"rt2"},
				},
			},
			cn = {
				{
					"落落大方、伴随着笑意的声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"落落大方、伴隨著笑意的聲音。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00459",
		linknext = "0036_00461",
		line = 6419,
	},
	["0036_00461"] = {
		{"cgdel", id=19, lv=19, time=0, alphadel=1, evmaskoff=1},
		{"evset", file="kcg06", set="kcg06", path=":ev/kcg06/"},
		{"evset", file="kcg060101", set="kcg060101", path=":ev/kcg060101/"},
		{"bg", id=18, file="kcg060101", x=0, y=0, path=":cg/kcg06/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=3000},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0055", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“This can only be described as the intentional misappropriation of the FS, an organization built upon all of your ideals.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“这不过是想把FS这个集合了众人意志形成的组织，化为自己的所有物。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「這不過是想把FS這個集合了眾人意志形成的組織，化為自己的所有物。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00460",
		linknext = "0036_00462",
		line = 6438,
	},
	["0036_00462"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...Mizuhiki Akino’s voice.",
					{"rt2"},
				},
			},
			cn = {
				{
					"──那个声音是，秋野水引。",
					{"rt2"},
				},
			},
			tw = {
				{
					"──那個聲音是，秋野水引。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00461",
		linknext = "0036_00463",
		line = 6448,
	},
	["0036_00463"] = {
		{"cgdel", id=19, time=0, alphadel=1, lv=5},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0056", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Please view this footage, taken by a security camera today at SHO headquarters. The FS Big Three infiltrated an off-limits control room.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“请看这段视频。这是今天发生在SHO总部大楼的监视画面。FS的三巨头，入侵了禁制进入的控制室。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「請看這段影片。這是今天發生在SHO總部大樓的監視畫面。FS的三巨頭，入侵了禁制進入的控制室。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00462",
		linknext = "0036_00464",
		line = 6462,
	},
	["0036_00464"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0057", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“The data kept here is individual data on all of you living on this island. In other words, we believe they infiltrated this room to extract your personal information.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“这里存储的是岛上每个人的个人资讯。换句话说，他们被认定是为了获取个人资讯而潜入的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「這裡存儲的是島上每個人的個人資訊。換句話說，他們被認定是為了獲取個人資訊而潛入的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00463",
		linknext = "0036_00465",
		line = 6474,
	},
	["0036_00465"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She exaggerates in order to incite a feeling of danger.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这是为了煽动危机感的夸大表现。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這是為了煽動危機感的誇大表現。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00464",
		linknext = "0036_00466",
		line = 6484,
	},
	["0036_00466"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0058", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“So then, why would they take this personal information? In order to have data on all of you, the supporters of the Lewd Code, that’s why.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“为什么她们要获取个人的资讯呢？肯定是为了要获得那些支持变态法的人的资料。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「為什麼她們要獲取個人的資訊呢？肯定是為了要獲得那些支持變態法的人的資料。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00465",
		linknext = "0036_00467",
		line = 6496,
	},
	["0036_00467"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She drives that danger home in order to implant within them a sense of personal involvement.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了让当事人萌生具体的危机感而做的煽动行为。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了讓當事人萌生具體的危機感而做的煽動行為。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00466",
		linknext = "0036_00468",
		line = 6506,
	},
	["0036_00468"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She’s good. She’s real good.",
					{"rt2"},
				},
			},
			cn = {
				{
					"厉害，真的是非常厉害的手段。",
					{"rt2"},
				},
			},
			tw = {
				{
					"厲害，真的是非常厲害的手段。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00467",
		linknext = "0036_00469",
		line = 6516,
	},
	["0036_00469"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0059", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“That’s right. The FS has been plotting to crush the Lewd Code all while under the protection of it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“没错。尽管FS受到了变态法的庇护，他们仍在谋划着摧毁变态法的计划──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「沒錯。儘管FS受到了變態法的庇護，他們仍在謀劃著摧毀變態法的計畫──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00468",
		linknext = "0036_00470",
		line = 6528,
	},
	["0036_00470"] = {
