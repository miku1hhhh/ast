	},
	["0036_00211"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If you went back a few months, I bet I would have never imagined I’d be saying these words.",
					{"rt2"},
				},
			},
			cn = {
				{
					"要是几个月的我，根本连想都不会想到我居然会说出这种话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要是幾個月的我，根本連想都不會想到我居然會說出這種話。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00210",
		linknext = "0036_00212",
		line = 2877,
	},
	["0036_00212"] = {
