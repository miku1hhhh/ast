	["0036_00089"] = {
		{"fg", file="susuko_02m_00002", file1="susuko_02m_00101", file2="susuko_02m_00213", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[1000] = {
				{"fg", file="susuko_02m_00002", file1="susuko_02m_00101", file2="susuko_02m_00218", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, timestamp=24, delay2=1000, mode=3, x=-405, y=-5},
				{"fgact", ch="スス子11", id=11, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine", timestamp=24, delay2=1000},
			},
			[999] = {
				{"transitiontime", time=300, timestamp=24, delay2=1000},
			},
		},
		text = {
			vo = {
				{"vo", file="susuko0260", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“S’right. Thanks to a piece of tras... my dad, our family’s seriously slumming it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“是啊。因为那个人渣、⋯⋯我爸的关系，我们家真的他妈的穷到不可思议。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「是啊。因為那個人渣、⋯⋯我爸的關係，我們家真的他媽的窮到不可思議。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00088",
		linknext = "0036_00090",
		line = 1276,
	},
	["0036_00090"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00214", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Did you just call him a piece of trash?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你刚刚是说了人渣吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳剛剛是說了人渣嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00089",
		linknext = "0036_00091",
		line = 1288,
	},
	["0036_00091"] = {
		{"fg", file="susuko_02m_00002", file1="susuko_02m_00101", file2="susuko_02m_00206", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0261", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“My pops is such a loser, a total slacker... and my mom got so sick and tired of him that she slipped away and left me and my sister behind...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“我爸是个完全不工作的死废柴⋯⋯妈妈受不了就丢下我跟我姐跑了⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「我爸是個完全不工作的死廢柴⋯⋯媽媽受不了就丟下我跟我姐跑了⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00090",
		linknext = "0036_00092",
		line = 1303,
	},
	["0036_00092"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00213", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wow, that’s pretty heavy...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“相当惊人呢⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「相當驚人呢⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00091",
		linknext = "0036_00093",
		line = 1315,
	},
	["0036_00093"] = {
		{"fg", file="susuko_02m_00002", file1="susuko_02m_00101", file2="susuko_02m_00211", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0262", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Sure... Seeing that makes me think of marriage not as a happy stopping point in life but as a split in the road that takes you either to heaven or hell...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“嗯⋯⋯这么看来，结婚未必会是幸福的终点，而是区分天国与地狱的叉路吧⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「嗯⋯⋯這麼看來，結婚未必會是幸福的終點，而是區分天國與地獄的叉路吧⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00092",
		linknext = "0036_00094",
		line = 1330,
	},
	["0036_00094"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00213", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
