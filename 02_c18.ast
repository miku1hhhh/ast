				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“While there were a few slight surprises, things mostly went as planned...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“事情有点超出了计算，但大部分都按计划进行──”",
