	["0036_00593"] = {
		{"fg", file="mizuhiki_02m_00001", file1="mizuhiki_02m_00101", file2="mizuhiki_02m_00206", path=":fg/mizuhiki_02m/", id=15, lv=15, head="mizuhiki_02m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0072", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“I’m not so refined that I’d pick and choose my methods. My love and my hate are like a vulgar, blazing hellfire...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“我不够高尚到可以选择手段。因为我的仇恨就与庸俗的地狱火一样⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
