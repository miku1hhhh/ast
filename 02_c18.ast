		{"fg", file="nanase_02m_00001", file1="nanase_02m_00102", file2="nanase_02m_00204", path=":fg/nanase_02m/", id=4, lv=4, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-205, y=-5},
