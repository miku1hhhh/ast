				},
			},
			cn = {
				{
					name = {"礼"},
					"“不止我们一个人，SHO特殊站都部也一起来了！从现在开始，用鹤翼阵想办法将他们全部扫射出去，然后四个人一起逮捕他们！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不止我們一個人，SHO特殊站都部也一起來了！從現在開始，用鶴翼陣想辦法將他們全部掃射出去，然後四個人一起逮捕他們！」",
					{"rt2"},
				},
			},
		},
