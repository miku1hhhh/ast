					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“The Birds of a Feather have shown up! In the mountains behind school, size unknown. Second squad engaged them but they’re fully neutralized! We’re in serious shit!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"‘‘Tori公’出现了！在学校后山，数量不明，二队正在跟他们交战但被对方无力化了！现在情况很危急！！！’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"『『Tori公』出現了！在學校後山，數量不明，二隊正在跟他們交戰但被對方無力化了！現在情況很危急！！！』",
					{"rt2"},
				},
			},
		},
