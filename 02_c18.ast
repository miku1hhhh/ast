		text = {
			vo = {
				{"vo", file="rei0897", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“‘Lewd Code Looms Large,’ huh... I know the Perverted Times is a pro-SHO paper, but how far along do you think it really is, Miss Touka?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“‘变态法即将颁布’吗？⋯⋯变态新闻是支持SHO的，但你觉得实际上他们进展到了哪个程度呢？桐香大人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「『變態法即將頒布』嗎？⋯⋯變態新聞是支持SHO的，但妳覺得實際上他們進展到了哪個程度呢？桐香大人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00046",
		linknext = "0036_00048",
		line = 633,
	},
	["0036_00048"] = {
