					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“...Miss Katagiri. Could you please praise her for me? This broadcast was all thanks to her, and she seems to be happiest when you’re the one complimenting her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“……片桐同学。这次播放也是她的功劳，能不能夸奖一下？被片桐同学夸的话，她应该会非常高兴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「……片桐同學。這次播放也是她的功勞，能不能誇獎一下？被片桐同學誇的話，她應該會非常高興。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00720",
		linknext = "0036_00722",
		line = 11085,
	},
