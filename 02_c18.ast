	["0036_00106"] = {
		{"fgact", ch="シューベルト12", id=12, act="移動", x=200, y=0, time=800},
		{"fgact", ch="スス子11", id=11, act="移動", x=-200, y=0, time=800},
		{"fg", file="rin_01m_00001", file1="rin_01m_00101", file2="rin_01m_00211", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", alpha=0, ch_origin="凛", ch="凛14", mw="mw", sync=1, a_chr151=1, mode=3, x=195, y=-5},
		{"fgact", ch="凛14", id=14, lv=14, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="凛14", id=14, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0170", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“I’m here for the advancement opportunities, of course! Success in the FS means a guaranteed SHO position! It’s why I’ve settled for being a miserly grunt! Also, divine revelation!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“我当然是为了出人头地才加入的啊！如果在FS有好的成绩就能保送SHO。我就是因为这样才甘愿当个一般兵受苦的。当然还有神命的指示嘛！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「我當然是為了出人頭地才加入的啊！如果在FS有好的成績就能保送SHO。我就是因為這樣才甘願當個一般兵受苦的。當然還有神命的指示嘛！」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00105",
		linknext = "0036_00107",
		line = 1505,
	},
	["0036_00107"] = {
		{"fg", file="susuko_02m_00002", file1="susuko_02m_00101", file2="susuko_02m_00213", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0265", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Oh, Rin... So you were here... Huh, that so. Well, do your best...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“啊、凛酱⋯⋯原来你在啊⋯⋯哇啊原来是这样啊⋯⋯那你加油喔⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「啊、凜醬⋯⋯原來妳在啊⋯⋯哇啊原來是這樣啊⋯⋯那妳加油喔⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00106",
		linknext = "0036_00108",
		line = 1520,
	},
	["0036_00108"] = {
		{"fg", file="rin_01m_00001", file1="rin_01m_00101", file2="rin_01m_00204", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[2000] = {
				{"fg", file="rin_01m_00001", file1="rin_01m_00101", file2="rin_01m_00203", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, timestamp=27, delay2=2000, mode=3, x=-5, y=-5},
				{"fgact", ch="凛14", id=14, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine", timestamp=27, delay2=2000},
			},
			[1999] = {
				{"transitiontime", time=300, timestamp=27, delay2=2000},
			},
			[5000] = {
				{"fg", file="rin_01m_00001", file1="rin_01m_00101", file2="rin_01m_00226", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, timestamp=28, delay2=5000, mode=3, x=-5, y=-5},
			},
			[4999] = {
				{"transitiontime", time=300, timestamp=28, delay2=5000},
			},
		},
		text = {
			vo = {
				{"vo", file="rin0171", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“What’s that attitude about? Oh, you must have a grudge against me for snitching. Ugh, the unwashed masses are so quick to do this. I was merely doing my job.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“你那是什么态度啊。啊啊──你还在记恨我告发的事是吗？真是讨厌呢下等人就是这样。我不过是尽了我的职责而已喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「妳那是什麼態度啊。啊啊──妳還在記恨我告發的事是嗎？真是討厭呢下等人就是這樣。我不過是盡了我的職責而已喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00107",
		linknext = "0036_00109",
		line = 1542,
	},
	["0036_00109"] = {
		{"fg", file="rin_01m_00001", file1="rin_01m_00101", file2="rin_01m_00220", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0172", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“It is a soldier’s job to faithfully carry out their orders. An officer’s command is absolute. What else should I have done?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“军人的工作就是要确实、忠诚地服从命令。要对上级的命令绝对服从所以也没办法嘛！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「軍人的工作就是要確實、忠誠地服從命令。要對上級的命令絕對服從所以也沒辦法嘛！」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00108",
		linknext = "0036_00110",
		line = 1557,
	},
	["0036_00110"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00203", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0175", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“In that case, your orders are to shut your mouth.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“那么我以上级的身份命你，闭嘴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「那麼我以上級的身份命你，閉嘴。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00109",
		linknext = "0036_00111",
		line = 1572,
	},
	["0036_00111"] = {
		{"fg", file="rin_01m_00001", file1="rin_01m_00101", file3="rin_01m_00305", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
