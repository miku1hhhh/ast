		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0060", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“FS Representative Touka Reizeiin. Disciplinary Committee President Rei Tadasugawa. First Squad Commander Ikuko Onabuta—these three women have corrupted the FS.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“FS的代表，冷泉院桐香。风纪委员长，糺川礼。第一队队长，女部田郁子──FS已经被她们腐蚀了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「FS的代表，冷泉院桐香。風紀委員長，糺川禮。第一隊隊長，女部田郁子──FS已經被她們腐蝕了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00476",
		linknext = "0036_00478",
		line = 6640,
	},
	["0036_00478"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Akino charges on, continuing to disparage us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"秋野继续堂而皇之地发表诋毁我们的言论。",
					{"rt2"},
				},
			},
			tw = {
				{
					"秋野繼續堂而皇之地發表詆毀我們的言論。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00477",
