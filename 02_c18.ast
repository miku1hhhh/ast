		text = {
			vo = {
				{"vo", file="misaki0087", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Hey, everyone! Are we all good?! Sounded like a real loud scuffle out there, is everyone all right?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“大家～你们没事吧？！发出了很大的声响乒乒乓乓的，你们还好吗──！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「大家～你們沒事吧？！發出了很大的聲響乒乒乓乓的，你們還好嗎──！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00715",
		linknext = "0036_00717",
		line = 11001,
	},
	["0036_00717"] = {
