		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0088", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“...I never imagined that a propeller made with d10o could break... It seems like there’s room for improvement.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“──没想到用‘d10o’制造的螺旋桨都会坏掉⋯⋯看来、还有改进的余地⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「──沒想到用『d10o』製造的螺旋槳都會壞掉⋯⋯看來、還有改進的餘地⋯⋯」",
					{"rt2"},
				},
			},
		},
