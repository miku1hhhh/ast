					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“By the way, I’m on team has a big sister. It must be an honor to share that with me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“顺带一提，我也是有姐姐的那一派。跟我一样很光荣吧？”",
