		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00202", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0272", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Sure is so! Up to the other day you always stayed silent, and if you did speak, it was just a ‘sure’ or a ‘mhm’ and stuff!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“是这样唷，橘同学以前很沉默寡言喔，不管说什么都只会回‘啊啊’或‘唔嗯’之类的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「是這樣唷，橘同學以前很沈默寡言喔，不管說什麼都只會回『啊啊』或『唔嗯』之類的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00152",
		linknext = "0036_00154",
		line = 2165,
	},
	["0036_00154"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I was that quiet in this world...?",
					{"rt2"},
				},
			},
			cn = {
				{
					"这边的我，原来这么沉默是金的吗⋯⋯。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這邊的我，原來這麼沈默是金的嗎⋯⋯。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00153",
		linknext = "0036_00155",
		line = 2175,
	},
	["0036_00155"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I tend to enjoy talking, though.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但我很喜欢说话就是了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但我很喜歡說話就是了。",
					{"rt2"},
