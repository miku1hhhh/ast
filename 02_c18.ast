					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What is she, queen of the flamewars?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她当自己是口水战冠军吗？”",
