					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Wow, that’s deep...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“还真深奥⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「還真深奧⋯⋯」",
