	["0036_00095"] = {
		{"fg", file="susuko_02m_00002", file1="susuko_02m_00101", file2="susuko_02m_00208", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0263", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“I gotta support him...! If Susu doesn’t sustain that super-sized scum, he’s gonna end up dead...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“要是我不养他⋯⋯！要是丝丝不养他的话，那个大型垃圾会这样死掉的⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「要是我不養他⋯⋯！要是絲絲不養他的話，那個大型垃圾會這樣死掉的⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00094",
		linknext = "0036_00096",
		line = 1357,
	},
	["0036_00096"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00214", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hey, I’m really sorry for bringing this up...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我真的很抱歉提歉这件事⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我真的很抱歉提歉這件事⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00095",
		linknext = "0036_00097",
		line = 1369,
	},
	["0036_00097"] = {
		{"fg", file="susuko_02m_00002", file1="susuko_02m_00102", file2="susuko_02m_00215", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[3000] = {
				{"fg", file="susuko_02m_00002", file1="susuko_02m_00102", file2="susuko_02m_00218", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, timestamp=25, delay2=3000, mode=3, x=-405, y=-5},
			},
			[2999] = {
				{"transitiontime", time=300, timestamp=25, delay2=3000},
			},
			[6000] = {
				{"fg", file="susuko_02m_00002", file1="susuko_02m_00101", file2="susuko_02m_00208", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, timestamp=26, delay2=6000, mode=3, x=-405, y=-5},
				{"fgact", ch="スス子11", id=11, act="浮遊横", loop=20, size=5, time=50, ease="easeinout_sine", timestamp=26, delay2=6000},
			},
			[5999] = {
				{"transitiontime", time=300, timestamp=26, delay2=6000},
			},
		},
		text = {
			vo = {
				{"vo", file="susuko0264", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“It’d be nice if he succumbed in a way that’d pay out insurance money...! Oh but I love my daddy, I’d be so sad if he died...! Sniffle, what sorrow...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“我希望他至少是用领得到保险金的方式死掉⋯⋯！但是我最喜欢爸爸了要是他死掉我会很难过的⋯⋯！唔唔呜，头好痛！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「我希望他至少是用領得到保險金的方式死掉⋯⋯！但是我最喜歡爸爸了要是他死掉我會很難過的⋯⋯！唔唔嗚，頭好痛！」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00096",
		linknext = "0036_00098",
		line = 1391,
	},
	["0036_00098"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She has her head in her hands, and her eyes are so bloodshot that I’m afraid she might start hyperventilating.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她抱着头，仿佛快要过度呼吸一样目呲欲裂。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她抱著頭，彷彿快要過度呼吸一樣目呲欲裂。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00097",
		linknext = "0036_00099",
		line = 1401,
	},
	["0036_00099"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It makes me wonder what her older sister is doing... But I think I’ll hold off on that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我有点想知道她姐姐怎么了⋯⋯不过还是算了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我有點想知道她姐姐怎麼了⋯⋯不過還是算了。",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00098",
		linknext = "0036_00100",
		line = 1411,
	},
	["0036_00100"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00219", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I guess the same goes for you, Schubert?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你也是一样的理由吗？舒伯特。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你也是一樣的理由嗎？舒伯特。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00099",
		linknext = "0036_00101",
		line = 1423,
	},
	["0036_00101"] = {
		{"fg", file="schubert_01m_00002", file2="schubert_01m_00205", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0172", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Well, I suppose so. My parents are also in debt after a failed business venture, so we’re by no means wealthy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“嗯、对啊⋯⋯。我家也是因为父母的事业失败所以有欠债，不怎么宽裕。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「嗯、對啊⋯⋯。我家也是因為父母的事業失敗所以有欠債，不怎麼寬裕。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00100",
		linknext = "0036_00102",
		line = 1438,
	},
	["0036_00102"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00211", file4="schubert_01m_00402", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0173", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“That said, my actions are guided by data, not money! I’ve always been the type who’s drawn to the unknown.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“不过比起钱、数据资料才是我的行动准则喔！我从以前就总是会被未知的事物吸引呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「不過比起錢、數據資料才是我的行動準則喔！我從以前就總是會被未知的事物吸引呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00101",
		linknext = "0036_00103",
		line = 1453,
	},
	["0036_00103"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00202", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0174", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Being in the FS—or rather, being with you allows me to witness yet-unknown human potential. That’s what I find fun, and it’s what’s more important than anything to me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“加入FS──更准确一点说是跟随你的话，就能发掘出更多不知的人们的可能性。这点对我来说非常有趣，这才是最重要的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「加入FS──更準確一點說是跟隨你的話，就能發掘出更多不知的人們的可能性。這點對我來說非常有趣，這才是最重要的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0036_00102",
		linknext = "0036_00104",
		line = 1468,
	},
	["0036_00104"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Schubert’s eyes gleam as he says this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"舒伯特眼里闪烁着金光，如此说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"舒伯特眼裡閃爍著金光，如此說道。",
					{"rt2"},
