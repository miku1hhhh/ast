		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0179", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Cheer up, Susuko...! Having a big sister doesn’t mean you’re doomed to turn out like Rin...!”",
