			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Yes, and at home you were simply moved by the old sexual sleeves on your shelf... ‘What art!’ you said...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“在家的时候也是如此，对着架上老旧的飞机杯感动不已的样子……说什么‘这是艺术啊！’之类的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「在家的時候也是如此，對著架上老舊的飛機杯感動不已的樣子……說什麼『這是藝術啊！』之類的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00074",
		linknext = "0055_00076",
		line = 1126,
	},
	["0055_00076"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", file2="asane_01f_00201", path=":fg/asane_01f/", id=30, ch="麻沙音", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
