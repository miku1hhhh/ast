					name = {"郁子", "Ikuko"},
					"“Please cooperate so we can make this nice and smooth! Anyone trying to get one over on us will be punished by yours truly!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“为了能顺利进行，请大家配合一下～！若是有人想捣乱，那么郁就会逞罚大家喔～♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「為了能順利進行，請大家配合一下～！若是有人想搗亂，那麼郁就會逞罰大家喔～♪」",
					{"rt2"},
				},
			},
		},
