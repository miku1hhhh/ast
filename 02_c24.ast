			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s the freedom we’ve all been given.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那就会赋予我们平等的自由。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那就會賦予我們平等的自由。",
					{"rt2"},
				},
			},
		},
