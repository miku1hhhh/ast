	["0055_00075"] = {
		{"fg", file="fumino_02m_00007", file1="fumino_02m_00101", file2="fumino_02m_00211", path=":fg/fumino_02m/", id=7, lv=7, head="fumino_02m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
