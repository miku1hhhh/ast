		{"transitiontime", time=500},
		{"cgact", file="cgact", id=19, act="移動", x=200, y=-0.5, time=10000, lv=19},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0877", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I’m very sorry for the tardiness, everyone...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘我来晚了，真的是非常抱歉，各位──’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『我來晚了，真的是非常抱歉，各位──』",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00152",
		linknext = "0055_00154",
		line = 2322,
	},
	["0055_00154"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But the girl who suddenly appears in front of us all snatches away and monopolizes everyone’s attention.",
					{"rt2"},
				},
			},
			cn = {
				{
					"突然出现在眼前的少女，夺走了大家的目光。",
					{"rt2"},
				},
			},
			tw = {
				{
					"突然出現在眼前的少女，奪走了大家的目光。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00153",
		linknext = "0055_00155",
		line = 2332,
	},
	["0055_00155"] = {
		{"se", id=0, stop=1, time=1000},
		{"cgdel", id=19, lv=19, time=0, alphadel=1, evmaskoff=1},
		{"bgm", file="bgm09.5", vol=100},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="oldkcg050101", x=-5, y=-2.5, path=":cg/oldkcg05/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=1000},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0878", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I am FS representative and student council president Touka Reizeiin.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘我是FS代表兼学生会长的冷泉院桐香。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『我是FS代表兼學生會長的冷泉院桐香。』",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00154",
		linknext = "0055_00156",
		line = 2352,
	},
	["0055_00156"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All she needs is to show up, and you can’t help but turn to face her overwhelming presence.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一旦她出现──那股压倒性的氛围，很难让人不将目光转移到她身上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一旦她出現──那股壓倒性的氛圍，很難讓人不將目光轉移到她身上。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00155",
		linknext = "0055_00157",
		line = 2362,
	},
	["0055_00157"] = {
		{"se", id=5, loop=0, file="se_d007"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Every student begins to cheer.",
					{"rt2"},
				},
			},
			cn = {
				{
					"学生们都在欢呼。",
					{"rt2"},
				},
			},
			tw = {
				{
					"學生們都在歡呼。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00156",
		linknext = "0055_00158",
		line = 2373,
	},
	["0055_00158"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They do this because she is someone whose announcements always bring joy to Minotsuki’s students.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为她总是能发表带给水乃月的学生们快乐消息的人物啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為她總是能發表帶給水乃月的學生們快樂消息的人物啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00157",
		linknext = "0055_00159",
		line = 2383,
	},
	["0055_00159"] = {
		{"se", id=5, stop=1, time=1000},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0879", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I’ve gathered you here today because I have a number of matters I’d like to report on. FS members... please hand out what we’ve discussed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘因为今天有几件事要向大家报告，所以才将大家聚集起来。……FS的各位，按照惯例把那个发下去吧。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『因為今天有幾件事要向大家報告，所以才將大家聚集起來。……FS的各位，按照慣例把那個發下去吧。』",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00158",
		linknext = "0055_00160",
		line = 2396,
	},
	["0055_00160"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The nearby FS members all begin to distribute something at once.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在附近的FS，同时间开始发放着什么东西。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在附近的FS，同時間開始發放著什麼東西。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00159",
		linknext = "0055_00161",
		line = 2406,
	},
	["0055_00161"] = {
		{"se", id=0, loop=0, file="se_a141"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I get one as well.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我的手上也拿到了一份。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我的手上也拿到了一份。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00160",
		linknext = "0055_00162",
		line = 2417,
	},
	["0055_00162"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s a fairly familiar item—a rectangular card.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是比较常见的──长方形卡片。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是比較常見的──長方形卡片。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00161",
		linknext = "0055_00163",
		line = 2427,
	},
	["0055_00163"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0880", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“These are your Perversion Permits—specifically, prototypes of the newly updated permits we plan to distribute.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘这是变态许可证──是预定要进行新改版的测试品。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『這是變態許可證──是預定要進行新改版的測試品。』",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00162",
		linknext = "0055_00164",
		line = 2439,
	},
	["0055_00164"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0881", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Until now, these permits required you to circle either ‘Male’ or ‘Female’ under sex. This was done for reasons of convenience, allowing for prompt perverted sex.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘以前必须要在许可证上圈出男女。因为这样可以更快速更方便的进行变态做爱。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『以前必須要在許可證上圈出男女。因為這樣可以更快速更方便的進行變態做愛。』",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00163",
		linknext = "0055_00165",
		line = 2451,
	},
	["0055_00165"] = {
		{"evset", file="oldkcg05", set="oldkcg05", path=":ev/oldkcg05/"},
		{"evset", file="oldkcg050102", set="oldkcg050", path=":ev/oldkcg050/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="oldkcg050102", x=-5, y=-2.5, path=":cg/oldkcg05/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0882", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“However, that section is blank on these new permits.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘但是，在新型的许可证上，那一栏将会是空白。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『但是，在新型的許可證上，那一欄將會是空白。』",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00164",
		linknext = "0055_00166",
		line = 2470,
	},
	["0055_00166"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0883", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You may write your own gender there, or you are free to not write anything at all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘各位可以在上面写上自己的性别，不写也没关系。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『各位可以在上面寫上自己的性別，不寫也沒關係。』",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00165",
		linknext = "0055_00167",
		line = 2482,
	},
	["0055_00167"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0884", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“If you feel that you are neither male nor female, you may honestly write that down and nobody will criticize you for doing so.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘要是觉得自己既不是男人也非女人的话，即使坦白的写上去，也不会受到任何责怪的。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『要是覺得自己既不是男人也非女人的話，即使坦白的寫上去，也不會受到任何責怪的。』",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00166",
		linknext = "0055_00168",
		line = 2494,
	},
	["0055_00168"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="oldkcg050101", x=-5, y=-2.5, path=":cg/oldkcg05/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0885", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You are not required to fill out this field according to any biological point of view. You may freely express the way that you feel—that blank space is one of possibility.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘这个性别栏并不是用生物学的观点来记录，是可以自由表达你自己的想法──也就是说，这也可以是空白的。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『這個性別欄並不是用生物學的觀點來記錄，是可以自由表達你自己的想法──也就是說，這也可以是空白的。』",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00167",
		linknext = "0055_00169",
		line = 2510,
	},
	["0055_00169"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The students are a little bewildered. This must not have been something they ever considered.",
					{"rt2"},
				},
			},
			cn = {
				{
					"肯定是从来都没有想过的吧，学生们都稍微有些困惑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"肯定是從來都沒有想過的吧，學生們都稍微有些困惑。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00168",
		linknext = "0055_00170",
		line = 2520,
	},
	["0055_00170"] = {
		{"evset", file="oldkcg05", set="oldkcg05", path=":ev/oldkcg05/"},
		{"evset", file="oldkcg050103", set="oldkcg050", path=":ev/oldkcg050/"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But this is where the uniquely charismatic student council president, Touka Reizeiin, shines.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是那可是魅力无双的学生会长，冷泉院桐香啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是那可是魅力無雙的學生會長，冷泉院桐香啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00169",
		linknext = "0055_00171",
		line = 2532,
	},
	["0055_00171"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="oldkcg050103", x=-5, y=-2.5, path=":cg/oldkcg05/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0886", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“No new zoning will be established as a result of this. We expect it to create new kinds of confusion, and even result in new problems.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘因此，并不会设置新的分区。预计会有新混乱或新纠纷的发生。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『因此，並不會設置新的分區。預計會有新混亂或新糾紛的發生。』",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00170",
		linknext = "0055_00172",
		line = 2548,
	},
	["0055_00172"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0887", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“But we cannot ignore the potential of this blank space if we want Seiran Island to take its next step.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘但是为了让青蓝岛能更上一层楼，是无法忽视这空白的可能性的。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『但是為了讓青藍島能更上一層樓，是無法忽視這空白的可能性的。』",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00171",
		linknext = "0055_00173",
		line = 2560,
	},
	["0055_00173"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="oldkcg050101", x=-5, y=-2.5, path=":cg/oldkcg05/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0888", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“So please, I ask that you lead the charge when it comes to those new Permits—would you be models for the rest of the island?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘所以各位，能成为使用这款新许可证的先锋──并成为这座岛的榜样吗？’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『所以各位，能成為使用這款新許可證的先鋒──並成為這座島的榜樣嗎？』",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00172",
		linknext = "0055_00174",
		line = 2576,
	},
	["0055_00174"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She skillfully uses her words to excite the crowd.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她熟练地运用着话语，使大家情绪高涨了起来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她熟練地運用著話語，使大家情緒高漲了起來。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00173",
		linknext = "0055_00175",
		line = 2586,
	},
	["0055_00175"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0119", path=":vo/", ch="gmob"},
			},
			ja = {
				{
					name = {"モブ女A", "女子生徒A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Female Student A"},
					"“I guess instead of deciding based on looks, she wants us to treat people as the gender they tell us they are, huh...! And that it’s up to you whether or not you have perverted sex with them!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "女学生A"},
					"“也就是说不靠外观来决定，而是使用自我宣布的性别，对吧……！要不要和那个人进行变态做爱，全靠自己的想法的意思──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "女學生A"},
					"「也就是說不靠外觀來決定，而是使用自我宣布的性別，對吧……！要不要和那個人進行變態做愛，全靠自己的想法的意思──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00174",
		linknext = "0055_00176",
		line = 2598,
	},
	["0055_00176"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="bmoba0035", path=":vo/", ch="bmob"},
			},
			ja = {
				{
					name = {"モブ男A", "男子生徒A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ男A", "Male Student A"},
					"“I dunno about all this complicated stuff, but Miss Touka wants our help! Of course we’re gonna give it to her!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ男A", "男学生A"},
					"“虽然有点小困难但也无妨，因为是来自桐香大人的拜托啊！我们不做的话怎么行呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男A", "男學生A"},
					"「雖然有點小困難但也無妨，因為是來自桐香大人的拜託啊！我們不做的話怎麼行呢！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00175",
		linknext = "0055_00177",
		line = 2610,
	},
	["0055_00177"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I doubt that the SHO has approved these permits yet.",
					{"rt2"},
				},
			},
			cn = {
				{
					"SHO应该还没认可这个许可证吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"SHO應該還沒認可這個許可證吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00176",
		linknext = "0055_00178",
		line = 2620,
	},
	["0055_00178"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But that’s exactly why Touka is doing this—she wants to spread them with the help of everyone from Minotsuki Academy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因此桐香她──才会借着让水乃月学园的大家的帮忙，使这个能够普及化。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因此桐香她──才會藉著讓水乃月學園的大家的幫忙，使這個能夠普及化。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00177",
		linknext = "0055_00179",
		line = 2630,
	},
	["0055_00179"] = {
		{"evset", file="oldkcg05", set="oldkcg05", path=":ev/oldkcg05/"},
		{"evset", file="oldkcg050104", set="oldkcg050", path=":ev/oldkcg050/"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No. More than just spread them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不对，这不仅仅是要普及。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不對，這不僅僅是要普及。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00178",
		linknext = "0055_00180",
		line = 2642,
	},
	["0055_00180"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="oldkcg050104", x=-5, y=-2.5, path=":cg/oldkcg05/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0889", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“It will be difficult to understand someone if you see them as a person with a sexuality different from your own.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘若是找到和自己性取向不同的人该如何相处，要理解对方可不是一件简单的事情。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『若是找到和自己性取向不同的人該如何相處，要理解對方可不是一件簡單的事情。』",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00179",
		linknext = "0055_00181",
		line = 2658,
	},
	["0055_00181"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A kind of common sense.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那样的常识。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那樣的常識。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00180",
		linknext = "0055_00182",
		line = 2668,
	},
	["0055_00182"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="oldkcg050102", x=-5, y=-2.5, path=":cg/oldkcg05/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0890", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“But if they have come here to Seiran Island, know that they too are just like us. We all have each other’s bare backs as lovers of perversion.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘但是既然都来到了青蓝岛，那个人也是和我们一样喜欢变态做爱的无套粉。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『但是既然都來到了青藍島，那個人也是和我們一樣喜歡變態做愛的無套粉。』",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00181",
		linknext = "0055_00183",
		line = 2684,
	},
	["0055_00183"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A kind of situation where nobody feels that it’s strange for people like that to exist.",
					{"rt2"},
				},
			},
			cn = {
				{
					"创造一个即便这样的人出现也不会有违和感的状态。",
					{"rt2"},
				},
			},
			tw = {
				{
					"創造一個即便這樣的人出現也不會有違和感的狀態。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00182",
		linknext = "0055_00184",
		line = 2694,
	},
	["0055_00184"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0891", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“It takes much time for humans to understand that which they do not. Doing so requires effort.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘人类对于未知的事物，要是不花很长的时间是无法了解的。为此必须要努力。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『人類對於未知的事物，要是不花很長的時間是無法了解的。為此必須要努力。』",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00183",
		linknext = "0055_00185",
		line = 2706,
	},
	["0055_00185"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She wants to create that. Acceptance.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是想要创造宽容的环性吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是想要創造寬容的環性吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00184",
		linknext = "0055_00186",
		line = 2716,
	},
	["0055_00186"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0892", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Let us never fail to be prepared to make this effort, even if it is ultimately fruitless.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘即使永远没有结果，也不要忘记不懈努力的态度。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『即使永遠沒有結果，也不要忘記不懈努力的態度。』",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00185",
		linknext = "0055_00187",
		line = 2728,
	},
	["0055_00187"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This is Touka Reizeiin’s answer.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那就是冷泉院桐香的想法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那就是冷泉院桐香的想法。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00186",
		linknext = "0055_00188",
		line = 2738,
	},
	["0055_00188"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0893", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“And if you do feel as though others do not understand you... If you feel that you’re suffering all alone...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘然后，如果你觉得自己不被人理解的话。若是因为孤独而痛苦着的话。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『然後，如果你覺得自己不被人理解的話。若是因為孤獨而痛苦著的話。』",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00187",
		linknext = "0055_00189",
		line = 2750,
	},
	["0055_00189"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As well as the FS Big Three’s answer.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后是FS三巨头的想法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後是FS三巨頭的想法。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00188",
		linknext = "0055_00190",
		line = 2760,
	},
	["0055_00190"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="oldkcg050101", x=-5, y=-2.5, path=":cg/oldkcg05/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0894", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“...I ask that you consider challenging yourself to make an effort to be understood, just as others are doing for you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘那就和大家一样，试着努力地获得大家的理解，大家觉得怎么样呢？’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『那就和大家一樣，試著努力地獲得大家的理解，大家覺得怎麼樣呢？』",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00189",
		linknext = "0055_00191",
		line = 2776,
	},
	["0055_00191"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Their way to create a new path of coexistence.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是新的共存之道啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是新的共存之道啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00190",
		linknext = "0055_00192",
		line = 2786,
	},
	["0055_00192"] = {
		{"bgm", stop=1},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="oldkcg050102", x=-5, y=-2.5, path=":cg/oldkcg05/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0895", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“...Well, now that we have the formal talk out of the way. My final report is one regarding your fashion and style.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘……好了，严肃的话题就到此结束。最后要告诉大家关于流行相关的事。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『……好了，嚴肅的話題就到此結束。最後要告訴大家關於流行相關的事。』",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00191",
		linknext = "0055_00193",
		line = 2803,
	},
	["0055_00193"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0896", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Regarding the Minotsuki Academy school rules that have been under consideration for some time—we’ve decide to make a slight modification to them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘之前就一直在考虑着，关于水乃月学园的校规──将会有些微的改变。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『之前就一直在考慮著，關於水乃月學園的校規──將會有些微的改變。』",
