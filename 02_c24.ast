				{
					name = {"モブ女A", "女子生徒A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Female Student A"},
					"“It’s starting to get too cold for skirts, so let’s wear long pants! I bet we’d look so cute if we coordinated in different colors! And all you have to do to start getting fucked is zip them open!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "女学生A"},
					"“也快到了穿裙子会冷的季节了，就穿长裤吧！要是换个颜色凑成一套不也挺可爱的──！？这样只要拉链拉开就可以马上被干了……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "女學生A"},
					"「也快到了穿裙子會冷的季節了，就穿長褲吧！要是換個顏色湊成一套不也挺可愛的──！？這樣只要拉鍊拉開就可以馬上被幹了……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00196",
