					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“No, I wouldn’t say that... Um, even this uniform... It’s something Touka gave me as a present in the past...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“不会的，没有那种事……那个，这身制服……是很久之前桐香送给我的礼物，所以……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「不會的，沒有那種事……那個，這身制服……是很久之前桐香送給我的禮物，所以……」",
					{"rt2"},
				},
			},
		},
