				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“除此之外，在看到旧的“贯穿丸”时，喊着‘超帅的武器！’之类的，现在才在情绪高涨……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「除此之外，在看到舊的“貫穿丸”時，喊著『超帥的武器！』之類的，現在才在情緒高漲……」",
					{"rt2"},
				},
			},
		},
