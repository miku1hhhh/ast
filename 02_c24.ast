	["0055_00087"] = {
		{"fg", file="misaki_01m_00001", file1="misaki_01m_00101", file2="misaki_01m_00202", path=":fg/misaki_01m/", id=6, lv=6, head="misaki_01m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-205, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="美岬6", id=6, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0160", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Oh, if your schedules are open, would you want to pack them with calories? Sounds like they finally opened an all-you-can-eat sweets and pasta place on Seiran Island, we have to go!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“话说回来，你今天变胖了吗？回到青蓝岛就能去吃甜点跟意大利面吃到饱了，大家一起去吃吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「話說回來，你今天變胖了嗎？回到青藍島就能去吃甜點跟義大利麵吃到飽了，大家一起去吃吧！」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00086",
		linknext = "0055_00088",
		line = 1273,
	},
	["0055_00088"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", file2="asane_01f_00216", path=":fg/asane_01f/", id=30, ch="麻沙音", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
