	["0055_00060"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So that’s what I was like in the other world...",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个世界的我啊，原来是这样的感觉啊……。",
