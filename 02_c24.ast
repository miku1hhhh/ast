			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“It is quite all right... I am your servant... Whether or not my master eats is his decision... If anything, I am at fault for being unable to produce what you seek...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“没关系……我只是个佣人……吃或不吃都是由主人自己决定的……反倒是做不出主人想要的东西的文乃，才该检讨……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「沒關係……我只是個傭人……吃或不吃都是由主人自己決定的……反倒是做不出主人想要的東西的文乃，才該檢討……」",
					{"rt2"},
				},
			},
		},
