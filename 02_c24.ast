	["0055_00237"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg010105-1", x=0, y=0, path=":cg/kcg01/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0288", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“She said that she can’t wear it anymore, and apologized for it being a hand-me-down... But something about that made me kind of happy... It felt like she was saying I’m a girl.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“说是因为自己穿不到的旧衣服……但是，因为那样总觉得很开心……感觉像是被说了是女孩子的样子呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「說是因為自己穿不到的舊衣服……但是，因為那樣總覺得很開心……感覺像是被說了是女孩子的樣子呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00236",
		linknext = "0055_00238",
		line = 3402,
	},
	["0055_00238"] = {
