				},
			},
			tw = {
				{
					name = {"文乃"},
					"「但、但是……文乃沒經歷過自己做的料理被剩下的經驗……所以，心裡面亂哄哄的……滴咕滴咕滴咕……！」",
					{"rt2"},
				},
