				{"vo", file="asane0174", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You’re the only fatty here so don’t try to make things appealing to us by talking about how much weight we’ll gain by doing some all-you-can-eat buffat.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哪有时间？不要用那种语调来炫耀自己胖好吗？死胖子就只有你一人而已，这个定期肥胖无限制的人……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哪有時間？不要用那種語調來炫耀自己胖好嗎？死胖子就只有妳一人而已，這個定期肥胖無限制的人……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00087",
		linknext = "0055_00089",
		line = 1286,
	},
	["0055_00089"] = {
