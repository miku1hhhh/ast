				{"transitiontime", time=300, timestamp=33, delay2=3000},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko1162", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“She says that, but Tokie’s not here... But I guess I can’t blame her. She’s been working without any sleep ever since we got back.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“因为这样桐香酱才没有出现的呢……唉，这也是没办法的事。毕竟回来之后就不眠不休地在工作着。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「因為這樣桐香醬才沒有出現的呢……唉，這也是沒辦法的事。畢竟回來之後就不眠不休地在工作著。」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00118",
		linknext = "0055_00120",
		line = 1791,
	},
	["0055_00120"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All of us made it back to this world.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们全都回到这个世界了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們全都回到這個世界了。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00119",
