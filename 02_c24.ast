		text = {
			vo = {
				{"vo", file="asane0176", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You’re all calling each other by your first names?! Holy shit you’re like lovers it’s so naughty it’s so lewd two girls at the same time oh shit when can I insert myself into the FS raw-dog kennel?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“居然互喊对方姓名！？不妙啊，这不就是恋人嘛，真是色啊，又很变态，脚踏两条船也太恶劣了吧！我什么时候可以加入FS跟无套粉的行列啊──！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「居然互喊對方姓名！？不妙啊，這不就是戀人嘛，真是色啊，又很變態，腳踏兩條船也太惡劣了吧！我什麼時候可以加入FS跟無套粉的行列啊──！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00113",
		linknext = "0055_00115",
		line = 1703,
	},
	["0055_00115"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
