	},
	["0055_00061"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I guess it would surprise everyone if that’s who I became all of a sudden one day...",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且突然转变成“我”，也难怪周围的人会吓一跳……。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且突然轉變成“我”，也難怪周圍的人會嚇一跳……。",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00060",
		linknext = "0055_00062",
		line = 918,
	},
	["0055_00062"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", file2="nanase_01m_00228", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0143", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“You know it wasn’t easy at all, right? You even seriously traumatized Fumino by not finishing all the food she made you...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“真的是特别不妙呢？因为没有吃光文乃做的料理，让文乃大受打击呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「真的是特別不妙呢？因爲沒有吃光文乃做的料理，讓文乃大受打擊呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00061",
		linknext = "0055_00063",
		line = 933,
	},
	["0055_00063"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00209", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What? Fumino’s cooking? Why?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“咦，文乃的料理嘛，怎么会──！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「咦，文乃的料理嘛，怎麼會──！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00062",
		linknext = "0055_00064",
		line = 945,
	},
	["0055_00064"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", file2="nanase_01m_00228", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="奈々瀬4", id=4, act="振動下", loop=1, size=12.5, time=400, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0144", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Sigh... You said something about it being ‘so refined and new that your brain can’t keep up’ or something... Though you were still fine with my cooking...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“啥……说什么‘这太高级了吃不惯，所以脑子适应不了’之类的……我是觉得没什么问题啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「啥……說什麼『這太高級了吃不慣，所以腦子適應不了』之類的……我是覺得沒什麼問題啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0055_00063",
		linknext = "0055_00065",
		line = 961,
	},
	["0055_00065"] = {
