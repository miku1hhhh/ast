					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If calling someone by their first name is equivalent to sex, does that make the NLNS my harem?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“要是喊名字而已就是做爱了，那NLNS就是我的后宫了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「要是喊名字而已就是做愛了，那NLNS就是我的後宮了？」",
					{"rt2"},
				},
			},
		},
