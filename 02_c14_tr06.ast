					{"rt2"},
				},
			},
		},
		linkback = "0025_00202",
		linknext = "0025_00204",
		line = 3085,
	},
	["0025_00204"] = {
		{"fg", file="tohka_02m_00003", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=8, lv=10, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0577", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes. I wanted to take that dove out of my hat and get back at everyone... but instead, it only shat on me and escaped. Just pooed and left.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“是的，我还以为绝对能变出鸽子给大家看看的说⋯⋯结果它居然大了便就跑。简直就是踩到屎还滑倒嘛！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「是的，我還以為絕對能變出鴿子給大家看看的說⋯⋯結果它居然大了便就跑。簡直就是踩到屎還滑倒嘛！」",
					{"rt2"},
				},
			},
		},
		linkback = "0025_00203",
		linknext = "0025_00205",
		line = 3100,
	},
	["0025_00205"] = {
