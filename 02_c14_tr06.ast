	},
	["0025_00175"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00214", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And raccoons are omnivorous, so they can eat everything. Probably doves too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而且狸猫是杂食动物所以什么都吃，应该也会吃鸽子吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而且狸貓是雜食動物所以什麼都吃，應該也會吃鴿子吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0025_00174",
		linknext = "0025_00176",
		line = 2716,
	},
