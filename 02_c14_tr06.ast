	["0025_00150"] = {
		{"fg", file="ikuko_02m_00002", file1="ikuko_02m_00101", file2="ikuko_02m_00202", path=":fg/ikuko_02m/", id=10, lv=9, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0700", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“On the other hand, all animals seem to like Rei for some reason.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“反倒是礼酱莫名地受动物欢迎呢～”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「反倒是禮醬莫名地受動物歡迎呢～」",
					{"rt2"},
				},
			},
		},
		linkback = "0025_00149",
		linknext = "0025_00151",
		line = 2353,
	},
	["0025_00151"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00201", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Isn’t that because she seems like she’d look after them? She looks like the type who’d come to school to feed the class pet every day, all the way through summer break.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那是因为她会连饲养员的工作都做得很认真不是吗？就连暑假都还每天来学校喂饲料之类的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那是因為她會連飼養員的工作都做得很認真不是嗎？就連暑假都還每天來學校餵飼料之類的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0025_00150",
		linknext = "0025_00152",
		line = 2365,
	},
	["0025_00152"] = {
		{"fg", file="rei_02m_00007", file1="rei_02m_00101", file2="rei_02m_00212", path=":fg/rei_02m/", id=9, lv=8, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0609", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Well, it’s true that I used to be in charge of the class pets when I was little...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“唔，我小学的时候确实是当过饲养员啦，不过⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「唔，我小學的時候確實是當過飼養員啦，不過⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0025_00151",
		linknext = "0025_00153",
		line = 2380,
	},
	["0025_00153"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She also looks like the type who’d get chased around the room by a chicken, crying while the creature pecks her without mercy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过被养的鸡追着啄所以哭着逃跑的了。",
