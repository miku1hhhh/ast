				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Oooh, right! A carefree air suits her best. It’s also cute ’cause it’s so round!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“啊啊对！跟她那悠哉的气质最吻合，圆滚滚的也很可爱！”",
