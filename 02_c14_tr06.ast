				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yes. One portion is for making people change on their own by encouraging them with music.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没错。跟着音乐的节奏自己一个人也能换衣服的鼓励作──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒錯。跟著音樂的節奏自己一個人也能換衣服的鼓勵作──」",
					{"rt2"},
				},
			},
		},
		linkback = "0025_00039",
		linknext = "0025_00041",
		line = 555,
	},
	["0025_00041"] = {
