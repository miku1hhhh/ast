	["0025_00003"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yep. Junnosuke Tachibana has made a full recovery. I’m feeling great!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是喔，橘淳之介彻底痊愈。现在状况相当良好喔⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是喔，橘淳之介徹底痊癒。現在狀況相當良好喔⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0025_00002",
		linknext = "0025_00004",
		line = 50,
	},
	["0025_00004"] = {
		{"fg", file="ikuko_02m_00002", file1="ikuko_02m_00101", file2="ikuko_02m_00204", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", alpha=0, ch_origin="郁子", ch="郁子10", mw="mw", sync=1, a_chr151=1, mode=3, x=595, y=-5},
		{"fgact", ch="郁子10", id=10, lv=10, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="郁子10", id=10, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0909", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“That’s incredible. It normally takes about two months to fully heal. Your body must have a peculiar structure. Can I put it to a test?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“真是惊人呢，正常的话要完全痊愈少说要两个月的说。你那是什么身体构造啊？我可以测试看看吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「真是驚人呢，正常的話要完全痊癒少說要兩個月的說。你那是什麼身體構造啊？我可以測試看看嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0025_00003",
		linknext = "0025_00005",
		line = 65,
	},
	["0025_00005"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00210", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
