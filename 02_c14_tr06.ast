					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Then, what am I? What do you think, Tachibana? Hehe! The animals that doves hate most are cats. I must be a cat!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呐、那我呢？前辈觉得我像什么？嗯唔、会被鸽子讨厌的动物，果然还是猫咪对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「吶、那我呢？前輩覺得我像什麼？嗯唔、會被鴿子討厭的動物，果然還是貓咪對吧？」",
					{"rt2"},
				},
			},
		},
