			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I had a match with Blowbo to imitate the sound of giving a blowjob on a vibrator. I won, so now Blowbo does everything I tell it to.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我跟啾啪酱用按摩棒比赛口交音，如果我赢的话它就要听我的话啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我跟啾啪醬用按摩棒比賽口交音，如果我贏的話牠就要聽我的話啊？」",
					{"rt2"},
				},
			},
		},
