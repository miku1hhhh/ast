			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I think she’s practicing magic tricks. Tokie likes that kind of stuff. She often performs at the FS parties.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“应该是在练习魔术表演吧。桐香酱说过她很喜欢魔术。也常常在FS的派对上表演的说。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「應該是在練習魔術表演吧。桐香醬說過她很喜歡魔術。也常常在FS的派對上表演的說。」",
					{"rt2"},
				},
			},
		},
