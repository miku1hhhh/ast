			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Maybe there’s something in me that scares animals...? Hey, if we were to be animals, what would we be?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我到底是有什么地方会让动物害怕⋯⋯呐，如果把我们都比作动物的话大家会是什么呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我到底是有什麼地方會讓動物害怕⋯⋯吶，如果把我們都比作動物的話大家會是什麼呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0025_00153",
		linknext = "0025_00155",
		line = 2409,
	},
	["0025_00155"] = {
