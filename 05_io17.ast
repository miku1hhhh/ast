		{"se", id=0, loop=0, file="se_a100"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I find my sister in the crowd, and we latch on to each other.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一在人群中确认到妹妹的身影，我们马上奔向彼此，紧紧相拥。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一在人群中確認到妹妹的身影，我們馬上奔向彼此，緊緊相擁。",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00128",
		linknext = "0081_00130",
		line = 1783,
	},
	["0081_00130"] = {
		{"fg", file="asane_02ll_00003", file1="asane_02ll_00104", file2="asane_02ll_00208", path=":fg/asane_02ll/", id=3, lv=3, head="asane_02ll", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0351", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“What should we do, Bro?! A meteor’s about to hit us! We’re all gonna die!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“怎么办……怎么办啊老哥……陨石要掉下来了！大家都会死掉啦啊啊啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「怎麼辦……怎麼辦啊老哥……隕石要掉下來了！大家都會死掉啦啊啊啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00129",
		linknext = "0081_00131",
		line = 1798,
	},
	["0081_00131"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00208", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It’s okay, Asa! Everything’s gonna be all right.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“冷静点麻沙酱！肯定──肯定不会有事的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「冷靜點麻沙醬！肯定──肯定不會有事的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00130",
		linknext = "0081_00132",
		line = 1810,
	},
	["0081_00132"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was an empty assurance, but it’s the best a brother can do for now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然没有任何根据──但是现在，身为兄长，也只能这么说了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然沒有任何根據──但是現在，身為兄長，也只能這麼說了。",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00131",
		linknext = "0081_00133",
		line = 1820,
	},
	["0081_00133"] = {
		{"fg", file="asane_02ll_00003", file1="asane_02ll_00106", file2="asane_02ll_00211", path=":fg/asane_02ll/", id=3, lv=3, head="asane_02ll", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0352", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I don’t wanna die, Bro... I haven’t fulfilled my dream yet... My dream for a threesome... with Nanase and Onabuta and Reizeiin and Bro and me...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不要啊老哥……我的梦想、都还没有实现……完全没有3P到……完全还没有和奈奈濑同学和女部田前辈和冷泉院同学和老哥和我3P到啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不要啊老哥……我的夢想、都還沒有實現……完全沒有3P到……完全還沒有和奈奈瀨同學和女部田前輩和冷泉院同學和老哥和我3P到啊……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00132",
		linknext = "0081_00134",
		line = 1835,
	},
	["0081_00134"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00224", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I’m so sorry...! I promised that I’d teach you at least how to count...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对不起……真的很对不起……！明明约好了至少要让你学会怎么算数的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對不起……真的很對不起……！明明約好了至少要讓妳學會怎麼算數的……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00133",
		linknext = "0081_00135",
		line = 1847,
	},
