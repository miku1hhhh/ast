		{"text"},
		text = {
			vo = {
				{"vo", file="rin0297", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Remember when I killed that frenzied wild boar?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“你还记得我以前宰掉了一只凶暴的野生山猪的事情吗？”",
