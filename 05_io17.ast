	["0081_00148"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The crowd peacefully make a space for him, and turn their ears to his words.",
					{"rt2"},
				},
			},
			cn = {
				{
					"群众自然而然地让开了路，倾听起他的话语。",
