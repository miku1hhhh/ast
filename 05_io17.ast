	["0081_00178"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"While everyone is losing their sanity at this calamity, it seems to be having an opposite effect on Misaki, leaving her quite calm. Double negatives make a positive, I guess.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在异常状况之中、所有人都失去了正常的思考能力的时候，就只有平常就不正常的美岬因为负负得正的现象反而最正经。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在異常狀況之中、所有人都失去了正常的思考能力的時候，就只有平常就不正常的美岬因為負負得正的現象反而最正經。",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00177",
		linknext = "0081_00179",
		line = 2526,
	},
