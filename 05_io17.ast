		},
		text = {
			vo = {
				{"vo", file="tohka1714", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You don’t need to thank me for what I did. We lived to achieve coexistence, and if its final moment is to be with your family, well... I find that beautiful.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不，我没有做什么值得你道谢的事情。……我们是以共存为目标生存下来的。如果其结果是跟家人一起迎来结局，那也没什么不好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不，我沒有做什麼值得妳道謝的事情。……我們是以共存為目標生存下來的。如果其結果是跟家人一起迎來結局，那也沒什麼不好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00216",
		linknext = "0081_00218",
		line = 3056,
	},
