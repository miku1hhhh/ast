				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Rin...? Is that you?! Oh, thank goodness... Where in the world have you been?! I’ve been looking all over for you. Oh, Rin...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“凛……真的是凛吗……！？啊啊……太好了……最后还能……真是的，你到底跑到哪里去了啦！我一直在找你耶！呜呜呜、凛～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「凜……真的是凜嗎……！？啊啊……太好了……最後還能……真是的，妳到底跑到哪裡去了啦！我一直在找妳耶！嗚嗚嗚、凜～！」",
					{"rt2"},
				},
			},
		},
