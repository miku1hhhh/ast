				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“...I’ve been living in the dark, crawling across mud, living like a savage... all to let a god descend into this body.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“……生活在黑暗之中、啜饮泥水、在地上爬行的同时……让神寄宿在这具躯体之中了喔……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「……生活在黑暗之中、啜飲泥水、在地上爬行的同時……讓神寄宿在這具軀體之中了喔……」",
					{"rt2"},
				},
			},
		},
