					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Has it ever? But man, we won’t be able to have conversations like this anymore... Oh man, there are so many things I still want to do...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“从来就没有想出办法过吧你……不过，这种对话……也已经是最后了吗……啊──啊……我明明还有很多事情想尝试的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「從來就沒有想出辦法過吧你……不過，這種對話……也已經是最後了嗎……啊──啊……我明明還有很多事情想嘗試的……」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00212",
