			},
			[9499] = {
				{"transitiontime", time=300, timestamp=10, delay2=9500},
			},
		},
		text = {
			vo = {
				{"vo", file="mizuhiki0560", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“You know, this island has been growing on me so much, but soon it will all be over. Thank you Touka, for giving me a chance to live.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“我总算……这么喜欢青蓝岛了……。这样啊……这样就结束了啊……谢谢你，桐香同学，谢谢你给了我活着的机会。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「我總算……這麼喜歡青藍島了……。這樣啊……這樣就結束了啊……謝謝妳，桐香同學，謝謝妳給了我活著的機會。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00215",
		linknext = "0081_00217",
		line = 3039,
	},
	["0081_00217"] = {
		{"fg", file="tohka_01m_00002", file1="tohka_01m_00101", file2="tohka_01m_00214", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[6800] = {
				{"fg", file="tohka_01m_00002", file1="tohka_01m_00101", file2="tohka_01m_00210", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, timestamp=11, delay2=6800, mode=3, x=-405, y=-5},
