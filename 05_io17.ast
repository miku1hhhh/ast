	["0081_00182"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00213", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0110", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“The government has said they’ll do whatever they can, but we have so little time. We can’t expect any external help.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"‘虽然政府也说会尽力处理，可是老天爷给我们的时间实在是太短了。……外来的援助，恐怕是无法期待了吧。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"『雖然政府也說會盡力處理，可是老天爺給我們的時間實在是太短了。……外來的援助，恐怕是無法期待了吧。』",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00181",
		linknext = "0081_00183",
		line = 2584,
	},
	["0081_00183"] = {
