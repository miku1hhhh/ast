			ja = {
				{
					name = {"茅津野アナ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"茅津野アナ", "Pussy Galore"},
					"“According to the simu-lotion results, the meteor detached from the comet Hale-Fuck will obliterate the entire island on impact.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"茅津野アナ", "茅津野播报员"},
					"‘根据NAKA的模拟结果，如果从哈梅彗星分裂出来的陨石直接击中，会让整个岛屿从地图上消失。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"茅津野アナ", "茅津野播報員"},
					"『根據NAKA的模擬結果，如果從哈梅彗星分裂出來的隕石直接擊中，會讓整個島嶼從地圖上消失。』",
					{"rt2"},
				},
			},
		},
