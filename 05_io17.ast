	["0081_00255"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I remember hearing about something like that in World B.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这么说起来──在B世界，似乎有听说过这么一件事情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這麼說起來──在B世界，似乎有聽說過這麼一件事情。",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00254",
		linknext = "0081_00256",
		line = 3596,
	},
	["0081_00256"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00203", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=29},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You said you killed it with ejaculation regulation.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我记得，说是靠射精管理杀掉的──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我記得，說是靠射精管理殺掉的──」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00255",
		linknext = "0081_00257",
		line = 3608,
	},
	["0081_00257"] = {
		{"fg", file="ran_01f_00001", file1="ran_01f_00102", file2="ran_01f_00206", file4="ran_01f_00401", path=":fg/ran_01f/", id=30, ch="蘭", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0154", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Yes. Rin once performed ejaculation regulation on a male student as a treatment for his impotence, so that he could become erect with even the slightest stimulation.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“是的……凛以前曾经采用射精管理，作为治疗某个男学生的阳痿的一环。为了让他能因为一些细微的刺激勃起。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「是的……凜以前曾經採用射精管理，作為治療某個男學生的陽痿的一環。為了讓他能因為一些細微的刺激勃起。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00256",
		linknext = "0081_00258",
		line = 3621,
	},
	["0081_00258"] = {
		{"fg", file="rei_01f_00007", file1="rei_01f_00101", file2="rei_01f_00204", path=":fg/rei_01f/", id=30, ch="礼", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1956", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I also heard about it, but this ejaculation regulation apparently lasted for a whole month.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我也只是事后听说而已……据说凛对那个男学生进行的射精管理整整长达一个月。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我也只是事後聽說而已……據說凜對那個男學生進行的射精管理整整長達一個月。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00257",
		linknext = "0081_00259",
		line = 3634,
