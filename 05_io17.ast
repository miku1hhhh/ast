		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All the people blown away by the shockwave rise up, look up to the sky and rejoice.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被冲击波吹飞的人们也抬起头看向天空，表情随即明朗了起来。",
