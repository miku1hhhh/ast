				{
					name = {"モブ男C", "赛巴斯鸡"},
					"“哈啊啊啊，仁浦大人……这座岛……这座岛的未来就拜托您了……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男C", "賽巴斯雞"},
					"「哈啊啊啊，仁浦大人……這座島……這座島的未來就拜託您了……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00194",
		linknext = "0081_00196",
		line = 2739,
	},
	["0081_00196"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The elderly islanders are fully aware of this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"阅历丰富的老人们，都已经理解了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"閱歷豐富的老人們，都已經理解了。",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00195",
		linknext = "0081_00197",
		line = 2749,
	},
	["0081_00197"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He knows more than anyone else what ripples his death could produce. Of course he has to make this decision.",
					{"rt2"},
				},
			},
			cn = {
				{
					"会这么判断也是理所当然的。自己的死亡会掀起怎么样的涟漪，想必仁浦氏自己是最清楚的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"會這麼判斷也是理所當然的。自己的死亡會掀起怎麼樣的漣漪，想必仁浦氏自己是最清楚的。",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00196",
		linknext = "0081_00198",
		line = 2759,
	},
	["0081_00198"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Which is why I can’t resist it, no matter what he may feel about it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正因如此，他无法拒绝。不论他心中抱持着何种想法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正因如此，他無法拒絕。不論他心中抱持著何種想法。",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00197",
		linknext = "0081_00199",
		line = 2769,
	},
	["0081_00199"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00206", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=500, draw2=1},
		{"ex", time=800, func="wait"},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuki0007", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"水姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水姫", "Mizuki"},
					"“Governor, this way please.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水姫"},
					"“那么仁浦大人。请往这边──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水姫"},
					"「那麼仁浦大人。請往這邊──」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00198",
		linknext = "0081_00200",
		line = 2784,
	},
	["0081_00200"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00213", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0112", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“...Just a moment. I’m sure a seat for myself can fit two children on it. Get them on instead of me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“……不──能稍等一下吗？我一个人的座位，如果是小孩，应该能坐得下两个人吧？请优先把位子给他们吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「……不──能稍等一下嗎？我一個人的座位，如果是小孩，應該能坐得下兩個人吧？請優先把位子給他們吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00199",
		linknext = "0081_00201",
		line = 2799,
	},
	["0081_00201"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuki0008", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"水姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水姫", "Mizuki"},
					"“What? But...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水姫"},
					"“咦……不、不，可是……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水姫"},
					"「咦……不、不，可是……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00200",
		linknext = "0081_00202",
		line = 2811,
	},
	["0081_00202"] = {
		{"bgm", file="bgm21", vol=100},
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00201", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0113", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“The future belongs to the young. There’s no need for an old man like myself to cling on to life so pathetically.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“要肩负起未来的是你们这些年轻人。我这种老头死皮赖脸地紧抓着自己的小命又有什么用？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「要肩負起未來的是你們這些年輕人。我這種老頭死皮賴臉地緊抓著自己的小命又有什麼用？」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00201",
		linknext = "0081_00203",
		line = 2827,
	},
	["0081_00203"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuki0009", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"水姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水姫", "Mizuki"},
					"“But without a leader for the young, who will manage our perverted sex law?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水姫"},
					"“可是，如果没有人引导您所说的年轻人的话，我们的变态条例就……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水姫"},
					"「可是，如果沒有人引導您所說的年輕人的話，我們的變態條例就……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00202",
		linknext = "0081_00204",
		line = 2839,
	},
	["0081_00204"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00207", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0114", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“The young are fully capable of leading themselves.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“呵……就算没有父母，孩子还是会长大的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「呵……就算沒有父母，孩子還是會長大的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00203",
		linknext = "0081_00205",
		line = 2854,
	},
	["0081_00205"] = {
		{"fg", mode=-1, id=16, ch="仁浦16", ch_origin="仁浦", lv=16, time=0, sync=0},
		{"bg", id=29, file="blackband_00000", x=0, y=0, lv=29, path=":bg/"},
		{"bg", id=2, file="bg07_3l_00000", x=50, y=-100, lv=2, path=":bg/", sync=0, style="blur", blurx=11, blury=11, ax=1280, ay=730, bx=-480, by=-280},
		{"fg", file="fumino_01l_00001", file1="fumino_01l_00101", file2="fumino_01l_00205", path=":fg/fumino_01l/", id=7, lv=7, head="fumino_01l", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=35, y=-5},
		{"transitiontime", time=500},
		{"cgact", file="cgact", id=2, act="移動", x=-105, y=-5, time=6000, lv=2},
		{"fgact", ch="文乃7", id=7, act="移動", x=-40, y=0, time=6000},
		{"fg", file="hitoura_01f_00001", file2="hitoura_01f_00204", path=":fg/hitoura_01f/", id=30, ch="仁浦", lv=7, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0115", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“This is an island that my wife and my daughter loved. Anyone who abandons it deserves no future. As a citizen, I wish to remain on this island in its final moments.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“这是我的妻子……和我的女儿深爱的岛屿。如果我见死不救，作为人类毫无未来可言。我也、至少在最后……想要以一个人类的身份，跟这座岛同生共死。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「這是我的妻子……和我的女兒深愛的島嶼。如果我見死不救，作為人類毫無未來可言。我也、至少在最後……想要以一個人類的身分，跟這座島同生共死。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00204",
		linknext = "0081_00206",
		line = 2875,
	},
	["0081_00206"] = {
		{"fgact", ch="文乃7", id=7, lv=7, act="表示アクション", alpha=0, alphadel=1, style="reset", time=500},
		{"cgdel", id=2, lv=2, time=500, alphadel=1},
		{"cgact", file="cgact", act="表示アクション", alpha=0, id=29, lv=29, time=500, alphadel=1, style="reset", x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuki0010", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"水姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水姫", "Mizuki"},
					"“Mr. Governor... Understood, sir. Then we shall follow you, no matter where you should tread.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水姫"},
					"“仁浦大人……我知道了。那么我也与您一同留下吧。……只要有您在，哪怕水里火里，在所不辞。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水姫"},
					"「仁浦大人……我知道了。那麼我也與您一同留下吧。……只要有您在，哪怕水裡火裡，在所不辭。」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00205",
		linknext = "0081_00207",
		line = 2893,
	},
	["0081_00207"] = {
		{"cgact", file="cgact", act="表示アクション", alpha=0, id=16, time=300, alphadel=1, style="reset"},
		{"cgact", file="cgact", act="表示アクション", alpha=0, id=17, time=100, alphadel=1, style="reset"},
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file2="fumino_01m_00204", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=500},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0229", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「………………」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00206",
		linknext = "0081_00208",
		line = 2911,
	},
	["0081_00208"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino, who never thought much of her father, looked into his eyes silently, just for this moment.",
					{"rt2"},
				},
			},
			cn = {
				{
					"平常对父亲特别严厉的文乃，就只有这个时候什么话都没有说──而是静静地，凝视着他的脸庞。",
					{"rt2"},
				},
			},
			tw = {
				{
					"平常對父親特別嚴厲的文乃，就只有這個時候什麼話都沒有說──而是靜靜地，凝視著他的臉龐。",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00207",
		linknext = "0081_00209",
		line = 2921,
	},
	["0081_00209"] = {
		{"fgact", ch="文乃7", id=7, lv=7, act="表示アクション", alpha=0, alphadel=1, style="reset", time=500},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And with the governor making a statement as a citizen, the end seems nigher than ever.",
					{"rt2"},
				},
			},
			cn = {
				{
					"同时──因为仁浦氏吐露出了作为各人的心声，末日终于化为了现实，落在了大家眼前。",
					{"rt2"},
				},
			},
			tw = {
				{
					"同時──因為仁浦氏吐露出了作為各人的心聲，末日終於化為了現實，落在了大家眼前。",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00208",
		linknext = "0081_00210",
		line = 2933,
	},
	["0081_00210"] = {
		{"fg", file="kouki_01m_00001", file1="kouki_01m_00101", file2="kouki_01m_00208", path=":fg/kouki_01m/", id=17, lv=17, head="kouki_01m", alpha=0, ch_origin="光姫", ch="光姫17", mw="mw", sync=1, a_chr151=1, mode=3, x=595, y=-5},
		{"fgact", ch="光姫17", id=17, lv=17, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="光姫17", id=17, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="kouki0130", path=":vo/", ch="kouki"},
			},
			ja = {
				{
					name = {"光姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"光姫", "Kouki"},
					"“Mizuki! Mizukiiii! Don’t be scared! Your big sister will be with you until the very end!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"光姫"},
					"“水姬酱、水姬酱～！不用害怕喔！姐姐直到最后都会待在你身边的喔～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"光姫"},
					"「水姬醬、水姬醬～！不用害怕喔！姊姊直到最後都會待在妳身邊的喔～！」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00209",
		linknext = "0081_00211",
		line = 2948,
	},
	["0081_00211"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuki0011", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"水姫"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水姫", "Mizuki"},
					"“Um, I wish to be with Governor Hitoura... for heaven’s sake. All right, thank you for all you’ve done for me, sister...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水姫"},
					"“咦？不，我要和仁浦大人一起…………唉，真拿你没办法……好乖好乖，至今为止谢谢你了，姐姐……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水姫"},
					"「咦？不，我要和仁浦大人一起…………唉，真拿妳沒辦法……好乖好乖，至今為止謝謝妳了，姊姊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00210",
		linknext = "0081_00212",
		line = 2960,
	},
	["0081_00212"] = {
		{"cgdel", id=16, time=0, alphadel=1, lv=5},
		{"fg", mode=-1, id=17, ch="光姫17", ch_origin="光姫", lv=17, time=0, sync=0},
