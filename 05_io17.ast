	},
	["0081_00149"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00205", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0099", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Well... since there’s not much time left, let me give you a brief overview of what we know so far.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"‘呃──没有时间了。我就把已知的情报简短地告诉大家吧。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"『呃──沒有時間了。我就把已知的情報簡短地告訴大家吧。』",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00148",
		linknext = "0081_00150",
		line = 2079,
	},
	["0081_00150"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00217", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0100", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“According to NASSA, the cause of Hale-Fuck comet’s shattering is gravitational force.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"‘根据NAKA的情报，哈梅彗星之所以像那样分裂，是受到引力的影响。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"『根據NAKA的情報，哈梅彗星之所以像那樣分裂，是受到引力的影響。』",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00149",
		linknext = "0081_00151",
		line = 2094,
	},
	["0081_00151"] = {
		{"fg", file="schubert_01f_00001", file1="schubert_01f_00102", file2="schubert_01f_00223", file4="schubert_01f_00401", file5="schubert_01f_00501", path=":fg/schubert_01f/", id=30, ch="シューベルト", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0324", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Gravitational force? But my data said that it shouldn’t be affected by Earth’s gravity given the distance.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“您说引力……！？可是，根据我的资料所说，按照哈梅彗星的距离，应该不可能受到地球的引力影响才对啊……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「您說引力……！？可是，根據我的資料所說，按照哈梅彗星的距離，應該不可能受到地球的引力影響才對啊……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00150",
		linknext = "0081_00152",
		line = 2107,
	},
	["0081_00152"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The crowd is stirred from Schubert’s words.",
					{"rt2"},
				},
			},
			cn = {
				{
					"听到舒伯特的话，群众一片哗然。",
					{"rt2"},
				},
			},
			tw = {
				{
					"聽到舒伯特的話，群眾一片嘩然。",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00151",
		linknext = "0081_00153",
		line = 2117,
	},
	["0081_00153"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00205", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0101", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Please calm down and listen. What affected the comet is not the gravity you’re all familiar with.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"‘请各位冷静下来听我说。影响了彗星的，并不是各位所知道的一般的引力。……如果要更精确地来称呼──’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"『請各位冷靜下來聽我說。影響了彗星的，並不是各位所知道的一般的引力。……如果要更精確地來稱呼──』",
					{"rt2"},
				},
			},
		},
		linkback = "0081_00152",
		linknext = "0081_00154",
		line = 2132,
	},
