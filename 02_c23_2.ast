	["0054_00269"] = {
		{"se", id=0, loop=0, file="se_b033"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It lands between the two of us, showing a breaking news report on its screen.",
					{"rt2"},
				},
			},
			cn = {
				{
					"落在两人之间的平板画面播放了临时新闻的视频。",
					{"rt2"},
				},
			},
			tw = {
				{
					"落在兩人之間的平板畫面播放了臨時新聞的影片。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00268",
