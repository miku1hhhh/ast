			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Enough drivel! I’ve hoped for that so many times, wished for it so many times, but it never appeared!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“因为这样的玩笑话！！我无数次的期待着、无数次的渴望着，但是从来都没有实现过！！”",
					{"rt2"},
