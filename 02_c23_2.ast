			},
			cn = {
				{
					name = {"淳之介"},
					"“既然这样为何要把我叫来──？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「既然這樣為何要把我叫來──？」",
