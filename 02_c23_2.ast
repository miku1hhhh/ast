		text = {
			vo = {
				{"vo", file="mizuhiki0258", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Shut up! Everything tries to exclude me from what’s considered normal, whether it’s malicious disdain or pushy goodwill! It all takes away a place where I can be me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“给我闭嘴！不管是那侮辱般的恶意！或是强加而来的善意！一切都将我从普通人中给排除了！夺走了我的容身之处！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「給我閉嘴！不管是那侮辱般的惡意！或是強加而來的善意！一切都將我從普通人中給排除了！奪走了我的容身之處！」",
					{"rt2"},
				},
			},
		},
