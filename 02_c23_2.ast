		text = {
			vo = {
				{"vo", file="mizuhiki0243", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“All they want is a way to make money! Don’t you lump me in with them! I fight for my sake alone, and I’m not letting anyone get in my way!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“别把我和那些赚钱的家伙混为一谈！我只为了我自己战斗！才不会被任何认给阻碍！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「別把我和那些賺錢的傢伙混為一談！我只為了我自己戰鬥！才不會被任何認給阻礙！」",
					{"rt2"},
				},
			},
		},
