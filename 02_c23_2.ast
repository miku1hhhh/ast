	["0054_00253"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’m woozy from all the attacks I’ve taken to the head. The world wobbles before my eyes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我摇晃着被瞄准的头部，感觉世界都摇晃。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我搖晃著被瞄準的頭部，感覺世界都搖晃。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00252",
		linknext = "0054_00254",
