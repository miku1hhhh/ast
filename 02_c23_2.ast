			},
			cn = {
				{
					name = {"淳之介"},
					"“美岬……对这边的我来说，肯定是需要笑容的。请用你天生的幽默来逗这边的我笑吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「美岬……對這邊的我來說，肯定是需要笑容的。請用你天生的幽默來逗這邊的我笑吧。」",
					{"rt2"},
				},
			},
		},
