	["0054_00256"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I guess that goes to show just how much the two of us are alike...",
					{"rt2"},
				},
			},
			cn = {
				{
					"就这一点，那家伙和我也太过于相似了──",
					{"rt2"},
				},
			},
			tw = {
				{
					"就這一點，那傢伙和我也太過於相似了──",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00255",
