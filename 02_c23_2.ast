	["0054_00345"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file3="jun_01f_00307", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You can only go so far if you live life on your own! If you’ve given up on trying to get others to understand you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“独自一人生活的人是有极限的！特别是那些已经放弃被理解的人！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「獨自一人生活的人是有極限的！特別是那些已經放棄被理解的人！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00344",
		linknext = "0054_00346",
		line = 4898,
	},
