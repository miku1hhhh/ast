	["0054_00108"] = {
		{"cgact", file="cgact", id=29, act="stopact", lv=29, x=0, y=0},
		{"cgdel", id=29, lv=29, time=300, alphadel=1, evmaskoff=1, sync=0, rule="eff_008r_00000"},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don’t you think you need to make an effort to find people who will understand you?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“难道不觉个有必要努力地找出能理解自己的人嘛！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「難道不覺個有必要努力地找出能理解自己的人嘛！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00107",
		linknext = "0054_00109",
		line = 154,
	},
	["0054_00109"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That’s the kind of thing a kid who doesn’t want to grow up does, you know! Moaning on and on about the people around you without ever putting in that kind of work first!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果连努力都不肯，周围的人也会渐渐地感到不满吧，只有长不大的孩子才会这么想！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果連努力都不肯，周圍的人也會漸漸地感到不滿吧，只有長不大的孩子才會這麼想！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00108",
		linknext = "0054_00110",
		line = 165,
	},
	["0054_00110"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What kind of little brat are you, flailing around in the hopes that it’ll make the people around you listen?! That’s not how a grown adult acts!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是屁孩嘛！！一生气就不听周围的人说的话，这一点都不成熟喔！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是屁孩嘛！！一生氣就不聽周圍的人說的話，這一點都不成熟喔！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00109",
