	["0054_00255"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This battle is going far longer than I originally imagined.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这场战斗比预期的还要来的更冗长。",
					{"rt2"},
