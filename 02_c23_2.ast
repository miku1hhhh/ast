	["0054_00571"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00211", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...Because of everything that happened on the mainland, I imagine that the unrest she caused won’t get too much media attention.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……因为本岛发生的事件，水引所引起的骚动并不会有太多的报导吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……因為本島發生的事件，水引所引起的騷動並不會有太多的報導吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00570",
		linknext = "0054_00572",
