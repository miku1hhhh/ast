			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Now you sound just like those extremist activists who want everything to be solved all at once! You’re no different at all from them!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“想一口气都解决所有问题，是极端运动家都有的共通点！你和那些家伙没啥不同！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「想一口氣都解決所有問題，是極端運動家都有的共通點！你和那些傢伙沒啥不同！」",
					{"rt2"},
				},
			},
		},
