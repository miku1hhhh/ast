		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file3="jun_01f_00306", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Legally speaking, what Mizuhiki did is unforgivable. We could easily expect the police to punish her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“从法律上来说，水引是做了无可饶恕的事情。就算是被警察抓了也是没办法的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「從法律上來說，水引是做了無可饒恕的事情。就算是被警察抓了也是沒辦法的事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00575",
		linknext = "0054_00577",
		line = 9330,
	},
	["0054_00577"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file3="jun_01f_00301", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I’m not asking you all to get what she did. I won’t ask you to force yourselves to understand.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我不会要求每个人都要了解他所做的事情，也不希望勉强大家去理解。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我不會要求每個人都要了解他所做的事情，也不希望勉強大家去理解。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00576",
		linknext = "0054_00578",
		line = 9342,
	},
	["0054_00578"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file3="jun_01f_00309", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
