	},
	["0054_00254"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’ve landed again and again on my left knee. I can barely feel my leg below it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"反复地的左膝几乎没有了知觉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"反復地的左膝幾乎沒有了知覺。",
