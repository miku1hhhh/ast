		{"fg", mode=-1, id=17, ch="armor17", ch_origin="armor", lv=17, time=0, sync=0},
		{"bg", id=27, file="aci012801-1", x=0, y=0, path=":cg/aci/", lv=27, ev=1, bx=800, by=450},
		{"bg", id=27, file="aci012801-1", x=0, y=0, path=":cg/aci/", lv=27, ev=1, time=300, sync=0, rule="eff_009_00000", a_chr60=1, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0224", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“No amount of working out is going to cure you of that! It just keeps taking a toll on your body! You’ll never be able to beat me!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“无论怎样进行肌肉训练,这些都是永远不会消失的！都会积累在身体里！那么要战胜我是不可能的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「無論怎樣進行肌肉訓練,這些都是永遠不會消失的！都會積累在身體裡！那麽要戰勝我是不可能的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00256",
		linknext = "0054_00258",
		line = 3288,
	},
	["0054_00258"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’m at an overwhelming disadvantage in a fight where we repeatedly take off and land again.",
					{"rt2"},
				},
			},
			cn = {
				{
					"反复飞行和降落的战斗方式，我处于压倒性的劣势。",
					{"rt2"},
				},
			},
			tw = {
				{
					"反復飛行和降落的戰斗方式，我處於壓倒性的劣勢。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00257",
		linknext = "0054_00259",
		line = 3298,
	},
	["0054_00259"] = {
