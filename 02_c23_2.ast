	["0054_00261"] = {
		{"cgdel", id=18, lv=18, time=300, alphadel=1, evmaskoff=1, sync=0, rule="eff_008r_00000"},
		{"cgdel", id=27, lv=27, time=300, alphadel=1, evmaskoff=1, sync=0, rule="eff_008r_00000"},
		{"fg", file="armor_01m_00001", path=":fg/armor_01m/", id=17, lv=17, head="armor_01m", ch_origin="armor", ch="armor17", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00216", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=17, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I’m not... the only one... who’s fighting!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“还在战斗的……并非只有……我一个人而已──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「還在戰鬥的……並非只有……我一個人而已──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00260",
		linknext = "0054_00262",
		line = 3336,
	},
	["0054_00262"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00203", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“My comrades... they’re all around this island... all around Japan... and they’re fighting too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在这座岛中……哈啊……在整个日本都有伙伴──在战斗着。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在這座島中……哈啊……在整個日本都有夥伴──在戰鬥著。」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00261",
		linknext = "0054_00263",
		line = 3348,
	},
	["0054_00263"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0225", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Don’t be ridiculous... I’m settling this here! You’re going to be defeated, while I’m going to destroy Seiran Island and the perverted sex law!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“什么蠢话……就在这里做了解吧！将你给击败，我要将青蓝岛和变态条例给破坏殆尽！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「什麼蠢話……就在這裡做了解吧！將你給擊敗，我要將青藍島和變態條例給破壞殆盡！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00262",
		linknext = "0054_00264",
		line = 3360,
	},
	["0054_00264"] = {
		{"bg", id=27, file="aci010601-1", x=0, y=0, path=":cg/aci/", lv=27, ev=1, bx=800, by=450},
		{"bg", id=27, file="aci010601-1", x=0, y=0, path=":cg/aci/", lv=27, ev=1, time=300, sync=0, rule="eff_009_00000", a_chr60=1, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0226", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Even if you did defeat me, the whole country will hear about this riot! The seeds of unrest have been planted across Japan! Nobody’s going to want to have perverted sex anymore!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“反之，就算我被打败了，这场骚动也会传遍全国，不安的种子肯定会一直残留在日本各地！再也没有人想要变态作爱了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「反之，就算我被打敗了，這場騷動也會傳遍全國，不安的種子肯定會一直殘留在日本各地！再也沒有人想要變態作愛了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00263",
		linknext = "0054_00265",
		line = 3374,
	},
	["0054_00265"] = {
		{"cgdel", id=27, lv=27, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=27, file="aci010701-1", x=0, y=0, path=":cg/aci/", lv=27, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0227", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“And in that case, the perverted sex law might as well be done for! I’m getting my vengeance no matter how you might struggle! Hahaha! Mwahahahaha!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“那样的话，变态条例也就不可能再继续下去了！无论你在怎么挣扎，我的复仇都会实现的！哈哈哈，呼哈哈哈哈哈──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「那樣的話，變態條例也就不可能再繼續下去了！無論你在怎麼掙扎，我的復仇都會實現的！哈哈哈，呼哈哈哈哈哈──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00264",
		linknext = "0054_00266",
		line = 3390,
	},
