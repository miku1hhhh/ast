			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...You’ve used suicide attacks, the ultimate way to force compliance, in your attempt to reject conformity! The outcome of this battle was decided the moment you did that!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“──试图拒绝同调压力的你，却使用了最强大的同调压力当必杀技！在那个时候就已经分出胜负了！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「──試圖拒絕同調壓力的你，卻使用了最強大的同調壓力當必殺技！在那個時候就已經分出勝負了！！」",
					{"rt2"},
				},
			},
		},
