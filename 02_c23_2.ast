	},
	["0054_00270"] = {
		{"se", id=5, stop=1, time=1000},
		{"cgact", file="cgact", act="表示アクション", alpha=0, id=1, lv=1, time=500, alphadel=1, style="reset"},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0115", path=":vo/", ch="gmob"},
			},
			ja = {
				{
					name = {"モブ女A", "アナウンサー"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Announcer"},
					"“We interrupt this program for a news bulletin. Protests have broken out across the nation regarding the recently passed Lewd Code.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "播报员"},
					"‘在这里为您拨到一则临时新闻。针对前几天通过的〝超变态法〞，各地同时举行了示威活动。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "播報員"},
					"『在這裡為您撥到一則臨時新聞。針對前幾天通過的〝超變態法〞，各地同時舉行了示威活動。』",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00269",
		linknext = "0054_00271",
		line = 3457,
	},
	["0054_00271"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0116", path=":vo/", ch="gmob"},
			},
			ja = {
				{
					name = {"モブ女A", "アナウンサー"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Announcer"},
					"“These activities have been particularly intense in the Tokyo area, resulting in a string of injuries. If this continues, it will be Japan’s largest post-war—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "播报员"},
					"‘尤其是位在东京的活动格外的激烈，陆续出现不少受伤的人，再这样下去将会成为日本战后最大规模的──’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "播報員"},
					"『尤其是位在東京的活動格外的激烈，陸續出現不少受傷的人，再這樣下去將會成為日本戰後最大規模的──』",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00270",
		linknext = "0054_00272",
		line = 3469,
	},
	["0054_00272"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0075", path=":vo/", ch="gmob"},
			},
			ja = {
				{
					name = {"モブ女C", "デモの中心人物らしき女性"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "Ringleader-esque Protester"},
					"“Say no to the Lewd Code! Stop encouraging sexual exploitation! The Prime Minister needs to step down!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "像示威核心人物的女性"},
					"‘反对日本变态法！！！绝不容忍性剥削！总理给我下台──’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "像示威核心人物的女性"},
					"『反對日本變態法！！！絕不容忍性剝削！總理給我下台──』",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00271",
		linknext = "0054_00273",
		line = 3481,
	},
	["0054_00273"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The voices of the feminists who once ran amok on the island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是曾经在岛上大闹的女权主义者的声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是曾經在島上大鬧的女權主義者的聲音。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00272",
		linknext = "0054_00274",
		line = 3491,
	},
	["0054_00274"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Alarming images play on the screen, with Molotov cocktails being thrown at the National Diet. Even the Self-Defense Force has been mobilized.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后画面变的混乱，国会议堂被丢掷汽油弹，自卫队也出动维持秩序。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後畫面變的混亂，國會議堂被丟擲汽油彈，自衛隊也出動維持秩序。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00273",
		linknext = "0054_00275",
		line = 3501,
	},
	["0054_00275"] = {
		{"se", id=5, loop=1, file="se_d026", vol=60},
		{"bg", id=27, file="aci012101-1", x=0, y=0, path=":cg/aci/", lv=27, ev=1, bx=800, by=450},
		{"bg", id=27, file="aci012101-1", x=0, y=0, path=":cg/aci/", lv=27, ev=1, time=300, sync=0, rule="eff_009_00000", a_chr60=1, bx=800, by=450},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0228", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“So what’s your point?! This is the exact kind of chaos I wanted! Yes, keep going! Keep suffering! And then, your half-assed beliefs about what’s normal will be...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“这到底是在做什么──？这些象征着我所渴望的混沌啊！再混乱一点、在更痛苦一点！然后再用一般人暧昧不明的考虑方式──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「這到底是在做什麼──？這些象徵著我所渴望的混沌啊！再混亂一點、在更痛苦一點！然後再用一般人曖昧不明的考慮方式──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00274",
		linknext = "0054_00276",
		line = 3516,
	},
	["0054_00276"] = {
		{"cgdel", id=20, lv=20, time=0, alphadel=1},
		{"cgdel", id=27, lv=27, time=0, alphadel=1, evmaskoff=1},
		{"fg", file="armor_01m_00001", path=":fg/armor_01m/", id=17, lv=17, head="armor_01m", ch_origin="armor", ch="armor17", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"bg", id=1, file="bg29_3_00000", x=0, y=0, lv=1, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"transitiontime", time=300},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00203", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=1, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Just think about it, Akino. This is happening across the country. Money’s been spent, and it’s happening all at once, almost like someone’s behind it all...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“想像一下，秋野。这是在全国各地都发生的事情。仿佛就是有人集结大家，花了钱一起──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「想像一下，秋野。這是在全國各地都發生的事情。彷彿就是有人集結大家，花了錢一起──」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00275",
		linknext = "0054_00277",
		line = 3536,
	},
	["0054_00277"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Someone who fanned the flames of these protests.",
					{"rt2"},
				},
			},
			cn = {
				{
					"引爆这个示威游行的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"引爆這個示威遊行的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00276",
		linknext = "0054_00278",
		line = 3546,
	},
	["0054_00278"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Someone who tossed enough money around to lead the public.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是个挥霍金钱并煽动人心的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是個揮霍金錢並煽動人心的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00277",
		linknext = "0054_00279",
		line = 3556,
	},
	["0054_00279"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There has to be someone like that here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是理所当然般的存在。",
