			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But I at least want all of you... to accept her for who she is.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“只是，只有你们──希望你们能允许她的存在。”",
