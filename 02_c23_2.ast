	["0054_00355"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Isn’t it because you wanted someone to make you stop? Because you wanted someone to get you to quit?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“难道不是为了想被阻止吗，难道说不是想被劝退嘛！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「難道不是為了想被阻止嗎，難道說不是想被勸退嘛！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00354",
