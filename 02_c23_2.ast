					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Isn’t it because you felt like living with someone in the same place, the same space, the same world?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“难道没想过跟谁一起生活在同个地方、同个空间或同个世界嘛！？”",
