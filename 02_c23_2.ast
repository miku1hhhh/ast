	["0054_00252"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’ve also taken more damage, as the one fighting with my unarmored body.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而用自身肉体去对战的我所受到的伤害更大。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而用自身肉體去對戰的我所受到的傷害更大。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00251",
