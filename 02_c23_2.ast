	["0054_00313"] = {
		{"cgact", file="cgact", id=29, act="stopact", lv=29, x=0, y=0},
		{"cgdel", id=29, lv=29, time=300, alphadel=1, evmaskoff=1, sync=0, rule="eff_008r_00000"},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“‘The shining woman visible from afar’—I’m saying it describes your heart perfectly!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“〝远看起来更耀眼的女人〞──我说的是代表你的心情啦！”",
