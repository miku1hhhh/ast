	["0054_00294"] = {
		{"cgdel", id=27, lv=27, time=300, alphadel=1, evmaskoff=1, sync=0, rule="eff_010_00000"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The incident in the past where an online activist tried to raise awareness, only for their actions to be taken over by grifters in the name of feminism.",
					{"rt2"},
				},
			},
			cn = {
				{
					"以前在网上的启蒙活动已经被赚钱的女权主义所取代。",
					{"rt2"},
				},
			},
			tw = {
				{
					"以前在網上的啟蒙活動已經被賺錢的女權主義所取代。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00293",
		linknext = "0054_00295",
		line = 3749,
	},
	["0054_00295"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I came to think that the individual at the center of this all, who made their exit having lost all hope, was Mizuhiki Akino.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且我觉得身陷在绝望漩涡中的人──就是秋野水引。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且我覺得身陷在絕望漩渦中的人──就是秋野水引。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00294",
		linknext = "0054_00296",
		line = 3759,
	},
	["0054_00296"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s a valid theory if Akino is the person I think.",
					{"rt2"},
				},
			},
			cn = {
				{
					"若是我猜测的人确定是秋野的话，那么就能实现那个假设。",
					{"rt2"},
				},
			},
			tw = {
				{
					"若是我猜測的人確定是秋野的話，那麼就能實現那個假設。",
