	["0054_00314"] = {
		{"bg", id=29, file="aci011101-1", x=0, y=0, path=":cg/aci/", lv=29, ev=1, bx=800, by=450},
		{"bg", id=29, file="aci011101-1", x=0, y=0, path=":cg/aci/", lv=29, ev=1, time=300, sync=0, rule="eff_009_00000", a_chr60=1, bx=800, by=450},
		{"cgact", file="cgact", id=29, act="浮遊", loop=-1, size=2.5, time=50, ease="easeinout_sine", lv=29, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0234", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Look at you, discriminating at the drop of a hat! And what about you, with your Ariadne’s thread?! You’re the kind of man who’s useless without a woman guiding him along, aren’t you!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“就这样立刻歧视了呢！你这家伙才是跟Ariadne的丝线一样，没有女孩子牵着你的手，就什么也做不了的男人吧！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「就這樣立刻歧視了呢！你這傢伙才是跟Ariadne的絲線一樣，沒有女孩子牽著你的手，就什麼也做不了的男人吧！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00313",
		linknext = "0054_00315",
		line = 4143,
	},
	["0054_00315"] = {
		{"cgact", file="cgact", id=29, act="stopact", lv=29, x=0, y=0},
		{"cgdel", id=29, lv=29, time=300, alphadel=1, evmaskoff=1, sync=0, rule="eff_008r_00000"},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Stop shoehorning men and women into everything! What’s making you understand the world in such a twisted way?! You’re only ever going to see it as full of malice like that!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不要马上就扯男女啦！为什么那么扭曲地去感受事物呢？那样只会觉得整个世界充满恶意！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
