			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“You said you had an idea of how to make it back... and that you could do it with Akino’s help. But how...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“虽说回去的方法，已经有头绪了……说是有秋野君在的话就能办到……但是，该怎么做呢──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「雖說回去的方法，已經有頭緒了……說是有秋野君在的話就能辦到……但是，該怎麼做呢──」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00504",
		linknext = "0054_00506",
		line = 8447,
	},
	["0054_00506"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00211", file4="jun_01f_00403", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
			ja = {
