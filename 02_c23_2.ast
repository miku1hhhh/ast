					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“I hate this world, with all its platitudes! I hate it, I hate it, I hate it, I hate it! I hate everything about it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“我痛恨这个华而不实的世界！痛恨痛恨痛恨痛恨痛恨痛恨痛恨！我痛恨这世界上所有的事情！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「我痛恨這個華而不實的世界！痛恨痛恨痛恨痛恨痛恨痛恨痛恨！我痛恨這世界上所有的事情！！」",
					{"rt2"},
				},
			},
		},
