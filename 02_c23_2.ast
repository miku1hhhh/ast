				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Who knows, it might only get small little writeups online. In that case, it shouldn’t turn into anything too serious.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“若是有的话，应该也只是很小的网络新闻也说不定。要真是那样，应该也不是什么大事吧。”",
