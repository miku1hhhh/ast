		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0260", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Do you know how many times I’ve been hurt because I came out of that shell?! How many wounds I’ve suffered?! So I should stop defending myself and just die?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“要是没有封闭在空壳之中，要承受多少次折磨！？要承受多少次的伤害！？难道要我不自我保护而去死嘛！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「要是沒有封閉在空殼之中，要承受多少次折磨！？要承受多少次的傷害！？難道要我不自我保護而去死嘛！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00440",
		linknext = "0054_00442",
		line = 7099,
	},
