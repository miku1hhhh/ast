	["0054_00280"] = {
		{"se", id=5, stop=1, time=1000},
		{"bg", id=22, file="pm3_00001", x=0, y=0, lv=22, path=":cg/pm3/", ev=1},
		{"bg", id=20, file="blackback_00000", x=0, y=0, lv=20, path=":bg/", sync=0, ax=805, ay=455, bx=-5, by=-5},
		{"transitiontime", time=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0117", path=":vo/", ch="gmob"},
			},
			ja = {
				{
					name = {"モブ女A", "アナウンサー"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Announcer"},
					"“Let us turn to an expert on the subject. Mister Sakimori, what exactly is going to come of this?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "播报员"},
					"‘那就让我们听听专家的意见吧。驻防先生，这到底是怎么一回事呢──？’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "播報員"},
					"『那就讓我們聽聽專家的意見吧。駐防先生，這到底是怎麼一回事呢──？』",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00279",
		linknext = "0054_00281",
		line = 3582,
	},
	["0054_00281"] = {
		{"fg", file="sakimori_01m_00001", file2="sakimori_01m_00204", file3="sakimori_01m_00301", path=":fg/sakimori_01m/", id=21, lv=21, head="sakimori_01m", ch_origin="防人老人", ch="防人老人21", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=1000},
		{"text"},
		text = {
			vo = {
				{"vo", file="sakimori0058", path=":vo/", ch="sakimori"},
			},
			ja = {
				{
					name = {"防人老人"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"防人老人", "Sakimori"},
					"“We should consider this a case of what you’d call feminism gone amok, though I’ve never seen it get this bad before. Some are even suggesting that the Lewd Code be reconsidered...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"防人老人", "驻防老人"},
					"‘我们应该将其视为是女权主义的暴走。不过却从未见过这么大规模的事件。也有人提出是否要再度检视变态法──’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"防人老人", "駐防老人"},
					"『我們應該將其視為是女權主義的暴走。不過卻從未見過這麼大規模的事件。也有人提出是否要再度檢視變態法──』",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00280",
		linknext = "0054_00282",
		line = 3596,
	},
	["0054_00282"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I hear the old man’s affected tone of voice.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可以听到老人有点刻意的声音。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可以聽到老人有點刻意的聲音。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00281",
		linknext = "0054_00283",
		line = 3606,
	},
	["0054_00283"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Every news program is covering this uprising.",
					{"rt2"},
				},
			},
			cn = {
				{
					"报导中到处都是这样的暴动。",
					{"rt2"},
				},
			},
			tw = {
				{
					"報導中到處都是這樣的暴動。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00282",
		linknext = "0054_00284",
		line = 3616,
	},
	["0054_00284"] = {
		{"fgact", ch="防人老人21", id=21, lv=21, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"cgact", file="cgact", act="表示アクション", alpha=0, id=20, lv=20, time=300, alphadel=1, style="reset"},
		{"cgact", file="cgact", act="表示アクション", alpha=0, id=22, lv=22, time=300, alphadel=1, style="reset", x=0, y=0},
		{"bgm", file="bgm39", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00203", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=22, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Do you get it, Akino? The meaning in what you’re doing was in causing a crisis that disrupted our regular, peaceful lives!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“──明白了吗，秋野，你的所作所为就是会给平稳的生活带来恐慌！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「──明白了嗎，秋野，妳的所作所為就是會給平穩的生活帶來恐慌！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00283",
		linknext = "0054_00285",
		line = 3635,
	},
	["0054_00285"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file3="jun_01f_00307", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=22},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But if an even bigger disturbance breaks out, your actions lose the impact they would have had! They won’t even make the news!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是，如果再发生更加激烈的暴动的话，你的行动也就没那么大冲击性，更不会被报导了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是，如果再發生更加激烈的暴動的話，你的行動也就沒那麼大衝擊性，更不會被報導了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00284",
		linknext = "0054_00286",
		line = 3647,
	},
	["0054_00286"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If she wanted to destroy our daily lives, sow chaos, and cause our values to crumble...",
					{"rt2"},
				},
			},
			cn = {
				{
					"若是想破坏日常生活、引起纷乱而导致价值观崩坏的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"若是想破壞日常生活、引起紛亂而導致價值觀崩壞的話。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00285",
		linknext = "0054_00287",
		line = 3657,
	},
	["0054_00287"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...She would have had to do it while we still led our normal lives.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那么就要在一般日常生活中发生。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那麼就要在一般日常生活中發生。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00286",
		linknext = "0054_00288",
		line = 3667,
	},
	["0054_00288"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Doing it all in the midst of such intense events weakens their shock.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过一定有更激烈的事件发生的话，那么冲击性就会减弱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過一定有更激烈的事件發生的話，那麼衝擊性就會減弱。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00287",
		linknext = "0054_00289",
		line = 3677,
	},
	["0054_00289"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It turns her point into something completely different.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那么所谓的主张，就会被其他事物给替代了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那麼所謂的主張，就會被其他事物給替代了。",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00288",
		linknext = "0054_00290",
		line = 3687,
	},
	["0054_00290"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file3="jun_01f_00307", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=22},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Now they’re just going to think that what you did was just a part of these extremist riots!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样子，你做过的事情，全都会被当作是过激派人士暴行的一部分罢了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
