		{"cgact", file="cgact", id=26, act="浮遊横", loop=-1, size=5, time=50, ease="easeinout_sine", lv=26, x=-105, y=-155},
		{"cgact", file="cgact", id=27, act="浮遊横", loop=-1, size=5, time=50, ease="easeinout_sine", lv=27, x=-200, y=0},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...How long are you going to keep this up?! You know that people are always going to keep misunderstanding you like this!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“──到底要持续这件事到何时！再这样下去，你会被大家永远的误解的！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「──到底要持續這件事到何時！再這樣下去，妳會被大家永遠的誤解的！？」",
					{"rt2"},
				},
			},
		},
		linknext = "0054_00100",
		line = 31,
	},
	["0054_00100"] = {
		{"bg", id=29, file="aci011801-1", x=0, y=0, path=":cg/aci/", lv=29, ev=1, bx=800, by=450},
		{"bg", id=29, file="aci011801-1", x=0, y=0, path=":cg/aci/", lv=29, ev=1, time=300, sync=0, rule="eff_009_00000", a_chr60=1, bx=800, by=450},
		{"cgact", file="cgact", id=29, act="浮遊横", loop=-1, size=2.5, time=50, ease="easeinout_sine", lv=29, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0202", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“As if they’d ever try to understand in the first place! It’s impossible for humans to get others to understand them! You sound like a child!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“明明就没有想要理解的意思！无论是谁都了解不了我的，不可能有那样的人存在！这就是小朋友理论──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「明明就沒有想要理解的意思！無論是誰都瞭解不了我的，不可能有那樣的人存在！這就是小朋友理論──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00099",
		linknext = "0054_00101",
		line = 46,
	},
	["0054_00101"] = {
		{"cgact", file="cgact", id=29, act="stopact", lv=29, x=0, y=0},
		{"cgdel", id=29, lv=29, time=300, alphadel=1, evmaskoff=1, sync=0, rule="eff_008r_00000"},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You don’t need everyone to understand you! Everyone has thoughts and feelings they want to keep to themselves!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也不需要让所有人都知道！人总有想要隐藏起来的事情啊！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也不需要讓所有人都知道！人總有想要隱藏起來的事情啊！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00100",
		linknext = "0054_00102",
		line = 59,
	},
	["0054_00102"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The idea of the whole world truly understanding you is something out a fairytale!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所有人都能正确的理解这样的事，就是痴人说梦──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所有人都能正確的理解這樣的事，就是癡人說夢──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00101",
		linknext = "0054_00103",
		line = 70,
	},
	["0054_00103"] = {
		{"bg", id=29, file="aci011801-1", x=0, y=0, path=":cg/aci/", lv=29, ev=1, bx=800, by=450},
		{"bg", id=29, file="aci011801-1", x=0, y=0, path=":cg/aci/", lv=29, ev=1, time=300, sync=0, rule="eff_009_00000", a_chr60=1, bx=800, by=450},
		{"cgact", file="cgact", id=29, act="浮遊横", loop=-1, size=2.5, time=50, ease="easeinout_sine", lv=29, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0203", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“That’s right, and it’s why I’m crushing you all! Nothing annoys me worse than someone patting themselves on the back for spouting a bunch of daydreams!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“正因为是痴人说梦，所以才要击碎！没有什么比自以为是的妄想更令人生气了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「正因為是痴人說夢，所以才要擊碎！沒有什麽比自以為是的妄想更令人生氣了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00102",
		linknext = "0054_00104",
		line = 85,
	},
	["0054_00104"] = {
		{"cgact", file="cgact", id=29, act="stopact", lv=29, x=0, y=0},
		{"cgdel", id=29, lv=29, time=300, alphadel=1, evmaskoff=1, sync=0, rule="eff_008r_00000"},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But it’s still possible to find acceptance! Even if we don’t understand each other, all we need is mutual respect!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是我可以容许你！就算理解不了也会互相尊重！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但是我可以容許妳！就算理解不了也會互相尊重！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00103",
		linknext = "0054_00105",
		line = 98,
	},
	["0054_00105"] = {
		{"bg", id=29, file="aci012201-1", x=0, y=0, path=":cg/aci/", lv=29, ev=1, bx=800, by=450},
		{"bg", id=29, file="aci012201-1", x=0, y=0, path=":cg/aci/", lv=29, ev=1, time=300, sync=0, rule="eff_009_00000", a_chr60=1, bx=800, by=450},
		{"cgact", file="cgact", id=29, act="浮遊横", loop=-1, size=2.5, time=50, ease="easeinout_sine", lv=29, x=0, y=0},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0204", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“So you’re saying we should just ignore each other with a smile?! So you want minorities to be just as isolated as they’ve always been!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“这就是所谓和善的无视彼此吧！？果然少数族群还是孤独的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「這就是所謂和善的無視彼此吧！？果然少數族群還是孤獨的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0054_00104",
		linknext = "0054_00106",
		line = 113,
	},
	["0054_00106"] = {
		{"cgact", file="cgact", id=29, act="stopact", lv=29, x=0, y=0},
		{"cgdel", id=29, lv=29, time=300, alphadel=1, evmaskoff=1, sync=0, rule="eff_008r_00000"},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That’s why you need to find people whose understanding you truly want!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这就是为什么需要一个发自内心理解自己的人存在啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這就是為什麼需要一個發自內心理解自己的人存在啊！」",
