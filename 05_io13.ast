		},
		text = {
			vo = {
				{"vo", file="rin0254", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Yes, I’m sure you feel splendid about it. Although your future seems quite bleak since you probably won’t be seeing any combat with the law becoming so tepid.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“……呵……你就尽情花丸吧。条例变得这么不温不火，战斗什么的想必以后几乎不会发生了，我想郁子前辈前途黯淡自然不在话下……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「……呵……妳就盡情花丸吧。條例變得這麼不溫不火，戰鬥什麼的想必以後幾乎不會發生了，我想郁子前輩前途黯淡自然不在話下……」",
					{"rt2"},
				},
			},
		},
		linkback = "0077_00093",
		linknext = "0077_00095",
		line = 1423,
	},
	["0077_00095"] = {
