			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Seriously? For some strange reason it sure loves picking on Rin. It’s smooth sailing with Ikuko, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“真的喔？虽然不知道是为什么，但是那孩子很喜欢欺负凛酱呢……虽然对有子同学到是亲得有点诡异。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「真的喔？雖然不知道是為什麼，但是那孩子很喜歡欺負凜醬呢……雖然對有子同學到是親得有點詭異。」",
					{"rt2"},
				},
			},
		},
