				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“When my time to shine arrives, I shall give you the privilege to say that you were once my underling!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“等到我花丸的那一天，就特别赐给你能够吹嘘‘我是那孩子的小弟喔’的权利吧！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「等到我花丸的那一天，就特別賜給妳能夠吹噓『我是那孩子的小弟喔』的權利吧！」",
					{"rt2"},
				},
			},
		},
