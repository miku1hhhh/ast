		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00103", file2="ikuko_01m_00221", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=395, y=-5},
