	},
	["0077_00040"] = {
		{"bgm", file="bgm11", vol=100},
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00213", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0084", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“You could say that. Seiran Island is still undergoing change, and I need to see it with my own eyes. There’s no way I can get the full picture just by doing paperwork in my office.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“算是吧。毕竟青蓝岛现在也正在不断变化……不能只靠桌面上的纸张，如果不亲眼看看岛上的模样，总会有意所不能及的地方嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「算是吧。畢竟青藍島現在也正在不斷變化……不能只靠桌面上的紙張，如果不親眼看看島上的模樣，總會有意所不能及的地方嘛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0077_00039",
		linknext = "0077_00041",
		line = 550,
	},
