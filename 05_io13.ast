			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“That hero’s my boyfriend by the way.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“你说的英雄是我的男朋友喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「妳說的英雄是我的男朋友喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0077_00092",
		linknext = "0077_00094",
