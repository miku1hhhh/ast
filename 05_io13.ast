	["0077_00039"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00219", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Governor Hitoura! Fancy indeed. Out for a walk?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“仁浦、县长──确实是奇遇呢。您出来散步吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
