		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rather than getting mad at Ikuko’s ill-mannered greetings, Senba merely smiles back and continues throwing daggers in turn.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然郁子一上来讲话就那么没礼貌，可是仙波小姐不但没有生气，而且还笑容满面地展开了高度依赖脉络的对话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然郁子一上來講話就那麼沒禮貌，可是仙波小姐不但沒有生氣，而且還笑容滿面地展開了高度依賴脈絡的對話。",
					{"rt2"},
				},
			},
		},
		linkback = "0077_00023",
		linknext = "0077_00025",
		line = 334,
	},
	["0077_00025"] = {
