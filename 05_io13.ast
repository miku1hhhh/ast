					{"rt2"},
				},
			},
			en = {
				{
					"Ikuko has said, and I quote, “Girls who don’t take life seriously like Kokie annoy me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					"据郁子所说，“像光姬酱那种一辈子都撒娇过关的类型总是让我无名火起嘛──”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"據郁子所說，「像光姬醬那種一輩子都撒嬌過關的類型總是讓我無名火起嘛──」。",
					{"rt2"},
				},
			},
