		{"text"},
		delay = {
			[2700] = {
				{"fg", file="rin_01m_00002", file1="rin_01m_00101", file2="rin_01m_00212", path=":fg/rin_01m/", id=14, lv=14, head="rin_01m", ch_origin="凛", ch="凛14", mw="mw", sync=0, timestamp=23, delay2=2700, mode=3, x=-605, y=-5},
