		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Susuko did not know me in World A, but learning that I’m Ikuko’s boyfriend got her interested in me enough to start conversations. Now we’re good friends.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我和丝丝子在A世界原本没有见过──可是她一听说我是郁子的交往对象，马上兴致勃勃地跑来找我搭话，现在已经完全跟我混熟了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我和絲絲子在A世界原本沒有見過──可是她一聽說我是郁子的交往對象，馬上興致勃勃地跑來找我搭話，現在已經完全跟我混熟了。",
					{"rt2"},
				},
			},
		},
