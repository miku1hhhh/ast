	["0012_00024"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00102", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“To be honest, this won’t be easy... But there is a way to come out on top.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“老实说如果事情变成这样会很痛苦⋯⋯不过多少还是有能赢的方法。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「老實說如果事情變成這樣會很痛苦⋯⋯不過多少還是有能贏的方法。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00023",
		linknext = "0012_00025",
		line = 373,
	},
	["0012_00025"] = {
		{"evset", file="kcg03", set="kcg03", path=":ev/kcg03/"},
		{"evset", file="kcg0300222-1", set="kcg030022", path=":ev/kcg030022/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg0300222-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", lv=18, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The key is Hinami, their DPS dealer. I don’t know how, but that chair of hers always lands perfectly on your shins, and it deflects bullets... She’s able to do real damage with it somehow.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“关键是主力输出的雏见。她那个椅子不知道为什么既可以攻击又可以防守⋯⋯可以制造出很大的伤害。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「關鍵是主力輸出的雛見。她那個椅子不知道為什麼既可以攻擊又可以防守⋯⋯可以製造出很大的傷害。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00024",
		linknext = "0012_00026",
		line = 392,
	},
	["0012_00026"] = {
		{"evset", file="kcg03", set="kcg03", path=":ev/kcg03/"},
		{"evset", file="kcg0300242-1", set="kcg030024", path=":ev/kcg030024/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg0300242-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0284", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Yeah, that really is weird... She got me on the bridge of my nose with her chair, and I hadn’t felt pain like that since the time I left a grain of rice uneaten in my bowl at home.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“啊，那个真的不可思议呢⋯⋯郁的鼻梁上撞到那把椅子上的时候感觉到的痛啊，差不多程度的痛还是在老家没有把饭吃完被揍的时候。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「啊，那個真的不可思議呢⋯⋯郁的鼻樑上撞到那把椅子上的時候感覺到的痛啊，差不多程度的痛還是在老家沒有把飯吃完被揍的時候。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00025",
		linknext = "0012_00027",
		line = 411,
	},
	["0012_00027"] = {
		{"evset", file="kcg03", set="kcg03", path=":ev/kcg03/"},
		{"evset", file="kcg0300244-1", set="kcg030024", path=":ev/kcg030024/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg0300244-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0269", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Well, Hinami has loved that folding chair ever since she was little... I imagine there’s some kind of miraculous power residing within it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“因为那是雏见从小就珍藏的钢管椅嘛⋯⋯上面应该寄宿着神奇的力量吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「因為那是雛見從小就珍藏的鋼管椅嘛⋯⋯上面應該寄宿著神奇的力量吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00026",
		linknext = "0012_00028",
		line = 430,
	},
	["0012_00028"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00210", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, that is possible... She is the holy mother, after all...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没错，有可能⋯⋯因为雏见是‘圣母’嘛⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒錯，有可能⋯⋯因為雛見是『聖母』嘛⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00027",
		linknext = "0012_00029",
		line = 442,
	},
	["0012_00029"] = {
		{"evset", file="kcg03", set="kcg03", path=":ev/kcg03/"},
		{"evset", file="kcg0300224-1", set="kcg030022", path=":ev/kcg030022/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg0300224-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0285", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Holy, hole-y, or whore-ly, it’s all the same to me. What do we need to do?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“不管是圣母还是淫母还是艳母都随便啦，我们到底要怎么对付她？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「不管是聖母還是淫母還是艷母都隨便啦，我們到底要怎麼對付她？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00028",
		linknext = "0012_00030",
		line = 461,
	},
	["0012_00030"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Generally speaking, we’ll take her two-on-one. One person attacks, then the other keeps her from landing a counterattack with her chair.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“要对付雏见基本上得二对一才行。一个负责进攻，另一个负责挡住椅子的反弹。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「要對付雛見基本上得二對一才行。一個負責進攻，另一個負責擋住椅子的反彈。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00029",
		linknext = "0012_00031",
		line = 473,
	},
	["0012_00031"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s the only possible way to deal with Hinami.",
					{"rt2"},
				},
			},
			cn = {
				{
					"除此之外，没有任何可以对付雏见的办法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"除此之外，沒有任何可以對付雛見的辦法。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00030",
		linknext = "0012_00032",
		line = 483,
	},
	["0012_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Assigning two of the FS’s Big Three to her will make the fight a close one, though.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过，如果从FS三巨头分出两人一组对付她的话，应该可以势均力敌。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過，如果從FS三巨頭分出兩人一組對付她的話，應該可以勢均力敵。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00031",
		linknext = "0012_00033",
		line = 493,
	},
	["0012_00033"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I think Touka and Ikuko are suited for that. Touka can use coins to restrict her movement, and Ikuko is a close-quarters combat specialist.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对付那种人，还是桐香和郁子比较适合。桐香可以用硬币控制动作，而郁子擅长近身格斗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對付那種人，還是桐香和郁子比較適合。桐香可以用硬幣控制動作，而郁子擅長近身格鬥。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00032",
		linknext = "0012_00034",
		line = 505,
	},
	["0012_00034"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ikuko will bring her into close combat, then we prevent the chair counter with coins. If it’s the other way around, bait a chair shot and block it with your sword. That should minimize the damage.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“郁子先进行近战，桐香用硬币弹开椅子的反击。反过来椅子触发反击的时候，用刀挡开。这样就能降低她的攻击效果。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「郁子先進行近戰，桐香用硬幣彈開椅子的反擊。反過來椅子觸發反擊的時候，用刀擋開。這樣就能降低她的攻擊效果。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00033",
		linknext = "0012_00035",
		line = 517,
	},
	["0012_00035"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Rei and I will figure out a way to deal with the rest of the members.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“剩下的成员，就由我跟礼前辈来想办法应付。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「剩下的成員，就由我跟禮前輩來想辦法應付。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00034",
		linknext = "0012_00036",
		line = 529,
	},
	["0012_00036"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file3="jun_01f_00302", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It should be easy for us to work together since she’s teaching me how to fight. I think we can do this, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“礼前辈教会我战斗技巧之后我们要配合就比较易。这样一来，我们两个一起上应该没问题吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「禮前輩教會我戰鬥技巧之後我們要配合就比較易。這樣一來，我們兩個一起上應該沒問題吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00035",
		linknext = "0012_00037",
		line = 541,
	},
	["0012_00037"] = {
