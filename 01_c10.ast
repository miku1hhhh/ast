		text = {
			vo = {
				{"vo", file="ikuko0281", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Same here. Everyone being so motivated is a lifesaver. I think they could do this even without me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“在这里也一样吧──还能提高大家的积极性。这样就算没有郁在也没问题了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「在這裡也一樣吧──還能提高大家的積極性。這樣就算沒有郁在也沒問題了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00001",
		linknext = "0012_00003",
		line = 47,
	},
	["0012_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We’ve all gathered in the bath to give our interim reports.",
					{"rt2"},
				},
			},
			cn = {
				{
					"众人聚集的大浴场，就是我们临时汇报的地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"眾人聚集的大浴場，就是我們臨時匯報的地方。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00002",
		linknext = "0012_00004",
		line = 57,
	},
	["0012_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Meeting elsewhere would take time, plus we’re able to relax here.",
					{"rt2"},
					"We’re even able to bring up topics we wouldn’t want others to hear. It’s a perfect location.",
					{"rt2"},
				},
			},
			cn = {
				{
					"反正在其他地方集合也很花时间、这边又能放松、就算连讲秘密也都没问题，",
					{"rt2"},
					"这个地点非常完美。",
					{"rt2"},
				},
			},
			tw = {
				{
					"反正在其他地方集合也很花時間、這邊又能放鬆、就算連講秘密也都沒問題，",
					{"rt2"},
					"這個地點非常完美。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00003",
		linknext = "0012_00005",
		line = 71,
	},
	["0012_00005"] = {
		{"evset", file="kcg03", set="kcg03", path=":ev/kcg03/"},
