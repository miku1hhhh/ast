			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“C-Cheer up, Darling! We know you were hard at work commanding the unit...! And you were amazing as a shield during the final battle!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“振、振作点亲爱的！郁跟大家都很清楚你是他们的司令塔喔⋯⋯！在最终决战也是作为护盾非常活跃的喔！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「振、振作點親愛的！郁跟大家都很清楚你是他們的司令塔喔⋯⋯！在最終決戰也是作為護盾非常活躍的喔！」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00018",
