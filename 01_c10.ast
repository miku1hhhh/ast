		{"text"},
		text = {
			vo = {
				{"vo", file="rei0266", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“...And that’s it for my progress report. A lot has happened, but it seems like we’re managing to make progress.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“⋯⋯这样等等，关于现场的汇报就这些了，虽然发生了很多事、不过应该是可以顺利进行的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「⋯⋯這樣等等，關於現場的匯報就這些了，雖然發生了很多事、不過應該是可以順利進行的。」",
					{"rt2"},
				},
			},
		},
		linknext = "0012_00002",
		line = 24,
	},
	["0012_00002"] = {
