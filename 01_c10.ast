	["0012_00052"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It never hurts for everyone’s motivation to be high before combat.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管怎样，总之得要在开战之前提高大家的积极性。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管怎樣，總之得要在開戰之前提高大家的積極性。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00051",
		linknext = "0012_00053",
		line = 830,
	},
	["0012_00053"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And if you want to motivate someone, you praise them. That’s the steadfast rule.",
					{"rt2"},
				},
			},
			cn = {
				{
					"总之想要提高战斗力的话，首先就是要好好夸奖她们。这是铁则。",
					{"rt2"},
				},
			},
			tw = {
				{
					"總之想要提高戰鬥力的話，首先就是要好好誇獎她們。這是鐵則。",
					{"rt2"},
				},
			},
		},
