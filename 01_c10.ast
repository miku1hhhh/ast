	["0012_00054"] = {
		{"evset", file="kcg03", set="kcg03", path=":ev/kcg03/"},
		{"evset", file="kcg0300431-1", set="kcg030043", path=":ev/kcg030043/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg0300431-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0224", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I am surprised that you’re able to come up with such concrete strategies, Tachibana. I was convinced you were the type that always improvises.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不过，前辈居然提出如此具体的战略建议，真是令人惊讶。我还以为你是临机应变的类型呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不過，前輩居然提出如此具體的戰略建議，真是令人驚訝。我還以為你是臨機應變的類型呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00053",
		linknext = "0012_00055",
		line = 859,
	},
	["0012_00055"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file3="jun_01f_00309", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
