				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Tokie’s pretty simple for the most part... I’m not lucky enough to be that way, though. I still don’t know about this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“因为桐香酱也是很单纯嘛⋯⋯我就没办法相信事情会这么简单。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「因為桐香醬也是很單純嘛⋯⋯我就沒辦法相信事情會這麼簡單。」",
					{"rt2"},
				},
			},
		},
