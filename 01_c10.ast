			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No, Miss Touka! Junnosuke’s self-conscious about the fact that his job was redundant basically all the time except for our final battle!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不行喔桐香大人，淳之介是担心自己除了最终决战以外，是个谁都可以取代的角色……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不行喔桐香大人，淳之介是擔心自己除了最終決戰以外，是個誰都可以取代的角色……！」",
					{"rt2"},
				},
			},
		},
