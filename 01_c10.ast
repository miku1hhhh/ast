		text = {
			vo = {
				{"vo", file="tohka0217", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I see. It really is such a complete unit now that I’m looking at it again... Oh, but wait? You never mentioned your role.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“原来如此，这样看来是个相当完整的的部队呢⋯⋯哎？前辈你的职责是什么呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「原來如此，這樣看來是個相當完整的的部隊呢⋯⋯哎？前輩你的職責是什麼呢？」",
					{"rt2"},
				},
			},
		},
