				{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1, timestamp=2, delay2=7800},
				{"bg", id=18, file="kcg0300112-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, timestamp=2, delay2=7800, bx=800, by=450},
			},
			[7799] = {
				{"transitiontime", time=300, timestamp=2, delay2=7800},
			},
		},
		text = {
			vo = {
				{"vo", file="tohka0216", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“That leaves the capture of the former NLNS, or the current ‘Birds of a Feather,’ as our only problem. As far as our strategy, Tachibana is...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“那么现在的问题就只剩要确保旧NLNS、现在的‘Tori公’成员，这一点而已。至于我们的作战计划，前辈你──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「那麼現在的問題就只剩要確保舊NLNS、現在的『Tori公』成員，這一點而已。至於我們的作戰計劃，前輩你──」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00004",
		linknext = "0012_00006",
		line = 94,
	},
	["0012_00006"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, I’m thinking about it. You can leave it to me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯嗯，我正在想呢。交给我吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯嗯，我正在想呢。交給我吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00005",
		linknext = "0012_00007",
		line = 106,
	},
	["0012_00007"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Roles in the NLNS are assigned as follows. Nanase acts as recon. Hinami is the attacker. Fumino provides long-range support. Misaki is on transport, and Asane handles electronic warfare.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“NLNS的职责分配长这样：奈奈濑是侦查员。雏见负责攻击。远距离支援由文乃负责。运载是美岬。电子战的部分是麻沙音。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「NLNS的職責分配長這樣：奈奈瀨是偵查員。雛見負責攻擊。遠距離支援由文乃負責。運載是美岬。電子戰的部分是麻沙音。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00006",
		linknext = "0012_00008",
		line = 118,
	},
	["0012_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It’s going to become extremely difficult for us to coordinate if they get support in the form of electronic warfare. I’m sure you’re all aware of that, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“要是加入电子战的支援的话，我们这边联络起来会非常困难。这点大家应该都了解吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「要是加入電子戰的支援的話，我們這邊聯絡起來會非常困難。這點大家應該都了解吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00007",
		linknext = "0012_00009",
		line = 129,
	},
	["0012_00009"] = {
		{"evset", file="kcg03", set="kcg03", path=":ev/kcg03/"},
		{"evset", file="kcg0300115-1", set="kcg030011", path=":ev/kcg030011/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg0300115-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0267", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“They’re a unit that specializes in sowing confusion on the ground. They’ve given me trouble so many times in the past...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“专门来搅局的一群人啊。我已经在这上面吃过很多次亏了⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「專門來攪局的一群人啊。我已經在這上面吃過很多次虧了⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00008",
		linknext = "0012_00010",
		line = 148,
	},
	["0012_00010"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“When acting as a team, Nanase generally will jump in first as a scout. Hinami follows up to deal damage, then Fumino and Asane act if the situation calls for it. Misaki brings up the rear.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“团体行动也是，基本是由侦查员奈奈濑先探察。然后是雏乃负责攻击。依照状况文乃跟麻沙音也会接着上场。美岬负责断后。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「團體行動也是，基本是由偵查員奈奈瀨先探察。然後是雛乃負責攻擊。依照狀況文乃跟麻沙音也會接著上場。美岬負責斷後。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00009",
		linknext = "0012_00011",
		line = 160,
	},
	["0012_00011"] = {
		{"evset", file="kcg03", set="kcg03", path=":ev/kcg03/"},
		{"evset", file="kcg0300145-1", set="kcg030014", path=":ev/kcg030014/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg0300145-1", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0282", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“So Misaki carries anyone who might be lagging behind along with her. Pretty solid plan, I’d say.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“有人迟到的话就让美岬酱去载。还蛮合理的嘛？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「有人遲到的話就讓美岬醬去載。還蠻合理的嘛？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00010",
		linknext = "0012_00012",
		line = 179,
	},
	["0012_00012"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“This is the pattern used when escaping, though. Combat is different.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这边说的是逃走的情况，如果是战斗情况的话又是另一回事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這邊說的是逃走的情況，如果是戰鬥情況的話又是另一回事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00011",
		linknext = "0012_00013",
		line = 191,
	},
	["0012_00013"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Nanase continues to take the lead, and Hinami is still the main attacker. This creates chaos among the enemy unit and draws their attention.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“首先侦查员一样是奈奈濑没变。主攻手也是雏见没错。她们会瓦解敌方的队伍，让他们聚集在一起。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「首先偵查員一樣是奈奈瀨沒變。主攻手也是雛見沒錯。她們會瓦解敵方的隊伍，讓他們聚集在一起。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00012",
		linknext = "0012_00014",
		line = 203,
	},
	["0012_00014"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Using this opening, Misaki will take Fumino to a sniping point, often by bike. Once that happens, it’s just a matter of time before the enemy is wiped out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“趁这个时间点美岬就会用自行车之类的工具载文乃到狙击点去。之后就只要等着敌方被她歼灭就可以了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「趁這個時間點美岬就會用自行車之類的工具載文乃到狙擊點去。之後就只要等著敵方被她殲滅就可以了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00013",
		linknext = "0012_00015",
		line = 215,
	},
	["0012_00015"] = {
