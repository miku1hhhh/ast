					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“One moment, Tachibana. Though I think this is a splendid formation, what about the matter of Fumino?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“稍等一下，前辈。虽然我觉得这样分配很棒，但是文乃要怎么对付呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「稍等一下，前輩。雖然我覺得這樣分配很棒，但是文乃要怎麼對付呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00040",
		linknext = "0012_00042",
		line = 647,
	},
	["0012_00042"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0221", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Her bullets are capable of coming at us from beyond our field of recognition. There’s almost nothing we can do to combat them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“她的子弹是从我的感知范围外射来的，我几乎没有办法反制。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「她的子彈是從我的感知範圍外射來的，我幾乎沒有辦法反制。」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00041",
