					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“This all rides on you and your unbelievable close-quarters combat abilities. I’m counting on you, Ikuko.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是因为有近战最强的你在，所以事情才能变得这么单纯。所以就要拜托你了，郁子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是因為有近戰最強的妳在，所以事情才能變得這麼單純。所以就要拜託妳了，郁子。」",
					{"rt2"},
				},
			},
		},
