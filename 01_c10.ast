	["0012_00022"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00102", file2="jun_01f_00226", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, thanks a bunch! You three did beat the crap out of me, though!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“真是谢谢你们！！！虽然我都已经被你们戳到体无完肤了！！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「真是謝謝妳們！！！雖然我都已經被你們戳到體無完膚了！！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00021",
		linknext = "0012_00023",
		line = 351,
	},
	["0012_00023"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I did do the same to them... With all the others, of course.",
					{"rt2"},
				},
			},
			cn = {
				{
					"算了，就算是被戳到体无完肤⋯⋯至少是被她们所有人一起。",
					{"rt2"},
				},
			},
			tw = {
				{
					"算了，就算是被戳到體無完膚⋯⋯至少是被她們所有人一起。",
					{"rt2"},
				},
			},
		},
		linkback = "0012_00022",
