			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“This time around is special. Normally I left everything to Nanase. You’d better not keep relying on me, okay?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这次比较特别，通常是奈奈濑处理一切。所以其他时候别想靠我。”",
