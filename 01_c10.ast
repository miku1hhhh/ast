		text = {
			vo = {
				{"vo", file="tohka0218", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I’m sorry, Tachibana. I never realized it weighed so heavily on your mind that you didn’t have much of an effect in combat... Cheer up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“对不起，我不知道前辈你对在基本战斗中派不上用场的这件事这么在意⋯⋯你要打起精神喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「對不起，我不知道前輩你對在基本戰鬥中派不上用場的這件事這麼在意⋯⋯你要打起精神喔。」",
					{"rt2"},
				},
			},
		},
