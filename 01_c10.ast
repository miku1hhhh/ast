			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“This is a matter of compatibility, not strength. These are our optimal assignments.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这跟强弱没有关系，而是属性的问题。这种配置是最好的。”",
