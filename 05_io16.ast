	},
	["0080_00138"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00101", file2="ikuko_01m_00224", path=":fg/ikuko_01m/", id=10, lv=6, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1777", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I always thought it was his fault that my mom died, and that I had to suffer and inherit the Onabuta style.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“因为我觉得妈妈之所以会死掉、我之所以不得不承受那些痛苦好继承女部田流，全都是他的错……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「因為我覺得媽媽之所以會死掉、我之所以不得不承受那些痛苦好繼承女部田流，全都是他的錯……」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00137",
		linknext = "0080_00139",
		line = 2106,
	},
	["0080_00139"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00101", file2="ikuko_01m_00228", path=":fg/ikuko_01m/", id=10, lv=6, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
