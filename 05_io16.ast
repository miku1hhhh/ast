	["0080_00071"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00211", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1760", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I think Rin is doing fine. She’s probably up to something weird again. You’d be surprised how much guts she has.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“虽然我觉得凛酱应该不用担心就是了。大概是不学乖地又在做什么怪事了吧？那孩子虽然看起来是那样，却是相当有毅力的类型嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「雖然我覺得凜醬應該不用擔心就是了。大概是不學乖地又在做什麼怪事了吧？那孩子雖然看起來是那樣，卻是相當有毅力的類型嘛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00070",
		linknext = "0080_00072",
		line = 1039,
	},
	["0080_00072"] = {
		{"fg", file="mizuhiki_01m_00002", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00209", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="mizuhiki0557", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“She’s the only B-level first grader who was able to pass the FS entrance test on the first try, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“记得……是在女部田同学之后唯一一个在FS的入队考试里合格的B等部1年级生对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「記得……是在女部田同學之後唯一一個在FS的入隊考試裡合格的B等部1年級生對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00071",
		linknext = "0080_00073",
		line = 1053,
	},
	["0080_00073"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file3="ikuko_01m_00312", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1761", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Yup. Except that, unlike me who aced the test, she was foaming at her mouth at the end.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“对。唉，虽然说凛酱合格的时候口吐白沫，跟轻松合格超强的郁郁酱大不相同就是了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「對。唉，雖然說凜醬合格的時候口吐白沫，跟輕鬆合格超強的郁郁醬大不相同就是了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00072",
		linknext = "0080_00074",
		line = 1068,
	},
	["0080_00074"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00219", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0322", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“But nonetheless, older siblings tend to worry about their younger siblings. That’s just how it works.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“说是这么说，果然做兄姐的，就是会忍不住担心弟妹啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「說是這麼說，果然做兄姊的，就是會忍不住擔心弟妹啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00073",
		linknext = "0080_00075",
		line = 1082,
	},
	["0080_00075"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file3="ikuko_01m_00314", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1762", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I guess. I mean, Junnosuke was so worried about Asane even when he was on the other side.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“这样啊……确实淳之介君在另一边的时候，也那么担心麻沙音酱呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「這樣啊……確實淳之介君在另一邊的時候，也那麼擔心麻沙音醬呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00074",
		linknext = "0080_00076",
		line = 1097,
