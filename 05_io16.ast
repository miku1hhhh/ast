				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“I’ve heard that in area C for homosexuals, there are those who are called ‘the watchers’ who like to just watch same-sex couples. Is she one of those?”",
					{"rt2"},
				},
			},
			cn = {
