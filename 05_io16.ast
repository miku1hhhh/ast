	["0080_00055"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00201", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0318", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Well, perhaps I can ‘mingle’ with Junnosuke a little more as requested, but I really do have business to attend to.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“好啦。虽然我也很想应观众希望再跟淳之介调一会儿情──但是很不巧，我也差不多该离开了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「好啦。雖然我也很想應觀眾希望再跟淳之介調一會兒情──但是很不巧，我也差不多該離開了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00054",
		linknext = "0080_00056",
		line = 759,
	},
	["0080_00056"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00205", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1757", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Oh, that’s too bad. FS?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“哎呀，是这样吗……真遗憾。是FS的事情？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「哎呀，是這樣嗎……真遺憾。是FS的事情？」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00055",
		linknext = "0080_00057",
		line = 774,
	},
	["0080_00057"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00202", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0319", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Tomorrow’s my little sister’s birthday. I haven’t been able to be with her since I joined FS, so I figured if I want to make her favorite pumpkin dishes, I should start on them today.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“不，明天是舍妹的生日。加入了FS以后就没什么时间陪她，所以我想趁今天多做几道她最喜欢的南瓜料理。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「不，明天是舍妹的生日。加入了FS以後就沒什麼時間陪她，所以我想趁今天多做幾道她最喜歡的南瓜料理。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00056",
		linknext = "0080_00058",
		line = 789,
	},
	["0080_00058"] = {
		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file2="ikuko_02m_00207", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
