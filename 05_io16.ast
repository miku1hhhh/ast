	["0080_00049"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She says she doesn’t know, so we have no business determining anything about her anyway.",
					{"rt2"},
				},
			},
			cn = {
				{
					"既然本人都说不知道了，外人也不好妄下结论吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"既然本人都說不知道了，外人也不好妄下結論吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00048",
		linknext = "0080_00050",
		line = 669,
	},
	["0080_00050"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She was once treated as a man, but was unable to fully become one. I’m sure there are thing only she can grasp.",
					{"rt2"},
				},
			},
			cn = {
				{
					"过去被当成男子养育，结果还是无法打从心底成为男子的郁子──肯定也有些情绪，是只有当事人才能够理解的吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"過去被當成男子養育，結果還是無法打從心底成為男子的郁子──肯定也有些情緒，是只有當事人才能夠理解的吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00049",
		linknext = "0080_00051",
		line = 679,
	},
	["0080_00051"] = {
		{"fg", file="mizuhiki_01m_00002", file1="mizuhiki_01m_00101", file2="mizuhiki_01m_00209", file4="mizuhiki_01m_00401", path=":fg/mizuhiki_01m/", id=15, lv=15, head="mizuhiki_01m", ch_origin="水引", ch="水引15", mw="mw", sync=0, mode=3, x=-605, y=-5},
