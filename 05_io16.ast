				},
			},
			tw = {
				{
					name = {"水引"},
					"「順帶一問……如果是我和橘君在一起，妳會有什麼感覺？」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00050",
		linknext = "0080_00052",
		line = 694,
