	["0080_00130"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00101", file2="ikuko_01m_00223", path=":fg/ikuko_01m/", id=10, lv=6, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1770", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“If I continue dating with you, we’ll probably get married, and then have kids.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“就这样和淳之介君交往下去……然后有一天结了婚……最后肯定，也会生小孩对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「就這樣和淳之介君交往下去……然後有一天結了婚……最後肯定，也會生小孩對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00129",
		linknext = "0080_00131",
		line = 1986,
	},
	["0080_00131"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00101", file3="ikuko_01m_00313", path=":fg/ikuko_01m/", id=10, lv=6, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1771", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I have so many bad memories from blood relatives. After I came to Seiran Island and met a lot of people, I ended up hating my dad and my grandpa.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“血脉相连的家族，我不好的回忆还比较多。来到青蓝岛之后，认识了许多人……父亲大人……爸爸和爷爷，也都变成了讨厌的对象。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「血脈相連的家族，我不好的回憶還比較多。來到青藍島之後，認識了許多人……父親大人……爸爸和爺爺，也都變成了討厭的對象。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00130",
		linknext = "0080_00132",
		line = 2001,
	},
	["0080_00132"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00101", file2="ikuko_01m_00223", path=":fg/ikuko_01m/", id=10, lv=6, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1772", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I just wondered if I would be all right. Maybe I’ll end up being hated by my own child someday too...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我总是会忍不住怀疑，我自己没问题吗？我……是不是迟早也会变成被自己的孩子讨厌的人呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我總是會忍不住懷疑，我自己沒問題嗎？我……是不是遲早也會變成被自己的孩子討厭的人呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00131",
		linknext = "0080_00133",
		line = 2016,
	},
	["0080_00133"] = {
