					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“By the way, what happens when you see Tachibana and I together?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“顺带一问……如果是我和橘君在一起，你会有什么感觉？”",
