		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0355", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“When I broke my hip after trying to give myself a rimjob, my sister was so dead worried about me that she called the insane asylum right away.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“我在挑战自舔肛门闪到腰的时候，姐姐也超担心地说着不要紧吗马上帮我叫来了黄色的救护车嘛……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「我在挑戰自舔肛門閃到腰的時候，姊姊也超擔心地說著不要緊嗎馬上幫我叫來了黃色的救護車嘛……」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00076",
		linknext = "0080_00078",
		line = 1132,
	},
	["0080_00078"] = {
