	["0080_00156"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You’ve cared for FS like a real family, haven’t you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“郁子不也把FS当成真正的家人一样珍惜吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「郁子不也把FS當成真正的家人一樣珍惜嗎？」",
					{"rt2"},
