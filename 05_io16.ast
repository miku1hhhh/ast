				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It’s totally personalized for you, and it’s spoken in my love’s voice. It’s the ultimate audio porn.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不仅音响肯定是完美的量身订做，而且还能让最喜欢的郁子低语给我听──正是究极的语音作品。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不僅音響肯定是完美的量身訂做，而且還能讓最喜歡的郁子低語給我聽──正是究極的語音作品。」",
					{"rt2"},
				},
			},
		},
