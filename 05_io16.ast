			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“Kiri! Have you seen Rin? You’re the same class as her, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“那个……雾酱！你最近有没有见到凛？雾酱跟她是同一班的对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「那個……霧醬！妳最近有沒有見到凜？霧醬跟她是同一班的對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00066",
		linknext = "0080_00068",
		line = 974,
	},
	["0080_00068"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobd0008", path=":vo/", ch="gmob"},
			},
			ja = {
				{
					name = {"モブ女D", "霧"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女D", "Kiri"},
					"“Oh, Hanamaru? Um, I was wondering where she was too, but... No, I haven’t seen her lately either, I guess...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女D", "雾"},
					"“花丸酱……？呃……我也很担心……可是最近，完全……没见到她……没有对吧，悟……你有见到吗……？我想也是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女D", "霧"},
					"「花丸醬……？呃……我也很擔心……可是最近，完全……沒見到她……沒有對吧，悟……妳有見到嗎……？我想也是……」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00067",
		linknext = "0080_00069",
		line = 986,
	},
	["0080_00069"] = {
