	["0080_00059"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Little sisters are one of those things you want to strangle and cuddle at the same time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哼……毕竟所谓妹妹，就是无比惹人生厌──但又无比惹人怜爱的存在嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哼……畢竟所謂妹妹，就是無比惹人生厭──但又無比惹人憐愛的存在嘛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00058",
