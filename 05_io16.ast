		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1791", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Sure you can. There are people who change diapers here. Besides, they say you need to think like a baby to raise one, so it’s perfect, isn’t it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“可以吧。毕竟也有帮对方把屎把尿的人嘛。而且你看，都说养小孩最重要的是要从婴儿的角度思考嘛。这不是刚刚好吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「可以吧。畢竟也有幫對方把屎把尿的人嘛。而且你看，都說養小孩最重要的是要從嬰兒的角度思考嘛。這不是剛剛好嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00178",
