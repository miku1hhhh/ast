				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So yeah... I just can’t get satisfied from any of the audio porn out there anymore. It has to be Ikuko’s voice.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“结果……导致我不管听什么语音作品，不是郁子的声音就觉得少了些什么。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「結果……導致我不管聽什麼語音作品，不是郁子的聲音就覺得少了些什麼。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00033",
		linknext = "0080_00035",
		line = 449,
	},
	["0080_00035"] = {
