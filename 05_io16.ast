			},
		},
		linkback = "0080_00155",
		linknext = "0080_00157",
		line = 2337,
	},
	["0080_00157"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00201", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And you cared for me so many times. Not just in battle, but when I was feeling down, too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而且你也帮了我好几次。不只是在战斗的时候。在我低落的时候，你一定会支持我。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而且妳也幫了我好幾次。不只是在戰鬥的時候。在我低落的時候，妳一定會支持我。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00156",
		linknext = "0080_00158",
		line = 2349,
	},
	["0080_00158"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
