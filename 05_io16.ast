			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“It’s so weird. Why would he tell her to get pregnant when there’s no way she will?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“很奇怪吧？明明绝对不可能怀孕，却总是说着‘怀孕吧喔啦’什么的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「很奇怪吧？明明絕對不可能懷孕，卻總是說著『懷孕吧喔啦』什麼的。」",
					{"rt2"},
				},
			},
		},
