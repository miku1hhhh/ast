	},
	["0080_00118"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I never thought about it, but there seems to be some kind of a seasonal element to sex in Seiran Island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然以前我没有特别去意识，但是青蓝岛上的变态性爱，或许也可以算是一种独有的风情吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然以前我沒有特別去意識，但是青藍島上的變態性愛，或許也可以算是一種獨有的風情吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00117",
		linknext = "0080_00119",
		line = 1834,
	},
	["0080_00119"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Like how we feel the seasons changing from the beauties of nature, they too feel the passing of time from all the moans.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就像风花雪月能让人感觉到季节更迭──今后，我或许也会从娇喘声之中感觉到时光流逝吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就像風花雪月能讓人感覺到季節更迭──今後，我或許也會從嬌喘聲之中感覺到時光流逝吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00118",
		linknext = "0080_00120",
		line = 1844,
	},
	["0080_00120"] = {
