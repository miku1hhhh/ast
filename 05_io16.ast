					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“Ah, I get it. You’ve been all about Onabuta lately. Makes me a bit jealous.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“啊啊──是这样啊。毕竟橘君跟女部田同学正打得火热嘛……让人有点忌妒呢──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「啊啊──是這樣啊。畢竟橘君跟女部田同學正打得火熱嘛……讓人有點忌妒呢──」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00034",
		linknext = "0080_00036",
		line = 467,
	},
	["0080_00036"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00203", file4="schubert_01m_00402", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0314", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“But there might be truth in what he’s talking about. The greatest sex-pop is perhaps the voice of your love.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“不过，这或许也算是一种真理也说不定。最为优秀的性-POP──难道不就是恋人的语音作品吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「不過，這或許也算是一種真理也說不定。最為優秀的性-POP──難道不就是戀人的語音作品嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00035",
		linknext = "0080_00037",
		line = 482,
	},
	["0080_00037"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00203", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
