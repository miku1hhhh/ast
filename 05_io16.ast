	["0080_00134"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00101", file2="ikuko_01m_00224", path=":fg/ikuko_01m/", id=10, lv=6, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1773", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“You think? You and Nakamura and Misaki all talk about how you love your siblings, but I just wonder if I can ever feel like that too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“是吗……淳之介君也好、中村君也好、美岬酱也好……大家都说兄弟姐妹很重要……可是我，真的会有打从心底那么想的那一天吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「是嗎……淳之介君也好、中村君也好、美岬醬也好……大家都說兄弟姊妹很重要……可是我，真的會有打從心底那麼想的那一天嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00133",
		linknext = "0080_00135",
		line = 2043,
	},
	["0080_00135"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00101", file2="ikuko_01m_00228", path=":fg/ikuko_01m/", id=10, lv=6, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1774", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“You know, I almost had a little brother. But I wished that he would never be born, and then... that’s exactly what happened.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我也……曾经可能有个弟弟的。可是，我想着要是他不要出生就好了……结果，真的成真了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我也……曾經可能有個弟弟的。可是，我想著要是他不要出生就好了……結果，真的成真了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00134",
		linknext = "0080_00136",
		line = 2058,
	},
	["0080_00136"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00101", file2="ikuko_01m_00206", path=":fg/ikuko_01m/", id=10, lv=6, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[12200] = {
				{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00101", file2="ikuko_01m_00223", path=":fg/ikuko_01m/", id=10, lv=6, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, timestamp=17, delay2=12200, mode=3, x=-5, y=-5},
			},
			[12199] = {
				{"transitiontime", time=300, timestamp=17, delay2=12200},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko1775", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“And now, I’m worried that I may become jealous of the baby. I’m worried that the baby will take all of your attention away from me...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“所以下一次……我会不会忌妒生下来的婴儿呢？会不会觉得淳之介君怎么都只顾着小孩呢……我很不安。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「所以下一次……我會不會忌妒生下來的嬰兒呢？會不會覺得淳之介君怎麼都只顧著小孩呢……我很不安。」",
					{"rt2"},
				},
			},
		},
		linkback = "0080_00135",
		linknext = "0080_00137",
		line = 2076,
	},
	["0080_00137"] = {
		{"fg", file="ikuko_01m_00002", file1="ikuko_01m_00101", file2="ikuko_01m_00214", path=":fg/ikuko_01m/", id=10, lv=6, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1776", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I never said this before, but... I always resented my little brother.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我之前一直没有说……其实我以前，一直很恨我的弟弟。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我之前一直沒有說……其實我以前，一直很恨我的弟弟。」",
					{"rt2"},
				},
			},
		},
