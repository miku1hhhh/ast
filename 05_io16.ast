					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It’s your darling telling you. There’s nothing to worry about.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不用担心。你最喜欢的亲爱的都这么说了，没有什么好不安的啦。”",
