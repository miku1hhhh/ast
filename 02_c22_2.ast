	},
	["0049_00094"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00209", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00209", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She quietly turns around and begins to ask a question.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她悄悄地转过身问道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她悄悄地轉過身問道。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00093",
		linknext = "0049_00095",
		line = 1437,
	},
	["0049_00095"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00214", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0825", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Even now, I believe that everyone has the right to take revenge.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“谁都有复仇的权利，我到现在也是这么认为的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「誰都有復仇的權利，我到現在也是這麼認為的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00094",
		linknext = "0049_00096",
		line = 1452,
	},
	["0049_00096"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00203", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0826", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“If you’ve been misunderstood, alienated, and disparaged... and you use the power you have to retaliate, I believe that to be a blameless act.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“被人误会、无法被理解、被人蔑视等等──若是有能力讨回公道的话，我想这种事不应该被责备才对。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「被人誤會、無法被理解、被人蔑視等等──若是有能力討回公道的話，我想這種事不應該被責備才對。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00095",
		linknext = "0049_00097",
		line = 1467,
	},
	["0049_00097"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00206", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0827", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“So if that’s the case, would you call this justified revenge?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“这样的话，这可以算是名正言顺的复仇吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「這樣的話，這可以算是名正言順的復仇吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00096",
		linknext = "0049_00098",
		line = 1482,
	},
	["0049_00098"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There’s no such thing as revenge that’s justified, Touka.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“复仇这种事，并没有所谓的正当性喔，桐香。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「復仇這種事，並沒有所謂的正當性喔，桐香。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00097",
		linknext = "0049_00099",
		line = 1494,
	},
