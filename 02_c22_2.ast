		linkback = "0049_00145",
		linknext = "0049_00147",
		line = 2034,
	},
	["0049_00147"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"To accept those who are in the minority.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只需要容许少数族群的存在的这件事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只需要容許少數族群的存在的這件事。",
					{"rt2"},
				},
