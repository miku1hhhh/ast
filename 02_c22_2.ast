	["0049_00190"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00204", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0832", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“And so I thought I just had to create that kind of environment. I thought that everyone would be happy in an environment that forced us to understand each other.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“所以只要做出这样的环境就可以了。只要有一个强制彼此互相理解的环境，那么大家一定就能会得幸福。我是这么想的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「所以只要做出這樣的環境就可以了。只要有一個強制彼此互相理解的環境，那麼大家一定就能會得幸福。我是這麼想的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00189",
		linknext = "0049_00191",
		line = 2616,
	},
	["0049_00191"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
