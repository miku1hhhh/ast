	},
	["0049_00153"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That was the battle we needed to fight.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们无论如何都得做的“奋斗”，就是这件事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們無論如何都得做的「奮鬥」，就是這件事。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00152",
		linknext = "0049_00154",
		line = 2104,
	},
	["0049_00154"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00207", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
