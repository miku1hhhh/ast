		text = {
			vo = {
				{"vo", file="nanase0128", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“This really drives home just how much of a numbers disadvantage we’re at... We won’t even be able to put up a proper fight like this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“虽然说早就知道了，不过我们这边的人数还真是压倒性的少呢⋯⋯连好好打一场的等级都到不了吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「雖然說早就知道了，不過我們這邊的人數還真是壓倒性的少呢⋯⋯連好好打一場的等級都到不了吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00014",
		linknext = "0049_00016",
		line = 254,
	},
	["0049_00016"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Misaki, how was SHO headquarters looking?”",
