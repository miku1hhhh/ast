	["0049_00193"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0834", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“We need to work toward making others understand us, and we must have the tolerance required to accept others.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“让其他人能够宽容地接受着我们为了被理解而做的努力──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「讓其他人能夠寬容地接受著我們為了被理解而做的努力──」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00192",
		linknext = "0049_00194",
		line = 2656,
	},
	["0049_00194"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但若⋯⋯",
					{"rt2"},
				},
			},
			tw = {
				{
					"但若⋯⋯",
					{"rt2"},
