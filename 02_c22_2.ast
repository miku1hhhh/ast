			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“If we destroy SHO headquarters as that happens—that should take care of all the Hamedoris at once.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“只要在时将SHO总部大楼一起破坏掉的话──也能把Hamedori君们一网打尽。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「只要在時將SHO總部大樓一起破壞掉的話──也能把Hamedori君們一網打盡。」",
					{"rt2"},
				},
			},
		},
