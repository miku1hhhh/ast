				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You’re really willing to part with the beating heart of the SHO, Governor?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“难道县知事要自己放弃掉SHO的心脏吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「難道縣知事要自己放棄掉SHO的心臟嗎？」",
