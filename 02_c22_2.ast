	["0049_00003"] = {
		{"fg", file="schubert_01m_00002", file2="schubert_01m_00203", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0199", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“While I’m unsure of where the Hamedoris are hidden, we can predict that their numbers will be divided like so if they wish to destroy the island in a single night.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“虽然不知道Hamedori君藏在哪里，想要一夜就完成破坏的话，战力分配估算起来应该会是这样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「雖然不知道Hamedori君藏在哪裡，想要一夜就完成破壞的話，戰力分配估算起來應該會是這樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00002",
		linknext = "0049_00004",
		line = 64,
	},
	["0049_00004"] = {
