	["0049_00110"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But even so, I reject what she’s doing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“──但就算这样，我也不能认同那家伙的行为。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「──但就算這樣，我也不能認同那傢伙的行為。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00109",
		linknext = "0049_00111",
		line = 1640,
	},
	["0049_00111"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Wishing for somebody’s happiness is something everyone in this world does.",
					{"rt2"},
				},
			},
			cn = {
				{
					"人啊⋯⋯不论是谁都会希望某个人能幸福。",
					{"rt2"},
				},
			},
			tw = {
				{
					"人啊⋯⋯不論是誰都會希望某個人能幸福。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00110",
		linknext = "0049_00112",
		line = 1650,
	},
	["0049_00112"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even Hitoura worked hard in the hopes of bringing joy to the people and the minority living on the island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦以在岛上生活的人与少数群体的幸福作为心愿而努力着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦以在島上生活的人與少數群體的幸福作為心願而努力著。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00111",
		linknext = "0049_00113",
		line = 1660,
	},
	["0049_00113"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even Sakimori kept on fighting all alone in order to defend the honor of his own daughter.",
					{"rt2"},
				},
			},
			cn = {
				{
					"驻防老人为了守护自己女儿的名义而持续孤军奋战。",
					{"rt2"},
				},
			},
			tw = {
				{
					"駐防老人為了守護自己女兒的名義而持續孤軍奮戰。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00112",
		linknext = "0049_00114",
		line = 1670,
	},
	["0049_00114"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even I kept going for my own sake. For the sake of protecting my comrades.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我为了自己、为了守护同伴们而持续前行。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我為了自己、為了守護同伴們而持續前行。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00113",
		linknext = "0049_00115",
		line = 1680,
	},
	["0049_00115"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even Touka, the leader of the FS. Even Rei, always busy with her work. Even Ikuko, who lives to fight.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管是带领FS的桐香，还是被工作追着跑的礼前辈，或者热爱战斗的郁子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管是帶領FS的桐香，還是被工作追著跑的禮前輩，或者熱愛戰鬥的郁子。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00114",
		linknext = "0049_00116",
		line = 1690,
	},
	["0049_00116"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We’re all the same in that sense.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大家其实都是一样的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"大家其實都是一樣的。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00115",
		linknext = "0049_00117",
		line = 1700,
	},
	["0049_00117"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We’re all born alike into this world, and we all live alike within it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们，都是用同样的方式，在这个世界被生下、在这个世界活着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們，都是用同樣的方式，在這個世界被生下、在這個世界活著。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00116",
		linknext = "0049_00118",
		line = 1710,
	},
	["0049_00118"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00207", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don’t think it’s an issue of numbers, or of who the majority is.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那一定是人数太多、大多数人的人都这样──问题并不在这里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那一定是人數太多、大多數人的人都這樣──問題並不在這裡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00117",
		linknext = "0049_00119",
		line = 1722,
	},
	["0049_00119"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We’re always fighting, regardless of any difference in numbers.",
					{"rt2"},
				},
			},
			cn = {
				{
					"与人数无关的，我们总是在战斗着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"與人數無關的，我們總是在戰鬥著。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00118",
		linknext = "0049_00120",
		line = 1732,
	},
	["0049_00120"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We’re fighting for something.",
					{"rt2"},
				},
			},
			cn = {
				{
					"总是为了某些理由而奋斗。",
					{"rt2"},
				},
			},
			tw = {
				{
					"總是為了某些理由而奮鬥。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00119",
		linknext = "0049_00121",
		line = 1742,
	},
	["0049_00121"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s why there’s no such thing as justified revenge.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以，具有正当性的复仇什么的，是不存在的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以，具有正當性的復仇什麼的，是不存在的。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00120",
		linknext = "0049_00122",
		line = 1752,
	},
	["0049_00122"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It would mean having to pass a judgment on the act of revenge.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那只是，为复仇的行为标上了善恶的标签罢了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那只是，為復仇的行為標上了善惡的標籤罷了。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00121",
		linknext = "0049_00123",
		line = 1762,
	},
	["0049_00123"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There is no good or bad when it comes to revenge.",
					{"rt2"},
				},
			},
			cn = {
				{
					"复仇本身，并没有善恶之分。",
					{"rt2"},
				},
			},
			tw = {
				{
					"復仇本身，並沒有善惡之分。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00122",
		linknext = "0049_00124",
		line = 1772,
	},
	["0049_00124"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So even if you do have the right to get revenge, you can’t talk about how justifiable it may be.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以拥有复仇的权利、有复仇的正当性这种事是不存在的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以擁有復仇的權利、有復仇的正當性這種事是不存在的。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00123",
		linknext = "0049_00125",
		line = 1782,
	},
	["0049_00125"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Because it’s an act that squanders the fact that you live in the same world as the rest of us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为那只是一种，对于我们相安无事在同一个世界里生活这件事，毫无帮助的行为。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為那只是一種，對於我們相安無事在同一個世界裡生活這件事，毫無幫助的行為。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00124",
		linknext = "0049_00126",
		line = 1792,
	},
	["0049_00126"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00218", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0828", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“In which case—do you mean to say that living selfishly is the only way to rid ourselves of this kind of hatred?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“若是如此──只能像这样，为了排解怨憎而以自私利己的方式生活了，是这样吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「若是如此──只能像這樣，為了排解怨憎而以自私利己的方式生活了，是這樣嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00125",
		linknext = "0049_00127",
		line = 1807,
	},
	["0049_00127"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Maybe.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也许吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「也許吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00126",
		linknext = "0049_00128",
		line = 1819,
	},
	["0049_00128"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"All of us living in separate worlds, according to our own values.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不为了大同的世界而生，而是为了自己的价值而生。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不為了大同的世界而生，而是為了自己的價值而生。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00127",
		linknext = "0049_00129",
		line = 1829,
	},
	["0049_00129"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But that would just be so sad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过，这多少也有点悲哀。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過，這多少也有點悲哀。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00128",
		linknext = "0049_00130",
		line = 1839,
	},
	["0049_00130"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Constantly displaying a kind of justifiability that we all know doesn’t exist...",
					{"rt2"},
				},
			},
			cn = {
				{
					"不断夸示着根本不存在的正当性──",
					{"rt2"},
				},
			},
			tw = {
				{
					"不斷誇示著根本不存在的正當性──",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00129",
		linknext = "0049_00131",
		line = 1849,
	},
	["0049_00131"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...As you exercise your right to revenge would just be so sad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"以权力之名实复仇之实，真的是非常悲哀的一件事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"以權力之名實復仇之實，真的是非常悲哀的一件事。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00130",
		linknext = "0049_00132",
		line = 1859,
	},
	["0049_00132"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But you can cut off that hatred at its root.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过，将憎恨的根源扼杀是做得到的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過，將憎恨的根源扼殺是做得到的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00131",
		linknext = "0049_00133",
		line = 1871,
	},
	["0049_00133"] = {
