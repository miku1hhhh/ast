				},
			},
		},
		linkback = "0049_00044",
		linknext = "0049_00046",
		line = 725,
	},
	["0049_00046"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00210", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0066", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“...I’m the one to blame for bringing all of this upon us. And in that case, I need to be the one to make it right.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“⋯⋯会导致这样的情况都是因为我的关系。所以，我得要自己做出决断才行──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「⋯⋯會導致這樣的情況都是因為我的關係。所以，我得要自己做出決斷才行──」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00045",
		linknext = "0049_00047",
		line = 740,
	},
	["0049_00047"] = {
