	["0049_00019"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00203", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0821", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Our memories have already become quite overwritten at this point too. Even if we do win, we still don’t have a way to go back to—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“而且，对我们的记忆覆盖也已经进展到一定的程度了。就算我们赢了，要是没有回去的方法──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「而且，對我們的記憶覆蓋也已經進展到一定的程度了。就算我們贏了，要是沒有回去的方法──」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00018",
		linknext = "0049_00020",
		line = 313,
	},
	["0049_00020"] = {
