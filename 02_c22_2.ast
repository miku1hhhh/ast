		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1104", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Walking around with you like this does take me back, Darling. We used to fight all the time in the forest in our original world.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“不过，像这样跟亲爱的一起走在路上还真是令人怀念呢。在原本的世界时，我们也很常在森林里对战呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「不過，像這樣跟親愛的一起走在路上還真是令人懷念呢。在原本的世界時，我們也很常在森林裡對戰呢。」",
					{"rt2"},
				},
			},
		},
