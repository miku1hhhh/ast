		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00206", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0064", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“At the end of the day, he’s going after SHO headquarters. If we hold out here and defend, both he and all the Hamedoris will eventually converge on the site.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“他的目标肯定是SHO总部大楼。只要持续守着这里，所有的Hameodori君自然会汇集到这里来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「他的目標肯定是SHO總部大樓。只要持續守著這裡，所有的Hameodori君自然會匯集到這裡來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00042",
		linknext = "0049_00044",
		line = 692,
	},
	["0049_00044"] = {
		{"bgm", file="bgm22.5", vol=100},
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00213", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
