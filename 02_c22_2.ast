				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What we need to be fighting for...",
					{"rt2"},
				},
			},
			cn = {
				{
					"而是追求真正意义上的“共存”──",
					{"rt2"},
				},
			},
			tw = {
				{
					"而是追求真正意義上的「共存」──",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00176",
		linknext = "0049_00178",
		line = 2461,
	},
	["0049_00178"] = {
