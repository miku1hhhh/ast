	["0049_00037"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00208", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0062", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“I never thought the day would come when I’d get to savor the joy of being phooeyed by my growing daughter for no good reason... Nothing could make a father happier!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“能体会到被年轻的女儿毫无意义呸了的喜悦──作为父亲，没有比这更快乐的事了⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「能體會到被年輕的女兒毫無意義呸了的喜悅──作為父親，沒有比這更快樂的事了⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00036",
		linknext = "0049_00038",
		line = 594,
	},
	["0049_00038"] = {
