				{
					"⋯⋯从那儿做为起点。",
					{"rt2"},
				},
			},
			tw = {
				{
					"⋯⋯從那兒做為起點。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00169",
		linknext = "0049_00171",
		line = 2389,
	},
	["0049_00171"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We’ll get the chance to find even more people who understand us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一定能慢慢的，让越来越多的人有机会能找到理解自己的人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一定能慢慢的，讓越來越多的人有機會能找到理解自己的人。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00170",
		linknext = "0049_00172",
		line = 2399,
	},
	["0049_00172"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"There won’t be any more need to be hurt, or to hide inside our shells.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不会再受到伤害、也不必再伪装粉饰。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不會再受到傷害、也不必再偽裝粉飾。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00171",
		linknext = "0049_00173",
		line = 2409,
	},
	["0049_00173"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We’ll be able to live in the same world alongside even more people.",
					{"rt2"},
				},
			},
			cn = {
				{
					"让越来越多的人，能够在这个世界里共存。",
					{"rt2"},
				},
			},
			tw = {
				{
					"讓越來越多的人，能夠在這個世界裡共存。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00172",
		linknext = "0049_00174",
		line = 2419,
	},
	["0049_00174"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Which is why I move forward... while trying to start by making this world that kind of place.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以让我来起头，引导这个世界⋯⋯走向那样的光景。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以讓我來起頭，引導這個世界⋯⋯走向那樣的光景。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00173",
		linknext = "0049_00175",
		line = 2431,
	},
	["0049_00175"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Crushing Seiran Island isn’t what we need to do in order to find this kind of understanding.",
					{"rt2"},
				},
			},
			cn = {
				{
					"要达成这个理想，靠得不是瓦解青蓝岛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要達成這個理想，靠得不是瓦解青藍島。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00174",
		linknext = "0049_00176",
		line = 2441,
	},
	["0049_00176"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nor is it crushing Akino’s goals either.",
					{"rt2"},
				},
			},
			cn = {
				{
					"也不是将水引的目的完全推毁掉。",
					{"rt2"},
				},
			},
			tw = {
				{
					"也不是將水引的目的完全推毀掉。",
					{"rt2"},
				},
