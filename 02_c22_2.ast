					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And then from there—we just need to find those who truly understand us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“让人们接受后──我们只需要找到真正的理解者，这样就可以了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「讓人們接受後──我們只需要找到真正的理解者，這樣就可以了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00153",
		linknext = "0049_00155",
		line = 2116,
	},
	["0049_00155"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00309", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
