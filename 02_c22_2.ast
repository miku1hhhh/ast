	["0049_00188"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file3="tohka_01m_00303", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0831", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I... believed that we all simply needed to understand one another.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我啊──我觉得要是所有人都能互相能理解就好了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我啊──我覺得要是所有人都能互相能理解就好了。」",
					{"rt2"},
				},
			},
		},
