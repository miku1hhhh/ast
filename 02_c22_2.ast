	["0049_00076"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00212", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
