	["0049_00134"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You said it yourself, Touka—through understanding.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就是你刚刚说的喔，桐香──去理解他们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就是妳剛剛說的喔，桐香──去理解他們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00133",
		linknext = "0049_00135",
		line = 1898,
	},
	["0049_00135"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00201", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What we need is someone important to us who understands who we really are.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对我们来说不可或缺的，是真正能理解我们的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對我們來說不可或缺的，是真正能理解我們的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00134",
		linknext = "0049_00136",
		line = 1910,
	},
	["0049_00136"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file3="tohka_02m_00312", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0830", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“But, Tachibana... Didn’t you say that only children demand to be understood by everyone they meet?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“但是前辈⋯⋯要求别人无条件理解、包容自己的，只有孩子们⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「但是前輩⋯⋯要求別人無條件理解、包容自己的，只有孩子們⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00135",
		linknext = "0049_00137",
		line = 1925,
	},
	["0049_00137"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00309", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, I did... It’s not that we need to demand understanding.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊，你说的对⋯⋯得要请求别人的理解才行。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊，你說的對⋯⋯得要請求別人的理解才行。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00136",
		linknext = "0049_00138",
		line = 1937,
	},
	["0049_00138"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What we need is to work to be understood and to understand.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们都需要为被人理解与理解别人而努力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們都需要為被人理解與理解別人而努力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00137",
		linknext = "0049_00139",
		line = 1949,
	},
	["0049_00139"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00209", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The marginalized will always fail to be understood.",
					{"rt2"},
				},
			},
			cn = {
				{
					"少数族群体永远没办法被理解。",
					{"rt2"},
				},
			},
			tw = {
				{
					"少數族群體永遠沒辦法被理解。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00138",
		linknext = "0049_00140",
		line = 1962,
	},
	["0049_00140"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In which case, understanding is what they need.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以，才有被理解的必要。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以，才有被理解的必要。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00139",
		linknext = "0049_00141",
		line = 1972,
	},
	["0049_00141"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But not through violent demands for understanding.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但不是用暴力来寻求理解。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但不是用暴力來尋求理解。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00140",
		linknext = "0049_00142",
		line = 1982,
	},
	["0049_00142"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Just by letting the world know that they exist.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而是透过，让他们知道，这里确实有这样的存在，这种方式。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而是透過，讓他們知道，這裡確實有這樣的存在，這種方式。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00141",
		linknext = "0049_00143",
		line = 1992,
	},
	["0049_00143"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00207", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It means getting those who don’t understand to accept who you are.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“需要让不理解的人们，接受你的存在。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「需要讓不理解的人們，接受你的存在。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00142",
		linknext = "0049_00144",
		line = 2004,
	},
	["0049_00144"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We don’t have to get it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不明白也没关系。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不明白也沒關係。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00143",
		linknext = "0049_00145",
		line = 2014,
	},
	["0049_00145"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s even fine if we don’t care.",
					{"rt2"},
				},
			},
			cn = {
				{
					"漠不关心也无所谓。",
					{"rt2"},
				},
			},
			tw = {
				{
					"漠不關心也無所謂。",
					{"rt2"},
				},
