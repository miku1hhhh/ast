			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Heh heh, looks like the lawful wife and the lover will be working side-by-side again. How about we get along, Nanase?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呵呵，正妻跟情妇又碰头了呢？我们要好好相处喔，奈奈濑同学？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「呵呵，正妻跟情婦又碰頭了呢？我們要好好相處喔，奈奈瀨同學？」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00072",
		linknext = "0049_00074",
		line = 1105,
	},
	["0049_00074"] = {
