		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Two more hours until Asane can’t hold them off any longer.",
					{"rt2"},
				},
			},
			cn = {
				{
					"距离麻沙音为我们的拖延到的时间限制，还剩2小时。",
					{"rt2"},
				},
			},
			tw = {
				{
					"距離麻沙音為我們的拖延到的時間限制，還剩2小時。",
					{"rt2"},
				},
			},
		},
