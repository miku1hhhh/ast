		text = {
			vo = {
				{"vo", file="schubert0200", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“There will also be a need to pre-plan flight paths if this many will be taking to the skies. This data of mine here is a forecast of their routes if they’re airborne.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“想让这么大量的装甲飞行，一定得要事先设定好飞行路线。根据我的数据显示──若是它们朝着这边飞来的话，路径大概是长这样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「想讓這麼大量的裝甲飛行，一定得要事先設定好飛行路線。根據我的數據顯示──若是它們朝著這邊飛來的話，路徑大概是長這樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00007",
		linknext = "0049_00009",
		line = 126,
	},
