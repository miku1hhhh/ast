	["0049_00007"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I guess they would focus hardest on SHO headquarters... but that’s a lot of them at the other facilities too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“果然SHO总部大楼的火力是最集中的──不过其他设施也相当可观就是了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「果然SHO總部大樓的火力是最集中的──不過其他設施也相當可觀就是了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00006",
		linknext = "0049_00008",
		line = 109,
	},
	["0049_00008"] = {
