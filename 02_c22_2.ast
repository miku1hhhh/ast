	["0049_00072"] = {
		{"bgm", file="bgm16", vol=100},
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We’ll put together a strategy with help from Touka and Nanase, the brains of our two operations. I want you to think carefully about where you station everyone.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“作战计划交给两边的头头桐香跟奈奈濑来一起执行规划，你们得谨慎地决定战力的配置。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「作戰計畫交給兩邊的頭頭桐香跟奈奈瀨來一起執行規劃，妳們得謹慎地決定戰力的配置。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00071",
		linknext = "0049_00073",
		line = 1091,
	},
	["0049_00073"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=395, y=-5},
