		linknext = "0049_00146",
		line = 2024,
	},
	["0049_00146"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We just have to accept that they are there.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只需认同他们在那儿这件事就好。",
					{"rt2"},
				},
