					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I thought the same thing in the beginning.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“一开始时我也是这么想的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「一開始時我也是這麼想的。」",
