		},
		text = {
			vo = {
				{"vo", file="misaki0144", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Most of the SHO was standing by there, as expected. They must want to protect it at any cost, even if the other facilities are destroyed, but... everyone’s expressions looked so dead.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“果然跟预料的一样，几乎全SHO都在那边待命。大概是抱着其他地方被破坏掉也无所谓，只要能守住这里就好的想法吧⋯⋯不过他们都已经眼神死了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「果然跟預料的一樣，幾乎全SHO都在那邊待命。大概是抱著其他地方被破壞掉也無所謂，只要能守住這裡就好的想法吧⋯⋯不過他們都已經眼神死了呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00016",
		linknext = "0049_00018",
		line = 286,
	},
	["0049_00018"] = {
