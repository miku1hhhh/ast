		},
		linkback = "0049_00146",
		linknext = "0049_00148",
		line = 2044,
	},
	["0049_00148"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No violent demands for understanding, no unconscious discrimination.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不是透过暴力寻求理解、也不会下意识地产生歧视。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不是透過暴力尋求理解、也不會下意識地產生歧視。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00147",
		linknext = "0049_00149",
		line = 2054,
	},
	["0049_00149"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What we need is acceptance itself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这种包容，正是我们所不可或缺的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這種包容，正是我們所不可或缺的。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00148",
		linknext = "0049_00150",
		line = 2064,
	},
	["0049_00150"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If everyone is able to accept everyone else...",
					{"rt2"},
				},
			},
			cn = {
				{
					"只要大家能够相互包容的话⋯⋯",
					{"rt2"},
				},
			},
			tw = {
				{
					"只要大家能夠相互包容的話⋯⋯",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00149",
		linknext = "0049_00151",
		line = 2074,
	},
	["0049_00151"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If we become able to simply allow those we can’t understand to exist...",
					{"rt2"},
				},
			},
			cn = {
				{
					"只需要去包容，那些无法被理解的人是真实存在着的这件事──",
					{"rt2"},
				},
			},
			tw = {
				{
					"只需要去包容，那些無法被理解的人是真實存在著的這件事──",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00150",
		linknext = "0049_00152",
		line = 2084,
	},
	["0049_00152"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...That’s enough for the marginalized to live their lives.",
					{"rt2"},
				},
			},
			cn = {
				{
					"──只需如此，少数族群就能生存了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"──只需如此，少數族群就能生存了。",
					{"rt2"},
				},
