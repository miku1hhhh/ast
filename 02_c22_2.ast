	["0049_00048"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00202", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-405, y=-5},
		{"fg", file="hitoura_01m_00001", file1="hitoura_01m_00102", file2="hitoura_01m_00216", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=395, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That would mean stealing sex away from everyone on the island who enjoyed the perverted sex law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这样的话，就会夺走那些在岛上享受着变态条例的人们做爱的权利。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這樣的話，就會奪走那些在島上享受著變態條例的人們做愛的權利。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00047",
		linknext = "0049_00049",
		line = 768,
	},
	["0049_00049"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00221", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We aren’t sacrificing the headquarters. Not Lewd Land, not any facility.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不管是总部大楼还是变态游乐园，哪一个设施都不能被牺牲。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不管是總部大樓還是變態遊樂園，哪一個設施都不能被犧牲。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00048",
