					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...I was originally someone who wanted to overthrow Seiran Island too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我呢，原本也是打算推翻青蓝岛的男人喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
