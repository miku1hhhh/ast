					name = {"礼", "Rei"},
					"“That one time in particular. Your ECM scrambled our chain of command, and so we even had to fight ourselves... Right, Miss Touka?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那时真的是很辛苦呢。要把被电子干扰搞得混乱只会系统统合起来、又要实战──对吧、桐香大人？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那時真的是很辛苦呢。要把被電子干擾搞得混亂只會系統統合起來、又要實戰──對吧、桐香大人？」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00090",
		linknext = "0049_00092",
		line = 1396,
	},
	["0049_00092"] = {
		{"se", id=0, loop=0, file="se_a036"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Touka, second from the front, slows her pace a bit.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从头算起排在第二顺位的桐香停下了脚步，有点迟疑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"從頭算起排在第二順位的桐香停下了腳步，有點遲疑。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00091",
		linknext = "0049_00093",
		line = 1407,
	},
	["0049_00093"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00214", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", alpha=0, ch_origin="桐香", ch="桐香8", mw="mw", sync=1, a_chr151=1, mode=3, x=-205, y=-5},
