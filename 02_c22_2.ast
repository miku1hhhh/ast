		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00209", path=":fg/jun_01f/", id=30, ch="淳之介", lv=18, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...So what exactly brings you here? I thought we’re enemies, no?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯这到底是吹了什么样的风？我们应该是敌人才对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯這到底是吹了什麼樣的風？我們應該是敵人才對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00031",
		linknext = "0049_00033",
		line = 519,
	},
	["0049_00033"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00207", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0060", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Hah... While I could get in your way, it would do nothing to stop Akino’s outrageous acts.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“呼⋯⋯虽然我可以阻止你们，但却无法阻止秋野君的暴行。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「呼⋯⋯雖然我可以阻止你們，但卻無法阻止秋野君的暴行。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00032",
		linknext = "0049_00034",
		line = 534,
	},
	["0049_00034"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00202", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0061", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“And to tell the truth, I’m a bit grateful. You did give me time to speak with Fumino. Now we’re able to open up to one another.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“而且说真的，我也多少有点感激你们。让我有了跟文乃沟通的时间，现在我跟才能女儿之间没有隔阂。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「而且說真的，我也多少有點感激你們。讓我有了跟文乃溝通的時間，現在我跟才能女兒之間沒有隔閡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00033",
		linknext = "0049_00035",
		line = 549,
	},
	["0049_00035"] = {
