		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00204", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00204", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s why I was a bad guy from the island’s perspective.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以从青蓝岛的角度来看的话，我是个坏人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以從青藍島的角度來看的話，我是個壞人。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00101",
		linknext = "0049_00103",
		line = 1552,
	},
	["0049_00103"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
