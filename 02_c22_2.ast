					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Of course it is, Susuko. After all, I was collecting data in anticipation of just this scenario.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“那当然啊，丝丝子同学。我可是早就想到会有这种状况，收集了许多资料的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「那當然啊，絲絲子同學。我可是早就想到會有這種狀況，收集了許多資料的。」",
					{"rt2"},
				},
