			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You guys gave us so much trouble. We’d give up our days off and come running when you anti-copulators showed up, only for you to have gotten away when we arrived. It was pretty annoying, you know.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“你们还真会给我找麻烦。我一听到有反交尾势力出动就休假赶过来了，结果就听到你们追丢了。也太让人火大了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「你們還真會給我找麻煩。我一聽到有反交尾勢力出動就休假趕過來了，結果就聽到你們追丟了。也太讓人火大了吧？」",
					{"rt2"},
				},
			},
		},
