				},
			},
		},
		linkback = "0049_00102",
		linknext = "0049_00104",
		line = 1564,
	},
	["0049_00104"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00204", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I was going to teach everyone a lesson. I would make everyone understand exactly who I am...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我会让他们都知道。我会让所有的人都知道我的存在⋯⋯之类的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我會讓他們都知道。我會讓所有的人都知道我的存在⋯⋯之類的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00103",
		linknext = "0049_00105",
		line = 1576,
	},
	["0049_00105"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So to teach them, I began getting my revenge.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以，我才会为了让他们知道我的存在而展开了复仇。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以，我才會為了讓他們知道我的存在而展開了復仇。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00104",
		linknext = "0049_00106",
		line = 1586,
	},
	["0049_00106"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"To make everyone in the world understand that I exist right here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了让全世界的人都理解，我真的在这儿的这件事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了讓全世界的人都理解，我真的在這兒的這件事。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00105",
		linknext = "0049_00107",
		line = 1596,
	},
	["0049_00107"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That’s why I can really understand how Hamedori—how Mizuhiki Akino feels.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以我很能理解Hamedori君──秋野水引的心情。”",
