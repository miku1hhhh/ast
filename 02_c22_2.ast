	},
	["0049_00195"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file3="tohka_02m_00302", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0835", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Not forced understanding, nor persecution...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“没有强迫性的去理解，也没有压迫存在──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「沒有強迫性的去理解，也沒有壓迫存在──」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00194",
		linknext = "0049_00196",
		line = 2681,
	},
	["0049_00196"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If that kind of island really does exist...",
					{"rt2"},
				},
			},
			cn = {
				{
					"像这样的一座岛，真的存在的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"像這樣的一座島，真的存在的話。",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00195",
		linknext = "0049_00197",
		line = 2691,
	},
	["0049_00197"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00210", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0836", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“What I should have created was an environment that allows people to find those few people who truly understand them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“──我们应该要创造出的，是一个让少量的、真正的理解者能被找到的环境。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「──我們應該要創造出的，是一個讓少量的、真正的理解者能被找到的環境。」",
					{"rt2"},
				},
			},
		},
		linkback = "0049_00196",
		linknext = "0049_00198",
		line = 2706,
	},
	["0049_00198"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00207", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
