		{"fg", file="misaki_02m_00001", file1="misaki_02m_00103", file2="misaki_02m_00226", path=":fg/misaki_02m/", id=6, lv=6, head="misaki_02m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki0027", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Okay maybe I will submit to you in the end, or maybe I’ll beg for you to kill me like a captured swordswoman, but I’ll at least hold out long enough to maintain some of my honor!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“虽然最后可能还是会屈服，也可能会说‘咕、杀了我……！’，但为了保住某种程度的面子我会试着忍耐的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「雖然最後可能還是會屈服，也可能會說『咕、殺了我……！』，但為了保住某種程度的面子我會試著忍耐的……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00230",
		linknext = "0004_00232",
		line = 2765,
	},
	["0004_00232"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If anything, she seemed to be looking at a freak who started talking to her out of nowhere.",
					{"rt2"},
				},
			},
			cn = {
				{
					"根本是在面对突然跟她说话的怪人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"根本是在面對突然跟她說話的怪人。",
					{"rt2"},
				},
