	},
	["0004_00382"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0029", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I was getting some weird vibes so I went to school to check things out, and the perverted sex law was back to the old one!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我觉得四周的瘴气特别诡异，一去学校就发现变态条例恢复原状了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我覺得四周的瘴氣特別詭異，一去學校就發現變態條例恢復原狀了。」",
					{"rt2"},
				},
			},
		},
