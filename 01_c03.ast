			en = {
				{
					name = {"礼", "Rei"},
					"“I would be fine with that, but what if everyone thinks we’re kind of cringe and smirks at us...?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那倒还好，或许会被当作是有点神经的家伙，别人还会对我苦笑……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那倒還好，或許會被當作是有點神經的傢伙，別人還會對我苦笑……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00405",
		linknext = "0004_00407",
