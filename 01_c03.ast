				{
					"I really do feel a kindred spirit in her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我真的对她涌起了亲近感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我真的對她湧起了親近感。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00384",
		linknext = "0004_00386",
		line = 4675,
	},
	["0004_00386"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0044", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“To summarize what we’ve learned today, this place isn’t all too different from the one we know, generally speaking.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我们统整今天一天获知的情报后，得知这里基本上跟我们熟知的场所没什么不同。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我們統整今天一天獲知的情報後，得知這裡基本上跟我們熟知的場所沒什麼不同。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00385",
		linknext = "0004_00387",
		line = 4687,
	},
	["0004_00387"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0030", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“The old perverted sex law is still in effect, but everything else is the same. The FS exists, and the SHO still seems to function like normal.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“虽然老旧的变态条例还在，但除此之外的状况都一样，不仅有FS，SHO似乎也维持着正常的机能。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「雖然老舊的變態條例還在，但除此之外的狀況都一樣，不僅有FS，SHO似乎也維持著正常的機能。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00386",
		linknext = "0004_00388",
		line = 4699,
	},
	["0004_00388"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0044", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Even class today picked up where we left off... The passage of time doesn’t seem to have been interrupted. It’s the exact same.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“上课内容也延续了上礼拜的……也就是说，时间的流动是接壤的，这点没有任何变化。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「上課內容也延續了上禮拜的……也就是說，時間的流動是接壤的，這點沒有任何變化。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00387",
		linknext = "0004_00389",
		line = 4711,
	},
	["0004_00389"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0045", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes. With the exception of you... Tachibana?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“对，除了你以外喔……前辈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「對，除了你以外喔……前輩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00388",
		linknext = "0004_00390",
		line = 4723,
	},
	["0004_00390"] = {
		{"fg", file="jun_01f_00000", file1="jun_01f_00101", file2="jun_01f_00201", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
