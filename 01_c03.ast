			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Agh, the cold looks and awkward smiles all around me then...! And wait, why didn’t you say something to me earlier if you were around to see that?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“唔！当时感受到四周的冷淡视线，还被嘲笑……！话说既然郁子你有撞见，就该叫我一下啊！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「唔！當時感受到四周的冷淡視線，還被嘲笑……！話說既然郁子妳有撞見，就該叫我一下啊！」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00407",
		linknext = "0004_00409",
		line = 4979,
	},
