	["0004_00295"] = {
		{"fg", mode=-1, id=30},
		{"facehide"},
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00202", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0003", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "???"},
					"“Oh, heh... Well, not like there’s much work for me to do. You handle any problems as soon as they come up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "？？？"},
					"“对，呵呵……话虽如此，不管发生什么事，你都会去解决，我几乎没什么工作可以做耶？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "？？？"},
					"「對，呵呵……話雖如此，不管發生什麼事，你都會去解決，我幾乎沒什麼工作可以做耶？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00294",
		linknext = "0004_00296",
		line = 3561,
	},
	["0004_00296"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The boy chuckles to himself. He looks to be around my age.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看起来像同学年的男学生摆出了苦笑神情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看起來像同學年的男學生擺出了苦笑神情。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00295",
		linknext = "0004_00297",
		line = 3571,
	},
	["0004_00297"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It seems like a quip he makes often.",
					{"rt2"},
				},
			},
			cn = {
				{
					"用仿佛平常就在开玩笑的模样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"用彷彿平常就在開玩笑的模樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00296",
