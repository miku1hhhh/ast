					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「……從這邊看來，所謂的『饒富犯意』指的是平安時代的人們對變態做愛興致勃勃的象徵性古文。」",
					{"rt2"},
				},
			},
		},
