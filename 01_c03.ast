		line = 3581,
	},
	["0004_00298"] = {
		{"fg", mode=-1, id=30},
		{"facehide"},
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00205", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0004", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "???"},
					"“What good is my data in the face of junk like yours, capable of silencing any woman in one go.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "？？？"},
					"“在能够一击让任何女人闭嘴的你的大屌面前，我的数据根本不成体统。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "？？？"},
					"「在能夠一擊讓任何女人閉嘴的你的大屌面前，我的數據根本不成體統。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00297",
		linknext = "0004_00299",
		line = 3598,
	},
	["0004_00299"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I catch the faintest glimpse of what’s happening here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"事情真相的片段开始闪过我的眼前。",
					{"rt2"},
