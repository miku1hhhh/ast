					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "？？？"},
					"「好呃，今天也以變態條例之名，四處取締違規者吧！橘同學，啊不對──」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00301",
		linknext = "0004_00303",
		line = 3653,
	},
