			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“You’re coming to talk to me all of a sudden like this...? It’s been a while since we last spoke, right...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“怎么突然出声叫我……不如说，我们很久没见面了不是吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「怎麼突然出聲叫我……不如說，我們很久沒見面了不是嗎……？」",
					{"rt2"},
				},
			},
		},
