				{"vo", file="ikuko0032", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“...I doubt anyone would believe us if we told them, huh? They might think we’ve gone crazy and send us to a hospital on the mainland.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“……这种事说给大家听也不会有人相信吧。一定会被当作脑袋有问题，说不定还会被送去本岛的医院。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「……這種事說給大家聽也不會有人相信吧。一定會被當作腦袋有問題，說不定還會被送去本島的醫院。」",
					{"rt2"},
				},
			},
		},
