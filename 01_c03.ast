				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Absolutely... I thought I’d gone mad until I met with Miss Touka. Like it had all been a dream, a pleasant little illusion I’d come up with...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“真是的……我和桐香大人会合以前，都怀疑自己是不是发疯了……我以为这或许全都是梦，都是为自己量身打造的幻觉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「真是的……我和桐香大人會合以前，都懷疑自己是不是發瘋了……我以為這或許全都是夢，都是為自己量身打造的幻覺……」",
					{"rt2"},
				},
			},
		},
