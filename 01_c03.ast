		},
		linkback = "0004_00389",
		linknext = "0004_00391",
		line = 4735,
	},
	["0004_00391"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That was right.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她说的对。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她說的對。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00390",
		linknext = "0004_00392",
		line = 4745,
	},
	["0004_00392"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Aside from the perverted sex law, just about everything lined up with how I expected it to be.",
					{"rt2"},
				},
			},
			cn = {
				{
					"除了变态条例以外，大部分都跟我的认知一样，没有差错。",
					{"rt2"},
				},
			},
			tw = {
				{
					"除了變態條例以外，大部分都跟我的認知一樣，沒有差錯。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00391",
		linknext = "0004_00393",
		line = 4755,
	},
	["0004_00393"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And yet, my own position is so utterly different.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但我身处的立场有决定性的不同。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但我身處的立場有決定性的不同。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00392",
		linknext = "0004_00394",
		line = 4765,
	},
	["0004_00394"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0046", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Instead of being the leader of the NLNS, your position is that of an FS member and student council vice president at Minotsuki Academy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“你的立场不再是NLNS的队长，你是FS的成员，也担任了水乃月学园的学生会副会长一职。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「你的立場不再是NLNS的隊長，你是FS的成員，也擔任了水乃月學園的學生會副會長一職。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00393",
		linknext = "0004_00395",
		line = 4777,
	},
	["0004_00395"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A “Junnosuke Tachibana,” vice president of the student council, has joined with the former FS Big Three.",
					{"rt2"},
				},
			},
			cn = {
				{
					"原本的FS三巨头，多加上了学生会副会长‘橘淳之介’。",
					{"rt2"},
				},
			},
			tw = {
				{
					"原本的FS三巨頭，多加上了學生會副會長『橘淳之介』。",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00394",
		linknext = "0004_00396",
		line = 4787,
	},
