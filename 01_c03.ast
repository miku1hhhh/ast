					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Ms. Minase"},
					"“...And so, we can say that the honor of ‘magna cum laude’ is our way of continuing to honor the ancient Roman love of big loads.”",
					{"rt2"},
