					{"rt2"},
				},
			},
			en = {
				{
					"But that would be ridiculous.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但，这怎么可能？",
					{"rt2"},
				},
			},
			tw = {
				{
					"但，這怎麼可能？",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00300",
