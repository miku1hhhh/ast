					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“……………………”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「……………………」",
					{"rt2"},
				},
