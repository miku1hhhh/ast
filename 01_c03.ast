				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This is an utterly different place, yet nearly identical to the world we know.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这里跟我们的认知几乎雷同，却是完全迥异的空间。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這裡跟我們的認知幾乎雷同，卻是完全迥異的空間。",
