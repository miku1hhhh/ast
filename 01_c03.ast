	["0004_00300"] = {
		{"fg", mode=-1, id=30},
		{"facehide"},
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00221", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0005", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト", "？？？"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "???"},
					"“I’m glad I’m able to focus on gathering data thanks to that, but could you just spare me the extra work of having to track you down?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "？？？"},
					"“虽然我只要专心收集数据就好，但可以拜托你不要让我做把你找出来的工作好吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "？？？"},
					"「雖然我只要專心收集數據就好，但可以拜託你不要讓我做把你找出來的工作好嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00299",
		linknext = "0004_00301",
		line = 3625,
	},
	["0004_00301"] = {
