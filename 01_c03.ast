				},
			},
			cn = {
				{
					name = {"礼"},
					"“这个时间带仅限特定职位的人可以在大浴场泡澡，所以其他人都不能进来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這個時間帶僅限特定職位的人可以在大浴場泡澡，所以其他人都不能進來。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00372",
		linknext = "0004_00374",
		line = 4529,
	},
	["0004_00374"] = {
