	["0004_00407"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg030001030501", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0033", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Ahaha! Yeah, you were pretty shook. You were screaming in the hallways nearly in tears. ‘Why is there still a perverted sex law?! It doesn’t make seeense!’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“啊哈哈！礼酱真的为此动摇了唷！还在走廊上眼眶泛泪，大声说着‘为什么变态条例还在啊～～！？这很奇怪吧～～！’这种话。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「啊哈哈！禮醬真的為此動搖了唷！還在走廊上眼眶泛淚，大聲說著『為什麼變態條例還在啊～～！？這很奇怪吧～～！』這種話。」",
					{"rt2"},
				},
			},
		},
		linkback = "0004_00406",
		linknext = "0004_00408",
		line = 4960,
	},
	["0004_00408"] = {
		{"evset", file="kcg03", set="kcg03", path=":ev/kcg03/"},
		{"evset", file="kcg030001030201", set="kcg030001", path=":ev/kcg030001/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg030001030201", x=0, y=0, path=":cg/kcg03/", lv=18, ev=1, bx=800, by=450},
