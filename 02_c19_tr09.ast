	["0041_00023"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They trapped us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们被他们设计了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們被他們設計了。",
					{"rt2"},
				},
