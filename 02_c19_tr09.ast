	},
	["0041_00024"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The SHO was hindering us in their attempt to grab real power.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因为要让SHO掌握所有权力，也因为我们是个碍事的存在。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因為要讓SHO掌握所有權力，也因為我們是個礙事的存在。",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00023",
		linknext = "0041_00025",
		line = 346,
	},
	["0041_00025"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s why Hitoura has been letting the FS roam freely up until now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"浦氏才会放任FS到现在──",
					{"rt2"},
				},
			},
			tw = {
				{
					"浦氏才會放任FS到現在──",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00024",
		linknext = "0041_00026",
		line = 356,
	},
	["0041_00026"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00211", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0035", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“You don’t seem as surprised as I expected you to be. You’re calm and collected even though your enemy’s boss is here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“你并没有我娑想的那么吃惊，敌方首领来了，你倒是很淡定。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「你並沒有我娑想的那麼吃驚，敵方首領來了，你倒是很淡定。」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00025",
		linknext = "0041_00027",
		line = 371,
	},
	["0041_00027"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=16},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I’m used to it. If I’m not mistaken, this is my final warning.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“早就习惯了嘛。所以这是最后通牒，对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「早就習慣了嘛。所以這是最後通牒，對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00026",
		linknext = "0041_00028",
		line = 383,
	},
	["0041_00028"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This has already happened once in the past.",
					{"rt2"},
				},
			},
			cn = {
				{
					"过去也曾有过一次。",
					{"rt2"},
				},
			},
			tw = {
				{
					"過去也曾有過一次。",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00027",
		linknext = "0041_00029",
		line = 393,
	},
	["0041_00029"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But that’s a piece of information that he doesn’t know.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过这件事他无从知晓。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過這件事他無從知曉。",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00028",
		linknext = "0041_00030",
		line = 403,
	},
	["0041_00030"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00201", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0036", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Exactly. As you know, the SHO lacks a good spokesperson. But you would work just fine.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“没错。如你所知的，SHO现在的宣传力还不足。有了你的加入，就能补足这一块。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「沒錯。如你所知的，SHO現在的宣傳力還不足。有了你的加入，就能補足這一塊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00029",
		linknext = "0041_00031",
		line = 418,
	},
	["0041_00031"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=16},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Is that your way of telling me to take the SHO’s side?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以你是要把我放去SHO？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以你是要把我放去SHO？」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00030",
		linknext = "0041_00032",
		line = 430,
	},
	["0041_00032"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00204", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0037", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Is there a reason for you to stay on a drowning ship? This is your last chance. Conquer this world with me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“一艘沉船难道还会有继续搭乘的理由吗？这是最后的机会了。跟我一起拿下这世界吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「一艘沈船難道還會有繼續搭乘的理由嗎？這是最後的機會了。跟我一起拿下這世界吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00031",
		linknext = "0041_00033",
		line = 445,
	},
	["0041_00033"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=16},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I refuse. That goal doesn’t exist in the world that I wish for.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我拒绝。我想要的世界，跟你的不一样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我拒絕。我想要的世界，跟你的不一樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00032",
		linknext = "0041_00034",
		line = 457,
	},
	["0041_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I openly reject his offer.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我明确地表示拒绝。",
					{"rt2"},
