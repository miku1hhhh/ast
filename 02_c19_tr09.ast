			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And no matter what it is, if she really wants to do something...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不管是什么，如果真心想要的话那么一定──”",
