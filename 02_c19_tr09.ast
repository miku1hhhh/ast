	},
	["0041_00065"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"He speaks to my back.",
					{"rt2"},
				},
			},
			cn = {
				{
					"男人的话语从那个背影传了过来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"男人的話語從那個背影傳了過來。",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00064",
		linknext = "0041_00066",
		line = 842,
	},
	["0041_00066"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00203", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0045", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“The dead-eyed girl can’t live outside Seiran Island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“‘无欲的少女’可是离开了青蓝岛就生存不下去的女人啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「『無欲的少女』可是離開了青藍島就生存不下去的女人啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00065",
		linknext = "0041_00067",
		line = 857,
	},
	["0041_00067"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00204", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0046", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Her combat and strategy skills would be completely useless in normal society. She would only end up as a girl unable to be satisfied with an average life.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“因为战斗能力和战略规划能力在正常社会中是没有用的。在外头，她只不过是个连生活都无法自理的小丫头罢了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「因為戰鬥能力和戰略規劃能力在正常社會中是沒有用的。在外頭，她只不過是個連生活都無法自理的小丫頭罷了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00066",
		linknext = "0041_00068",
		line = 872,
	},
	["0041_00068"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00217", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0047", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“If you really care for her, the right path for you is to lend me a hand and expand this island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“如果你真的在意那丫头，就应该借我一臂之力，尽你所能的去扩建这座岛屿。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「如果你真的在意那丫頭，就應該借我一臂之力，盡你所能的去擴建這座島嶼。」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00067",
		linknext = "0041_00069",
		line = 887,
	},
	["0041_00069"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00215", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0048", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Or do you want to imprison her on this small piece of land?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“还是说，你要把她关在这个小岛上？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「還是說，你要把她關在這個小島上？」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00068",
		linknext = "0041_00070",
		line = 902,
	},
	["0041_00070"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That is a fair argument.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦所言不假。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦所言不假。",
					{"rt2"},
