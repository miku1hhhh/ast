					"“This is one of the spots where the Mutable Membrane has been guarded from the start. Assuming that the FS higher-ups had connections with the yakuza, it’s an obvious thing to do. Right, boy?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“一时的皮膜是我本来就一直注意的地方之一。要是FS的上层真的跟黑道有来往，会知道你的行踪不是很正常的吗，年轻人？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「一時的皮膜是我本來就一直注意的地方之一。要是FS的上層真的跟黑道有來往，會知道你的行蹤不是很正常的嗎，年輕人？」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00019",
		linknext = "0041_00021",
		line = 301,
	},
	["0041_00021"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=16},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You should know best that something like that has never taken place.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“到底有没有跟黑道往来，最请楚的人不应该就是你吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「到底有沒有跟黑道往來，最請楚的人不應該就是你嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00020",
		linknext = "0041_00022",
		line = 313,
	},
	["0041_00022"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00207", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
