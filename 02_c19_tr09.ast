				{"vo", file="hitoura0049", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“She will learn it? Heh! Not at all, Tachibana.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“一定能够做到吗？呵、不对喔橘君──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「一定能夠做到嗎？呵、不對喔橘君──」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00075",
		linknext = "0041_00077",
		line = 981,
	},
	["0041_00077"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00201", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0050", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“She will never grow up. Except for her unquestionable talents, she can’t do things even a baby can do.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“──那个丫头长不大。除了发挥她的天赋之外，就连婴儿都能做的事，她都做不到。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「──那個丫頭長不大。除了發揮她的天賦之外，就連嬰兒都能做的事，她都做不到。」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00076",
		linknext = "0041_00078",
		line = 996,
	},
	["0041_00078"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00204", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[6500] = {
				{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00218", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, timestamp=1, delay2=6500, mode=3, x=-5, y=-5},
			},
			[6499] = {
				{"transitiontime", time=300, timestamp=1, delay2=6500},
			},
		},
		text = {
			vo = {
				{"vo", file="hitoura0051", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“In that case, she will never be able to live a normal life. I’m certain you are aware of that too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“否则，她不可能成为连正常人都无法生活的人类。⋯⋯你也注意到这件事了不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「否則，她不可能成為連正常人都無法生活的人類。⋯⋯你也注意到這件事了不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00077",
		linknext = "0041_00079",
		line = 1014,
	},
	["0041_00079"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00205", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0052", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“That’s Touka Reizeiin’s true nature. She can only perform well when she can use her talents. She won’t grow up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“从一开始就只能做她擅长做的事、一个停止了成长的女人──这就是名为冷泉院桐香的女孩的本质。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「從一開始就只能做她擅長做的事、一個停止了成長的女人──這就是名為冷泉院桐香的女孩的本質。」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00078",
		linknext = "0041_00080",
		line = 1029,
	},
	["0041_00080"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If he wasn’t right, she would’ve been able to at least change on her own and climb the stairs.",
					{"rt2"},
