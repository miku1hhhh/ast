	},
	["0041_00041"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00210", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0040", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“What a smart but bad boy... If you are going to reject my military rule, you leave me no choice but to destroy you.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“你真是个没见识的孩子……如果你拒绝了有着绝对地位的我，那我就只能狠狠地碾压你了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「你真是個沒見識的孩子……如果你拒絕了有著絕對地位的我，那我就只能狠狠地碾壓你了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00040",
		linknext = "0041_00042",
		line = 554,
	},
	["0041_00042"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00305", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=16},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Then try. Just don’t you come crying if you lose at your own game.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那你就试试看。不过被反击的话你也别抱怨喔！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那你就試試看。不過被反擊的話你也別抱怨喔！」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00041",
		linknext = "0041_00043",
		line = 566,
	},
	["0041_00043"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00205", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0041", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Do you think I will let you go back from here? We are an organization. You can’t fight properly without your comrades.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“你觉得我会让你离开这里吗？我这边可是一个组织。如果不能成为友军，那就只能对战了不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「你覺得我會讓你離開這裡嗎？我這邊可是一個組織。如果不能成為友軍，那就只能對戰了不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00042",
		linknext = "0041_00044",
		line = 581,
	},
	["0041_00044"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=16},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I understand that it’s your fastidious personality that makes it hard for you to get followers.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我知道你是个有洁癖的人，像这种地方，你是不会带部下来的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我知道你是個有潔癖的人，像這種地方，你是不會帶部下來的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00043",
		linknext = "0041_00045",
		line = 593,
	},
	["0041_00045"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00204", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0042", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Then, we have to fight one-on-one. Do you think you can win because I’m older?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“所以你觉得对上我这种中年男子，单挑的话你就有胜算是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「所以你覺得對上我這種中年男子，單挑的話你就有勝算是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00044",
		linknext = "0041_00046",
		line = 608,
	},
	["0041_00046"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00210", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=16},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Of course. Actually, it’s because I know your weak point.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那当然。因为我很清楚你的弱点是什么。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那當然。因為我很清楚你的弱點是什麼。」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00045",
		linknext = "0041_00047",
		line = 620,
	},
	["0041_00047"] = {
