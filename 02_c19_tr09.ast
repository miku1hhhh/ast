		line = 467,
	},
	["0041_00035"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00211", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hitoura’s face is a mask expressing neither bitterness nor anger.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仁浦苦笑了一下，露出似愠非愠的表情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"仁浦苦笑了一下，露出似慍非慍的表情。",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00034",
		linknext = "0041_00036",
		line = 480,
	},
	["0041_00036"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0038", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Why do you stick to the FS so much? I don’t comprehend why you’re so devoted to that dead-eyed girl.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“你为何要为FS拼命到这种程度？你为于那个‘无欲的少女’全力以赴的理由是什么？我实在不能理解。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「你為何要為FS拚命到這種程度？你為於那個『無欲的少女』全力以赴的理由是什麼？我實在不能理解。」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00035",
		linknext = "0041_00037",
		line = 492,
	},
	["0041_00037"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=16},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If I walked with you, I would only become a puppet for publicity.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“跟着你的话，我最终也不过只是个作为活看板的魁儡而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「跟著你的話，我最終也不過只是個作為活看板的魁儡而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00036",
		linknext = "0041_00038",
		line = 504,
	},
	["0041_00038"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00206", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0039", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“But you are aware that it will be the same if you follow that girl, right? Wasn’t it her who made you fulfill the role of His Sexellency and caused you to suffer, boy?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“但跟着那女孩也是一样的。把你推上性皇帝的角色折磨你的人，不就是她吗，年轻人？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「但跟著那女孩也是一樣的。把你推上性皇帝的角色折磨你的人，不就是她嗎，年輕人？」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00037",
		linknext = "0041_00039",
		line = 519,
	},
	["0041_00039"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No matter what he says, I do not falter.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无论他怎么说，我的心都不会被动摇。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無論他怎麼說，我的心都不會被動搖。",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00038",
		linknext = "0041_00040",
		line = 529,
	},
	["0041_00040"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’m sure that the me of this world would say the same thing.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这世界的我，一定也是这么想的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這世界的我，一定也是這麼想的。",
					{"rt2"},
