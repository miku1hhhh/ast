	},
	["0041_00071"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Touka can’t live a proper life outside Seiran Island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"桐香她，如果不是在青蓝岛上，几乎无法生存下去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"桐香她，如果不是在青藍島上，幾乎無法生存下去。",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00070",
