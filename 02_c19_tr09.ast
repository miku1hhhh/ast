		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This is the only thing he can’t entrust any other person with.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只有这件事，仁浦无法假他人之手。",
