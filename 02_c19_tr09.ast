	["0041_00053"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s why he started these negotiations. He thought that she may be with me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他认为她可能会和我在一起，所以才特意前来谈判。",
					{"rt2"},
