					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Nothing in particular. We gathered the FS members together and sent back those who wanted to go back home. We survived on rations for one... Simply going south, heading for Seiran island.”",
