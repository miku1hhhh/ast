		linkback = "0041_00054",
		linknext = "0041_00056",
		line = 717,
	},
	["0041_00056"] = {
		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00203", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0043", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Are you planning on keeping her close to you and running away your whole life? How impudent. Are you such a fool as not to understand that it’s impossible?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“你打算跟那个女人私奔一辈子？你傻到连这不可能都不知道吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「你打算跟那個女人私奔一輩子？你傻到連這不可能都不知道嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00055",
		linknext = "0041_00057",
		line = 732,
	},
	["0041_00057"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00210", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=16},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It’s not impossible. That’s because the Sakimori have my back. They’re politicians, you know.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这也不是不可能，毕竟我背后站着的是作为政治家的驻防老先生。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這也不是不可能，畢竟我背後站著的是作為政治家的駐防老先生。」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00056",
		linknext = "0041_00058",
		line = 744,
	},
	["0041_00058"] = {
