		{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00217", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=1000},
		{"text"},
		text = {
			vo = {
				{"vo", file="hitoura0044", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Let me tell you one thing, boy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“──我就这么说吧，年轻人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「──我就這麼說吧，年輕人。」",
