					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That has nothing to do with this. I know there is something that only she can do.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这种事无关紧要。她也，一定只有她才能做的事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這種事無關緊要。她也，一定只有她才能做的事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0041_00073",
		linknext = "0041_00075",
