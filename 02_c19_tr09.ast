				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我什么都没做。我召集了FS，让他们送想回家的人回去、帮忙那些人找口饭吃──我就往南去了青蓝岛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我什麼都沒做。我召集了FS，讓他們送想回家的人回去、幫忙那些人找口飯吃──我就往南去了青藍島。」",
					{"rt2"},
				},
			},
		},
