	},
	["0023_00188"] = {
		{"fg", file="ikuko_01f_00001", file1="ikuko_01f_00101", file2="ikuko_01f_00223", path=":fg/ikuko_01f/", id=30, ch="郁子", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0671", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“The wisdom of youth, I guess. You have a general idea of where the limits of your power are.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我大概也是自视过高吧。我的能力到底到哪个程度，我自己也大概清楚。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我大概也是自視過高吧。我的能力到底到哪個程度，我自己也大概清楚。」",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00187",
		linknext = "0023_00189",
		line = 2675,
	},
	["0023_00189"] = {
		{"fg", file="ikuko_01f_00001", file1="ikuko_01f_00101", file3="ikuko_01f_00306", path=":fg/ikuko_01f/", id=30, ch="郁子", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0672", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Take riding the boat home for example. If I wanted to, I know I could take out everyone who refused to board. Y’know, ’cause I’m super strong.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“被送上遣返船的那个时候呢。要是我认真起来的话，也是可以把那些人都干掉不登船的喔？你看、我很强吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「被送上遣返船的那個時候呢。要是我認真起來的話，也是可以把那些人都幹掉不登船的喔？你看、我很強吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00188",
		linknext = "0023_00190",
		line = 2688,
	},
	["0023_00190"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file3="jun_01f_00309", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, you are pretty strong.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是啊，真的强得不得了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是啊，真的強得不得了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00189",
		linknext = "0023_00191",
		line = 2700,
	},
	["0023_00191"] = {
		{"fg", file="ikuko_01f_00001", file1="ikuko_01f_00101", file3="ikuko_01f_00313", path=":fg/ikuko_01f/", id=30, ch="郁子", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0673", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Yeah. But, I couldn’t do it. I knew dealing with whoever was in front of me was my limit, and it’d all end up the same in the end... so I just didn’t bother.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嗯。⋯⋯但是呢，这件事最后没有下文。我知道打倒眼前的对手就差不多是极限了，最后还是会落得得一样的下场⋯⋯结果最后我就什么也没做了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嗯。⋯⋯但是呢，這件事最後沒有下文。我知道打倒眼前的對手就差不多是極限了，最後還是會落得得一樣的下場⋯⋯結果最後我就什麼也沒做了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00190",
		linknext = "0023_00192",
		line = 2713,
	},
	["0023_00192"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A wise choice, I think.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我觉得那是非常明智的判断。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我覺得那是非常明智的判斷。",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00191",
		linknext = "0023_00193",
		line = 2723,
	},
	["0023_00193"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They were merciless to the people on the island, disguising what they did as justice.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那些人以正义为由头，对岛上的人毫不留情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那些人以正義為由頭，對島上的人毫不留情。",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00192",
		linknext = "0023_00194",
		line = 2733,
	},
	["0023_00194"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If they’d tried to resist, there’s a high chance that not only Ikuko, but other members of the FS wouldn’t have been able to walk away unscathed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"若是抵抗不成，恐怖怕不只是郁子，多数的FS都会遭受池鱼之殃。",
					{"rt2"},
				},
			},
			tw = {
				{
					"若是抵抗不成，恐怖怕不只是郁子，多數的FS都會遭受池魚之殃。",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00193",
		linknext = "0023_00195",
		line = 2743,
	},
	["0023_00195"] = {
		{"cgact", file="cgact", act="表示アクション", alpha=0, id=2, lv=2, time=300, alphadel=1, style="reset"},
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00229", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300, draw2=1},
		{"ex", time=500, func="wait"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0674", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“If it were you and your crew, you would have resisted even in a situation like that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“若是淳之介君你的话，那时候一定会起身反抗的吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「若是淳之介君你的話，那時候一定會起身反抗的吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00194",
		linknext = "0023_00196",
		line = 2760,
	},
	["0023_00196"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00218", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
		text = {
			ja = {
