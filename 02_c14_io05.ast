	["0023_00092"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The sleight-of-hand-lip-service-under-the-table technique—using every trick in the book to get one over on those more powerful than me. That’s my M.O.",
					{"rt2"},
				},
			},
			cn = {
				{
					"使些小聪明的迂回手段──我原先的作法尽是走一些宵小之道来达到目的。",
