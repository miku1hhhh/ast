	["0023_00091"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And if I’m to take Ikuko head-on without a weapon, then I may as well give up any hopes of winning unless I go in with some kamikaze offensive.",
					{"rt2"},
				},
			},
			cn = {
				{
					"跟郁子的比试也是。赤手空拳正面迎击无异于直接找死。",
