				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I get angry just thinking about it... Argh, I can’t believe I lost to a dumb robot penguin! It makes me want to scream... Inami, can I use Blowbo like a punching bag for a minute?”",
