	["0023_00238"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00206", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=20},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fair enough. Sorry, by the way. For asking weird questions.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是吗⋯⋯抱歉。问了唐突的问题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是嗎⋯⋯抱歉。問了唐突的問題。」",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00237",
		linknext = "0023_00239",
		line = 3332,
	},
	["0023_00239"] = {
		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file2="ikuko_02m_00207", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0691", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“It wasn’t weird. It’s not like I’m trying to forget what happened or anything, so don’t worry.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“没事的，没关系。也还没到连回想都不想回想的地步啦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「沒事的，沒關係。也還沒到連回想都不想回想的地步啦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00238",
		linknext = "0023_00240",
		line = 3347,
	},
	["0023_00240"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00211", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0692", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Besides, I can’t stand girls who walk around all sullen and miserable like they have the most tragic backstory ever. It’s enough to make me vom.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我啊，可是对要装成那种一脸‘人家有着悲催过去喔～～’的苦情女主角的事，讨厌到连胃里的食糜酱都会跑出来的程度喔──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我啊，可是對要裝成那種一臉『人家有著悲催過去喔～～』的苦情女主角的事，討厭到連胃裡的食糜醬都會跑出來的程度喔──」",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00239",
		linknext = "0023_00241",
		line = 3362,
	},
	["0023_00241"] = {
