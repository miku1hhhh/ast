	},
	["0023_00209"] = {
		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file3="ikuko_02m_00310", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[2400] = {
				{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file2="ikuko_02m_00211", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, timestamp=33, delay2=2400, mode=3, x=-5, y=-5},
			},
			[2399] = {
				{"transitiontime", time=300, timestamp=33, delay2=2400},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko0680", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I’d love to say I always wanted to fight alongside you... Buuut, no. I don’t think I have.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我会跟着亲爱的一起战斗──虽然是想这么说，不过实际上没有呢。嗯嗯，没有──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我會跟著親愛的一起戰鬥──雖然是想這麼說，不過實際上沒有呢。嗯嗯，沒有──」",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00208",
		linknext = "0023_00210",
		line = 2948,
	},
	["0023_00210"] = {
		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file3="ikuko_02m_00306", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0681", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I’ve loved this island from the very beginning, so I’ve always fought to protect the perverted sex law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我从一开始就很喜欢这座岛，就像是被变态条例给拯救了一样呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我從一開始就很喜歡這座島，就像是被變態條例給拯救了一樣呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00209",
		linknext = "0023_00211",
		line = 2963,
	},
	["0023_00211"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Huh.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样啊──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣啊──」",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00210",
		linknext = "0023_00212",
		line = 2975,
	},
	["0023_00212"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The majority of the relationships I’ve made on this island have been with members of the NLNS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我在这座岛上的交友关系，几乎只仅限于NLNS的同伴们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我在這座島上的交友關係，幾乎只僅限於NLNS的同伴們。",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00211",
		linknext = "0023_00213",
		line = 2985,
	},
	["0023_00213"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I never had the opportunity to get to know a real believer of the perverted ways. Some of them were saved by it, after all.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以说，我几乎对那些变态条例的信奉者们一无所知──但果然，也是有被它所拯救的人们存在着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以說，我幾乎對那些變態條例的信奉者們一無所知──但果然，也是有被它所拯救的人們存在著。",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00212",
		linknext = "0023_00214",
		line = 2995,
	},
	["0023_00214"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, they make up the overwhelming majority of people on the island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不如说，在这座岛上，被拯救的人们才是压倒性的多数派。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不如說，在這座島上，被拯救的人們才是壓倒性的多數派。",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00213",
		linknext = "0023_00215",
		line = 3005,
	},
	["0023_00215"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It only makes sense that Fumino, who’s grown up seeing the island in this light, would choose the path of coexistence.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以说文乃她──这个一直将这座岛的看在眼里的少女才会盼望着一条共存之道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以說文乃她──這個一直將這座島的看在眼裡的少女才會盼望著一條共存之道。",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00214",
		linknext = "0023_00216",
		line = 3015,
	},
	["0023_00216"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I made my choice for her sake, and looking back, I don’t think it was the wrong one.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然当时是为了文才这么做的──但当时的选择并没有错，我再次地想着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然當時是為了文才這麼做的──但當時的選擇並沒有錯，我再次地想著。",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00215",
		linknext = "0023_00217",
		line = 3025,
	},
	["0023_00217"] = {
		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file2="ikuko_02m_00202", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[6000] = {
				{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file2="ikuko_02m_00229", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, timestamp=34, delay2=6000, mode=3, x=-5, y=-5},
			},
			[5999] = {
				{"transitiontime", time=300, timestamp=34, delay2=6000},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko0682", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I prefer the law after you and your friends changed it, by the way. Because you seem happier now. Rei can get a little hot-headed, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“但我也喜欢被亲爱的你们更改之后的条例喔？不管怎么说，亲爱的你看起来很高兴。不过礼酱有点太激动就是了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「但我也喜歡被親愛的你們更改之後的條例喔？不管怎麼說，親愛的你看起來很高興。不過禮醬有點太激動就是了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00216",
		linknext = "0023_00218",
		line = 3043,
	},
	["0023_00218"] = {
		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file2="ikuko_02m_00210", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0683", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Tokie also really liked that world too, it seems. We’ll have to get back to it soon.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“桐香酱好像也很中意那个世界。所以说大家还是尽早回去吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「桐香醬好像也很中意那個世界。所以說大家還是儘早回去吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00217",
		linknext = "0023_00219",
		line = 3058,
	},
	["0023_00219"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
