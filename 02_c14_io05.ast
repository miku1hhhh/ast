			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well there’s less chance of being attacked now that the event’s over. It makes sense that they can relax a little.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“活动后被袭击的风险性会一口气降低──所以心情会比平时更放松喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「活動後被襲擊的風險性會一口氣降低──所以心情會比平時更放鬆喔。」",
					{"rt2"},
				},
			},
		},
