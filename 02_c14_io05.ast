	["0023_00220"] = {
		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file3="ikuko_02m_00311", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ikuko said she was upset after losing to Hamedori, but looking at her now, that irritation is nowhere to be seen.",
					{"rt2"},
				},
			},
			cn = {
				{
					"郁子说着输给Hamedori君气不过，但那张侧脸上却一点也看不见沮丧的影子。",
					{"rt2"},
				},
			},
			tw = {
				{
					"郁子說著輸給Hamedori君氣不過，但那張側臉上卻一點也看不見沮喪的影子。",
					{"rt2"},
				},
