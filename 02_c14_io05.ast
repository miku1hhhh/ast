			cn = {
				{
					name = {"モブ女C", "蠢酷"},
					"“没错，全都是田中队长打倒的。队长可以说是一勃绝尘干穴无双。跟传言中‘强得乱七八糟’说得一模一样，真的强得乱七八糟耶⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "蠢酷"},
					"「沒錯，全都是田中隊長打倒的。隊長可以說是一勃絕塵幹穴無雙。跟傳言中『強得亂七八糟』說得一模一樣，真的強得亂七八糟耶⋯⋯！」",
					{"rt2"},
				},
			},
		},
