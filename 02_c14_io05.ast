		{"fgact", ch="フェラチオウム24", id=24, act="汎用アクション", rotate=-360, time=800, loop=-1, ease="none", ax=800, ay=450},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She makes a circle with her thumb and forefinger, then looks at the sky through it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她以拇指和食指箍出一个圈，透过这个圈圈望向天空。",
