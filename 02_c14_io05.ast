			},
			cn = {
				{
					"连缓都没缓过劲就接着跟我们做爱对战──隔天却能这样跟没事一样地笑闹着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"連緩都沒緩過勁就接著跟我們做愛對戰──隔天卻能這樣跟沒事一樣地笑鬧著。",
