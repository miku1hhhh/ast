			cn = {
				{
					name = {"郁子"},
					"“真是了不得呢。昨天那么胡闹，今天就可以像什么事都没发生过、开开心心地出门。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「真是了不得呢。昨天那麼胡鬧，今天就可以像什麼事都沒發生過、開開心心地出門。」",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00164",
