	["0023_00180"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00206", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0667", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I can’t say I totally get it, but I kinda do. When I think about being pushed away by Tokie or Rei and the others... it scares me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“虽然不知道该怎么说⋯⋯但我懂你的心情。我也是，桐香酱跟礼酱她们⋯⋯要是被她们疏远了⋯⋯光想我都觉得可怕。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「雖然不知道該怎麼說⋯⋯但我懂你的心情。我也是，桐香醬跟禮醬她們⋯⋯要是被她們疏遠了⋯⋯光想我都覺得可怕。」",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00179",
		linknext = "0023_00181",
		line = 2565,
	},
