				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Exactly. Impatient, bizarre planning, impossible-to-comprehend special moves... That’s how you fight, right Junnosuke?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“原来如此。所以那种诡异又不入流的作战方式跟那些让人无法理解的必杀技，才会是淳之介你们一直以来的做法吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「原來如此。所以那種詭異又不入流的作戰方式跟那些讓人無法理解的必殺技，才會是淳之介你們一直以來的做法吧？」",
					{"rt2"},
				},
			},
		},
