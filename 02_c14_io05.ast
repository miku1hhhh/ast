	["0023_00090"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I shouldn’t just be focusing on how to get stronger. I should be thinking about how to outsmart her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我原先所想的净是该使什么手段才能赢过对方、而非是单纯的想要提升自己的能力。",
					{"rt2"},
				},
