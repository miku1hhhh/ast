			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Shall we head home? Rei said we’re having curry for dinner and we’re not gonna get any if we’re too late getting back.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“差不多也该回去了。礼酱说了晚餐是咖喱喔。要是太晚回去的话就没我们的份了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「差不多也該回去了。禮醬說了晚餐是咖哩喔。要是太晚回去的話就沒我們的份了。」",
					{"rt2"},
				},
			},
		},
