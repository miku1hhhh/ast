	["0023_00201"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A smile appears on her face as she takes a gulp of her coffee milk, but I can feel the shadow of something else behind her expression.",
					{"rt2"},
				},
			},
			cn = {
				{
					"纵使她一边吸着咖啡牛奶一边露出了笑意──我依旧在那个表情里看到暗藏着的阴霾。",
