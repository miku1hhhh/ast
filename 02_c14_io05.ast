	["0023_00184"] = {
		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file2="ikuko_02m_00229", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0669", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“But, I must say I’m impressed by you, Junnosuke. At your ability to push ahead despite the way things are. There’s no way I could do it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“但我觉得⋯⋯淳之介君你果然很了不起呢。就算碰到这种情况，你也没有气馁持续努力着。要是我的话我绝对做不到的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「但我覺得⋯⋯淳之介君你果然很了不起呢。就算碰到這種情況，你也沒有氣餒持續努力著。要是我的話我絕對做不到的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00183",
		linknext = "0023_00185",
		line = 2615,
	},
	["0023_00185"] = {
