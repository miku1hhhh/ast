	["0023_00182"] = {
		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file2="ikuko_02m_00224", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0668", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“It was really scary, leaving them behind. For them to look at me like they never knew me hurt... a lot.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“光是跟大家分开就这么可怕了⋯⋯要是被摆出一副我不认识你的脸⋯⋯那真是太痛苦了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「光是跟大家分開就這麼可怕了⋯⋯要是被擺出一副我不認識你的臉⋯⋯那真是太痛苦了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00181",
		linknext = "0023_00183",
		line = 2590,
	},
	["0023_00183"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’ll probably never forget the times after the abolishment of the perverted sex law when the island was purged.",
