	["0023_00045"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ikuko, Touka and Rei—the Big Three—should have had what it took to keep up.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然而，说着输了的郁子、桐香跟礼前辈──三巨头应该还有继续战斗下去的能力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然而，說著輸了的郁子、桐香跟禮前輩──三巨頭應該還有繼續戰鬥下去的能力。",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00044",
		linknext = "0023_00046",
		line = 690,
	},
	["0023_00046"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The only reason they had to withdraw was because I was knocked out suddenly.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因此不得不退出战斗的最大理由──除了我在一瞬间失去了战斗能力的这件事以外别无他想。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因此不得不退出戰鬥的最大理由──除了我在一瞬間失去了戰鬥能力的這件事以外別無他想。",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00045",
		linknext = "0023_00047",
		line = 700,
	},
	["0023_00047"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Everyone is too nice to say it, but the reason we were able to secure an escape route was because we put up just enough of a fight to stall Hamedori.",
					{"rt2"},
				},
			},
			cn = {
				{
					"大家都很温柔所以没有说出口──要是在那种情况下有退路可走，就可以阻止Hamedori君、与之对抗。",
					{"rt2"},
				},
			},
			tw = {
				{
					"大家都很溫柔所以沒有說出口──要是在那種情況下有退路可走，就可以阻止Hamedori君、與之對抗。",
					{"rt2"},
				},
			},
		},
