					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don’t know about that...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这个嘛⋯⋯”",
					{"rt2"},
