	["0023_00088"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I know I can’t win in a fair fight, so I resort to cunning in order to get the upper hand.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正是知道正面迎敌赢不了对方，我才会一直都以一些投机取巧的偏门左道取胜。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正是知道正面迎敵贏不了對方，我才會一直都以一些投機取巧的偏門左道取勝。",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00087",
		linknext = "0023_00089",
		line = 1262,
	},
	["0023_00089"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don’t think there’s anything wrong with training yourself but even Ikuko wouldn’t stand a chance against someone she’s no match for.",
					{"rt2"},
				},
			},
			cn = {
				{
					"锻炼自己固然不是坏事──不过碰上连郁子也不敌的对手的话，要赢是完全不可能的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"鍛鍊自己固然不是壞事──不過碰上連郁子也不敵的對手的話，要贏是完全不可能的。",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00088",
