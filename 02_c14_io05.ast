				},
			},
			tw = {
				{
					name = {"郁子"},
					"「但不管怎麼說，結果都是這樣喔。如果是正大光明的對戰的情況，淳之介君你太弱了。你在跟我PK時唯一贏過我的那次，是用了秘密武器勃起肉棒對吧？」",
					{"rt2"},
