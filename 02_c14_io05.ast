	["0023_00205"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Have you ever considered fighting like I do?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“郁子你也⋯⋯你是真的曾经想过，像我们那样战斗吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「郁子你也⋯⋯你是真的曾經想過，像我們那樣戰鬥嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00204",
		linknext = "0023_00206",
		line = 2890,
	},
	["0023_00206"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file3="ikuko_01m_00312", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0679", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Hmm... You mean, have I ever wanted to fight to take down the law, you mean?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“唔⋯⋯你是指，为了推翻条例而战吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「唔⋯⋯你是指，為了推翻條例而戰嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00205",
		linknext = "0023_00207",
		line = 2905,
	},
	["0023_00207"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well if you wanna put it simply, then yeah.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“──细究起来的话，是这么说没错。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「──細究起來的話，是這麼說沒錯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00206",
		linknext = "0023_00208",
		line = 2917,
	},
	["0023_00208"] = {
		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file3="ikuko_02m_00304", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ikuko touches a pointer finger to her cheek and turns her head in contemplation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"郁子用食指戳着自己的脸颊，歪着头思考。",
					{"rt2"},
				},
			},
			tw = {
				{
					"郁子用食指戳著自己的臉頰，歪著頭思考。",
