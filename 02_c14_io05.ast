	["0023_00044"] = {
		{"ex", time=500, func="wait"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"...and yet we were still left with the bitter taste of defeat in our mouths.",
					{"rt2"},
				},
