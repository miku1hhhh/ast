	["0023_00043"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We were able to draw out the enemy leader just as we had planned during our fight with the BoaF the other day...",
					{"rt2"},
				},
			},
			cn = {
				{
					"在前几天与‘Tori公’的战斗里，我们按照计划成功地引出了对方的首领。",
