	},
	["0023_00197"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0675", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“You would have for sure. Just five or six of you were making enemies all over the island. I think back on it now and still wonder what the hell we were doing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“你肯定会的。因为你可是靠着仅仅5、6个人之力就与全岛为敌。老实说到了现在我也还是很纳闷你们到底是怎么做得到。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「你肯定會的。因為你可是靠著僅僅5、6個人之力就與全島為敵。老實說到了現在我也還是很納悶你們到底是怎麼做得到。」",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00196",
		linknext = "0023_00198",
		line = 2784,
	},
	["0023_00198"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file3="ikuko_01m_00306", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[12300] = {
				{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00229", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, timestamp=32, delay2=12300, mode=3, x=-5, y=-5},
			},
			[12299] = {
				{"transitiontime", time=300, timestamp=32, delay2=12300},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko0676", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I’m also a little jealous, though. Not being able to see the edge of your own limitations and just charging through anyway. Kind of like Misaki.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“但是呢，我有点羡慕你呢。像这样⋯⋯不知道自己的极限在哪，奋力向前的感觉。怎么说，美岬酱就是这种典型吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「但是呢，我有點羨慕你呢。像這樣⋯⋯不知道自己的極限在哪，奮力向前的感覺。怎麼說，美岬醬就是這種典型吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00197",
		linknext = "0023_00199",
		line = 2802,
	},
	["0023_00199"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file3="jun_01f_00309", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That’s because Misaki doesn’t pay any attention to what’s ahead or behind her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“美岬是根本就没有瞻前顾后的概念好吗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「美岬是根本就沒有瞻前顧後的概念好嗎。」",
					{"rt2"},
				},
			},
		},
		linkback = "0023_00198",
		linknext = "0023_00200",
		line = 2814,
	},
	["0023_00200"] = {
