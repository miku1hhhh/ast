					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Why would you say that all of a sudden... Do you not think I’m hot the rest of the time?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“突、突然之间说什么啊……那种说法，好像在说现在不可爱一样不是吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「突、突然之間說什麼啊……那種說法，好像在說現在不可愛一樣不是嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00399",
		linknext = "0073_00401",
		line = 5016,
	},
	["0073_00401"] = {
