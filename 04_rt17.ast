		{"text"},
		text = {
			vo = {
				{"vo", file="rei1542", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I know... With you and Hinami helping me out, I feel like I can finally be honest with myself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯……正因为你愿意这么说……正因为有雏见在背后推我一把……所以我总算、能够诚实面对自己了”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯……正因為你願意這麼說……正因為有雛見在背後推我一把……所以我總算、能夠誠實面對自己了」",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00415",
		linknext = "0073_00417",
		line = 5213,
	},
	["0073_00417"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="rhcg030102", x=0, y=0, path=":cg/rhcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1543", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Whether it’s the island, or our families... We’ve all got things that are gonna cause us pain.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“即使如此……岛上的事情、家里的事情之类的……今后，我想我一定还会有许多事情让你烦恼吧”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「即使如此……島上的事情、家裡的事情之類的……今後，我想我一定還會有許多事情讓你煩惱吧」",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00416",
		linknext = "0073_00418",
