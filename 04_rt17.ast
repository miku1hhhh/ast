				{
					name = {"淳之介", "Junnosuke"},
					"“So let me be there for you as well when things get tough. I’m also pretty clumsy, but we’ll hold each other up. Okay?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以──在礼难过的时候，请让我待在你的身边。要说笨拙我也差不多……所以就让我们支持着彼此走下去吧”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以──在禮難過的時候，請讓我待在妳的身邊。要說笨拙我也差不多……所以就讓我們支持著彼此走下去吧」",
					{"rt2"},
				},
			},
		},
