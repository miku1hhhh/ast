	["0073_00414"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="rhcg030102", x=0, y=0, path=":cg/rhcg03/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1541", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“That said, I don’t exactly think it was wrong to reject you that day. The road ahead is gonna be really tough for you... for both of us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……可是、啊。就算是现在，我也不觉得……拒绝你的告白、是个错误。因为、今后……我肯定会给你平添许多辛苦”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……可是、啊。就算是現在，我也不覺得……拒絕你的告白、是個錯誤。因為、今後……我肯定會給你平添許多辛苦」",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00413",
		linknext = "0073_00415",
		line = 5186,
	},
