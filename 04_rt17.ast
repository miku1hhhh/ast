			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I just want you to let me support you. I might be a little clumsy and unable to do it as well as Hinami, but I just want to be with you, no matter what.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“到时候……请让我支持你吧。我很笨拙，想必没办法像雏见做得那么好……可是不论如何，我也想跟你在一起”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「到時候……請讓我支持你吧。我很笨拙，想必沒辦法像雛見做得那麼好……可是不論如何，我也想跟你在一起」",
					{"rt2"},
				},
			},
		},
