	["0073_00008"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My room, my little nest, the place that I can be at my most calm... But with Rei here with me, I’m totally on edge.",
					{"rt2"},
				},
			},
			cn = {
				{
					"比任何地方都令人安心、可以说是老巢的自己房间──光是有礼在这里，就让我心中骚然。",
					{"rt2"},
				},
			},
			tw = {
				{
					"比任何地方都令人安心、可以說是老巢的自己房間──光是有禮在這裡，就讓我心中騷然。",
					{"rt2"},
				},
			},
		},
