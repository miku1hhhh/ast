	["0073_00155"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1465", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I’m sorry... I don’t know what’s happening to me... I feel so nervous all of a sudden. Haah... Like... what if I hate it...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“对不起，在这种时候……为什么呢？突然、变成这种奇怪的感觉……哈啊……想说……要是想起了不愉快的事情、该怎么办……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「對不起，在這種時候……為什麼呢？突然、變成這種奇怪的感覺……哈啊……想說……要是想起了不愉快的事情、該怎麼辦……」",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00154",
		linknext = "0073_00156",
		line = 1965,
	},
	["0073_00156"] = {
		{"text"},
		text = {
