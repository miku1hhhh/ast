			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I’m sorry... I don’t mean to make it awkward this late... It’s okay, go ahead. You can put it in.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“真的对不起……在这种时候说起这种话题……不、不要紧的……随你喜欢插进来……也可以的”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「真的對不起……在這種時候說起這種話題……不、不要緊的……隨你喜歡插進來……也可以的」",
					{"rt2"},
				},
			},
		},
		linkback = "0073_00155",
