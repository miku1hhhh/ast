	["0073_00416"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="rhcg030101", x=0, y=0, path=":cg/rhcg03/", lv=18, ev=1, bx=800, by=450},
