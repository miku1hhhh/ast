					{"rt2"},
				},
			},
			en = {
				{
					"She doesn’t seem to particularly mind herself, so we’ve decided to not make any noise for now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她本人早就已经不在意了，所以决定暂时维持现状。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她本人早就已經不在意了，所以決定暫時維持現狀。",
					{"rt2"},
				},
			},
		},
