	},
	["0002_00403"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00201", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=12},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Anyway, I wanted to ask what you were doing after this. You’re not on dinner duty today, are you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“另外我想问一下你之后有没有事？你今天不是负责做晚餐的吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「另外我想問一下妳之後有沒有事？妳今天不是負責做晚餐的吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00402",
		linknext = "0002_00404",
		line = 5772,
	},
	["0002_00404"] = {
