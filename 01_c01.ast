					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What a kind and unselfish heart... I’m always so proud to have you as a little sister.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你真是充满包容力又心地善良的人……不愧是我的妹妹。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳真是充滿包容力又心地善良的人……不愧是我的妹妹。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00592",
		linknext = "0002_00594",
		line = 8512,
	},
	["0002_00594"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg020102", x=0, y=0, path=":cg/kcg02/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0058", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“So if you do start dating someone, promise me she’ll be a total slut! I won’t accept anyone else, okay?! And to be specific, I’m talking about Nanase!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“相对的，要交往一定要找婊子喔……！除此之外的人我都不承认……！具体形容就是奈奈濑姐……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「相對的，要交往一定要找婊子喔……！除此之外的人我都不承認……！具體形容就是奈奈瀨姊……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00593",
		linknext = "0002_00595",
		line = 8528,
	},
	["0002_00595"] = {
