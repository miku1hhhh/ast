					{"rt2"},
				},
			},
			en = {
				{
					"Perhaps they find her approachable (regardless of how she might object) because she’s Mr. Hitoura’s daughter.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说不定因为她是那位仁浦氏的女儿，所以自带一些亲切感吧（她本人很不服气就是了）。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說不定因為她是那位仁浦氏的女兒，所以自帶一些親切感吧（她本人很不服氣就是了）。",
					{"rt2"},
				},
			},
