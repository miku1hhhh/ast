			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Glug, glug, hooh! Nothing beats the feeling of washing down unchewed white rice that’s stuck in your throat with some tea! Isn’t that right?!”",
