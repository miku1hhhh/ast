	["0002_00596"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0059", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I mean, she’s your first love...! She’s always so concerned about the both of us, and she’ll probably still give me attention even if you become lovers... It just has to be her!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“因为那是我的初恋对象……！她很关心我和哥哥，如果她跟你交往，她应该也会照顾到我……果然只有奈奈濑姐是首选……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「因為那是我的初戀對象……！她很關心我和哥哥，如果她跟你交往，她應該也會照顧到我……果然只有奈奈瀨姊是首選……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00595",
		linknext = "0002_00597",
		line = 8552,
	},
	["0002_00597"] = {
