					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“That’s right. You’ve surely seen the video promoting tourism on Seiran Island at least once before, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯。青蓝岛的观光介绍PV，你之前也看过一次吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯。青藍島的觀光介紹PV，你之前也看過一次吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00195",
		linknext = "0002_00197",
		line = 3000,
	},
	["0002_00197"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00223", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
