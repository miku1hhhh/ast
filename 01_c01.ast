		},
		text = {
			vo = {
				{"vo", file="asane0012", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Oh, fine. I guess I’ll get around to eating breakfast... But it’s Fumino’s turn today, right...? I don’t feel that motivated... CHOMP CHOMP CHOMP!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“真没办法，该吃早餐了……不过今天是轮到文乃吧……积极是很重要的……嘎嘎嘎！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「真沒辦法，該吃早餐了……不過今天是輪到文乃吧……積極是很重要的……嘎嘎嘎！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00053",
		linknext = "0002_00055",
		line = 798,
	},
	["0002_00055"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If you’re going to say something, you really need to mean it...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你最好对自己说的话负责。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳最好對自己說的話負責。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00054",
		linknext = "0002_00056",
		line = 810,
	},
	["0002_00056"] = {
		{"fg", file="asane_02m_00008", file1="asane_02m_00101", file2="asane_02m_00223", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=1, size=12.5, time=200, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0013", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Well, anyone who calls herself a professional needs to always maintain a high level of motivation.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不管面对什么环境，专业人士都必须要维持高积极性材行啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不管面對什麼環境，專業人士都必須要維持高積極性材行啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00055",
		linknext = "0002_00057",
		line = 826,
	},
	["0002_00057"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00205", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You’re gonna get fat if that’s your approach to eating. It’s already hard enough to carry you around, okay?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你说那种话，还一直吃的话会发胖喔。搬你下来真的很累人耶。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳說那種話，還一直吃的話會發胖喔。搬妳下來真的很累人耶。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00056",
		linknext = "0002_00058",
		line = 838,
	},
	["0002_00058"] = {
