	["0002_00327"] = {
		{"bgm", file="bgm02", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh, Nanase... Well, I happened to catch the president looking spaced out for once. We’re just chatting, that’s all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哦，奈奈濑……没有啦，我难得看到会长在发呆，才在这边跟她随便聊聊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哦，奈奈瀨……沒有啦，我難得看到會長在發呆，才在這邊跟她隨便聊聊。」",
					{"rt2"},
				},
			},
		},
