	["0002_00415"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file3="ikuko_02m_00304", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0001", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Hmm, how did it go again...? I only read the school rules once when I joined.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嗯～是这样吗～？我只有在入队的时候看了一次校规。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嗯～是這樣嗎～？我只有在入隊的時候看了一次校規。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00414",
		linknext = "0002_00416",
		line = 5927,
	},
	["0002_00416"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00211", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0002", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“We’re allowed to dress ourselves, but when it comes to issued school uniforms you have to wear the one for your legal gender? To ensure the smoothest possible sex or something?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我们虽然是便服学校，但指定的制服必须按照性别穿上对吧？因为打着可以更顺利做爱的名目。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我們雖然是便服學校，但指定的制服必須按照性別穿上對吧？因為打著可以更順利做愛的名目。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00415",
		linknext = "0002_00417",
		line = 5942,
	},
	["0002_00417"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=12},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And Fumino is listed as male on both her family register and her school ID. She’s stuck wearing guy clothes until that gets fixed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“文乃在户籍上和学生证上面都写说是男性，在修改以前都必须穿男生的制服。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「文乃在戶籍上和學生證上面都寫說是男性，在修改以前都必須穿男生的制服。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00416",
		linknext = "0002_00418",
		line = 5954,
	},
	["0002_00418"] = {
