	["0002_00567"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s like watching a baby go from bawling to beaming in the blink of an eye... Or it would be, if I was talking about someone cuter than my online troll of a little sister.",
					{"rt2"},
				},
			},
			cn = {
				{
					"刚才大哭的乌鸦笑了……话说妹妹在网络上疯狂挑衅他人的表现，好像有点太可爱了喔。",
					{"rt2"},
				},
			},
			tw = {
				{
					"剛才大哭的烏鴉笑了……話說妹妹在網路上瘋狂挑釁他人的表現，好像有點太可愛了喔。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00566",
		linknext = "0002_00568",
		line = 8205,
	},
	["0002_00568"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Still, she cheered up. That’s all that really matters.",
					{"rt2"},
				},
			},
			cn = {
				{
					"既然她现在已经恢复精神，这样就好了吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"既然她現在已經恢復精神，這樣就好了吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00567",
		linknext = "0002_00569",
		line = 8215,
	},
	["0002_00569"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“How long has it been since we’ve slept together like this anyway, Asa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“话说回来，我多久没像这样跟你一起睡觉了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「話說回來，我多久沒像這樣跟妳一起睡覺了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00568",
		linknext = "0002_00570",
		line = 8227,
	},
	["0002_00570"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg020102", x=0, y=0, path=":cg/kcg02/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0052", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Maybe about three months...? You know we used to do this for days before coming here...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“睽违三个月了不是吗……？在我们搬来这里以前，常常好几天都一起睡觉……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「睽違三個月了不是嗎……？在我們搬來這裡以前，常常好幾天都一起睡覺……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00569",
		linknext = "0002_00571",
		line = 8243,
	},
	["0002_00571"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00201", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah... I guess it has been a while now since the accident...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样啊……事故发生后，已经过了一段时间了啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣啊……事故發生後，已經過了一段時間了啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00570",
		linknext = "0002_00572",
		line = 8255,
	},
	["0002_00572"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The two of us came back to this island we could barely remember after suddenly losing our parents in a traffic accident.",
					{"rt2"},
				},
			},
			cn = {
				{
					"父母因为交通事故突然去世，遗留的兄妹俩来到了根本没来过的岛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"父母因為交通事故突然去世，遺留的兄妹倆來到了根本沒來過的島。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00571",
		linknext = "0002_00573",
		line = 8265,
	},
	["0002_00573"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The island had a law that permitted perverted sex, among other things.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这座岛还设立了可以进行变态做爱的条例。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這座島還設立了可以進行變態做愛的條例。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00572",
		linknext = "0002_00574",
		line = 8275,
	},
	["0002_00574"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We ended up having to live a life on the run. It was all we could do to survive.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们一直持续过着侥幸逃避的生活。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們一直持續過著僥倖逃避的生活。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00573",
		linknext = "0002_00575",
		line = 8285,
	},
	["0002_00575"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00201", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Thanks to a whole bunch of coincidences, we found our first ally in Nanase.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“透过种种巧合，奈奈濑率先成了我们的同伴。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「透過種種巧合，奈奈瀨率先成了我們的同伴。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00574",
		linknext = "0002_00576",
		line = 8297,
	},
	["0002_00576"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg020103", x=0, y=0, path=":cg/kcg02/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0053", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Wata joined us next thanks to you completely overstepping your bounds...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“多亏哥哥一马当先的勇气，再来换渡酱成了同伴……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「多虧哥哥一馬當先的勇氣，再來換渡醬成了同伴……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00575",
		linknext = "0002_00577",
		line = 8313,
	},
	["0002_00577"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00201", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Then there was Misaki, thanks to me deciding to ignore you and fight...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我不听你的话上前战斗，让美岬加入了我们──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我不聽妳的話上前戰鬥，讓美岬加入了我們──」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00576",
		linknext = "0002_00578",
		line = 8325,
	},
	["0002_00578"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0054", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“And then Fumino came to us, fought with a bunch of people, and disappeared again...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“文乃来到了我们家，和好多人一起战斗，后来文乃又不见了──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「文乃來到了我們家，和好多人一起戰鬥，後來文乃又不見了──」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00577",
		linknext = "0002_00579",
		line = 8337,
	},
	["0002_00579"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...Until she reappeared and we fought alongside her, as well as the FS—and managed to put in place the True Perverted Sex Law.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们和归来的文乃、FS一起战斗──获得了真变态条例。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們和歸來的文乃、FS一起戰鬥──獲得了真變態條例。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00578",
		linknext = "0002_00580",
		line = 8349,
	},
	["0002_00580"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So much happened over the course of a few short months.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明只过了几个月，却发生了好多事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明只過了幾個月，卻發生了好多事。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00579",
		linknext = "0002_00581",
		line = 8359,
	},
	["0002_00581"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As someone personally involved in everything that happened, I’m not one to judge how we fought.",
					{"rt2"},
				},
			},
			cn = {
				{
					"战斗的利与弊，身为当事者的我不好评论。",
					{"rt2"},
				},
			},
			tw = {
				{
					"戰鬥的利與弊，身為當事者的我不好評論。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00580",
		linknext = "0002_00582",
		line = 8369,
	},
	["0002_00582"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But the two of us ended up being surrounded by allies before we knew it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"等回过神来，我们兄妹的身边真的多了好多同伴。",
					{"rt2"},
				},
			},
			tw = {
				{
					"等回過神來，我們兄妹的身邊真的多了好多同伴。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00581",
		linknext = "0002_00583",
		line = 8379,
	},
	["0002_00583"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s what brought so much color to our lives that we were nearly able to forget about all the fear and loneliness that came from the death of our parents.",
					{"rt2"},
				},
			},
			cn = {
				{
					"热闹到让我们都要忘了父母去世后的不安和寂寞。",
					{"rt2"},
				},
			},
			tw = {
				{
					"熱鬧到讓我們都要忘了父母去世後的不安和寂寞。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00582",
		linknext = "0002_00584",
		line = 8389,
	},
	["0002_00584"] = {
