			},
			cn = {
				{
					name = {"美岬"},
					"“这么一来",
					{"gaiji", text="①"},
					"就算放开手、嗯齁",
					{"gaiji", text="①"},
					"也能坐得很稳",
					{"gaiji", text="①"},
					"等回过神来就会抵达目的地嗯",
					{"gaiji", text="①"},
					"很优秀哦哦哦",
					{"gaiji", text="①"},
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「這麼一來",
					{"gaiji", text="①"},
					"就算放開手、嗯齁",
					{"gaiji", text="①"},
					"也能坐得很穩",
					{"gaiji", text="①"},
					"等回過神來就會抵達目的地嗯",
					{"gaiji", text="①"},
					"很優秀哦哦哦",
					{"gaiji", text="①"},
					{"gaiji", text="①"},
					"」",
					{"rt2"},
				},
			},
		},
