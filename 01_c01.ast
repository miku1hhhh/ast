	["0002_00335"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00203", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“In any case, I normally wouldn’t have anything to do with someone who looks like a total slut like Nanase, but now she’s an important friend. Not a bride, and not a wife.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“总之，奈奈濑长得像超级婊子，原本是跟我扯不上关系的人种，但她是我们的重要伙伴，既不是我的太太也不是妻子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「總之，奈奈瀨長得像超級婊子，原本是跟我扯不上關係的人種，但她是我們的重要夥伴，既不是我的太太也不是妻子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00334",
		linknext = "0002_00336",
		line = 4865,
	},
	["0002_00336"] = {
