			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“In exchange, I suppose you could say... Tachibana, I have a job I want you to do.”",
