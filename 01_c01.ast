					"I could stay up as late as I want, but instead I’ll wake up early and enjoy my day of rest to the fullest.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然熬夜也没关系，但我想早点起床享受假日。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然熬夜也沒關係，但我想早點起床享受假日。",
					{"rt2"},
				},
			},
		},
