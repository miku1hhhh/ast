				},
			},
			tw = {
				{
					name = {"文乃"},
					"「不是……所以我正打算去圖書館借書……前幾天借的都已經看完了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00403",
		linknext = "0002_00405",
		line = 5787,
	},
	["0002_00405"] = {
