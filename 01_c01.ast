				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“That’s it! The old video made such a strong impact, we have to make something that’s just as impressive!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“就是那样！之前的PV也很有冲击感，新视频可不能输给它……！”",
