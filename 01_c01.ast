		line = 6750,
	},
	["0002_00473"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"An illegal facility from the start, it was ultimately sealed off. There’s no possible way for us to get in now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那原本就是违法设施，所以也被封印，现在不管使用什么手段都没办法进去了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那原本就是違法設施，所以也被封印，現在不管使用什麼手段都沒辦法進去了。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00472",
		linknext = "0002_00474",
		line = 6760,
	},
	["0002_00474"] = {
