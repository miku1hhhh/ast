	["0002_00310"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00201", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0019", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“How cold of you. All you need to do is stay by my side and hold my hand now and then, you know. Act now and there’s a real scholarship in it for you, not even a student loan.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“真无情，偶尔在一旁握住我的手就好了唷？现在加入还会附赠不必还款的奖学金。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「真無情，偶爾在一旁握住我的手就好了唷？現在加入還會附贈不必還款的獎學金。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00309",
		linknext = "0002_00311",
		line = 4538,
	},
