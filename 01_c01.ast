			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“There, there, everything will be okay. In that case, you can sleep with me tonight. Come on, get in.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“好啦好啦乖乖，那我们今天一起睡吧，进去棉被里。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「好啦好啦乖乖，那我們今天一起睡吧，進去棉被裡。」",
					{"rt2"},
				},
			},
		},
