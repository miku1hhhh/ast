			},
			tw = {
				{
					"但我們管不住別人的嘴，隨著時間的過去，我們的傳聞瞬間就流傳出去了。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00231",
		linknext = "0002_00233",
		line = 3522,
	},
	["0002_00233"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It seems the source of the information was a loose-lipped and soft-headed natural PR spokesperson of a chairwoman... but what good would blaming her do?",
					{"rt2"},
				},
			},
			cn = {
				{
					"据说传闻的源头就是口风不紧、脑袋很差却具备情报扩散力的理事长大姐……责怪她也没用。",
					{"rt2"},
				},
			},
			tw = {
				{
					"據說傳聞的源頭就是口風不緊、腦袋很差卻具備情報擴散力的理事長大姊……責怪她也沒用。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00232",
		linknext = "0002_00234",
		line = 3532,
	},
	["0002_00234"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The battle ended up turning into a tale of young men and women who sought the freedom to be lewd...",
					{"rt2"},
				},
			},
			cn = {
				{
					"相传那场战斗是少年少女追求变态的故事……。",
					{"rt2"},
				},
			},
			tw = {
				{
					"相傳那場戰鬥是少年少女追求變態的故事……。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00233",
		linknext = "0002_00235",
		line = 3542,
	},
	["0002_00235"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Now people call it things like “The Boner Uprising,” or “The Lewd War,” or “The Cocktober Revolution.”",
					{"rt2"},
				},
			},
			cn = {
				{
					"现在似乎被称之为‘改造事态的勃起’‘变态战役’‘勃起革命’等。",
					{"rt2"},
				},
			},
			tw = {
				{
					"現在似乎被稱之為『改造事態的勃起』『變態戰役』『勃起革命』等。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00234",
		linknext = "0002_00236",
		line = 3552,
	},
	["0002_00236"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After that, the island’s residents have started to take notice of us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"后来，我们就一直受到岛上居民的注目。",
					{"rt2"},
				},
			},
			tw = {
				{
					"後來，我們就一直受到島上居民的注目。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00235",
		linknext = "0002_00237",
		line = 3562,
	},
	["0002_00237"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00206", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Not like we did anything that deserves being publicly honored, though...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但我们也没做什么值得受表扬的事……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但我們也沒做什麼值得受表揚的事……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00236",
		linknext = "0002_00238",
		line = 3574,
	},
	["0002_00238"] = {
		{"fg", file="asane_01f_00001", file1="asane_01f_00101", file2="asane_01f_00222", path=":fg/asane_01f/", id=30, ch="麻沙音", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
		{"text"},
