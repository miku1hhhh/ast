			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“If anything, it feels like we forced them to clean up after our mess...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“感觉比较像是收拾了自己的烂摊子……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「感覺比較像是收拾了自己的爛攤子……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00237",
		linknext = "0002_00239",
		line = 3587,
	},
	["0002_00239"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Normally we would be finding ourselves in the somewhat awkward position of having killed off the perverted sex law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我们本来是站在破坏变态条例的立场，所以被那样称呼实在是有点尴尬。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我們本來是站在破壞變態條例的立場，所以被那樣稱呼實在是有點尷尬。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00238",
		linknext = "0002_00240",
		line = 3597,
	},
	["0002_00240"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Not to mention that being the center of attention like this is embarrassing too.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且被这样子注目让人很难为情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且被這樣子注目讓人很難為情。",
					{"rt2"},
				},
			},
		},
