			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“对，以前是发生过一些事，但我们现在是可以若无其事往来的好伙伴喔！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「對，以前是發生過一些事，但我們現在是可以若無其事往來的好夥伴喔！」",
					{"rt2"},
				},
			},
		},
