				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The battle may be over now, but that hasn’t changed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使战斗结束后的现在，同伴也没有离开。",
