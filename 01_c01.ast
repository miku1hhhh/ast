					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ男A", "男學生A"},
					"「喂快看，是片桐奈奈瀨耶……！仔細近看她那副超色的身體，眼睛都要流出忍耐汁了……！」",
					{"rt2"},
				},
