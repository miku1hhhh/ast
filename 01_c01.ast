		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ever since all of that happened, Nanase has been making me flustered every time we meet by casually touching on the subject.",
					{"rt2"},
				},
			},
			cn = {
				{
					"从那次以后，奈奈濑只要一逮到机会就会轻描淡写提出来，想让我慌张。",
