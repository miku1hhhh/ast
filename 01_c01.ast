	["0002_00201"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00202", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0017", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I did hear that you’re all healed up now! Everyone’ll be so surprised when they see it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“而且我听说你的身体恢复得差不多了！大家都会很惊讶喔～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「而且我聽說你的身體恢復得差不多了！大家都會很驚訝喔～！」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00200",
		linknext = "0002_00202",
		line = 3073,
	},
	["0002_00202"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00213", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If you want freaks that’ll surprise everyone, they’re all over the place here. Why not just grab them...?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果要找让大家惊讶的怪人，那边就有一大堆，去抓来就好了吧……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果要找讓大家驚訝的怪人，那邊就有一大堆，去抓來就好了吧……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00201",
		linknext = "0002_00203",
		line = 3085,
	},
	["0002_00203"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00216", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
