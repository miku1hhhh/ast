	["0002_00472"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s been a while since we lost our secret base... NLNS headquarters.",
					{"rt2"},
				},
			},
			cn = {
				{
					"自从我们的秘密基地……NLNS本部消失后好久没这样了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"自從我們的秘密基地……NLNS本部消失後好久沒這樣了。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00471",
