			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“So if you do this!❤ You can even ride, mmh!❤ Hands-freeee!❤ You’ll be at your destination before you knooow it...!❤ What a masterpieeece!❤❤”",
					{"rt2"},
