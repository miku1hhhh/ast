		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"People seem to be less reserved about talking to Fumino compared to how they treat the rest of us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃比其他成员还容易被别人搭话。",
