		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00209", file4="jun_01f_00404", path=":fg/jun_01f/", id=30, ch="淳之介", lv=4, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Whoa! What’s up, Asa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“唔哦哦，麻沙酱怎么了？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「唔哦哦，麻沙醬怎麼了？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00554",
		linknext = "0002_00556",
		line = 7994,
	},
	["0002_00556"] = {
		{"fg", file="asane_01m_00008", file1="asane_01m_00101", file2="asane_01m_00221", path=":fg/asane_01m/", id=3, lv=4, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=3, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0046", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I dropped a round on netplay just now so I throttled my connection to lag out a win then started teabagging the guy but he reported me and they banned my ID it’s not faaaaaaaaair!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我刚才在网络对战输了一回合就刻意降网速制造时间差赢了以后做出屈伸动作挑衅就被控诉违规现在ID被停权了啦啊啊──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「我剛才在網路對戰輸了一回合就刻意降網速製造時間差贏了以後做出屈伸動作挑釁就被控訴違規現在ID被停權了啦啊啊──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00555",
		linknext = "0002_00557",
		line = 8010,
	},
	["0002_00557"] = {
		{"fg", file="asane_02m_00008", file1="asane_02m_00101", file2="asane_02m_00211", path=":fg/asane_02m/", id=3, lv=4, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=2, size=27.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0047", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Urgh... Argh! Can you believe it, after I put in all that hard work to earn the W?! I think you’d be totally justified in patting me on the head and making me feel all better!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“呜呜、呜呜！麻沙酱好不容易努力拿下了胜利这太过分了吧！快点安慰我啦～～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗚嗚、嗚嗚！麻沙醬好不容易努力拿下了勝利這太過分了吧！快點安慰我啦～～！」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00556",
		linknext = "0002_00558",
		line = 8026,
	},
	["0002_00558"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file3="jun_01f_00309", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yep, there, there... Most people wouldn’t try to comfort a little sister who’s too stupid to realize that what she did wasn’t hard work or earned, but I will...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哦哦好乖好乖……不知道这种行为算不上努力的笨妹妹就由我来安慰吧……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哦哦好乖好乖……不知道這種行為算不上努力的笨妹妹就由我來安慰吧……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00557",
		linknext = "0002_00559",
		line = 8038,
	},
	["0002_00559"] = {
		{"se", id=0, loop=0, file="se_a093"},
		{"fg", file="asane_01l_00008", file1="asane_01l_00101", file2="asane_01l_00211", path=":fg/asane_01l/", id=3, lv=4, head="asane_01l", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=2, size=12.5, time=350, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0048", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Waaah! Waaah! I can’t find anyone online ever willing to take my side! I’m always alone, no matter where I goooooo! I’m so lonelyyy! You gotta hold me tight in your aaarms!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“呜哇──！呜哇──！网络上根本没人站在我这边～～！我不管去哪里都是孤单一人～～！好寂寞喔～～！快点抱紧我～～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗚哇──！嗚哇──！網路上根本沒人站在我這邊～～！我不管去哪裡都是孤單一人～～！好寂寞喔～～！快點抱緊我～～！」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00558",
		linknext = "0002_00560",
		line = 8055,
	},
	["0002_00560"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00201", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
