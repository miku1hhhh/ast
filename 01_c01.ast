	["0002_00247"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She’s as popular as ever... or actually, it seems she’s even more popular than before. The authority she commands is unrivaled.",
					{"rt2"},
				},
			},
			cn = {
				{
					"冷泉院的人气还是那么高……不如说似乎比以前更高了，那道威光简直无人能敌。",
					{"rt2"},
				},
			},
			tw = {
				{
					"冷泉院的人氣還是那麼高……不如說似乎比以前更高了，那道威光簡直無人能敵。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00246",
		linknext = "0002_00248",
		line = 3703,
	},
	["0002_00248"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’m sure people around her naturally figure that she’s at the head of the Steel Six.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她被认定是‘钢铁六人’领导者这点，也让周围的人热血沸腾了吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她被認定是『鋼鐵六人』領導者這點，也讓周圍的人熱血沸騰了吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00247",
		linknext = "0002_00249",
		line = 3713,
	},
	["0002_00249"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She’s not without her own problems, but she never shows them in public.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她本人似乎觉得有点困扰，但不会在众人面前展现。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她本人似乎覺得有點困擾，但不會在眾人面前展現。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00248",
		linknext = "0002_00250",
		line = 3723,
	},
	["0002_00250"] = {
		{"se", id=0, stop=1, time=1000},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0001", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Heh. I see you’re all putting yourselves out there and enjoying perverted sex as always. I’m very glad to see it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘呵呵，各位今天都很积极地享受着变态做爱呢！非常好。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『呵呵，各位今天都很積極地享受著變態做愛呢！非常好。』",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00249",
		linknext = "0002_00251",
		line = 3736,
	},
	["0002_00251"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0002", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Sex has returned to us once more with the enforcement of the True Perverted Sex Law, but it has done so in a new form.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘执行真变态条例后，做爱再度回到了我们的身边，但形式和以前不一样了。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『執行真變態條例後，做愛再度回到了我們的身邊，但形式和以前不一樣了。』",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00250",
		linknext = "0002_00252",
		line = 3748,
	},
	["0002_00252"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0003", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“It’s come back to us in a form that’s more fun, more pleasurable, and more usable as a tool for communication with those you care for.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘做爱复活成更开心、更舒适、并成为与重要他人之间的交流工具了。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『做愛復活成更開心、更舒適、並成為與重要他人之間的交流工具了。』",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00251",
		linknext = "0002_00253",
		line = 3760,
	},
	["0002_00253"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0004", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Sex is not meant to be repressed, nor is it something to be imposed... That was the conclusion we came to.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘做爱并非能够抑制的行为，也不能加以强制……这是我们得出的结论。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『做愛並非能夠抑制的行為，也不能加以強制……這是我們得出的結論。』",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00252",
		linknext = "0002_00254",
		line = 3772,
	},
	["0002_00254"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0005", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“The island is gradually changing along with the thoughts and feelings of its people.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘我们要集合整座岛和大家的意志，慢慢改变形体。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『我們要集合整座島和大家的意志，慢慢改變形體。』",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00253",
		linknext = "0002_00255",
		line = 3784,
	},
	["0002_00255"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0006", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“But it is not a perfect place. It is still developing, and it has yet to become somewhere that affirms all human beings.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘但现在还不是完全体，还在发展的途中，还不能够成为所有人肯定的模样。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『但現在還不是完全體，還在發展的途中，還不能夠成為所有人肯定的模樣。』",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00254",
		linknext = "0002_00256",
		line = 3796,
	},
	["0002_00256"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0007", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“That is why I want all of you to make this island an even better place by showing even more respect and understanding to each other.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"‘所以各位，我们要更尊重他人，更理解他人，让整座岛变得更美好。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"『所以各位，我們要更尊重他人，更理解他人，讓整座島變得更美好。』",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00255",
