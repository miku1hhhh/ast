	["0002_00065"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00215", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bad girl. What am I always telling you? You need to really chew your food before you swallow it. That’s how you get esophageal cancer.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不好好嚼完再吞很容易得食道癌，我不是说不要再这么做了吗？”",
