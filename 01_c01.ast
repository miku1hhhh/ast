			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Unbelievable. Jun and Asa made this without breaking a single plate, using any wrong seasonings, or even burning their clothes! Oh, how you’ve grown...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“没想到那个淳和麻沙酱没打破盘子、没放错调味料、没烧掉衣服就做完了料理……！有显着的成长了呢……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「沒想到那個淳和麻沙醬沒打破盤子、沒放錯調味料、沒燒掉衣服就做完了料理……！有顯著的成長了呢……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00463",
		linknext = "0002_00465",
		line = 6637,
	},
	["0002_00465"] = {
