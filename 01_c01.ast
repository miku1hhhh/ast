	["0002_00590"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0056", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Yeah... You’re in a total harem sitch now, right...? And with all those girls around you... It’s got me feeling kind of lonely...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“嗯……哥哥你现在完全是后宫状态嘛……身边有那么多女生围绕……让我有点寂寞……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗯……哥哥你現在完全是後宮狀態嘛……身邊有那麼多女生圍繞……讓我有點寂寞……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00589",
		linknext = "0002_00591",
		line = 8469,
	},
	["0002_00591"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00208", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And that’s why you were teabagging your opponents...! I can’t believe it, how could I make my beloved little sister feel lonely like this?! I’m a failure as a big brother!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“所以你才会用屈伸动作挑衅对战对手吗……！怎么会这样？我竟然让最爱的妹妹感到寂寞，我是个失格的哥哥──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「所以妳才會用屈伸動作挑釁對戰對手嗎……！怎麼會這樣？我竟然讓最愛的妹妹感到寂寞，我是個失格的哥哥──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00590",
		linknext = "0002_00592",
		line = 8481,
	},
	["0002_00592"] = {
		{"evset", file="kcg02", set="kcg02", path=":ev/kcg02/"},
		{"evset", file="kcg020104", set="kcg020104", path=":ev/kcg020104/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="kcg020104", x=0, y=0, path=":cg/kcg02/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0057", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“It’s okay, Bro. Just how it is... Family always comes last, whether in romance or in a house fire...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“没关系啦，哥哥，这也没办法……家人永远是最后一个顺位，这点不管在火灾现场还是恋爱之中都一样……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「沒關係啦，哥哥，這也沒辦法……家人永遠是最後一個順位，這點不管在火災現場還是戀愛之中都一樣……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00591",
		linknext = "0002_00593",
		line = 8500,
	},
	["0002_00593"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00210", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
