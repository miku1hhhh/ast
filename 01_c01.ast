					"……她还是一样，是个让人无法理解的少女。",
					{"rt2"},
				},
			},
			tw = {
				{
					"……她還是一樣，是個讓人無法理解的少女。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00286",
		linknext = "0002_00288",
		line = 4245,
	},
	["0002_00288"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00201", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It’s rare to see someone as busy as you standing around in a place like this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“看到忙碌的会长在这种地方发呆，还挺稀奇的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「看到忙碌的會長在這種地方發呆，還挺稀奇的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00287",
		linknext = "0002_00289",
		line = 4257,
	},
	["0002_00289"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00201", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0011", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Well, my work had just come to a good stopping point. I’ll be done with my afternoon tasks once I look over these documents.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我只是想稍微从工作中透透气，今天只要看过这些文件，上午的分就做完了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我只是想稍微從工作中透透氣，今天只要看過這些文件，上午的分就做完了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00288",
		linknext = "0002_00290",
		line = 4272,
	},
	["0002_00290"] = {
		{"se", id=0, loop=0, file="se_a141"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She sounds nonchalant as she waves a thick stack of papers around.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她轻轻甩着厚厚的纸束，若无其事地说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她輕輕甩著厚厚的紙束，若無其事地說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00289",
		linknext = "0002_00291",
		line = 4283,
	},
	["0002_00291"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I imagine it would take me and Asa a good two days to just read through them all.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那份量的话，我和麻沙酱光是阅读就得花上两天吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那份量的話，我和麻沙醬光是閱讀就得花上兩天吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00290",
		linknext = "0002_00292",
		line = 4293,
	},
	["0002_00292"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But perhaps it’s a simple task for our dear student council president.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过这对我们学生会长来说，是不值得一提的小工作。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過這對我們學生會長來說，是不值得一提的小工作。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00291",
		linknext = "0002_00293",
		line = 4303,
	},
	["0002_00293"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Things have calmed down on the island, but it seems like there’s no end to the FS’s work.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“岛上的事都告了一个段落，FS的工作却还是没完没了啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「島上的事都告了一個段落，FS的工作卻還是沒完沒了啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00292",
		linknext = "0002_00294",
		line = 4315,
	},
	["0002_00294"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00202", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0012", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Yes, there is still much we’d like to do. I’m just glad that I’m able to be of help.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“是啊，我还有很多事情想做，能让自己活用在那些事情中，让我觉得很幸福。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「是啊，我還有很多事情想做，能讓自己活用在那些事情中，讓我覺得很幸福。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00293",
		linknext = "0002_00295",
		line = 4330,
	},
	["0002_00295"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00219", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What kind of work are you doing right now? You mentioned before something about improving the equipment at the perverted amusement park?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“最近要做什么工作？先前听说你们要强化变态游乐园的设备什么的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「最近要做什麼工作？先前聽說你們要強化變態遊樂園的設備什麼的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00294",
		linknext = "0002_00296",
		line = 4342,
	},
	["0002_00296"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00201", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0013", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I’m now working to improve livability on the island. Though we have the three districts of the Spanktuary, the Chaste Zone, and the Hole-y Land, many are still dissatisfied.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“现在在强化居住性。‘保护",
					{"gaiji", text="①"},
					"区’的A地区、‘禁乱区’的B地区、‘挖屁乐园’的C地区，这几个区域还是有很多不满的抱怨。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「現在在強化居住性。『保護",
					{"gaiji", text="①"},
					"區』的A地區、『禁亂區』的B地區、『挖屁樂園』的C地區，這幾個區域還是有很多不滿的抱怨。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00295",
		linknext = "0002_00297",
		line = 4357,
	},
	["0002_00297"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00201", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Like what, in particular?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“具体来说是？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「具體來說是？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00296",
		linknext = "0002_00298",
		line = 4369,
	},
	["0002_00298"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00212", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0014", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Frequent complaints include the fixation on ‘Holes’ being insufficiently inclusive to lesbians, or how it’s unclear why the ‘Chaste Zone’ is in District B in the first place.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“‘也有蕾丝边在使用，却用“挖”这个字眼很奇怪’‘明明是禁乱区却说是B地区到底是怎样’这些抱怨很多呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「『也有蕾絲邊在使用，卻用“挖”這個字眼很奇怪』『明明是禁亂區卻說是B地區到底是怎樣』這些抱怨很多呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00297",
		linknext = "0002_00299",
		line = 4384,
	},
	["0002_00299"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The former might have some merit, but do you really need to listen to people who say the latter...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“前者就算了，后者的抱怨有听的必要吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「前者就算了，後者的抱怨有聽的必要嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00298",
		linknext = "0002_00300",
		line = 4396,
	},
	["0002_00300"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00202", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="桐香8", id=8, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0015", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I do. I want to make this island a place that nobody wants to leave.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“对，我希望这座岛成为大家都不想离开的场所。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「對，我希望這座島成為大家都不想離開的場所。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00299",
		linknext = "0002_00301",
		line = 4412,
	},
	["0002_00301"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She laughs to herself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她呵呵笑着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她呵呵笑著。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00300",
		linknext = "0002_00302",
		line = 4422,
	},
	["0002_00302"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0016", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Because if I do that, you won’t want to leave here either, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“这么一来，你也不会想要离开这里吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「這麼一來，你也不會想要離開這裡吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00301",
		linknext = "0002_00303",
		line = 4437,
	},
	["0002_00303"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It seems the president doesn’t want me to let me off the island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"看来会长不希望我离开这座岛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"看來會長不希望我離開這座島。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00302",
		linknext = "0002_00304",
		line = 4447,
	},
	["0002_00304"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If I’m being honest, I don’t see how that would serve to motivate anybody. She shouldn’t push herself too hard, though.",
					{"rt2"},
				},
			},
			cn = {
				{
					"老实说我不太懂怎么会把这个当动机努力，别太勉强自己吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"老實說我不太懂怎麼會把這個當動機努力，別太勉強自己吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00303",
		linknext = "0002_00305",
		line = 4457,
	},
	["0002_00305"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Too much work is like poison for the body, you know. Take things in moderation.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“过劳对身体不好，要适度一点喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「過勞對身體不好，要適度一點喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00304",
		linknext = "0002_00306",
		line = 4469,
