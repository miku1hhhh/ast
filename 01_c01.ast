					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Heh... It did make me a little happy. I could feel just how much my little sister had grown...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哼……感受到妹妹的成长，让我有点开心呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哼……感受到妹妹的成長，讓我有點開心呢……」",
					{"rt2"},
				},
			},
		},
