		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0027", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“As much as I’d love to keep standing around and feeling chagrined, I should get back to work. Please excuse me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“虽然我想继续感受这股悔恨感，但我还有工作要做，先失陪了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「雖然我想繼續感受這股悔恨感，但我還有工作要做，先失陪了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00340",
		linknext = "0002_00342",
		line = 4948,
	},
	["0002_00342"] = {
