					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Was your heart stolen away by that ephemeral little girl instead, then? Or maybe that little junior of yours? Or was it the plain girl?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“那你的心是被那个虚幻少女夺走了吗？还是那个小小的前辈？或是那个朴素女？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「那你的心是被那個虛幻少女奪走了嗎？還是那個小小的前輩？或是那個樸素女？」",
					{"rt2"},
				},
			},
		},
