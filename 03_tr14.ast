				},
			},
			cn = {
				{
					name = {"郁子"},
					"“阿宅会喜欢的女人……1.清纯2.长发3.总是面带笑容4.嚣张的小屁妞5.擅长倾听有点色色的话题。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「阿宅會喜歡的女人……1.清純2.長髮3.總是面帶笑容4.囂張的小屁妞5.擅長傾聽有點色色的話題。」",
					{"rt2"},
				},
			},
		},
