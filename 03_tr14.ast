					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Ugh, it pains me to admit it, but that’s actually cute...! The president is always so calm and collected. If Jun knew that side of her, he would be one-hit KO’d!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“唔，虽然很不甘心，不过的确很可爱……！要是让淳知道平常扑克脸的会长私底下会这么做的话，他肯定会被一击必杀的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「唔，雖然很不甘心，不過的確很可愛……！要是讓淳知道平常撲克臉的會長私底下會這麼做的話，他肯定會被一擊必殺的……！」",
					{"rt2"},
				},
			},
		},
