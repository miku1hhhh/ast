				},
			},
			tw = {
				{
					name = {"文乃"},
					"「這、這個嘛……我們本來也想出點主意，不過等我們發現時，他已經換好衣服了……原本應該會由我們幫他搭配穿搭才對……」",
					{"rt2"},
				},
