				{"vo", file="rin0232", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Is that so? Interesting. As interesting as forcing a clown to say a joke that only you can understand.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“哦──真是有趣呢。就像好莱坞明星为了电影试映会来日本，却让他表演现在流行的笑点一样有趣呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「哦──真是有趣呢。就像好萊塢明星為了電影試映會來日本，卻讓他表演現在流行的笑點一樣有趣呢。」",
					{"rt2"},
				},
			},
		},
