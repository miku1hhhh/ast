				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Ayeee! If you act cute and childish, even Darling will be able to hold your hand!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“对对对！她只要像个小孩一直说方言的话，就算是亲爱的也能够轻易牵手吧……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「對對對！她只要像個小孩一直說方言的話，就算是親愛的也能夠輕易牽手吧……！」",
					{"rt2"},
				},
			},
		},
