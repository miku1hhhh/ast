			cn = {
				{
					name = {"淳之介"},
					"“才、才没有这回事……！我们只是出来玩而已……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「才、才沒有這回事……！我們只是出來玩而已……！」",
