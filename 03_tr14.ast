			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I like both cats and dogs. Small or big, I love them all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“虽然我也喜欢猫，不过狗我也喜欢哦，大只和小只的都喜欢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「雖然我也喜歡貓，不過狗我也喜歡哦，大隻和小隻的都喜歡。」",
					{"rt2"},
				},
			},
		},
