					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Come on, there’s no way we would! It would be a tragedy if Ranran and Rinrin knew about it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“我当然不可能这么做……！先不提兰兰，要是凛凛知道的话，她肯定会来搞破坏的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「我當然不可能這麼做……！先不提蘭蘭，要是凜凜知道的話，她肯定會來搞破壞的……！」",
					{"rt2"},
				},
			},
		},
