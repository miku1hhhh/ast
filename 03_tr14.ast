			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Instructor! We decided to compete on a whim, but how are we going to go about it?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“教官，虽然我姑且跟来了，不过具体来说，比赛要怎样进行呢──？”",
