		text = {
			vo = {
				{"vo", file="rin0231", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“Yes. And what you two are up to? We hope you aren’t in an illicit sexual relationship. You can’t be, right? You’re the student council president and the hero of the island, after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“嗯，你们在做什么呢？该不会是异性间的不纯交流吧？应该不是这样对吧？你们可是学生会长和岛上的英雄呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「嗯，你們在做什麼呢？該不會是異性間的不純交流吧？應該不是這樣對吧？你們可是學生會長和島上的英雄呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00216",
		linknext = "0061_00218",
		line = 3699,
	},
	["0061_00218"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00104", file2="jun_01f_00203", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
