			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“That’s because Tokie doesn’t understand people’s emotions at all... Darling is likely to get angry if anything happens at this rate...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“毕竟小桐香不了解人心到让人绝望的程度呢……要是她在这种状态下做了什么，就算在约会中，感觉亲爱的也会生气……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「畢竟小桐香不了解人心到讓人絕望的程度呢……要是她在這種狀態下做了什麼，就算在約會中，感覺親愛的也會生氣……」",
					{"rt2"},
				},
			},
		},
