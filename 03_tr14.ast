			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“We’ll observe these two and when one of them does something cute, they’ll be granted a point. The one with the higher score wins.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“观察他们的行动，只要做出‘可爱的行为’就会根据可爱度给予点数，总分最高的人就赢了……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「觀察他們的行動，只要做出『可愛的行為』就會根據可愛度給予點數，總分最高的人就贏了……！」",
					{"rt2"},
				},
			},
		},
