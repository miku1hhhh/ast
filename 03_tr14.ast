		text = {
			vo = {
				{"vo", file="gmoba0122", path=":vo/", ch="gmob"},
			},
			ja = {
				{
					name = {"モブ女A", "女A"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Girl A"},
					"“Even the filthiest public janitor can fuck his tired old wife with this aphrodisiac whisky ‘Nude Royale’! Free of charge today, Fucksgiving Day!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "女A"},
					"“如果是加了媚药的威士忌‘裸妇小牛’，不管是多么肮脏的管理员大叔都能和疲于工作的人妻尽情做爱！现在有感谢客人的大放射服务哦～～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "女A"},
					"「如果是加了媚藥的威士忌『裸婦小牛』，不管是多麼骯髒的管理員大叔都能和疲於工作的人妻盡情做愛！現在有感謝客人的大放射服務哦～～！」",
					{"rt2"},
				},
			},
		},
		linkback = "0061_00263",
		linknext = "0061_00265",
		line = 4422,
	},
	["0061_00265"] = {
