	["0061_00228"] = {
		{"fg", file="ran_01m_00001", file1="ran_01m_00101", file2="ran_01m_00202", file4="ran_01m_00401", path=":fg/ran_01m/", id=13, lv=14, head="ran_01m", ch_origin="蘭", ch="蘭13", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ran0095", path=":vo/", ch="ran"},
			},
			ja = {
				{
					name = {"蘭"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"蘭", "Ran"},
					"“In the Hanamaru family, we’ve been using dogs for ejaculation management for generations. We started with small dogs, then medium, and finally, our father moved on to big ones.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"蘭", "兰"},
					"“花丸家代代都会使用狗传授射精管理，刚开始是小狗，再来是中型犬、大型犬，最后则是会进化到自己的父亲哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"蘭"},
					"「花丸家代代都會使用狗傳授射精管理，剛開始是小狗，再來是中型犬、大型犬，最後則是會進化到自己的父親哦。」",
					{"rt2"},
				},
			},
		},
