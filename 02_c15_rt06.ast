			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I don’t think so.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“才不是自我满足呢。”",
					{"rt2"},
				},
