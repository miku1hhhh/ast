		linkback = "0028_00145",
		linknext = "0028_00147",
		line = 1805,
	},
	["0028_00147"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But despite all this, Rei continued to protect her younger siblings like the caring big sister she was.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即便如此，身为姐姐的她，还是一直守护着妹弟们。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即便如此，身為姐姐的她，還是一直守護著妹弟們。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00146",
		linknext = "0028_00148",
		line = 1815,
	},
	["0028_00148"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This hellish experience was an unending nightmare for her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那些地狱般的日子就像无尽的噩梦一样继续着──",
					{"rt2"},
				},
			},
			tw = {
				{
					"那些地獄般的日子就像無盡的噩夢一樣繼續著──",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00147",
		linknext = "0028_00149",
		line = 1825,
	},
	["0028_00149"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Yet, she’s speaking about it blankly, like she’s reading from a script.",
					{"rt2"},
				},
			},
			cn = {
				{
					"仿佛在读事先准备好的剧本般，她用毫无感情的语调叙述着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"彷彿在讀事先準備好的劇本般，她用毫無感情的語調敘述著。",
					{"rt2"},
				},
			},
		},
