		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her father had huge debts when he died.",
					{"rt2"},
				},
			},
			cn = {
				{
					"过世的父亲身负高额借款。",
					{"rt2"},
				},
			},
			tw = {
				{
					"過世的父親身負高額借款。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00143",
		linknext = "0028_00145",
		line = 1785,
	},
	["0028_00145"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"At night, the remaining family members were constantly harassed by debt collectors.",
					{"rt2"},
				},
			},
			cn = {
				{
					"每晚都害怕着紧迫盯人的讨债。",
					{"rt2"},
				},
			},
			tw = {
				{
					"每晚都害怕著緊迫盯人的討債。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00144",
		linknext = "0028_00146",
		line = 1795,
	},
	["0028_00146"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her mother was often assaulted.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被母亲施以暴力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被母親施以暴力。",
					{"rt2"},
				},
