	},
	["0028_00136"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hey, even I’ve got secrets I want to hide and a past I want to run from.",
					{"rt2"},
				},
			},
			cn = {
				{
					"每个人都有想要隐藏的秘密、都有想要埋藏的过去。",
					{"rt2"},
				},
			},
			tw = {
				{
					"每個人都有想要隱藏的秘密、都有想要埋藏的過去。",
					{"rt2"},
				},
