	},
	["0028_00088"] = {
		{"bgm", stop=1},
		{"fg", file="rei_02m_00008", file1="rei_02m_00101", file3="rei_02m_00321", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0643", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I’ve sent so many people to the guillotine. I forced them into the very sexual acts they were trying so hard to avoid.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我⋯⋯把很多人逼上了断头台。我逼迫了那些不想要随意做爱的人去做爱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我⋯⋯把很多人逼上了斷頭台。我逼迫了那些不想要隨意做愛的人去做愛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00087",
		linknext = "0028_00089",
		line = 1064,
	},
	["0028_00089"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
