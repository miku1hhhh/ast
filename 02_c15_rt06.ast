				{
					"The computer was right. Using its “correct speech patterns” certainly made my partners happy, and made me very popular indeed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在性爱的过程中使用正确用语确实地让对象愉快，于是我的评价也变好了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在性愛的過程中使用正確用語確實地讓對象愉快，於是我的評價也變好了。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00575",
