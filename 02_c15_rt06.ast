				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hah, classic Hinami. And yet... She’s so good at reading how people are feeling.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“哈哈，确实是雏见才会有的状况。但不要看她那样⋯⋯她比谁都能⋯⋯看透人心呢。”",
