		text = {
			vo = {
				{"vo", file="rei0761", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I think she got what she deserved. The way it happened was a little violent, but... it happens. I thought that one day it might happen. She was always strange.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“⋯⋯我觉得那个人活该。她的做法那么苛刻⋯⋯这只是刚好的报应，只是不知道什么时候会来而已。那个人一直都很奇怪⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「⋯⋯我覺得那個人活該。她的做法那麼苛刻⋯⋯這只是剛好的報應，只是不知道什麼時候會來而已。那個人一直都很奇怪⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00652",
		linknext = "0028_00654",
		line = 7963,
	},
	["0028_00654"] = {
		{"fg", file="rei_02m_00008", file1="rei_02m_00101", file2="rei_02m_00211", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
