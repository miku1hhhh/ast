		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’ve got no reason to keep this stuff inside any more.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然这一直是我心中的秘密，但也不用再隐瞒了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然這一直是我心中的祕密，但也不用再隱瞞了。",
