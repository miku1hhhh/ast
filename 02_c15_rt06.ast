	["0028_00612"] = {
		{"fg", file="rei_01m_00008", file1="rei_01m_00101", file2="rei_01m_00209", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[2400] = {
				{"fg", file="rei_01m_00008", file1="rei_01m_00101", file2="rei_01m_00214", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=38, delay2=2400, mode=3, x=-5, y=-5},
			},
			[2399] = {
				{"transitiontime", time=300, timestamp=38, delay2=2400},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0746", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Oh... So, Hinami did talk about it...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是、吗⋯⋯雏见她是这没说的吗⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是、嗎⋯⋯雛見她是這沒說的嗎⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00611",
		linknext = "0028_00613",
		line = 7412,
	},
	["0028_00613"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hinami had always lived on the island, so she didn’t have the kneejerk revulsion to the wanton sexual exploits of its inhabitants that Rei and I did.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一直住在岛上的雏见，并不像我跟礼前辈一样反感乱交行为。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一直住在島上的雛見，並不像我跟禮前輩一樣反感亂交行為。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00612",
		linknext = "0028_00614",
		line = 7422,
	},
	["0028_00614"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But the idea that she wanted to wait for someone she really liked... That was all thanks to Rei being there.",
					{"rt2"},
				},
			},
			cn = {
				{
					"尽管如此，她还是觉得这种事要跟喜欢的人一起做──这一定是因为有礼前辈在的关系。",
					{"rt2"},
				},
			},
			tw = {
				{
					"儘管如此，她還是覺得這種事要跟喜歡的人一起做──這一定是因為有禮前輩在的關係。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00613",
		linknext = "0028_00615",
		line = 7432,
	},
	["0028_00615"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00210", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The reason that Hinami joined us, the NLNS—No Love, No Sex—team... If you look back, it was all because of you, Rei.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“NLNS是宣扬No Love, No 做爱的组织──雏见之所以能成为我们的伙伴，追溯回去也是多亏了礼前辈啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「NLNS是宣揚No Love, No 做愛的組織──雛見之所以能成為我們的夥伴，追溯回去也是多虧了禮前輩啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00614",
		linknext = "0028_00616",
		line = 7444,
	},
	["0028_00616"] = {
		{"fg", file="rei_02m_00008", file1="rei_02m_00102", file3="rei_02m_00309", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0747", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“That’s got to be an overstatement.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“哈。你讲得太夸张了啦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「哈。你講得太誇張了啦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00615",
		linknext = "0028_00617",
		line = 7459,
	},
	["0028_00617"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She smiles uncomfortably, but it’s not all bad.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她露出了苦笑，似乎并不是很认同我的话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她露出了苦笑，似乎並不是很認同我的話。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00616",
		linknext = "0028_00618",
		line = 7469,
	},
	["0028_00618"] = {
		{"fg", file="rei_01m_00008", file1="rei_01m_00101", file2="rei_01m_00201", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[2500] = {
				{"fg", file="rei_01m_00008", file1="rei_01m_00101", file2="rei_01m_00215", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=39, delay2=2500, mode=3, x=-5, y=-5},
			},
			[2499] = {
				{"transitiontime", time=300, timestamp=39, delay2=2500},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0748", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Anyway, the story got a little derailed there. But you have to understand what led up to all the things I’ve committed.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“……有点偏离主题呢。回到正题，不过在这后面也没有什么事好说的就是了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「……有點偏離主題呢。回到正題，不過在這後面也沒有什麼事好說的就是了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00617",
		linknext = "0028_00619",
		line = 7487,
	},
	["0028_00619"] = {
		{"fg", file="rei_01m_00008", file1="rei_01m_00101", file2="rei_01m_00215", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[10000] = {
				{"fg", file="rei_01m_00008", file1="rei_01m_00101", file2="rei_01m_00201", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=40, delay2=10000, mode=3, x=-5, y=-5},
			},
			[9999] = {
				{"transitiontime", time=300, timestamp=40, delay2=10000},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0749", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I reached B-level and managed to join the FS. I protected Hinami while persecuting other non-procreators, becoming an exemplary officer, and eventually president of the disciplinary committee.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我上了B等部，好不容易进了FS，一边保护雏见一边取缔着那些非性产者、为了成为一名为人表率的FS而努力不懈⋯⋯最后成为了风纪委员长。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我上了B等部，好不容易進了FS，一邊保護雛見一邊取締著那些非性產者、為了成為一名為人表率的FS而努力不懈⋯⋯最後成為了風紀委員長。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00618",
		linknext = "0028_00620",
		line = 7505,
	},
	["0028_00620"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00207", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
