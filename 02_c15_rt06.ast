		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00218", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Rei, did you ever think of trying to bargain with them? To get an exemption or something.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯礼前辈，你有没有想过？到底是用什么样的交换条件⋯⋯才能得到豁免？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯禮前輩，你有沒有想過？到底是用什麼樣的交換條件⋯⋯才能得到豁免？」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00085",
		linknext = "0028_00087",
		line = 1031,
	},
	["0028_00087"] = {
		{"fg", mode=-1, id=30},
		{"facehide"},
