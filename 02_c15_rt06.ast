	["0028_00157"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But what? My mind whirs into action by itself, turning over everything she’s said. I notice it instantly.",
					{"rt2"},
