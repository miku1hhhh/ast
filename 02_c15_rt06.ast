			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino had lost her memory in a fight after she stood up to the outlaws who were rampaging around the island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"独自在岛上对抗亡命之徒的文野，几乎失去了那场战斗的所有记忆。",
