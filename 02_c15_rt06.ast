					{"rt2"},
				},
			},
			en = {
				{
					"Rei shakes her head listlessly at my vague question.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈无力地摇头回应了我含糊其辞的问题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩無力地搖頭回應了我含糊其辭的問題。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00086",
