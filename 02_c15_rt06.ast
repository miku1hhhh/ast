		},
		text = {
			vo = {
				{"vo", file="rei0742", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“She helped to unravel my tangled emotions. My situation didn’t change immediately, but Hinami... really soothed me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“雏见她啊，拯救了自暴自弃的我。虽然说情况并没有马上改变⋯⋯但只要有雏见在，我就会很安心。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「雛見她啊，拯救了自暴自棄的我。雖然說情況並沒有馬上改變⋯⋯但只要有雛見在，我就會很安心。」",
					{"rt2"},
				},
			},
		},
