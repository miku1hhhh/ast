	["0028_00566"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That said, the savage pounding constantly attacking me, combined with the terrifying onslaught of pleasure, would have certainly woken me up again immediately.",
					{"rt2"},
				},
			},
			cn = {
				{
					"快要陷入放松地失神状态时、又被强迫接受那种强烈的震动，对于那种冲击产生了一种类似于危机感的、对于快乐的恐惧又瞬间唤醒了我的意识。",
					{"rt2"},
				},
			},
			tw = {
				{
					"快要陷入放鬆地失神狀態時、又被強迫接受那種強烈的震動，對於那種衝擊產生了一種類似於危機感的、對於快樂的恐懼又瞬間喚醒了我的意識。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00565",
