		line = 8642,
	},
	["0028_00707"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But... A long time has passed since then, and I think we’ve both changed.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，在那之后已经过了非常长的一段时间──如今的心境也不可能与以前一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，在那之後已經過了非常長的一段時間──如今的心境也不可能與以前一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00706",
		linknext = "0028_00708",
		line = 8652,
	},
	["0028_00708"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even within the FS, now that I’m fighting alongside them, you could describe Touka and Ikuko as potential partners... but I don’t think of them that way.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算是现在并肩作战的战友FS──虽然雾香和郁子我觉得很重要，但说到爱情，还是不一样的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算是現在並肩作戰的戰友FS──雖然霧香和郁子我覺得很重要，但說到愛情，還是不一樣的。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00707",
