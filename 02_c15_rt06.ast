			cn = {
				{
					"是哪里呢？就算不自觉，我的思绪也会自发地反刍着着她的话──然后我马上就注意到了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是哪裡呢？就算不自覺，我的思緒也會自發地反芻著著她的話──然後我馬上就注意到了。",
