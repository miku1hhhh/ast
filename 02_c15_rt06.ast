		{"text"},
		text = {
			vo = {
				{"vo", file="rei0744", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hinami wanted to do what I was always too scared to do.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“⋯⋯因为我希望雏见她，能不要跟我有一样的遭遇。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「⋯⋯因為我希望雛見她，能不要跟我有一樣的遭遇。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00606",
		linknext = "0028_00608",
		line = 7339,
	},
	["0028_00608"] = {
		{"fg", file="rei_01m_00008", file1="rei_01m_00101", file2="rei_01m_00210", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
