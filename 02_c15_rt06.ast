	["0028_00220"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0053", path=":vo/", ch="gmob"},
			},
			ja = {
				{
					name = {"モブ女C", "SHO職員"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "SHO Personnel"},
					"“Don’t worry about it. We normally deal with non-procreators in here, so we use this to prevent them from resisting.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "SHO职员"},
					"“啊啊，不用太在意。这是对非性产对象使用的，目的是为了让他们变得完全无法反抗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "SHO職員"},
					"「啊啊，不用太在意。這是對非性產對象使用的，目的是為了讓他們變得完全無法反抗。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00219",
		linknext = "0028_00221",
		line = 2754,
	},
	["0028_00221"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0672", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“S-Surely you don’t need to use them on me...? I’m not resisting at all...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这、这样的话⋯⋯我应该没有必要做不是吗⋯⋯？我又⋯⋯不会反抗⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這、這樣的話⋯⋯我應該沒有必要做不是嗎⋯⋯？我又⋯⋯不會反抗⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00220",
		linknext = "0028_00222",
