			},
			cn = {
				{
					"原本住在本岛的少女突然被带到青蓝岛来，明明就还不到条例的适用年龄、却莫名其妙地失去了自己的贞洁──",
					{"rt2"},
				},
			},
			tw = {
				{
					"原本住在本島的少女突然被帶到青藍島來，明明就還不到條例的適用年齡、卻莫名其妙地失去了自己的貞潔──",
					{"rt2"},
				},
			},
		},
