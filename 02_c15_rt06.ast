		{"text"},
		delay = {
			[4800] = {
				{"fg", file="rei_02m_00008", file1="rei_02m_00101", file2="rei_02m_00206", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=44, delay2=4800, mode=3, x=-5, y=-5},
