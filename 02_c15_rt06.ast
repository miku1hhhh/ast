		},
		text = {
			vo = {
				{"vo", file="rei0656", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“God, you’d think the president of the disciplinary committee would be a little better at enforcing the rules. Yet, I’m so self-centered.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“哈⋯⋯我真是个自私的人，像我这样的说是风纪委员长，真是离奇。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「哈⋯⋯我真是個自私的人，像我這樣的說是風紀委員長，真是離奇。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00120",
		linknext = "0028_00122",
		line = 1522,
	},
	["0028_00122"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00218", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hey, I’m no different.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯我大概也跟你一样的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯我大概也跟你一樣的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00121",
		linknext = "0028_00123",
		line = 1534,
	},
	["0028_00123"] = {
		{"fg", file="rei_02m_00008", file1="rei_02m_00101", file2="rei_02m_00224", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", lv=9, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I thought nothing of destroying the law and plunging the island into chaos just to protect a few of my friends.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“因为我是那种，能为了保护几个朋友，不介意推翻条例让整个岛屿陷入混乱的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「因為我是那種，能為了保護幾個朋友，不介意推翻條例讓整個島嶼陷入混亂的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00122",
		linknext = "0028_00124",
		line = 1549,
	},
	["0028_00124"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And that led to Fumino getting hurt and Rei and the other FS members losing their home.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那样做的结果是让文乃受了伤，剥夺了包含礼前辈在内、许多FS的安身之地。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那樣做的結果是讓文乃受了傷，剝奪了包含禮前輩在內、許多FS的安身之地。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00123",
		linknext = "0028_00125",
		line = 1559,
	},
	["0028_00125"] = {
		{"fgact", ch="礼9", id=9, lv=9, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They were almost forcibly deported from the island. And the fact that I got to wield that power was practically a coincidence.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对那些即将以几乎是被驱逐出境的方式被赶出岛外的FS们──我能帮助他们几乎是一种巧合。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對那些即將以幾乎是被驅逐出境的方式被趕出島外的FS們──我能幫助他們幾乎是一種巧合。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00124",
		linknext = "0028_00126",
		line = 1571,
	},
	["0028_00126"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ikuko said that many FS members had problems at home that led to them enlisting.",
					{"rt2"},
				},
			},
			cn = {
				{
					"FS大多是家里有问题的孩子们──当时郁子是这么说的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"FS大多是家裡有問題的孩子們──當時郁子是這麼說的。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00125",
		linknext = "0028_00127",
		line = 1581,
	},
	["0028_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even though the island is the reason she was forced into doing things she didn’t want to do, even though she hated it, Rei still referred to Seiran as “our home.”",
					{"rt2"},
				},
			},
			cn = {
				{
					"这是一座强迫性交的岛屿──虽然表现出强烈的厌恶感，但礼前辈却把青蓝岛说成“我们的安身之处”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這是一座強迫性交的島嶼──雖然表現出強烈的厭惡感，但禮前輩卻把青藍島說成「我們的安身之處」。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00126",
		linknext = "0028_00128",
		line = 1591,
	},
	["0028_00128"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But why?",
					{"rt2"},
				},
			},
			cn = {
				{
					"这是为什么呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"這是為什麼呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00127",
		linknext = "0028_00129",
		line = 1601,
	},
	["0028_00129"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Why did she even come to Seiran Island? What happened between her and Hinami?",
					{"rt2"},
				},
			},
			cn = {
				{
					"她为什么要来青蓝岛──是因为雏见在那里发生了什么事吗？",
