	["0028_00610"] = {
		{"fg", file="rei_01m_00008", file1="rei_01m_00101", file2="rei_01m_00224", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I cut off Rei’s self-pity before it can take root.",
					{"rt2"},
				},
			},
			cn = {
				{
					"直视着礼前辈的目光，我坚定地断言道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"直視著禮前輩的目光，我堅定地斷言道。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00609",
		linknext = "0028_00611",
		line = 7382,
	},
	["0028_00611"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hinami always said that... she wanted to do it with someone she actually liked.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那种事果然还是想跟喜欢的人做──雏见是这么说的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那種事果然還是想跟喜歡的人做──雛見是這麼說的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00610",
