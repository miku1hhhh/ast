					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Listening to what you say, it sounds like you’ve always needed someone to support you, to be a rock in your life.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“但是⋯⋯听你说起起来，你需要一个⋯⋯可以支持你内心的人的样子。”",
