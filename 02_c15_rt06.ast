	["0028_00028"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After Asane’s rejection, I went straight back to the FS dorms and shut myself in my room without talking to a soul.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被麻沙音拒绝的我──在回到FS宿舍后，谁也没打招呼、立即就把自己关在房间里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被麻沙音拒絕的我──在回到FS宿舍後，誰也沒打招呼、立即就把自己關在房間裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00027",
		linknext = "0028_00029",
		line = 326,
	},
	["0028_00029"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I was in shock and knew that I wouldn’t be able to muster a response to anyone... But I remember someone called out to me, didn’t they?",
					{"rt2"},
				},
			},
			cn = {
				{
					"我太震惊了，甚至来不及反驳什么──我确实有着被谁叫唤了的记忆。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我太震驚了，甚至來不及反駁什麼──我確實有著被誰叫喚了的記憶。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00028",
		linknext = "0028_00030",
		line = 336,
	},
	["0028_00030"] = {
