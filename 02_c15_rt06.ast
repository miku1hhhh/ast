	["0028_00231"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0058", path=":vo/", ch="gmob"},
			},
			ja = {
				{
					name = {"モブ女C", "SHO職員"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "SHO Personnel"},
					"“The system will take care of the rest. Your readings are being monitored in real time, so there’s nothing to worry about. If anything happens, I’ll be back straight away!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "SHO职员"},
					"“剩下的那孩子全都会自动完成。放心吧，你的身体状况会被实时监控。如果有什么状况我会在第一时间赶来的！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "SHO職員"},
					"「剩下的那孩子全都會自動完成。放心吧，妳的身體狀況會被實時監控。如果有什麼狀況我會在第一時間趕來的！」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00230",
		linknext = "0028_00232",
		line = 2882,
	},
	["0028_00232"] = {
