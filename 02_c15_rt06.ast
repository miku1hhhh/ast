			},
		},
		text = {
			vo = {
				{"vo", file="rei0660", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“They told me about Seiran Island. Said that if we went there, we would be freed from the awfulness in our lives.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“那时候，有人介绍我们来青蓝岛。据说如果去了那里，就可以摆脱这么苦的生活……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那時候，有人介紹我們來青藍島。據說如果去了那裡，就可以擺脫這麼苦的生活……」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00149",
		linknext = "0028_00151",
		line = 1852,
	},
	["0028_00151"] = {
		{"fg", file="rei_02m_00008", file1="rei_02m_00101", file2="rei_02m_00214", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
