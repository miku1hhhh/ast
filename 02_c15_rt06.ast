				{"fg", file="rei_02m_00008", file1="rei_02m_00101", file3="rei_02m_00320", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=41, delay2=2300, mode=3, x=-5, y=-5},
			},
			[2299] = {
				{"transitiontime", time=300, timestamp=41, delay2=2300},
