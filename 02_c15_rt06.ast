				{"fg", file="rei_02m_00008", file1="rei_02m_00101", file3="rei_02m_00320", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=52, delay2=10300, mode=3, x=-5, y=-5},
			},
			[10299] = {
				{"transitiontime", time=300, timestamp=52, delay2=10300},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0762", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“After my dad died, she lost it, bit by bit. She thought someone was after her, she started eating weirdly... and tried to push it all onto us kids.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“从父亲死掉之后，她就慢慢疯了。总是说着我们被人盯上了。并且不断将这种偏执的思想强诸于我们身上。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「從父親死掉之後，她就慢慢瘋了。總是說著我們被人盯上了。並且不斷將這種偏執的思想強諸於我們身上。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00653",
		linknext = "0028_00655",
		line = 7981,
	},
	["0028_00655"] = {
