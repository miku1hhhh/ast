	["0028_00090"] = {
		{"fg", file="rei_02m_00008", file1="rei_02m_00101", file2="rei_02m_00204", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0644", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“More names than could fill a dozen of these files. That’s how I climbed to the top of the FS. On the backs of other people and their suffering.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不是一两个文件夹就能整理好的那种人数。我就是靠着那个……成为了FS的风纪委员长。用他们作垫脚石。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不是一兩個文件夾就能整理好的那種人數。我就是靠著那個……成為了FS的風紀委員長。用他們作墊腳石。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00089",
		linknext = "0028_00091",
		line = 1091,
	},
	["0028_00091"] = {
		{"fg", file="rei_02m_00008", file1="rei_02m_00101", file2="rei_02m_00210", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0645", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“How could I have the right to ask for exemption from sexual duties? That would be asking way too much.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“为什么⋯⋯像我这样的人能够获得性行为的免除权？⋯⋯像我这样⋯⋯连虫子都不如的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「為什麼⋯⋯像我這樣的人能夠獲得性行為的免除權？⋯⋯像我這樣⋯⋯連蟲子都不如的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00090",
		linknext = "0028_00092",
		line = 1106,
	},
	["0028_00092"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I can’t say anything to that.",
					{"rt2"},
