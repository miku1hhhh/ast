			[4799] = {
				{"transitiontime", time=300, timestamp=44, delay2=4800},
			},
			[8000] = {
				{"fg", file="rei_02m_00008", file1="rei_02m_00101", file2="rei_02m_00219", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=45, delay2=8000, mode=3, x=-5, y=-5},
			},
			[7999] = {
				{"transitiontime", time=300, timestamp=45, delay2=8000},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0752", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Before I knew it, my subordinates, who were always glorifying the law and its benefits, idolized me... I couldn’t betray their trust in me, so I was stuck.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不知不觉地。我对那些赞美着条例的部下们产生了好感⋯⋯我不能背叛他们的信任。结果变得不知道该怎么做才好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不知不覺地。我對那些讚美著條例的部下們產生了好感⋯⋯我不能背叛他們的信任。結果變得不知道該怎麼做才好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00622",
		linknext = "0028_00624",
		line = 7577,
	},
	["0028_00624"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The Hanamaru sisters, Schubert... Images of all the FS members float through my mind.",
					{"rt2"},
				},
			},
			cn = {
				{
					"花丸姐妹、丝丝子，还有舒伯特──我的脑里一一浮现出FS成员们的脸。",
					{"rt2"},
				},
			},
			tw = {
				{
					"花丸姐妹、絲絲子，還有舒伯特──我的腦裡一一浮現出FS成員們的臉。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00623",
		linknext = "0028_00625",
		line = 7587,
	},
	["0028_00625"] = {
		{"fg", file="rei_01m_00008", file1="rei_01m_00101", file2="rei_01m_00214", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0753", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Well, the rest is history. You guys destroyed the law, and everything became exactly how I always wanted it to be.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“哎⋯⋯然后你们就为了要推翻条例而发生了种种的事⋯⋯最后就是用理想的方式皆大欢喜了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「哎⋯⋯然後你們就為了要推翻條例而發生了種種的事⋯⋯最後就是用理想的方式皆大歡喜了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00624",
		linknext = "0028_00626",
		line = 7602,
	},
	["0028_00626"] = {
		{"fg", file="rei_01m_00008", file1="rei_01m_00101", file3="rei_01m_00309", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
