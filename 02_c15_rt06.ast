			[5200] = {
				{"fg", file="rei_02m_00008", file1="rei_02m_00101", file2="rei_02m_00214", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=42, delay2=5200, mode=3, x=-5, y=-5},
			},
			[5199] = {
				{"transitiontime", time=300, timestamp=42, delay2=5200},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0750", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“It felt that way in real life, to be honest. I had given up, took the most pragmatic way out, and before I knew it, I was in this position.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我是实际上的感受也是这样的。在我自我放弃之后一切都过得很快，等我回过神来时我就已经处在那样的身份了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我是實際上的感受也是這樣的。在我自我放棄之後一切都過得很快，等我回過神來時我就已經處在那樣的身份了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00620",
		linknext = "0028_00622",
		line = 7538,
	},
	["0028_00622"] = {
		{"fg", file="rei_02m_00008", file1="rei_02m_00101", file3="rei_02m_00321", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
