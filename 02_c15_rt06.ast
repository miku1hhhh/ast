			},
			[6599] = {
				{"transitiontime", time=300, timestamp=50, delay2=6600},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0760", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“It wasn’t just a shot or two, either. I always told my forces to show no mercy to anyone who does anything to children. That worked out well.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不是一两发而已。数量还满多的。这都是，无法容忍会对小孩子出手的人的我指导结果。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不是一兩發而已。數量還滿多的。這都是，無法容忍會對小孩子出手的人的我指導結果。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00647",
		linknext = "0028_00649",
		line = 7904,
	},
	["0028_00649"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei was casually talking about her own mother being shot in the head and left with permanent brain damage and memory loss...",
					{"rt2"},
				},
			},
			cn = {
				{
					"头部被多发子弹击中的冲击造成了脑震荡，变成了留下后遗症的记忆障碍程度──礼前辈漫不经心地说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"頭部被多發子彈擊中的衝擊造成了腦震盪，變成了留下後遺症的記憶障礙程度──禮前輩漫不經心地說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00648",
		linknext = "0028_00650",
		line = 7914,
	},
	["0028_00650"] = {
		{"ex", time=500, func="wait"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Is this really fine?",
					{"rt2"},
				},
			},
			cn = {
				{
					"发生了这样的事吗？",
					{"rt2"},
				},
			},
			tw = {
				{
					"發生了這樣的事嗎？",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00649",
		linknext = "0028_00651",
		line = 7925,
	},
	["0028_00651"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She endured so much awful shit, and managed to make it to president of the disciplinary committee...",
					{"rt2"},
				},
			},
			cn = {
				{
					"忍耐忍耐再忍耐，好不容易才当上了风纪委员长──",
					{"rt2"},
				},
			},
			tw = {
				{
					"忍耐忍耐再忍耐，好不容易才當上了風紀委員長──",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00650",
		linknext = "0028_00652",
		line = 7935,
	},
	["0028_00652"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Having her own commands used to harm her own mother was a terrible sequence of events.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就在那时，就算不是直接的、她最终还是攻击了自己的母亲──真是太糟糕了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就在那時，就算不是直接的、她最終還是攻擊了自己的母親──真是太糟糕了。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00651",
		linknext = "0028_00653",
