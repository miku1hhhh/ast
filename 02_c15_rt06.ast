	["0028_00159"] = {
		{"fg", file="rei_02m_00008", file1="rei_02m_00101", file3="rei_02m_00320", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0663", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Yup. I was underage at the time. The law shouldn’t have applied to me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“啊啊、没错⋯⋯当时的我还没有到条例的适用年龄。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「啊啊、沒錯⋯⋯當時的我還沒有到條例的適用年齡。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00158",
		linknext = "0028_00160",
		line = 1964,
	},
	["0028_00160"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"On the island, the law governed all aspects of life.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在这座岛上，那个条例拥有绝对的权力。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在這座島上，那個條例擁有絕對的權力。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00159",
		linknext = "0028_00161",
		line = 1974,
	},
	["0028_00161"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Any eligible people who didn’t have sex were subject to severe penalties.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那些受该条例约束但不从事性活动的人将受到严厉惩罚。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那些受該條例約束但不從事性活動的人將受到嚴厲懲罰。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00160",
		linknext = "0028_00162",
		line = 1984,
	},
	["0028_00162"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"By the same token, those who were outside of the law’s remit were strictly forbidden from engaging in sexual activity.",
					{"rt2"},
				},
			},
			cn = {
				{
					"相同的──与未涵盖在条例范围内的人发生性关系，这种事也是被严格禁止的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"相同的──與未涵蓋在條例範圍內的人發生性關係，這種事也是被嚴格禁止的。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00161",
