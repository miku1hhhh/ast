			ja = {
				{
					name = {"モブ女B", "ヘブンズゲート"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女B", "Heaven’s Gate"},
					"“Hello. I am Heaven’s Gate. It is my job to introduce you to the world of pleasure. Let’s begin.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女B", "天堂之门"},
					"‘您好。我是天堂之门。是接下来将引领您进入舒畅的快乐世界的辅助系统。请多多指教。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女B", "天堂之門"},
					"『您好。我是天堂之門。是接下來將引領您進入舒暢的快樂世界的輔助系統。請多多指教。』",
					{"rt2"},
				},
			},
		},
