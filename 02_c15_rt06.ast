	["0028_00578"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I worried that she’d turn her attention to my siblings if I didn’t, so I did as I was told.",
					{"rt2"},
				},
			},
			cn = {
				{
					"要是抵抗的话就会换弟妹们遭殃，所以我也只能顺从。",
