			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“She took a rubber bullet to the head not long after I became president of the disciplinary committee, and it caused her to lose all her memories except some old ones.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“在我成为了风纪委员长后没多久，她就被防暴弹打到头⋯⋯变得只能记得非常久以前的事了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「在我成為了風紀委員長後沒多久，她就被防暴彈打到頭⋯⋯變得只能記得非常久以前的事了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00636",
		linknext = "0028_00638",
		line = 7760,
	},
