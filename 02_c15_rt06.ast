	},
	["0028_00577"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My mother praised me with the fervor one has for their own accomplishments, and took me back there multiple times.",
					{"rt2"},
				},
			},
			cn = {
				{
					"母亲自豪地说着这全是她的功劳，又把我带到了那个地方好几次。",
					{"rt2"},
				},
			},
			tw = {
				{
					"母親自豪地說著這全是她的功勞，又把我帶到了那個地方好幾次。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00576",
