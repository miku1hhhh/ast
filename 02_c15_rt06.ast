			tw = {
				{
					name = {"淳之介"},
					"「雛見違反了條例的事⋯⋯妳不可能會不知道的吧？妳明明知道卻還是這麼做，是為什麼呢⋯⋯？」",
					{"rt2"},
				},
			},
		},
