				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“The way I phrased it sounds more noble than it has any right to be. Why do you think I used the guillotine on so many people, Junnosuke?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这话⋯⋯太过美化了。呐，淳之介⋯⋯你觉得为什么我会把那么多人送上断头台去？”",
