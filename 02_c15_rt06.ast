		text = {
			vo = {
				{"vo", file="rei0759", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“The FS got wind of it and staged a raid... and shot her in the head with a rubber bullet.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“就这样──被FS抓了个现行⋯⋯头就被防暴弹射到了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「就這樣──被FS抓了個現行⋯⋯頭就被防暴彈射到了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00646",
		linknext = "0028_00648",
		line = 7883,
	},
	["0028_00648"] = {
		{"fg", file="rei_02m_00008", file1="rei_02m_00101", file2="rei_02m_00211", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
