					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I think you’ve saved my ass more than a few times too, Rei.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我才是，不知道被礼前辈帮了多少次。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我才是，不知道被禮前輩幫了多少次。」",
					{"rt2"},
