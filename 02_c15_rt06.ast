			cn = {
				{
					name = {"礼"},
					"“那个人她、已经不记得清蓝岛上的事了。连我被做了什么事、也完全不记得了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「那個人她、已經不記得清藍島上的事了。連我被做了什麼事、也完全不記得了。」",
					{"rt2"},
				},
			},
