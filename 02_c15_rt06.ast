		},
		text = {
			vo = {
				{"vo", file="rei0766", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I don’t like that she forgot the crimes she committed, but when I see her, it reminds me of better times. I can’t bring myself to confront her.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“她把对我做的事全忘了⋯⋯真的让我很不甘心、很无法原谅⋯⋯但就算看到本人、我也不可能说出怀念的这种话来⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「她把對我做的事全忘了⋯⋯真的讓我很不甘心、很無法原諒⋯⋯但就算看到本人、我也不可能說出懷念的這種話來⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00659",
