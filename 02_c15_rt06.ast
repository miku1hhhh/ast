			},
			en = {
				{
					"The cameras stationed around the room whirred and moved around as they adjusted their angles, repeating for a while until they finally stopped.",
					{"rt2"},
				},
			},
			cn = {
				{
					"安装在房间四边的摄影镜头随着机械的驱动声改变角度，然后在重复调整几次后停止了。",
