				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"With the NLNS, I had the best comrades anyone could ask for. It hurt to not have everyone together here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"和NLNS──无法取代的伙伴分开的现在，才彻底感受到痛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"和NLNS──無法取代的夥伴分開的現在，才徹底感受到痛。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00693",
