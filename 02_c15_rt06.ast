		line = 1116,
	},
	["0028_00093"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’ve seen Rei send non-procreators to the guillotine for punishment first-hand.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈将非性产者送上断头台的那一刻──我曾经看过。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩將非性產者送上斷頭台的那一刻──我曾經看過。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00092",
		linknext = "0028_00094",
		line = 1126,
	},
	["0028_00094"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Regardless of how she felt about it at the time, I can’t deny the simple truth that she did it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"无论她本人抱持着怎样的想法，做过的事实都不会改变。",
					{"rt2"},
				},
			},
			tw = {
				{
					"無論她本人抱持著怎樣的想法，做過的事實都不會改變。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00093",
