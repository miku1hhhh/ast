	["0028_00156"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Something’s weird about her story. Something I can’t explain.",
					{"rt2"},
				},
			},
			cn = {
				{
					"刚才礼前辈说的内容，似乎有些奇怪──有些难以理解的地方。",
