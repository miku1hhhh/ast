	["0028_00597"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She looks down at the charm, filled with melancholy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她用充满乡愁的眼神看着手上的吊饰。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她用充滿鄉愁的眼神看著手上的吊飾。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00596",
		linknext = "0028_00598",
		line = 7180,
	},
	["0028_00598"] = {
		{"fg", file="rei_02m_00008", file1="rei_02m_00101", file2="rei_02m_00214", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[5700] = {
				{"fg", file="rei_02m_00008", file1="rei_02m_00101", file3="rei_02m_00309", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=31, delay2=5700, mode=3, x=-5, y=-5},
			},
			[5699] = {
				{"transitiontime", time=300, timestamp=31, delay2=5700},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0738", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“That was surprising, to say the least... I was used to being ignored by everyone and being on my own, but then she turned up out of nowhere and started talking to me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我吓了一跳⋯⋯对很明显就是被无视、被孤立的我⋯⋯她完全没有犹豫地就跟我搭话了⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我嚇了一跳⋯⋯對很明顯就是被無視、被孤立的我⋯⋯她完全沒有猶豫地就跟我搭話了⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00597",
		linknext = "0028_00599",
		line = 7198,
	},
	["0028_00599"] = {
		{"fg", file="rei_02m_00008", file1="rei_02m_00101", file2="rei_02m_00214", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0739", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“She just didn’t notice that I was being bullied.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“她好像是没有意识到我被人欺负的这件事。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「她好像是沒有意識到我被人欺負的這件事。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00598",
		linknext = "0028_00600",
		line = 7213,
	},
	["0028_00600"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file3="jun_01f_00309", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Heh, that’s just how Hinami is.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯确实是她会有的情况呢，雏见她。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯確實是她會有的情況呢，雛見她。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00599",
		linknext = "0028_00601",
		line = 7225,
	},
	["0028_00601"] = {
		{"fg", file="rei_01m_00008", file1="rei_01m_00101", file2="rei_01m_00214", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
