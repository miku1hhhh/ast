		line = 8074,
	},
	["0028_00661"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei rests a hand on her chest—is she happy or sad? —and sits in contemplation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"把手放在心口的礼前辈，累出了细腻的情感──那到底是开心还是难过呢？",
					{"rt2"},
				},
			},
			tw = {
				{
