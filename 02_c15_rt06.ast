	["0028_00704"] = {
		{"fgact", ch="礼9", id=9, lv=9, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"To tell the truth, the NLNS members were more important to me than mere love interests. They were my irreplaceable comrades.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算这么说，NLNS可不只是恋爱的对象，而志同道合、无可取代的重要伙伴。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算這麼說，NLNS可不只是戀愛的對象，而志同道合、無可取代的重要夥伴。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00703",
		linknext = "0028_00705",
		line = 8622,
	},
	["0028_00705"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My first crush was definitely Nanase, and she’s still my main partner in the NLNS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我的初恋确实是奈奈濑没错，就算是现在，说到NLNS伙伴，我也总是只想到奈奈濑。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我的初戀確實是奈奈瀨沒錯，就算是現在，說到NLNS夥伴，我也總是只想到奈奈瀨。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00704",
		linknext = "0028_00706",
		line = 8632,
	},
	["0028_00706"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She understands me better than anyone.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她比谁都还要了解我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她比誰都還要了解我。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00705",
