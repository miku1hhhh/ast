	},
	["0028_00672"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I was also bullied in school...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我──以前也被人欺负过。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我──以前也被人欺負過。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00671",
		linknext = "0028_00673",
		line = 8234,
	},
	["0028_00673"] = {
		{"fgact", ch="礼9", id=9, lv=9, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I continued for a long while.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是相当久以前的事了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那是相當久以前的事了。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00672",
		linknext = "0028_00674",
		line = 8246,
	},
	["0028_00674"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nanase, a girl in the same year, had spoken to me like a friend, even though I was the target of the bullies.",
					{"rt2"},
				},
			},
			cn = {
				{
					"同年级的女同学──奈奈濑在我被欺负的时候，亲切地对我打了招呼。",
					{"rt2"},
				},
			},
			tw = {
				{
					"同年級的女同學──奈奈瀨在我被欺負的時候，親切地對我打了招呼。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00673",
		linknext = "0028_00675",
		line = 8256,
	},
	["0028_00675"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And yet... I still managed to hurt her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然而，我却做出了伤害她的事情来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然而，我卻做出了傷害她的事情來。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00674",
		linknext = "0028_00676",
		line = 8266,
	},
	["0028_00676"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Then I was rescued by Fumino’s mother, Fumika.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在那之后我遇到了文乃的母亲──文歌小姐，然后被她救了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在那之後我遇到了文乃的母親──文歌小姐，然後被她救了。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00675",
		linknext = "0028_00677",
		line = 8276,
	},
	["0028_00677"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But she died after suffering intense persecution for a long time.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她不断受到迫害，甚至失去了生命。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她不斷受到迫害，甚至失去了生命。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00676",
		linknext = "0028_00678",
		line = 8286,
	},
	["0028_00678"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I left the island, but my feelings never subsided. I continued to despise the island and everything it stood for.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管我离开这座岛多少年，那时候的情绪都没有消失过，我一直憎恨着这座岛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管我離開這座島多少年，那時候的情緒都沒有消失過，我一直憎恨著這座島。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00677",
		linknext = "0028_00679",
		line = 8296,
	},
	["0028_00679"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s why I started the Anti-Copulation Front—the NLNS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以，我才会成立了反交尾势力──成立了NLNS。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以，我才會成立了反交尾勢力──成立了NLNS。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00678",
		linknext = "0028_00680",
		line = 8306,
	},
	["0028_00680"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"With the support of my friends, I fought hard, and there were times when I didn’t think we were going to make it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我在朋友的支持下拼命战斗着，在这期间也有过绝望的时候。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我在朋友的支持下拚命戰鬥著，在這期間也有過絕望的時候。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00679",
		linknext = "0028_00681",
		line = 8316,
	},
	["0028_00681"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But we didn’t give up, we knuckled down, not for revenge against the past, but for a future where the two sides could coexist. Eventually, our prayers were answered.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使这样，我也没有放弃持续坚持着──并不是为了报复过去的夙怨，而是为了未来的共存而战，最终达成了圆满的心愿。",
					{"rt2"},
				},
			},
			tw = {
				{
					"即使這樣，我也沒有放棄持續堅持著──並不是為了報復過去的夙怨，而是為了未來的共存而戰，最終達成了圓滿的心願。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00680",
		linknext = "0028_00682",
		line = 8326,
	},
	["0028_00682"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file3="jun_01f_00309", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well, you know the rest. You were there, after all.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯唔，最后的事礼前辈也都知道了吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯唔，最後的事禮前輩也都知道了吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00681",
		linknext = "0028_00683",
		line = 8338,
	},
	["0028_00683"] = {
		{"fg", file="rei_02m_00008", file1="rei_02m_00101", file3="rei_02m_00309", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[1000] = {
				{"fg", file="rei_02m_00008", file1="rei_02m_00101", file2="rei_02m_00207", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=59, delay2=1000, mode=3, x=-5, y=-5},
