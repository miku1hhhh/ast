			},
		},
		linkback = "0028_00626",
		linknext = "0028_00628",
		line = 7632,
	},
	["0028_00628"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei had always protected Hinami. She taught me to fight.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈一直护着雏见。教会我如何战斗。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩一直護著雛見。教會我如何戰鬥。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00627",
		linknext = "0028_00629",
		line = 7642,
	},
	["0028_00629"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Without her, I wouldn’t have had the power to change things on Seiran Island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"若不是这样，我肯定无法改变青蓝岛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"若不是這樣，我肯定無法改變青藍島。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00628",
		linknext = "0028_00630",
		line = 7652,
	},
	["0028_00630"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She had struggled on for so long by herself, but she held us together and helped bring about a great change.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她一直一个人守护着、坚持着的东西──最终造成了巨大的变化。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她一直一個人守護著、堅持著的東西──最終造成了巨大的變化。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00629",
