			},
		},
		text = {
			vo = {
				{"vo", file="rei0745", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I worked furiously to make sure that she wouldn’t be put in danger... Maybe it was more for myself than for her. Just an ego trip.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“为了不让雏见受到危险，我做了很多的事。⋯⋯不过那可能全都只是为了自我满足而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「為了不讓雛見受到危險，我做了很多的事。⋯⋯不過那可能全都只是為了自我滿足而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00607",
		linknext = "0028_00609",
		line = 7357,
	},
	["0028_00609"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
