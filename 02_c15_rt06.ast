					name = {"礼", "Rei"},
					"“This was six years ago. I was living with my family, five of us, in a small apartment in Kanto.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这都是6年以前的事了⋯⋯当时我们是住在关东某个小公寓里的一家5口。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這都是6年以前的事了⋯⋯當時我們是住在關東某個小公寓裡的一家5口。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00141",
		linknext = "0028_00143",
