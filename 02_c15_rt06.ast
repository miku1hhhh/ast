			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She was breaking the law, right? There was no way you couldn’t have known that. So, why didn’t you...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“雏见违反了条例的事⋯⋯你不可能会不知道的吧？你明明知道却还是这么做，是为什么呢⋯⋯？”",
					{"rt2"},
				},
