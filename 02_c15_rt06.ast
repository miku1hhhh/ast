	["0028_00040"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file3="jun_01f_00301", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No dice. She said I’m not part of her family anymore, so there’s no point in even discussing it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“被拒绝了。‘我已经不是这个家的人了、跟我没有什么话好说的’，她对我这么说。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「被拒絕了。『我已經不是這個家的人了、跟我沒有什麼話好說的』，她對我這麼說。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00039",
		linknext = "0028_00041",
		line = 469,
	},
	["0028_00041"] = {
