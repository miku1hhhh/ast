		text = {
			vo = {
				{"vo", file="rei0650", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I hated non-procreators. I hated the Anti-Copulation Front. I couldn’t stand that I was being forced into sex while they tried so hard to escape it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我恨着那些被称为非性产者、⋯⋯那些反交尾势力的人们。尽管我是被迫发生性关系⋯⋯但我无法原谅那些试图逃避规则的人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我恨著那些被稱為非性產者、⋯⋯那些反交尾勢力的人們。儘管我是被迫發生性關係⋯⋯但我無法原諒那些試圖逃避規則的人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00106",
		linknext = "0028_00108",
		line = 1322,
	},
	["0028_00108"] = {
