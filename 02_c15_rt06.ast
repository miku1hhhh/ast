		},
		text = {
			vo = {
				{"vo", file="rei0751", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“President of the disciplinary committee, FS commander... Pretty impressive ranks, but in the end, that’s all they are.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“风纪委员长、FS大队长⋯⋯虽然名头很大，不过也只是名头大而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「風紀委員長、FS大隊長⋯⋯雖然名頭很大，不過也只是名頭大而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00621",
		linknext = "0028_00623",
		line = 7556,
	},
	["0028_00623"] = {
		{"fg", file="rei_02m_00008", file1="rei_02m_00101", file3="rei_02m_00320", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
