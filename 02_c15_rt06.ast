		text = {
			vo = {
				{"vo", file="rei0661", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I remember being really happy. I might even have cried. We were saved! But it turns out I didn’t really know anything.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我记得⋯⋯我那时候很开心。搞不好还哭了。觉得终于得救了⋯⋯那时候的我还什么都不知道。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我記得⋯⋯我那時候很開心。搞不好還哭了。覺得終於得救了⋯⋯那時候的我還什麼都不知道。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00150",
		linknext = "0028_00152",
		line = 1870,
	},
	["0028_00152"] = {
		{"fg", file="rei_02m_00008", file1="rei_02m_00101", file3="rei_02m_00321", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0662", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“So, I came to Seiran with my mother. We were taken away from the center of town to some dimly lit building, paired with unknown men... And that was only the start.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“之后，我和妈妈一起来到了青蓝岛⋯⋯我被带到了市中心外一座灯光昏暗的建筑里，和一个我不认识的男人单独呆在一起──这就是开始。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「之後，我和媽媽一起來到了青藍島⋯⋯我被帶到了市中心外一座燈光昏暗的建築裡，和一個我不認識的男人單獨呆在一起──這就是開始。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00151",
		linknext = "0028_00153",
		line = 1885,
	},
	["0028_00153"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She slowly unloaded her story to me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她说的每一个字都重重地压在我的心上。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她說的每一個字都重重地壓在我的心上。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00152",
		linknext = "0028_00154",
		line = 1895,
	},
	["0028_00154"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I thought it might be like this, but hearing it directly, the reality of her situation piercing directly into my mind... It’s painful.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明心知肚明──当直面现实的时候，还是忍不住心头一痛。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明心知肚明──當直面現實的時候，還是忍不住心頭一痛。",
