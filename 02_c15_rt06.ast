			},
			[5500] = {
				{"fg", file="rei_02m_00008", file1="rei_02m_00101", file2="rei_02m_00210", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=60, delay2=5500, mode=3, x=-5, y=-5},
			},
			[5499] = {
				{"transitiontime", time=300, timestamp=60, delay2=5500},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0771", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Heh, yeah. But it’s different hearing it from you. It’s a pretty crazy story.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是啊。不过，听你亲口说果然还是不太一样呢。你真的⋯⋯也发生了很多的事呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是啊。不過，聽你親口說果然還是不太一樣呢。你真的⋯⋯也發生了很多的事呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00682",
		linknext = "0028_00684",
		line = 8358,
	},
	["0028_00684"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file3="jun_01f_00309", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You got that right. We’re pretty similar, you and I...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是的。──也许，我们两个有点像呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是的。──也許，我們兩個有點像呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00683",
		linknext = "0028_00685",
		line = 8370,
	},
	["0028_00685"] = {
		{"fg", file="rei_02m_00008", file1="rei_02m_00101", file2="rei_02m_00214", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0772", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Maybe.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“⋯⋯也许吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「⋯⋯也許吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00684",
		linknext = "0028_00686",
		line = 8385,
	},
	["0028_00686"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We couldn’t fit in on the island, we became lonely, and we were saved by a special someone.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在岛上无法融入、被人孤立，然后在那里被谁帮助了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在島上無法融入、被人孤立，然後在那裡被誰幫助了。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00685",
		linknext = "0028_00687",
		line = 8395,
	},
	["0028_00687"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We both didn’t have the natural talent to do something about it, but we compensated with hard work.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没有成就某事的天赋，只能靠努力往上爬。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒有成就某事的天賦，只能靠努力往上爬。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00686",
		linknext = "0028_00688",
		line = 8405,
	},
	["0028_00688"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I have vague memories of His Sexellency being forced into things he didn’t want to do in order to help Asane, so I sympathize with her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"或许是因为有了为麻沙音而被迫去做了跟本不想做的事的‘性帝’的记忆──我更能够理解这点。",
					{"rt2"},
				},
			},
			tw = {
				{
					"或許是因為有了為麻沙音而被迫去做了跟本不想做的事的『性帝』的記憶──我更能夠理解這點。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00687",
		linknext = "0028_00689",
		line = 8415,
	},
	["0028_00689"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Well, I’m not gonna claim that I understand her perfectly. That would be a gross overstatement.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不能说我理解礼前辈的心情这样的大话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不能說我理解禮前輩的心情這樣的大話。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00688",
		linknext = "0028_00690",
		line = 8425,
	},
	["0028_00690"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But we do feel the same way, and we have had similar life experiences, so being able to talk like this has been really relieving.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，因为有相似的想法，也有相似的经历──这样跟她说话，我感到很安心。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，因為有相似的想法，也有相似的經歷──這樣跟她說話，我感到很安心。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00689",
		linknext = "0028_00691",
		line = 8435,
	},
	["0028_00691"] = {
		{"bgm", file="bgm23", vol=100},
