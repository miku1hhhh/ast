	},
	["0028_00143"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her long eyelashes flick down as she speaks, full of uncertainty.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈稍微眯起有着长睫毛的双眼，淡薄地说道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩稍微瞇起有著長睫毛的雙眼，淡薄地說道。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00142",
