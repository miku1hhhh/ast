		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even if it hurts me, I need to know more about her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"即使内容会让人不舒服，我依然想了解她。",
					{"rt2"},
				},
