					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“That’s why making Hinami happy is the absolute most important thing in the world to me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“所以⋯⋯就只有雏见⋯⋯就只有雏见她，我希望她能够幸福。”",
