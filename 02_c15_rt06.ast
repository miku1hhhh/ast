	},
	["0028_00137"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I want to open up and share everything with someone close to me. It’s only natural to want that level of human connection.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这些事只想让重要的人知道、只想对他们坦白──我想这种想法是每个人都会有的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這些事只想讓重要的人知道、只想對他們坦白──我想這種想法是每個人都會有的。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00136",
