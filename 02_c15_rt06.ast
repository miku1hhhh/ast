		text = {
			vo = {
				{"vo", file="rei0651", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I held this childish resentment toward them. All because of my own personal grudge. Which is why I could pass judgment on them instead of sympathizing with their cause.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这只是一种幼稚的怨恨……只是个人的私仇。这就是为什么我能够在没有同情的情况下惩治他们。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這只是一種幼稚的怨恨……只是個人的私仇。這就是為什麼我能夠在沒有同情的情況下懲治他們。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00107",
		linknext = "0028_00109",
		line = 1340,
	},
	["0028_00109"] = {
