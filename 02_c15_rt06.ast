		},
		text = {
			vo = {
				{"vo", file="rei0664", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Being exempt from the law, I couldn’t join the FS. So, the only way to get me earning money was... that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“因为不是条例的适用对象，我连FS都进不了……我想我当时唯一能赚钱的方法就是利用它了吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「因為不是條例的適用對象，我連FS都進不了……我想我當時唯一能賺錢的方法就是利用它了吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00167",
		linknext = "0028_00169",
		line = 2064,
	},
	["0028_00169"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She continues talking as if these awful things happened to someone else.",
					{"rt2"},
				},
			},
			cn = {
				{
					"像是在说着其他人的事一样，礼前辈继续往下说。",
					{"rt2"},
				},
			},
			tw = {
				{
					"像是在說著其他人的事一樣，禮前輩繼續往下說。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00168",
		linknext = "0028_00170",
		line = 2074,
	},
	["0028_00170"] = {
		{"fgact", ch="礼9", id=9, lv=9, act="表示アクション", alpha=0, alphadel=1, style="reset", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She harbored such disgust toward what she was forced to do, so her “customers” were not exactly satisfied with her service.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当时的礼前辈非常反感这种行为，看来顾客的评价也不是很好。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當時的禮前輩非常反感這種行為，看來顧客的評價也不是很好。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00169",
		linknext = "0028_00171",
		line = 2086,
	},
	["0028_00171"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Of course, she would. She had been deceived, forced into sexual slavery. How could she have felt any other way?",
					{"rt2"},
				},
			},
			cn = {
				{
					"这是当然的。完全不知情就被骗去卖身，又怎么可能好好服务客人呢？",
					{"rt2"},
				},
			},
			tw = {
				{
					"這是當然的。完全不知情就被騙去賣身，又怎麼可能好好服務客人呢？",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00170",
		linknext = "0028_00172",
		line = 2096,
	},
	["0028_00172"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But those around her didn’t see it that way, of course. An unpopular girl is an unprofitable girl.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然而，对于这样的情况，周围的人并不会逐一了解。失去了人气，就同等于失去了收入。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然而，對於這樣的情況，周圍的人並不會逐一了解。失去了人氣，就同等於失去了收入。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00171",
		linknext = "0028_00173",
		line = 2106,
	},
	["0028_00173"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her mother scolded her, asking her if she was trying to ruin their lives.",
					{"rt2"},
				},
			},
			cn = {
				{
					"你想让你的家人流落街头吗？──她母亲着她劈头骂道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"你想讓你的家人流落街頭嗎？──她母親著她劈頭罵道。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00172",
		linknext = "0028_00174",
		line = 2116,
	},
	["0028_00174"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"So, she studied. How to make people happy, how to gasp and moan...",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以她拼了命地去学，学着如何娇喘、如何取悦对方、如何获得快感。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以她拚了命地去學，學著如何嬌喘、如何取悅對方、如何獲得快感。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00173",
		linknext = "0028_00175",
		line = 2126,
	},
	["0028_00175"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She was just a girl, still not old enough to be subject to the law...",
					{"rt2"},
				},
			},
			cn = {
				{
					"那时的她，还是个没达到条例适用对象年龄的少女。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那時的她，還是個沒達到條例適用對象年齡的少女。",
					{"rt2"},
				},
			},
		},
		linkback = "0028_00174",
		linknext = "0028_00176",
