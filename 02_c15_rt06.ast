		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s late at night in the dorms and no one is around, which makes the normally busy open area seem all the more cold.",
					{"rt2"},
				},
			},
			cn = {
				{
					"深夜没有人经过宿舍，没有了往常的喧嚣，感觉有些冷。",
