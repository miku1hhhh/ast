		line = 1994,
	},
	["0028_00163"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even six years ago, the rules were the same.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这一点，6年前应该也没有任何改变才对。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這一點，6年前應該也沒有任何改變才對。",
