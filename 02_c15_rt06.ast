				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「哈哈，確實是雛見才會有的狀況。但不要看她那樣⋯⋯她比誰都能⋯⋯看透人心呢。」",
					{"rt2"},
				},
			},
		},
