	},
	["0028_00222"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmobc0054", path=":vo/", ch="gmob"},
			},
			ja = {
				{
					name = {"モブ女C", "SHO職員"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女C", "SHO Personnel"},
					"“I understand, but... This is just how we do things here. Don’t worry, there’s nothing to be afraid of.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女C", "SHO职员"},
					"“嗯，我知道，不过呢⋯⋯程序上来说不这么做是不行的。所以别担心，不用害怕。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女C", "SHO職員"},
					"「嗯，我知道，不過呢⋯⋯程序上來說不這麼做是不行的。所以別擔心，不用害怕。」",
					{"rt2"},
				},
			},
		},
