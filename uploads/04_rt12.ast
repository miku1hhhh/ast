					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I called out to you at school, but you were looking at the floor the whole time. Did something happen? Did you get... switched again?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“在学校里叫你也不怎么应声，而且又一直垂着头……不会是，又像之前一样……交换了？之类的吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「在學校裡叫你也不怎麼應聲，而且又一直垂著頭……不會是，又像之前一樣……交換了？之類的嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00058",
		linknext = "0068_00060",
		line = 854,
	},
