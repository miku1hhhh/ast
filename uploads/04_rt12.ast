					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I couldn’t tell her that I didn’t care about what she’d done here on the island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
