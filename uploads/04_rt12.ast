					"It’s something I could never avoid if we were together. A reality I can never ignore.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只要跟礼前辈在一起，那是绝对无法避免的。是无法视而不见的现实。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只要跟禮前輩在一起，那是絕對無法避免的。是無法視而不見的現實。",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00116",
		linknext = "0068_00118",
		line = 1519,
	},
	["0068_00118"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The truth blindsides me, and there’s no way I can deny it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被她将事实直接摆在眼前──‘我不会在意’那种逢场作戏的台词，我怎么可能说得出口。",
					{"rt2"},
				},
			},
			tw = {
				{
					"被她將事實直接擺在眼前──『我不會在意』那種逢場作戲的台詞，我怎麼可能說得出口。",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00117",
		linknext = "0068_00119",
		line = 1529,
	},
	["0068_00119"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Supposing we did have a future together, the moment I even showed the slightest hint of displeasure would be a knife in her gut.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算这那句话能许我们一个不一样的未来──在我表现出那怕一点点嫌恶的瞬间，那句话就会化作伤害礼前辈的刀刃。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算這那句話能許我們一個不一樣的未來──在我表現出那怕一點點嫌惡的瞬間，那句話就會化作傷害禮前輩的刀刃。",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00118",
		linknext = "0068_00120",
		line = 1539,
	},
