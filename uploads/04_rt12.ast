					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Well... yeah, I’m not entirely convinced either, but the authorities are talking about increased economic activity in the hundreds of millions of yen!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“这个嘛……我也不是不同意……但是上面的人似乎估计会有以亿计算的经济效果喔？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「這個嘛……我也不是不同意……但是上面的人似乎估計會有以億計算的經濟效果喔？」",
					{"rt2"},
