	},
	["0068_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And she definitely freshly washed and dried the carpet just so I could roll around on it feeling sorry for myself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在此之上，她甚至还为了让郁闷的我能够舒服地在地上打滚，把地毯给洗干净拿出去晒过太阳。做得如此彻底。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在此之上，她甚至還為了讓鬱悶的我能夠舒服地在地上打滾，把地毯給洗乾淨拿出去曬過太陽。做得如此徹底。",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00032",
		linknext = "0068_00034",
		line = 481,
