					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hey, Jorny! I’m in need of someone to pour sips of ice-cold cola directly into my mouth while fanning me to make sure I’m in optimal gaming condition.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“喂。色贞德给我端着冷吱吱的可乐在我口渴的时候适量地喂我一点同时要一直拿着扇子帮我扇风好让我能够舒舒服服地打电动。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「喂。色貞德給我端著冷吱吱的可樂在我口渴的時候適量地餵我一點同時要一直拿著扇子幫我搧風好讓我能夠舒舒服服地打電動。」",
					{"rt2"},
				},
			},
		},
