		{"fg", file="asane_02m_00003", file1="asane_02m_00101", file2="asane_02m_00205", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0265", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I don’t care what suits you better. You’re. In. The. Way! Besides, Fumino keeps the floor so spotless you could eat your dinner off it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“管你适不适合，我在说的是你很碍事……而且文乃像个傻瓜似地打扫个不停，所以我们家的地板根本超干净的吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「管你適不適合，我在說的是你很礙事……而且文乃像個傻瓜似地打掃個不停，所以我們家的地板根本超乾淨的吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00017",
		linknext = "0068_00019",
		line = 281,
	},
	["0068_00019"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file3="jun_01f_00301", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What a heartless sister. She can see that I’m depressed, and yet...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“妹妹好冷淡……我明明这么低落……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妹妹好冷淡……我明明這麼低落……」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00018",
		linknext = "0068_00020",
		line = 293,
	},
	["0068_00020"] = {
		{"fg", file="asane_02m_00003", file1="asane_02m_00101", file2="asane_02m_00203", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0266", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You’ve been like this ever since you got home yesterday! I was a little worried at first but now you’re just getting annoying.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“因为你从昨天回来就一直是那样啊……一开始我当然会担心，可是到现在也差不多磨光了好吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「因為你從昨天回來就一直是那樣啊……一開始我當然會擔心，可是到現在也差不多磨光了好嗎……」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00019",
		linknext = "0068_00021",
		line = 308,
	},
	["0068_00021"] = {
		{"fg", file="asane_02m_00003", file1="asane_02m_00101", file2="asane_02m_00223", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0267", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“It reminds me of how I can’t stand watching anime where the main character is being a little bitch for two or three episodes...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“这么说起来，动画里面的主角只要扭扭捏捏两话以上麻沙酱我就看不下去了呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「這麼說起來，動畫裡面的主角只要扭扭捏捏兩話以上麻沙醬我就看不下去了呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00020",
		linknext = "0068_00022",
		line = 323,
	},
	["0068_00022"] = {
		{"fg", file="asane_02m_00003", file1="asane_02m_00101", file2="asane_02m_00203", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0268", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You’ve been like this for at least twenty hours! In anime time that’s 150 episodes! No wonder I’m getting pissed off.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“哥哥不是已经扭扭捏捏20个小时以上了吗……如果换算成动画的话就已经150话以上了喔……谁受得了啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「哥哥不是已經扭扭捏捏20個小時以上了嗎……如果換算成動畫的話就已經150話以上了喔……誰受得了啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00021",
		linknext = "0068_00023",
		line = 338,
	},
	["0068_00023"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Those numbers seem off, but I’m not exactly a math genius. Someone like me even attempting to work the numbers in my head would only be an affront to mathematics.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然这计算感觉有点奇怪──但是像我这种人还在脑袋里玩弄数字，根本就是在亵渎数学吧……。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然這計算感覺有點奇怪──但是像我這種人還在腦袋裡玩弄數字，根本就是在褻瀆數學吧……。",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00022",
		linknext = "0068_00024",
		line = 348,
	},
	["0068_00024"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00218", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
