					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Oh my God you can’t be serious you’re really starting this again it’s like you’re the personification of annoyance... Time for some private gaming time.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“呜哇又开始了这家伙已经不行了真的已经变得像是麻烦的拟人化一样了……我还是躲起来打电动吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「嗚哇又開始了這傢伙已經不行了真的已經變得像是麻煩的擬人化一樣了……我還是躲起來打電動吧……」",
					{"rt2"},
				},
			},
		},
