	["0068_00029"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She was being a little mean, but it came from a place of caring about me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然麻沙酱嘴上很凶──但是我能清楚地感觉到她这样已经算是相当体贴我的了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然麻沙醬嘴上很兇──但是我能清楚地感覺到她這樣已經算是相當體貼我的了。",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00028",
