					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Now that I’m actually saying it out loud, it sounds so cliched. If someone said that to me, I’d probably burst out laughing.",
					{"rt2"},
				},
			},
			cn = {
				{
