	["0068_00145"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", file3="nanase_02m_00307", path=":fg/nanase_02m/", id=4, lv=4, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0299", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“So they decided to hold a big event to raise the island’s profile. And the Hamedori Raw Outbreak was born!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					[[“所以呢，就想说干脆举全岛之力办一个大活动……也就是"Hamedori君大量出现hame"。”]],
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					[[「所以呢，就想說乾脆舉全島之力辦一個大活動……也就是"Hamedori君大量出現hame"。」]],
					{"rt2"},
				},
			},
		},
		linkback = "0068_00144",
		linknext = "0068_00146",
		line = 1888,
	},
	["0068_00146"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00101", file2="nanase_02m_00201", path=":fg/nanase_02m/", id=4, lv=4, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0300", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“They’re looking for volunteers to wear the costumes and perform across the island. Y’know, walking around, dancing, that kind of thing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“说是要募集协力人员，大家一起穿上布偶装，在岛上各处办表演。游行啦、跳舞啦之类的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「說是要募集協力人員，大家一起穿上布偶裝，在島上各處辦表演。遊行啦、跳舞啦之類的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00145",
		linknext = "0068_00147",
		line = 1903,
	},
	["0068_00147"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00206", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aren’t these people just pretending to be into Hamedori as a bit? No one’s seriously gonna come all the way here for this event.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说到底应该只是大家把‘Hamedori君很有人气’当成哏在玩而已吧……？就算当真去办了活动也绝对不会有人来的喔……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說到底應該只是大家把『Hamedori君很有人氣』當成哏在玩而已吧……？就算當真去辦了活動也絕對不會有人來的喔……」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00146",
		linknext = "0068_00148",
		line = 1915,
	},
	["0068_00148"] = {
