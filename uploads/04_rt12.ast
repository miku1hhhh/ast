					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yesterday, after school, I confessed to a girl... and she said we couldn’t be together.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“昨天放学后，我去告白了……然后……对方说不能和我交往”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「昨天放學後，我去告白了……然後……對方說不能和我交往」",
