	["0068_00030"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Squabble with my sis distracts me a little from my thoughts.",
					{"rt2"},
				},
			},
			cn = {
				{
					"跟妹妹拌拌嘴之后──让我的心情稍微轻松了一点。",
					{"rt2"},
				},
			},
			tw = {
				{
					"跟妹妹拌拌嘴之後──讓我的心情稍微輕鬆了一點。",
