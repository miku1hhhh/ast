			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I guess it wasn’t so much the getting dumped part as the part where I couldn’t fully deny what Rei was saying to me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“或许……比起被甩了这一点，无法完全否定礼学解说的话……才是让我最讨厌的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
