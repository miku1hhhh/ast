	["0068_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Today’s meal was mild and made from easy-to-digest ingredients. She probably made it with my current state in mind.",
					{"rt2"},
				},
			},
			cn = {
				{
					"今天做的菜都是容易吞咽、容易消化的东西，也是考虑到我的状况吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"今天做的菜都是容易吞嚥、容易消化的東西，也是考慮到我的狀況吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00031",
