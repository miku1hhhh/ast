	["0068_00070"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I made a mistake—one I could never take back—and we were apart for a long time. But finally I’m reunited with Nanase on the island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在那之后，我犯下了无法挽回的过错，分离了很长一段时间──然后总算在这座岛上与奈奈濑再度相会。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在那之後，我犯下了無法挽回的過錯，分離了很長一段時間──然後總算在這座島上與奈奈瀨再度相會。",
					{"rt2"},
