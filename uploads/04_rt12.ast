					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“150 episodes, huh... Three whole years of TV... What a pathetic man I am...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这样啊……我已经扭扭捏捏了150话……也就是已经3年了吗……哈哈，还真是个无可救药的男人啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這樣啊……我已經扭扭捏捏了150話……也就是已經3年了嗎……哈哈，還真是個無可救藥的男人啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00023",
		linknext = "0068_00025",
		line = 360,
	},
	["0068_00025"] = {
