	["0068_00031"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And Fumino doesn’t say much, but she’s been looking after me since yesterday as well.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然嘴巴上没有多说什么，但是文乃也从昨天开始就一直在关心我。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然嘴巴上沒有多說什麼，但是文乃也從昨天開始就一直在關心我。",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00030",
		linknext = "0068_00032",
