	["0068_00141"] = {
		{"fg", file="nanase_02m_00001", file1="nanase_02m_00102", file2="nanase_02m_00210", path=":fg/nanase_02m/", id=4, lv=4, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0297", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“I don’t know what it is exactly, but Hamedori’s been getting really popular on the mainland as a mascot. Like in a culty way.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我也不是很清楚……最近Hamedori君似乎在本岛莫名暴红。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我也不是很清楚……最近Hamedori君似乎在本島莫名暴紅。」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00140",
		linknext = "0068_00142",
		line = 1831,
	},
	["0068_00142"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Man, this country’s going to the dogs.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“这个国家不要紧吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「這個國家不要緊嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00141",
		linknext = "0068_00143",
		line = 1843,
	},
	["0068_00143"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", file3="nanase_01m_00307", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[7000] = {
				{"fg", file="nanase_01m_00001", file1="nanase_01m_00102", file2="nanase_01m_00210", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, timestamp=9, delay2=7000, mode=3, x=-5, y=-5},
			},
			[6999] = {
				{"transitiontime", time=300, timestamp=9, delay2=7000},
			},
		},
		text = {
			vo = {
				{"vo", file="nanase0298", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“So the people at the SHO have been making lots of these Hamedori outfits. Like, a crazy number, and now they don’t know what to do with them.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“然后呢，SHO的经营者们想说趁势多做几套Hamedori君的布偶装，可是却做得太多了，不知道该如何是好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「然後呢，SHO的經營者們想說趁勢多做幾套Hamedori君的布偶裝，可是卻做得太多了，不知道該如何是好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0068_00142",
		linknext = "0068_00144",
		line = 1861,
	},
	["0068_00144"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
