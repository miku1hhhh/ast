		{"text"},
		text = {
			vo = {
				{"vo", file="asane0029", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“She seems to not understand what an early lunch even is anymore... Does this girl have any common sense?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“提前吃便当根本不是这个意思……这家伙到底有没有常识……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「提早吃便當的概念已經蕩然無存了……這傢伙有常識嗎……？」",
					{"rt2"},
				},
			},
		},
