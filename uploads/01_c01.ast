				{"transitiontime", time=300, timestamp=25, delay2=3500},
			},
		},
		text = {
			vo = {
				{"vo", file="rei0020", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I actually submitted the idea to the SHO! It’s something that only you can do, Tachibana! Man, I can’t wait to start filming...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“其实呢，我已经向SHO提出这个点子了！毕竟只有橘能够胜任嘛！好期待正式拍摄哦……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「其實我已經向SHO提出這個點子了！畢竟只有橘能夠勝任嘛！好期待正式拍攝喔……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00203",
		linknext = "0002_00208",
		line = 1948,
	},
	["0002_00208"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Then again, when I see her with a smile this big on her face...",
					{"rt2"},
				},
			},
			cn = {
				{
					"可是，面对如此灿烂的笑容……",
					{"rt2"},
				},
			},
			tw = {
				{
					"可是，面對如此燦爛的笑容……",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00207",
		linknext = "0002_00209",
		line = 1958,
	},
	["0002_00209"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...Heh. Okay, leave it to me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“——呵，交给我吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「──呵，那就交給我吧。」",
