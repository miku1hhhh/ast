		linkback = "0002_00535",
		linknext = "0002_00537",
		line = 2857,
	},
	["0002_00537"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0029", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“It was you who saved my life when it had been cast aside... My eyes are meant to grant the wishes of the one I serve.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我这条命是您捡来的……我的双眼，是为了实现服侍之人的愿望而存在的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「我這條命是您撿來的……我的瞳孔，是為了實現主人的願望而存在。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00536",
		linknext = "0002_00538",
		line = 2869,
	},
	["0002_00538"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file2="fumino_01m_00204", path=":fg/fumino_01m/", id=7, lv=3, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0030", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I will be of service to you, no matter what. If there is anything you wish for, regardless of the time or the place...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“文乃一定会帮上您的忙。只要是您的愿望，无论何时何地……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「文乃一定會幫上您的忙。只要您吩咐，不管是何時何地……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00537",
		linknext = "0002_00539",
		line = 2884,
	},
	["0002_00539"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
