			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“No, I’m doing this because I want to, and it’s not like you’re back to a hundred percent, so I want to do anything I can to help...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“没关系，我是自愿这么做的。而且你还没有彻底痊愈，我想尽量帮助你们……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「沒關係，我是自己喜歡才來的。而且淳之介君還沒完全復原，我想盡量幫你的忙……！」",
					{"rt2"},
				},
			},
		},
