	["0002_00532"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They’re like a pair of crimson diamonds. It feels as if she can see through everything with them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那是如鲜红钻石般的，仿佛能洞察一切似的瞳孔。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那是如同鮮紅鑽石般，彷彿會看透一切的瞳孔。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00531",
		linknext = "0002_00533",
		line = 2805,
	},
	["0002_00533"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her gleaming orbs are tinged with the slightest bit of concern.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她那明亮的瞳孔里混入了些许担忧的颜色。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她那閃耀的瞳孔，混入了些許擔憂的色調。",
