	["0002_00045"] = {
		{"fg", file="asane_01f_00008", file1="asane_01f_00101", file2="asane_01f_00211", path=":fg/asane_01f/", id=30, ch="麻沙音", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0009", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“As a proud little sister, I’d rather follow my lord in death than surrender and eat breakfast... Mrrgh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“我宁愿以高傲妹妹的身份殉死，也不愿就地屈服，去吃什么早餐……呣呣呣……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「如果要我乖乖臣服吃早餐，我寧願以高傲妹妹的身分殉死……姆姆姆……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00044",
		linknext = "0002_00046",
		line = 650,
	},
	["0002_00046"] = {
