			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“No, it’s fine. I was hungry, so I went ahead and started on my lunch... Munch, munch... It’sh ahll goohd!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“没关系，我已经饿到提前吃便当了……嚼嚼嚼，所以没关系喔……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「沒關係，因為我也肚子餓到提早吃便當了……嚼嚼嚼，所以沒關係喔……！」",
					{"rt2"},
				},
			},
		},
