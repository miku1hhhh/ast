	["0002_00200"] = {
		{"bgm", file="bgm31", lock=1},
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="礼9", id=9, act="振動下", loop=1, size=22.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0016", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Yep! That’s the sales pitch, that there’s a super-human on Seiran Island who can eat bullet after bullet and come away just fine! Interesting, right?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯！青蓝岛上有不管吃几颗子弹都毫发无损的超人在！我们打算这样宣传！是不是很有趣？！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯！青藍島上也有不管吃幾顆子彈都沒事的超人存在，大概朝這個方向拍！很有趣吧！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00199",
		linknext = "0002_00201",
		line = 1887,
	},
	["0002_00201"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00202", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0017", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I did hear that you’re all healed up now! Everyone’ll be so surprised when they see it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“而且我听说你的身体已经恢复得差不多了！大家一定会大吃一惊的～！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「而且我聽說你的身體恢復得差不多了！大家都會很驚訝喔～！」",
					{"rt2"},
				},
			},
