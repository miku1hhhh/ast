	["0002_00534"] = {
		{"cgdel", id=8, lv=8, time=1000, alphadel=1},
		{"fgact", ch="文乃9", id=9, lv=9, act="表示アクション", alpha=0, alphadel=1, style="reset", time=1000},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file3="jun_01f_00309", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=9, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“No, it’s nothing. Something just made me think a little... Don’t worry about it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，没事。只是有件事让我有些在意……别担心。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒事，什麼事也沒有。只是發生了件讓我有點在意的事而已……妳不用擔心。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00533",
		linknext = "0002_00535",
		line = 2831,
	},
	["0002_00535"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00101", file2="fumino_02m_00220", path=":fg/fumino_02m/", id=7, lv=3, head="fumino_02m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It seems this answer won’t be enough on its own to satisfy her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只凭这句回答，似乎无法令她满意。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只憑這句回答，似乎無法令她滿意。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00534",
