			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“But that weight...?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“但是这份重量——”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「但是這份重量……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00057",
		linknext = "0002_00059",
		line = 839,
	},
	["0002_00059"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Heh... It does make me a little happy. I can feel just how much my little sister has grown...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“呵……这份重量让我感受到妹妹的成长，心里还挺开心的……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「呵……感受到妹妹的成長，心裡有點開心呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00058",
		linknext = "0002_00060",
		line = 851,
	},
