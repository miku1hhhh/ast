	["0002_00172"] = {
		{"bgm", file="bgm02", lock=1},
		{"fg", file="rei_01m_00001", file1="rei_01m_00102", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-505, y=-5},
