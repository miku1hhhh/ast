		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file2="fumino_01m_00210", path=":fg/fumino_01m/", id=7, lv=3, head="fumino_01m", alpha=0, ch_origin="文乃", ch="文乃7", mw="mw", sync=1, a_chr151=1, mode=3, x=-205, y=-5},
