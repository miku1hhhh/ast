	["0002_00464"] = {
		{"fg", file="nanase_02m_00006", file1="nanase_02m_00101", file2="nanase_02m_00216", path=":fg/nanase_02m/", id=4, lv=5, head="nanase_02m", ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0012", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Unbelievable. Jun and Asa made this without breaking a single plate, mistaking sugar for salt, or even burning their clothes! Oh, how you’ve grown...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“没想到那个淳和小麻在没打破盘子、没放错调味料、没烧掉衣服的情况完成了烹饪……！有显著的成长了呢……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「沒想到那個淳和麻沙醬沒打破盤子、沒放錯調味料、沒燒掉衣服就做出料理……！有顯著的成長哇……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00463",
		linknext = "0002_00465",
		line = 2364,
	},
	["0002_00465"] = {
