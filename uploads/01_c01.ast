	["0002_00403"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Anyway, I wanted to ask what you were doing after this. You’re not on dinner duty today, are you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对了，我想问一下你之后的安排。今天不是你负责做晚餐吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「對了，我想問一下妳之後有沒有事？今天不是妳負責做晚餐吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00390",
		linknext = "0002_00404",
		line = 2125,
	},
	["0002_00404"] = {
		{"fg", file="fumino_02m_00007", file1="fumino_02m_00101", file2="fumino_02m_00201", path=":fg/fumino_02m/", id=7, lv=3, head="fumino_02m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0020", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Correct... As such, I planned to borrow a book from the library... I’ve already finished the book I borrowed the other day.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“不是……所以我正打算去图书馆借书……前几天借的都已经看完了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「不是……所以我打算去圖書館借書……前幾天借的都已經看完了……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00403",
		linknext = "0002_00405",
		line = 2140,
	},
	["0002_00405"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Okay, then. Dinner’s at 6, so just be home by then. Don’t follow any strangers, got that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
