	["0002_00196"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00201", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0014", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“That’s right. You’ve surely seen the video promoting tourism on Seiran Island at least once before, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯，你应该也看过青蓝岛的旅游宣传视频吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯。你應該也看過青藍島的觀光介紹影片吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00195",
		linknext = "0002_00197",
		line = 1828,
	},
	["0002_00197"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00223", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, on the ship here... The one with Senba and Hamedori, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“对，我在来这座岛的船上看过……是仙波小姐和hamedori君会登场的那个视频吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「有，在我來這座島的船上看過……是仙波小姐和Hamedori君有出現的影片對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00196",
		linknext = "0002_00198",
		line = 1840,
	},
	["0002_00198"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00215", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="礼9", id=9, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0015", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Right. But well, the island’s law has been amended. They’re saying we can’t keep using it as-is, so we’re going to make a new promo video.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“没错。由于岛上的条例进行了修改，所以那个视频也不能再继续使用了。因此，我们决定制作新的视频。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「沒錯。由於島上的條例修改了，那個影片不能繼續使用。所以決定要製作新的影片。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00197",
		linknext = "0002_00199",
		line = 1856,
	},
	["0002_00199"] = {
		{"bgm", stop=1},
