	},
	["0002_00536"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file2="fumino_01m_00210", path=":fg/fumino_01m/", id=7, lv=3, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Fumino stands up even straighter than before.",
					{"rt2"},
				},
			},
			cn = {
				{
					"文乃重新调整自己的坐姿。",
					{"rt2"},
				},
			},
			tw = {
				{
					"文乃重新調整自己的坐姿。",
					{"rt2"},
