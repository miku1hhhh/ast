		linkback = "0002_00524",
		linknext = "0002_00526",
		line = 2707,
	},
	["0002_00526"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00101", file2="fumino_02m_00210", path=":fg/fumino_02m/", id=7, lv=3, head="fumino_02m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="文乃7", id=7, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0026", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“She retired to her bedroom not long ago... She wishes to go to sleep early today...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“她刚刚已经洗好了，现在回卧室了……说今天要早睡……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「她剛才洗好，已經回寝室了……還說今天要早睡……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00525",
		linknext = "0002_00527",
		line = 2723,
	},
	["0002_00527"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She says that, but she’s never gone to bed early in her life before... Heh...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她嘴上那样说，却从来没有早睡过……哈哈……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嘴巴上那樣說，卻從來沒有早睡過……哈哈……」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00526",
		linknext = "0002_00528",
		line = 2735,
	},
