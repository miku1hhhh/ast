			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Good morning, Misaki. Sorry to keep you waiting.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“早上好，美岬。抱歉让你久等了。”",
