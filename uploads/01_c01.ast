	},
	["0002_00202"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00213", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If you want freaks that’ll surprise everyone, they’re all over the place here. Why not just grab someone off the street...?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“如果要找让大家惊讶的怪人，那边就有一大堆，去抓他们就好了吧……？！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「如果要找讓大家驚訝的怪人，那邊就有一大堆，去抓來就好了吧……！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00201",
		linknext = "0002_00203",
		line = 1914,
	},
	["0002_00203"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00216", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="礼9", id=9, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0018", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“We are of course going to shine the spotlight on those kinds of average residents too. But in the big finale, you’re going to show up and get showered with bullets!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“当然，我们也会拍摄那样的普通市民，最后的镜头就让沐浴在枪林弹雨下的你登场！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「當然，也會拍到你說的一般市民。影片最後你就沐浴在槍林彈雨下現身！」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00202",
		linknext = "0002_00207",
		line = 1930,
	},
	["0002_00207"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00216", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-305, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[3500] = {
				{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00202", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=25, delay2=3500, mode=3, x=-305, y=-5},
			},
