		text = {
			vo = {
				{"vo", file="asane0016", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Glug, glug, hooh! Nothing beats the feeling of washing down unchewed white rice that’s stuck in your throat with some tea! Ain’t that right, Bro?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“咕噜咕噜，噗哈！果然让没嚼过的米堵在喉咙再用茶顺下去的感觉超棒的，哥哥……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「咕嚕咕嚕，噗哈！果然讓沒嚼過的米堵在喉嚨再用茶順下去的感覺超棒的，哥哥……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00063",
		linknext = "0002_00065",
		line = 959,
	},
	["0002_00065"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00215", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bad girl. What am I always telling you? You need to really chew your food before you swallow it. That’s how you get esophageal cancer.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不好好咀嚼再咽下去的话很容易得食道癌，我不是说过不要再这么做了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不好好咀嚼再吞很容易得食道癌，我不是說不要再這麼做了嗎？」",
					{"rt2"},
				},
			},
		},
