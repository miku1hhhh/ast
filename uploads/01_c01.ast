	["0002_00099"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I’m healed up now, so you don’t have to do this every morning. Look, I can even bend my fingers again.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我的伤已经好得差不多了，所以不用每天早上来接也可以。你看，我的手指也已经可以弯曲了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我的傷已經好得差不多了，不用每天早上來接沒關係喔！妳看，我的手指也已經可以彎曲了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00098",
