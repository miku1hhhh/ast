	["0002_00472"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s been a while since we lost our secret base... NLNS headquarters.",
					{"rt2"},
				},
			},
			cn = {
				{
					"自从我们失去了秘密基地——NLNS本部之后，已经过去了很久。",
					{"rt2"},
				},
			},
			tw = {
				{
					"自從我們的秘密基地……NLNS總部消失後好久沒這樣了。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00471",
		linknext = "0002_00473",
		line = 2477,
	},
	["0002_00473"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"An illegal facility from the start, it was ultimately sealed off. There’s no possible way for us to get in now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那里原本就是违法设施，所以遭到了“封印”，现在无论使用何种手段都没法进去了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那裡原本就是違法設施，現在已經被封印，不管使用什麼手段都沒辦法進去。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00472",
		linknext = "0002_00474",
		line = 2487,
	},
	["0002_00474"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"That’s why we all started gathering at my home after school like this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因此，放学后大家会像这样来我家集合。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因此放學後都會像這樣，所有人來我家集合。",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00473",
		linknext = "0002_00475",
		line = 2497,
	},
	["0002_00475"] = {
