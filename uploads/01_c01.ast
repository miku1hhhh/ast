		{"fgact", ch="文乃7", id=7, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0025", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Welcome back, Junnosuke... The bath has been prepared, if you wish to avail yourself.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“欢迎回来，淳之介同学……我已经放好洗澡水了，请先进去吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「歡迎回來，淳之介同學……我已經放好洗澡水了，請先進去吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00523",
		linknext = "0002_00525",
		line = 2695,
	},
	["0002_00525"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Thanks. Where’s Asa?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“谢谢，小麻呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「謝謝，麻沙醬呢？」",
					{"rt2"},
				},
