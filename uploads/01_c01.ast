		linkback = "0002_00208",
		linknext = "0002_00210",
		line = 1970,
	},
	["0002_00210"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“As long as you keep it to something like a rocket launcher, it’ll barely even leave a mosquito bite on me.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“毕竟对我来说，被火箭筒这种程度的东西击中也和被蚊子叮了一下没什么两样。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「畢竟對我來說，被火箭筒這種程度的東西擊中也和被蚊子叮了一下沒什麼兩樣。」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00209",
		linknext = "0002_00211",
		line = 1982,
	},
	["0002_00211"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-305, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="礼9", id=9, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0021", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I see, I see! You really are amazing, Tachibana! Okay, we’re holding a test shoot in a few days that’ll also act as a location hunt. I’ll be counting on you when the time comes! Now off you go!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这样啊！真不愧是橘！那么，我们会在几天后找外景的时候顺便试镜，到时候就拜托你啦！你可以走了！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是嘛是嘛！真不愧是橘！那幾天後會在找外景的時候順便試鏡，到時候拜託你囉！你可以走了！」",
					{"rt2"},
				},
			},
		},
		linkback = "0002_00210",
		linknext = "0002_00212",
		line = 1998,
	},
