		text = {
			vo = {
				{"vo", file="fumino0644", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Reizeiin, cats are very cautious creatures. Approaching them carelessly will rile up their nerves. Yes, indeed... indubitably.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“冷泉院同学⋯⋯猫是戒心很强的生物⋯⋯无形之间逗弄就会让她紧张感到压力⋯⋯原来原来⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「冷泉院同學⋯⋯貓是戒心很強的生物⋯⋯無形之間逗弄就會讓她緊張感到壓力⋯⋯原來原來⋯⋯」",
					{"rt2"},
				},
			},
		},
