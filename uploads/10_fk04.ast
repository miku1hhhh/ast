		{"fg", mode=-1, id=6, ch="美岬6", ch_origin="美岬", lv=6, time=0, sync=0},
		{"fg", file="ikuko_02m_00002", file1="ikuko_02m_00101", file2="ikuko_02m_00206", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2232", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Well, the old couple’s children have all moved out. Raising rescued cats is their source of joy now. I’ve even heard they’re quite depressed and are blaming themselves over it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“孩子已经离开岛上的寂寞夫妻⋯⋯养育浪猫变成他们唯一的乐趣，听说他们非常自责也很沮丧⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
