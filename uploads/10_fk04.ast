		text = {
			vo = {
				{"vo", file="mizuhiki0610", path=":vo/", ch="mizuhiki"},
			},
			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“It’s fine, I’m not going to do anything, okay? So let’s just go, all right? It’s fine between us, right? Let’s go. Nothing’s going to happen, so let’s head to your room???”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“我什么都不会做，放心⋯⋯好不好？去啦～～先去嘛。好不好啦，就去一下没关系的呀，走啦？没事，去嘛去嘛去嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水引"},
					"「我什麼都不會做，放心⋯⋯好不好？去啦～～先去嘛。好不好啦，就去一下沒關係的呀，走啦？沒事，去嘛去嘛去嘛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00470",
		linknext = "0111_00472",
