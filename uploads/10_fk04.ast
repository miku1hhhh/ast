	["0111_00110"] = {
		{"fg", file="asane_01f_00002", file1="asane_01f_00101", file2="asane_01f_00213", path=":fg/asane_01f/", id=30, ch="麻沙音", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1558", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“You’re amazing, Nanase! Whether it’s a big dog or a female cat, animals of all kinds flock to you. Must be those overwhelming maternal instincts, hehehe!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“不亏是奈奈濑姐⋯⋯！大型犬还是母猫，都会被你收服。是因为母性光辉太强吗⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「不虧是奈奈瀨姊⋯⋯！大型犬還是母貓，都會被妳收服。是因為母性光輝太強嗎⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00109",
		linknext = "0111_00111",
		line = 1817,
	},
	["0111_00111"] = {
