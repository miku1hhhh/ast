					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That must’ve dug up some terrible memories.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那么不喜欢她像Hamedori君吗，水引酱⋯⋯”",
