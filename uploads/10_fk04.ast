		{"fg", file="asane_02m_00002", file1="asane_02m_00101", file2="asane_02m_00221", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="麻沙音3", id=3, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane1559", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“T-That’s right! Tama-Tama is our cat now. There’s no need to give her back to those old fogies!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“对呀对呀⋯⋯蛋蛋是我们家的猫，才不要还给老爷爷们呢⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「對呀對呀⋯⋯蛋蛋是我們家的貓，才不要還給老爺爺們呢⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00159",
		linknext = "0111_00161",
		line = 2597,
	},
	["0111_00161"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file3="jun_01f_00310", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Exactly. She’s a part of our family! Hmph! As if we could give her back to a senile old couple that can’t even keep track of a lost kitten!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“是呀，蛋蛋已经是我们家族的一员了！哈！怎么可能还给不知小猫去向的老糊涂啊──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「是呀，蛋蛋已經是我們家族的一員了！哈！怎麼可能還給不知小貓去向的老糊塗啊──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00160",
		linknext = "0111_00162",
		line = 2609,
	},
	["0111_00162"] = {
