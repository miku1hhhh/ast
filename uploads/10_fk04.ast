				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Use it too much and it’s bad for your heart. Keep it in moderation, all right, Bro?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“凉感会造成心脏的负担，要适当喔⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「涼感會造成心臟的負擔，要適當喔⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00015",
		linknext = "0111_00017",
		line = 238,
	},
	["0111_00017"] = {
