	},
	["0111_00168"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A cat could be such a saving grace for people like that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有只猫的陪伴将是多么大的救赎啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"有隻貓的陪伴將是多麼大的救贖啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00167",
		linknext = "0111_00169",
