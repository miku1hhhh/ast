			en = {
				{
					name = {"凛", "Rin"},
					"“There’s a raccoon dog on Mt. Senba, and a hunter shoots it with his rifle, then boils, grills, and eats it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“仙波山上有只狸，猎人用猎枪打狸，煮了狸！烤了狸！吃了狸！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「仙波山上有隻狸，獵人用獵槍打貍，煮了狸！烤了狸！吃了狸！」",
					{"rt2"},
				},
			},
		},
