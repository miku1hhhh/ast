		},
		linkback = "0111_00170",
		linknext = "0111_00172",
		line = 2752,
	},
	["0111_00172"] = {
		{"fg", file="fumino_01m_00001", file1="fumino_01m_00101", file3="fumino_01m_00303", path=":fg/fumino_01m/", id=7, lv=7, head="fumino_01m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0654", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“I’ve read that cats will go to those who need them most.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“猫咪会去需要她的地方，连书也这么写着⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「貓咪會去需要她的地方，連書也這麼寫著⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00171",
		linknext = "0111_00173",
		line = 2767,
	},
	["0111_00173"] = {
