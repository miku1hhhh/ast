		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2229", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Tokie and Rei insisted on coming early and went to the meeting place in the afternoon. And then, everyone showed up as well...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“桐香酱和礼酱一直吵着要早点来，从中午开始就在集合地那边。然后大家陆陆续续也都到了──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「桐香醬和禮醬一直吵著要早點來，從中午開始就在集合地那邊。然後大家陸陸續續也都到了──」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00095",
		linknext = "0111_00097",
		line = 1588,
	},
	["0111_00097"] = {
