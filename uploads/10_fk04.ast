	},
	["0111_00169"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even for me, Tama-Tama has done so much to put me at ease ever since we took her in.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我自己也是自从有了蛋蛋以后，常被疗愈常因此得到救赎啊。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我自己也是自從有了蛋蛋以後，常被療癒常因此得到救贖啊。",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00168",
