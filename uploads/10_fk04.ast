					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“You might not think so, but I get along with cats pretty well, actually. I think I’ll poke around at the base of her butt and see if I can arouse her♪”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“别看我这样，我很容易被猫喜欢喔。你看，拍打屁股尾巴的地方，就能让幼小的她记住什么是发情♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「別看我這樣，我很容易被貓喜歡喔。你看，拍打屁股尾巴的地方，就能讓幼小的她記住什麼是發情♪」",
					{"rt2"},
				},
			},
		},
