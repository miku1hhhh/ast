			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“Even if... she used to be Toshiaki, Tama-Tama is a member of our family now!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“就算真的是精明⋯⋯！这孩子还是我们家的孩子⋯⋯”",
