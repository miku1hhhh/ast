			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Don’t bring up that dog... For some reason, animals just tend to warm up to me quickly. Ooh, she’s purring.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
