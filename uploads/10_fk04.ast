		{"fgact", ch="文乃7", id=7, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="fumino0668", path=":vo/", ch="fumino"},
			},
			ja = {
				{
					name = {"文乃"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“The chopsticks are there... So I’ll just set out some side dishes... Something to snack on in little bowls...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“筷子准备好了⋯⋯接下来上主菜⋯⋯简单吃的用小碗装⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"文乃"},
					"「筷子準備好了⋯⋯接下來上主菜⋯⋯簡單吃的用小碗裝⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00393",
		linknext = "0111_00395",
		line = 5957,
	},
	["0111_00395"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That’s all right, Fumino. We can all take what we need from the plate, so you should have a seat too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“文乃没关系啦，大家就用盘子装着吃就好了，你坐着吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「文乃沒關係啦，大家就用盤子裝著吃就好了，妳坐著吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00394",
		linknext = "0111_00396",
		line = 5969,
	},
	["0111_00396"] = {
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00101", file2="fumino_02m_00203", path=":fg/fumino_02m/", id=7, lv=7, head="fumino_02m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
