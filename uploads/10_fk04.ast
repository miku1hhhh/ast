			ja = {
				{
					name = {"水引"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"水引", "Mizuhiki"},
					"“No, she doesn’t. Nope. Definitely not. You’re a cat, all right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水引"},
					"“才没那回事⋯⋯嗯，没有⋯⋯你是猫猫没错⋯⋯”",
