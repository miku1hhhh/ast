				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“人家说夫妻会越来越像是真的耶⋯⋯啊，真讨厌，是说奈奈濑姐要来的关系，我坐也不是站也不是，现在就好想飞奔去迎接啊──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「人家說夫妻會越來越像是真的耶⋯⋯啊，真討厭，是說奈奈瀨姊要來的關係，我坐也不是站也不是，現在就好想飛奔去迎接啊──！」",
					{"rt2"},
				},
			},
		},
