		},
		linkback = "0111_00116",
		linknext = "0111_00118",
		line = 1929,
	},
	["0111_00118"] = {
		{"fg", file="misaki_01m_00002", file1="misaki_01m_00101", file2="misaki_01m_00228", path=":fg/misaki_01m/", id=6, lv=6, head="misaki_01m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="misaki1287", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“So, you still haven’t found the owner of this Tamadori here?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“听说还没找到领养蛋dori君的主人？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「聽說還沒找到領養蛋dori君的主人？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00117",
		linknext = "0111_00119",
		line = 1943,
	},
	["0111_00119"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00218", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=12},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Don’t change her name so casually. And no, we haven’t.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“很自然地就帮她改名字了耶⋯⋯是呀，还没找到。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「很自然地就幫她改名字了耶⋯⋯是呀，還沒找到。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00118",
		linknext = "0111_00120",
		line = 1955,
	},
	["0111_00120"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=12},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If nothing changes, we’ll probably end up keeping her. I think that’s for the best.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“再继续这样下去，感觉就会变成我们收编她了。不过现在觉得干脆就那样也不错。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「再繼續這樣下去，感覺就會變成我們收編她了。不過現在覺得乾脆就那樣也不錯。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00119",
		linknext = "0111_00121",
		line = 1967,
	},
	["0111_00121"] = {
