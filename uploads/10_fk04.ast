				},
			},
			en = {
				{
					name = {"文乃", "Fumino"},
					"“In that case, the ones who really need Tama-Tama... are the elderly couple who lost her before.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"文乃"},
					"“我也知道，他们是真的需要蛋蛋。”",
