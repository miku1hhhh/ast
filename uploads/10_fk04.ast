					name = {"ヒナミ", "Hinami"},
					"“Gulp! Yum! I’ve never had this before, but it’s so sweet and tasty! I think I’ll drink a ton of it to loosen up a bit!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“大口大口喝！噗哈！酒好甜好好喝啊！喝多的话身体就会变软吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「大口大口喝！噗哈！酒好甜好好喝啊！喝多的話身體就會變軟吧。」",
					{"rt2"},
				},
