	["0111_00158"] = {
		{"bgm", file="bgm21", vol=100},
		{"fg", file="fumino_02m_00001", file1="fumino_02m_00104", file2="fumino_02m_00203", path=":fg/fumino_02m/", id=7, lv=7, head="fumino_02m", ch_origin="文乃", ch="文乃7", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
