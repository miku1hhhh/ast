			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“The one the FS has received a search request for? Hm, you’re right. They’re both black cats, and the timing matches up too.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“你说向FS提出搜索请求的那个？⋯⋯没错耶，是只全黑的小猫，时间点也很符合⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「妳說向FS提出搜索請求的那個？⋯⋯沒錯耶，是隻全黑的小貓，時間點也很符合⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00150",
		linknext = "0111_00152",
		line = 2453,
	},
	["0111_00152"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00219", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=7},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Could you explain?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“怎么一回事？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「怎麼一回事？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00151",
		linknext = "0111_00153",
		line = 2465,
	},
	["0111_00153"] = {
		{"fg", file="rei_01m_00002", file1="rei_01m_00101", file2="rei_01m_00224", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2362", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“A little while back, an elderly couple came down to the SHO, asking about a baby cat that’s run away not long after it was born.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不久前一对老夫妇来找SHO⋯⋯说刚出生没多久的小猫失踪了⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不久前一對老夫婦來找SHO⋯⋯說剛出生沒多久的小貓失蹤了⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00152",
		linknext = "0111_00154",
		line = 2479,
	},
	["0111_00154"] = {
		{"fg", file="hinami_01f_00002", file1="hinami_01f_00101", file2="hinami_01f_00213", path=":fg/hinami_01f/", id=30, ch="ヒナミ", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0989", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“They named a female cat Toshiaki?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“是不是只母猫，然后名字叫精明啊，礼酱？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「是不是隻母貓，然後名字叫精明啊，禮醬？」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00153",
		linknext = "0111_00155",
		line = 2492,
	},
	["0111_00155"] = {
		{"fg", file="tohka_02m_00002", file1="tohka_02m_00101", file2="tohka_02m_00202", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1908", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Since it was a black cat, that reminded them of the familiar from ‘Kiki’s Climax Service,’ who was named Governor. From there, they thought of Governor Hitoura and so, Toshiaki.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“黑猫的话，那就是和耻部利的名作“痴女高潮便”中的从魔“吉事”有关，然后从吉事→知事→仁浦县知事→精明变成这样啰。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「黑貓的話，那就是和恥部利的名作“痴女高潮便”中的從魔“吉事”有關，然後從吉事→知事→仁浦縣知事→精明變成這樣囉。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00154",
		linknext = "0111_00156",
		line = 2507,
	},
	["0111_00156"] = {
