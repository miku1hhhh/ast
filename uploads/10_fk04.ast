		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1909", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I’ve gotten in contact with them. They’ll need to prepare for her arrival, so they’ve asked for you to keep her for one more week.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“联络好了。他们那边要准备接手要点时间，希望能再寄放这里一周。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「聯絡好了。他們那邊要準備接手要點時間，希望能再寄放這裡一週。」",
					{"rt2"},
				},
			},
		},
		linkback = "0111_00173",
