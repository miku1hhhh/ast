		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A quiet daily life with no source of joy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"没什么乐趣，平静的日子中。",
					{"rt2"},
				},
			},
			tw = {
				{
					"沒什麼樂趣，平靜的日子中。",
