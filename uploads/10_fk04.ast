			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“We won’t have to do battle again. Oh, but if you start to feel sick, stop right away, okay?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“也不用战斗了⋯⋯啊，不过觉得不舒服的话就不要勉强喔。”",
