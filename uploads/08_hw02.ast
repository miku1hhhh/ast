		text = {
			vo = {
				{"vo", file="rei2179", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Maybe I wasn’t really trying to protect Hinami, I was just pushing my beliefs down her throat. Maybe she would be happier if she accepted the island’s customs... I couldn’t stop thinking like that.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“想要保护雏见这件事，只是我一厢情愿……我无数次的想着……其实雏见她沾染上这座岛的气息，说不定会比较幸福吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「想要保護雛見這件事，只是我一廂情願……我無數次的想著……其實雛見她沾染上這座島的氣息，說不定會比較幸福吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00195",
		linknext = "0097_00197",
		line = 2858,
	},
