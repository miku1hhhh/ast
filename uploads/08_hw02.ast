		},
		text = {
			vo = {
				{"vo", file="rei2171", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I hear that whatever the giver himself would like to receive often makes for a good gift. How about you, Tachibana? Is there something you’d like from Hinami, or for her to do for you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“时常听到人家说，自己收到了会很开心的东西……橘觉得呢？有没有想让雏见送的东西或是想让她做的事情呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「時常聽到人家說，自己收到了會很開心的東西……橘覺得呢？有沒有想讓雛見送的東西或是想讓她做的事情呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00170",
		linknext = "0097_00172",
		line = 2517,
	},
	["0097_00172"] = {
