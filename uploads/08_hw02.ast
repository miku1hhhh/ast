					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Tell me, Rei, what kind of presents do girls like? Besides strange-looking belts.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“礼学姐请告诉我吧，女孩子收到什么礼物会很开心？除了奇怪的腰带之外。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「禮學姊請告訴我吧，女孩子收到什麼禮物會很開心？除了奇怪的腰帶之外。」",
					{"rt2"},
				},
			},
		},
