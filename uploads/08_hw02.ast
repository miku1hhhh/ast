					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I thought the perverted sex law was abolished, so why is our study material still full of this stuff?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过，明明变态条例都已经瓦解了，总觉得还是老样子啊……”",
