		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I have no regrets. I did it for my loved ones, even if it meant breaking some eggs.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不后悔那个选择。即便如此，还是有想守护的东西，也有想拯救的东西。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不後悔那個選擇。即便如此，還是有想守護的東西，也有想拯救的東西。",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00106",
		linknext = "0097_00108",
