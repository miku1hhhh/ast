				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“A-Anyway! Hinami, Tachibana and I aren’t in a relationship, so we shouldn’t be getting in a bath together. So... yeah, please understand.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“总……总而言之，雏见！不是恋人关系的我与橘一起入浴就是一个大问题！所以……怎么说，虽然抱歉但是请放弃吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「總……總而言之，雛見！不是戀人關係的我與橘一起入浴就是一個大問題！所以……怎麼說，雖然抱歉但是請放棄吧……」",
					{"rt2"},
				},
			},
		},
