			},
		},
		text = {
			vo = {
				{"vo", file="rei2145", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“They announced that they’ll continue broadcasting, albeit with restricted viewership access. They’re struggling with all the broadcast regulations now that the perverted sex law is gone.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是啊。好像是设定了收看限制，之后电视台拨放还会继续下去的意思吧……虽是这么说，但条例消失的现在，规定太多也是很伤脑筋的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是啊。好像是設定了收看限制，之後電視台撥放還會繼續下去的意思吧……雖是這麼說，但條例消失的現在，規定太多也是很傷腦筋的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00092",
		linknext = "0097_00094",
		line = 1358,
	},
	["0097_00094"] = {
