			},
			tw = {
				{
					name = {"淳之介"},
					"「不過，明明變態條例都已經瓦解了，總覺得還是老樣子啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00023",
		linknext = "0097_00025",
		line = 345,
	},
