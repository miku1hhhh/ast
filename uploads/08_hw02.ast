	["0097_00563"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We can’t change the past no matter how hard we wish for it—no matter how gruesome her past may have been, it has led Rei to become the person she is today.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不管做了什么都无法改写过去──不论是经历了多么[|凄惨的过去，对]现在的礼学姐来说，都是过去的事情了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不管做了什麼都無法改寫過去──不論是經歷了多麼[|悽慘的過去，對]現在的禮學姊來說，都是過去的事情了。",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00562",
		linknext = "0097_00564",
		line = 7815,
	},
	["0097_00564"] = {
