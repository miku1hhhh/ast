	},
	["0097_00108"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Perhaps most people on this island don’t see the current situation as an improvement.",
					{"rt2"},
				},
			},
			cn = {
				{
					"生活在青蓝岛上的多数人，或许都在感叹着现在的这个状态吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"生活在青藍島上的多數人，或許都在感嘆著現在的這個狀態吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00107",
		linknext = "0097_00109",
		line = 1563,
	},
	["0097_00109"] = {
