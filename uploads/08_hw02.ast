	["0097_00556"] = {
		{"bgm", file="bgm27", vol=100},
		{"text"},
		text = {
			vo = {
				{"vo", file="hinami0618", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“If only I had noticed sooner...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“……应该再早一点，查觉到才对。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「……應該再早一點，查覺到才對。」",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00555",
		linknext = "0097_00557",
		line = 7744,
	},
	["0097_00557"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This may be the first time I’ve heard Hinami express regret.",
					{"rt2"},
				},
			},
			cn = {
				{
					"像这样从雏见嘴里说出后悔的话语，还是第一次听见。",
					{"rt2"},
				},
			},
			tw = {
				{
					"像這樣從雛見嘴裡說出後悔的話語，還是第一次聽見。",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00556",
		linknext = "0097_00558",
		line = 7754,
	},
	["0097_00558"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The pain she feels that makes her utter those words is conveyed to me with full clarity. I feel the same pain.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我非常理解这种溢出的感觉很难受。所以特别痛苦。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我非常理解這種溢出的感覺很難受。所以特別痛苦。",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00557",
		linknext = "0097_00559",
		line = 7764,
	},
	["0097_00559"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My relationship with the two of them is hardly as long as theirs, and even I feel that same frustration.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就连我这个没认识很久的人，有时也会觉得自己应该早一点查觉到才是。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就連我這個沒認識很久的人，有時也會覺得自己應該早一點查覺到才是。",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00558",
		linknext = "0097_00560",
		line = 7774,
	},
	["0097_00560"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Hinami was with Rei for such a long time. She must’ve witnessed her doing those things many times.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一直和礼学姐相处的雏见，肯定实际看过她这行为很多次才是。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一直和禮學姊相處的雛見，肯定實際看過她這行為很多次才是。",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00559",
		linknext = "0097_00561",
		line = 7784,
	},
	["0097_00561"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And all those times, Hinami never did anything... Her regret must be immeasurable.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当亲眼所见之时──毫无疑问的，也会后悔的受不了吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當親眼所見之時──毫無疑問的，也會後悔的受不了吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00560",
		linknext = "0097_00562",
		line = 7794,
