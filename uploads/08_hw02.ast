	["0097_00023"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"This would’ve been a great opportunity for Asa to get her homework done too, if it wasn’t for the fact that the vacation flipped her sleep pattern upside down.",
					{"rt2"},
				},
			},
			cn = {
				{
					"要是麻沙酱也能借此机会将作业做完就好了──在暑假期间完全是日夜颠倒的状态，最近则是睡到跨日了还在睡。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要是麻沙醬也能藉此機會將作業做完就好了──在暑假期間完全是日夜顛倒的狀態，最近則是睡到跨日了還在睡。",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00022",
		linknext = "0097_00024",
		line = 333,
	},
	["0097_00024"] = {
