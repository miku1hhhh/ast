					{"rt2"},
				},
			},
			cn = {
				{
					"正如雏见所说的，希望今后能慢慢地积累幸福的回忆──由衷地希望礼学姐能一直开开心心的就好了。",
					{"rt2"},
				},
			},
			tw = {
