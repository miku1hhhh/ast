					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“That’s the pluperfect subjunctive second-person plural of the word ‘ahegare’. It means ‘you had made an ahegao’.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“那是敬语版的‘上吧’下两段的用法。是跟很了不起的人做爱时，让对方上自己所使用的话语。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「那是敬語版的『上吧』下兩段的用法。是跟很了不起的人做愛時，讓對方上自己所使用的話語。」",
					{"rt2"},
				},
			},
		},
