		text = {
			vo = {
				{"vo", file="rei2150", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I mean, look at this island. There are people here who were happily making a living from sex-based work, and we need a productive outlet to take them in and rechannel their efforts.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“正因为是这样的一个岛……有的人喜欢做爱，也有以此做为生计的人在。对他们来说，是需要有接纳他们的地方。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「正因為是這樣的一個島……有的人喜歡做愛，也有以此做為生計的人在。對他們來說，是需要有接納他們的地方。」",
					{"rt2"},
				},
			},
		},
