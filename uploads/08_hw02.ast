	["0097_00192"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Tomorrow’s weather will be mostly cloudy, partly sunny. It should be a pleasant day.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明天会是多云转晴且愉快的一天吧。",
					{"rt2"},
