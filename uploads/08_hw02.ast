	["0097_00105"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Here on Seiran Island, there are definitely people who enjoy sex. If anything, they are in the majority.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在青蓝岛有喜欢做爱的人在──毫无疑问的占了大多数。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在青藍島有喜歡做愛的人在──毫無疑問的佔了大多數。",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00104",
		linknext = "0097_00106",
		line = 1526,
	},
	["0097_00106"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"With full understanding of that fact, we still chose to end the perverted sex law.",
					{"rt2"},
				},
			},
			cn = {
				{
					"明明知晓了这一切，我们还是击溃了变态条例。",
					{"rt2"},
				},
			},
			tw = {
				{
					"明明知曉了這一切，我們還是擊潰了變態條例。",
					{"rt2"},
				},
			},
		},
		linkback = "0097_00105",
		linknext = "0097_00107",
		line = 1536,
	},
	["0097_00107"] = {
