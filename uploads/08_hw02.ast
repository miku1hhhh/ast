		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I hope that one day, this island can become a truly great place to live for everyone, including them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"尽管如此，我还是希望有一天这个岛对他们而言──是大家都能轻松生活下去的地方。",
					{"rt2"},
				},
			},
			tw = {
				{
					"儘管如此，我還是希望有一天這個島對他們而言──是大家都能輕鬆生活下去的地方。",
					{"rt2"},
				},
			},
		},
