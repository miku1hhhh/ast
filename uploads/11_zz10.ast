		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00228", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", lv=9, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Bullshit! You’re a typical tokusatsu nerd who makes Rider references even to people who won’t get them! And you seem to love an*l! That’s the Rei I know!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“骗人！我所认识的礼前辈是个典型的臭特摄厨，就算对方不懂也硬要讲假面骑士梗，而且弱点是〇眼！你这种人才不是我的礼前辈！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「騙人！就算對方不懂也硬要講假面騎士梗的典型臭特攝廚而且屁眼是弱點的才是禮前輩！這種人不是我的禮前輩！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00023",
		linknext = "0124_00025",
		line = 349,
	},
	["0124_00025"] = {
