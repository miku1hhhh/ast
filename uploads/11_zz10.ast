			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Y-Yikes. What’s with this man...? I-If you do anything inappropriate, I’m going to call the police...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“讨、讨厌，这个人是怎么回事……你、你要是做出太出格的行为，我会报警的哦……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「討、討厭，這個人是怎樣……你、你要是做出太奇怪的行為，我會報警喔……？」",
					{"rt2"},
				},
			},
		},
