	["0124_00027"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00228", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“The Rei I know would never say that! Replying to official accounts with screengrab memes, yes! Weirdly threatening critiques mixed with insults, yes! But this?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“礼前辈才不会这样说话！礼前辈可是个会对官方帐号的贴文回复特摄影集截图还有自己心情的麻烦鬼宅宅！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「禮前輩才不會這樣說話！禮前輩可是個會對官方帳號的貼文回覆特攝影集截圖還有自己心情的麻煩鬼宅宅！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0124_00026",
		linknext = "0124_00028",
		line = 388,
	},
	["0124_00028"] = {
