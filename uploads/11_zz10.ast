				},
			},
			tw = {
				{
					name = {"美岬"},
					"「……像這樣！我寫了名為『處女的晚洩冒險第六部 精之海』的故事！你覺得怎麼樣，淳之介！」",
					{"rt2"},
				},
			},
		},
