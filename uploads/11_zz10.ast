				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“C’mon, verbally abuse me like always! Yell, ‘What’re you shaking like a leaf for?! If you’re gonna shake, do it with your hips and your d*ck in my a*s, you impotent virgin! OR I’LL KILL YOU!’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“拜托你骂我！！比方说‘你怎么在发抖！？要抖等你用〇〇推车〇翻天再来抖，你这个不举处男！杀了你喔！’之类的！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「拜託妳罵我！！比方說『你怎麼在發抖！？要抖等你用老漢推車操翻天再來抖，你這個不舉處男！殺了你喔！』這樣！！」",
					{"rt2"},
				},
			},
		},
