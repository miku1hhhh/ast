		{"fgact", ch="郁子10", id=10, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		delay = {
			[1000] = {
				{"se", id=0, loop=0, file="se_b057", timestamp=138, delay2=1000},
			},
			[999] = {
				{"transitiontime", time=300, timestamp=138, delay2=1000},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko2099", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“It’s just a cheap knockoff. It only has one engraving, and there’s no name engraved on the chrysanthemum here, see? If it were the real deal then it’d be behind glass in a museum somewhere.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“是便宜货。你看，这上面连个菊花铭文都没有对吧？要是真品的话是国宝或国家重要文化财产没错，不过这只是廉价的赝品啦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「是便宜貨。妳看，這上面連個菊花銘文都沒有對吧？要是真品的話是國寶或國家重要文化財產沒錯，不過這只是廉價的贗品啦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00444",
		linknext = "0093_00446",
		line = 6527,
	},
	["0093_00446"] = {
		{"fg", file="tohka_01m_00001", file1="tohka_01m_00101", file2="tohka_01m_00202", path=":fg/tohka_01m/", id=8, lv=8, head="tohka_01m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1816", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“It’s not so easy to get your hands on a real katana. Ikuko had to jump through a bunch of hoops to get hers. Right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“也就是说，一般来说是买不到刀的。只有郁子是从SHO那边透过特殊的管道拿到刀的，对吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「也就是說，一般來說是買不到刀的。只有郁子是從SHO那邊透過特殊的管道拿到刀的，對吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00445",
		linknext = "0093_00447",
		line = 6542,
	},
	["0093_00447"] = {
		{"se", id=0, loop=0, file="se_a185"},
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00203", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="礼9", id=9, act="振動下", loop=4, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		delay = {
			[4500] = {
				{"se", id=0, loop=0, file="se_a098", timestamp=139, delay2=4500},
				{"fg", file="rei_01m_00001", file1="rei_01m_00102", file2="rei_01m_00209", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=139, delay2=4500, mode=3, x=-605, y=-5},
				{"fgact", ch="礼9", id=9, act="振動下", loop=1, size=-12.5, time=200, ease="easeinout_sine", timestamp=139, delay2=4500},
			},
			[4499] = {
				{"transitiontime", time=300, timestamp=139, delay2=4500},
			},
		},
		text = {
			vo = {
				{"vo", file="rei2060", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“More charges to add to your list of crimes. Now take off your masks and confess to your crimes! ...Wait, you?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“看样子你还有更多的罪行，把那个面具摘下来忏悔吧──！⋯⋯唔、是你⋯⋯！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「看樣子妳還有更多的罪行，把那個面具摘下來懺悔吧──！⋯⋯唔、是妳⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00446",
		linknext = "0093_00448",
		line = 6564,
	},
	["0093_00448"] = {
		{"se", id=0, loop=0, file="se_a094"},
		{"fgact", ch="桐香8", id=8, act="移動", x=200, y=0, time=300},
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00102", file2="susuko_02m_00217", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", alpha=0, ch_origin="スス子", ch="スス子11", mw="mw", sync=1, a_chr151=1, mode=3, x=-205, y=395},
