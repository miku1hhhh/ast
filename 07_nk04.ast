			[3999] = {
				{"transitiontime", time=300, timestamp=114, delay2=4000},
			},
		},
		text = {
			vo = {
				{"vo", file="susuko0530", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子", "だんだら模様の女"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Zigzag-Sleeved Girl"},
					"“Pardon? What was that? Aaah, sour grapes? Those who oppose our cause deserve to die!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "横条纹女"},
					"“蛤⋯⋯？你说什么？啊、真是悲哀啊⋯⋯！与变态行为敌对，罪该万死──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "橫條紋女"},
					"「蛤⋯⋯？你說什麼？啊、真是悲哀啊⋯⋯！與變態行為敵對，罪該萬死──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00384",
		linknext = "0093_00386",
		line = 5524,
	},
	["0093_00386"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Oh geez... August, could you explain to them, please?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哎啊啊⋯⋯为我解释一下，Orgast。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哎啊啊⋯⋯為我解釋一下，Orgast。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00385",
		linknext = "0093_00387",
		line = 5536,
	},
	["0093_00387"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="august0014", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"オーガスト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"オーガスト", "August"},
					"“As you wish, Master. Greetings. I am the First Orgasm Assistance Protocol, but you may call me August for short.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"オーガスト", "August"},
					"‘明白了，主人。大家好，我是First Orgasm Assist Protocol。请简单称呼我为Orgast。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"オーガスト", "August"},
					"『明白了，主人。大家好，我是First Orgasm Assist Protocol。請簡單稱呼我為Orgast。』",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00386",
		linknext = "0093_00388",
		line = 5548,
	},
	["0093_00388"] = {
		{"fg", mode=-1, id=30},
		{"facehide"},
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00202", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", mwframe="mwframe", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[2500] = {
				{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00215", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", mwframe="mwframe", sync=0, timestamp=115, delay2=2500, mode=3, x=-5, y=-5},
				{"fgact", ch="スス子11", id=11, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine", timestamp=115, delay2=2500},
			},
			[2499] = {
				{"transitiontime", time=300, timestamp=115, delay2=2500},
			},
		},
		text = {
			vo = {
				{"vo", file="susuko0531", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子", "だんだら模様の女"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Zigzag-Sleeved Girl"},
					"“I-It’s a pleasure to meet yo— Wait, what is the meaning of this?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "横条纹女"},
					"“啊，你好，很高兴认识你……所以，这到底是怎么回事！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "橫條紋女"},
					"「啊，你好，很高興認識你……所以，這到底是怎麼回事！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00387",
		linknext = "0093_00389",
		line = 5569,
	},
	["0093_00389"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="august0015", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"オーガスト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"オーガスト", "August"},
					"“As you may have already seen, my master’s body has been finely chiseled into the pinnacle of physical fitness. Each individual muscle has been honed into a deadly weapon.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"オーガスト", "August"},
					"‘你们也都看到了，主人全身的肌肉都练出来了。可以说，每一块肌肉都是致命的武器。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"オーガスト", "August"},
					"『你們也都看到了，主人全身的肌肉都練出來了。可以說，每一塊肌肉都是致命的武器。』",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00388",
		linknext = "0093_00390",
		line = 5581,
	},
	["0093_00390"] = {
		{"fg", mode=-1, id=30},
		{"facehide"},
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00102", file2="susuko_02m_00203", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", mwframe="mwframe", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="スス子11", id=11, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0532", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子", "だんだら模様の女"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Zigzag-Sleeved Girl"},
					"“S-So what?! Like I said, it doesn’t matter how many muscles this loser has, he—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "横条纹女"},
					"“那、那又怎么样！不管你到底有多少肌肉，面对这种数量的对手也──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "橫條紋女"},
					"「那、那又怎麼樣！不管你到底有多少肌肉，面對這種數量的對手也──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00389",
		linknext = "0093_00391",
		line = 5599,
	},
	["0093_00391"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="august0016", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"オーガスト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"オーガスト", "August"},
					"“Do you know how many muscles there are in the human body?”",
					{"rt2"},
				},
			},
			cn = {
				{
