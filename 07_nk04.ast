	["0093_00393"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="august0017", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"オーガスト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"オーガスト", "August"},
					"“There are approximately six hundred individual muscles in the human body.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"オーガスト", "August"},
					"‘肌肉会依据不同的人产生个体差异，不过据说大约是600块左右。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"オーガスト", "August"},
					"『肌肉會依據不同的人產生個體差異，不過據說大約是600塊左右。』",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00392",
		linknext = "0093_00394",
		line = 5648,
	},
	["0093_00394"] = {
		{"bgm", file="bgm15", vol=100},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You know what that means, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“没错，也就是说，我的身体是──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「沒錯，也就是說，我的身體是──」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00393",
		linknext = "0093_00395",
		line = 5661,
	},
	["0093_00395"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="august0018", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"オーガスト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"オーガスト", "August"},
					"“In essence, this human body is equipped with more than six hundred deadly weapons. The difference in strength here is six hundred to seventy four. We have the upper hand, Master.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"オーガスト", "August"},
					"‘──您可以把它当作是全身布满了600多件的凶器。实力差距是600比74，是我方压倒性的胜利，主人。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"オーガスト", "August"},
					"『──您可以把它當作是全身佈滿了600多件的兇器。實力差距是600比74，是我方壓倒性的勝利，主人。』",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00394",
		linknext = "0093_00396",
		line = 5673,
	},
	["0093_00396"] = {
		{"fg", mode=-1, id=30},
		{"facehide"},
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00102", file2="susuko_02m_00209", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", mwframe="mwframe", sync=0, mode=3, x=-5, y=-5},
