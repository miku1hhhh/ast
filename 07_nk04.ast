	},
	["0093_00083"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00219", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You said ‘seven’ before. Is that how many times this has happened so far?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“第七起⋯⋯这种事已经发生过很多次了吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「第七起⋯⋯這種事已經發生過很多次了嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00082",
		linknext = "0093_00084",
		line = 1222,
	},
	["0093_00084"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00102", file3="rei_01m_00313", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2054", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“It’s only been happening at Minotsuki Academy. Ran, the super serious, has been the one to find them until now. She’s been doing her best to keep it under wraps, but now...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这只发生在水乃月学园里。之前都是正经八百把抢第一当成生存价值的兰在偶然间发现的，所以没有说出去。但……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這只發生在水乃月學園裡。之前都是正經八百把搶第一當成生存價值的蘭在偶然間發現的，所以沒有說出去。但……」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00083",
		linknext = "0093_00085",
		line = 1237,
	},
	["0093_00085"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00203", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She’s been turning up at the last minute recently saying she was looking for her sister. But this is actually what she’s been doing the whole time?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她最近一直忙着找妹妹吧，所以──？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「她最近一直忙著找妹妹吧，所以──？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00084",
		linknext = "0093_00086",
		line = 1249,
	},
	["0093_00086"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00102", file2="rei_02m_00204", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2055", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“There’s no use in trying to keep it quiet any more. We must inform the Teacher Corps and put out a bulletin to every class.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“已经不能继续瞒下去了⋯⋯还是说服老师公告全学年吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「已經不能繼續瞞下去了⋯⋯還是說服老師公告全學年吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00085",
