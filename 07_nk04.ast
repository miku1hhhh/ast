	["0093_00032"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file3="jun_01f_00303", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You’re telling me you wouldn’t love to see your big brother cum so hard his balls turned inside out?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“要是哥哥我能像拔作那样像要把蛋蛋都射出来一样的大量射精的话，麻沙酱你应该也会很开心吧！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「要是哥哥我能像拔作那樣像要把蛋蛋都射出來一樣的大量射精的話，麻沙醬妳應該也會很開心吧！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00031",
		linknext = "0093_00033",
		line = 470,
	},
	["0093_00033"] = {
