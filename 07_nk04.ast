	["0093_00404"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Of course, by “us” I meant me and my muscles—each with its own individual name.",
					{"rt2"},
