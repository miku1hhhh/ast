					name = {"礼"},
					"“好了，走快点！都是因为你害我们被污名化了，兼差就已经很忙了还要做这种奇怪的善后收尾，真的是很麻烦耶⋯⋯！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「好了，走快點！都是因為妳害我們被污名化了，兼差就已經很忙了還要做這種奇怪的善後收尾，真的是很麻煩耶⋯⋯！？」",
					{"rt2"},
				},
			},
		},
