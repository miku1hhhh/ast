	["0093_00079"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00203", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", alpha=0, ch_origin="礼", ch="礼9", mw="mw", sync=1, a_chr151=1, mode=3, x=195, y=-5},
		{"fgact", ch="礼9", id=9, lv=9, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="礼9", id=9, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2052", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Tachibana? No, they’re just unconscious. But they’ll probably catch a cold. Who knows how long they’ve been left here like that...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“是橘啊⋯⋯他们应该只是晕过去而已啦。但是维持这种全裸的状态被长时间丢在这边，大概会感冒吧⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「是橘啊⋯⋯他們應該只是暈過去而已啦。但是維持這種全裸的狀態被長時間丟在這邊，大概會感冒吧⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00078",
		linknext = "0093_00080",
		line = 1175,
	},
	["0093_00080"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Probably students of the school. Both had been stripped naked. Their clothes lie neatly folded to one side.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这一男一女──大概是水乃月的学生──身上的衣服被扒个精光，规整地摆放在旁边。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這一男一女──大概是水乃月的學生──身上的衣服被扒個精光，規整地擺放在旁邊。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00079",
		linknext = "0093_00081",
		line = 1185,
	},
	["0093_00081"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00102", file2="rei_02m_00210", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2053", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Doesn’t look like anything was stolen this time either. Huff, still no closer to figuring out a motive.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这是果然也是一样，东西都没被偷走⋯⋯啊、完全搞不懂目的是什么啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這是果然也是一樣，東西都沒被偷走⋯⋯啊、完全搞不懂目的是什麼啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00080",
		linknext = "0093_00082",
		line = 1200,
	},
	["0093_00082"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I ask some questions as I help lay a blanket over the victims.",
					{"rt2"},
				},
			},
			cn = {
				{
					"她一边帮被害者盖上毛巾，一边问。",
					{"rt2"},
				},
			},
			tw = {
				{
					"她一邊幫被害者蓋上毛巾，一邊問。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00081",
