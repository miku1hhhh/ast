			en = {
				{
					name = {"非表示", "Zigzag-Sleeved Girl"},
					"“They refused invitations for sex, despite professing the freedom to be perverted while attending Minotsuki Academy! Therefore, we, the Erect Elect, passed down divine punishment!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"非表示", "横条纹女"},
					"“这些人在水乃月上课宣称有‘变态行为的自由’，拒绝做爱！因此受到了我们‘茎选组’的天诛！”",
