		text = {
			vo = {
				{"vo", file="susuko0545", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Hmph... You may have defeated me, but there will be a second and a third to replace me! Mark my words, you will witness the power of the Perverted Five Stars! Hyukhyukhyuk!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“哼⋯⋯就算打倒我，也还会有第二个、第三个变态激进份子出现的⋯⋯我会衷心期盼着‘变态五老星’的出现的⋯⋯！丝丝丝丝丝！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「哼⋯⋯就算打倒我，也還會有第二個、第三個變態激進份子出現的⋯⋯我會衷心期盼著『變態五老星』的出現的⋯⋯！絲絲絲絲絲！」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00454",
		linknext = "0093_00456",
		line = 6723,
	},
	["0093_00456"] = {
