					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Sultry Teacher"},
					"“But that’s why the syntactic structures that are important for comprehending long texts have a strong memorization element.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "色情女老师"},
					"“⋯⋯所以，在阅读长篇文章的时候，记住重要的语法很重要。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "色情女老師"},
					"「⋯⋯所以，在閱讀長篇文章的時候，記住重要的語法很重要。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00101",
		linknext = "0093_00103",
