		{"fgact", ch="礼9", id=9, lv=9, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="礼9", id=9, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei2056", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Couldn’t tell you. There hasn’t been any pattern to the victims. This is the first time it’s been a couple. Their motive and their means are a total mystery to us...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“我也不知道。受害者互相没有关联性。这也是第一次情侣组受害。他们做这种事的目的、手段，到现在都还是个谜⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「我也不知道。受害者互相沒有關聯性。這也是第一次情侶組受害。他們做這種事的目的、手段，到現在都還是個謎⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00089",
