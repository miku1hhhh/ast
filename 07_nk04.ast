		text = {
			vo = {
				{"vo", file="susuko0534", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子", "だんだら模様の女"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Zigzag-Sleeved Girl"},
					"“What kinda math is that?! The hell does some fancy-pants AI know about what’s happening anyway?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "横条纹女"},
					"“那种计算很诡异吧！？话说那个AI到底又说明了什么啊！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "橫條紋女"},
					"「那種計算很詭異吧！？話說那個AI到底又說明了什麼啊！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00395",
		linknext = "0093_00397",
		line = 5694,
	},
	["0093_00397"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="august0019", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"オーガスト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"オーガスト", "August"},
					"“I am a processing program, not an AI. For a variety of reasons, I have been equipped with a number of upgrades that allow me to analyze a situation to come to an optimal decision.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"オーガスト", "August"},
					"‘我不是AI，而是个处理程式。由于各种的状况得到了升级，配备了在这种情况下能做出准确判断的系统。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"オーガスト", "August"},
					"『我不是AI，而是個處理程式。由於各種的狀況得到了升級，配備了在這種情況下能做出準確判斷的系統。』",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00396",
		linknext = "0093_00398",
		line = 5706,
	},
