			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Four eyes in the back’s gonna get my subscapularis muscle. I’ve got my right gastrocnemius trained on the one with the long face! And my pectorals are looking at you, buddy!”",
