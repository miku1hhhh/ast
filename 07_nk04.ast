			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well what kind of perv extremist group are you if you can’t handle that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“什么，你们⋯⋯你们这些变态激进份子连这种程度都做不到吗⋯⋯？”",
