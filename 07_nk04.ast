				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「咳、咳⋯⋯唔，我有慢性肺結核⋯⋯！」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00449",
		linknext = "0093_00451",
		line = 6621,
	},
	["0093_00451"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00228", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1817", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“There’s usually a tasty katsudon included in the interrogation. Should I put in the order and get it to go?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“审问的话也有附上炸猪派盖饭对吧。对了，今天要不要去店里买些东西啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「審問的話也有附上炸豬派蓋飯對吧。對了，今天要不要去店裡買些東西啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00450",
		linknext = "0093_00452",
		line = 6636,
	},
	["0093_00452"] = {
		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file2="ikuko_02m_00214", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="郁子10", id=10, act="振動下", loop=1, size=12.5, time=500, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2100", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“No, Tokie. We don’t have the budget for that! I’ve got a box of sushi at home, will that do?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“不行啦桐香酱。我们没有那种闲钱吧，家里剩的散寿司就够了吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「不行啦桐香醬。我們沒有那種閒錢吧，家裡剩的散壽司就夠了吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00451",
		linknext = "0093_00453",
		line = 6652,
	},
	["0093_00453"] = {
