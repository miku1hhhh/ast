	["0093_00036"] = {
		{"fg", file="jun_01f_00003", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“In that case, let’s go check on that menu Nanase put together for me. It’s gonna help increase the amount of fuel I have in the tank.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就是这样，所以我请奈奈濑帮忙设计了可以大量射精的菜单。让我们来看看成果如何吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就是這樣，所以我請奈奈瀨幫忙設計了可以大量射精的菜單。讓我們來看看成果如何吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00035",
		linknext = "0093_00037",
		line = 524,
	},
	["0093_00037"] = {
		{"fg", file="asane_02m_00003", file1="asane_02m_00102", file2="asane_02m_00217", path=":fg/asane_02m/", id=3, lv=3, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
