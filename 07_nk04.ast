				{"cgact", file="cgact", id=24, act="アルファフェード点滅", loop=-1, alpha="256,0", time=300, alphadel=0, timestamp=112, delay2=400, lv=24},
			},
			[399] = {
				{"transitiontime", time=200, timestamp=112, delay2=400},
			},
		},
		text = {
			vo = {
				{"vo", file="august0013", path=":vo/", ch="mob"},
			},
			ja = {
				{
					name = {"オーガスト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"オーガスト", "August"},
					"“The bandits are assembling in a circular pattern. 74 total. Equipped with assault rifles and longswords. We are surrounded.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"オーガスト", "August"},
					"‘暴徒们正围成圆形中。数量有74人。配备SHO突击步枪与常见。将您包围了。’",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"オーガスト", "August"},
					"『暴徒們正圍成圓形中。數量有74人。配備SHO突擊步槍與常見。將您包圍了。』",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00376",
		linknext = "0093_00378",
		line = 5402,
	},
	["0093_00378"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They layer themselves one row on top of another, creating an impenetrable wall.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他们层层包围着，形成了一个无法通过的人墙。",
					{"rt2"},
				},
			},
			tw = {
				{
					"他們層層包圍著，形成了一個無法通過的人牆。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00377",
		linknext = "0093_00379",
		line = 5412,
	},
	["0093_00379"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Then they all brace their machine guns on their shoulders.",
					{"rt2"},
				},
			},
			cn = {
				{
					"并且，所有人肩膀上都扛着机关枪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"並且，所有人肩膀上都扛著機關槍。",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00378",
		linknext = "0093_00380",
		line = 5422,
	},
	["0093_00380"] = {
		{"cgdel", id=22, lv=22, time=0, alphadel=1},
		{"cgdel", id=23, lv=23, time=0, alphadel=1},
		{"cgact", file="cgact", id=24, act="stopact", lv=24},
		{"cgdel", id=24, time=0, alphadel=1, lv=24},
		{"cgdel", id=2, lv=2, time=1000, alphadel=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", lv=2, mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You call yourselves the Erect Elect and you stoop to using firearms? Hmph, your anti-government ancestors, the Shinsengumi, would be rolling in their graves.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你自称是茎选组还用这些枪炮—哼—，反政府的志士听了也会傻眼吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你自稱是莖選組還用這些槍砲—哼—，反政府的志士聽了也會傻眼吧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00379",
		linknext = "0093_00381",
		line = 5442,
	},
	["0093_00381"] = {
		{"se", id=0, loop=0, file="se_b056"},
		{"fg", mode=-1, id=30},
		{"facehide"},
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00226", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", mwframe="mwframe", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0528", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子", "だんだら模様の女"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Zigzag-Sleeved Girl"},
					"“Even their commander Kondo Isami carried a handgun. We simply updated with the times.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "横条纹女"},
					"“就连近藤勇都有手枪，我们只是把它变成稍微大了一点的机关枪而已！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "橫條紋女"},
					"「就連近藤勇都有手槍，我們只是把它變成稍微大了一點的機關槍而已！」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00380",
		linknext = "0093_00382",
		line = 5459,
	},
	["0093_00382"] = {
		{"fg", mode=-1, id=30},
		{"facehide"},
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00215", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", mwframe="mwframe", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0529", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子", "だんだら模様の女"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Zigzag-Sleeved Girl"},
					"“Sure, you have some sick guns, but we’ve got REAL ones! There’s no way you’re getting out of this without a hearty helping of lead! Now it is time for your Divine Punishment!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "横条纹女"},
					"“不管你有多少块肌肉，面对这么多枪可不只是被扫成蜂窝而已！现在就是你受到天诛的时刻──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "橫條紋女"},
					"「不管你有多少塊肌肉，面對這麼多槍可不只是被掃成蜂窩而已！現在就是你受到天誅的時刻──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00381",
		linknext = "0093_00383",
		line = 5476,
	},
	["0093_00383"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"What does a group of perv extremists expect to achieve?",
					{"rt2"},
				},
			},
			cn = {
				{
					"要是思考这些变态激进份子聚在一起，到底想做什么的话──",
					{"rt2"},
				},
			},
			tw = {
				{
					"要是思考這些變態激進份子聚在一起，到底想做什麼的話──",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00382",
		linknext = "0093_00384",
		line = 5486,
	},
	["0093_00384"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00402", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mwframe="mwframe", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hmph, you really have no idea what you’re doing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哼⋯⋯看来你什么都不懂呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哼⋯⋯看來妳什麼都不懂呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00383",
		linknext = "0093_00385",
		line = 5499,
	},
	["0093_00385"] = {
		{"fg", mode=-1, id=30},
