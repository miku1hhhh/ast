		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"On their each of their foreheads is a label with the words DIVINE PUNISHMENT written on it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"被害者的额头上还被贴了一张写着‘天诛’的纸。",
