					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“The FS Disciplinary Committee’s been totally disbanded so no, none of us have a key. And when I went to the staff room to borrow it, they told me it had gone missing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“因为FS风纪委员已经全部解散了，所以我们也没有钥匙⋯⋯虽然有教师休息室要，不过好像不见了的样子。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「因為FS風紀委員已經全部解散了，所以我們也沒有鑰匙⋯⋯雖然有教師休息室要，不過好像不見了的樣子。」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00218",
		linknext = "0093_00220",
		line = 2904,
	},
	["0093_00220"] = {
