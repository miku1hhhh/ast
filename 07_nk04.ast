	},
	["0093_00103"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="gmoba0163", path=":vo/", ch="gmob"},
			},
			ja = {
				{
					name = {"モブ女A", "色っぽい女教師"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"モブ女A", "Sultry Teacher"},
					"“So from the ‘not only A but also B’ construction of ‘not only pussy but also clit’, we can derive the meaning of ‘I want you to play with my clit too, not just my pussy.’ In this way...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"モブ女A", "色情女老师"},
					"“比如说用‘Not only A but also B’的语法造出‘ Not only omanko but also kurichan’，就是‘不单只有小穴、连小淫豆都想要被爱抚’的意思──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"モブ女A", "色情女老師"},
					"「比如說用『Not only A but also B』的語法造出『 Not only omanko but also kurichan』，就是『不單只有小穴、連小淫荳都想要被愛撫』的意思──」",
					{"rt2"},
				},
			},
		},
