		{"fgact", ch="スス子11", id=11, act="移動", x=0, y=-400, time=700},
		{"fgact", ch="スス子11", id=11, act="浮遊横", loop=3, size=5, time=125, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0542", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Uh-ohhh, haha... Looks like the disciplinary committee president found me! Whoopsie-daiisy...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“啊哈哈、被教官抓到了⋯⋯失败失败⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「啊哈哈、被教官抓到了⋯⋯失敗失敗⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00447",
		linknext = "0093_00449",
		line = 6582,
	},
	["0093_00449"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00102", file2="rei_01m_00223", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[3500] = {
				{"fg", file="rei_02m_00001", file1="rei_02m_00102", file2="rei_02m_00213", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, timestamp=140, delay2=3500, mode=3, x=-605, y=-5},
				{"fgact", ch="礼9", id=9, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine", timestamp=140, delay2=3500},
			},
			[3499] = {
				{"transitiontime", time=300, timestamp=140, delay2=3500},
			},
		},
		text = {
			vo = {
				{"vo", file="rei2061", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Inami?! What are you doing here? No, actually let’s talk later. You have a lot of explaining to do!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“伊波⋯⋯！？你，你为什么会在那种地方还做这种⋯⋯！不，这些事等等再说，我今天可是有很多事要好好问问你喔⋯⋯！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「伊波⋯⋯！？妳，妳為什麼會在那種地方還做這種⋯⋯！不，這些事等等再說，我今天可是有很多事要好好問問妳喔⋯⋯！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00448",
		linknext = "0093_00450",
		line = 6601,
	},
	["0093_00450"] = {
