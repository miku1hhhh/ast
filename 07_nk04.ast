		{"fgact", ch="奈々瀬4", id=4, act="移動", x=-200, y=0, time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0831", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Today we have clam miso soup with a broiled eel rice bowl, round steak with walnut and avocado salad, then grated yam with deep-fried turtle head nuggets!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“今天是蛤蛎味增汤跟蒲烧鳗盖饭，用牛后腿肉煎的五分熟牛排搭上酪梨坚果沙拉，还有山药泥跟炸鱼头～♪”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「今天是蛤蠣味增湯跟蒲燒鰻蓋飯，用牛後腿肉煎的五分熟牛排搭上酪梨堅果沙拉，還有山藥泥跟炸魚頭～♪」",
					{"rt2"},
				},
			},
		},
		linkback = "0093_00038",
		linknext = "0093_00040",
		line = 578,
	},
	["0093_00040"] = {
