			},
			cn = {
				{
					name = {"桐香"},
					"“因为我最喜欢被前辈骂了啊。该说是可以感受到爱情吗……？要是他能惩罚我就更好了……",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「因為我最喜歡被前輩罵了啊。該說是可以感受到愛情嗎……？要是他能懲罰我就更好了……",
					{"gaiji", text="①"},
					"」",
					{"rt2"},
				},
			},
		},
