	["0063_00039"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00206", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0382", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Oh my gosh! You’re totally that type of a person who buys unnecessary stuff on infomercials...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“教官绝对是在晚上的通贩节目购买不必要的东西的类型吧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「教官絕對是在晚上的通販節目購買不必要的東西的類型吧……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00038",
		linknext = "0063_00040",
		line = 555,
	},
	["0063_00040"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00223", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-205, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="礼9", id=9, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1151", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Come on! Who wouldn’t want a knife that can cut everything and doesn’t need to be sharpened?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“因为节目上说是不需要保养、却可以用来切各种东西的菜刀哦！被这么说的话当然会想买吧～～！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「因為節目上說是不需要保養、卻可以用來切各種東西的菜刀哦！被這麼說的話當然會想買吧～～！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00039",
		linknext = "0063_00041",
		line = 571,
	},
	["0063_00041"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00214", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="郁子10", id=10, act="振動下", loop=1, size=12.5, time=300, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1250", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Why would you need that? I’m telling you that I can cut everything in two. That’s why we don’t need Tanoogle Translate either.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“就算没有这种东西，郁也能帮你把任何东西砍成两半啊？所以你也不需要狸狸加尔哦──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「就算沒有這種東西，郁也能幫妳把任何東西砍成兩半啊？所以妳也不需要狸狸加爾哦──」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00040",
		linknext = "0063_00042",
		line = 587,
	},
	["0063_00042"] = {
		{"bgm", stop=1},
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
