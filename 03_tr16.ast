	["0063_00226"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00222", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It’s not so simple! If someone requires a lot of your work, it only pisses you off, right? I am pissed! But she’s so cute!!!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“才没有这么简单呢！费工夫的事情会让人很生气吧？我也会生气啊！不过实在太可爱了！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「才沒有這麼簡單呢！費工夫的事情會讓人很生氣吧？我也會生氣啊！不過實在太可愛了！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00225",
		linknext = "0063_00227",
		line = 3458,
	},
	["0063_00227"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00102", file2="jun_01f_00208", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She’s so adorable that I hate her! And here am I, dealing with these contradicting emotions every fucking day!”",
					{"rt2"},
				},
			},
			cn = {
				{
