	["0063_00216"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00211", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Touka sure needs a lot of attention... If we say that Asa’s caretaking is one Asa unit, then Touka takes 12 Asas.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“桐香照顾起来的确很费工夫……如果照顾麻沙音的麻烦程度是1麻沙酱的话，桐香就是12麻沙酱。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「桐香照顧起來的確很費工夫……如果照顧麻沙音的麻煩程度是1麻沙醬的話，桐香就是12麻沙醬。」",
					{"rt2"},
				},
			},
		},
