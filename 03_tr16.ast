		{"fg", file="misaki_02m_00001", file1="misaki_02m_00101", file2="misaki_02m_00206", path=":fg/misaki_02m/", id=6, lv=6, head="misaki_02m", ch_origin="美岬", ch="美岬6", mw="mw", sync=0, mode=3, x=-205, y=-5},
