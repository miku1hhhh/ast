	["0063_00150"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1296", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Up until now, I loved being cuckolded... so I almost forced you to get along with everyone...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“我原本非常喜欢NTR……所以你把我排除在外，和大家感情变好的话，我原本应该会觉得很舒服才对，但是……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「我原本非常喜歡NTR……所以你把我排除在外，和大家感情變好的話，我原本應該會覺得很舒服才對，但是……」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00149",
		linknext = "0063_00151",
		line = 2265,
	},
	["0063_00151"] = {
