			[3000] = {
				{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00205", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, timestamp=3, delay2=3000, mode=3, x=195, y=-5},
			},
			[2999] = {
				{"transitiontime", time=300, timestamp=3, delay2=3000},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko1245", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“The other day, she was like, ‘There was an earthquake. Did you cause it?’ When I said that I didn’t, she said that we should prepare sandbags to build a dike against tsunamis.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“她之前也对我说过‘地震时要怎么做？’，我一回答她根本没有发生地震后，才知道她是指为了预防海啸，要事先堆好沙包呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「她之前也對我說過『地震時要怎麼做？』，我一回答她根本沒有發生地震後，才知道她是指為了預防海嘯，要事先堆好沙包呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00011",
		linknext = "0063_00013",
		line = 187,
	},
	["0063_00013"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00205", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[7000] = {
				{"fg", file="schubert_01m_00001", file1="schubert_01m_00102", file2="schubert_01m_00214", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, timestamp=4, delay2=7000, mode=3, x=595, y=-5},
			},
			[6999] = {
				{"transitiontime", time=300, timestamp=4, delay2=7000},
			},
		},
		text = {
			vo = {
				{"vo", file="schubert0250", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“She probably thinks that everyone’s brains work in the same way as hers. Should we call her a genius? Do you always follow her, Junnosuke?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“她以为所有人的智商程度都和自己一样吧，该说是天才的习性吗……？淳之介平常跟得上她吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「她以為所有人的智商程度都和自己一樣吧，該說是天才的習性嗎……？淳之介平常跟得上她嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00012",
		linknext = "0063_00014",
		line = 205,
	},
	["0063_00014"] = {
