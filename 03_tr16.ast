				},
			},
			cn = {
				{
					name = {"美岬"},
					"“惩罚游戏是让初经前的女孩在肛门插入按摩棒的那个过年特别节目吗！？咳咳！请你们务必要让我这个肛门研究家一起欣赏……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「懲罰遊戲是讓初經前的女孩在肛門插入按摩棒的那個過年特別節目嗎！？咳咳！請你們務必要讓我這個肛門研究家一起欣賞……！」",
					{"rt2"},
				},
			},
		},
