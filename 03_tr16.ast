	["0063_00205"] = {
		{"fg", file="hinami_02m_00001", file1="hinami_02m_00101", file2="hinami_02m_00206", path=":fg/hinami_02m/", id=5, lv=5, head="hinami_02m", ch_origin="ヒナミ", ch="ヒナミ5", mw="mw", sync=0, mode=3, x=195, y=-5},
