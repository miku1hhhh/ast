	["0063_00174"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=2},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Incredible. You’re the prodigy of your time. An unparalleled child. A genius chimpanzee. You deserve a hug as a reward!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你太棒了，这是能够创造时代的才能、罕见的小婴儿、天才黑猩猩，我要奖励你！（抱紧）”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳太棒了，這是能夠創造時代的才能、罕見的小嬰兒、天才黑猩猩，我要獎勵妳！（抱緊）」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00173",
		linknext = "0063_00175",
		line = 2672,
	},
