			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“What’s the point, then? Ah, I butted in again... Inami, it’s your turn.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“这样就没有意义了吧？……啊，我又吐槽了，我要交棒给伊波酱了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「這樣就沒有意義了吧？……啊，我又吐槽了，我要交棒給伊波醬了。」",
					{"rt2"},
				},
			},
