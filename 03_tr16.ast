			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Hehe! Today, I properly rang the bell and came in through the front door.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“呵呵，我今天有好好地从玄关按电铃进来哦。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「呵呵，我今天有好好地從玄關按電鈴進來哦。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00172",
