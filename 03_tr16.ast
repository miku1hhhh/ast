	["0063_00010"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00219", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="スス子11", id=11, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0379", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“Yeah, the president is always smiling. Even we FS members don’t know what she’s thinking.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“嗯，因为会长总是面带笑容，所以就连FS的我们也都不知道她在想什么呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「嗯，因為會長總是面帶笑容，所以就連FS的我們也都不知道她在想什麼呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00009",
		linknext = "0063_00011",
		line = 151,
	},
	["0063_00011"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00219", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-205, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1147", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Sometimes we don’t understand not only what she feels, but even what she’s saying... There are too many gaps.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“别说她的想法，就连她有时候在说什么我都搞不懂呢……她的思考实在太过跳跃了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「別說她的想法，就連她有時候在說什麼我都搞不懂呢……她的思考實在太過跳躍了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00010",
		linknext = "0063_00012",
		line = 166,
	},
	["0063_00012"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00214", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=195, y=-5},
