	["0063_00026"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"You can search all around Japan, but you’ll never find such a cute raccoon outside Seiran Island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那么可爱又惹人怜爱的狸猫，就算日本之大，也只有青蓝岛才有吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那麼可愛又惹人憐愛的狸貓，就算日本之大，也只有青藍島才有吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00025",
		linknext = "0063_00027",
		line = 370,
	},
	["0063_00027"] = {
