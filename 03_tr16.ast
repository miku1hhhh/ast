					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“来吧桐香！把头躺在我的膝盖上！！我帮你挖耳朵！！你之前因为听不见而感到慌张对吧！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「來吧桐香！把頭躺在我的膝蓋上！！我幫妳挖耳朵！！妳之前因為聽不見而感到慌張對吧！？」",
					{"rt2"},
				},
			},
		},
