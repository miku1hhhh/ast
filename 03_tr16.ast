		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What the fuck do you even gather the data for?! Hmph! And you call yourselves Toukanistas! You’re a bunch of complete noobs!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你是为了什么才收集资料啊！！啧，你们这些业余桐香研究者！一堆外行！！！”",
