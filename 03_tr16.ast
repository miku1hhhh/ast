	["0063_00172"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"As I open the front door, I see Touka. She is a thousand times cuter than any raccoon.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我一打开玄关，比狸猫更可爱的桐香就站在那里。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我一打開玄關，比狸貓更可愛的桐香就站在那裡。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00171",
