			cn = {
				{
					name = {"礼"},
					"“唔，我有看过这种东西……！我记得是把猫狗的语言转换成日文的机器──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「唔，我有看過這種東西……！我記得是把貓狗的語言轉換成日文的機器──！」",
