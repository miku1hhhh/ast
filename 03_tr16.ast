					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“It’s because whatever you say about Touka, her face is really pretty! I’m so glad that you’re okay, Darling!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“小桐香真的只有长相‘好看’到让人无法置信呢……！幸好你没事，亲爱的……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「小桐香真的只有長相『好看』到讓人無法置信呢……！幸好你沒事，親愛的……！」",
					{"rt2"},
				},
			},
		},
