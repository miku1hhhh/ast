		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Thanks to this, I’ve been able to communicate with Touka smoothly. As a result, she started showing me various expressions.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“使用这个道具和桐香进行圆滑沟通的结果，她也让我看见各式各样的表情了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「使用這個道具和桐香進行圓滑溝通的結果，她也讓我看見各式各樣的表情了。」",
					{"rt2"},
				},
			},
		},
