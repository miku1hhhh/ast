		{"cgdel", id=18, time=0, alphadel=1, lv=18},
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00202", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-205, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="礼9", id=9, act="振動下", loop=1, size=12.5, time=250, ease="easeinout_sine"},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She says to me in the disciplinary committee room where I came to help. I’m at loss for words at her directness.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了帮忙FS而来到风纪委员室，却听到这句大言不惭的话，让人不知道该如何回答。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了幫忙FS而來到風紀委員室，卻聽到這句大言不慚的話，讓人不知道該如何回答。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00002",
		linknext = "0063_00004",
		line = 60,
	},
	["0063_00004"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=3},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, Rei. I wanna see them so much, I’m about to lose my mind...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“嗯，我也想看到几乎要发疯了……礼前辈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「嗯，我也想看到幾乎要發瘋了……禮前輩。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00003",
		linknext = "0063_00005",
		line = 72,
	},
	["0063_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"On second thought, it’s natural to be curious about Touka’s different expressions.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过仔细想想，我想看到桐香各式各样的表情也是理所当然的吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過仔細想想，我想看到桐香各式各樣的表情也是理所當然的吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00004",
		linknext = "0063_00006",
		line = 82,
	},
	["0063_00006"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00206", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", alpha=0, ch_origin="スス子", ch="スス子11", mw="mw", sync=1, a_chr151=1, mode=3, x=-905, y=-5},
		{"fgact", ch="スス子11", id=11, lv=11, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="スス子11", id=11, act="移動", x=300, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0378", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“But they started understanding each other at some point. So... What the hell are they talking about?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“你们似乎在我没搞懂的时候就彼此理解了……呃，所以究竟是怎么回事啊？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「你們似乎在我沒搞懂的時候就彼此理解了……呃，所以究竟是怎麼回事啊？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00005",
		linknext = "0063_00007",
		line = 97,
	},
	["0063_00007"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00202", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", alpha=0, ch_origin="郁子", ch="郁子10", mw="mw", sync=1, a_chr151=1, mode=3, x=395, y=-5},
		{"fgact", ch="郁子10", id=10, lv=10, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="郁子10", id=10, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1244", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Tokie’s always grinning. They must be talking about how she looks like when she isn’t.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“因为小桐香总是笑嘻嘻的，所以才想看看她除此之外的表情吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「因為小桐香總是笑嘻嘻的，所以才想看看她除此之外的表情吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00006",
		linknext = "0063_00008",
		line = 112,
	},
	["0063_00008"] = {
