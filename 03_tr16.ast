				},
			},
			en = {
				{
					"That’s why it’s difficult for me to talk to her for a long time.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因此，要和她长时间对话很困难。",
					{"rt2"},
				},
			},
			tw = {
				{
					"因此，要和她長時間對話很困難。",
					{"rt2"},
				},
			},
		},
