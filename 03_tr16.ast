	["0063_00016"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Touka either speaks too little or too much, so I’m often confused even when she’s talking.",
					{"rt2"},
				},
			},
			cn = {
				{
					"桐香总是处于话说得太少或是太多的两种状态之一，就算她开口说话，让人感到混乱的状况也很多。",
					{"rt2"},
				},
			},
			tw = {
				{
					"桐香總是處於話說得太少或是太多的兩種狀態之一，就算她開口說話，讓人感到混亂的狀況也很多。",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00015",
		linknext = "0063_00017",
		line = 238,
	},
	["0063_00017"] = {
