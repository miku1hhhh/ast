					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“You took a blow from Miss Touka’s kissy face from a point-blank range. You couldn’t help it... I’m glad you made it alive, Junnosuke...!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“在近距离遭到桐香大人的亲吻表情攻击，会变成这样也是无可奈何的……真亏你能活着回来呢，淳之介……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「在近距離遭到桐香大人的親吻表情攻擊，會變成這樣也是無可奈何的……真虧你能活著回來呢，淳之介……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00121",
		linknext = "0063_00123",
		line = 1862,
	},
	["0063_00123"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00102", file2="ikuko_02m_00203", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
