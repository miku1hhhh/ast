				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“别把我的道具和那种可疑的东西相提并论……好吧，虽然我不会卖你，不过可以让你见识它的效果。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「別把我的道具和那種可疑的東西相提並論……好吧，雖然我不會賣妳，不過可以讓妳見識它的效果。」",
					{"rt2"},
				},
			},
		},
