	["0063_00028"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I made it in cooperation with my little sister in order to understand what that cute creature is saying.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“她那么惹人怜爱，为了能够理解她说的话，所以我和妹妹一起制作了这个道具──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「她那麼惹人憐愛，為了能夠理解她說的話，所以我和妹妹一起製作了這個道具──」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00027",
		linknext = "0063_00029",
		line = 392,
	},
	["0063_00029"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00102", file2="susuko_02m_00205", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0380", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“You forced Asa to work on it, right...? She’s been worn out for the last few days. She was saying that she’s sick of hearing voices that make no sense.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“不对，是你逼她做的吧……？这几天麻沙酱说‘听太多意义不明的声音感觉很难受’，整个人感觉都很累呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「不對，是你逼她做的吧……？這幾天麻沙醬說『聽太多意義不明的聲音感覺很難受』，整個人感覺都很累呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0063_00028",
		linknext = "0063_00030",
		line = 407,
	},
	["0063_00030"] = {
