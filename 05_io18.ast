	["0082_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Nobody believed that the meteor was destroyed by ejaculation, resulting in various cum-spiracy theories emerging about the topic...",
					{"rt2"},
				},
			},
			cn = {
				{
					"用射精破坏了淫石的这一点基本上没人相信，关于淫石为何碎裂这点也出现了很多淫魔论──",
					{"rt2"},
				},
			},
			tw = {
				{
					"用射精破壞了淫石的這一點基本上沒人相信，關於淫石為何碎裂這點也出現了很多淫魔論──",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00001",
		linknext = "0082_00003",
		line = 51,
	},
	["0082_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But none of that matters to us now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可是那毕竟是另一回事──跟我们并没有什么关系。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可是那畢竟是另一回事──跟我們並沒有什麼關係。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00002",
		linknext = "0082_00004",
		line = 61,
	},
	["0082_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The Seiran Island we protected with our cocks would go through several more ridiculous tribulations, but as of now all things remain normal.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那一天大家殚精竭力保护周全的青蓝岛，在那之后又经历了好几次时不时就会发生的、像傻瓜一般的风波──来来去去，还是一如往常的热闹。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那一天大家殫精竭力保護周全的青藍島，在那之後又經歷了好幾次時不時就會發生的、像傻瓜一般的風波──來來去去，還是一如往常的熱鬧。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00003",
		linknext = "0082_00005",
		line = 71,
	},
	["0082_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I left the island for study, and now six years after the Hale-Fuck Fucking Incident, I’ve returned to the island to start a new life.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一度为了升学离开了岛上的我，在射爆哈梅彗星事件过了六年之后的现在，结果还是回到了青蓝岛──并且住了下来。",
					{"rt2"},
				},
			},
			tw = {
				{
					"一度為了升學離開了島上的我，在射爆哈梅彗星事件過了六年之後的現在，結果還是回到了青藍島──並且住了下來。",
					{"rt2"},
				},
			},
		},
