	["0082_00009"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hey, don’t go running so fast! You’re putting too much stress on your body!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“喂，等一下！不要那么急！小心影响到身体！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「喂，等一下！不要那麼急！小心影響到身體！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00008",
		linknext = "0082_00010",
		line = 130,
	},
	["0082_00010"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1988", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“You just won’t quit with your worrying, will you? A little run won’t do any harm. I heard it’s worse if you keep worrying about it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“啊哈哈！亲爱的还是一样爱瞎操心呢。稍微跑几步不会怎么样啦。也有人说太过在意反而有害喔──？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「啊哈哈！親愛的還是一樣愛瞎操心呢。稍微跑幾步不會怎麼樣啦。也有人說太過在意反而有害喔──？」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00009",
		linknext = "0082_00011",
		line = 142,
	},
	["0082_00011"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I understand, but what if you trip or something?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“说是那么说啦！但是万一跌倒了或什么的要怎么办！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「說是那麼說啦！但是萬一跌倒了或什麼的要怎麼辦！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00010",
		linknext = "0082_00012",
		line = 153,
	},
	["0082_00012"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1989", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Don’t worry. I know how to tuck and roll.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“就说不用担心啦。我会护身倒法啊。”",
