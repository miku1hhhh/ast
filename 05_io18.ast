	["0082_00063"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After doing a bunch of things in Kanto, she’s now completely hooked on it, and posts a little video every once in a while.",
					{"rt2"},
				},
			},
			cn = {
				{
					"后来在关东忙来忙去之间她似乎是完全享受了起来，开始定期上传视频。",
					{"rt2"},
				},
			},
			tw = {
				{
					"後來在關東忙來忙去之間她似乎是完全享受了起來，開始定期上傳影片。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00062",
		linknext = "0082_00064",
		line = 799,
	},
	["0082_00064"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was already a habit of hers to take pictures in World B, and she also liked taking pictures of us having sex.",
					{"rt2"},
				},
			},
			cn = {
				{
					"郁子在我们去B世界的时候就养成了拍照片的习惯，而且也很喜欢在和我发生性行为的时候摄影。",
					{"rt2"},
				},
			},
			tw = {
				{
					"郁子在我們去B世界的時候就養成了拍照片的習慣，而且也很喜歡在和我發生性行為的時候攝影。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00063",
		linknext = "0082_00065",
		line = 809,
	},
	["0082_00065"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She always had the talent for it, I guess.",
					{"rt2"},
				},
			},
			cn = {
				{
					"或许她原本就有那种素质之类的吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"或許她原本就有那種素質之類的吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00064",
		linknext = "0082_00066",
		line = 819,
	},
	["0082_00066"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The videos at first were really just nothing, but once she started posting her visits to haunted places, or making videos of her performing with her superhuman abilities, the videos got traction.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然一开始都是一些没什么特出之处的视频，可是随着她在视频里去灵异地点啊、发挥她超乎常人的运动能力等等，观看次数也一点一点地越来越多。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然一開始都是一些沒什麼特出之處的影片，可是隨著她在影片裡去靈異地點啊、發揮她超乎常人的運動能力等等，觀看次數也一點一點地越來越多。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00065",
		linknext = "0082_00067",
		line = 829,
	},
	["0082_00067"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Seeing results in the numbers got her even more motivated. One day she came to me asking if I had any ideas for a video.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当成果以数字的形式展现出来以后她似乎更乐在其中了，终于有一天她问我“有什么有趣的梗吗？”。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當成果以數字的形式展現出來以後她似乎更樂在其中了，終於有一天她問我「有什麼有趣的梗嗎？」。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00066",
		linknext = "0082_00068",
		line = 839,
	},
	["0082_00068"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I answered “How about you do that Lewd Samba” without thinking much of it, but the video went super viral.",
					{"rt2"},
				},
			},
			cn = {
				{
					"当时我随口提议了“不然你就试着跳个色贫贱森巴之类的怎么样？”，结果观看次数高得吓人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"當時我隨口提議了「不然妳就試著跳個色貧賤森巴之類的怎麼樣？」，結果觀看次數高得嚇人。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00067",
		linknext = "0082_00069",
		line = 849,
	},
	["0082_00069"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I didn’t realize Japan had so much potential.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我太小看日本这个国家了。",
					{"rt2"},
