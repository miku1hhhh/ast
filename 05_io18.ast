			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“...I’m so glad it was you, Junnosuke. I really am. We may not be a perfect couple, but I’m sure that we can work together to make this a happy family.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“……真的，是淳之介君实在太好了。真的太好了。就算是一对没出息的夫妇，两人一起的话肯定能组成一个好家庭吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「……真的，是淳之介君實在太好了。真的太好了。就算是一對沒出息的夫婦，兩人一起的話肯定能組成一個好家庭吧。」",
					{"rt2"},
				},
			},
		},
