				},
			},
			en = {
				{
					"The story of Cumageddon spread across the world.",
					{"rt2"},
				},
			},
			cn = {
				{
					"淫石坠落在岛上的事件，不久之后成为了世界性的话题。",
					{"rt2"},
				},
			},
			tw = {
				{
					"淫石墜落在島上的事件，不久之後成為了世界性的話題。",
					{"rt2"},
				},
			},
