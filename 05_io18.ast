				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Heh, I totally get that. Life across the pond was fun too, but Seiran Island really is the best.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“嘻……我懂。虽然住在另一边的时候也挺快乐的，但果然还是青蓝岛最棒了呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「嘻……我懂。雖然住在另一邊的時候也挺快樂的，但果然還是青藍島最棒了呢。」",
					{"rt2"},
				},
			},
		},
