		line = 879,
	},
	["0082_00072"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And there were many more events and struggles that I have absolutely no time to explain...",
					{"rt2"},
				},
			},
			cn = {
				{
					"如此这般，虽然还有很多说都说不完的波折──",
					{"rt2"},
				},
			},
			tw = {
				{
					"如此這般，雖然還有很多說都說不完的波折──",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00071",
