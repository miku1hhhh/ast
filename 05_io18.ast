	},
	["0082_00034"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But the real hype began when the two eventually conflicted over their religious differences regarding Hamedori.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然而──博得如今这种人气的契机，恐怕是原本和乐融融地一起信奉着Hamedori君的他们两个，因为Hamedori观的不同而开始对立一事吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然而──博得如今這種人氣的契機，恐怕是原本和樂融融地一起信奉著Hamedori君的他們兩個，因為Hamedori觀的不同而開始對立一事吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00033",
