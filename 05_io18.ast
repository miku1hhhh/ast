		line = 423,
	},
	["0082_00032"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"One is a blowjob cockatoo that went viral with just its blowjob noises, and the other is the great Brat Girl who charmed the internet with her ejaculation regulation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"一边是曾经只靠啾啪声就称霸天下的口交鹦鹉，另一边是曾经用射精管理迷倒众生的小屁妞大人──",
					{"rt2"},
				},
			},
			tw = {
				{
					"一邊是曾經只靠啾啪聲就稱霸天下的口交鸚鵡，另一邊是曾經用射精管理迷倒眾生的小屁妞大人──",
					{"rt2"},
