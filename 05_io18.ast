		{"evset", file="icg05_l010103", set="icg05_l01", path=":ev/icg05_l01/"},
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="icg05_l010103", x=-202.5, y=-99, path=":cg/icg05_l/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2001", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Hamedori’s nice too, but let’s get on some rides too. Like the Ferris wheel, the merry-go-round...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“虽然Hamedori君也挺好的，但是难得都来到游乐园了，要不要去搭个什么？摩天轮啊、或是旋转木马啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「雖然Hamedori君也挺好的，但是難得都來到遊樂園了，要不要去搭個什麼？摩天輪啊、或是旋轉木馬啊……」",
