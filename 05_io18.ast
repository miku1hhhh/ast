	["0082_00070"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"After Ikuko went viral, Misaki got competitive for some reason and posted a bunch of videos, and long story short she became popular as the SlurpTube drama queen.",
					{"rt2"},
				},
			},
			cn = {
				{
					"郁子一红，这次换美岬燃烧起了对抗心，开始拼命上传视频，详细的我就不说了，总之她也在转眼之间以炎上系Chyoutuber的身份远近驰名。",
					{"rt2"},
				},
			},
			tw = {
				{
					"郁子一紅，這次換美岬燃燒起了對抗心，開始拼命上傳影片，詳細的我就不說了，總之她也在轉眼之間以炎上系Chyoutuber的身分遠近馳名。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00069",
		linknext = "0082_00071",
		line = 869,
	},
	["0082_00071"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She already had a history of being called the Shitgirl on the net. Her explosiveness has always been there.",
					{"rt2"},
				},
			},
			cn = {
				{
					"原本她就在一部分网民之间以大便女酱的身份受到众人喜爱。一开始的时候爆发力就非常惊人了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"原本她就在一部分網民之間以大便女醬的身分受到眾人喜愛。一開始的時候爆發力就非常驚人了。",
					{"rt2"},
				},
			},
		},
