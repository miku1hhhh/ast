	},
	["0082_00127"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“If they do, you can teach them how to take care of it.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就算遗传到了，也有你能教导整理的方法不是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就算遺傳到了，也有妳能教導整理的方法不是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00126",
		linknext = "0082_00128",
		line = 1619,
	},
	["0082_00128"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even after being vulnerable and telling everything about each other, Ikuko still didn’t want to show me her hair not done up.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我们不论是什么事情都会正面跟彼此商量，但是只有没有整理好的头发，郁子还是不喜欢被我看到。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我們不論是什麼事情都會正面跟彼此商量，但是只有沒有整理好的頭髮，郁子還是不喜歡被我看到。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00127",
		linknext = "0082_00129",
		line = 1629,
	},
	["0082_00129"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I saw it one day while she was bathing by chance, and what I saw was apparently still fairly done up.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那一天偶然看见的只是正好在盥洗的模样，好像已经算是相当整齐的了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那一天偶然看見的只是正好在盥洗的模樣，好像已經算是相當整齊的了。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00128",
		linknext = "0082_00130",
		line = 1639,
	},
	["0082_00130"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The day after we were married, I witnessed Ikuko happily sleeping with hair that looked like a bird’s nest. Oh man, that was the biggest crisis of our marriage.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在登记的隔一天，目击到飘飘然过了头的郁子顶着一个像鸟巢一样的发型一脸幸福地爆睡的模样的时候──那可是眼看着就要离婚了的危机。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在登記的隔一天，目擊到飄飄然過了頭的郁子頂著一個像鳥巢一樣的髮型一臉幸福地爆睡的模樣的時候──那可是眼看著就要離婚了的危機。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00129",
		linknext = "0082_00131",
		line = 1649,
	},
	["0082_00131"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="icg05010202", x=-5, y=-2, path=":cg/icg05/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=500},
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We indulge in fond memories, but the cloud over Ikuko’s face is still intact.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我不小心沉浸在了回忆里，然而郁子的表情上的阴霾还没有消失。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我不小心沉浸在了回憶裡，然而郁子的表情上的陰霾還沒有消失。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00130",
		linknext = "0082_00132",
		line = 1663,
	},
	["0082_00132"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2020", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“...Will I be a good mother?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“……我能当个好妈妈吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「……我能當個好媽媽嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00131",
		linknext = "0082_00133",
		line = 1675,
	},
	["0082_00133"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her old memories will never fade, no matter how long time passes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不论过了多久，想必过去的记忆都是不会消失的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不論過了多久，想必過去的記憶都是不會消失的。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00132",
		linknext = "0082_00134",
		line = 1685,
	},
	["0082_00134"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She’s strong in front of other people, but when she’s just with me she would sometimes show her weak side like this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在人前总是表现得很坚强的郁子，在和我两人独处的时候，有时就会像这样展现出软弱的一面。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在人前總是表現得很堅強的郁子，在和我兩人獨處的時候，有時就會像這樣展現出軟弱的一面。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00133",
		linknext = "0082_00135",
		line = 1695,
	},
	["0082_00135"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I think you’ll be a great mother.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我……倒是觉得如果是郁子，一定能成为一个好妈妈喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我……倒是覺得如果是郁子，一定能成為一個好媽媽喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00134",
		linknext = "0082_00136",
		line = 1706,
	},
	["0082_00136"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But you know what? You don’t have to try so hard to be a good mom. You’re Ikuko above everything else, even a mother.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“可是啊。不用勉强自己成为一个好妈妈也无所谓。因为郁子在身为母亲之前，是郁子自己啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「可是啊。不用勉強自己成為一個好媽媽也無所謂。因為郁子在身為母親之前，是郁子自己啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00135",
		linknext = "0082_00137",
		line = 1717,
	},
