	["0082_00013"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That won’t relieve all the impact. Even the slightest bumps can accumulate overtime and have bad effects...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就算护身了也无法把冲击全部分散掉啊！要是小小的护身倒逐渐累积起来造成了什么不好的影响……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就算護身了也無法把衝擊全部分散掉啊！要是小小的護身倒逐漸累積起來造成了什麼不好的影響……」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00012",
		linknext = "0082_00014",
		line = 176,
	},
	["0082_00014"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1990", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I hardly ever trip, let alone enough to have any ‘accumulating effects.’ Look, the Hame-dream Parade is about to start!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“累积什么的，我又不会每天跌倒……啊，你看！已经要开始了喔，Hamedori梦幻游行！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「累積什麼的，我又不會每天跌倒……啊，你看！已經要開始了喔，Hamedori夢幻遊行！」",
					{"rt2"},
				},
			},
		},
