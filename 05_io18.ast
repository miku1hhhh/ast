				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“...But it’s been a while since we had an actual date with just the two of us like this.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“可是……感觉已经好久没有过了呢。只有我们两个人、好好地约会。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「可是……感覺已經好久沒有過了呢。只有我們兩個人、好好地約會。」",
					{"rt2"},
				},
			},
		},
