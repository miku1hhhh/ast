					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I hope they don’t get my hair...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“要是不要遗传到我的发质就好了……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「要是不要遺傳到我的髮質就好了……」",
