	["0082_00046"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She was referring to her life after graduating Minotsuki Academy.",
					{"rt2"},
				},
			},
			cn = {
				{
					"“住在另一边”指的大概是我们从水乃月学园毕业以后的事情吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"「住在另一邊」指的大概是我們從水乃月學園畢業以後的事情吧。",
					{"rt2"},
				},
			},
		},
