	["0082_00029"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"At the end of the Hale-Fuck Fucking Incident, Rin, the younger Hanamaru, and Blowbo collided with the giant Hamedori artwork.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在射爆哈梅彗星事件的终盘，撞上了巨大Hamedori君的雕像的花丸妹──凛，和啾啪酱。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在射爆哈梅彗星事件的終盤，撞上了巨大Hamedori君的雕像的花丸妹──凜，和啾啪醬。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00028",
		linknext = "0082_00030",
		line = 403,
	},
	["0082_00030"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Either the hit knocked a few screws loose, or there were no screws in the first place, but from then on, the two began worshipping Hamedori as a god for some reason.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不知道究竟是撞到了要害还是原本脑袋就有问题，她和它在那之后开始把Hamedori君当成神明崇拜。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不知道究竟是撞到了要害還是原本腦袋就有問題，她和牠在那之後開始把Hamedori君當成神明崇拜。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00029",
		linknext = "0082_00031",
		line = 413,
	},
	["0082_00031"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"They went as far as preaching to the internet that Hamedori is the lord and savior.",
					{"rt2"},
				},
			},
			cn = {
				{
					"然后他们还特地在网络上开始到处宣扬Hamedori君正是救世的神明。",
					{"rt2"},
				},
			},
			tw = {
				{
					"然後他們還特地在網路上開始到處宣揚Hamedori君正是救世的神明。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00030",
