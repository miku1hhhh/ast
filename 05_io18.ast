	["0082_00092"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="icg05_l010105", x=-202.5, y=-99, path=":cg/icg05_l/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2004", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“See? You miss it because you keep thinking about unimportant things. When you get caught up in your immediate worries, you miss the more important things in life. That’s your lesson for today.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“看吧──，就是因为你一直在想一些多余的事情，所以才会错过的啊？要是总是拘泥于眼前的操心事，就会看漏更重要的事物。这就是今天的教训喔？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「看吧──，就是因為你一直在想一些多餘的事情，所以才會錯過的啊？要是總是拘泥於眼前的操心事，就會看漏更重要的事物。這就是今天的教訓喔？」",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00091",
		linknext = "0082_00093",
		line = 1144,
	},
	["0082_00093"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Can’t talk back to that one.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我无法反驳。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我無法反駁。",
					{"rt2"},
				},
			},
		},
		linkback = "0082_00092",
		linknext = "0082_00094",
		line = 1154,
	},
	["0082_00094"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’ve begun to realize recently that I have a habit of getting caught up in immediate problems so that I miss out on more important things.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这也是最近才注意到的，我似乎有被眼前的小事耽搁、结果反而错过关键的倾向。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這也是最近才注意到的，我似乎有被眼前的小事耽擱、結果反而錯過關鍵的傾向。",
					{"rt2"},
				},
			},
		},
