	["0082_00048"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It was a tough school to get into, but I studied hard so that I could stay with Ikuko, and I was able to pass the entrance exam.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然对我来说是一大难关，但是因为我满心想着要尽可能跟郁子在一起，所以总算是考上了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然對我來說是一大難關，但是因為我滿心想著要盡可能跟郁子在一起，所以總算是考上了。",
					{"rt2"},
				},
			},
		},
