	},
	["0082_00073"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"At the end of it all, we returned to Seiran Island after graduation to start a business.",
					{"rt2"},
				},
			},
			cn = {
				{
					"最后，我们在毕业之后决定回到青蓝岛开设公司。",
					{"rt2"},
				},
			},
			tw = {
				{
					"最後，我們在畢業之後決定回到青藍島開設公司。",
