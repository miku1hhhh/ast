		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We both went to the same university after graduation.",
					{"rt2"},
				},
			},
			cn = {
				{
					"毕业之后──我和郁子往同一所学校升了学。",
					{"rt2"},
				},
			},
			tw = {
				{
					"畢業之後──我和郁子往同一所學校升了學。",
					{"rt2"},
				},
			},
