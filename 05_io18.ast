	},
	["0082_00033"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Having these two claim that Hamedori is a god was enough to get people’s attention.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这对组合突然开始宣称“Hamedori君乃是神明”，当然是十足夺人眼球。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這對組合突然開始宣稱「Hamedori君乃是神明」，當然是十足奪人眼球。",
					{"rt2"},
				},
			},
