	},
	["0011_00212"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She was a freshman when she created the FS, thought of a war strategy, and no matter how strong the enemy was she’d always dismantle them with her Luohanqian.",
					{"rt2"},
				},
			},
			cn = {
				{
					"以一年级的身份管理着FS、指挥作战，无论什么样的强敌都能用罗汉钱压制。",
					{"rt2"},
				},
			},
			tw = {
				{
					"以一年級的身份管理著FS、指揮作戰，無論什麼樣的強敵都能用羅漢錢壓制。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00211",
		linknext = "0011_00213",
		line = 2811,
	},
	["0011_00213"] = {
