		{"fgact", ch="郁子10", id=10, act="移動", x=-200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0277", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Hello, Darling. You look tired. Was there a lot of stuff to do at work?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“哟呵，亲爱的。你看起来很累呢。有那么忙吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「喲呵，親愛的。你看起來很累呢。有那麼忙嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00231",
		linknext = "0011_00233",
		line = 3091,
	},
	["0011_00233"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00220", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Yeah, there sure was... But I didn’t have anything to do and ended up just staring like useless trash. It felt awful.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊没有，虽然是很忙……但我没有任何工作可以做，看到自己这么没用我很沮丧……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊沒有，雖然是很忙……但我沒有任何工作可以做，看到自己這麼沒用我很沮喪……」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00232",
		linknext = "0011_00234",
		line = 3103,
	},
	["0011_00234"] = {
