			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“To be exact, you’ll be her assistant. Your task is to attend to her during busy periods, and also in daily life.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不仅如此，还有桐香大人随从。包括繁忙季节的日常生活也要请你照顾。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「不僅如此，還有桐香大人隨從。包括繁忙季節的日常生活也要請你照顧。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00001",
		linknext = "0011_00003",
		line = 38,
	},
	["0011_00003"] = {
