					name = {"礼"},
					"“啊，我忘了跟你说，电话只要桐香大人一动手指就会飞过去，所以就算响了你也坐着就好了，不然很危险喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「啊，我忘了跟你說，電話只要桐香大人一動手指就會飛過去，所以就算響了你也坐著就好了，不然很危險喔。」",
					{"rt2"},
				},
			},
		},
