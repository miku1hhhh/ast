	["0011_00054"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Originally, it’s the organization that should manage information about the event and make decisions.",
					{"rt2"},
				},
			},
			cn = {
				{
					"通常来说，一个组织应该是先汇整活动相关的情报资料、再由组织各部门来执行与运作。",
					{"rt2"},
				},
			},
			tw = {
				{
					"通常來說，一個組織應該是先彙整活動相關的情報資料、再由組織各部門來執行與運作。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00053",
		linknext = "0011_00055",
		line = 721,
	},
	["0011_00055"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"However, it’s just simpler, faster, and more effective if people who have a grasp of the situation make the decisions top-down.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，若是让一个对上下的决策过程无所不知的人来做，那就是非常简单快速、轻巧的步法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，若是讓一個對上下的決策過程無所不知的人來做，那就是非常簡單快速、輕巧的步法。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00054",
		linknext = "0011_00056",
		line = 731,
	},
