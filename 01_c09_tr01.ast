		{"fgact", ch="礼9", id=9, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0257", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Your eyes look like they’re about to pop out. What’s so surprising about that?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“这种事有意外到需要把眼睛瞪到那么大吗⋯⋯？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「這種事有意外到需要把眼睛瞪到那麼大嗎⋯⋯？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00204",
		linknext = "0011_00206",
		line = 2728,
	},
	["0011_00206"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00208", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It’s just impossible for Touka Reizeiin to yield to mere pollen! She’s a student council president!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那个冷泉院桐香居然会屈服于花粉之下，这不可能吧──！她是学生会长耶！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「那個冷泉院桐香居然會屈服於花粉之下，這不可能吧──！她是學生會長耶！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00205",
		linknext = "0011_00207",
		line = 2740,
	},
	["0011_00207"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00102", file2="rei_02m_00210", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-505, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0258", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Even a president might suffer from allergies... What percent of the Japanese population do you think has a pollen allergy?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“居然连会长都会得屈服……到底是有多少日本人有花粉症……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「居然連會長都會得屈服……到底是有多少日本人有花粉症……」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00206",
		linknext = "0011_00208",
		line = 2755,
	},
	["0011_00208"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“This girl gave me a real hard time during the fight! And now you’re saying that this brave princess is now dripping wet and red because of POLLEN?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“和我上演一场激战的家伙，居然会被区区花草交配程度的攻击搞到鼻子黏糊糊、脸色通红，像公主骑士一样屈服────！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「和我上演一場激戰的傢伙，居然會被區區花草交配程度的攻擊搞到鼻子黏糊糊、臉色通紅，像公主騎士一樣屈服────！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00207",
		linknext = "0011_00209",
		line = 2766,
	},
	["0011_00209"] = {
