	["0011_00006"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00204", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0246", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“It would be too mean if I just dumped everything onto you on your first day, so I’ll accompany you this time. Try to remember everything. Can you do that, Junnosuke?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“第一天就把所有的事情都交给你太难了，所以今天我陪你一整天。虽然很辛苦不过要全部都记住──你可以吗，淳之介？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「第一天就把所有的事情都交給你太難了，所以今天我陪你一整天。雖然很辛苦不過要全部都記住──你可以嗎，淳之介？」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00005",
		linknext = "0011_00007",
		line = 83,
	},
	["0011_00007"] = {
