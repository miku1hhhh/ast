	["0011_00152"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file2="tohka_02m_00227", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="桐香8", id=8, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka0202", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“The point is to imagine yourself as a camera and press the shutter button. Then, you only need to decide which folder you want to save your files in.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“诀窍就是假装自己是相机然后按下快门，接着决定想要保存在哪个文件夹里面，这样而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「訣竅就是假裝自己是相機然後按下快門，接著決定想要保存在哪個文件夾裡面，這樣而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00151",
		linknext = "0011_00153",
		line = 2054,
	},
	["0011_00153"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00102", file2="jun_01f_00207", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=8},
