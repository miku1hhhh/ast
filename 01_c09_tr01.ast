					{"rt2"},
				},
			},
			en = {
				{
					"What’s more, she turns out to be able to cut a person into shreds with her thread.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且，她还有个可以靠特殊的丝线切割人类的大招。",
					{"rt2"},
				},
			},
			tw = {
				{
					"而且，她還有個可以靠特殊的絲線切割人類的大招。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00212",
