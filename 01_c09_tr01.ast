				},
			},
			cn = {
				{
					name = {"桐香"},
					"“好的、我了解了⋯⋯那么预算的运作方式就改一下吧，另外设立一个特别预算，中队长以下可以自由来决算使用──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「好的、我了解了⋯⋯那麼預算的運作方式就改一下吧，另外設立一個特別預算，中隊長以下可以自由來決算使用──」",
					{"rt2"},
				},
			},
		},
