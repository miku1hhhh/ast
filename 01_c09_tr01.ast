					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「會長好！關於那天的SHK直播，五隊的通訊隊會負責轉播──橘同學，你坐在那兒幹什麼？你是在地板上自慰嗎？」",
					{"rt2"},
				},
			},
		},
