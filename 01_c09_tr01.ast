	["0011_00154"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But I have heard that people who are capable of speed-reading take a kind of picture of the pages spread in front of them, and then save those pictures in their memory.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这么说来，我是有听说擅长速读的人都可以像扫描图片一样保存记忆。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這麼說來，我是有聽說擅長速讀的人都可以像掃描圖片一樣保存記憶。",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00153",
