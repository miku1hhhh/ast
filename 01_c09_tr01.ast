			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“There are just busier times during the day. Except for the time right after conferences and meetings, not so many people come here.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“忙也是有时间性的。除非是在在讨论完或会议之后，不然一般来说不会那么频繁地有人来。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「忙也是有時間性的。除非是在在討論完或會議之後，不然一般來說不會那麼頻繁地有人來。」",
					{"rt2"},
				},
			},
		},
