	["0011_00216"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00219", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=-505, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="礼9", id=9, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0260", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Miss Touka has severe hay fever. She’s allergic to dust too. Still, she doesn’t want to take her medicine. She spits it out even if I mix it with food. I have to throw it straight into her throat.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“桐香大人几乎所对所有的花粉都过敏。灰尘也会。要让她好好吃药可是很麻烦的。就算混在食物里面她也会吐出来，最后只能塞进她的嘴里让她硬吞下去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「桐香大人幾乎所對所有的花粉都過敏。灰塵也會。要讓她好好吃藥可是很麻煩的。就算混在食物裡面她也會吐出來，最後只能塞進她的嘴裡讓她硬吞下去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0011_00215",
		linknext = "0011_00217",
		line = 2857,
	},
	["0011_00217"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00214", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
