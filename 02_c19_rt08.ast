				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Oh, sorry. I’m not blaming you or anything. Even if we were able to outsmart them, I know that what we were doing went against the FS code.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“啊啊、抱歉。我没有怪你的意思。虽然我们被阴了……但我们确实做了一些背叛了FS信任的事情。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「啊啊、抱歉。我沒有怪你的意思。雖然我們被陰了……但我們確實做了一些背叛了FS信任的事情。」",
