		line = 538,
	},
	["0040_00045"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei was the president of the disciplinary committee and an FS instructor, so I can imagine this is tough for her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"身为风纪委员长兼FS指导教官的礼前辈才更如她自己说的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"身為風紀委員長兼FS指導教官的禮前輩才更如她自己說的。",
					{"rt2"},
				},
			},
		},
		linkback = "0040_00044",
		linknext = "0040_00046",
		line = 548,
	},
