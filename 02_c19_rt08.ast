				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’ve met so many people on this island who mean the world to me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我在这座岛上，遇上了多少重要的人──",
