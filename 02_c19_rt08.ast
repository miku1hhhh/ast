				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s a little risky walking around in the open; someone could easily see me. I do feel like I’m being watched, even out in the mountains...",
					{"rt2"},
				},
			},
			cn = {
				{
					"就这样漫不经心地四处游荡，有被人发现的危险，事实上，我也察觉到山中会有追捕者，但是──",
					{"rt2"},
				},
			},
			tw = {
				{
					"就這樣漫不經心地四處遊蕩，有被人發現的危險，事實上，我也察覺到山中會有追捕者，但是──",
					{"rt2"},
				},
			},
		},
