			},
			en = {
				{
					"If I truly believed what I just said, I wouldn’t even try to pull an unsure smile like this one.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是──若她真的这么相信自己所说的，就不会露出那么不安的笑脸了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是──若她真的這麼相信自己所說的，就不會露出那麼不安的笑臉了。",
					{"rt2"},
				},
			},
		},
