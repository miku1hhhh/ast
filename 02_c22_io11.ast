	["0050_00165"] = {
		{"fg", file="ikuko_01ll_00001", file1="ikuko_01ll_00101", file2="ikuko_01ll_00229", path=":fg/ikuko_01ll/", id=10, lv=10, head="ikuko_01ll", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=0, y=0},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1136", path=":vo/", ch="ikuko"},
