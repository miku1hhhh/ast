			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I’ve been writing about what happened back on our own world and everything that’s happened in this one. Whatever comes to mind.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
