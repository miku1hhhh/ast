				{"vo", file="ikuko1135", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I love you, Junnosuke.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“⋯⋯我啊，我喜欢淳之介君你喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「⋯⋯我啊，我喜歡淳之介君你喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00153",
		linknext = "0050_00155",
		line = 2009,
	},
	["0050_00155"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No jokes or innuendos. Ikuko speaks from the heart.",
					{"rt2"},
				},
			},
			cn = {
				{
					"并非玩笑或随口说说──这是郁子的真心话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"並非玩笑或隨口說說──這是郁子的真心話。",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00154",
		linknext = "0050_00156",
		line = 2019,
	},
	["0050_00156"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She never seemed to care about love before, but seems to have nurtured the idea during her time with me nonetheless.",
					{"rt2"},
				},
			},
			cn = {
				{
					"缺乏恋爱观的郁子，在与我相处的日子里一点一点成长成了如今的模样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"缺乏戀愛觀的郁子，在與我相處的日子裡一點一點成長成了如今的模樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00155",
		linknext = "0050_00157",
		line = 2029,
	},
	["0050_00157"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"In this moment, I finally realize something myself.",
					{"rt2"},
				},
			},
			cn = {
				{
					"到现在，我才总算察觉到这件事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"到現在，我才總算察覺到這件事。",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00156",
		linknext = "0050_00158",
		line = 2039,
	},
	["0050_00158"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I crossed worlds, made enemies of my closest friends and even turned my own sister’s murderous intent against myself, but I made it this far in spite of that.",
					{"rt2"},
				},
			},
			cn = {
				{
					"超越了世界，与重视的伙伴们为敌、被自己唯一的妹妹投杀意──尽管如此我还是一路熬过来了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"超越了世界，與重視的夥伴們為敵、被自己唯一的妹妹投殺意──儘管如此我還是一路熬過來了。",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00157",
		linknext = "0050_00159",
		line = 2049,
	},
	["0050_00159"] = {
