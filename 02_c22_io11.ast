				{"fg", file="ikuko_02l_00006", file1="ikuko_02l_00103", file2="ikuko_02l_00205", path=":fg/ikuko_02l/", id=10, lv=10, head="ikuko_02l", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, timestamp=9, delay2=5500, mode=3, x=-5, y=-5},
			},
			[5499] = {
				{"transitiontime", time=300, timestamp=9, delay2=5500},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko1132", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I know I said before that I wouldn’t mind if you were part of a harem so long as it made you happy, but if we got back to Asa and the others... I know it’d make me kind of lonely.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“麻纱音酱跟大家都回来了⋯⋯淳之介君很高兴的样子⋯⋯虽然我之前说过你干脆建后宫就好了⋯⋯但不知道为什么，实际看到之后让我觉得很寂寞。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「麻紗音醬跟大家都回來了⋯⋯淳之介君很高興的樣子⋯⋯雖然我之前說過你幹脆建後宮就好了⋯⋯但不知道為什麼，實際看到之後讓我覺得很寂寞。」",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00147",
		linknext = "0050_00149",
		line = 1931,
	},
