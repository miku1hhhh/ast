		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file2="ikuko_02m_00204", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1105", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Don’t think about it like you’re falling. Think about it like you’re running through the sky. Like you’re sprinting down a 90-degree slope.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“想着自己掉下去可不行。要想着自己是在空中跑才行。打个比方的话，就像是在90的斜坡上全力奔跑那种感觉。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「想著自己掉下去可不行。要想著自己是在空中跑才行。打個比方的話，就像是在90的斜坡上全力奔跑那種感覺。」",
					{"rt2"},
				},
			},
		},
		linknext = "0050_00002",
		line = 24,
	},
	["0050_00002"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Ikuko gives me the run-down, glancing down at her tablet.",
					{"rt2"},
				},
			},
			cn = {
				{
					"郁子看着平板道。",
					{"rt2"},
				},
			},
			tw = {
				{
					"郁子看著平板道。",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00001",
		linknext = "0050_00003",
		line = 34,
	},
	["0050_00003"] = {
		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file3="ikuko_02m_00312", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[8000] = {
				{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file2="ikuko_02m_00204", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, timestamp=1, delay2=8000, mode=3, x=-5, y=-5},
			},
			[7999] = {
				{"transitiontime", time=300, timestamp=1, delay2=8000},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko1106", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“It’s impossible to support yourself with just your legs. Legs, shins, buttocks, back, shoulders—the impact will be distributed throughout the body. That’s the theory behind a five-point landing.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“光靠脚是绝对不可能支撑着全部的体重的。脚、小腿、臀部、背部、肩膀──得把冲击力分散到全身，然后释放到外面。这就是五点着地理论。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「光靠腳是絕對不可能支撐著全部的體重的。腳、小腿、臀部、背部、肩膀──得把衝擊力分散到全身，然後釋放到外面。這就是五點著地理論。」",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00002",
		linknext = "0050_00004",
		line = 52,
	},
	["0050_00004"] = {
		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file2="ikuko_02m_00214", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1107", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“But there’s obviously a limit. You’re trying to do something beyond what a standard five-point landing can support...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“当然这也是有限度的。你要做到的可不光只是能五点着地而已。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「當然這也是有限度的。你要做到的可不光只是能五點著地而已。」",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00003",
		linknext = "0050_00005",
		line = 67,
	},
