		line = 991,
	},
	["0050_00071"] = {
		{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file3="ikuko_01m_00313", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1118", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I may not have been born with a penis, but that doesn’t mean I don’t understand. I get that feeling of being denied the right to realize your true self.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“虽然说我不可能有小鸡鸡⋯⋯但我也不是不能理解。不能做真正的自己的那种心情⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「雖然說我不可能有小雞雞⋯⋯但我也不是不能理解。不能做真正的自己的那種心情⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00070",
		linknext = "0050_00072",
		line = 1006,
	},
	["0050_00072"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00206", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Ikuko...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“郁子……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「郁子……」",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00071",
		linknext = "0050_00073",
		line = 1018,
	},
	["0050_00073"] = {
		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file3="ikuko_02m_00312", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1119", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“But I also can’t sympathize at all. To destroy everything because you can’t get your own way is so selfish and childish.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“唉，我可没有在同情他喔？因为自己不配认同所以干脆就把一切都毁掉，这种事只有任性的小孩子才会做嘛！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「唉，我可沒有在同情他喔？因為自己不配認同所以乾脆就把一切都毀掉，這種事只有任性的小孩子才會做嘛！」",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00072",
		linknext = "0050_00074",
		line = 1033,
	},
	["0050_00074"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"No argument there.",
					{"rt2"},
				},
			},
			cn = {
				{
					"郁子说的一点也没错。",
					{"rt2"},
				},
			},
			tw = {
				{
					"郁子說的一點也沒錯。",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00073",
		linknext = "0050_00075",
		line = 1043,
	},
	["0050_00075"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"To have gained so much power and only wish for chaos and destruction is no different from a child throwing a tantrum.",
					{"rt2"},
				},
			},
			cn = {
				{
					"身怀着那种力量，却连个目标都没有只想着破坏跟让一切变得混乱──根本是发脾气的孩子才会做的事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"身懷著那種力量，卻連個目標都沒有只想著破壞跟讓一切變得混亂──根本是發脾氣的孩子才會做的事。",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00074",
		linknext = "0050_00076",
		line = 1053,
	},
	["0050_00076"] = {
		{"fg", file="ikuko_02m_00006", file1="ikuko_02m_00101", file3="ikuko_02m_00313", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1120", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“It really is so immature. Maybe it’s her sudden grasp of power that’s caused her to be like this after spending so long being repressed and misunderstood.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“⋯⋯也许他真的是个小孩子也说不定。被人欺压、在无人了解他的状况下长大、然后突然就获得了力量⋯⋯才会让他变成了这个模样也说不定。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「⋯⋯也許他真的是個小孩子也說不定。被人欺壓、在無人了解他的狀況下長大、然後突然就獲得了力量⋯⋯才會讓他變成了這個模樣也說不定。」",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00075",
		linknext = "0050_00077",
		line = 1068,
	},
	["0050_00077"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I think she’s on the money.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这是个假设。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這是個假設。",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00076",
		linknext = "0050_00078",
		line = 1078,
	},
	["0050_00078"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It may sound cliche to say this, but it isn’t only the big events that send us down the wrong path.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这么说或许会被当做成腔滥调──不过人啊，不会只被特定的事件给折腾。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這麼說或許會被當做成腔濫調──不過人啊，不會只被特定的事件給折騰。",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00077",
		linknext = "0050_00079",
		line = 1088,
	},
	["0050_00079"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When the bad days keep coming and won’t stop, it can seriously eat away at the soul.",
					{"rt2"},
				},
			},
			cn = {
				{
					"有些非常常见的事──正是因为很常见，反而会被默默侵蚀。",
					{"rt2"},
				},
			},
			tw = {
				{
					"有些非常常見的事──正是因為很常見，反而會被默默侵蝕。",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00078",
		linknext = "0050_00080",
		line = 1098,
	},
	["0050_00080"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"For those in the minority living outside of what the majority consider to be common sense, that common sense is like an invisible poison.",
					{"rt2"},
				},
			},
			cn = {
				{
					"对那些身在大多数人来说是常识圈子外的少数族群来说，常识本身的存在就是一种无形的毒。",
					{"rt2"},
				},
			},
			tw = {
				{
					"對那些身在大多數人來說是常識圈子外的少數族群來說，常識本身的存在就是一種無形的毒。",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00079",
		linknext = "0050_00081",
		line = 1108,
	},
	["0050_00081"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Is that what Akino is so desperate to destroy? Those values and common sense that held her back this whole time?",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以秋野才会无比痛恨那些“常识”与“价值观”，进而想要摧毁他们──应该是这样的吧？",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以秋野才會無比痛恨那些「常識」與「價值觀」，進而想要摧毀他們──應該是這樣的吧？",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00080",
		linknext = "0050_00082",
		line = 1118,
	},
	["0050_00082"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But for her to resort to crushing what she can’t stomach through force... She’s become no different than those who made her suffer in the first place. That can’t be what she would have wanted.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过──只是因为自己不喜欢就靠着强大的力量来排除对方的这种结果，应该是秋野嘴讨厌的做法才对。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過──只是因為自己不喜歡就靠著強大的力量來排除對方的這種結果，應該是秋野嘴討厭的做法才對。",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00081",
		linknext = "0050_00083",
		line = 1128,
	},
	["0050_00083"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"She has to see the vicious cycle this is going to turn into.",
					{"rt2"},
				},
			},
			cn = {
				{
					"他现在却在做着曾经最讨厌的行为，究竟是──",
					{"rt2"},
				},
			},
			tw = {
				{
					"他現在卻在做著曾經最討厭的行為，究竟是──",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00082",
		linknext = "0050_00084",
		line = 1138,
	},
