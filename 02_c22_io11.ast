			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“But I can’t be sure. I don’t know if these feelings are actually my own right now.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“⋯⋯我分不清楚。现在这种喜欢淳之介君你的这个心情，是不是真正来自我自己。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「⋯⋯我分不清楚。現在這種喜歡淳之介君你的這個心情，是不是真正來自我自己。」",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00164",
