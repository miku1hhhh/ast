			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“I always thought you were more important to me as a battle companion in the beginning but now... I dunno, I feel jealous?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“我觉得，对淳之介来说，果然还是最开始就跟着你一起战斗的伙伴们比较重要吧⋯⋯之类的。我这会这么想，是因为嫉妒吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「我覺得，對淳之介來說，果然還是最開始就跟著你一起戰鬥的夥伴們比較重要吧⋯⋯之類的。我這會這麼想，是因為嫉妒嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0050_00148",
		linknext = "0050_00150",
		line = 1949,
	},
	["0050_00150"] = {
