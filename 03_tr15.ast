		linknext = "0062_00145",
		line = 2185,
	},
	["0062_00145"] = {
		{"fg", file="ikuko_02l_00002", file1="ikuko_02l_00101", file2="ikuko_02l_00202", path=":fg/ikuko_02l/", id=22, lv=22, head="ikuko_02l", ch_origin="郁子", ch="郁子22", mw="mw", sync=0, mode=3, x=395, y=-5},
