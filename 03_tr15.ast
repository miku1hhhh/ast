				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Okaaay, my little children. Let’s read a picture book together♪ Today’s book is ‘A Little Red Swollen Cock.’ Get in pairs and read it to each other♪”",
					{"rt2"},
				},
			},
			cn = {
