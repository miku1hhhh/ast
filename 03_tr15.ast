	["0062_00136"] = {
		{"fg", file="asane_01m_00002", file1="asane_01m_00101", file2="asane_01m_00203", path=":fg/asane_01m/", id=3, lv=3, head="asane_01m", alpha=0, ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=1, a_chr151=1, mode=3, x=-805, y=-5},
		{"fgact", ch="麻沙音3", id=3, lv=3, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="麻沙音3", id=3, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0226", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Totally. It’s absolutely ridiculous. To become an announcer, you need higher education. Also, to be someone like Pussy Galore doesn’t mean being a whore!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“真的是太蠢了女主播是高学历女人的工作吧她这种智商没问题吗顺带一提假清纯系不在麻沙酱的守备范围内就算是女生的小穴也和女主播有点不同。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「真的是太蠢了女主播是高學歷女人的工作吧她這種智商沒問題嗎順帶一提假清純系不在麻沙醬的守備範圍內就算是女生的小穴也和女主播有點不同。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00135",
		linknext = "0062_00137",
		line = 2047,
	},
	["0062_00137"] = {
