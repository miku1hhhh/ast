		text = {
			vo = {
				{"vo", file="rei1144", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Wow! As expected, Miss Touka has great pronunciation and she looks great on the screen! She has a strong presence. You would never tell she’s a newbie!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“喔喔……！真不愧是桐香大人，不但咬字没有问题，而且画面还很好看……！既有存在感又有气势，完全不像是新人呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「喔喔……！真不愧是桐香大人，不但咬字沒有問題，而且畫面還很好看……！既有存在感又有氣勢，完全不像是新人呢！」",
					{"rt2"},
				},
			},
		},
