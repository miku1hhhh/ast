			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Well... They’re children. They cry without a reason.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“那个……你听好了，所谓的小孩啊，就是会毫无意义哭泣的生物哦。”",
