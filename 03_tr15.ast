					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“No worries. I have you, so I’m only interested in working, Tachibana.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“不过我已经有你了，所以只是单纯对这份工作有兴趣哦，前辈。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「不過我已經有你了，所以只是單純對這份工作有興趣哦，前輩。」",
					{"rt2"},
