					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Hm, well, I want to go to a national college... But one time an HR person from the SHO approached me and told me that they want me to work for the SHO, so I’m not sure if I’ll go there...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“嗯、是啊，毕竟我的目标是国立大学……不过SHO的人事负责人来找我说‘请你务必要加入SHO’，所以我还不知道到底要不要过去……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「嗯、是啊，畢竟我的目標是國立大學……不過SHO的人事負責人來找我說『請妳務必要加入SHO』，所以我還不知道到底要不要過去……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00029",
		linknext = "0062_00031",
		line = 450,
	},
