		{"fgact", ch="桐香8", id=8, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1192", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Good afternoon. This is Touka Reizeiin, giving Tachibana what he wants. You’re watching the SBS, the Seiran Broadcasting Service. And now, the noon news.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“大家好，我是能够接纳前辈一切的主播冷泉院桐香。SHK青蓝岛电视台要开始播报午间新闻了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「大家好，我是能夠接納前輩一切的主播冷泉院桐香。SHK青藍島電視台要開始播報午間新聞了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00142",
		linknext = "0062_00144",
		line = 2166,
	},
	["0062_00144"] = {
