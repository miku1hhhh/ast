			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Without a reason?! That’s illogical! What now? What should I say to someone like that? I can’t comprehend such a thing!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“毫无意义的哭泣……！？这种行为没有道理吗？怎么办，我该对这种对象说些什么呢？我完全无法理解……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「毫無意義的哭泣……！？這種行為沒有道理嗎？怎麼辦，我該對這種對象說些什麼呢？我完全無法理解……！」",
					{"rt2"},
				},
			},
		},
