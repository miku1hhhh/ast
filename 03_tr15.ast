		{"text"},
		text = {
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“The dead-eyed girl can’t live outside Seiran Island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“‘没有欲望的少女’无法在青蓝岛以外的地方活下去。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「『沒有慾望的少女』無法在青藍島以外的地方活下去。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00117",
		linknext = "0062_00119",
		line = 1777,
	},
	["0062_00119"] = {
		{"fg", mode=-1, id=30},
		{"facehide"},
		{"text"},
		text = {
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“Her combat and strategy skills would be completely useless in normal society. She would only end up as a girl unable to be satisfied with an average life.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“毕竟战斗和发想作战的能力在普通社会里完全派不上用场，她只是个无法过着普通人生活的小ㄚ头。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「畢竟戰鬥和發想作戰的能力在普通社會裡完全派不上用場，她只是個無法過著普通人生活的小ㄚ頭。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00118",
		linknext = "0062_00120",
		line = 1790,
	},
	["0062_00120"] = {
		{"text"},
		text = {
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“If you really care for her, the right path for you is to lend me a hand and expand this island.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“如果你真的有替她着想，就应该尽力协助我扩展青蓝岛，这才是正道。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「如果你真的有替她著想，就應該盡力協助我擴展青藍島，這才是正道。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00119",
		linknext = "0062_00121",
		line = 1801,
	},
	["0062_00121"] = {
		{"text"},
		text = {
