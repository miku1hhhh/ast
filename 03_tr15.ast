		text = {
			vo = {
				{"vo", file="tohka1194", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Mr. Dick Assman, a famous caster, was arrested without a warrant. The arrestee says he was influenced by the comments on the internet. Well, that was a truly painful incident. Hehe!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“被紧急逮捕的男性，同时也是以造型师闻名的井伊一物造表示‘这都是受到网络留言的影响’。哎呀，还真是惨痛的事件呢，呵呵！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「被緊急逮捕的男性，同時也是以造型師聞名的井伊一物造表示『這都是受到網路留言的影響』。哎呀，還真是慘痛的事件呢，呵呵！」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00146",
		linknext = "0062_00148",
		line = 2240,
	},
	["0062_00148"] = {
		{"bgm", stop=1},
