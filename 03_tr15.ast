			},
			ja = {
				{
					name = {"茅津野アナ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"茅津野アナ", "Pussy Galore"},
					"“Good afternoon. This is Pussy Galore, giving the people what they want. A new announcer has joined us today. Let’s bid her a warm welcome.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"茅津野アナ", "茅津野播报员"},
					"“大家好，我是能够接纳你的一切的主播茅津野，从今天开始会有新人主播加入，就是她。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"茅津野アナ", "茅津野播報員"},
					"「大家好，我是能夠接納你的一切的主播茅津野，從今天開始會有新人主播加入，就是她。」",
					{"rt2"},
				},
			},
		},
