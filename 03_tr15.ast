			},
			[3999] = {
				{"transitiontime", time=300, timestamp=8, delay2=4000},
			},
		},
		text = {
			vo = {
				{"vo", file="rei1136", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Yeah... But I have no money, you know? If I wanna get the tuition exemption, I need to lower the level. Going to the same school as Hinami might be impossible...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯……不过我家很穷……如果要减免学费的话，就得降低程度才行，要和雏见上同一所学校很困难呢……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯……不過我家很窮……如果要減免學費的話，就得降低程度才行，要和雛見上同一所學校很困難呢……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00043",
		linknext = "0062_00045",
		line = 672,
	},
	["0062_00045"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00218", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=15},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“So there’s a recommended category for FS college candidates?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“FS连升学都有推荐名额啊……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「FS連升學都有推薦名額啊……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00044",
		linknext = "0062_00046",
