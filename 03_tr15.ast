				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“I see! The president has almost nothing to do with Hamedori! You think of everything, Jun!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“原来如此，在Hamedori君里面的话，是不是会长就几乎没有影响了！真不愧是淳呢！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「原來如此，在Hamedori君裡面的話，是不是會長就幾乎沒有影響了！真不愧是淳呢！」",
					{"rt2"},
				},
			},
		},
