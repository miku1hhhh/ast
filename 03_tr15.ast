					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「欸，淳，這畢竟關係到將來，你還是先不要考慮會長的事會比較好……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00058",
		linknext = "0062_00060",
		line = 870,
