	["0062_00124"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It’s weird to just decide that you’re not able to do anything at such a young age.",
					{"rt2"},
				},
			},
			cn = {
				{
					"到了这个年纪还认为自己无法办到任何事情，像这样先入为主反而比较奇怪。",
					{"rt2"},
				},
			},
			tw = {
				{
					"到了這個年紀還認為自己無法辦到任何事情，像這樣先入為主反而比較奇怪。",
					{"rt2"},
				},
			},
		},
