		text = {
			vo = {
				{"vo", file="misaki0205", path=":vo/", ch="misaki"},
			},
			ja = {
				{
					name = {"美岬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"美岬", "Misaki"},
					"“Our president sure can rock the work that may be super busy depending on the time, like a cafe! Good thinking, Junnosuke!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"美岬"},
					"“咖啡厅的工作虽然会根据时间带不同而变得非常忙碌，不过，如果是能同时处理多重任务的学生会长就能够胜任……！就是这么回事吧，淳之介！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"美岬"},
					"「咖啡廳的工作雖然會根據時間帶不同而變得非常忙碌，不過，如果是能同時處理多重任務的學生會長就能夠勝任……！就是這麼回事吧，淳之介！」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00161",
		linknext = "0062_00163",
		line = 2581,
	},
	["0062_00163"] = {
