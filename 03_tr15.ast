		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1193", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Early this morning, a human-shaped figurine was found in a female student’s anus, causing its rupture. The student was immediately taken to a hospital.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“本日清晨发生了一件意外，有位女学生将人偶插入肛门导致裂伤，最后紧急住院了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「本日清晨發生了一件意外，有位女學生將人偶插入肛門導致裂傷，最後緊急住院了。」",
					{"rt2"},
				},
			},
