					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Ms. Minase"},
					"“Consider carefully what you want to do in the future and decide which path to take. All right, today’s homeroom is over.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“将来想要做什么……请大家好好思考过后再决定出路。那么，今天的班会就到此结束。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「將來想要做什麼……請大家好好思考過後再決定出路。那麼，今天的班會就到此結束。」",
					{"rt2"},
				},
			},
		},
