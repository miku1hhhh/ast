					{"rt2"},
				},
			},
			en = {
				{
					name = {"水無瀬先生", "Ms. Minase"},
					"“...You may think that it’s a bit quick, but remember that your exams are coming soon.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"水無瀬先生", "水无瀬老师"},
					"“──事情就是这样，大家可能会觉得有点早，不过大考的时间也开始接近了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"水無瀬先生", "水無瀬老師"},
					"「──事情就是這樣，大家可能會覺得有點早，不過大考的時間也開始接近了。」",
					{"rt2"},
				},
			},
		},
		linknext = "0062_00002",
