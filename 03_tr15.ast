		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Also, the caretaker who was in charge will come back in 30 minutes.",
					{"rt2"},
				},
			},
			cn = {
				{
					"而且现在负责的保母也不在，在她回来之前的30分钟是由我们负责。",
