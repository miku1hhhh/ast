		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You’re talking like someone who’s only been interested in sports at school...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你居然说这种像是一直在打棒球的笨蛋才会说的话……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳居然說這種像是一直在打棒球的笨蛋才會說的話……」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00041",
		linknext = "0062_00043",
		line = 639,
	},
	["0062_00043"] = {
		{"fg", file="nanase_01m_00001", file1="nanase_01m_00101", file2="nanase_01m_00219", path=":fg/nanase_01m/", id=4, lv=4, head="nanase_01m", alpha=0, ch_origin="奈々瀬", ch="奈々瀬4", mw="mw", sync=1, a_chr151=1, mode=3, x=-405, y=-5},
		{"fgact", ch="奈々瀬4", id=4, lv=4, act="表示アクション", a1=0, a2=255, time=500, a_chr=151, alpha=255},
		{"fgact", ch="奈々瀬4", id=4, act="移動", x=200, y=0, time=700},
		{"text"},
		text = {
			vo = {
				{"vo", file="nanase0219", path=":vo/", ch="nanase"},
			},
			ja = {
				{
					name = {"奈々瀬"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“But isn’t there an admission category for recommended candidates when you’re a president of the disciplinary committee? I heard they can put you into a nice place.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“不过，如果是FS的风纪委员，不是应该有推荐名额吗？我听说可以进到很好的学校啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「不過，如果是FS的風紀委員，不是應該有推薦名額嗎？我聽說可以進到很好的學校啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00042",
		linknext = "0062_00044",
		line = 654,
	},
	["0062_00044"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00206", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=195, y=-5},
