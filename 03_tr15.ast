				{
					name = {"淳之介", "Junnosuke"},
					"“It sounds like the name of the bank president. In that case—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然我觉得他的名字变得像是银行总裁一样，不过，如果是这份工作的话──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然我覺得他的名字變得像是銀行總裁一樣，不過，如果是這份工作的話──！」",
					{"rt2"},
				},
			},
		},
