					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I know! Touka, just imagine them as your partners in the baby play. If you approach them like that, it should be fine!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“──对了！桐香，你把孩子们当成婴儿游戏的对象吧！只要像这样和他们相处就好了──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「──對了！桐香，妳把孩子們當成嬰兒遊戲的對象吧！只要像這樣和他們相處就好了──！」",
					{"rt2"},
				},
			},
		},
