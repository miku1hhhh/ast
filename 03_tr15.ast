				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Both of us need to study hard... Nanase, you’re going for the advanced one, I suppose?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“我们都不太会念书呢……奈奈濑应该是特别升学班吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「我們都不太會念書呢……奈奈瀨應該是特別升學班吧？」",
					{"rt2"},
				},
			},
		},
