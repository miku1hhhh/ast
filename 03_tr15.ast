				{"fg", file="hitoura_01m_00001", file2="hitoura_01m_00207", path=":fg/hitoura_01m/", id=16, lv=16, head="hitoura_01m", ch_origin="仁浦", ch="仁浦16", mw="mw", sync=0, timestamp=17, delay2=2000, mode=3, x=-5, y=-5},
			},
			[1999] = {
				{"transitiontime", time=300, timestamp=17, delay2=2000},
			},
		},
		text = {
			vo = {
				{"vo", file="hitoura0075", path=":vo/", ch="hitoura"},
			},
			ja = {
				{
					name = {"仁浦"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"仁浦", "Hitoura"},
					"“The theme was brought up so suddenly, it was really a hard thing to do, but I couldn’t refuse when the hero of this island asks for my help. Please accept my—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"仁浦"},
					"“因为要求太过突然，所以准备很费工夫，不过，这毕竟是拯救青蓝岛的英雄的请求，所以也没办法。大家也都欣然接受──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"仁浦"},
					"「因為要求太過突然，所以準備很費工夫，不過，這畢竟是拯救青藍島的英雄的請求，所以也沒辦法。大家也都欣然接受──」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00138",
		linknext = "0062_00140",
		line = 2098,
	},
	["0062_00140"] = {
