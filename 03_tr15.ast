					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香", "桐dori君"},
					"「各位，現在69雲霄飛車要等一小時哦～～♪Goinghameri號可以立刻搭乘，推薦大家去搭哦～～♪」",
					{"rt2"},
