	["0062_00006"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"From the third semester in Minotsuki Academy, classes are divided into a College Prep Course, an Advanced College Prep Course, and a Secret Shagniques Course.",
					{"rt2"},
				},
			},
			cn = {
				{
					"水乃月学园从第三学期开始，就会将班级分成‘升学班’、‘特别升学班’和‘性秘技班’。",
					{"rt2"},
				},
			},
			tw = {
				{
					"水乃月學園從第三學期開始，就會將班級分成『升學班』、『特別升學班』和『性秘技班』。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00005",
		linknext = "0062_00007",
		line = 87,
	},
	["0062_00007"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The College Prep Course is chosen by students who are planning to go to a normal college. The Advanced College Prep Course is for those who plan on going to a high-level college.",
					{"rt2"},
				},
			},
			cn = {
				{
					"‘升学班’是想要升学到普通学校的学生，‘特别升学班’则是想要进入名列前茅的学校的学生。",
					{"rt2"},
				},
			},
			tw = {
				{
					"『升學班』是想要升學到普通學校的學生，『特別升學班』則是想要進入名列前茅的學校的學生。",
					{"rt2"},
				},
			},
		},
