	},
	["0062_00046"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00209", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		delay = {
			[1000] = {
				{"fg", file="ikuko_01m_00001", file1="ikuko_01m_00101", file2="ikuko_01m_00207", path=":fg/ikuko_01m/", id=10, lv=10, head="ikuko_01m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, timestamp=9, delay2=1000, mode=3, x=595, y=-5},
			},
			[999] = {
				{"transitiontime", time=300, timestamp=9, delay2=1000},
			},
		},
		text = {
			vo = {
				{"vo", file="ikuko1240", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Haven’t you heard about that, Darling? The SHO has laid down plenty of thick, sturdy pipe to funnel students into various universities. Dickmouth College is probably the most prestigious.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“你没听说过吗？亲爱的。SHO在许多学校都有足以匹敌大鸡鸡的人脉，有名的地方就像是‘情痴’吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「你沒聽說過嗎？親愛的。SHO在許多學校都有足以匹敵大雞雞的人脈，有名的地方就像是『情癡』吧？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00045",
		linknext = "0062_00047",
		line = 702,
	},
	["0062_00047"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=15},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Is that okay? Won’t you get scolded?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你这么说不会被骂吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳這麼說不會被罵嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00046",
		linknext = "0062_00048",
		line = 714,
	},
	["0062_00048"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00201", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1137", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Of the so-called Jam-it-in-my-V League, there are also Hardervard, Browntown, and Cornhole Pooniversity, and aside from that, private institutions like Moanash and Stanfuck.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“如果是MARNKO的话有‘野外做爱学院’、‘法茎’、‘立娇声’，其他私立学校还有穴命奸或是早女田。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「如果是MARNKO的話有『野外做愛學院』、『法莖』、『立嬌聲』，其他私立學校還有穴命姦或是早女田。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00047",
		linknext = "0062_00049",
		line = 729,
	},
	["0062_00049"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I heard Stanfuck and Hardervard are almost impossible to get into.",
					{"rt2"},
				},
			},
			cn = {
				{
					"法茎的H在哪里……？",
					{"rt2"},
				},
			},
			tw = {
				{
					"法莖的H在哪裡……？",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00048",
		linknext = "0062_00050",
		line = 739,
	},
	["0062_00050"] = {
		{"fg", file="rei_02m_00001", file1="rei_02m_00101", file2="rei_02m_00207", path=":fg/rei_02m/", id=9, lv=9, head="rei_02m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1138", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“As for national and public ones, there are also many strong institutions like Cumbridge and Coxford.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“如果是国公立，九州视奸、穴口大也有复数的推荐名额。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「如果是國公立，九州視姦、穴口大也有複數的推薦名額。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00049",
		linknext = "0062_00051",
		line = 754,
	},
	["0062_00051"] = {
		{"fg", file="rei_01m_00001", file1="rei_01m_00101", file2="rei_01m_00207", path=":fg/rei_01m/", id=9, lv=9, head="rei_01m", ch_origin="礼", ch="礼9", mw="mw", sync=0, mode=3, x=195, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei1139", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Among them, Institut Polybabique de Breast is often chosen by those who aim for managerial positions. If you want to get an important post at the SHO, these work well.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“特别是‘物大生子’，如果想要担任SHO的重要职位，去那间学校似乎会非常有利，所以干部候补生都会升学到那间学校。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「特別是『物大生子』，如果想要擔任SHO的重要職位，去那間學校似乎會非常有利，所以幹部候補生都會升學到那間學校。」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00050",
		linknext = "0062_00052",
		line = 769,
	},
	["0062_00052"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I see. Speaking of which, I feel like Ms. Minase was saying that right after changing schools.",
					{"rt2"},
				},
			},
			cn = {
				{
					"原来如此，在我刚转学过来的时候，我记得水无瀬老师也有说过这种话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"原來如此，在我剛轉學過來的時候，我記得水無瀬老師也有說過這種話。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00051",
		linknext = "0062_00053",
		line = 779,
	},
	["0062_00053"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"A lot of people join the FS exactly because it gives them solid prospects for the future.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正因为能够保障将来，所以FS才会聚集这么多人吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正因為能夠保障將來，所以FS才會聚集這麼多人吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00052",
		linknext = "0062_00054",
		line = 789,
	},
	["0062_00054"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00218", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=15},
		{"text"},
