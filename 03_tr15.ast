			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“She can’t cook at all, but any apron suits her. It shows her good sides—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“虽然她完全不会做料理，但是不管哪种围裙穿起来都很适合。这里能够充分发挥她的优点──”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「雖然她完全不會做料理，但是不管哪種圍裙穿起來都很適合。這裡能夠充分發揮她的優點──」",
					{"rt2"},
