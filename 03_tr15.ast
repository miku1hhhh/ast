		},
		text = {
			vo = {
				{"vo", file="tohka1207", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Why are you crying? What happened? I want to know the reason. Let’s talk. We need to understand each other. Let me hear the reason why you’re crying.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“你为什么要哭呢？为什么？我想知道你为什么要哭。告诉我吧，我们试着互相理解吧？让我听看看吧，你为什么会哭──？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「妳為什麼要哭呢？為什麼？我想知道妳為什麼要哭。告訴我吧，我們試著互相理解吧？讓我聽看看吧，妳為什麼會哭──？」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00193",
		linknext = "0062_00195",
		line = 3111,
	},
