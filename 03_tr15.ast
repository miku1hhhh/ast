		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You have good pronunciation and also look great. Your voice is beautiful and you’re used to speaking in front of people. Perfect, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“桐香的咬字清晰、长相也很出色，声音又好听，而且也很习惯在许多人面前说话。这很适合你吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「桐香的咬字清晰、長相也很出色，聲音又好聽，而且也很習慣在許多人面前說話。這很適合妳吧？」",
					{"rt2"},
				},
			},
		},
