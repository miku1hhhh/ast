		{"fgact", ch="郁子22", id=22, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko1243", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“She seems like she can make it through just with her voice, pronunciation, and showiness. With this, even our misfit, Tokie can—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“感觉光靠声音咬字和气势就能过关了，这么一来，就连不适应社会的小桐香也能工作了──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「感覺光靠聲音咬字和氣勢就能過關了，這麼一來，就連不適應社會的小桐香也能工作了──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0062_00144",
		linknext = "0062_00146",
		line = 2200,
	},
	["0062_00146"] = {
