	["0035_00079"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00202", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=10},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“You don’t know? It’s how they say something’s cool in your hometown.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你没听过吗？就是说你讲长崎腔最棒了的意思喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「妳沒聽過嗎？就是說妳講長崎腔最棒了的意思喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0035_00078",
		linknext = "0035_00080",
		line = 1019,
	},
	["0035_00080"] = {
		{"fg", file="ikuko_02l_00003", file1="ikuko_02l_00106", file2="ikuko_02l_00208", path=":fg/ikuko_02l/", id=10, lv=10, head="ikuko_02l", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko0949", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Cannae say I e’er heard tha’ it... ‘Sides, ye can compliment my accent all ye want, s’nae gonna cheer me up.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“虽然没有听过不过⋯⋯首先，被你这样子夸，狼嘛未欢心喔（人家也不会开心的喔）⋯⋯”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「雖然沒有聽過不過⋯⋯首先，被你這樣子誇，狼嘛未歡心喔（人家也不會開心的喔）⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0035_00079",
		linknext = "0035_00081",
		line = 1034,
	},
	["0035_00081"] = {
