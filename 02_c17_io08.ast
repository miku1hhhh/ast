	["0035_00003"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Easier said than done, however, since the program isn’t finished. That’s been the hardest part.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说是这么说，不过程式还没设计出来。接下来才是最困难的部分。",
