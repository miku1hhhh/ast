	["0035_00004"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’ve found a way to return to my own world, but at the moment it remains nothing more than a dream.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我看到了回到原来世界的可能性──但此刻一切都只不过是我在脑海中的设想而已。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我看到了回到原來世界的可能性──但此刻一切都只不過是我在腦海中的設想而已。",
					{"rt2"},
				},
			},
		},
		linkback = "0035_00003",
		linknext = "0035_00005",
		line = 59,
	},
	["0035_00005"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My whole plan will go up in smoke in an instant if the guy who built the sex sleeve that sent me here turns out not to be the vice president.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个制造让我跨越世界线的飞机杯的职人──若他是副会长的假设不成立，那么一切都土崩瓦解了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那個製造讓我跨越世界線的飛機杯的職人──若他是副會長的假設不成立，那麼一切都土崩瓦解了。",
					{"rt2"},
				},
			},
		},
		linkback = "0035_00004",
		linknext = "0035_00006",
		line = 69,
	},
	["0035_00006"] = {
