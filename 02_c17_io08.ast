					{"rt2"},
				},
			},
			en = {
				{
					"That’s why I need to be prepared to take the next step on my own if that turns out to be the case.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这就是为什么即使发生这种情况，我们也必须做好充分准备，以便我们能够采取下一步行动。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這就是為什麼即使發生這種情況，我們也必須做好充分準備，以便我們能夠採取下一步行動。",
					{"rt2"},
				},
