				},
			},
			cn = {
				{
					"姑且是把乳夹型窃听器的设计图做出来了，剩下的就只剩用3D列印机印出来而已。",
					{"rt2"},
				},
			},
			tw = {
				{
					"姑且是把乳夾型竊聽器的設計圖做出來了，剩下的就只剩用3D列印機印出來而已。",
					{"rt2"},
				},
