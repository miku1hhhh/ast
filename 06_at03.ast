			en = {
				{
					name = {"麻沙音", "Asane"},
					"“A mommy, a mama, a baby, a dog, and Mickey makes a pretty weird family.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“由马麻、妈妈、小孩、狗和小美组成的家庭，会不会太特殊了一点……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「由馬麻、媽媽、小孩、狗和小美組成的家庭，會不會太特殊了一點……？」",
