	["0085_00279"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00218", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“It’s an ordinary aphrodisiac, I think. I heard something about top secret distribution to the SHO and putting it in water coolers, but I don’t really remember. I was busy with training.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“据说是普通的媚药。记得师父好像还说过这东西通过机密管道流通给了SHO之后被混在供水系统里面如何如何的，但是我记得不太清楚了。因为修行实在太辛苦了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「據說是普通的媚藥。記得師父好像還說過這東西通過機密管道流通給了SHO之後被混在供水系統裡面如何如何的，但是我記得不太清楚了。因為修行實在太辛苦了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00278",
		linknext = "0085_00280",
