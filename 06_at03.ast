				{"vo", file="asane0609", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“If you start badmouthing Misaki worse than I do you’re gonna ruin the balance of our relationship.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“要是老哥对待美岬比妹妹还刻薄那力量的均衡就要崩塌了所以快住手。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「要是老哥對待美岬比妹妹還刻薄那力量的均衡就要崩塌了所以快住手。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00197",
		linknext = "0085_00199",
		line = 3137,
	},
	["0085_00199"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00202", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Fumino is a puppy of course. A cute and smart puppy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“而文乃当然是狗狗了。是既可爱又聪明的狗狗。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「而文乃當然是狗狗了。是既可愛又聰明的狗狗。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00198",
		linknext = "0085_00200",
		line = 3149,
	},
	["0085_00200"] = {
