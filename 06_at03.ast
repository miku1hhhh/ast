		text = {
			vo = {
				{"vo", file="hinami0337", path=":vo/", ch="hinami"},
			},
			ja = {
				{
					name = {"ヒナミ"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“Oh, it’s Rei! What’s up, did you come to play? Sorry we didn’t have a proper welcome ready! Come over here! I’ve got the cushions we bought before set up!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“啊，是礼酱！怎么了──，是来玩的吗？啊，不好意思没有什么可以招待的。到这边来到这边来！我把之前和礼酱一起买的坐垫放在这里了喔！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「啊，是禮醬！怎麼了──，是來玩的嗎？啊，不好意思沒有什麼可以招待的。到這邊來到這邊來！我把之前和禮醬一起買的坐墊放在這裡了喔！」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00066",
		linknext = "0085_00068",
		line = 1131,
	},
	["0085_00068"] = {
