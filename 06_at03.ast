			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“So I’ve made up my mind❤ Nanase, Asane! Please go on a date together❤”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“就是这样，我决定好了",
					{"gaiji", text="①"},
					"奈奈濑同学、麻沙音同学，就请两位去约个会吧",
					{"gaiji", text="①"},
					"”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「就是這樣，我決定好了",
					{"gaiji", text="①"},
					"奈奈瀨同學、麻沙音同學，就請兩位去約個會吧",
					{"gaiji", text="①"},
					"」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00105",
		linknext = "0085_00107",
