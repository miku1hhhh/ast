	["0085_00079"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The NLNS has to do something in return for the restoration of our base.",
					{"rt2"},
				},
			},
			cn = {
				{
					"所以作为复活基地的回报，NLNS也打算帮FS办一些事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"所以作為復活基地的回報，NLNS也打算幫FS辦一些事。",
