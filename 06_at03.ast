			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Hiyaaaah... Wait, what am I supposed to make a mess of during the date?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“喔啦啊啊啊啊啊啊……不不这在约会的时候是要我乱丢什么东西啊？”",
