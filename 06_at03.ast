					"“Exactly, you’re a pro-level mess-maker! I guarantee when Nanase sees you like that, she’ll go, ‘Aw, let me clean you up...❤’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					[[“没错，在我们之中你也是乱丢东西的专家！看到那副模样奈奈濑肯定也会变成"真会给人添麻烦，实在拿你没办法……]],
					{"gaiji", text="①"},
					[["那样！”]],
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					[[「沒錯，在我們之中妳也是亂丟東西的專家！看到那副模樣奈奈瀨肯定也會變成"真會給人添麻煩，實在拿妳沒辦法……]],
					{"gaiji", text="①"},
					[["那樣！」]],
					{"rt2"},
				},
			},
		},
		linkback = "0085_00254",
		linknext = "0085_00256",
		line = 3961,
	},
	["0085_00256"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00201", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“At which point you can head straight to a hotel. Make a mess there too, and she’ll look at you and go ‘What would you do without me...❤’ 100%! Now try it!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					[[“就那样往最终目的地宾馆前进然后看着到了那里还是乱七八糟的你肯定就会变成"拿你没办法，真是的……]],
					{"gaiji", text="①"},
					[["那样！来，试试看吧！”]],
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					[[「就那樣往最終目的地賓館前進然後看著到了那裡還是亂七八糟的妳肯定就會變成"拿妳沒辦法，真是的……]],
					{"gaiji", text="①"},
					[["那樣！來，試試看吧！」]],
					{"rt2"},
				},
			},
		},
		linkback = "0085_00255",
		linknext = "0085_00257",
		line = 3973,
	},
