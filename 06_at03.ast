	["0085_00082"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00214", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I thought you’d react like that, that’s why I didn’t say ‘anything.’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“就是猜到你会有那种反应，所以我才没加上‘什么都’这三个字的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「就是猜到妳會有那種反應，所以我才沒加上『什麼都』這三個字的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00081",
		linknext = "0085_00083",
		line = 1407,
	},
	["0085_00083"] = {
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00106", file2="tohka_02m_00225", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="tohka1731", path=":vo/", ch="touka"},
			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Oh my... No matter how it looks, I am an FS delegate, you know? How could I possibly pass on such a weird request?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“怎、怎么会……不管在怎么下流我都是FS的代表喔？怎么可能做做做那种奇怪的要求嘛。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「怎、怎麼會……不管在怎麼下流我都是FS的代表喔？怎麼可能做做做那種奇怪的要求嘛。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00082",
		linknext = "0085_00084",
		line = 1422,
	},
	["0085_00084"] = {
