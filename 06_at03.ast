				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“I’ve been here the whole time. ...So, Asane, you like Nanase?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“一直都在喔。……话说回来麻沙音同学，你喜欢奈奈濑同学是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「一直都在喔。……話說回來麻沙音同學，妳喜歡奈奈瀨同學是嗎？」",
					{"rt2"},
				},
			},
		},
