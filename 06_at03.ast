			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“Oh, I took out all that! The app was so bloated and messy it made me think of Misaki, so I slimmed it down!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“啊，那个我已经整理掉了……！维持原样的话画面简直就像畔同学一样烦躁而且处理速度还所以我就帮它减肥了……！！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊，那個我已經整理掉了……！維持原樣的話畫面簡直就像畔同學一樣煩躁而且處理速度還所以我就幫它減肥了……！！」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00042",
		linknext = "0085_00044",
		line = 749,
	},
	["0085_00044"] = {
