	["0085_00227"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00210", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hah, I just imitated how Rei got around Hinami before. You’re better at playing the mom than I expected.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“哼，我参考了刚才礼前辈根除见撒娇的模样──你扮演的马麻也意外地棒喔。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「哼，我參考了剛才禮前輩根除見撒嬌的模樣──妳扮演的馬麻也意外地棒喔。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00226",
		linknext = "0085_00228",
		line = 3583,
	},
	["0085_00228"] = {
		{"fg", file="asane_01l_00003", file1="asane_01l_00101", file2="asane_01l_00210", path=":fg/asane_01l/", id=3, lv=4, head="asane_01l", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-305},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0623", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I don’t like kids that much, but... Maybe I’d actually be an okay mom?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“虽然我并没有多喜欢小孩就是了……说不定意外地能当个好妈妈呢？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「雖然我並沒有多喜歡小孩就是了……說不定意外地能當個好媽媽呢？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00227",
		linknext = "0085_00229",
		line = 3598,
	},
	["0085_00229"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00207", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=4},
