				},
			},
			en = {
				{
					name = {"ヒナミ", "Hinami"},
					"“You’re the guest Rei, so have a seat right there! Now let me get some tea and snacks! You’ll stay to eat, right?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"ヒナミ", "雏见"},
					"“礼酱是客人，所以就在那边坐着吧！来，这边有茶和饼干～！一起吃吧？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"ヒナミ", "雛見"},
					"「禮醬是客人，所以就在那邊坐著吧！來，這邊有茶和餅乾～！一起吃吧？」",
					{"rt2"},
				},
			},
		},
