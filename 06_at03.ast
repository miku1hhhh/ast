			},
			tw = {
				{
					name = {"麻沙音"},
					"「啊、呃……那方面我可以吃豬肝之類的來補……既然難得有約會的機會，我想……試試看，什麼的……支支吾吾……」",
					{"rt2"},
				},
			},
		},
