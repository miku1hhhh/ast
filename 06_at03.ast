	},
	["0085_00081"] = {
		{"bgm", file="bgm25", vol=100},
		{"fg", file="tohka_02m_00001", file1="tohka_02m_00101", file3="tohka_02m_00306", path=":fg/tohka_02m/", id=8, lv=8, head="tohka_02m", ch_origin="桐香", ch="桐香8", mw="mw", sync=0, mode=3, x=-5, y=-5},
