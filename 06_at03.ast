					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That’s why we need to make this relationship work, whatever it takes!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“为了有那一天，不论如何都要让恋情有结果，对吧……！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「為了有那一天，不論如何都要讓戀情有結果，對吧……！」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00228",
		linknext = "0085_00230",
		line = 3610,
	},
	["0085_00230"] = {
