					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"奈々瀬", "Nanase"},
					"“Hmm... What’s this? This PC looks a little odd... It should have some search bars in the upper right and a clock and dictionary and buttons...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"奈々瀬", "奈奈濑"},
					"“我看看……咦？电脑好像也有点不一样了呢……我记得以前不是右上的搜寻栏有好几行、还大大的时钟啊字典啊之类的按钮吗……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"奈々瀬", "奈奈瀨"},
					"「我看看……咦？電腦好像也有點不一樣了呢……我記得以前不是右上的搜尋欄有好幾行、還大大的時鐘啊字典啊之類的按鈕嗎……」",
					{"rt2"},
				},
			},
		},
