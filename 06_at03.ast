				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“Anything...?!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“什么事都可以吗……！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「什麼事都可以嗎……！？」",
					{"rt2"},
