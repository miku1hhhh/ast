					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“True, Hinami’s motherly powers aren’t to be scoffed at. To distinguish them, I’d say Hinami is a ‘mommy’ and Nanase is a ‘mama.’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“啊啊，雏见的母性也不容小觑──不过如果要大致区分的话，那么雏见就是‘马麻’，而奈奈濑则是‘妈妈’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「啊啊，雛見的母性也不容小覷──不過如果要大致區分的話，那麼雛見就是『馬麻』，而奈奈瀨則是『媽媽』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00194",
		linknext = "0085_00196",
		line = 3095,
	},
	["0085_00196"] = {
		{"fg", file="asane_01m_00003", file1="asane_01m_00101", file2="asane_01m_00216", path=":fg/asane_01m/", id=3, lv=4, head="asane_01m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="asane0608", path=":vo/", ch="asane"},
			},
			ja = {
				{
					name = {"麻沙音"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"麻沙音", "Asane"},
					"“I see... Or maybe not...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"麻沙音"},
					"“感觉好像听得懂又好像听不懂……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"麻沙音"},
					"「感覺好像聽得懂又好像聽不懂……」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00195",
		linknext = "0085_00197",
		line = 3110,
	},
	["0085_00197"] = {
		{"fg", file="jun_01f_00001", file1="jun_01f_00101", file2="jun_01f_00201", file4="jun_01f_00401", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=1},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“And Misaki is a ‘talking chimpanzee named Mickey.’”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“顺带一提美岬是‘听得懂人话的黑猩猩小美’。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「順帶一提美岬是『聽得懂人話的黑猩猩小美』。」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00196",
		linknext = "0085_00198",
		line = 3122,
	},
	["0085_00198"] = {
		{"fg", file="asane_02m_00003", file1="asane_02m_00101", file2="asane_02m_00214", path=":fg/asane_02m/", id=3, lv=4, head="asane_02m", ch_origin="麻沙音", ch="麻沙音3", mw="mw", sync=0, mode=3, x=-5, y=-5},
		{"transitiontime", time=300},
