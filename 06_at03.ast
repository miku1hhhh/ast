		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We wouldn’t be comfortable just accepting free support from them.",
					{"rt2"},
				},
			},
			cn = {
				{
					"单方面受人施舍，我们心里也不舒服。",
