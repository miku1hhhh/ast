	},
	["0085_00080"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I thought that we’d put all our battles behind us and be allies going forward, however...",
					{"rt2"},
				},
			},
			cn = {
				{
					"将敌对的往事付诸东流，今后要携手并进，就是这么一回事──",
