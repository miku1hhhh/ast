	["0085_00108"] = {
		{"fg", file="ikuko_02m_00001", file1="ikuko_02m_00101", file2="ikuko_02m_00214", path=":fg/ikuko_02m/", id=10, lv=10, head="ikuko_02m", ch_origin="郁子", ch="郁子10", mw="mw", sync=0, mode=3, x=495, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="ikuko2032", path=":vo/", ch="ikuko"},
			},
			ja = {
				{
					name = {"郁子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"郁子", "Ikuko"},
					"“Umm, I think the idea is that if Nanase and Asane hook up, Tokie will have fewer rivals, plus she gets the satisfaction of sort of cucking you?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"郁子"},
					"“呃──，就是说只要奈奈濑酱和麻沙音酱凑成对竞争者就减少了很划算，在此之上如果被甩了在NTR方面很爽得很划算，是吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"郁子"},
					"「呃──，就是說只要奈奈瀨醬和麻沙音醬湊成對競爭者就減少了很划算，在此之上如果被甩了在NTR方面很爽得很划算，是嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0085_00107",
		linknext = "0085_00109",
		line = 1839,
	},
	["0085_00109"] = {
