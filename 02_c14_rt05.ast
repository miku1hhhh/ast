	["0024_00204"] = {
		{"bgm", file="bgm21", vol=100},
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00218", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“I didn’t have time to think about that. You show the slightest moment of weakness in a fight, and you’re done.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯我连思考这种事情的时间都没有。因为对方在抓到机会的那一瞬间就把我打到在地了。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯我連思考這種事情的時間都沒有。因為對方在抓到機會的那一瞬間就把我打到在地了。」",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00203",
