					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「先帶著你脱戰的人也是禮前輩喔？那時候其他兩個人還在阻止Tori公喔！」",
					{"rt2"},
				},
			},
		},
