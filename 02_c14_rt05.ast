			cn = {
				{
					"舒伯特是个很关心伙伴的搭挡。这么想的话，他很有可能是顾虑到我的情况才用会故意用这种智障方式在这里等我的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"舒伯特是個很關心夥伴的搭擋。這麼想的話，他很有可能是顧慮到我的情況才用會故意用這種智障方式在這裡等我的。",
