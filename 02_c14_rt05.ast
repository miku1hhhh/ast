			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Did you know? Reluctantly showing someone your panties with a disgusted face arouses them greatly. I’m currently researching how this works.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
