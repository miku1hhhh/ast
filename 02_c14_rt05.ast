				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「顏面騎乘莫名其妙變成了肛門按摩棒顏面騎乘了啦，這明明就是最讓人熱血沸騰的一幕的說⋯⋯」",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00191",
		linknext = "0024_00193",
		line = 2728,
	},
	["0024_00193"] = {
