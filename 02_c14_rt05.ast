		text = {
			vo = {
				{"vo", file="rei0550", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Hmm... Junnosuke? Wait, you’re already walking around?! You should be resting! Are you sure you’re okay to be out of bed? Are you sleepwalking right now?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“嗯唔⋯⋯淳之介？你已经可以走动了吗！？不去睡觉真的没关系吗！？不要勉强自己喔！还是说你是梦游症梦游到我这里来了！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「嗯唔⋯⋯淳之介？你已經可以走動了嗎！？不去睡覺真的沒關係嗎！？不要勉強自己喔！還是說你是夢遊症夢遊到我這裡來了！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00091",
		linknext = "0024_00093",
		line = 1319,
	},
