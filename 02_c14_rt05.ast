					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「一臉嫌惡地讓人看自己的內褲會讓對方興奮對吧？我現在正在做這項修行喔。」",
					{"rt2"},
				},
			},
		},
