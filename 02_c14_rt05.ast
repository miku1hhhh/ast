				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“For the longest time, I wanted to change the island. I wondered if there was anything I could do.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“从很久以前就是了。我想要改变这个岛⋯⋯已经想了很久。我想要为它做些什么。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「從很久以前就是了。我想要改變這個島⋯⋯已經想了很久。我想要為它做些什麼。」",
					{"rt2"},
				},
			},
		},
