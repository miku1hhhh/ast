					name = {"淳之介", "Junnosuke"},
					"“Well, it’s very... freshly cleaned.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不过⋯⋯真这的很有刚被整理过的房间的感觉呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不過⋯⋯真這的很有剛被整理過的房間的感覺呢。」",
