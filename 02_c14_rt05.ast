		line = 3083,
	},
	["0024_00225"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="oldhcg0601017", x=0, y=0, path=":cg/oldhcg06/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0587", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“The world you changed... I really, really like it. It was such a fun place to be.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“被你们所改变的那个世界，真的⋯⋯真的让我觉得很舒服、很愉快。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「被你們所改變的那個世界，真的⋯⋯真的讓我覺得很舒服、很愉快。」",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00224",
		linknext = "0024_00226",
		line = 3099,
	},
	["0024_00226"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0588", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Whether you choose to return to that world, or to fight the rules of this world, I don’t think that’d be wrong.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“所以。为了回到那边的世界⋯⋯背叛了这边世界的伙伴──我并不觉得这么做是错的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「所以。為了回到那邊的世界⋯⋯背叛了這邊世界的夥伴──我並不覺得這麼做是錯的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00225",
		linknext = "0024_00227",
		line = 3111,
	},
	["0024_00227"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei’s expression is clear and filled with conviction.",
					{"rt2"},
				},
			},
			cn = {
				{
					"说着这话的礼前辈的神情十分地澄──我不禁看得入迷了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"說著這話的禮前輩的神情十分地澄──我不禁看得入迷了。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00226",
		linknext = "0024_00228",
		line = 3121,
	},
	["0024_00228"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We started this fight for our own sake. At one point, it was spite towards the island’s customs that fueled us.",
					{"rt2"},
				},
			},
			cn = {
				{
					"原先只是为了自己才展开的、一度想对这座岛进行的复仇念头──",
					{"rt2"},
				},
			},
			tw = {
				{
					"原先只是為了自己才展開的、一度想對這座島進行的復仇念頭──",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00227",
		linknext = "0024_00229",
		line = 3131,
	},
	["0024_00229"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But what we won through our struggle brought about smiles to the people—like the one on Rei’s face right now.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在获得了最终的胜利之时，也有人高兴得露出了这样的神情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在獲得了最終的勝利之時，也有人高興得露出了這樣的神情。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00228",
		linknext = "0024_00230",
		line = 3141,
	},
	["0024_00230"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"We made the choice, not to destroy the law completely, but to coexist. I know that was the right thing to do.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那仿佛像是有人告诉我，当时的选择──并非将条例彻底推翻、而是与之共从──我所选择的方向一点也没错。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那彷彿像是有人告訴我，當時的選擇──並非將條例徹底推翻、而是與之共從──我所選擇的方向一點也沒錯。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00229",
		linknext = "0024_00231",
		line = 3151,
	},
