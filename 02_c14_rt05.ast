				{"vo", file="schubert0150", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Also, the student council president’s uniform was destroyed, but she still oozes charisma. I wanted to harness some of that vibe for myself!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“因为，就连学生会长都穿着大胆曝露的制服来展现魅力值不是吗？我也想要效仿她，多少增加一点魅力。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「因為，就連學生會長都穿著大膽曝露的制服來展現魅力值不是嗎？我也想要效仿她，多少增加一點魅力。」",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00038",
		linknext = "0024_00040",
		line = 508,
	},
	["0024_00040"] = {
