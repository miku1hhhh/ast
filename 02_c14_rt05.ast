	["0024_00133"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00206", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“...I’m sorry about what happened. It sounds like I really made you worry. The others were saying you’ve been all over the place while I was out.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“⋯⋯昨天真的很抱歉。让礼前辈操了那么多的心⋯⋯还让你心烦意乱的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「⋯⋯昨天真的很抱歉。讓禮前輩操了那麼多的心⋯⋯還讓你心煩意亂的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00132",
		linknext = "0024_00134",
		line = 1911,
	},
