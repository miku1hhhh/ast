			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I still don’t think that what we’re doing is wrong, though.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“不过呢。就算这样⋯⋯我也不觉得我自己做错了。”",
