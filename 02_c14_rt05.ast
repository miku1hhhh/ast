	},
	["0024_00153"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Being defeated once, even twice, that’s nothing. Those are rookie numbers.",
					{"rt2"},
				},
			},
			cn = {
				{
					"只是输个1、2次有什么关系。这根本算不了什么。",
					{"rt2"},
				},
			},
			tw = {
				{
					"只是輸個1、2次有什麼關係。這根本算不了什麼。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00152",
		linknext = "0024_00154",
		line = 2195,
	},
	["0024_00154"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Try losing ten times. Try a hundred. If you don’t let it keep you down, the flames of possibility can never be extinguished.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就算百战百败──只要不放弃勇敢面对的气魄，代表可能性的火焰就永远不会消灭。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就算百戰百敗──只要不放棄勇敢面對的氣魄，代表可能性的火焰就永遠不會消滅。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00153",
		linknext = "0024_00155",
		line = 2205,
	},
	["0024_00155"] = {
