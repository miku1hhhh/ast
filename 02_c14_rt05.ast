	["0024_00221"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"When they were my enemies, I assumed they spent their time either moaning or yelling.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在与她敌对的那时，我对她的印象只有她气喘吁吁或怒气初冲的模样──",
					{"rt2"},
				},
			},
			tw = {
				{
					"在與她敵對的那時，我對她的印象只有她氣喘吁吁或怒氣初沖的模樣──",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00220",
		linknext = "0024_00222",
		line = 3047,
	},
	["0024_00222"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Now I realize they’re simply normal people like us, who laugh and cry just the same.",
					{"rt2"},
				},
			},
			cn = {
				{
					"脱离了那种环境，她们也会哭、也会笑──和我们没有两样，只是个普通人。",
					{"rt2"},
				},
			},
			tw = {
				{
					"脫離了那種環境，她們也會哭、也會笑──和我們沒有兩樣，只是個普通人。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00221",
		linknext = "0024_00223",
		line = 3057,
	},
	["0024_00223"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="oldhcg06010115", x=0, y=0, path=":cg/oldhcg06/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
