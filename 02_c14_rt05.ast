			},
		},
		text = {
			vo = {
				{"vo", file="rei0592", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“The weight of the things I was carrying became too much to bear. My hands were tied, and I couldn’t balance everything. Before I knew it, I became the person I had set out to oppose.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“身上背负的担子越来越大、被这个身份死死束缚着⋯⋯权衡了各种事却依旧什么也做不到⋯⋯结果变成了跟以前想要成为的人完全相反的那种人。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「身上背負的擔子越來越大、被這個身份死死束縛著⋯⋯權衡了各種事卻依舊什麼也做不到⋯⋯結果變成了跟以前想要成為的人完全相反的那種人。」",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00234",
		linknext = "0024_00236",
		line = 3229,
	},
	["0024_00236"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Her smile fades—I feel a pang of sadness in my chest.",
					{"rt2"},
				},
			},
			cn = {
				{
					"那个笑容过于虚幻──光是看着就让我觉得胸口发紧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"那個笑容過於虛幻──光是看著就讓我覺得胸口發緊。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00235",
		linknext = "0024_00237",
		line = 3239,
	},
	["0024_00237"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei wanted to fight the status quo of Seiran Island... To do something about the perverted sex law...",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈也觉得应该要对变态条例做些什么──她也试图去抵抗青蓝岛的做法。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩也覺得應該要對變態條例做些什麼──她也試圖去抵抗青藍島的做法。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00236",
		linknext = "0024_00238",
		line = 3249,
	},
	["0024_00238"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And to do that, she went along with the rules for years, enduring so many of the things she despised, to gain power through the FS.",
					{"rt2"},
				},
			},
			cn = {
				{
					"因此她长年迎合着条例、拼命忍受着自己厌恶的行为、为了获得权力而投身FS奋力工作着──",
					{"rt2"},
				},
			},
			tw = {
				{
					"因此她長年迎合著條例、拼命忍受著自己厭惡的行為、為了獲得權力而投身FS奮力工作著──",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00237",
		linknext = "0024_00239",
		line = 3259,
	},
	["0024_00239"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"And the end result? She became president of the disciplinary committee, responsible for forcing sexual acts upon non-procreators.",
					{"rt2"},
				},
			},
			cn = {
				{
					"费尽心力，最终却成为了强迫非性产者进行性行为的风纪委员长──这太残酷了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"費盡心力，最終卻成為了強迫非性產者進行性行為的風紀委員長──這太殘酷了。",
					{"rt2"},
				},
			},
		},
