			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I tried as hard as I could, even though I really wasn’t fit for it. Somehow, I became president. But that wasn’t enough.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“没有才能的话就只能靠努力，我好不容易当上了风纪委员长，但⋯⋯结果我还是不行啊。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「沒有才能的話就只能靠努力，我好不容易當上了風紀委員長，但⋯⋯結果我還是不行啊。」",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00233",
