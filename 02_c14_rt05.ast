	["0024_00192"] = {
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0582", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“Well, Kamen Dickrider had just turbo-evolved into Anal Vibe Facesitter, it was getting so hype...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“颜面骑乘莫名其妙变成了肛门按摩棒颜面骑乘了啦，这明明就是最让人热血沸腾的一幕的说⋯⋯”",
