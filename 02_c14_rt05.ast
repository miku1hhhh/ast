	["0024_00208"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file2="jun_01f_00203", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“What about you, Rei? You haven’t fought her directly, but Hinami’s on the enemy’s side in this fight.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“礼前辈呢？虽然说不是正面对上⋯⋯但雏见也是对方的一员？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「禮前輩呢？雖然說不是正面對上⋯⋯但雛見也是對方的一員？」",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00207",
		linknext = "0024_00209",
		line = 2907,
	},
	["0024_00209"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei’s expression doesn’t change, but she’s clearly thinking about it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"礼前辈的表情没有变化，陷入了短暂的思考中。",
					{"rt2"},
				},
			},
			tw = {
				{
					"禮前輩的表情沒有變化，陷入了短暫的思考中。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00208",
		linknext = "0024_00210",
		line = 2917,
	},
	["0024_00210"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“That’s not all, though, is it? We’re fighting the Anti-Copulation Front, but we’re going against the law ourselves.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不止是这个问题⋯⋯我们在跟反交尾势力对抗的同时──其实我们自己也在违反条例。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不止是這個問題⋯⋯我們在跟反交尾勢力對抗的同時──其實我們自己也在違反條例。」",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00209",
		linknext = "0024_00211",
		line = 2929,
	},
	["0024_00211"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00206", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Isn’t it hard for you, going against everything the FS believes in?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“背叛了那些仰慕你的FS们的信任⋯⋯你不痛苦吗？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「背叛了那些仰慕你的FS們的信任⋯⋯你不痛苦嗎？」",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00210",
		linknext = "0024_00212",
		line = 2941,
	},
	["0024_00212"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I know she’s holding a lot in.",
					{"rt2"},
				},
			},
			cn = {
				{
					"这个人呢，本来就很容易一个人承受一些有的没的的事。",
					{"rt2"},
				},
			},
			tw = {
				{
					"這個人呢，本來就很容易一個人承受一些有的沒的的事。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00211",
		linknext = "0024_00213",
		line = 2951,
	},
	["0024_00213"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Even though we talked before about how important it is to not shoulder everything by ourselves, it’s hard to change a habit deeply ingrained.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然我之前也对他直言了不用什么事都自己一个人扛──不过这种事也不是说变就能变的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然我之前也對他直言了不用什麼事都自己一個人扛──不過這種事也不是說變就能變的。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00212",
		linknext = "0024_00214",
		line = 2961,
	},
	["0024_00214"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Touka and I are treated like gods and distanced from the public, while Ikuko just ambles through everything with ease.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我跟桐香在某种程度上都被神格化了、因而与周遭的人维持着一段距离，郁子的话大概都是任其发展。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我跟桐香在某種程度上都被神格化了、因而與周遭的人維持著一段距離，郁子的話大概都是任其發展。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00213",
		linknext = "0024_00215",
		line = 2971,
	},
	["0024_00215"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei, on the other hand, is admired by her subordinates, and she cares about them too. She’s diligent to a fault.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在这之中──礼前辈则是饱受部下的景仰又很会照顾人。个性认真到了简直是愚蠢的地步。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在這之中──禮前輩則是飽受部下的景仰又很會照顧人。個性認真到了簡直是愚蠢的地步。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00214",
		linknext = "0024_00216",
		line = 2981,
	},
	["0024_00216"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Because she’s in that position, she has to think about these problems all the time. I know it.",
					{"rt2"},
				},
			},
			cn = {
				{
					"正是因为这样的立场，所以想都没有想过自己现在的行为代表着什么吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"正是因為這樣的立場，所以想都沒有想過自己現在的行為代表著什麼吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00215",
		linknext = "0024_00217",
		line = 2991,
	},
	["0024_00217"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"If she ever feels inadequate, she may not be able to go to Hinami for solace, but I’d like to be there for her.",
					{"rt2"},
				},
			},
			cn = {
				{
					"要是她为此而自责──我也许无法像雏见那样温柔包容一切，但作为亲近之人，我想要倾听她的烦恼。",
					{"rt2"},
				},
			},
			tw = {
				{
					"要是她為此而自責──我也許無法像雛見那樣溫柔包容一切，但作為親近之人，我想要傾聽她的煩惱。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00216",
		linknext = "0024_00218",
		line = 3001,
	},
	["0024_00218"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="oldhcg06010114", x=0, y=0, path=":cg/oldhcg06/", lv=18, ev=1, bx=800, by=450},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="rei0585", path=":vo/", ch="rei"},
			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I do care about the FS, you’re right. And sometimes I do feel like I’m not good enough.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“确实、FS对我来说⋯⋯是非常重要的存在。对不起他们什么的，我确实也会这么想。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「確實、FS對我來說⋯⋯是非常重要的存在。對不起他們什麼的，我確實也會這麼想。」",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00217",
		linknext = "0024_00219",
		line = 3017,
	},
	["0024_00219"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I hear people chatting and laughing in the corridor.",
					{"rt2"},
				},
			},
			cn = {
				{
					"我听见了从走廊上传来的欢笑声。",
					{"rt2"},
				},
			},
			tw = {
				{
					"我聽見了從走廊上傳來的歡笑聲。",
