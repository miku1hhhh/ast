	["0024_00197"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But with these kinds of porn parodies of famous works skirting the line, it’s amazing the island isn’t buried under a pile of lawsuits.",
					{"rt2"},
				},
			},
			cn = {
				{
					"不过──做出一堆像这种超变态版本的东西，这座岛到今天都还没有被舆论给压垮还真是不可思议。",
					{"rt2"},
				},
			},
			tw = {
				{
					"不過──做出一堆像這種超變態版本的東西，這座島到今天都還沒有被輿論給壓垮還真是不可思議。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00196",
		linknext = "0024_00198",
		line = 2784,
	},
	["0024_00198"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe they just wanted to pretend the shows didn’t exist instead of drawing attention.",
					{"rt2"},
				},
			},
			cn = {
				{
					"可能是版权方也极度不想跟这些东西扯上关系吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"可能是版權方也極度不想跟這些東西扯上關係吧。",
					{"rt2"},
				},
			},
		},
