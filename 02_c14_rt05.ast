	["0024_00242"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I’m Junnosuke Tachibana, His Sexellency. I use the power invested in me by the perverted sex law to protect Asane... To guarantee the safety of everyone here.",
					{"rt2"},
				},
			},
			cn = {
				{
					"为了保护麻沙音──确保她的安全，在变态条例下成为了‘性帝’的橘淳之介。",
					{"rt2"},
				},
			},
			tw = {
				{
					"為了保護麻沙音──確保她的安全，在變態條例下成為了『性帝』的橘淳之介。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00241",
