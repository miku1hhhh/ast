				{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1, timestamp=57, delay2=9500},
				{"bg", id=18, file="oldhcg06010115", x=0, y=0, path=":cg/oldhcg06/", lv=18, ev=1, timestamp=57, delay2=9500, bx=800, by=450},
