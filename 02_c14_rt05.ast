	["0024_00030"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Obviously, on this island, it’s not an uncommon sight to see a man naked or in his underwear.",
					{"rt2"},
				},
			},
			cn = {
				{
					"住在这个岛上的话，裸男或者只穿内裤的男人都是日常风景的一环没什么好大惊小怪的。这是真的。",
					{"rt2"},
				},
			},
			tw = {
				{
					"住在這個島上的話，裸男或者只穿內褲的男人都是日常風景的一環沒什麼好大驚小怪的。這是真的。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00029",
		linknext = "0024_00031",
		line = 389,
	},
	["0024_00031"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"But a man tinkering with a tablet in the middle of a common space with no pants on is weird, even for Seiran Island.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，在宿舍大厅连裤子都不穿看着平板的男人，就算是在青蓝岛上也能算是个异类。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，在宿舍大廳連褲子都不穿看著平板的男人，就算是在青藍島上也能算是個異類。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00030",
		linknext = "0024_00032",
		line = 399,
	},
	["0024_00032"] = {
