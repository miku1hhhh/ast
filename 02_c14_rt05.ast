		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Maybe if we had been crushing them, I would’ve had room to think about these questions, but my hands were full with just fighting at that point.",
					{"rt2"},
				},
			},
			cn = {
				{
					"如果我们有压倒性的优势的话，也许我还会有这种心情──但那时光是战斗就耗尽我全部的心神了。",
					{"rt2"},
				},
			},
			tw = {
				{
					"如果我們有壓倒性的優勢的話，也許我還會有這種心情──但那時光是戰鬥就耗盡我全部的心神了。",
					{"rt2"},
				},
