	["0024_00124"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00101", file2="jun_01f_00207", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Not really... I was just thinking that your room’s pretty different to mine, despite the floor plan being pretty much the same.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“不，没有⋯⋯我只是觉得虽然格局都一样，不过还是很不同呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「不，沒有⋯⋯我只是覺得雖然格局都一樣，不過還是很不同呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00123",
		linknext = "0024_00125",
		line = 1803,
	},
	["0024_00125"] = {
		{"fg", file="jun_01f_00002", file1="jun_01f_00102", file3="jun_01f_00309", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=9},
