	["0024_00224"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"The laughter fades as they move away, but Rei still seems content.",
					{"rt2"},
				},
			},
			cn = {
				{
					"在笑声逐渐远去时，礼前辈露出了平静的神情。",
					{"rt2"},
				},
			},
			tw = {
				{
					"在笑聲逐漸遠去時，禮前輩露出了平靜的神情。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00223",
