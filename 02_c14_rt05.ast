			cn = {
				{
					"刚出房间的时候我确实心情还很低落──这大概都是多亏了跟舒伯特的对话。",
					{"rt2"},
				},
			},
			tw = {
				{
					"剛出房間的時候我確實心情還很低落──這大概都是多虧了跟舒伯特的對話。",
