				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“I know we lost, but we all survived, so you shouldn’t get all mopey. There’ll be a way forward, provided we don’t give up. You know that better than anyone!”",
					{"rt2"},
				},
			},
