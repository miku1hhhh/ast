			},
			ja = {
				{
					name = {"礼"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"礼", "Rei"},
					"“No! I don’t want you thinking I’m sloppy.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"礼"},
					"“才不要呢⋯⋯这样会被人当成邋遢的女孩子吧。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"礼", "禮"},
					"「才不要呢⋯⋯這樣會被人當成邋遢的女孩子吧。」",
					{"rt2"},
				},
