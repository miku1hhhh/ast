	["0024_00235"] = {
		{"cgdel", id=18, lv=18, time=0, alphadel=1, evmaskoff=1},
		{"bg", id=18, file="oldhcg06010114", x=0, y=0, path=":cg/oldhcg06/", lv=18, ev=1, bx=800, by=450},
