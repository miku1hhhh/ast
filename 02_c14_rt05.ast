				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Rei’s in a totally different position and situation to me, but I... I also had to do things I didn’t want to, in order to protect those close to me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"虽然这与礼前辈的立场与处境不尽相同──这个男人也是，无论有多厌恶，为了重要的家人，不得不做出违背本意的行为。",
					{"rt2"},
				},
			},
			tw = {
				{
					"雖然這與禮前輩的立場與處境不盡相同──這個男人也是，無論有多厭惡，為了重要的家人，不得不做出違背本意的行為。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00242",
		linknext = "0024_00244",
		line = 3311,
	},
