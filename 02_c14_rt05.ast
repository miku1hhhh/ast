	},
	["0024_00129"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"It must be because of her reputation as the demonic president of the disciplinary committee that she’s concerned about this.",
					{"rt2"},
				},
			},
			cn = {
				{
					"就连这个恶魔一样的风纪委员长也会──或是说正是因为身为风纪委员的关系──她才会在意这种事吧。",
					{"rt2"},
				},
			},
			tw = {
				{
					"就連這個惡魔一樣的風紀委員長也會──或是說正是因為身為風紀委員的關係──她才會在意這種事吧。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00128",
		linknext = "0024_00130",
		line = 1869,
	},
	["0024_00130"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"Chatting with her about meaningless shit like this makes me feel like yesterday didn’t happen.",
					{"rt2"},
				},
			},
			cn = {
				{
					"但是，像这样悠哉地聊着天，仿佛昨天的事都是假的一样。",
					{"rt2"},
				},
			},
			tw = {
				{
					"但是，像這樣悠哉地聊著天，彷彿昨天的事都是假的一樣。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00129",
		linknext = "0024_00131",
		line = 1879,
	},
	["0024_00131"] = {
		{"text"},
		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"My wounds twinge—as if to remind me that no, it very much did.",
					{"rt2"},
				},
			},
			cn = {
				{
					"──即便这么想，伤口与痛楚确实存在着。",
					{"rt2"},
				},
			},
			tw = {
				{
					"──即便這麼想，傷口與痛楚確實存在著。",
					{"rt2"},
				},
			},
		},
		linkback = "0024_00130",
		linknext = "0024_00132",
		line = 1889,
	},
	["0024_00132"] = {
