	["0019_00141"] = {
		{"fg", file="tohka_02ll_00001", file1="tohka_02ll_00101", file2="tohka_02ll_00212", path=":fg/tohka_02ll/", id=17, lv=17, head="tohka_02ll", ch_origin="桐香", ch="桐香17", mw="mw", sync=0, mode=3, x=0, y=0},
