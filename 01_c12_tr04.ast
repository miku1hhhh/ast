	["0019_00020"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00211", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=18},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But when she throws up, she’s wasting the nutrients she just took in, so I thought of an effective way to make her take calories.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但如果吐出来，好不容易摄取的营养就没意义了，所以我想了比较有效率的摄取卡路里的方法。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「但如果吐出來，好不容易攝取的營養就沒意義了，所以我想了比較有效率的攝取卡路里的方法。」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00019",
		linknext = "0019_00021",
		line = 298,
	},
