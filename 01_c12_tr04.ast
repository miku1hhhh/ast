	["0019_00063"] = {
		{"se", id=0, loop=0, file="se_a098"},
		{"cgact", file="cgact", id=1, act="浮遊横", loop=5, size=5, time=50, ease="easeinout_sine", lv=1},
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file3="jun_01f_00307", path=":fg/jun_01f/", id=30, ch="淳之介", lv=1, mw="mw", mode=1, sync=0, x=-5, y=-5},
		{"text"},
		text = {
			ja = {
				{
					name = {"淳之介"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Hear me out! The student council president whom you admire so much wouldn’t have been able to even arrive at the academy without her babysitter!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“你们所尊敬的学生会长！没有我这个‘桐香酱照顾员’可是连好好来学校都办不到喔！？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「你們所尊敬的學生會長！沒有我這個『桐香醬照顧員』可是連好好來學校都辦不到喔！？」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00062",
		linknext = "0019_00064",
		line = 943,
	},
	["0019_00064"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00101", file2="susuko_02m_00201", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-605, y=-5},
		{"transitiontime", time=300},
		{"fgact", ch="スス子11", id=11, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="susuko0164", path=":vo/", ch="susuko"},
			},
			ja = {
				{
					name = {"スス子"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"スス子", "Susuko"},
					"“There’s no way the president is such a person!”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"スス子", "丝丝子"},
					"“怎么可能，会长才不是那种人呢。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"スス子", "絲絲子"},
					"「怎麼可能，會長才不是那種人呢。」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00063",
		linknext = "0019_00065",
		line = 959,
	},
	["0019_00065"] = {
		{"fg", file="schubert_01m_00001", file2="schubert_01m_00202", file4="schubert_01m_00401", file5="schubert_01m_00501", path=":fg/schubert_01m/", id=12, lv=12, head="schubert_01m", ch_origin="シューベルト", ch="シューベルト12", mw="mw", sync=0, mode=3, x=595, y=-5},
		{"transitiontime", time=300},
		{"text"},
		text = {
			vo = {
				{"vo", file="schubert0133", path=":vo/", ch="schubert"},
			},
			ja = {
				{
					name = {"シューベルト"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“My data says that it’s impossible. Our president is a perfect human being, Your Sexellency.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“我的数据说明没有这些事。我们的会长是完美的人类所以不可能有那种事，性帝。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「我的數據說明沒有這些事。我們的會長是完美的人類所以不可能有那種事，性帝。」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00064",
		linknext = "0019_00066",
		line = 974,
	},
	["0019_00066"] = {
