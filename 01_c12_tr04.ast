					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"シューベルト", "Schubert"},
					"“Excuse me, President! We got the estimation for the outdoor sales, so if you could check—”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"シューベルト", "舒伯特"},
					"“失礼了学生会长！我们预测了露天摊贩的贩售情况，还请确认──！”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"シューベルト", "舒伯特"},
					"「失禮了學生會長！我們預測了露天攤販的販售情況，還請確認──！」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00043",
		linknext = "0019_00045",
		line = 683,
	},
