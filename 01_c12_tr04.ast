				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“Aren’t you worried about what will happen to our image if we tear their clothes off out in public?”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“在大众面前剥光衣服的印象不是比较差吗……？”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"淳之介"},
					"「在大眾面前剝光衣服的印象不是比較差嗎……？」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00133",
