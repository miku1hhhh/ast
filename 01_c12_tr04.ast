		text = {
			ja = {
				{
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					"I don’t know if this is because of how much they respect her, but of course, they don’t believe me.",
					{"rt2"},
				},
			},
			cn = {
				{
					"是因为尊敬度有差吗，他们竟然完全不信。",
					{"rt2"},
				},
			},
			tw = {
				{
					"是因為尊敬度有差嗎，他們竟然完全不信。",
					{"rt2"},
				},
			},
		},
