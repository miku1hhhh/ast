			},
			ja = {
				{
					name = {"桐香"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"桐香", "Touka"},
					"“In this world, there’s a clear division between men and women. There was something similar in other documents as well too...”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"桐香"},
					"“这边的世界──男女份际好像分得很清楚，其他文件也有类似的内容……”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"桐香"},
					"「這邊的世界──男女份際好像分得很清楚，其他文件也有類似的內容……」",
					{"rt2"},
				},
			},
		},
