				{"vo", file="rin0147", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“We should rip those clothes off them and violate them to make them feel what it means to be a woman. People who pretend to be of the opposite sex are pervs, so we can capture them right there.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“把她剥光然后全裸侵犯她就可以了吧，如果是相反，男穿女装的话就是变态，当场逮捕就好。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「把她剝光然後全裸侵犯她就可以了吧，如果是相反，男穿女裝的話就是變態，當場逮捕就好。」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00130",
