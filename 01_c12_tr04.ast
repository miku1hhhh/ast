				},
			},
			tw = {
				{
					name = {"凛"},
					"「你們在那邊偷偷說些什麼啊？總之明天之前把文件送到SHO總部大樓！辦不到的話活動立刻中止，麻煩了，再見！」",
					{"rt2"},
				},
			},
		},
