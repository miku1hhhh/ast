					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"淳之介", "Junnosuke"},
					"“But... Isn’t that our world? Like, types of uniforms.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"淳之介"},
					"“但是……我们世界不也是这样吗？你想，制服种类之类的。”",
					{"rt2"},
				},
			},
			tw = {
