		{"fgact", ch="凛14", id=14, act="振動下", loop=1, size=12.5, time=150, ease="easeinout_sine"},
		{"text"},
		text = {
			vo = {
				{"vo", file="rin0148", path=":vo/", ch="rin"},
			},
			ja = {
				{
					name = {"凛"},
					"*テキスト*",
					{"rt2"},
				},
			},
			en = {
				{
					name = {"凛", "Rin"},
					"“It would have an adverse effect on our image if such fellas appear right before the USP plan... God will forgive us.”",
					{"rt2"},
				},
			},
			cn = {
				{
					name = {"凛"},
					"“要执行USD计划前，要是出现这种家伙会让整体印象变差的……神也会原谅我们的。”",
					{"rt2"},
				},
			},
			tw = {
				{
					name = {"凛"},
					"「要執行USD計畫前，要是出現這種傢伙會讓整體印象變差的……神也會原諒我們的。」",
					{"rt2"},
				},
			},
		},
		linkback = "0019_00132",
		linknext = "0019_00134",
		line = 2001,
	},
	["0019_00134"] = {
		{"fg", file="jun_01f_00006", file1="jun_01f_00101", file2="jun_01f_00213", path=":fg/jun_01f/", id=30, ch="淳之介", mw="mw", mode=1, sync=0, x=-5, y=-5, lv=17},
		{"text"},
		text = {
