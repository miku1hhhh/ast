	["0019_00062"] = {
		{"fg", file="susuko_02m_00001", file1="susuko_02m_00102", file2="susuko_02m_00211", path=":fg/susuko_02m/", id=11, lv=11, head="susuko_02m", ch_origin="スス子", ch="スス子11", mw="mw", sync=0, mode=3, x=-605, y=-5},
